#!/bin/bash
function lua_chon_NAME() {
  # 1. Thử lấy tên domain theo chuẩn của Root (cắt đường dẫn pwd)
  NAME=$(pwd | cut -f5 -d '/')

  # 2. Xử lý trong lồng Chroot (Khi bị mất đường dẫn gốc)
  if [[ "$NAME" == "" || "$NAME" == "html" || "$NAME" == "bin" ]]; then

    # [LỚP LỌC 1]: Bắt buộc phải có dấu chấm (.) và không được chứa chữ 'lsphp'
    NAME=$(ls /usr/local/lsws/ 2>/dev/null | grep '\.' | grep -v 'lsphp' | head -n 1)

    # [LỚP LỌC 2 - DỰ PHÒNG CỰC MẠNH]: Tìm đích danh cái file Lối tắt (Symlink)
    # Vì thư mục lsphp là thư mục thật, còn domain mình đúc bằng "ln -s" nên nó là Symlink
    if [[ "$NAME" == "" ]]; then
      NAME=$(find /usr/local/lsws/ -maxdepth 1 -type l 2>/dev/null | awk -F'/' '{print $NF}' | head -n 1)
    fi
  fi

  # 3. Chốt hạ
  if [[ "$NAME" == "" ]]; then
    echo -e "Không xác định được domain"
    exit 1
  fi
}
