#!/bin/bash

export LANG=en_US.UTF-8
export LC_ALL=en_US.UTF-8

RED='\033[0;31m'
NC='\033[0m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
box_inner_width=71

# Lấy tên user hiện tại một cách an toàn (Ưu tiên biến $USER, nếu rỗng thì dùng whoami)
current_user="${USER:-$(whoami)}"

# Lấy đường dẫn thư mục hiện hành
current_path=$(pwd)
if [[ "$current_path" == "/" ]]; then
  current_path="/ (Chroot Root)"
fi

# Lời chào theo buổi (Chỉ cần tính 1 lần ở ngoài vòng lặp cho nhẹ máy)
thoi_gian=$(date +'%H' | sed 's/^0//g')
if (($thoi_gian < 10)); then
  thoi_diem='Chúc bạn có buổi sáng tuyệt vời'
elif (($thoi_gian < 14)); then
  thoi_diem='Chúc bạn có buổi trưa tuyệt vời'
elif (($thoi_gian < 18)); then
  thoi_diem='Chúc bạn có buổi chiều tuyệt vời'
else
  thoi_diem='Chúc bạn có buổi tối tuyệt vời'
fi

# --- CÁC HÀM HỖ TRỢ ---
center_text() {
  local text="$1"
  local clean_text=$(echo -e "$text" | sed "s/\x1B\[[0-9;]*[a-zA-Z]//g")
  local text_len=${#clean_text}
  if ((text_len >= box_inner_width)); then
    printf "${RED}|${NC} %s ${RED}|${NC}\n" "$text"
    return
  fi
  local total_padding=$((box_inner_width - text_len))
  local pad_left=$((total_padding / 2))
  local pad_right=$((total_padding - pad_left))
  printf "${RED}|${NC}%*s%s%*s${RED}|${NC}\n" $pad_left "" "$text" $pad_right ""
}

# --- DISPLAY FUNCTION ---
print_dashboard() {
  local current_time=$(date "+%d/%m/%Y %H:%M:%S")

  clear
  echo -e "${RED}+-----------------------------------------------------------------------+${NC}"
  center_text ""
  center_text "WPTANGTOC OLS - USER CONTROL PANEL"
  center_text "Môi trường quản trị bảo mật tuyệt đối (Chroot Jail)"
  center_text ""
  echo -e "${RED}+-----------------------------------------------------------------------+${NC}"

  echo -e "${GREEN}${thoi_diem}!${NC}\n"

  echo "-------------------------------------------------------------------------"
  # Cải tiến: Đưa mã màu ra ngoài %s để không bị lỗi lệch khung hiển thị
  printf " Tài khoản (User)   : ${GREEN}%-25s${NC}\n" "$current_user"
  printf " Thư mục hiện tại   : ${YELLOW}%-25s${NC}\n" "$current_path"
  printf " Quyền hạn hệ thống : ${BLUE}%-25s${NC}\n" "Giới hạn (Limited)"
  printf " Thời gian máy chủ  : %-25s\n" "$current_time"
  echo "-------------------------------------------------------------------------"

  menu_str="[ENTER] Mở Menu Quản Trị  |  [0] Thoát ra dòng lệnh"
  clean_menu=$(echo -e "$menu_str" | sed "s/\x1B\[[0-9;]*[a-zA-Z]//g")
  width=73
  pad=$(((width - ${#clean_menu}) / 2))
  if [ $pad -lt 0 ]; then pad=0; fi
  printf "%${pad}s" ""
  echo -e "${GREEN}${menu_str}${NC}"
  echo '-------------------------------------------------------------------------'
}

# --- VÒNG LẶP CHÍNH (Đồng hồ Live) ---
tput civis
ACTION="menu"

while true; do
  buffer=$(print_dashboard)
  echo -e "$buffer"
  lines=$(echo "$buffer" | wc -l)

  # Chờ người dùng bấm phím (Cập nhật đồng hồ mỗi giây)
  read -t 1 -n 1 -s key_input
  if [ $? -eq 0 ]; then
    if [[ "$key_input" == "0" ]]; then
      ACTION="exit"
    else
      ACTION="menu"
    fi
    break
  fi
  tput cuu "$lines"
done

trap - SIGINT
tput cnorm
echo ""

# --- CHUYỂN HƯỚNG ---
case $ACTION in
"exit")
  echo -e "Đã thoát ra màn hình Terminal."
  echo -e "Nhập lệnh ${GREEN}1${NC} để gọi lại Menu."
  ;;
*)
  if [ -f "/etc/wptt-user/wptangtoc-user" ]; then
    exec /etc/wptt-user/wptangtoc-user
  else
    echo -e "${RED}Lỗi: Không tìm thấy file wptangtoc-user. Vui lòng liên hệ Admin!${NC}"
  fi
  ;;
esac
