#!/bin/bash

# Load bảng màu nếu có (hoặc tự định nghĩa để an toàn)
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
CYAN='\033[0;36m'
NC='\033[0m'

clear
echo ""
echo -e "${CYAN}=========================================================================${NC}"
echo -e "${CYAN}|${NC}                     ${GREEN}CẤU HÌNH CRON JOB (TỰ ĐỘNG HÓA)${NC}                   ${CYAN}|${NC}"
echo -e "${CYAN}=========================================================================${NC}"
echo -e "💡 Mẹo: Truy cập ${YELLOW}https://wptangtoc.com/crontab/${NC} để lấy mã Cron chuẩn."
echo -e "${CYAN}=========================================================================${NC}"
echo ""

echo -e "Xác nhận bạn muốn chỉnh sửa Cron Job?"
prompt="Nhập lựa chọn của bạn [1-2]: "
dongy="n"
options=("Đồng ý" "Không đồng ý")
PS3="$prompt"
select opt in "${options[@]}"; do
  case "$REPLY" in
  1)
    dongy="y"
    break
    ;;
  2)
    dongy="n"
    break
    ;;
  $((${#options[@]} + 1)))
    printf "\n${RED}Bạn nhập sai, hệ thống sẽ tự động chọn Không đồng ý.${NC}\n"
    break
    ;;
  *)
    printf "\n${RED}Bạn nhập sai, hệ thống sẽ tự động chọn Không đồng ý.${NC}\n"
    break
    ;;
  esac
done

if [[ "$dongy" = "y" ]]; then
  editor_cau_hinh="nano"
  echo ""
  echo -e "Công cụ soạn thảo đang sử dụng: ${GREEN}$editor_cau_hinh${NC}"

  if [[ $editor_cau_hinh = "nano" ]]; then
    echo -e "${YELLOW}--- HƯỚNG DẪN LƯU FILE ---${NC}"
    echo -e "1. Chỉnh sửa xong, ấn ${GREEN}Ctrl + O${NC} để lưu."
    echo -e "2. Ấn ${GREEN}Enter${NC} để xác nhận tên file."
    echo -e "3. Ấn ${GREEN}Ctrl + X${NC} để thoát ra ngoài."
    echo -e "${YELLOW}--------------------------${NC}"
    echo "Đang mở trình soạn thảo..."
    sleep 4
  fi

  # [MẤU CHỐT]: Ép tuyệt đối trình soạn thảo Nano cho môi trường hiện tại
  export VISUAL=nano
  export EDITOR=nano

  # Gọi lệnh cron (Nó sẽ ăn theo cái Fake Crontab mình tạo ở file khởi tạo lồng)
  crontab -e
fi

echo ""
echo -e "${GREEN}Đang quay lại Menu chính...${NC}"
sleep 1
exec /etc/wptt-user/wptangtoc-user
