# @website: https://wptangtoc.com
# @email: giatuan@wptangtoc.com
# @since: 2026

if [[ -f /etc/wptt-user/.wptt.conf ]]; then
  . /etc/wptt-user/.wptt.conf
fi

if [[ $ngon_ngu = '' ]]; then ngon_ngu='vi'; fi
if [[ -f /etc/wptt-user/lang/$ngon_ngu.sh ]]; then
  . /etc/wptt-user/lang/$ngon_ngu.sh
fi

version_wptangtoc_ols="Phiên bản Chroot"

# BẢNG MÀU CHUẨN
RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[0;33m'
CYAN='\033[0;36m'
NC='\033[0m'

clear
if [[ $1 = "" ]]; then
  # Căn giữa hoàn hảo (Khung viền đỏ, Text ở giữa xanh/trắng)
  echo -e "${RED}+-----------------------------------------------------------------------+${NC}"
  echo -e "${RED}|${NC}                                                                       ${RED}|${NC}"
  echo -e "${RED}|${NC}                      ${GREEN}WPTANGTOC OLS - USER PANEL${NC}                       ${RED}|${NC}"
  echo -e "${RED}|${NC}                       Phát triển bởi: Gia Tuấn                        ${RED}|${NC}"
  echo -e "${RED}|${NC}                                                                       ${RED}|${NC}"
  echo -e "${RED}+-----------------------------------------------------------------------+${NC}"
  echo ""
else
  echo ""
  echo -e "${GREEN}=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=${NC}"
  echo ""
  echo -e "${CYAN}WPTangToc OLS MENU chính:${NC}"
  echo ""
fi

options=(
  "Quản lý WordPress"      # 1
  "Quản lý Database"       # 2
  "Sao lưu & Khôi phục"    # 3
  "Tải mã nguồn WordPress" # 4
  "Preload Cache"          # 5
  "Quản lý logs"           # 6
  "Quản lý mã nguồn"       # 7
  "Quản lý Cache"          # 8
  "Cấu hình Crontab"       # 9
)

# Thêm màu Vàng (YELLOW) rực rỡ cho dòng nhắc lệnh để khách hàng dễ nhìn
PS3=$'\n'"Nhập lựa chọn của bạn (1-${#options[@]}) [0=Thoát]: "

# Đã dùng exec thì vòng lặp select sẽ bị phá hủy ngay khi chọn
select opt in "${options[@]}"; do
  case $opt in
  "${options[0]}")
    exec /etc/wptt-user/wptt-wordpress-main
    ;;
  "${options[1]}")
    exec /etc/wptt-user/wptt-db-main
    ;;
  "${options[2]}")
    exec /etc/wptt-user/wptt-backup-restore-main
    ;;
  "${options[3]}")
    exec /etc/wptt-user/wptt-install-wordpress2 99
    ;;
  "${options[4]}")
    exec /etc/wptt-user/wptt-preload-cache2 98
    ;;
  "${options[5]}")
    exec /etc/wptt-user/wptt-menu-logs
    ;;
  "${options[6]}")
    exec /etc/wptt-user/wptt-ma-nguon-main
    ;;
  "${options[7]}")
    exec /etc/wptt-user/wptt-cache-main
    ;;

  "${options[8]}")
    exec /etc/wptt-user/cron-cau-hinh
    ;;
  *)
    clear
    if [ -f "/etc/wptt-user/wptt-status" ]; then
      exec /etc/wptt-user/wptt-status
    else
      echo -e "${GREEN}Đã thoát menu WPTangToc OLS an toàn.${NC}"
      exit 0
    fi
    ;;
  esac
done
