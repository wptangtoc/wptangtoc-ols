# ==============================================================================
# 1. KHỞI TẠO BIẾN & MÀU SẮC
# ==============================================================================
. /etc/wptt/echo-color
C_RED='\033[1;31m'
C_GREEN='\033[1;32m'
C_YELLOW='\033[1;33m'
C_CYAN='\033[1;36m'
C_BOLD_WHITE='\033[1;37m'
C_RESET='\033[0m'

stty iutf8
PS3=""

cli_menu_num=$(awk '/^[[:space:]]*[0-9]+\)/ {num=$1} /terminal-cli/ {print num; exit}' /usr/bin/wptangtoc 2>/dev/null | tr -d ')')

# Nếu tìm thấy thì trừ 1 (vì menu hiển thị thường là n+1 so với index array)
# Nếu không tìm thấy thì mặc định là 36
if [[ -n "$cli_menu_num" ]]; then
    cli_menu_num=$((cli_menu_num + 1))
else
    cli_menu_num="36"
fi


