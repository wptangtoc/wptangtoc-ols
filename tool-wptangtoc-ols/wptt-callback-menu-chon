#!/bin/bash

# Khai báo bảng màu phòng trường hợp chưa được nạp
C_RED='\033[1;31m'
C_GREEN='\033[1;32m'
C_YELLOW='\033[1;33m'
C_CYAN='\033[1;36m'
C_RESET='\033[0m'

# --- Vòng lặp Menu Tương tác ---
stty iutf8 # Tương thích với bộ gõ tiếng Việt Telex
fzf_installed=false
if command -v fzf &>/dev/null; then
  fzf_installed=true
fi

# Chuyển PS3 thành PROMPT_TEXT để tự in dòng nhắc lệnh (Đồng bộ với Menu Chính)
if $fzf_installed; then
  PROMPT_TEXT="\n$(tput setab 0)${nhap_lua_chon_cua_ban:-Nhập lựa chọn} (1-${#options[@]}) [00=${chon_nhanh:-Chọn nhanh}] [0=${exit_thoat:-Thoát}]:$(tput sgr0) "
else
  PROMPT_TEXT="\n$(tput setab 0)${nhap_lua_chon_cua_ban:-Nhập lựa chọn} (1-${#options[@]}) [0=${exit_thoat:-Thoát}]:$(tput sgr0) "
fi

# Tắt prompt mặc định của select
PS3=""

# ==============================================================================
# ĐỘNG CƠ NHẬN PHÍM MỚI (BẢO VỆ CPU & CHỐNG RỚT MẠNG ĐỘT NGỘT)
# ==============================================================================
while true; do

  # Mượn select để in danh sách Menu ra màn hình 1 lần duy nhất rồi tắt
  select opt in "${options[@]}"; do break; done </dev/null

  # In dòng chữ mời nhập lựa chọn
  echo -en "$PROMPT_TEXT"

  # Bẫy lỗi EOF (Mất kết nối SSH, rớt mạng)
  if ! read -r REPLY; then
    echo -e "\n${C_RED}⚠️ Đã mất kết nối Terminal (EOF). Tự động thoát Menu để bảo vệ hệ thống...${C_RESET}"
    exit 1
  fi

  case "$REPLY" in
  0) # Thoát/Quay lại menu chính
    echo -e "\nĐang quay lại menu chính..."
    if command -v wptangtoc &>/dev/null; then
      exec /usr/bin/wptangtoc 1
    else
      echo "Lỗi: Lệnh 'wptangtoc' không tìm thấy để quay lại menu chính."
    fi
    break
    ;;

  00) # Gọi FZF (chỉ khi đã cài đặt)
    if $fzf_installed; then
      fzf_height=$((${#options[@]} + 4))
      fzf_prompt="${nhap_lua_chon_cua_ban:-Tìm kiếm lựa chọn} (Mũi tên di chuyển, Enter chọn, ESC hủy): "

      # Cấu trúc bảng FZF
      selected_opt=$(printf '%s\n' "${options[@]}" | nl -w 3 -s ': ' | fzf --prompt="$fzf_prompt" --height="$fzf_height" --border=rounded --color=border:red --cycle --reverse)
      fzf_exit_status=$?
      selected_opt=$(echo "$selected_opt" | sed 's/^[[:space:]]*[0-9]\+\:[[:space:]]*//')

      if [[ $fzf_exit_status -eq 0 ]] && [[ -n "$selected_opt" ]]; then
        selected_index=-1
        for i in "${!options[@]}"; do
          if [[ "$(echo -n "${options[$i]}" | sed 's/[[:space:]]*$//')" == "$(echo -n "$selected_opt" | sed 's/[[:space:]]*$//')" ]]; then
            selected_index=$i
            break
          fi
        done

        if [[ $selected_index -ne -1 ]]; then
          echo -e "\nĐã chọn: ${options[$selected_index]}"
          run_action "$selected_index"
        else
          echo "Lỗi: Không thể khớp lựa chọn FZF '$selected_opt' với danh sách."
        fi
      else
        echo "${vui_long_chon_lai:-Vui lòng chọn lại.}"
      fi
    else
      echo "${lua_chon_khong_hop_le:-Lựa chọn không hợp lệ}: '00'. FZF chưa được cài đặt."
    fi
    REPLY=""
    continue
    ;;

  *) # Xử lý nhập số, lệnh hoặc chuỗi không hợp lệ
    # 1. Kiểm tra nếu nhập đúng số thứ tự
    if [[ "$REPLY" =~ ^[1-9][0-9]*$ ]] && [ "$REPLY" -ge 1 ] && [ "$REPLY" -le ${#options[@]} ]; then
      action_index=$((REPLY - 1))
      echo -e "\nĐã chọn: ${options[$action_index]}"
      run_action "$action_index"
    else
      # 2. Xử lý khi nhập sai (Kiểm tra xem có phải gõ lệnh Linux không)
      if [[ -n "$REPLY" ]]; then
        first_word=$(echo "$REPLY" | awk '{print $1}')
        if command -v "$first_word" >/dev/null 2>&1; then

          # Lấy tự động số thứ tự của Menu Terminal CLI
          found_idx=$(awk '/^[[:space:]]*[0-9]+\)/ {num=$1} /terminal-cli/ {print num; exit}' /usr/bin/wptangtoc | tr -d ')')
          if [[ -n "$found_idx" ]]; then
            cli_menu_num=$((found_idx + 1))
          else
            cli_menu_num="36" # Backup an toàn
          fi

          echo -e "\n${C_YELLOW}Có vẻ bạn đang muốn chạy dòng lệnh Linux CLI: ${C_CYAN}$REPLY${C_RESET}"
          echo -e "Để gõ lệnh, bạn hãy quay lại Menu Chính và chọn ${C_GREEN}[ Mở Terminal / Dòng lệnh CLI - (Menu $cli_menu_num) ]${C_RESET} hoặc ấn Ctrl+C trước nhé!\n"
        else
          # Báo lỗi nhập linh tinh
          echo -e "\n${C_RED}${lua_chon_khong_hop_le:-Lựa chọn không hợp lệ}: '$REPLY'. ${vui_long_chon_lai:-Vui lòng chọn lại.}${C_RESET}"
        fi
      fi
    fi
    REPLY=""
    continue
    ;;
  esac
done
