# [[ -z "$cli_menu_num" ]] && cli_menu_num="36"

# ==============================================================================
# 2. ĐỊNH TUYẾN NGỮ CẢNH (CONTEXT-AWARE ROUTING)
# ==============================================================================
# Phân biệt đang chạy ở Menu Chính hay Menu Con để Route lệnh thoát (Phím 0) cho đúng
if [[ "$0" == *"/wptangtoc" || "$0" == *"wptangtoc" || "$MENU_TITLE" == *"WPTANGTOC OLS"* ]]; then
  TEXT_BACK="Quay về Bảng theo dõi trạng thái"
  ROUTE_BACK="/etc/wptt/wptt-status2"
else
  TEXT_BACK="Quay lại Menu Chính"
  ROUTE_BACK="/usr/bin/wptangtoc"
fi

# ==============================================================================
# 3. BẪY TÍN HIỆU (BẢO VỆ SHELL)
# ==============================================================================
trap '
  stty sane; tput cnorm
  echo -e "\n\nĐã thoát. Nhập lệnh ${C_GREEN}1${C_RESET} hoặc ${C_GREEN}wptangtoc${C_RESET} để quay lại."
  export WPTT_BYPASS=1
  exec bash
' SIGINT SIGTERM SIGQUIT

# ==============================================================================
# 4. CÁC HÀM VẼ GIAO DIỆN (ÉP SÁT LỀ TRÁI THEO YÊU CẦU UX)
# ==============================================================================
MARGIN=""
calc_margin() {
  MARGIN="" # Đã vô hiệu hóa tính năng tự động căn giữa để đảm bảo đồng bộ với các tính năng cũ
}

truncate_text() {
  local text="$1"
  local max_len=$2
  [[ ${#text} -gt $max_len ]] && echo "${text:0:$((max_len-2))}.." || echo "$text"
}

print_item() {
  local num="$1"
  local text="$2"
  [[ -z "$text" ]] && { echo "|"; return; }

  if [[ -z "$num" ]]; then
    local plain=$(truncate_text "▶ $text" 36)
    local colored="${C_YELLOW}▶ ${C_BOLD_WHITE}${plain:2}${C_RESET}"
    echo "$plain|$colored"
  else
    local plain=$(truncate_text "$(printf "[%2s] %s" "$num" "$text")" 36)
    local item_text="${plain:5}"
    local colored="${C_GREEN}[$(printf "%2s" "$num")]${C_RESET} ${C_CYAN}${item_text}${C_RESET}"
    echo "$plain|$colored"
  fi
}

print_row() {
  local l_num="$1"; local l_text="$2"; local r_num="$3"; local r_text="$4"
  local l_data=$(print_item "$l_num" "$l_text")
  local l_plain="${l_data%|*}"; local l_color="${l_data#*|}"
  local pad_l=$(( 37 - ${#l_plain} )); [[ $pad_l -lt 0 ]] && pad_l=0

  local r_plain=""; local r_color=""; local pad_r=37
  if [[ -n "$r_text" ]]; then
    local r_data=$(print_item "$r_num" "$r_text")
    r_plain="${r_data%|*}"; r_color="${r_data#*|}"
    pad_r=$(( 37 - ${#r_plain} )); [[ $pad_r -lt 0 ]] && pad_r=0
  fi
  printf "${MARGIN}${C_CYAN}│${C_RESET} %b%*s  %b%*s ${C_CYAN}│${C_RESET}\n" "$l_color" "$pad_l" "" "$r_color" "$pad_r" ""
}

print_header() {
  local text="${1:-TRUNG TÂM QUẢN TRỊ WPTANGTOC OLS}"
  local inner=78
  local p_left=$(( (inner - ${#text}) / 2 ))
  local p_right=$(( inner - ${#text} - p_left ))
  printf "${MARGIN}${C_CYAN}│${C_RESET}%*s${C_BOLD_WHITE}%s${C_RESET}%*s${C_CYAN}│${C_RESET}\n" "$p_left" "" "$text" "$p_right" ""
}

print_spacer() { printf "${MARGIN}${C_CYAN}│%78s│${C_RESET}\n" ""; }

draw_default_grid() {
  local item_count=1
  for opt in "${options[@]}"; do
    if [[ "$opt" == *"───"* ]]; then
      print_spacer
      local clean_opt=$(echo "$opt" | sed -e 's/───//g' -e 's/\[//g' -e 's/\]//g' | xargs)
      print_row "" "$clean_opt" "" ""
    else
      print_row "$item_count" "$opt" "" ""
      ((item_count++))
    fi
  done
}

# ==============================================================================
# 5. VÒNG LẶP DASHBOARD CHÍNH
# ==============================================================================
total_valid_opts=0
for opt in "${options[@]}"; do [[ "$opt" != *"───"* ]] && ((total_valid_opts++)); done

while true; do
  calc_margin 
  # clear
  
  echo -e "${MARGIN}${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
  print_header "$MENU_TITLE"
  echo -e "${MARGIN}${C_CYAN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
  print_spacer
  
  if declare -f draw_custom_grid > /dev/null; then
    draw_custom_grid
  else
    draw_default_grid
  fi

  print_spacer
  echo -e "${MARGIN}${C_CYAN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
  
  plain_foot=" Nhập số (1-$total_valid_opts) | [00] Tìm kiếm | [0] $TEXT_BACK "
  color_foot=" ${C_YELLOW}Nhập số (1-$total_valid_opts)${C_RESET} | ${C_GREEN}[00] Tìm kiếm${C_RESET} | ${C_RED}[0] $TEXT_BACK${C_RESET} "
  p_l=$(( (78 - ${#plain_foot}) / 2 )); p_r=$(( 78 - ${#plain_foot} - p_l ))
  printf "${MARGIN}${C_CYAN}│${C_RESET}%*s%b%*s${C_CYAN}│${C_RESET}\n" "$p_l" "" "$color_foot" "$p_r" ""
  
  echo -e "${MARGIN}${C_CYAN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
  printf "${MARGIN}${C_CYAN}│${C_RESET}  ${C_GREEN}>>${C_RESET} ${C_BOLD_WHITE}Lựa chọn của bạn: ${C_RESET}%-55s${C_CYAN}│${C_RESET}\n" ""
  echo -e "${MARGIN}${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯${C_RESET}"

  margin_len=${#MARGIN}
  cursor_col=$(( margin_len + 25 ))
  echo -en "\033[2A\033[${cursor_col}G"
  
  read -r choice
  echo -en "\033[2B"

  # ĐIỀU HƯỚNG THEO NGỮ CẢNH (CONTEXT-AWARE)
  if [[ "$choice" == "0" ]]; then
    echo -e "\n${MARGIN}${C_YELLOW}Đang $TEXT_BACK...${C_RESET}"
    exec $ROUTE_BACK
    exit 0
  
  elif [[ "$choice" == "00" ]]; then
    if command -v fzf &>/dev/null; then
      selected=$(
        count=1
        for opt in "${options[@]}"; do
          if [[ "$opt" != *"───"* ]]; then
            printf "%2d. %s\n" "$count" "$opt"
            ((count++))
          fi
        done | fzf --prompt="Tìm kiếm > " --height=40% --border=rounded --color=border:cyan --cycle --reverse
      )
      
      if [[ -n "$selected" ]]; then
        sel_num=$(echo "$selected" | grep -o '^[[:space:]]*[0-9]\+' | tr -d ' ')
        if [[ -n "$sel_num" ]]; then
          m_count=1
          for i in "${!options[@]}"; do
            if [[ "${options[$i]}" != *"───"* ]]; then
              if [[ $m_count -eq $sel_num ]]; then
                echo -e "\n${MARGIN}${C_GREEN}>> Đang khởi chạy: ${options[$i]}${C_RESET}\n"
                run_action "$i"
                break 2 
              fi
              ((m_count++))
            fi
          done
        fi
      fi
    else
      echo -e "\n${MARGIN}${C_RED}[!] Lỗi: FZF chưa được cài đặt.${C_RESET}"; sleep 1.5
    fi
  
  elif [[ "$choice" =~ ^[1-9][0-9]*$ ]] && [ "$choice" -ge 1 ] && [ "$choice" -le "$total_valid_opts" ]; then
    m_count=1
    for i in "${!options[@]}"; do
      if [[ "${options[$i]}" != *"───"* ]]; then
        if [[ $m_count -eq $choice ]]; then
          echo -e "\n${MARGIN}${C_GREEN}>> Đang khởi chạy: ${options[$i]}${C_RESET}\n"
          run_action "$i"
          break 2
        fi
        ((m_count++))
      fi
    done
  
  elif [[ -n "$choice" ]]; then
    f_word="${choice%% *}"
    if command -v "$f_word" >/dev/null 2>&1; then
# ==============================================================================
# BOX CẢNH BÁO: KHI NGƯỜI DÙNG GÕ LỆNH TRỰC TIẾP
# ==============================================================================
echo -e "${C_YELLOW}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
# Dòng 1: Nhận diện hành động
text_nhan_dien="Sếp đang muốn chạy lệnh CLI: $choice"
left_text "${C_YELLOW}${text_nhan_dien}${C_RESET}"
text_huong_dan="Để gõ lệnh CLI, vui lòng vào Menu chính ➜ $cli_menu_num (Terminal) hoặc nhấn Ctrl + C"
left_text "${C_YELLOW}${text_huong_dan}${C_RESET}"

echo -e "${C_YELLOW}╰──────────────────────────────────────────────────────────────────────────────╯${C_RESET}"

# Nút bấm quay lại tinh tế hơn
echo -en "\n${C_GREEN}➜ Nhấn [Enter] để quay lại Menu...${C_RESET}"
read -r dummy

    else
      echo -e "\n${MARGIN}${C_RED}[!] Lựa chọn không hợp lệ. Hãy nhập từ 1 đến $total_valid_opts.${C_RESET}"
    sleep 1.5
    fi
  fi
done
