#!/bin/bash

# ==============================================================================
# Tối ưu hóa I/O File System với Ext4 Fast Commit 
# ==============================================================================
echo "ép xung I/O (Fast Commit)..."

# 1. Lớp bảo vệ 1: Phải là quyền Root
if [ "$EUID" -ne 0 ]; then
    echo "❌ Lỗi: Vui lòng chạy kịch bản này bằng quyền Root!"
    exit 1
fi

# 2. Lớp bảo vệ 2: Kiểm tra phiên bản Kernel (Phải >= 5.10)
KERNEL_MAJOR=$(uname -r | awk -F. '{print $1}')
KERNEL_MINOR=$(uname -r | awk -F. '{print $2}')

if [ "$KERNEL_MAJOR" -lt 5 ] || ( [ "$KERNEL_MAJOR" -eq 5 ] && [ "$KERNEL_MINOR" -lt 10 ] ); then
    echo "⚠️ Bỏ qua: Kernel hiện tại ($(uname -r)) quá cũ. Fast Commit yêu cầu Kernel >= 5.10."
return 2>/dev/null;
exit
fi

# 3. Tự động nội soi tìm phân vùng chứa hệ điều hành (Root /)
# Dùng findmnt để lấy chính xác tên thiết bị vật lý (VD: /dev/sda1, /dev/vda1, /dev/nvme0n1p1)
ROOT_PARTITION=$(findmnt -n -o SOURCE /)
ROOT_FSTYPE=$(findmnt -n -o FSTYPE /)

# 4. Lớp bảo vệ 3: Chỉ chơi với Ext4
if [ "$ROOT_FSTYPE" != "ext4" ]; then
    echo "⚠️ Bỏ qua: Phân vùng gốc ($ROOT_PARTITION) đang dùng định dạng '$ROOT_FSTYPE'. Kỹ thuật này chỉ dành riêng cho Ext4."
    return 2>/dev/null;
exit
fi

# 5. Lớp bảo vệ 4: Kiểm tra xem đã bật trước đó chưa để tránh ghi đè vô ích
if tune2fs -l "$ROOT_PARTITION" 2>/dev/null | grep -q "fast_commit"; then
    echo "✅ Tuyệt vời: Ổ cứng $ROOT_PARTITION đã được trang bị sẵn Fast Commit từ trước!"
	return 2>/dev/null;
exit
fi

# THỰC THI ÉP XUNG
echo "🚀 Đủ điều kiện! Đang mở khóa Fast Commit trên $ROOT_PARTITION..."

# Bật tính năng fast_commit trực tiếp không cần khởi động lại
tune2fs -O fast_commit "$ROOT_PARTITION" >/dev/null 2>&1

# Nghiệm thu lại kết quả sau khi vung đao
if tune2fs -l "$ROOT_PARTITION" 2>/dev/null | grep -q "fast_commit"; then
    echo "🎉 THÀNH CÔNG: Đã kích hoạt Fast Commit! MariaDB và PHP Session sẽ ghi dữ liệu với tốc độ tia chớp."
else
    echo "❌ THẤT BẠI: Không thể kích hoạt. Hệ điều hành hoặc phiên bản e2fsprogs không hỗ trợ."
fi
