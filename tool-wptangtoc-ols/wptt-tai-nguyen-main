function huong_dan() {
  Tính năng Quản lý Tài nguyên trong WPTangToc OLS là một công cụ tích hợp giúp bạn theo dõi việc sử dụng các tài nguyên hệ thống quan trọng trên máy chủ của mình. 📊⚙️

  Giới thiệu ngắn gọn:

  Mục đích: Cung cấp cho người dùng cái nhìn tổng quan về mức độ sử dụng CPU, RAM [bộ nhớ], và có thể cả Disk I/O [hoạt động đọc/ghi của ổ đĩa] và Network I/O [lưu lượng mạng] theo thời gian thực hoặc gần thực. Điều này giúp xác định các điểm nghẽn tiềm ẩn hoặc tình trạng quá tải của máy chủ.

  Lợi ích:
  * Hiểu rõ hiệu suất máy chủ: Nắm bắt được tình trạng sức khỏe của server.
  * Chẩn đoán sự cố: Hỗ trợ tìm ra nguyên nhân gây chậm hoặc treo máy chủ [ví dụ: một tiến trình chiếm quá nhiều CPU/RAM].
  * Tối ưu hóa: Cung cấp thông tin để đưa ra quyết định nâng cấp tài nguyên hoặc tối ưu hóa ứng dụng/website.
  * Sử dụng thuận tiện: Truy cập thông tin tài nguyên dễ dàng ngay trong WPTangToc OLS mà không cần nhiều lệnh phức tạp.
  Tính năng này giúp bạn chủ động hơn trong việc giám sát và đảm bảo máy chủ luôn hoạt động trong điều kiện tốt nhất.
}

if [[ -z "$1" ]]; then
  . /etc/wptt/wptt-header-menu
  header_menu
else
  . /etc/wptt/echo-color 2>/dev/null
  echoDo "=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-="
fi

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null

echo ""
echo "$quan_ly_tai_nguyen:" > /dev/null # Để wptt-search tổng vẫn bắt được danh mục

# ==============================================================================
# 2. KHAI BÁO TIÊU ĐỀ MENU VÀ OPTIONS (ĐÃ QUY HOẠCH LẠI LOGIC UX)
# ==============================================================================
MENU_TITLE="TRUNG TÂM GIÁM SÁT TÀI NGUYÊN (RESOURCES)"

options=(
  # --- CỘT TRÁI: PHẦN CỨNG & HỆ THỐNG ---
  "$kiem_tra CPU"                           #0 (Hiển thị: 1)
  "$kiem_tra RAM"                           #1 (Hiển thị: 2)
  "$kiem_tra $o_cung"                       #2 (Hiển thị: 3)
  "$kiem_tra $cong_nghe_ao_hoa"             #3 (Hiển thị: 4)

  # --- CỘT PHẢI: MẠNG & GIÁM SÁT THỜI GIAN THỰC ---
  "$xem system monitoring(TOP)"             #4 (Hiển thị: 5)
  "$quan_ly_bang_thong"                     #5 (Hiển thị: 6)
  "$kiem_tra $toc_do internet"              #6 (Hiển thị: 7)
  "$kiem_tra $toc_do ping internet" #7 (Hiển thị: 8)
)

# ==============================================================================
# 3. LOGIC XỬ LÝ (ÁNH XẠ CHUẨN 100% VỚI INDEX MỚI)
# ==============================================================================
run_action() {
  local index=$1
  local script_path=""
  local script_args="98" # Mặc định là 98

  case $index in
  # Nhóm Phần cứng
  0) script_path="/etc/wptt/tai-nguyen-server/wptt-kiem-tra-cpu" ;;
  1) script_path="/etc/wptt/tai-nguyen-server/wptt-kiem-tra-ram" ;;
  2) script_path="/etc/wptt/tai-nguyen-server/wptt-kiem-tra-disk" ;;
  3) script_path="/etc/wptt/tai-nguyen-server/wptt-kiem-tra-ao-hoa-vps" ;;
  
  # Nhóm Mạng & Giám sát
  4) script_path="/etc/wptt/tai-nguyen-server/wptt-top" ;;
  5) script_path="/etc/wptt/tai-nguyen-server/wptt-bang-thong-main" ;;
  6) script_path="/etc/wptt/tai-nguyen-server/wptt-kiem-tra-mang-internet" ;;
  7) script_path="/etc/wptt/tai-nguyen-server/wptt-kiem-tra-ping-internet" ;;
  esac

  if [[ -x "$script_path" || -f "$script_path" ]]; then
    exec bash "$script_path" "$script_args"
  else
    echo -e "\n\033[1;31m[!] Lỗi: Không tìm thấy hoặc không thể thực thi script '$script_path'.\033[0m"
    sleep 2
    exec /etc/wptt/wptt-tai-nguyen-main 1
  fi
}

# ==============================================================================
# 4. GIAO DIỆN TÙY CHỈNH (CĂN CHỈNH SỐ THỨ TỰ TUẦN TỰ)
# ==============================================================================
draw_custom_grid() {
  print_row "" "PHẦN CỨNG & HỆ THỐNG" "" "MẠNG & GIÁM SÁT (MONITOR)"
  print_row "1" "${options[0]}" "5" "${options[4]}"
  print_row "2" "${options[1]}" "6" "${options[5]}"
  print_row "3" "${options[2]}" "7" "${options[6]}"
  print_row "4" "${options[3]}" "8" "${options[7]}"
}

# ==============================================================================
# 5. KÍCH HOẠT THƯ VIỆN UI ENGINE CHẠY
# ==============================================================================
. /etc/wptt/wptt-callback-menu-chon
