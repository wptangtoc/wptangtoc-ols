#!/bin/bash

function huong_dan() {
  Tính năng Thay đổi tài khoản đăng nhập File Manager cho phép bạn cập nhật thông tin xác thực [tài khoản, mật khẩu] được sử dụng để truy cập vào công cụ File Manager [Trình quản lý tệp]

  Nói một cách đơn giản, đây là cách bạn đổi mật khẩu hoặc thông tin đăng nhập khác để quản lý file website, nhằm tăng cường bảo mật hoặc khi có sự thay đổi về người quản lý.

  Mục Đích Chính
  * Bảo mật: Cập nhật mật khẩu định kỳ, hoặc khi nghi ngờ thông tin đăng nhập cũ bị lộ.
  * Khi có thay đổi người dùng: Nếu người khác tiếp quản việc quản lý file.
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null

clear
echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}QUẢN LÝ FILE MANAGER ➜ Thay đổi tài khoản / PassWord${C_RESET}"
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

function lua_chon_NAME() {
  unset NAME selects
  selects=()
  local box_inner_width=${box_inner_width:-71}

  for filepath in /etc/wptt/vhost/.*.conf; do
    [[ ! -f "$filepath" || "$filepath" == *"/..conf" ]] && continue
    local domain="${filepath##*/}"
    domain="${domain%.conf}"
    domain="${domain#.}"

    if [[ "$domain" == ?*.?* ]]; then
      # CHỈ HIỂN THỊ DOMAIN ĐÃ CÓ FILE MANAGER
      if [[ -d "/usr/local/lsws/$domain/html/quan-ly-files" ]]; then
        selects+=("$domain")
      fi
    fi
  done

  if [[ ${#selects[@]} -eq 0 ]]; then
    echo -e "${C_YELLOW}⚠️ Hệ thống chưa có website nào được kích hoạt File Manager!${C_RESET}"
    sleep 3
    exec /etc/wptt/wptt-quan-ly-files-main 1
  fi

  mapfile -t selects < <(printf "%s\n" "${selects[@]}" | sort -uV)

  # RENDER KHUNG MENU BO CONG
  echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
  local title_text="Nhập lựa chọn website bạn muốn đổi Pass File Manager:"
  local len=$(echo -n "$title_text" | awk '{print length($0)}')
  local pad_r=$((box_inner_width - len - 2))
  [[ $pad_r -lt 0 ]] && pad_r=0
  echo -e "${C_CYAN}│${C_RESET}  ${C_YELLOW}${title_text}${C_RESET}$(printf '%*s' "$pad_r" "")${C_CYAN}│${C_RESET}"

  local line_len=$((len + 3))
  local pad_line_r=$((box_inner_width - line_len))
  [[ $pad_line_r -lt 0 ]] && pad_line_r=0
  local short_line=$(printf "%${line_len}s" "" | sed 's/ /─/g')
  echo -e "${C_CYAN}├${short_line}$(printf '%*s' "$pad_line_r" "")│${C_RESET}"

  local i=1
  for domain in "${selects[@]}"; do
    local item_text=$(printf "  ${C_CYAN}%3d)${C_RESET} ${C_BOLD_WHITE}%s${C_RESET}" "$i" "$domain")
    local clean_text=$(printf "  %3d) %s" "$i" "$domain")
    local item_len=$(echo -n "$clean_text" | awk '{print length($0)}')
    local pad=$((box_inner_width - item_len))
    [[ $pad -lt 0 ]] && pad=0
    echo -e "${C_CYAN}│${C_RESET}${item_text}$(printf '%*s' "$pad" "")${C_CYAN}│${C_RESET}"
    ((i++))
  done
  echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯${C_RESET}"

  local fzf_installed=false
  if command -v fzf &>/dev/null; then
    fzf_installed=true
    PROMPT_TEXT="Nhập lựa chọn website (1-${#selects[@]}) [00=Tìm nhanh] [0=Thoát]: "
  else
    PROMPT_TEXT="Nhập lựa chọn website (1-${#selects[@]}) [0=Thoát]: "
  fi

  while true; do
    echo -en "${C_CYAN}👉 ${PROMPT_TEXT}${C_RESET}"
    if ! read -r REPLY; then exit 1; fi
    REPLY=$(echo "$REPLY" | tr -d ' ' | tr '[:upper:]' '[:lower:]')

    case "$REPLY" in
    0)
      echo -e "\n${C_GREEN}Đang thoát...${C_RESET}"
      NAME="0"
      return 0
      ;;
    00)
      if $fzf_installed; then
        local selected_name=$(printf '%s\n' "${selects[@]}" | nl -w 3 -s ': ' | fzf --prompt="Tìm website đổi Pass FileManager >> " --height=40% --border=rounded --color=border:red --cycle --reverse)
        selected_name=$(echo "$selected_name" | sed 's/^[[:space:]]*[0-9]\+\:[[:space:]]*//')
        if [[ -n "$selected_name" ]]; then
          NAME="$selected_name"
          return 0
        else
          echo -e "${C_YELLOW}Đã hủy chọn. Vui lòng chọn lại.${C_RESET}"
        fi
      else
        echo -e "${C_RED}Lỗi: FZF chưa được cài đặt.${C_RESET}"
      fi
      ;;
    *)
      if [[ "$REPLY" =~ ^[0-9]+$ ]] && [ "$REPLY" -ge 1 ] && [ "$REPLY" -le ${#selects[@]} ]; then
        local action_index=$((REPLY - 1))
        NAME="${selects[$action_index]}"
        return 0
      else
        echo -e "\n${C_RED}❌ Lựa chọn không hợp lệ! Vui lòng chọn lại.${C_RESET}"
      fi
      ;;
    esac
  done
}

lua_chon_NAME

# --- CHỐT CHẶN THOÁT HIỂM ---
if [[ "$NAME" == "0" || -z "$NAME" ]]; then
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-quan-ly-files-main 1
  return 2>/dev/null || exit
fi

pathcheck="/etc/wptt/vhost/.$NAME.conf"
if [[ ! -f "$pathcheck" ]]; then
  echo -e "\n${C_RED}❌ Tên miền không tồn tại trên hệ thống này!${C_RESET}"
  sleep 3
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-quan-ly-files-main 1
  return 2>/dev/null || exit
fi

if [[ ! -d "/usr/local/lsws/$NAME/html/quan-ly-files" ]]; then
  echo -e "\n${C_YELLOW}⚠️ Website này chưa kích hoạt trình quản lý files!${C_RESET}"
  sleep 2
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-quan-ly-files-main 1
  return 2>/dev/null || exit
fi

if wptt_xac_nhan "Bạn có chắc chắn muốn TẠO MỚI Mật khẩu File Manager?" "${C_BOLD_WHITE}Website:${C_RESET} ${C_YELLOW}$NAME${C_RESET}" "" "Đồng ý (Reset Pass)" "Hủy bỏ"; then
  echo ""
  _runing "Đang thiết lập lại tài khoản và mật khẩu an toàn..."

  # 1. Tải Source Code mới nhất
  cd /usr/local/lsws/$NAME/html || exit 1
  wget -q --timeout=15 --tries=3 https://wptangtoc.com/share/quan-ly-files.zip
  [[ ! -f quan-ly-files.zip ]] && wget -q --timeout=15 --tries=3 https://wptangtoc.com/share/quan-ly-files.zip --no-check-certificate
  [[ ! -f quan-ly-files.zip ]] && wget -q --timeout=15 --tries=3 https://github.com/wptangtoc/wptangtoc-ols/raw/refs/heads/main/quan-ly-files.zip

  if [[ ! -f quan-ly-files.zip ]]; then
    _runloi "Tải FileManager thất bại! Vui lòng thử lại sau."
    exec /etc/wptt/wptt-quan-ly-files-main 1
  fi

  rm -f quan-ly-files.zip

  # 2. Xóa cấu hình cũ trong vhost
  sed -i '/password_dang_nhap_quan_ly_file_cap_2/d' /etc/wptt/vhost/.$NAME.conf
  sed -i '/id_dang_nhap_quan_ly_file_cap_2/d' /etc/wptt/vhost/.$NAME.conf
  sed -i '/id_quan_ly_files/d' /etc/wptt/vhost/.$NAME.conf
  sed -i '/password_quan_ly_file/d' /etc/wptt/vhost/.$NAME.conf

  # 3. Gen Pass Lớp 2 (Ứng dụng)
  password_quan_ly_file=$(openssl rand -base64 32 | tr -dc 'a-zA-Z0-9' | head -c 32)
  user_quan_ly_file=$(openssl rand -base64 32 | tr -dc 'a-zA-Z0-9' | head -c 24)

  mkdir -p /usr/local/lsws/"$NAME"/passwd
  cd /usr/local/lsws/$NAME/html/quan-ly-files || exit
  php ma-hoa-wptangtoc.php "$user_quan_ly_file" "$password_quan_ly_file"
  rm -f ma-hoa-wptangtoc.php

  echo "id_quan_ly_files=$user_quan_ly_file" >>/etc/wptt/vhost/.$NAME.conf
  echo "password_quan_ly_file=$password_quan_ly_file" >>/etc/wptt/vhost/.$NAME.conf

  # 4. Gen Pass Lớp 1 (OLS HTTP Auth)
  [[ "$Server_Edition" == "OLS" ]] && PHP_Command="admin_php" || PHP_Command="admin_php5"

  Webadmin_Pass=$(openssl rand -base64 48 | tr -dc 'a-zA-Z0-9' | head -c 36)
  id_ols_admin=$(openssl rand -base64 32 | tr -dc 'a-zA-Z0-9' | head -c 24)
  Encrypt_string=$(/usr/local/lsws/admin/fcgi-bin/$PHP_Command -q /usr/local/lsws/admin/misc/htpasswd.php "${Webadmin_Pass}")

  echo "$id_ols_admin:$Encrypt_string" >/usr/local/lsws/"$NAME"/passwd/.files

  echo "id_dang_nhap_quan_ly_file_cap_2=$id_ols_admin" >>/etc/wptt/vhost/.$NAME.conf
  echo "password_dang_nhap_quan_ly_file_cap_2=$Webadmin_Pass" >>/etc/wptt/vhost/.$NAME.conf

  # 5. Phân quyền
  . /etc/wptt/vhost/.$NAME.conf

  if $(cat /etc/*release | grep -q "Ubuntu"); then
    tuong_thich_nhom_litespeed="nogroup"
  else
    tuong_thich_nhom_litespeed="nobody"
  fi

  chown nobody:$tuong_thich_nhom_litespeed /usr/local/lsws/"$NAME"/passwd/.files
  chmod 400 /usr/local/lsws/"$NAME"/passwd/.files

  chown -R "$User_name_vhost":"$User_name_vhost" /usr/local/lsws/"$NAME"/html/quan-ly-files
  chmod 400 /usr/local/lsws/"$NAME"/passwd/.password-giatuan.json
  chmod 400 /usr/local/lsws/"$NAME"/passwd/.user-giatuan.json
  chown "$User_name_vhost":"$User_name_vhost" /usr/local/lsws/"$NAME"/passwd/.password-giatuan.json
  chown "$User_name_vhost":"$User_name_vhost" /usr/local/lsws/"$NAME"/passwd/.user-giatuan.json

  /usr/local/lsws/bin/lswsctrl restart >/dev/null 2>&1
  _rundone "Khởi tạo thành công Mật khẩu mới cho $NAME"

  # ==============================================================================
  # BẢNG TÓM TẮT THÔNG TIN TRUY CẬP (UX BO CONG CĂN LỀ TỰ ĐỘNG)
  # ==============================================================================
  unset ssl_xac_thuc_kha_dung
  . /etc/wptt/ssl/check-ssl-cert-con-kha-dung $NAME
  if [[ $ssl_xac_thuc_kha_dung = 'true' ]]; then
    url_truy_cap="https://$NAME/quan-ly-files"
  else
    url_truy_cap="http://$NAME/quan-ly-files"
  fi

  box_inner_width=${box_inner_width:-71}

  echo -e "\n${C_GREEN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_BOLD_WHITE}ĐỔI PASS THÀNH CÔNG! TÀI KHOẢN MỚI CỦA BẠN LÀ:${C_RESET}"
  echo -e "${C_GREEN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"

  function in_dong() {
    local raw_text="$1"
    local colored_text="$2"
    local pad=$((box_inner_width - ${#raw_text}))
    [[ $pad -lt 0 ]] && pad=0
    echo -e "${C_GREEN}│${C_RESET}${colored_text}$(printf '%*s' "$pad" "")${C_GREEN}│${C_RESET}"
  }

  in_dong "  Đường dẫn truy cập : $url_truy_cap" "  ${C_BOLD_WHITE}Đường dẫn truy cập :${C_RESET} ${C_CYAN}$url_truy_cap${C_RESET}"
  echo -e "${C_GREEN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
  in_dong "  LỚP 1: XÁC THỰC MÁY CHỦ (HTTP Basic Auth)" "  ${C_BOLD_WHITE}LỚP 1: XÁC THỰC MÁY CHỦ (HTTP Basic Auth)${C_RESET}"
  in_dong "  User đăng nhập     : $id_ols_admin" "  User đăng nhập     : ${C_YELLOW}$id_ols_admin${C_RESET}"
  in_dong "  Password           : $Webadmin_Pass" "  Password           : ${C_YELLOW}$Webadmin_Pass${C_RESET}"
  echo -e "${C_GREEN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
  in_dong "  LỚP 2: ĐĂNG NHẬP ỨNG DỤNG FILE MANAGER" "  ${C_BOLD_WHITE}LỚP 2: ĐĂNG NHẬP ỨNG DỤNG FILE MANAGER${C_RESET}"
  in_dong "  User File Manager  : $user_quan_ly_file" "  User File Manager  : ${C_YELLOW}$user_quan_ly_file${C_RESET}"
  in_dong "  Password           : $password_quan_ly_file" "  Password           : ${C_YELLOW}$password_quan_ly_file${C_RESET}"
  echo -e "${C_GREEN}╰───────────────────────────────────────────────────────────────────────╯${C_RESET}\n"

  echo -e "${C_CYAN}Ghi chú:${C_RESET} Tài khoản mới đã được lưu vào hệ thống WPTangToc OLS."
  echo "Thay doi Pass filemanager website $NAME : $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log

else
  echo -e "${C_YELLOW}Đã hủy thao tác đổi Pass.${C_RESET}"
  sleep 1
fi

echo -en "\n${C_GREEN}Nhấn phím [Enter] để quay lại Menu...${C_RESET}"
read -r
[[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-quan-ly-files-main 1
