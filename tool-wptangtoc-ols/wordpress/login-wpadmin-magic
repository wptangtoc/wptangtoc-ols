#!/bin/bash
# @author: Gia Tuấn
# @website: https://wptangtoc.com
# @since: 2026

function huong_dan() {
  Tính năng này đăng nhập nhanh vào tài khoản dashboard WP-admin không cần biết tài khoản admin WordPress.
}

. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null

echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}Quản lý WordPress ➜ Đăng nhập Login WP-Admin Magic Link${C_RESET}"
echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯${C_RESET}\n"

NAME=$1

if [[ $NAME = "98" ]]; then
  NAME=""
fi

if [[ "$NAME" = "" ]]; then
  . /etc/wptt/tenmien-only-website-by-wordpress 2>/dev/null
  lua_chon_NAME "Magic Link đăng nhập WP-Admin"
fi

if [[ "$NAME" = "0" || "$NAME" = "" ]]; then
  exec /etc/wptt/wptt-wordpress-main 1
fi

[[ ! -f "/etc/wptt/vhost/.$NAME.conf" ]] && echoDo "Domain không tồn tại trên hệ thống." && exec /etc/wptt/wptt-wordpress-main 1


unset lock_down
. /etc/wptt/vhost/.$NAME.conf
if [[ -n "$lock_down" ]]; then
	echo "Vui lòng tắt tính năng lockdown bảo mật cho website $NAME thì mới đuợc phép dùng tính năng này"
	check_menu_wptangtoc_active=$1
if [[ $check_menu_wptangtoc_active = "98" ]]; then
  echo -en "${C_GREEN}Nhấn phím [Enter] để quay lại Menu quản lý WordPress...${C_RESET}"
  read -r
  exec /etc/wptt/wptt-wordpress-main 1
fi
exit;
fi


. /etc/wptt/php/php-cli-domain-config $NAME

# ==============================================================================
# KIỂM TRA TƯƠNG THÍCH PHP 8.4+
# ==============================================================================
if [[ "$phien_ban_php_domain_thuc_thi" == "84" || "$phien_ban_php_domain_thuc_thi" == "85" ]]; then
  phien_ban_php_co_cham="${phien_ban_php_domain_thuc_thi:0:1}.${phien_ban_php_domain_thuc_thi:1:1}"
  echo -e "\n${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_RED}CẢNH BÁO TƯƠNG THÍCH PHP${C_RESET}"
  echo -e "${C_CYAN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
  center_text "Website $NAME đang chạy PHP ${phien_ban_php_co_cham}."
  center_text "Công cụ wp-cli-login-command hiện tại chưa hỗ trợ tốt PHP 8.4+."
  center_text "Nếu link Magic báo lỗi 'Expired', vui lòng hạ PHP xuống 8.2 hoặc 8.3."
  echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯${C_RESET}\n"

  check_menu_wptangtoc_active=$1
  if [[ $check_menu_wptangtoc_active = "98" ]]; then
    echo -en "${C_GREEN}Nhấn phím [Enter] để quay lại Menu quản lý WordPress...${C_RESET}"
    read -r
    exec /etc/wptt/wptt-wordpress-main 1
  fi
  return 2>/dev/null || exit
fi

pathcheckwp="/usr/local/lsws/$NAME/html/wp-load.php"
if [[ ! -f "$pathcheckwp" ]]; then
  clear
  echoDo "Hệ thống xác nhận bạn không sử dụng WordPress"
  echoDo "Tính năng này chỉ có thể hoạt động trên WordPress"
  sleep 3
  exec /etc/wptt/wptt-wordpress-main 1
  exit
fi

echo "Login magic link WordPress website $NAME: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log

# Kiểm tra và cài đặt Package bằng lệnh WP-CLI
if ! /usr/local/bin/wp package list --allow-root 2>/dev/null | grep -qi 'wp-cli-login-command'; then
  _runing "Cài đặt WP CLI package wp-cli-login-command"
  /usr/local/bin/wp package install aaemnnosttv/wp-cli-login-command --allow-root >/dev/null 2>&1
  unset config_download_package_login_link && config_download_package_login_link='yes'
fi

if [[ $config_download_package_login_link = 'yes' ]]; then
  if /usr/local/bin/wp package list --allow-root 2>/dev/null | grep -qi 'wp-cli-login-command'; then
    _rundone "Cài đặt WP CLI package wp-cli-login-command"
  else
    _runloi "Cài đặt WP CLI package wp-cli-login-command"
    echo "Chưa cài đặt được WP CLI package wp-cli-login-command"
    echo "Nên không thể sử dụng được tính năng này"
    sleep 3
    [[ ${1:-} == "98" ]] && exec /etc/wptt/wptt-wordpress-main 1
    exit
  fi
fi

path="/usr/local/lsws/$NAME/html"
pathlogin="/usr/local/lsws/$NAME/html/wp-content/plugins/wp-cli-login-server"

. /etc/wptt/vhost/.$NAME.conf
. /etc/wptt/php/php-cli-domain-config $NAME

WP_EXEC="sudo -u $User_name_vhost /usr/local/lsws/lsphp${phien_ban_php_domain_thuc_thi}/bin/php /usr/local/bin/wp"
WP_ROOT="/usr/local/lsws/lsphp${phien_ban_php_domain_thuc_thi}/bin/php /usr/local/bin/wp"

if [[ ! -d "$pathlogin" ]]; then
  _runing "Download plugin WP CLI login"
  $WP_ROOT login install --activate --path="$path" --allow-root >/dev/null 2>&1
  chown -Rh $User_name_vhost:$User_name_vhost $path/wp-content/plugins/wp-cli-login-server
  _rundone "Download plugin WP CLI login"
fi

# ==============================================================================
# TUYỆT KỸ MU-PLUGIN: SÁT THỦ LỌC SẠCH DATABASE + PHẦN CỨNG RỖNG
# ==============================================================================
MU_DIR="${path}/wp-content/mu-plugins"
mkdir -p "$MU_DIR"
MU_FILE="${MU_DIR}/wptt-magic-destruct.php"

cat << 'EOF' > "$MU_FILE"
<?php
/**
 * Plugin Name: WPTangToc Magic Link Destruct Pro
 * Description: Tự động dọn dẹp hệ thống, Database và thư mục mu-plugins sau khi đăng nhập thành công.
 */
add_action('admin_init', 'wptt_magic_link_cleanup_pro');
function wptt_magic_link_cleanup_pro() {
    if (defined('DOING_AJAX') && DOING_AJAX) return;
    
    // Chỉ kích hoạt khi một tài khoản đã xác thực login thành công vào admin dashboard
    if (!function_exists('is_user_logged_in') || !is_user_logged_in()) return;
    if (!current_user_can('manage_options')) return;

    require_once ABSPATH . 'wp-admin/includes/plugin.php';
    require_once ABSPATH . 'wp-admin/includes/file.php';
    
    // 1. Tắt plugin an toàn theo chuẩn WordPress
    $plugin_slug = 'wp-cli-login-server/wp-cli-login-server.php';
    if (is_plugin_active($plugin_slug)) {
        deactivate_plugins($plugin_slug, true);
    }
    
    // 2. Xóa sạch toàn bộ thư mục plugin tạm
    $plugin_dir = WP_PLUGIN_DIR . '/wp-cli-login-server';
    if (file_exists($plugin_dir)) {
        WP_Filesystem();
        global $wp_filesystem;
        if (is_object($wp_filesystem)) {
            $wp_filesystem->delete($plugin_dir, true);
        } else {
            array_map('unlink', glob("$plugin_dir/*.*"));
            @rmdir($plugin_dir);
        }
    }
    
    // 3. THỰC THI CẢI TIẾN: DỌN SẠCH RÁC DATABASE (An toàn tuyệt đối, tự nhận diện Prefix bảng)
    delete_option('wp_cli_login');
    update_option('recently_activated', array());
    
    // 4. Tự sát: Xóa file mu-plugin này
    $current_file = __FILE__;
    $mu_dir = dirname($current_file);
    @unlink($current_file);
    
    // 5. THỰC THI CẢI TIẾN: Kiểm tra nếu thư mục mu-plugins rỗng thì xóa luôn cả thư mục
    if (file_exists($mu_dir) && is_dir($mu_dir)) {
        $remaining_files = array_diff(scandir($mu_dir), array('.', '..'));
        if (empty($remaining_files)) {
            @rmdir($mu_dir);
        }
    }
}
EOF

# Trả lại quyền sở hữu chuẩn xác cho user vhost
chown -R $User_name_vhost:$User_name_vhost "$MU_DIR"

clear
_runing "Đang tạo mã Magic Link mã hóa"
tuan=$($WP_ROOT user list --role=administrator --field=user_login --path="$path" --allow-root 2>/dev/null | head -n 1)
if [[ -z $tuan ]]; then
  _runloi "Lấy tài khoản Administrator"
  echo -e "\n${C_RED}❌ Lỗi: Không xác định được tài khoản administrator của website $NAME${C_RESET}"
  sleep 3
  [[ ${1:-} == "98" ]] && exec /etc/wptt/wptt-wordpress-main 1
  return 2>/dev/null || exit
fi

# Tẩy sạch ký tự \r \n và khoảng trắng thừa để lấy URL thuần túy
giatuandzdz=$($WP_ROOT login create "$tuan" --path="$path" --allow-root 2>/dev/null | grep -o 'http.*' | tr -d '\r\n ')

if [[ -n "$giatuandzdz" ]]; then
  _rundone "Tạo mã Magic Link thành công "

  echo -e "\n${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_YELLOW}MAGIC LINK LOGIN WP-ADMIN${C_RESET}"
  echo -e "${C_CYAN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
  center_text "${C_GREEN}Tài khoản truy cập: ${C_BOLD_WHITE}$tuan${C_RESET}"
  center_text ""
  center_text "Hãy bôi đen và COPY đường dẫn bên dưới dán vào trình duyệt:"
  center_text "${C_CYAN}$giatuandzdz${C_RESET}"
  center_text ""
  center_text "${C_YELLOW}[!] Lưu ý: Link này chỉ sử dụng 1 lần duy nhất trong vòng 15 phút!${C_RESET}"
  echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯${C_RESET}\n"

else
  _runloi "Tạo link đăng nhập"
  echo -e "\n${C_RED}Lỗi: Không thể thiết lập được magic link login.${C_RESET}"
fi

check_menu_wptangtoc_active=$1
if [[ $check_menu_wptangtoc_active = "98" ]]; then
  echo -en "${C_GREEN}Nhấn phím [Enter] để quay lại Menu quản lý WordPress...${C_RESET}"
  read -r
  exec /etc/wptt/wptt-wordpress-main 1
fi
