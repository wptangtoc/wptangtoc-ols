#!/bin/bash

function huong_dan() {
  Tính năng xóa transient WordPress đề cập đến việc loại bỏ các dữ liệu tạm thời [transients] mà WordPress và các plugin/theme lưu trữ trong cơ sở dữ liệu để tăng tốc độ tải trang hoặc lưu kết quả của các tác vụ tốn thời gian.

  Transient WordPress là gì?
  Transients là một cơ chế lưu trữ đệm [caching] đơn giản. WordPress sử dụng chúng để lưu trữ thông tin [ví dụ: kết quả từ một API bên ngoài, một truy vấn cơ sở dữ liệu phức tạp, HTML của một widget] trong một khoảng thời gian nhất định. Khi hết hạn, transient đó sẽ tự động bị xóa [hoặc được tạo lại khi cần]. Điều này giúp giảm tải cho server và cải thiện hiệu suất website vì không phải thực hiện lại các tác vụ nặng nề mỗi khi có yêu cầu.

  Tại sao cần xóa [tính năng/lợi ích của việc xóa]:

  Khắc phục sự cố [Troubleshooting]:
  * Đôi khi, transients có thể lưu trữ dữ liệu bị hỏng hoặc đã lỗi thời, gây ra lỗi hiển thị hoặc các vấn đề chức năng trên website. Xóa transients buộc WordPress phải tạo lại dữ liệu mới, thường sẽ giải quyết được các vấn đề này.

  Cập nhật Dữ liệu Ngay Lập tức:
  * Trong quá trình phát triển hoặc khi bạn vừa thay đổi một cài đặt quan trọng mà dữ liệu của nó được lưu trong transient, việc xóa transient sẽ giúp thay đổi có hiệu lực ngay lập tức thay vì phải chờ nó tự hết hạn.

  Giải phóng Dung lượng Cơ sở dữ liệu [Ít phổ biến hơn]:
  * Mặc dù transients được thiết kế để tự hết hạn, đôi khi có những transient mồ côi [không tự xóa] hoặc quá nhiều transient được tạo ra có thể làm tăng nhẹ dung lượng bảng wp_options trong cơ sở dữ liệu. Xóa chúng có thể giúp dọn dẹp.

  Sau khi Di chuyển Website hoặc Cập nhật Lớn:
  * Đôi khi, sau khi di chuyển website sang một server mới hoặc sau một bản cập nhật lớn [WordPress core, theme, plugin], việc xóa transients là một bước tốt để đảm bảo mọi thứ hoạt động với dữ liệu mới nhất.

  Tính năng xóa transient trong WordPress là một công cụ hữu ích để khắc phục sự cố, đảm bảo dữ liệu luôn mới và đôi khi để dọn dẹp cơ sở dữ liệu. Nó giúp website hoạt động trơn tru hơn bằng cách buộc làm mới các dữ liệu được lưu trữ tạm thời.
}

# Nạp file cấu hình chính từ /etc/wptt/.wptt.conf
. /etc/wptt/.wptt.conf

# Kiểm tra biến $ngon_ngu, nếu rỗng thì đặt giá trị mặc định là 'vi'
[[ $ngon_ngu == '' ]] && ngon_ngu='vi'

# Nạp file ngôn ngữ tương ứng từ thư mục /etc/wptt/lang/
. /etc/wptt/lang/$ngon_ngu.sh

# Nạp script echo-color để sử dụng các màu sắc trong output
. /etc/wptt/echo-color

# Đặt tên tính năng hiện tại là "xoa transient database"
tinh_nang_ten="$xoa transient database"

# In tiêu đề với đường viền màu xanh dương và văn bản giữa dòng
echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_BOLD_WHITE}$quan_ly_wordpress ➜ $tinh_nang_ten${C_RESET}"
echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯${C_RESET}\n"

# Lấy tên website từ tham số đầu vào
NAME=$1

# Nếu NAME là '98', gán rỗng cho NAME
[[ $NAME == "98" ]] && NAME=""

# Nếu NAME chưa được thiết lập, thực hiện lựa chọn tên miền từ tất cả các website WordPress
if [[ -z "$NAME" ]]; then
  . /etc/wptt/tenmien-them-lua-chon-tat-ca-website-by-wordpress
  lua_chon_NAME "$tinh_nang_ten"
fi

# Nạp core-functions chứa các hàm hỗ trợ chung
. /etc/wptt/core-functions

# Nếu tham số đầu vào là '98', thiết lập biến môi trường và chuyển hướng về menu chính
if [[ "$1" == '98' ]]; then
  WPTT_IN_MENU="yes"
  WPTT_MENU_BACK="/etc/wptt/wptt-db-main 1"
fi

# Kiểm tra trạng thái của MariaDB, nếu không hoạt động thì hiển thị thông báo lỗi và thoát
wptt_check_mariadb || wptt_die "MariaDB đang bị sập! Hệ thống từ chối không cho phép tối ưu database."

# Nếu NAME là 'Tất cả website', thực hiện vòng lặp qua tất cả các file cấu hình domain
if [[ "$NAME" == 'Tất cả website' ]]; then
  for filepath in /etc/wptt/vhost/.*.conf; do
    # Bỏ qua nếu không phải file hoặc tên chứa "/..conf"
    [[ ! -f "$filepath" || "$filepath" == *"/..conf" ]] && continue

    # Lấy tên miền từ đường dẫn file cấu hình
    domain="${filepath##*/}"
    domain="${domain%%.conf}"
    domain="${domain#.}"

    # Kiểm tra nếu tên miền có định dạng hợp lệ (chứa ít nhất 1 dấu chấm)
    if [[ "$domain" == ?*.?* ]]; then
      path="/usr/local/lsws/$domain/html/wp-config.php"

      # Nếu file wp-config.php tồn tại, thực hiện xoá transient cho website này
      if [[ -f "$path" ]]; then
        _runing "Xoá transient cho website $domain"
        # Gọi chính script này xử lý ngầm trong background
        (/etc/wptt/wordpress/transient "$domain" >/dev/null 2>&1)
        _rundone "Xoá transient cho website $domain"
      fi
    fi
  done

  # Nếu tham số đầu vào là '98', chuyển hướng về menu chính của WordPress
  [[ ${1:-} == "98" ]] && exec /etc/wptt/wptt-wordpress-main 1
  exit
fi

# Nếu NAME bằng '0' hoặc chưa được thiết lập, chuyển hướng về menu chính của WordPress
[[ "$NAME" == "0" || -z "$NAME" ]] && exec /etc/wptt/wptt-wordpress-main 1

# Định nghĩa đường dẫn đến file cấu hình domain
path_conf="/etc/wptt/vhost/.$NAME.conf"

# Kiểm tra nếu file cấu hình không tồn tại, hiển thị thông báo lỗi và chuyển hướng về menu chính của WordPress sau 2 giây
[[ ! -f "$path_conf" ]] && {
  echoDo "Domain không tồn tại trên hệ thống."
  sleep 2
  exec /etc/wptt/wptt-wordpress-main 1
}

# Định nghĩa đường dẫn đến thư mục gốc của website
path="/usr/local/lsws/$NAME/html"

# Kiểm tra nếu file wp-load.php không tồn tại, hiển thị thông báo lỗi và chuyển hướng về menu chính của WordPress sau 2 giây
[[ ! -f "$path/wp-load.php" ]] && {
  echoDo "Hệ thống xác nhận bạn không sử dụng WordPress"
  echoDo "Tính năng này chỉ có thể hoạt động trên WordPress"
  sleep 2
  exec /etc/wptt/wptt-wordpress-main 1
}

# Nạp file cấu hình domain và thiết lập môi trường PHP cho domain hiện tại
. "$path_conf"
. /etc/wptt/php/php-cli-domain-config $NAME

# Khai báo WP_EXEC với quyền người dùng cụ thể để thực thi các lệnh wp-cli
WP_EXEC="sudo -u $User_name_vhost /usr/local/lsws/lsphp${phien_ban_php_domain_thuc_thi}/bin/php /usr/local/bin/wp"

# Bắt đầu quá trình xoá transient cho website hiện tại
_runing "Xoá transient cho website $NAME"

# Thực thi lệnh wp-cli để xoá tất cả các transient trong WordPress
$WP_EXEC transient delete --all --path="$path" --allow-root >/dev/null 2>&1

# Kết thúc quá trình xoá transient và hiển thị thông báo hoàn thành
_rundone "Xoá transient cho website $NAME"

# Nếu tham số đầu vào là '98', chuyển hướng về menu chính của WordPress
[[ ${1:-} == "98" ]] && exec /etc/wptt/wptt-wordpress-main 1
