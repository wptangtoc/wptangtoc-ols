#!/bin/bash

function huong_dan() {
  tính năng rewrite trong WordPress, hay còn gọi là WordPress Rewrite API và thường được biết đến qua Permalinks [Đường dẫn tĩnh], là một hệ thống mạnh mẽ cho phép WordPress chuyển đổi các URL [địa chỉ web] mặc định khó hiểu thành các URL thân thiện, dễ đọc và tốt cho SEO.

  Giải thích ngắn gọn:

  Thay vì một URL dạng:
  * http://example.com/?p=123 [khó nhớ, không thân thiện với SEO]
  WordPress có thể rewrite [viết lại] nó thành dạng:
  * http://example.com/ten-bai-viet-cua-ban/ [dễ đọc, dễ nhớ, tốt cho SEO]
  hoặc
  * http://example.com/chuyen-muc/ten-bai-viet/

  Tính năng rewrite của WordPress là một công cụ thiết yếu giúp website của bạn có các đường dẫn URL đẹp mắt, dễ hiểu, thân thiện với người dùng và đặc biệt quan trọng cho việc tối ưu hóa công cụ tìm kiếm [SEO].
}

. /etc/wptt/.wptt.conf
[[ $ngon_ngu == '' ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh

echo -e "\n========================================================================="
echo -e "|$quan_ly_wordpress => Rewrite permalink                                 |"
echo -e "=========================================================================\n"

. /etc/wptt/echo-color
NAME=$1
[[ $NAME == "98" ]] && NAME=""

if [[ -z "$NAME" ]]; then
  . /etc/wptt/tenmien-them-lua-chon-tat-ca-website-by-wordpress
  echo -e "\n$nhap_lua_chon_website_cua_ban rewrite permalink: \n"
  lua_chon_NAME
fi

if [[ "$NAME" == 'Tất cả website' ]]; then
  for filepath in /etc/wptt/vhost/.*.conf; do
    [[ ! -f "$filepath" || "$filepath" == *"/..conf" ]] && continue

    domain="${filepath##*/}"
    domain="${domain%.conf}"
    domain="${domain#.}"

    if [[ "$domain" == ?*.?* ]]; then
      path="/usr/local/lsws/$domain/html/wp-config.php"
      if [[ -f "$path" ]]; then
        UI_STRING="Rewrite permalink cho website $domain"
        _runing "$UI_STRING"
        (/etc/wptt/wordpress/rewrite "$domain" >/dev/null 2>&1)
        _rundone "$UI_STRING"
      fi
    fi
  done

  [[ ${1:-} == "98" ]] && exec /etc/wptt/wptt-wordpress-main 1
  exit
fi

# --- KHỐI XỬ LÝ 1 WEBSITE CỤ THỂ ---
[[ "$NAME" == "0" || -z "$NAME" ]] && exec /etc/wptt/wptt-wordpress-main 1

path_conf="/etc/wptt/vhost/.$NAME.conf"
[[ ! -f "$path_conf" ]] && {
  echoDo "Tên miền không tồn tại trên hệ thống này"
  sleep 2
  exec /etc/wptt/wptt-wordpress-main 1
}

path="/usr/local/lsws/$NAME/html"

[[ ! -f "$path/wp-load.php" ]] && {
  echoDo "Hệ thống xác nhận bạn không sử dụng WordPress"
  echoDo "Tính năng này chỉ có thể hoạt động trên WordPress"
  sleep 2
  exec /etc/wptt/wptt-wordpress-main 1
}

# --- THỰC THI REWRITE ---
. "$path_conf"
. /etc/wptt/php/php-cli-domain-config $NAME

WP_EXEC="sudo -u $User_name_vhost /usr/local/lsws/lsphp${phien_ban_php_domain_thuc_thi}/bin/php /usr/local/bin/wp"

UI_STRING="Rewrite permalink cho website $NAME"
_runing "$UI_STRING"

$WP_EXEC rewrite flush --path="$path" --allow-root >/dev/null 2>&1

# Dùng reload để nạp lại cấu hình mượt mà không làm sập tiến trình
/usr/local/lsws/bin/lswsctrl reload >/dev/null 2>&1

_rundone "$UI_STRING"

[[ ${1:-} == "98" ]] && exec /etc/wptt/wptt-wordpress-main 1
