function huong_dan() {
  Tính năng này thiết lập một lớp bảo mật thứ 2 [HTTP Basic Auth] khi truy cập vào wp-admin hoặc wp-login.php.

  Tính năng Kích hoạt bảo mật 2 lớp đăng nhập WordPress [Two-Factor Authentication - 2FA] là việc thiết lập một lớp bảo vệ bổ sung cho quá trình đăng nhập vào trang quản trị WordPress, yêu cầu người dùng phải qua một lớp xác thực của máy chủ trước khi vào tới màn hình đăng nhập của WordPress.

  Mục Đích Chính [Cực Kỳ Quan Trọng]:
  * Tăng cường bảo mật mạnh mẽ: Ngay cả khi hacker có mật khẩu WordPress của bạn, họ cũng không thể truy cập nếu không qua được lớp khiên này.
  * Chống tấn công Brute-Force [dò mật khẩu]: Chặn đứng mọi bot quét tự động ngay từ tầng Server [OpenLiteSpeed], giúp tiết kiệm tài nguyên CPU tuyệt đối.
  * Bảo vệ tài khoản quản trị [Admin]: Một rào chắn vững chắc cho các website đặc biệt quan trọng.

  Bạn có thể dễ dàng Bật/Tắt tính năng này tùy theo nhu cầu vận hành thực tế.
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null # Nạp thư viện UI Xác nhận

clear
echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}BẢO MẬT ➜ Bật / Tắt Bảo mật wp-admin 2 lớp (2FA)${C_RESET}"
echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

# ==============================================================================
# HÀM MENU LỌC THÔNG MINH (CHỈ HIỂN THỊ DOMAIN WP + CÓ TRẠNG THÁI)
# ==============================================================================
function lua_chon_NAME() {
  unset NAME selects
  selects=()
  local box_inner_width=${box_inner_width:-71}

  # Quét vòng lặp siêu tốc
  for filepath in /etc/wptt/vhost/.*.conf; do
    [[ ! -f "$filepath" || "$filepath" == *"/..conf" ]] && continue

    local domain="${filepath##*/}"
    domain="${domain%.conf}"
    domain="${domain#.}"

    # Chỉ quét các domain có định dạng chuẩn và có nhân WordPress
    if [[ "$domain" == ?*.?* && -f "/usr/local/lsws/$domain/html/wp-load.php" ]]; then
      local check_mk="/usr/local/lsws/$domain/passwd/.mk"

      if [[ -f "$check_mk" ]]; then
        selects+=("$domain|[Đang BẬT]")
      else
        selects+=("$domain|[Đang TẮT]")
      fi
    fi
  done

  if [[ ${#selects[@]} -eq 0 ]]; then
    echo -e "${C_YELLOW}⚠️ Hệ thống chưa có Website WordPress nào để cấu hình 2FA!${C_RESET}"
    sleep 3
    exec /etc/wptt/wptt-bao-mat-main 1
  fi

  # Sắp xếp mảng chuẩn Version
  mapfile -t selects < <(printf "%s\n" "${selects[@]}" | sort -uV)

  # Cải tiến UX: Thêm tùy chọn "Tất Cả" ở cuối nếu có >= 2 website WP
  if [[ ${#selects[@]} -ge 2 ]]; then
    selects+=("TẤT CẢ WEBSITE (Thao tác đồng loạt)|[Hàng Loạt]")
  fi

  # RENDER KHUNG MENU BO CONG (TÁCH STATUS ĐỂ TÔ MÀU)
  echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
  local title_text="Lựa chọn website WP bạn muốn cấu hình 2FA:"
  local len=$(echo -n "$title_text" | awk '{print length($0)}')
  local pad_r=$((box_inner_width - len - 2))
  [[ $pad_r -lt 0 ]] && pad_r=0
  echo -e "${C_CYAN}│${C_RESET}  ${C_YELLOW}${title_text}${C_RESET}$(printf '%*s' "$pad_r" "")${C_CYAN}│${C_RESET}"

  local line_len=$((len + 3))
  local pad_line_r=$((box_inner_width - line_len))
  [[ $pad_line_r -lt 0 ]] && pad_line_r=0
  local short_line=$(printf "%${line_len}s" "" | sed 's/ /─/g')
  echo -e "${C_CYAN}├${short_line}$(printf '%*s' "$pad_line_r" "")│${C_RESET}"

  local i=1
  for item in "${selects[@]}"; do
    local dom=$(echo "$item" | cut -d'|' -f1)
    local stt=$(echo "$item" | cut -d'|' -f2)

    local color_dom="${C_BOLD_WHITE}"
    local color_stt="${C_YELLOW}"

    if [[ "$stt" == "[Đang BẬT]" ]]; then color_stt="${C_GREEN}"; fi
    if [[ "$stt" == "[Đang TẮT]" ]]; then color_stt="${C_RED}"; fi
    if [[ "$dom" == "TẤT CẢ WEBSITE (Thao tác đồng loạt)" ]]; then
      color_dom="${C_YELLOW}"
      color_stt="${C_CYAN}"
    fi

    local item_text=$(printf "  ${C_CYAN}%3d)${C_RESET} ${color_dom}%-40s${C_RESET} %s" "$i" "$dom" "${color_stt}${stt}${C_RESET}")
    local clean_text=$(printf "  %3d) %-40s %s" "$i" "$dom" "$stt")

    local item_len=$(echo -n "$clean_text" | awk '{print length($0)}')
    local pad=$((box_inner_width - item_len))
    [[ $pad -lt 0 ]] && pad=0
    echo -e "${C_CYAN}│${C_RESET}${item_text}$(printf '%*s' "$pad" "")${C_CYAN}│${C_RESET}"
    ((i++))
  done
  echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯${C_RESET}"

  local fzf_installed=false
  if command -v fzf &>/dev/null; then
    fzf_installed=true
    PROMPT_TEXT="Nhập lựa chọn (1-${#selects[@]}) [00=Tìm nhanh] [0=Thoát]: "
  else
    PROMPT_TEXT="Nhập lựa chọn (1-${#selects[@]}) [0=Thoát]: "
  fi

  while true; do
    echo -en "${C_CYAN}${PROMPT_TEXT}${C_RESET}"
    if ! read -r REPLY; then exit 1; fi
    REPLY=$(echo "$REPLY" | tr -d ' ' | tr '[:upper:]' '[:lower:]')

    case "$REPLY" in
    0)
      echo -e "\n${C_GREEN}Đang thoát...${C_RESET}"
      NAME="0"
      return 0
      ;;
    00)
      if $fzf_installed; then
        local selected_item=$(printf '%s\n' "${selects[@]}" | nl -w 3 -s ': ' | fzf --prompt="Tìm website >> " --height=40% --border=rounded --color=border:red --cycle --reverse)
        local dom=$(echo "$selected_item" | sed 's/^[[:space:]]*[0-9]\+\:[[:space:]]*//' | cut -d'|' -f1)
        if [[ -n "$dom" ]]; then
          NAME="$dom"
          return 0
        else echo -e "${C_YELLOW}Đã hủy chọn. Vui lòng chọn lại.${C_RESET}"; fi
      else
        echo -e "${C_RED}Lỗi: FZF chưa cài đặt.${C_RESET}"
      fi
      ;;
    *)
      if [[ "$REPLY" =~ ^[0-9]+$ ]] && [ "$REPLY" -ge 1 ] && [ "$REPLY" -le ${#selects[@]} ]; then
        local action_index=$((REPLY - 1))
        NAME=$(echo "${selects[$action_index]}" | cut -d'|' -f1)
        return 0
      else
        echo -e "\n${C_RED}❌ Lựa chọn không hợp lệ! Vui lòng chọn lại.${C_RESET}"
      fi
      ;;
    esac
  done
}

# Nếu gọi script kèm tên domain từ command line
if [[ -n "$1" && "$1" != "98" ]]; then
  NAME="$1"
else
  lua_chon_NAME
fi

# Tách lấy tên chuẩn (Cắt bỏ râu ria nếu có)
NAME=$(echo "$NAME" | cut -d'|' -f1 | xargs)

# --- CHỐT CHẶN THOÁT HIỂM ---
[[ "$NAME" == "0" || -z "$NAME" ]] && exec /etc/wptt/wptt-bao-mat-main 1

# ==============================================================================
# HÀM KIỂM TRA PHỤ THUỘC (Lấy PHP_Command & Group Litespeed)
# ==============================================================================
if [[ -f "/usr/local/lsws/admin/fcgi-bin/admin_php" ]]; then
  PHP_Command="/usr/local/lsws/admin/fcgi-bin/admin_php"
else
  PHP_Command="/usr/local/lsws/admin/fcgi-bin/admin_php5"
fi

if grep -qi "ubuntu" /etc/os-release 2>/dev/null; then
  tuong_thich_nhom_litespeed="nogroup"
else
  tuong_thich_nhom_litespeed="nobody"
fi

# Mảng toàn cục lưu trữ thông tin tài khoản nếu cấu hình thành công
CREDENTIALS_LIST=()

# ==============================================================================
# HÀM THỰC THI BẬT/TẮT BẢO MẬT 2 LỚP CHO 1 DOMAIN
# ==============================================================================
function process_2fa() {
  local target_domain=$1
  local action=$2 # "bat" hoac "tat"
  local mk_path="/usr/local/lsws/$target_domain/passwd/.mk"
  local vhost_conf="/usr/local/lsws/conf/vhosts/$target_domain/$target_domain.conf"
  local wptt_vhost="/etc/wptt/vhost/.$target_domain.conf"

  if [[ "$action" == "bat" ]]; then
    [[ -f "$mk_path" ]] && return # Đã bật rồi thì bỏ qua

    UI_STRING="Kích hoạt Bảo mật 2 lớp cho $target_domain"
    _runing "$UI_STRING"

    # 1. Tạo thư mục và sinh mật khẩu
    mkdir -p "/usr/local/lsws/$target_domain/passwd"
    local Webadmin_Pass=$(openssl rand -base64 48 | tr -dc 'a-zA-Z0-9' | head -c 36)
    local id_ols_admin=$(openssl rand -base64 32 | tr -dc 'a-zA-Z0-9' | head -c 24)
    local Encrypt_string=$($PHP_Command -q /usr/local/lsws/admin/misc/htpasswd.php "${Webadmin_Pass}")

    echo "$id_ols_admin:$Encrypt_string" >"$mk_path"
    chown nobody:$tuong_thich_nhom_litespeed "$mk_path"
    chmod 400 "$mk_path"

    # 2. Xóa cấu hình cũ (nếu sót) và Tiêm cấu hình Vhost mới bằng EOF
    sed -i "/^realm ${target_domain}wp/,/^}/d" "$vhost_conf" 2>/dev/null
    sed -i "/^context exp:wp-login\.php/,/^}/d" "$vhost_conf" 2>/dev/null

    cat <<EOF >>"$vhost_conf"

realm ${target_domain}wp {
  userDB  {
    location              /usr/local/lsws/${target_domain}/passwd/.mk
  }
}

context exp:wp-login.php {
  location                \$DOC_ROOT/\$0
  allowBrowse             1
  realm                   ${target_domain}wp

  accessControl  {
    allow                 ALL
  }
  addDefaultCharset       off
}
EOF

    # 3. Lưu mật khẩu vào config của WPTangToc
    sed -i "/id_dang_nhap_wordpress_2/d" "$wptt_vhost" 2>/dev/null
    sed -i "/password_dang_nhap_wordpress_2/d" "$wptt_vhost" 2>/dev/null
    echo "id_dang_nhap_wordpress_2=$id_ols_admin" >>"$wptt_vhost"
    echo "password_dang_nhap_wordpress_2=$Webadmin_Pass" >>"$wptt_vhost"

    # 4. Ghi log và tích lũy thông tin vào mảng
    echo "Bật bảo mật 2 lớp WordPress cho website $target_domain: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log
    CREDENTIALS_LIST+=("$target_domain|$id_ols_admin|$Webadmin_Pass")

    _rundone "$UI_STRING"

  elif [[ "$action" == "tat" ]]; then
    [[ ! -f "$mk_path" ]] && return # Chưa bật thì bỏ qua

    UI_STRING="Tắt (Hủy) Bảo mật 2 lớp cho $target_domain"
    _runing "$UI_STRING"

    # 1. Xóa cấu hình Vhost bằng SED an toàn
    sed -i "/^realm ${target_domain}wp/,/^}/d" "$vhost_conf" 2>/dev/null
    sed -i "/^context exp:wp-login\.php/,/^}/d" "$vhost_conf" 2>/dev/null

    # 2. Xóa file passwd và thông tin trong config
    rm -rf "/usr/local/lsws/$target_domain/passwd/.mk"
    sed -i "/id_dang_nhap_wordpress_2/d" "$wptt_vhost" 2>/dev/null
    sed -i "/password_dang_nhap_wordpress_2/d" "$wptt_vhost" 2>/dev/null

    echo "Tắt bảo mật 2 lớp WordPress cho website $target_domain: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log
    _rundone "$UI_STRING"
  fi
}

# ==============================================================================
# XỬ LÝ LÔGIC RẼ NHÁNH BẬT / TẮT (CÓ UX XÁC NHẬN)
# ==============================================================================
echo ""
thao_tac_thanh_cong=false
msg_action=""

if [[ "$NAME" == "TẤT CẢ WEBSITE (Thao tác đồng loạt)" || "$NAME" == "TẤT" ]]; then
  echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_YELLOW}Cấu hình HÀNG LOẠT Bảo mật 2 lớp (2FA) cho toàn bộ hệ thống${C_RESET}"
  echo -e "${C_CYAN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
  echo -e "${C_CYAN}│${C_RESET}  ${C_CYAN}1)${C_RESET} BẬT đồng loạt cho tất cả                                         ${C_CYAN}│${C_RESET}"
  echo -e "${C_CYAN}│${C_RESET}  ${C_CYAN}2)${C_RESET} TẮT đồng loạt cho tất cả                                         ${C_CYAN}│${C_RESET}"
  echo -e "${C_CYAN}│${C_RESET}  ${C_CYAN}3)${C_RESET} Hủy bỏ thao tác                                                  ${C_CYAN}│${C_RESET}"
  echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯${C_RESET}"

  mass_action=""
  while true; do
    echo -en "${C_CYAN}Nhập lựa chọn của bạn [1-3]: ${C_RESET}"
    read -r REPLY
    case "$REPLY" in
    1)
      mass_action="bat"
      msg_action="BẬT Hàng Loạt"
      break
      ;;
    2)
      mass_action="tat"
      msg_action="TẮT Hàng Loạt"
      break
      ;;
    3)
      echo -e "${C_YELLOW}Đã hủy thao tác.${C_RESET}"
      sleep 1
      exec /etc/wptt/wptt-bao-mat-main 1
      ;;
    *) echo -e "${C_RED}❌ Nhập sai, vui lòng nhập từ 1 đến 3.${C_RESET}" ;;
    esac
  done

  echo ""
  for filepath in /etc/wptt/vhost/.*.conf; do
    [[ ! -f "$filepath" || "$filepath" == *"/..conf" ]] && continue
    domain="${filepath##*/}"
    domain="${domain%.conf}"
    domain="${domain#.}"
    if [[ "$domain" == ?*.?* && -f "/usr/local/lsws/$domain/html/wp-load.php" ]]; then
      process_2fa "$domain" "$mass_action"
    fi
  done
  thao_tac_thanh_cong=true

else
  pathcheck="/etc/wptt/vhost/.$NAME.conf"
  [[ ! -f "$pathcheck" ]] && {
    echo -e "${C_RED}❌ Tên miền không tồn tại!${C_RESET}"
    sleep 2
    exec /etc/wptt/wptt-bao-mat-main 1
  }

  if [[ -f "/usr/local/lsws/$NAME/passwd/.mk" ]]; then
    if wptt_xac_nhan "Tính năng 2FA đang BẬT. Bạn có muốn TẮT không?" "${C_BOLD_WHITE}Website:${C_RESET} $NAME" "" "Đồng ý TẮT" "Hủy bỏ"; then
      echo ""
      msg_action="TẮT Bảo mật 2 lớp"
      process_2fa "$NAME" "tat"
      thao_tac_thanh_cong=true
    fi
  else
    if wptt_xac_nhan "Tính năng 2FA đang TẮT. Bạn có muốn BẬT không?" "${C_BOLD_WHITE}Website:${C_RESET} $NAME" "" "Đồng ý BẬT" "Hủy bỏ"; then
      echo ""
      msg_action="BẬT Bảo mật 2 lớp"
      process_2fa "$NAME" "bat"
      thao_tac_thanh_cong=true
    fi
  fi
fi

# ==============================================================================
# KHỞI ĐỘNG LẠI DỊCH VỤ VÀ IN BÁO CÁO (UX BO CONG)
# ==============================================================================
if $thao_tac_thanh_cong; then
  # _runing "Đang nạp lại cấu hình OpenLiteSpeed..."
  /usr/local/lsws/bin/lswsctrl reload >/dev/null 2>&1
  # _rundone "Cập nhật dịch vụ hệ thống"

  # Nếu có sinh tài khoản mới (BẬT)
  if [[ ${#CREDENTIALS_LIST[@]} -gt 0 ]]; then
    echo -e "\n${C_GREEN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
    center_text "${C_BOLD_WHITE}HOÀN TẤT! HÃY LƯU LẠI THÔNG TIN ĐĂNG NHẬP SAU:${C_RESET}"
    echo -e "${C_GREEN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"

    for item in "${CREDENTIALS_LIST[@]}"; do
      dom=$(echo "$item" | cut -d'|' -f1)
      usr=$(echo "$item" | cut -d'|' -f2)
      pwd=$(echo "$item" | cut -d'|' -f3)

      left_text "▪ Website  : ${C_GREEN}$dom${C_RESET}" 2
      left_text "  User     : ${C_YELLOW}$usr${C_RESET}" 2
      left_text "  Mật khẩu : ${C_YELLOW}$pwd${C_RESET}" 2
      left_text "-------------------------------------------------" 2
    done
    echo -e "${C_GREEN}╰──────────────────────────────────────────────────────────────────────────────╯${C_RESET}"
    echo -e "${C_CYAN}Mẹo:${C_RESET} Có thể xem lại tài khoản tại menu: Bảo mật => Xem tài khoản 2 lớp\n"
    echo -en "${C_GREEN}Nhấn phím [Enter] để quay lại Menu...${C_RESET}"
    read -r dummy
  else
    # Nếu chỉ TẮT
    echo -e "\n${C_GREEN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
    center_text "${C_BOLD_WHITE}HOÀN TẤT CẤU HÌNH BẢO MẬT${C_RESET}"
    echo -e "${C_GREEN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
    left_text "Website thao tác : ${C_YELLOW}$NAME${C_RESET}"
    left_text "Hành động        : ${C_GREEN}$msg_action${C_RESET}"
    echo -e "${C_GREEN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"
  fi
else
  echo -e "${C_YELLOW}Đã hủy thao tác cấu hình bảo mật.${C_RESET}"
fi

[[ ${1:-} == "98" ]] && exec /etc/wptt/wptt-bao-mat-main 1
