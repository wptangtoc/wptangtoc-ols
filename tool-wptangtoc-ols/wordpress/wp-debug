#!/bin/bash

function huong_dan() {
  1. Tính Năng Bật WP_DEBUG WordPress [Enable WP_DEBUG]
  Bật WP_DEBUG là việc kích hoạt chế độ gỡ lỗi [debug mode] của WordPress bằng cách thay đổi một hằng số tên là WP_DEBUG trong tệp tin cấu hình wp-config.php.

  Khi WP_DEBUG được bật [true]:

  Mục đích chính:
  * Hiển thị/Ghi lại lỗi PHP: Giúp Lập trình viên và người quản trị website thấy được tất cả các lỗi PHP [errors], cảnh báo [warnings], và thông báo [notices] mà website đang gặp phải. Điều này cực kỳ hữu ích để tìm và sửa lỗi trong theme, plugin, hoặc code tùy chỉnh.
  * Phát hiện code lỗi thời: Giúp nhận diện các hàm hoặc cách sử dụng đã lỗi thời trong WordPress.
  * Hỗ trợ gỡ lỗi Màn hình trắng: Khi website bị màn hình trắng chết chóc, bật WP_DEBUG có thể hiển thị lỗi PHP ẩn gây ra vấn đề.
  Kết quả: Các lỗi và cảnh báo PHP sẽ được hiển thị hoặc ghi lại, giúp bạn chẩn đoán và khắc phục sự cố website.: file log được ghi trong: mã nguồn/wp-content/wp-debug.log

  2. Tính Năng Tắt WP_DEBUG WordPress [Disable WP_DEBUG]
  Tắt WP_DEBUG là việc vô hiệu hóa chế độ gỡ lỗi của WordPress, đưa website trở lại trạng thái hoạt động bình thường, không hiển thị thông tin gỡ lỗi.

  Mục đích chính [RẤT QUAN TRỌNG cho website đang chạy thật - live site]:
  * Bảo mật: Không bao giờ được để WP_DEBUG bật trên website đang chạy thật. Việc hiển thị lỗi chi tiết có thể tiết lộ thông tin nhạy cảm về cấu trúc website và máy chủ, tạo cơ hội cho kẻ tấn công.
  * Trải nghiệm người dùng: Các thông báo lỗi trên trang web làm người dùng khó chịu và website trông thiếu chuyên nghiệp.
  * Trạng thái hoạt động chuẩn: Đây là cài đặt mặc định và an toàn cho website sản xuất.

  Kết quả: Website sẽ không hiển thị các thông báo lỗi PHP ra ngoài, giúp bảo vệ thông tin và mang lại trải nghiệm tốt hơn cho người dùng. Đây là cài đặt tiêu chuẩn cho mọi website WordPress đang hoạt động.
}

# ==============================================================================
# NẠP CẤU HÌNH, NGÔN NGỮ VÀ MÀU SẮC
# ==============================================================================
. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null

clear
echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}$quan_ly_wordpress ➜ Cấu hình WP_DEBUG (Gỡ lỗi)${C_RESET}"
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯${C_RESET}\n"

# ==============================================================================
# HÀM CHỌN WEBSITE CÓ HIỂN THỊ TRẠNG THÁI DEBUG
# ==============================================================================
function lua_chon_NAME() {
  unset NAME
  local selects=()
  local i=1
  local box_inner_width=${box_inner_width:-71}

  if [ "$(ls -A /etc/wptt/vhost 2>/dev/null)" ]; then
    for filepath in /etc/wptt/vhost/.*.conf; do
      [[ ! -f "$filepath" || "$filepath" == *"/..conf" ]] && continue

      local domain="${filepath##*/}"
      domain="${domain%.conf}"
      domain="${domain#.}"

      if [[ "$domain" == ?*.?* ]]; then
        local wp_config="/usr/local/lsws/$domain/html/wp-config.php"
        if [[ -f "$wp_config" ]]; then
          local status_text=""
          # Kiểm tra xem WP_DEBUG đang là true hay false
          if grep -iqE "^[[:space:]]*define[[:space:]]*\([[:space:]]*['\"]WP_DEBUG['\"][[:space:]]*,[[:space:]]*true" "$wp_config" 2>/dev/null; then
            status_text="[Đang Bật - Debugging]"
            status_color=$C_RED
          else
            status_text="[Đang Tắt]"
            status_color=$C_GREEN
          fi
          selects+=("$domain|$status_text|$status_color")
        fi
      fi
    done
  fi

  if [[ ${#selects[@]} -eq 0 ]]; then
    echo -e "\n${C_RED}❌ Lỗi: $khong_co_domain_nao_ton_tai_tren_he_thong${C_RESET}"
    exit
  fi

  mapfile -t selects < <(printf "%s\n" "${selects[@]}" | sort -uV)

  # RENDER BOX CHỌN DOMAIN
  echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
  local title_text="${lua_chon_website_ban_muon:-Nhập lựa chọn website} WP_DEBUG:"
  local clean_title=$(echo -e "$title_text" | sed "s/\x1B\[[0-9;]*[a-zA-Z]//g")
  local len=${#clean_title}
  local pad_r=$((box_inner_width - len - 2))

  echo -e "${C_CYAN}│${C_RESET}  ${C_YELLOW}${title_text}${C_RESET}$(printf '%*s' "$pad_r" "")${C_CYAN}│${C_RESET}"
  local line_len=$((len + 3))
  local pad_line_r=$((box_inner_width - line_len))
  local short_line=$(printf "%${line_len}s" "" | sed 's/ /─/g')
  echo -e "${C_CYAN}├${short_line}$(printf '%*s' "$pad_line_r" "")│${C_RESET}"

  for val in "${selects[@]}"; do
    IFS='|' read -r d s c <<<"$val"
    local clean_row=$(printf "  %3d) %-32s %s" "$i" "$d" "$s")
    local item_row=$(printf "  ${C_CYAN}%3d)${C_RESET} ${C_BOLD_WHITE}%-32s${C_RESET} ${c}%s${C_RESET}" "$i" "$d" "$s")
    local pad=$((box_inner_width - ${#clean_row}))
    echo -e "${C_CYAN}│${C_RESET}${item_row}$(printf '%*s' "$pad" "")${C_CYAN}│${C_RESET}"
    ((i++))
  done
  echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯${C_RESET}"

  local fzf_installed=false
  command -v fzf &>/dev/null && fzf_installed=true
  local prompt_msg="${lua_chon_website_ban_muon:-Nhập lựa chọn} (1-${#selects[@]}) [00=${chon_nhanh:-Chọn nhanh}] [0=${exit_thoat:-Thoát}]: "

  while true; do
    echo -en "${C_CYAN}${prompt_msg}${C_RESET}"
    read -r REPLY
    REPLY=$(echo "$REPLY" | tr -d ' ' | tr '[:upper:]' '[:lower:]')

    case "$REPLY" in
    0) exec /etc/wptt/wptt-wordpress-main 1 ;;
    00)
      if $fzf_installed; then
        local fzf_list=()
        for val in "${selects[@]}"; do
          IFS='|' read -r d s c <<<"$val"
          fzf_list+=("$d $s")
        done
        local sel=$(printf '%s\n' "${fzf_list[@]}" | nl -w 3 -s ': ' | fzf --height=40% --border=rounded --reverse)
        NAME=$(echo "$sel" | sed 's/^[[:space:]]*[0-9]\+\:[[:space:]]*//' | awk '{print $1}')
        [[ -n "$NAME" ]] && return 0 || continue
      fi
      ;;
    *)
      if [[ "$REPLY" =~ ^[0-9]+$ ]] && [ "$REPLY" -ge 1 ] && [ "$REPLY" -le ${#selects[@]} ]; then
        local val="${selects[$((REPLY - 1))]}"
        NAME="${val%|*|*}"
        return 0
      elif [[ "$REPLY" == ?*.?* ]]; then
        NAME="$REPLY"
        return 0
      fi
      ;;
    esac
  done
}

lua_chon_NAME

# ==============================================================================
# XỬ LÝ LOGIC BẬT / TẮT
# ==============================================================================
path_html="/usr/local/lsws/$NAME/html"
wp_config="$path_html/wp-config.php"

[[ ! -f "$wp_config" ]] && echo -e "\n${C_RED}❌ Không tìm thấy wp-config.php cho $NAME${C_RESET}" && sleep 2 && exec /etc/wptt/wptt-wordpress-main 1

# Kiểm tra trạng thái hiện tại để quyết định hành động tiếp theo
if grep -iqE "^[[:space:]]*define[[:space:]]*\([[:space:]]*['\"]WP_DEBUG['\"][[:space:]]*,[[:space:]]*true" "$wp_config" 2>/dev/null; then
  current_mode="on"
  action_text="TẮT"
  target_val="false"
else
  current_mode="off"
  action_text="BẬT"
  target_val="true"
fi

echo -en "\n${C_YELLOW}👉 Xác nhận $action_text tính năng WP_DEBUG cho website $NAME? [y/n]: ${C_RESET}"
read -r confirm
[[ ! "$confirm" =~ ^[yY]$ ]] && echo -e "${C_YELLOW}Đã hủy thao tác.${C_RESET}" && sleep 1 && exec /etc/wptt/wptt-wordpress-main 1

echo ""
_runing "$action_text WP_DEBUG cho $NAME"

. /etc/wptt/vhost/.$NAME.conf
. /etc/wptt/php/php-cli-domain-config $NAME

# Thực thi cấu hình bằng WP-CLI (An toàn nhất)
sudo -u "$User_name_vhost" /usr/local/bin/wp config set WP_DEBUG $target_val --raw --path="$path_html" >/dev/null 2>&1
sudo -u "$User_name_vhost" /usr/local/bin/wp config set WP_DEBUG_LOG $target_val --raw --path="$path_html" >/dev/null 2>&1
sudo -u "$User_name_vhost" /usr/local/bin/wp config set WP_DEBUG_DISPLAY $target_val --raw --path="$path_html" >/dev/null 2>&1

# Nếu tắt thì dọn dẹp log cũ
if [[ "$target_val" == "false" ]]; then
  [[ -f "$path_html/wp-content/debug.log" ]] && rm -f "$path_html/wp-content/debug.log"
fi

# Reset OPcache để áp dụng ngay lập tức
sudo -u "$User_name_vhost" /usr/local/lsws/lsphp${phien_ban_php_domain_thuc_thi}/bin/php /usr/local/bin/wp eval 'opcache_reset();' --path="$path_html" --allow-root >/dev/null 2>&1

echo "$action_text WP_DEBUG website $NAME: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log
_rundone "$action_text WP_DEBUG cho $NAME"

if [[ "$target_val" == "true" ]]; then
  echo -e "${C_CYAN} File log sẽ được ghi tại: ${C_BOLD_WHITE}$path_html/wp-content/debug.log${C_RESET}"
fi

if [[ ${1:-} == "98" ]]; then
  exec /etc/wptt/wptt-wordpress-main 1
fi
