#!/bin/bash

function huong_dan() {
  tính năng cập nhật plugin WordPress là một chức năng cốt lõi của WordPress, cho phép người dùng dễ dàng nâng cấp các plugin đã cài đặt trên website của họ lên phiên bản mới nhất do nhà phát triển plugin cung cấp.

  Tại sao cần cập nhật plugin [lợi ích chính]:
  * Bảo mật: Đây là lý do quan trọng hàng đầu. Các bản cập nhật plugin thường xuyên vá các lỗ hổng bảo mật đã được phát hiện. Plugin lỗi thời là một trong những nguyên nhân phổ biến nhất khiến website WordPress bị tấn công.
  * Thêm Tính năng Mới và Cải tiến: Nhà phát triển liên tục cải thiện plugin bằng cách thêm các chức năng mới, tối ưu hóa hiệu suất, hoặc cải thiện giao diện người dùng.
  * Sửa lỗi [Bug Fixes]: Các phiên bản cập nhật khắc phục các lỗi còn tồn tại ở phiên bản trước, giúp plugin hoạt động ổn định và chính xác hơn.
  * Đảm bảo Tương thích: Giúp plugin hoạt động tốt với phiên bản WordPress mới nhất, cũng như với các theme và plugin khác, tránh xung đột gây lỗi website.
  * Tăng hiệu suất: Đôi khi các bản cập nhật bao gồm việc tối ưu mã nguồn, giúp plugin chạy nhanh hơn và nhẹ hơn.

  Tính năng cập nhật plugin WordPress đóng vai trò cực kỳ quan trọng trong việc duy trì một website an toàn, ổn định, đầy đủ tính năng và tương thích tốt. Việc thường xuyên kiểm tra và thực hiện cập nhật là một phần không thể thiếu trong quản trị website WordPress.
}

. /etc/wptt/.wptt.conf
if [[ $ngon_ngu = '' ]]; then
  ngon_ngu='vi'
fi
. /etc/wptt/lang/$ngon_ngu.sh
. /etc/wptt/echo-color
tinh_nang_ten="$cap_nhat WordPress Plugins"
echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_BOLD_WHITE}$quan_ly_cap_nhat_wordpress ➜ $tinh_nang_ten${C_RESET}"
echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯${C_RESET}\n"

NAME=$1
if [[ $NAME = "98" ]]; then
  NAME=""
fi

if [[ $NAME = "" ]]; then
  . /etc/wptt/tenmien-them-lua-chon-tat-ca-website-by-wordpress
  lua_chon_NAME "$tinh_nang_ten"
fi

if [[ $NAME = 'Tất cả website' ]]; then
  for filepath in /etc/wptt/vhost/.*.conf; do #kiểm for này hiệu suất nó rất tốt
    [[ ! -f "$filepath" || "$filepath" == *"/..conf" ]] && continue
    # Kỹ thuật Parameter Expansion (Xử lý cắt chuỗi trực tiếp trên RAM, không dùng sed)
    domain="${filepath##*/}" # Lấy tên file (.wptangtoc.com.conf)
    domain="${domain%.conf}" # Cắt đuôi .conf (.wptangtoc.com)
    domain="${domain#.}"     # Cắt dấu chấm ở đầu (wptangtoc.com)

    if [[ "$domain" == ?*.?* ]]; then #điều kiện yêu cầu có ký tự. ký tự đại diện cho domain
      if [[ -f /usr/local/lsws/$domain/html/wp-config.php ]]; then
        _runing "Đang cập nhật TẤT CẢ plugins cho website $domain..."
        (/etc/wptt/wordpress/update-plugin $domain >/dev/null 2>&1)
        _rundone "Cập nhật TẤT CẢ plugins cho website $domain"
      fi
    fi
  done

  check_menu_wptangtoc_active=$1
  if [[ $check_menu_wptangtoc_active = "98" ]]; then
    exec /etc/wptt/wptt-wordpress-main 1
  fi
  exit
fi

if [[ "$NAME" = "0" || "$NAME" = "" ]]; then
  exec /etc/wptt/wordpress/wptt-update-wordpress-main 1
fi

pathcheck="/etc/wptt/vhost/.$NAME.conf"
if [[ ! -f "$pathcheck" ]]; then
  clear
  echoDo "Tên miền không tồn tại trên hệ thống này"
  sleep 3
  exec /etc/wptt/wordpress/wptt-update-wordpress-main 1
  exit
fi

pathcheckwp="/usr/local/lsws/$NAME/html/wp-load.php"
if [[ ! -f "$pathcheckwp" ]]; then
  clear
  echo "Hệ thống xác nhận bạn chưa kích hoạt sử dụng WordPress"
  sleep 3
  exec /etc/wptt/wordpress/wptt-update-wordpress-main 1
  exit
fi

# =====================================================================
# KHỐI 2: CẬP NHẬT CHO 1 WEBSITE CỤ THỂ (Interactive Menu)
# =====================================================================
path="/usr/local/lsws/$NAME/html"
. /etc/wptt/php/php-cli-domain-config $NAME
. /etc/wptt/vhost/.$NAME.conf

# Khai báo biến WP_EXEC để tái sử dụng, đồng bộ 100% quyền User và phiên bản PHP
WP_EXEC="sudo -u $User_name_vhost /usr/local/lsws/lsphp${phien_ban_php_domain_thuc_thi}/bin/php /usr/local/bin/wp"

echo "Đang quét các bản cập nhật plugin cho website $NAME..."
# Chỉ lấy danh sách plugin CÓ BẢN CẬP NHẬT MỚI
plugins_need_update=$($WP_EXEC plugin list --update=available --field=name --allow-root --path="$path" 2>/dev/null)

if [[ -z "$plugins_need_update" ]]; then
  echo ""
  echoDone "Tuyệt vời! Tất cả plugin trên website $NAME đều đã ở phiên bản mới nhất."
  echo ""
else
  echo ""
  echo "========================================================================="
  echo " Danh sách plugin CẦN CẬP NHẬT trên website $NAME:"
  echo "-------------------------------------------------------------------------"
  $WP_EXEC plugin list --update=available --fields=name,version,update_version --allow-root --path="$path" 2>/dev/null
  echo "========================================================================="
  echo ""

  # Chuyển danh sách plugin thành mảng Bash
  selects=()
  while IFS= read -r line; do
    [[ -n "$line" ]] && selects+=("$line")
  done <<<"$plugins_need_update"

  # Tạo Menu Lựa chọn động
  options=("Cập nhật TẤT CẢ plugin đang có bản mới")
  for p in "${selects[@]}"; do
    options+=("Chỉ cập nhật plugin: $p")
  done

  PS3="
$(tput setab 0)-//- Chọn thao tác bạn muốn thực hiện (1-$((${#options[@]}))) [0=Thoát]:$(tput sgr0) "

  plugin_target=""
  select opt in "${options[@]}"; do
    if [[ "$REPLY" == "0" ]]; then
      exec /etc/wptt/wordpress/wptt-update-wordpress-main 1
    elif [[ "$REPLY" == "1" ]]; then
      plugin_target="all"
      break
    elif [[ "$REPLY" -gt 1 && "$REPLY" -le ${#options[@]} ]]; then
      idx=$((REPLY - 2))
      plugin_target="${selects[$idx]}"
      break
    else
      echoDo "Lựa chọn không hợp lệ, vui lòng chọn lại."
    fi
  done

  echo ""
  # Xử lý cập nhật dựa trên lựa chọn
  if [[ "$plugin_target" == "all" ]]; then
    _runing "Đang cập nhật TẤT CẢ plugins cho website $NAME"
    $WP_EXEC plugin update --all --path="$path" --allow-root >/dev/null 2>&1
    $WP_EXEC language plugin update --all --path="$path" --allow-root >/dev/null 2>&1
    _rundone "Cập nhật TẤT CẢ plugins cho website $NAME"
  else
    _runing "Đang cập nhật riêng plugin: $plugin_target"
    $WP_EXEC plugin update "$plugin_target" --path="$path" --allow-root >/dev/null 2>&1
    $WP_EXEC language plugin update "$plugin_target" --path="$path" --allow-root >/dev/null 2>&1
    _rundone "Cập nhật riêng plugin: $plugin_target"
  fi

  # Dọn dẹp hậu kỳ
  _runing "Dọn dẹp cache và phân quyền sau cập nhật"
  $WP_EXEC cache flush --path="$path" --allow-root >/dev/null 2>&1
  . /etc/wptt/wptt-phanquyen $NAME >/dev/null 2>&1
  $WP_EXEC rewrite flush --path="$path" --allow-root >/dev/null 2>&1
  _rundone "Dọn dẹp cache và phân quyền sau cập nhật"
fi

check_menu_wptangtoc_active=${1:-}
if [[ $check_menu_wptangtoc_active = "98" ]]; then
  exec /etc/wptt/wordpress/wptt-update-wordpress-main 1
fi
