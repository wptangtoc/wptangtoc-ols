#!/bin/bash

function huong_dan() {
  Tính năng cập nhật theme WordPress là một chức năng cho phép người dùng dễ dàng nâng cấp giao diện [theme] website của họ lên phiên bản mới nhất do nhà phát triển theme cung cấp.

  Tại sao cần cập nhật theme [lợi ích chính]:
  * Bảo mật: Đây là lý do quan trọng nhất. Các bản cập nhật theme thường xuyên vá các lỗ hổng bảo mật được phát hiện. Việc không cập nhật có thể khiến website của bạn dễ bị tấn công.
  * Thêm Tính năng Mới: Nhà phát triển thường bổ sung các tính năng, tùy chọn tùy chỉnh, hoặc cải tiến thiết kế trong các phiên bản mới, giúp website của bạn hiện đại và tiện dụng hơn.
  * Sửa lỗi [Bug Fixes]: Các phiên bản cập nhật sửa các lỗi đã biết từ phiên bản trước, giúp theme hoạt động ổn định và mượt mà hơn.
  * Đảm bảo Tương thích: Giúp theme tương thích tốt hơn với phiên bản WordPress mới nhất cũng như các plugin khác, tránh xung đột và lỗi không mong muốn.

  Tính năng cập nhật theme WordPress là một phần thiết yếu để duy trì một website an toàn, ổn định, và hiện đại. Việc thường xuyên kiểm tra và áp dụng các bản cập nhật là một thói quen tốt cho mọi chủ sở hữu website WordPress.
}

. /etc/wptt/.wptt.conf
if [[ $ngon_ngu = '' ]]; then
  ngon_ngu='vi'
fi
. /etc/wptt/lang/$ngon_ngu.sh

. /etc/wptt/echo-color
echo ""
echo ""
echo ""
echo "========================================================================="
echo "|$quan_ly_cap_nhat_wordpress => $cap_nhat themes WordPress             |"
echo "========================================================================="

NAME=$1
if [[ $NAME = "98" ]]; then
  NAME=""
fi

if [[ $NAME = "" ]]; then
  . /etc/wptt/tenmien-them-lua-chon-tat-ca-website-by-wordpress
  echo ""
  echo ""
  echo "$lua_chon_website_ban_muon $cap_nhat themes: "
  echo ""
  lua_chon_NAME
fi

if [[ $NAME = 'Tất cả website' ]]; then
  if [ "$(ls -A /etc/wptt/vhost | grep -v '^\.\.conf$' | sort -uV)" ]; then
    for entry in $(ls -A /etc/wptt/vhost | grep -v '^\.\.conf$' | sort -uV); do
      domain=$(echo $entry | sed 's/^.//' | sed 's/.conf//')
      unset path path_html
      path="/usr/local/lsws/$domain/html/wp-load.php"
      path_html="/usr/local/lsws/$domain/html"
      if [ "$domain" != "${domain/./}" ] && [ "$domain" != '.' ]; then
        if [[ -f "$path" ]]; then
          _runing "Đang cập nhật TẤT CẢ themes cho website $domain..."
          (/etc/wptt/wordpress/update-theme $domain >/dev/null 2>&1)
          _rundone "Cập nhật TẤT CẢ themes cho website $domain"
        fi
      fi
    done
  fi

  check_menu_wptangtoc_active=$1
  if [[ $check_menu_wptangtoc_active = "98" ]]; then
    exec /etc/wptt/wptt-wordpress-main 1
  fi
  exit
fi

if [[ "$NAME" = "0" || "$NAME" = "" ]]; then
  exec /etc/wptt/wordpress/wptt-update-wordpress-main 1
fi

pathcheck="/etc/wptt/vhost/.$NAME.conf"
if [[ ! -f "$pathcheck" ]]; then
  clear
  echoDo "Tên miền không tồn tại trên hệ thống này"
  sleep 3
  exec /etc/wptt/wordpress/wptt-update-wordpress-main 1
  exit
fi

pathcheckwp="/usr/local/lsws/$NAME/html/wp-load.php"
if [[ ! -f "$pathcheckwp" ]]; then
  clear
  echo "Hệ thống xác nhận bạn chưa kích hoạt sử dụng WordPress"
  sleep 3
  exec /etc/wptt/wordpress/wptt-update-wordpress-main 1
  exit
fi

path="/usr/local/lsws/$NAME/html"
. /etc/wptt/php/php-cli-domain-config $NAME
. /etc/wptt/vhost/.$NAME.conf

# Khai báo biến WP_EXEC chuẩn xác
WP_EXEC="sudo -u $User_name_vhost /usr/local/lsws/lsphp${phien_ban_php_domain_thuc_thi}/bin/php /usr/local/bin/wp"

echo "Đang kiểm tra các bản cập nhật theme cho website $NAME..."
# Lấy danh sách theme CÓ bản cập nhật
themes_need_update=$($WP_EXEC theme list --update=available --field=name --allow-root --path="$path" 2>/dev/null)

if [[ -z "$themes_need_update" ]]; then
  echo ""
  echoDone "Website $NAME đã sử dụng các phiên bản theme mới nhất."
  echo ""
else
  echo ""
  echo "========================================================================="
  echo " Danh sách theme CẦN CẬP NHẬT của website $NAME:"
  echo "-------------------------------------------------------------------------"
  $WP_EXEC theme list --update=available --fields=name,version,update_version --allow-root --path="$path" 2>/dev/null
  echo "========================================================================="
  echo ""

  # Chuyển danh sách theme sang mảng
  selects=()
  while IFS= read -r line; do
    [[ -n "$line" ]] && selects+=("$line")
  done <<<"$themes_need_update"

  # Khởi tạo menu
  options=("Cập nhật TẤT CẢ các theme trên")
  for t in "${selects[@]}"; do
    options+=("Chỉ cập nhật theme: $t")
  done

  PS3="
$(tput setab 0)-//- Chọn thao tác cập nhật (1-$((${#options[@]}))) [0=Thoát]:$(tput sgr0) "

  theme_target=""
  select opt in "${options[@]}"; do
    if [[ "$REPLY" == "0" ]]; then
      exec /etc/wptt/wordpress/wptt-update-wordpress-main 1
    elif [[ "$REPLY" == "1" ]]; then
      theme_target="all"
      break
    elif [[ "$REPLY" -gt 1 && "$REPLY" -le ${#options[@]} ]]; then
      idx=$((REPLY - 2))
      theme_target="${selects[$idx]}"
      break
    else
      echoDo "Lựa chọn không hợp lệ."
    fi
  done

  echo ""
  # Thực thi cập nhật
  if [[ "$theme_target" == "all" ]]; then
    _runing "Đang cập nhật TẤT CẢ themes cho website $NAME"
    $WP_EXEC theme update --all --path="$path" --allow-root >/dev/null 2>&1
    $WP_EXEC language theme update --all --path="$path" --allow-root >/dev/null 2>&1
    _rundone "Cập nhật TẤT CẢ themes cho website $NAME"
  else
    _runing "Đang cập nhật theme: $theme_target"
    $WP_EXEC theme update "$theme_target" --path="$path" --allow-root >/dev/null 2>&1
    $WP_EXEC language theme update "$theme_target" --path="$path" --allow-root >/dev/null 2>&1
    _rundone "Cập nhật theme: $theme_target"
  fi

  # Xóa cache sau khi thay đổi giao diện
  _runing "Đang xóa cache website $NAME"
  . /etc/wptt/cache/wptt-xoacache $NAME >/dev/null 2>&1
  _rundone "Đã xóa cache website $NAME"
fi

check_menu_wptangtoc_active=${1:-}
if [[ $check_menu_wptangtoc_active = "98" ]]; then
  exec /etc/wptt/wordpress/wptt-update-wordpress-main 1
fi
