#!/bin/bash
# Tính năng: Auto-Revert 100% SQLite về lại MariaDB (Bản Fix Cấu Trúc Monorepo - Auto Downgrade & Export)
# @author: Gia Tuấn - WPTangToc
PATH='/root/.local/bin:/root/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin'

. /etc/wptt/echo-color
. /etc/wptt/.wptt.conf
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh

# =========================================================
# XỬ LÝ BIẾN ĐẦU VÀO VÀ MENU
# =========================================================
NAME=$1
[[ "$NAME" == "98" ]] && NAME=""

if [[ -z "$NAME" ]]; then
  . /etc/wptt/tenmien-them-lua-chon-tat-ca-website-by-wordpress
  echo -e "\n\n$nhap_lua_chon_website_cua_ban deactivate sqlite (Revert to MariaDB):\n"
  lua_chon_NAME
fi

if [[ "$NAME" == 'Tất cả website' ]]; then
  for filepath in /etc/wptt/vhost/.*.conf; do
    [[ ! -f "$filepath" || "$filepath" == *"/..conf" ]] && continue

    domain="${filepath##*/}"
    domain="${domain%.conf}"
    domain="${domain#.}"

    if [[ "$domain" == ?*.?* ]]; then
      path="/usr/local/lsws/$domain/html/wp-config.php"
      if [[ -f "$path" ]]; then
        _runing "deactivate sqlite website $domain"
        (/etc/wptt/wordpress/wptt-sqlite-deactive "$domain" >/dev/null 2>&1)
        _rundone "deactivate sqlite website $domain"
      fi
    fi
  done

  [[ ${1:-} == "98" ]] && exec /etc/wptt/wptt-wordpress-main 1
  exit
fi

[[ "$NAME" == "0" || -z "$NAME" ]] && exec /etc/wptt/wptt-wordpress-main 1

DOMAIN="$NAME"
if [[ -z "$DOMAIN" ]]; then
  echo "❌ Lỗi: Vui lòng nhập tên miền!"
  return 2>/dev/null || exit 1
fi

PATH_HTML="/usr/local/lsws/$DOMAIN/html"

if [[ ! -d "$PATH_HTML" ]]; then
  echo "❌ Lỗi: Không tìm thấy thư mục web tại $PATH_HTML"
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-wordpress-main 1
  return 2>/dev/null || exit
fi

if [[ ! -f "$PATH_HTML/wp-content/db.php" ]]; then
  echo "⚠️ Website $DOMAIN hiện không chạy SQLite (không tìm thấy db.php). Không cần phục hồi!"
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-wordpress-main 1
  return 2>/dev/null || exit
fi

# Lấy User Vhost
USER_VHOST=$(grep 'User_name_vhost' "/etc/wptt/vhost/.$DOMAIN.conf" 2>/dev/null | cut -d'=' -f2 | tr -d '"' | tr -d "'")
[[ -z "$USER_VHOST" ]] && USER_VHOST="nobody"

# =========================================================
# HÀM CẤP CỨU ROLLBACK (Khôi phục lại SQLite nếu MariaDB lỗi)
# =========================================================
function wptt_rollback_to_sqlite() {
  echo -e "\n❌ CÓ LỖI XẢY RA TRONG QUÁ TRÌNH NẠP DATA VÀO MARIADB!"
  echo "Đang tự động khôi phục (Rollback) lại trạng thái SQLite..."
  mv "$PATH_HTML/wp-content/db.php.bak" "$PATH_HTML/wp-content/db.php"
  killall -9 lsphp >/dev/null 2>&1
  echo "✅ Đã Rollback an toàn! Web vẫn đang chạy bằng SQLite. Hãy kiểm tra lại file sql."
  exit 1
}

echo "==========================================================="
echo "🔄 KHỞI ĐỘNG CỖ MÁY PHỤC HỒI TỪ SQLITE VỀ MARIADB CHO $DOMAIN"
echo "==========================================================="

cd "$PATH_HTML" || exit 1
killall -9 lsphp >/dev/null 2>&1

# ---------------------------------------------------------
# 1. NẠP GÓI WP-CLI-SQLITE-COMMAND (Bản v1.1.4 Ổn định)
# ---------------------------------------------------------
echo "[1/6] Đảm bảo đã nạp vũ khí wp-cli-sqlite-command (Bản v1.1.4)..."
rm -rf /root/.wp-cli/packages/
git config --global url."https://github.com/".insteadOf git@github.com:
export GIT_SSH_COMMAND="ssh -o UserKnownHostsFile=/dev/null -o StrictHostKeyChecking=no"

wp package install automattic/wp-cli-sqlite-command:v1.1.4 --allow-root >/dev/null 2>&1

# ---------------------------------------------------------
# 1.5. HẠ CẤP PLUGIN LẤY BỘ KHUNG XUẤT DATA (Bản Vàng 2.2.20)
# ---------------------------------------------------------
echo "[1.5/6] Đang ép hạ cấp Plugin về bản Vàng 2.2.20 để đánh thức cỗ máy Export..."
DOWNLOAD_URL="https://downloads.wordpress.org/plugin/sqlite-database-integration.2.2.20.zip"
if ! curl --output /dev/null --silent --head --fail "$DOWNLOAD_URL"; then
  DOWNLOAD_URL="https://downloads.wordpress.org/plugin/sqlite-database-integration.2.2.19.zip"
fi
wp plugin install "$DOWNLOAD_URL" --force --allow-root --skip-packages --path="$PATH_HTML" >/dev/null 2>&1
chown -R "$USER_VHOST:$USER_VHOST" "$PATH_HTML/wp-content/plugins/sqlite-database-integration" 2>/dev/null

# ---------------------------------------------------------
# 2. XUẤT DATA TỪ SQLITE VÀ CONVERT SANG MARIA-DB
# ---------------------------------------------------------
echo "[2/6] Đang trích xuất dữ liệu từ SQLite hiện tại và convert chuẩn MariaDB..."
FILE_SQL="chuyendoi_sqlite_to_mariadb.sql"

# Lệnh này ĐẶC BIỆT KHÔNG DÙNG --skip-packages vì nó CẦN gói wp-cli vừa cài để chạy
if ! wp sqlite export "$FILE_SQL" --enable-ast-driver --allow-root --quiet --path="$PATH_HTML"; then
  echo "❌ Lỗi: Không thể export Database từ SQLite. Vui lòng kiểm tra lại."
  exit 1
fi
BACKUP_FILE="/root/backup_${DOMAIN}_sqlite_$(date +%s).sql"
cp "$FILE_SQL" "$BACKUP_FILE"

# ---------------------------------------------------------
# 3. GẠT CẦU DAO: TẮT CHẾ ĐỘ SQLITE
# ---------------------------------------------------------
echo "[3/6] Đang ngắt cầu dao SQLite (Vô hiệu hóa db.php)..."
mv "$PATH_HTML/wp-content/db.php" "$PATH_HTML/wp-content/db.php.bak"

killall -9 lsphp >/dev/null 2>&1

# ---------------------------------------------------------
# 4. DỌN SẠCH MARIADB CŨ VÀ BƠM DỮ LIỆU TỪ SQLITE VÀO
# ---------------------------------------------------------
echo "[4/6] Đang làm sạch MariaDB cũ và ép nạp (Import) dữ liệu mới nhất..."
wp db reset --yes --allow-root --skip-packages --path="$PATH_HTML" >/dev/null 2>&1
wp db import "$FILE_SQL" --allow-root --skip-packages --path="$PATH_HTML"

if [[ $? -eq 0 ]]; then
  # ---------------------------------------------------------
  # 5. TẮT VÀ GỠ BỎ PLUGIN LÕI SQLITE
  # ---------------------------------------------------------
  echo "[5/6] Vô hiệu hóa và dọn dẹp Plugin SQLite..."
  wp plugin deactivate sqlite-database-integration --allow-root --skip-packages --path="$PATH_HTML" >/dev/null 2>&1
  wp plugin uninstall sqlite-database-integration --allow-root --skip-packages --path="$PATH_HTML" >/dev/null 2>&1

  # ---------------------------------------------------------
  # 6. DỌN DẸP CHIẾN TRƯỜNG & PHỤC HỒI RAM MARIADB
  # ---------------------------------------------------------
  echo "[6/6] Dọn dẹp chiến trường và bung lại sức mạnh MariaDB..."
  rm -f "$FILE_SQL" "$BACKUP_FILE"
  rm -f "$PATH_HTML/wp-content/db.php.bak"
  rm -rf "$PATH_HTML/wp-content/database"

  # Kích hoạt WPTangToc Auto-Tune để lấy lại RAM cho MariaDB
  echo '100' >/etc/wptt/.ram_hien_tai
  /bin/bash /etc/wptt/cau-hinh/wptt-auto-tune >/dev/null 2>&1

  echo -e "\n==========================================================="
  echo "🎉 HOÀN TẤT THẦN TỐC 100% PHỤC HỒI VỀ MARIADB!"
  echo "Dữ liệu mới nhất đã được migrate thành công!"
  echo "==========================================================="
else
  wptt_rollback_to_sqlite
fi
