#!/bin/bash

function huong_dan() {
  Kiểm tra phiên bản php mã nguồn Core WordPress
}

. /etc/wptt/.wptt.conf
if [[ $ngon_ngu = '' ]]; then
  ngon_ngu='vi'
fi
. /etc/wptt/lang/$ngon_ngu.sh

. /etc/wptt/echo-color

echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_BOLD_WHITE}$quan_ly_cap_nhat_wordpress ➜ Kiểm tra phiên bản WordPress${C_RESET}"
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯${C_RESET}\n"

NAME=$1
if [[ $NAME = "98" ]]; then
  NAME=""
fi

if [[ $NAME = "" ]]; then
  . /etc/wptt/tenmien-only-website-by-wordpress
  lua_chon_NAME "Kiểm tra phiên bản WordPress"
fi

if [[ "$NAME" = "0" || "$NAME" = "" ]]; then
  exec /etc/wptt/wordpress/wptt-update-wordpress-main 1
fi

pathcheck="/etc/wptt/vhost/.$NAME.conf"
if [[ ! -f "$pathcheck" ]]; then
  clear
  echoDo "Tên miền không tồn tại trên hệ thống này"
  sleep 3
  exec /etc/wptt/wordpress/wptt-update-wordpress-main 1
  exit
fi

pathcheckwp="/usr/local/lsws/$NAME/html/wp-load.php"
if [[ ! -f "$pathcheckwp" ]]; then
  clear
  echo "He thong xac nhan ban chua kich hoat su dung WordPress"
  sleep 3
  exec /etc/wptt/wordpress/wptt-update-wordpress-main 1
  exit
fi

. /etc/wptt/php/php-cli-domain-config $NAME
unset path version
path="/usr/local/lsws/$NAME/html"
. /etc/wptt/vhost/.$NAME.conf

version=$(sudo -u "$User_name_vhost" /usr/local/lsws/lsphp${phien_ban_php_domain_thuc_thi}/bin/php /usr/local/bin/wp core version --allow-root --path="$path")
echo "website $NAME Đang sử dụng Core WordPress $phien_ban: $version               "
echo "Phiên bản Plugins website $NAME:"
sudo -u "$User_name_vhost" /usr/local/lsws/lsphp${phien_ban_php_domain_thuc_thi}/bin/php /usr/local/bin/wp plugin list --fields=name,version,update_version --allow-root --path=$path
echo "Phiên bản Themes website $NAME:"
sudo -u "$User_name_vhost" /usr/local/lsws/lsphp${phien_ban_php_domain_thuc_thi}/bin/php /usr/local/bin/wp theme list --fields=name,version,update_version --allow-root --path=$path
check_menu_wptangtoc_active=$1
if [[ $check_menu_wptangtoc_active = "98" ]]; then
  echo -en "${C_GREEN}Nhấn phím [Enter] để quay lại Menu quản lý WordPress...${C_RESET}"
  read -r
  exec /etc/wptt/wordpress/wptt-update-wordpress-main 1
fi
