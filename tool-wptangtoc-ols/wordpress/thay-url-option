#!/bin/bash

function huong_dan() {
  Cập nhật Url home và siteurl cho mã nguồn Wordpress
  tính năng này rất hữu ích: một số anh em giả lập localhost không thay đổi url lại.
  tính năng này sẽ giúp update cập nhật lại home url và siteurl
}

. /etc/wptt/.wptt.conf
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh

. /etc/wptt/echo-color
echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_BOLD_WHITE}$quan_ly_wordpress ➜ $cap_nhat Url home && siteurl${C_RESET}"
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯${C_RESET}\n"

. /etc/wptt/tenmien-only-website-by-wordpress
lua_chon_NAME "$cap_nhat home && siteurl"

# --- CHỐT CHẶN THOÁT HIỂM (VỊ TRÍ BẮT BUỘC) ---
[[ "$NAME" == "0" || -z "$NAME" ]] && exec /etc/wptt/wptt-wordpress-main 1

path_conf="/etc/wptt/vhost/.$NAME.conf"
[[ ! -f "$path_conf" ]] && {
  echoDo "$ten_mien_nay_khong_ton_tai_tren_he_thong"
  sleep 2
  exec /etc/wptt/wptt-wordpress-main 1
}

path="/usr/local/lsws/$NAME/html"
[[ ! -f "$path/wp-load.php" ]] && {
  echoDo "$he_thong_xac_nhan_ban_khong_su_ma_nguon"
  echoDo "$tinh_nang_nay_chi_danh_cho_ma_nguon_wordpress"
  sleep 2
  exec /etc/wptt/wptt-wordpress-main 1
}

[[ ! -f "$path/wp-config.php" ]] && {
  echoDo "$he_thong_xac_nhan_ban_khong_su_ma_nguon"
  sleep 2
  exec /etc/wptt/wptt-wordpress-main 1
}

. "$path_conf"
. /etc/wptt/php/php-cli-domain-config $NAME

# Khai báo WP_EXEC chuẩn quyền
WP_EXEC="sudo -u $User_name_vhost /usr/local/lsws/lsphp${phien_ban_php_domain_thuc_thi}/bin/php /usr/local/bin/wp"

# --- BƯỚC 1: XÁC ĐỊNH PROTOCOL (HTTP hay HTTPS) ---
is_ssl=false
if [[ -f "/etc/letsencrypt/live/$NAME/cert.pem" || -d "/usr/local/lsws/$NAME/ssl" ]]; then
  is_ssl=true
# Curl check header thay vì body để tăng tốc x10 lần, timeout 5s chống treo
elif curl -sI -m 5 "https://$NAME" 2>/dev/null | grep -qiE 'cf-|cloudflare'; then
  is_ssl=true
fi

protocol="http"
[[ "$is_ssl" == true ]] && protocol="https"

# --- BƯỚC 2: XÁC ĐỊNH PREFIX (có www hay không) ---
current_home=$($WP_EXEC option get home --path="$path" 2>/dev/null)
prefix=""
if echo "$current_home" | grep -q '://www.'; then
  prefix="www."
fi

# --- BƯỚC 3: GHÉP CHUỖI VÀ THỰC THI (1 LẦN DUY NHẤT) ---
final_url="${protocol}://${prefix}${NAME}"
UI_STRING="$cap_nhat Home URL website $NAME: $final_url"

_runing "$UI_STRING"

$WP_EXEC option update home "$final_url" --path="$path" >/dev/null 2>&1
$WP_EXEC option update siteurl "$final_url" --path="$path" >/dev/null 2>&1

_rundone "$UI_STRING"

echo "Update home - siteurl Wordpress website $NAME ($final_url): $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log

[[ ${1:-} == "98" ]] && exec /etc/wptt/wptt-wordpress-main 1
