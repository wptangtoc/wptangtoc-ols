function huong_dan() {
  Tối ưu hoá toàn bộ database trong hệ thống
  OPTIMIZE TABLE: Giải Pháp Tối Ưu Hóa Không Gian và Hiệu Suất Cơ Sở Dữ Liệu
  Mục đích chính của OPTIMIZE TABLE:

  * Giảm không gian lưu trữ: Sau nhiều thao tác chèn, cập nhật hoặc xóa dữ liệu, các bảng có thể bị phân mảnh hoặc chứa nhiều không gian không được sử dụng. OPTIMIZE TABLE giúp thu hồi lại không gian thừa này.
  * Cải thiện hiệu quả I/O: Bằng cách chống phân mảnh dữ liệu và chỉ mục, lệnh này giúp giảm thiểu số lượng thao tác đọc/ghi [I/O] cần thiết khi truy cập bảng, từ đó tăng tốc độ truy vấn.
  Cập nhật thống kê chỉ mục: OPTIMIZE TABLE thường cập nhật các thông tin thống kê về chỉ mục, giúp bộ tối ưu hóa truy vấn của DBMS đưa ra các kế hoạch thực thi hiệu quả hơn.
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null # Nạp thư viện UX Bo Cong

# Dọn màn hình nếu chạy bằng tay (Nếu chạy bằng Cronjob sẽ tự bỏ qua)
if [ -t 1 ]; then clear; fi

echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}QUẢN LÝ DATABASE ➜ Tối ưu hóa toàn bộ Hệ thống (Optimize All)${C_RESET}"
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

if [[ "${1:-}" == '98' ]]; then
  WPTT_IN_MENU="yes"
  WPTT_MENU_BACK="/etc/wptt/wptt-db-main 1"
fi

# Chốt chặn an toàn
wptt_check_mariadb || wptt_die "MariaDB đang bị sập! Hệ thống từ chối cho phép chạy tiến trình tối ưu hóa."

# ==============================================================================
# BẢNG THÔNG TIN TIẾN TRÌNH
# ==============================================================================
echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
left_text "Tiến trình này sẽ quét toàn bộ Database trên máy chủ để:" 2
left_text "  1. Chống phân mảnh (Defrag) và thu hồi dung lượng thừa." 2
left_text "  2. Tái tạo lại chỉ mục (Rebuild Index) tăng tốc độ truy vấn." 2
left_text "  3. Tự động sửa chữa (Auto-repair) các Bảng bị lỗi." 2
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

# ==============================================================================
# XÁC ĐỊNH LỆNH VÀ TẠO CHỨNG CHỈ (CREDENTIALS) BẢO MẬT
# ==============================================================================
if command -v mariadb-check &>/dev/null; then
  DB_CHECK_CMD="mariadb-check"
else
  DB_CHECK_CMD="mysqlcheck"
fi

TEMP_CNF_ROOT=$(mktemp)
chmod 600 "$TEMP_CNF_ROOT" # Chỉ root mới đọc được

cat >"$TEMP_CNF_ROOT" <<EOF
[client]
user=${database_admin_username}
password=${database_admin_password}
host=localhost
EOF

# Cơ chế an toàn: Tự động xóa file khi script kết thúc hoặc bị hủy
trap "rm -f \"$TEMP_CNF_ROOT\"" EXIT

# ==============================================================================
# THỰC THI TỐI ƯU HÓA HÀNG LOẠT
# ==============================================================================
_runing "Đang tiến hành tối ưu hóa toàn bộ Database (Tiến trình có thể chạy lâu)..."

# Chạy lệnh và giấu output rối mắt vào file log tạm
$DB_CHECK_CMD --defaults-extra-file="$TEMP_CNF_ROOT" --optimize --auto-repair --all-databases \
  --skip-database="information_schema" \
  --skip-database="performance_schema" \
  --skip-database="sys" \
  --skip-database="mysql" >/tmp/wptt_db_optimize.log 2>&1

status=$?

if [[ $status -eq 0 ]]; then
  _rundone "Tối ưu hóa Database hoàn tất (Không phát hiện lỗi phần cứng)."
else
  _runloi "Tối ưu hóa hoàn tất nhưng có một vài cảnh báo (Warnings)."
  echo -e "${C_YELLOW}  ➜ Lưu ý: Cảnh báo 'Table does not support optimize' trên engine${C_RESET}"
  echo -e "${C_YELLOW}    InnoDB là điều hoàn toàn bình thường và hệ thống đã tự động${C_RESET}"
  echo -e "${C_YELLOW}    chuyển sang lệnh Recreate + Analyze thay thế an toàn!${C_RESET}"
  echo -e "${C_CYAN}  ➜ Xem chi tiết log tại: /tmp/wptt_db_optimize.log${C_RESET}"
fi

# Xóa file xác thực
rm -f "$TEMP_CNF_ROOT"

echo "Tối ưu hoá ALL database : $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log

# ==============================================================================
# BẢNG BÁO CÁO THÀNH CÔNG
# ==============================================================================
echo -e "\n${C_GREEN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_BOLD_WHITE}HOÀN TẤT TỐI ƯU HÓA HỆ THỐNG DATABASE${C_RESET}"
echo -e "${C_GREEN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
left_text "Kho dữ liệu đã được sắp xếp lại, rác đã dọn sạch. Máy chủ sẽ" 2
left_text "hoạt động trơn tru, nhẹ nhàng và phản hồi truy vấn nhanh hơn!" 2
echo -e "${C_GREEN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

# Chỉ yêu cầu nhấn Enter nếu chạy qua giao diện Menu
if [[ "${1:-}" == "98" ]]; then
  exec /etc/wptt/wptt-db-main 1
fi
