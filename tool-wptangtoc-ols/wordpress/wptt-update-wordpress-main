draw_custom_grid() {
  print_row "" "CẬP NHẬT & KIỂM TRA" "" "CÀI LẠI & HẠ CẤP"
  print_row "1" "${options[0]}" "4" "${options[3]}"
  print_row "2" "${options[1]}" "5" "${options[4]}"
  print_row "3" "${options[2]}" "7" "${options[6]}"
  print_row "6" "${options[5]}" "8" "${options[7]}"
  print_row "9" "${options[8]}" ""  ""
}

