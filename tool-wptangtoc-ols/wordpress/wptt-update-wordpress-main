function huong_dan() {
  Tính năng quản lý cập nhật WordPress là một hệ thống toàn diện được tích hợp trong wptangtoc ols để phục vụ hỗ trợ việc quản lý cập nhật của riêng WordPress, giúp người quản trị website dễ dàng theo dõi, kiểm soát và thực hiện việc nâng cấp cho tất cả các thành phần cốt lõi của website, bao gồm: lõi WordPress [core], [themes], và các [plugins].

  Tại sao quản lý cập nhật hiệu quả lại quan trọng?
  * Bảo mật Vững chắc: Giữ cho mọi thành phần của website luôn được vá lỗi bảo mật mới nhất.
  * Ổn định và Tương thích: Đảm bảo các thành phần hoạt động hài hòa với nhau, giảm thiểu xung đột.
  * Tiếp cận Tính năng Mới: Giúp bạn tận dụng được những cải tiến và chức năng mới nhất.
  * Quy trình Làm việc Tối ưu: Đơn giản hóa và hợp lý hóa công việc bảo trì website.

  Tóm lại: Tính năng quản lý cập nhật của WordPress là một công cụ mạnh mẽ và thân thiện, giúp người quản trị website duy trì một trang web an toàn, ổn định, hiện đại và hoạt động hiệu quả bằng cách đơn giản hóa việc theo dõi và áp dụng các bản nâng cấp cần thiết cho toàn bộ hệ thống.
}

if [[ -z "$1" ]]; then
  . /etc/wptt/wptt-header-menu
  header_menu
else
  clear
  . /etc/wptt/echo-color 2>/dev/null
  echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
  
  # Hàm vẽ tiêu đề phụ lọt lòng 78 (chống lệch UTF-8)
  center_tmp() {
    local text="$1"
    local clean_len=$(echo -en "$text" | sed "s/\x1B\[[0-9;]*[a-zA-Z]//g" | tr -d '\r\n')
    local len=$(LC_ALL=C.UTF-8 printf "%s" "$clean_len" | wc -m | tr -d ' ' 2>/dev/null)
    [[ -z "$len" || "$len" == "0" ]] && len=${#clean_len}
    
    local pad_left=$(((78 - len) / 2))
    local pad_right=$((78 - len - pad_left))
    printf "${C_CYAN}│${C_RESET}%*s%b%*s${C_CYAN}│${C_RESET}\n" "$pad_left" "" "$text" "$pad_right" ""
  }
  
  center_tmp "${C_YELLOW}TRUNG TÂM QUẢN LÝ CẬP NHẬT (WORDPRESS UPDATE)${C_RESET}"
  echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯${C_RESET}"
fi

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null

echo ""
echo "$quan_ly_cap_nhat_wordpress" > /dev/null # Dữ liệu ẩn cho bộ tìm kiếm WPTangToc

# ==============================================================================
# TẠO MENU 2 CỘT (TRÁI: CẬP NHẬT/KIỂM TRA | PHẢI: CÀI LẠI/HẠ CẤP)
# ==============================================================================
MENU_TITLE="TRUNG TÂM QUẢN LÝ CẬP NHẬT WORDPRESS"

options=(
  "$cap_nhat WordPress core"                  # 0 (Hiện: 1)
  "$cap_nhat plugins"                         # 1 (Hiện: 2)
  "$cap_nhat themes"                          # 2 (Hiện: 3)
  "$cai_lai wordpress core"                   # 3 (Hiện: 4)
  "$cai_lai wordpress All"                    # 4 (Hiện: 5)
  "$cap_nhat wordpress all website WordPress" # 5 (Hiện: 6)
  "Hạ cấp Core WordPress"                     # 6 (Hiện: 7)
  "Hạ cấp Plugin WordPress"                   # 7 (Hiện: 8)
  "$kiem_tra $phien_ban WordPress"            # 8 (Hiện: 9)
)

# Hàm thực thi hành động
run_action() {
  local index=$1
  local script_path=""
  local script_args="98"

  case $index in
  0) script_path="/etc/wptt/wordpress/update-core" ;;
  1) script_path="/etc/wptt/wordpress/update-plugin" ;;
  2) script_path="/etc/wptt/wordpress/update-theme" ;;
  3) script_path="/etc/wptt/wordpress/ghi-de-wordpress-core" ;;
  4) script_path="/etc/wptt/wordpress/wptt-update-reinstall-wordpress" ;;
  5) script_path="/etc/wptt/wordpress/update-full" ;;
  6) script_path="/etc/wptt/wordpress/ha-cap-phien-ban-wordpress-core" ;;
  7) script_path="/etc/wptt/wordpress/ha-cap-phien-ban-plugins" ;;
  8) script_path="/etc/wptt/wordpress/kiem-tra-version-wp" ;;
  *)
    echo -e "\n${C_RED}[!] ${lua_chon_khong_hop_le:-Lựa chọn không hợp lệ}: Index $index.${C_RESET}"
    return 1
    ;;
  esac

  # Kiểm tra và chạy script con
  if [[ -x "$script_path" || -f "$script_path" ]]; then
    exec bash "$script_path" "$script_args"
  else
    echo -e "\n${C_RED}[!] Lỗi: Không tìm thấy kịch bản '$script_path'.${C_RESET}"
    sleep 2
    exec /etc/wptt/wordpress-update-main 1
  fi
}

