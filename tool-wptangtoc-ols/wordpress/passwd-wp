#!/bin/bash

function huong_dan() {
  Tính năng giúp bạn thay đổi mật khẩu WordPress tài khoản administrator một cách dễ dàng

  Tính năng thay đổi mật khẩu administrator WordPress là một chức năng cơ bản và cực kỳ quan trọng để bảo vệ website của bạn. Nó cho phép người quản trị [admin] hoặc người dùng có quyền tương ứng cập nhật mật khẩu đăng nhập vào khu vực quản trị WordPress.

  Mục đích chính và tầm quan trọng:

  Bảo mật:
  * Thay đổi mật khẩu định kỳ hoặc khi nghi ngờ có dấu hiệu bị xâm nhập giúp ngăn chặn truy cập trái phép.
  * Đảm bảo chỉ những người được ủy quyền mới có thể vào quản trị website.

  Quản lý truy cập:
  * Khi bàn giao website hoặc khi có sự thay đổi về nhân sự quản trị, việc đổi mật khẩu là cần thiết.
  * Khi người dùng quên mất khẩu WordPress Admin có thể reset khôi phục lại.

  Việc thay đổi mật khẩu admin là một thao tác đơn giản nhưng thiết yếu để duy trì bảo đảm bảo mật cho website WordPress của bạn. Nên sử dụng mật khẩu mạnh và thay đổi định kỳ hoặc khi cần thiết.
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null # Nạp thư viện UI Xác nhận

clear
echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}${quan_ly_wordpress} ➜ Đổi Mật khẩu wp-admin (Administrator)${C_RESET}"
echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

. /etc/wptt/tenmien-only-website-by-wordpress
lua_chon_NAME "Đổi password admin WordPress"

[[ "$NAME" == "0" || -z "$NAME" ]] && exec /etc/wptt/wptt-wordpress-main 1

if [[ ! -f "/etc/wptt/vhost/.$NAME.conf" ]]; then
  echo -e "\n${C_RED}❌ Tên miền không tồn tại trên hệ thống này!${C_RESET}"
  sleep 3
  exec /etc/wptt/wptt-wordpress-main 1
fi

pathcheckwp="/usr/local/lsws/$NAME/html/wp-load.php"
if [[ ! -f "$pathcheckwp" ]]; then
  echo -e "\n${C_RED}❌ Hệ thống xác nhận website này không sử dụng WordPress!${C_RESET}"
  echo -e "${C_YELLOW}Tính năng này chỉ hoạt động trên mã nguồn WordPress.${C_RESET}"
  sleep 3
  exec /etc/wptt/wptt-wordpress-main 1
fi

# Nạp cấu hình PHP và Vhost
path="/usr/local/lsws/$NAME/html"
. "/etc/wptt/vhost/.$NAME.conf" 2>/dev/null
. /etc/wptt/php/php-cli-domain-config "$NAME" 2>/dev/null

echo "Đổi tài khoản WordPress Admin website $NAME: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log

# ==============================================================================
# HÀM MENU LỌC VÀ CHỌN TÀI KHOẢN ADMIN (UX BO CONG)
# ==============================================================================
function lua_chon_user() {
  admin_id=""
  local selects=()
  local box_inner_width=${box_inner_width:-71}

  _runing "Đang quét danh sách tài khoản Administrator..."
  mapfile -t selects < <(sudo -u "$User_name_vhost" "/usr/local/lsws/lsphp${phien_ban_php_domain_thuc_thi}/bin/php" /usr/local/bin/wp user list --role=administrator --field=user_login --path="$path" 2>/dev/null | sort -u)
  _rundone "Quét dữ liệu hoàn tất"

  if [[ ${#selects[@]} -eq 0 ]]; then
    echo -e "\n${C_RED}❌ Lỗi: Không xác định được user administrator nào trên website này!${C_RESET}"
    sleep 3
    exec /etc/wptt/wptt-wordpress-main 1
  fi

  echo -e "\n${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
  local title_text="Lựa chọn tài khoản bạn muốn đổi Mật khẩu:"
  local len=$(echo -n "$title_text" | awk '{print length($0)}')
  local pad_r=$((box_inner_width - len - 2))
  [[ $pad_r -lt 0 ]] && pad_r=0
  echo -e "${C_CYAN}│${C_RESET}  ${C_YELLOW}${title_text}${C_RESET}$(printf '%*s' "$pad_r" "")${C_CYAN}│${C_RESET}"

  local line_len=$((len + 3))
  local pad_line_r=$((box_inner_width - line_len))
  [[ $pad_line_r -lt 0 ]] && pad_line_r=0
  local short_line=$(printf "%${line_len}s" "" | sed 's/ /─/g')
  echo -e "${C_CYAN}├${short_line}$(printf '%*s' "$pad_line_r" "")│${C_RESET}"

  local i=1
  for usr in "${selects[@]}"; do
    local item_text=$(printf "  ${C_CYAN}%3d)${C_RESET} ${C_BOLD_WHITE}%s${C_RESET}" "$i" "$usr")
    local clean_text=$(printf "  %3d) %s" "$i" "$usr")
    local item_len=$(echo -n "$clean_text" | awk '{print length($0)}')
    local pad=$((box_inner_width - item_len))
    [[ $pad -lt 0 ]] && pad=0
    echo -e "${C_CYAN}│${C_RESET}${item_text}$(printf '%*s' "$pad" "")${C_CYAN}│${C_RESET}"
    ((i++))
  done
  echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯${C_RESET}"

  local fzf_installed=false
  if command -v fzf &>/dev/null; then
    fzf_installed=true
    PROMPT_TEXT="Nhập lựa chọn (1-${#selects[@]}) [00=Tìm nhanh] [0=Thoát]: "
  else
    PROMPT_TEXT="Nhập lựa chọn (1-${#selects[@]}) [0=Thoát]: "
  fi

  while true; do
    echo -en "${C_CYAN}${PROMPT_TEXT}${C_RESET}"
    if ! read -r REPLY; then exit 1; fi
    REPLY=$(echo "$REPLY" | tr -d ' ' | tr '[:upper:]' '[:lower:]')

    case "$REPLY" in
    0)
      echo -e "\n${C_GREEN}Đang thoát...${C_RESET}"
      admin_id="0"
      return 0
      ;;
    00)
      if $fzf_installed; then
        local selected_name=$(printf '%s\n' "${selects[@]}" | nl -w 3 -s ': ' | fzf --prompt="Tìm tài khoản >> " --height=40% --border=rounded --color=border:red --cycle --reverse)
        selected_name=$(echo "$selected_name" | sed 's/^[[:space:]]*[0-9]\+\:[[:space:]]*//')
        if [[ -n "$selected_name" ]]; then
          admin_id="$selected_name"
          return 0
        else echo -e "${C_YELLOW}Đã hủy chọn. Vui lòng chọn lại.${C_RESET}"; fi
      else
        echo -e "${C_RED}Lỗi: FZF chưa cài đặt.${C_RESET}"
      fi
      ;;
    *)
      if [[ "$REPLY" =~ ^[0-9]+$ ]] && [ "$REPLY" -ge 1 ] && [ "$REPLY" -le ${#selects[@]} ]; then
        local action_index=$((REPLY - 1))
        admin_id="${selects[$action_index]}"
        return 0
      else
        echo -e "\n${C_RED}❌ Lựa chọn không hợp lệ! Vui lòng chọn lại.${C_RESET}"
      fi
      ;;
    esac
  done
}

lua_chon_user

[[ "$admin_id" == "0" || -z "$admin_id" ]] && exec /etc/wptt/wptt-wordpress-main 1

# ==============================================================================
# HÀM NHẬP MẬT KHẨU ẨN KÝ TỰ (MASKING)
# ==============================================================================
function nhap_mat_khau_an() {
  local prompt_text="$1"
  local pass_var=""
  echo -en "${C_CYAN}${prompt_text} ${C_RESET}"
  while IFS= read -r -s -N 1 char; do
    # Enter
    if [[ -z "$char" ]] || [[ "$char" == $'\n' ]] || [[ "$char" == $'\r' ]]; then
      echo
      break
    # Backspace
    elif [[ "$char" == $'\x7f' ]]; then
      if [[ -n "$pass_var" ]]; then
        pass_var="${pass_var%?}"
        echo -ne '\b \b'
      fi
    # Ký tự thường
    else
      pass_var+="$char"
      echo -n '*'
    fi
  done
  eval "$2=\"\$pass_var\""
}

echo ""
echo -e "${C_YELLOW}Lưu ý: Hãy nhập mật khẩu mạnh (chữ hoa, chữ thường, số, ký tự đặc biệt) để đảm bảo an toàn.${C_RESET}"
nhap_mat_khau_an "Nhập mật khẩu mới cho [$admin_id]:" mypassword
nhap_mat_khau_an "Xác nhận lại mật khẩu mới      :" passwordwp2

if [[ "$passwordwp2" != "$mypassword" || -z "$mypassword" ]]; then
  echo -e "\n${C_RED}❌ Lỗi: Hai mật khẩu không khớp nhau hoặc bị bỏ trống!${C_RESET}"
  sleep 3
  exec /etc/wptt/wptt-wordpress-main 1
fi

# ==============================================================================
# XÁC NHẬN VÀ THỰC THI ĐỔI MẬT KHẨU
# ==============================================================================
echo ""
if wptt_xac_nhan "Bạn có chắc chắn muốn thay đổi mật khẩu cho tài khoản này?" "${C_BOLD_WHITE}Tài khoản:${C_RESET} ${C_YELLOW}$admin_id${C_RESET}" "" "Đồng ý Đổi" "Hủy bỏ"; then
  echo ""
  _runing "Đang tiến hành đổi mật khẩu cho tài khoản $admin_id..."

  # Thực thi WP-CLI qua Sudo user Vhost
  sudo -u "$User_name_vhost" "/usr/local/lsws/lsphp${phien_ban_php_domain_thuc_thi}/bin/php" /usr/local/bin/wp user update "${admin_id}" --user_pass="${mypassword}" --path="$path" --allow-root >/dev/null 2>&1

  # Xóa biến mật khẩu khỏi bộ nhớ ngay lập tức
  unset mypassword
  unset passwordwp2

  _rundone "Cập nhật dữ liệu vào Database hoàn tất"

  # ==============================================================================
  # BẢNG BÁO CÁO TỔNG HỢP (UX BO CONG)
  # ==============================================================================
  echo -e "\n${C_GREEN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_BOLD_WHITE}HOÀN TẤT ĐỔI MẬT KHẨU${C_RESET}"
  echo -e "${C_GREEN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
  left_text "Website thao tác : ${C_YELLOW}$NAME${C_RESET}"
  left_text "Tài khoản Admin  : ${C_GREEN}$admin_id${C_RESET}"
  left_text "Trạng thái       : Mật khẩu mới đã được cập nhật thành công."
  echo -e "${C_GREEN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

else
  echo -e "${C_YELLOW}Đã hủy thao tác đổi mật khẩu.${C_RESET}"
fi

[[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-wordpress-main 1
