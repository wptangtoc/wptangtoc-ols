#!/bin/bash

function huong_dan() {
  Tính năng Tùy chỉnh RAM WordPress là khả năng điều chỉnh giới hạn bộ nhớ [RAM] mà mỗi kịch bản [script] PHP của website WordPress được phép sử dụng trong quá trình thực thi.

  Nói một cách đơn giản, đây là việc bạn nới rộng hoặc thu hẹp không gian bộ nhớ RAM mà WordPress [cùng với theme và plugin của nó] có thể mượn từ máy chủ để chạy các tác vụ. Giới hạn này được gọi là memory_limit trong cấu hình PHP.

  Mục Đích Chính
  * Khắc phục lỗi Allowed memory size exhausted: Đây là lý do phổ biến nhất. Khi WordPress, theme hoặc plugin thực hiện một tác vụ nặng [ví dụ: xử lý hình ảnh, chạy các plugin phức tạp như WooCommerce, tạo backup], nó có thể cần nhiều RAM hơn mức được phép mặc định, dẫn đến lỗi nghiêm trọng [thường là màn hình trắng hoặc thông báo lỗi cụ thể]. Tăng giới hạn RAM có thể giải quyết vấn đề này.
  * Đảm bảo hoạt động của Plugin/Theme: Một số plugin hoặc theme nặng, nhiều tính năng yêu cầu một giới hạn RAM PHP tối thiểu để hoạt động trơn tru.
  * Hỗ trợ các tác vụ nặng trong trang quản trị: Các hoạt động trong backend WordPress như cập nhật, quản lý sản phẩm lớn, cũng có thể cần nhiều RAM hơn.
  * Cải thiện sự ổn định [gián tiếp]: Khi có đủ RAM, các script ít bị lỗi giữa chừng, giúp website hoạt động ổn định hơn.

  Sau khi tùy chỉnh, WordPress sẽ có thêm [hoặc bớt] bộ nhớ để hoạt động, giúp giải quyết các lỗi thiếu bộ nhớ và đảm bảo các tác vụ phức tạp có thể hoàn thành.
}

. /etc/wptt/.wptt.conf 2>/dev/null
if [[ $ngon_ngu = '' ]]; then
  ngon_ngu='vi'
fi
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null

tinh_nang_ten="${tang_gioi_han_ram:-Tăng giới hạn RAM} WordPress"
clear
echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}$quan_ly_cap_nhat_wordpress ➜ $tinh_nang_ten${C_RESET}"
echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯${C_RESET}\n"

function lua_chon_NAME() {
  unset NAME
  local selects=()
  local i=1
  local box_inner_width=${box_inner_width:-71}

  # 1. Quét file siêu tốc trên RAM và lấy thông tin RAM hiện tại
  if [ "$(ls -A /etc/wptt/vhost 2>/dev/null)" ]; then
    for filepath in /etc/wptt/vhost/.*.conf; do
      [[ ! -f "$filepath" || "$filepath" == *"/..conf" ]] && continue

      local domain="${filepath##*/}"
      domain="${domain%.conf}"
      domain="${domain#.}"

      if [[ "$domain" == ?*.?* ]]; then
        local wp_config="/usr/local/lsws/$domain/html/wp-config.php"
        if [[ -f "$wp_config" ]]; then
          local ram_giatri=$(grep -E "^[[:space:]]*define[[:space:]]*\([[:space:]]*['\"]WP_MEMORY_LIMIT['\"]" "$wp_config" 2>/dev/null | awk -F"['\"]" '{print $4}' | head -n 1)

          local ram_text=""
          if [[ -n $ram_giatri ]]; then
            ram_text="${ram_giatri}B"
          else
            ram_text="40MB (Mặc định)"
          fi

          # Lưu mảng gộp "Domain|RAM" để dễ sort và xử lý
          selects+=("$domain|$ram_text")
        fi
      fi
    done
  fi

  # 2. Kiểm tra nếu VPS chưa có website nào
  if [[ ${#selects[@]} -eq 0 ]]; then
    echo -e "\n${C_RED}❌ Lỗi: $khong_co_domain_nao_ton_tai_tren_he_thong${C_RESET}"
    exit
  fi

  # 3. Sắp xếp mảng
  mapfile -t selects < <(printf "%s\n" "${selects[@]}" | sort -uV)

  # ============================================================================
  # 4. RENDER KHỐI BO CONG (TAB GẠCH CHÂN CĂN LỀ TRÁI + CHIA CỘT)
  # ============================================================================
  echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"

  local title_text="${lua_chon_website_ban_muon:-Nhập lựa chọn website muốn} ${tang_gioi_han_ram:-tăng RAM}:"
  local clean_title=$(echo -e "$title_text" | sed "s/\x1B\[[0-9;]*[a-zA-Z]//g")
  local len=${#clean_title}
  local pad_r=$((box_inner_width - len - 2))
  [[ $pad_r -lt 0 ]] && pad_r=0

  # In ra Tiêu đề
  echo -e "${C_CYAN}│${C_RESET}  ${C_YELLOW}${title_text}${C_RESET}$(printf '%*s' "$pad_r" "")${C_CYAN}│${C_RESET}"

  # Vẽ đường gạch chân, sử dụng sed thay cho tr để chống lỗi UTF-8
  local line_len=$((len + 3))
  local pad_line_r=$((box_inner_width - line_len))
  [[ $pad_line_r -lt 0 ]] && pad_line_r=0
  local short_line=$(printf "%${line_len}s" "" | sed 's/ /─/g')
  echo -e "${C_CYAN}├${short_line}$(printf '%*s' "$pad_line_r" "")│${C_RESET}"

  # Vòng lặp in danh sách tên miền (Chia 2 cột: Domain và RAM)
  for val in "${selects[@]}"; do
    local d="${val%|*}"
    local r="${val#*|}"

    # %-32s giúp ép độ rộng của Domain luôn là 32 ký tự, đẩy phần RAM thẳng hàng với nhau
    local clean_text=$(printf "  %3d) %-32s [Hiện tại: %s]" "$i" "$d" "$r")
    local item_text=$(printf "  ${C_CYAN}%3d)${C_RESET} ${C_BOLD_WHITE}%-32s${C_RESET} ${C_YELLOW}[Hiện tại: %s]${C_RESET}" "$i" "$d" "$r")

    local len_text=${#clean_text}
    local pad=$((box_inner_width - len_text))
    [[ $pad -lt 0 ]] && pad=0

    echo -e "${C_CYAN}│${C_RESET}${item_text}$(printf '%*s' "$pad" "")${C_CYAN}│${C_RESET}"
    ((i++))
  done
  echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯${C_RESET}"

  # 5. Dòng nhắc lệnh FZF
  local fzf_installed=false
  if command -v fzf &>/dev/null; then
    fzf_installed=true
    PROMPT_TEXT="${lua_chon_website_ban_muon:-Nhập lựa chọn của bạn} (1-${#selects[@]}) [00=${chon_nhanh:-Chọn nhanh}] [0=${exit_thoat:-Thoát}]: "
  else
    PROMPT_TEXT="${lua_chon_website_ban_muon:-Nhập lựa chọn của bạn} (1-${#selects[@]}) [0=${exit_thoat:-Thoát}]: "
  fi

  # 6. NHẬN PHÍM
  while true; do
    echo -en "${C_CYAN}${PROMPT_TEXT}${C_RESET}"
    if ! read -r REPLY; then exit 1; fi
    REPLY=$(echo "$REPLY" | tr -d ' ' | tr '[:upper:]' '[:lower:]')

    case "$REPLY" in
    0) exec /etc/wptt/wptt-wordpress-main 1 ;;
    00)
      if $fzf_installed; then
        local fzf_list=()
        for val in "${selects[@]}"; do
          fzf_list+=("${val%|*} (Đang dùng: ${val#*|})")
        done
        local selected_name=$(printf '%s\n' "${fzf_list[@]}" | nl -w 3 -s ': ' | fzf --height=40% --border=rounded --color=border:red --reverse)
        selected_name=$(echo "$selected_name" | sed 's/^[[:space:]]*[0-9]\+\:[[:space:]]*//' | awk '{print $1}')

        if [[ -n "$selected_name" ]]; then
          NAME="$selected_name"
          return 0
        else
          echo -e "\n${C_YELLOW}Đã hủy chọn. Vui lòng chọn lại.${C_RESET}"
          continue
        fi
      fi
      ;;
    *)
      if [[ "$REPLY" =~ ^[0-9]+$ ]] && [ "$REPLY" -ge 1 ] && [ "$REPLY" -le ${#selects[@]} ]; then
        local val="${selects[$((REPLY - 1))]}"
        NAME="${val%|*}"
        return 0
      elif [[ "$REPLY" == ?*.?* ]] && [[ "$REPLY" != "." ]]; then
        local found=false
        for val in "${selects[@]}"; do
          local d="${val%|*}"
          if [[ "$d" == "$REPLY" ]]; then
            NAME="$d"
            found=true
            break
          fi
        done
        if $found; then return 0; else continue; fi
      else
        continue
      fi
      ;;
    esac
  done
}

lua_chon_NAME

pathcheck="/etc/wptt/vhost/.$NAME.conf"
if [[ ! -f "$pathcheck" ]]; then
  echo -e "\n${C_RED}❌ Tên miền không tồn tại trên hệ thống này${C_RESET}"
  sleep 3
  exec /etc/wptt/wptt-wordpress-main 1
fi

pathcheckwp="/usr/local/lsws/$NAME/html/wp-load.php"
if [[ ! -f "$pathcheckwp" ]]; then
  echo -e "\n${C_RED}❌ Hệ thống xác nhận bạn không sử dụng WordPress${C_RESET}"
  sleep 3
  exec /etc/wptt/wptt-wordpress-main 1
fi

echo ""
# Tút lại giao diện nhập RAM bằng màu sắc đồng bộ
echo -en "${C_CYAN}Nhập dung lượng RAM (MB) bạn muốn cấp cho ${C_BOLD_WHITE}$NAME${C_CYAN} (VD: 256, 512, 1024) [0=$exit_thoat]: ${C_RESET}"
read -r ram_number

if [[ $ram_number = '0' || $ram_number = '' ]]; then
  exec /etc/wptt/wptt-wordpress-main 1
fi

ram_number=$(echo "$ram_number" | sed -E 's/[mM][bB]?|[[:space:]]//g')

if [[ ! "$ram_number" =~ ^[0-9]+$ ]]; then
  echo -e "\n${C_RED}❌ Nhập sai định dạng. Vui lòng nhập số nguyên (VD: 512).${C_RESET}"
  if [[ ${1:-} = "98" ]]; then
    read -p "Bấm phím Enter để quay lại Menu..." enter
    exec /etc/wptt/wptt-wordpress-main 1
  fi
  exit
fi

echo ""
_runing "Tăng giới hạn Ram WordPress website $NAME thành ${ram_number}MB"

. /etc/wptt/vhost/.$NAME.conf
. /etc/wptt/php/php-cli-domain-config $NAME

WP_EXEC="sudo -u $User_name_vhost /usr/local/lsws/lsphp${phien_ban_php_domain_thuc_thi}/bin/php /usr/local/bin/wp"

$WP_EXEC config set WP_MEMORY_LIMIT "${ram_number}M" --path=/usr/local/lsws/$NAME/html --allow-root >/dev/null 2>&1
$WP_EXEC config set WP_MAX_MEMORY_LIMIT "${ram_number}M" --path=/usr/local/lsws/$NAME/html --allow-root >/dev/null 2>&1
$WP_EXEC eval 'opcache_reset();' --path=/usr/local/lsws/$NAME/html --allow-root >/dev/null 2>&1

_rundone "Tăng giới hạn Ram WordPress website $NAME thành ${ram_number}MB"

if [[ ${1:-} = "98" ]]; then
  exec /etc/wptt/wptt-wordpress-main 1
fi
