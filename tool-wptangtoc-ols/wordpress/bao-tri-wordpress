#!/bin/bash

function huong_dan() {
  1. Tính Năng Bật Bảo Trì WordPress [Enable WordPress Maintenance Mode]
  Bật bảo trì WordPress là quá trình kích hoạt một trạng thái tạm thời cho website WordPress của bạn, trong đó khách truy cập thông thường sẽ thấy một trang thông báo [ví dụ: Website đang được bảo trì, vui lòng quay lại sau] thay vì nội dung website chính.

  Trong khi đó, quản trị viên [admin] thường vẫn có thể truy cập vào khu vực quản trị [backend] để thực hiện các công việc cần thiết.

  Mục đích chính:
  * Thực hiện cập nhật lớn: An toàn khi cập nhật WordPress core, theme, plugin quan trọng.
  * Phát triển/Thiết kế lại: Khi đang có những thay đổi lớn về giao diện hoặc chức năng.
  * Sửa lỗi nghiêm trọng: Ngăn người dùng gặp phải lỗi trong khi bạn đang khắc phục.
  * Ngăn chặn tương tác không mong muốn: Tránh việc người dùng gửi dữ liệu hoặc thực hiện giao dịch trong quá trình thay đổi có thể ảnh hưởng đến dữ liệu.
  Kết quả: Khách truy cập sẽ thấy trang bảo trì [thường với mã trạng thái HTTP 503, tốt cho SEO], trong khi quản trị viên có thể làm việc ở backend.

  2. Tính Năng Tắt Bảo Trì WordPress [Disable WordPress Maintenance Mode]
  Tắt bảo trì WordPress là quá trình vô hiệu hóa chế độ bảo trì, đưa website WordPress trở lại trạng thái hoạt động bình thường và cho phép tất cả khách truy cập có thể vào xem nội dung.

  Mục đích chính:
  * Khi công việc bảo trì, cập nhật, hoặc sửa lỗi đã hoàn tất.
  * Website đã ổn định và sẵn sàng phục vụ người dùng.

  Kết quả: Trang thông báo bảo trì sẽ biến mất, và website của bạn sẽ hoạt động trở lại bình thường, chào đón tất cả khách truy cập.
}

. /etc/wptt/.wptt.conf 2>/dev/null
if [[ -z "$ngon_ngu" ]]; then ngon_ngu='vi'; fi
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions

clear
echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}$quan_ly_wordpress ➜ ${bat} / ${tat} ${che_do_bao_tri}${C_RESET}"
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯${C_RESET}\n"

# ==============================================================================
# HÀM CHỌN WEBSITE HIỂN THỊ TRẠNG THÁI (UX TAB GẠCH CHÂN)
# ==============================================================================
function lua_chon_NAME() {
  unset NAME
  local selects=()
  local i=1
  local box_inner_width=${box_inner_width:-71}

  # Quét file siêu tốc trên RAM (Check trực tiếp file .maintenance thay vì gọi wp-cli cho nhanh)
  if [ "$(ls -A /etc/wptt/vhost 2>/dev/null)" ]; then
    for filepath in /etc/wptt/vhost/.*.conf; do
      [[ ! -f "$filepath" || "$filepath" == *"/..conf" ]] && continue

      local domain="${filepath##*/}"
      domain="${domain%.conf}"
      domain="${domain#.}"

      if [[ "$domain" == ?*.?* ]]; then
        local path_html="/usr/local/lsws/$domain/html"
        if [[ -f "$path_html/wp-load.php" ]]; then
          local status_text=""
          local status_color=""

          if [[ -f "$path_html/.maintenance" ]]; then
            status_text="[Đang BẢO TRÌ]"
            status_color=$C_RED
          else
            status_text="[BÌNH THƯỜNG - Online]"
            status_color=$C_GREEN
          fi

          selects+=("$domain|$status_text|$status_color")
        fi
      fi
    done
  fi

  if [[ ${#selects[@]} -eq 0 ]]; then
    echo -e "\n${C_RED}❌ Lỗi: $khong_co_domain_nao_ton_tai_tren_he_thong${C_RESET}"
    sleep 3
    exec /etc/wptt/wptt-wordpress-main 1
  fi

  mapfile -t selects < <(printf "%s\n" "${selects[@]}" | sort -uV)

  # RENDER BOX CHỌN DOMAIN
  echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
  local title_text="${lua_chon_website_ban_muon:-Nhập lựa chọn website của bạn}:"
  local clean_title=$(echo -e "$title_text" | sed "s/\x1B\[[0-9;]*[a-zA-Z]//g")
  local len=${#clean_title}
  local pad_r=$((box_inner_width - len - 2))
  [[ $pad_r -lt 0 ]] && pad_r=0

  echo -e "${C_CYAN}│${C_RESET}  ${C_YELLOW}${title_text}${C_RESET}$(printf '%*s' "$pad_r" "")${C_CYAN}│${C_RESET}"

  # Đường gạch chân bằng sed chống lỗi UTF-8
  local line_len=$((len + 3))
  local pad_line_r=$((box_inner_width - line_len))
  [[ $pad_line_r -lt 0 ]] && pad_line_r=0
  local short_line=$(printf "%${line_len}s" "" | sed 's/ /─/g')
  echo -e "${C_CYAN}├${short_line}$(printf '%*s' "$pad_line_r" "")│${C_RESET}"

  for val in "${selects[@]}"; do
    IFS='|' read -r d s c <<<"$val"
    local clean_row=$(printf "  %3d) %-32s %s" "$i" "$d" "$s")
    local item_row=$(printf "  ${C_CYAN}%3d)${C_RESET} ${C_BOLD_WHITE}%-32s${C_RESET} ${c}%s${C_RESET}" "$i" "$d" "$s")
    local pad=$((box_inner_width - ${#clean_row}))
    [[ $pad -lt 0 ]] && pad=0

    echo -e "${C_CYAN}│${C_RESET}${item_row}$(printf '%*s' "$pad" "")${C_CYAN}│${C_RESET}"
    ((i++))
  done
  echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯${C_RESET}"

  local fzf_installed=false
  command -v fzf &>/dev/null && fzf_installed=true
  local prompt_msg="${lua_chon_website_ban_muon:-Nhập lựa chọn} (1-${#selects[@]}) [00=${chon_nhanh:-Chọn nhanh}] [0=${exit_thoat:-Thoát}]: "

  while true; do
    echo -en "${C_CYAN}${prompt_msg}${C_RESET}"
    if ! read -r REPLY; then exit 1; fi
    REPLY=$(echo "$REPLY" | tr -d ' ' | tr '[:upper:]' '[:lower:]')

    case "$REPLY" in
    0) exec /etc/wptt/wptt-wordpress-main 1 ;;
    00)
      if $fzf_installed; then
        local fzf_list=()
        for val in "${selects[@]}"; do
          IFS='|' read -r d s c <<<"$val"
          fzf_list+=("$d $s")
        done
        local sel=$(printf '%s\n' "${fzf_list[@]}" | nl -w 3 -s ': ' | fzf --height=40% --border=rounded --reverse)
        NAME=$(echo "$sel" | sed 's/^[[:space:]]*[0-9]\+\:[[:space:]]*//' | awk '{print $1}')
        [[ -n "$NAME" ]] && return 0 || continue
      fi
      ;;
    *)
      if [[ "$REPLY" =~ ^[0-9]+$ ]] && [ "$REPLY" -ge 1 ] && [ "$REPLY" -le ${#selects[@]} ]; then
        local val="${selects[$((REPLY - 1))]}"
        NAME="${val%|*|*}"
        return 0
      elif [[ "$REPLY" == ?*.?* ]]; then
        NAME="$REPLY"
        return 0
      fi
      ;;
    esac
  done
}

lua_chon_NAME

pathcheck="/etc/wptt/vhost/.$NAME.conf"
if [[ ! -f "$pathcheck" ]]; then
  echo -e "\n${C_RED}❌ Tên miền không tồn tại trên hệ thống này${C_RESET}"
  sleep 3
  exec /etc/wptt/wptt-wordpress-main 1
fi

path_html="/usr/local/lsws/$NAME/html"
if [[ ! -f "$path_html/wp-load.php" ]]; then
  echo -e "\n${C_RED}❌ Hệ thống xác nhận website không sử dụng WordPress.${C_RESET}"
  sleep 3
  exec /etc/wptt/wptt-wordpress-main 1
fi

# ==============================================================================
# XỬ LÝ LOGIC BẬT / TẮT BẢO TRÌ
# ==============================================================================
. /etc/wptt/php/php-cli-domain-config $NAME
. /etc/wptt/vhost/.$NAME.conf

WP_EXEC="sudo -u $User_name_vhost /usr/local/lsws/lsphp${phien_ban_php_domain_thuc_thi}/bin/php /usr/local/bin/wp"

# Check trạng thái qua file để ra quyết định ngược lại
if [[ -f "$path_html/.maintenance" ]]; then
  action_text="${tat:-TẮT} ${che_do_bao_tri:-chế độ bảo trì} (Online)"
  wp_cmd="deactivate"
  content="Xác nhận tắt bảo trì website ${NAME}?"
  content2="Đồng ý tắt bảo trì website $NAME"
else
  action_text="${bat:-BẬT} ${che_do_bao_tri:-chế độ bảo trì} (Offline)"
  wp_cmd="activate"
  content="Xác nhận bật bảo trì website ${NAME}?"
  content2="Đồng ý bật bảo trì website $NAME"
fi

if ! wptt_xac_nhan "$content" "" "" "$content2" "Không đồng ý (Hủy thao tác)"; then
  echo -e "${C_YELLOW}Đã hủy thao tác.${C_RESET}" && sleep 1 && exec /etc/wptt/wptt-wordpress-main 1
fi

echo ""
_runing "$action_text cho $NAME"

# Thực thi bật/tắt bằng WP-CLI chuẩn xác
$WP_EXEC maintenance-mode $wp_cmd --allow-root --path="$path_html" >/dev/null 2>&1

if [[ $wp_cmd = 'deactivate' ]]; then
  rm -f $path_html/.maintenance
fi
# Xóa cache
(/etc/wptt/cache/wptt-xoacache "$NAME" >/dev/null 2>&1)

echo "$action_text website $NAME: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log
_rundone "$action_text cho $NAME"

if [[ ${1:-} == "98" ]]; then
  exec /etc/wptt/wptt-wordpress-main 1
fi
