#!/bin/bash
# @author: Gia Tuấn
# @website: https://wptangtoc.com
# @since: 2026

function huong_dan() {
  Thiết lập kết nối unix socket cho mã nguồn WordPress
}

. /etc/wptt/.wptt.conf
. /etc/wptt/echo-color

echo -e "\n========================================================================="
echo -e "| Quản lý WordPress => Chuyển đổi unix socket database                  |"
echo -e "=========================================================================\n"

NAME=$1
[[ "$NAME" == "98" ]] && NAME=""

if [[ -z "$NAME" ]]; then
  . /etc/wptt/tenmien-them-lua-chon-tat-ca-website-by-wordpress
  echo -e "\nLựa chọn website muốn chuyển đổi unix socket database: \n"
  lua_chon_NAME
fi

# ==============================================================================
# KHỐI TẤT CẢ WEBSITE
# ==============================================================================
if [[ "$NAME" == 'Tất cả website' ]]; then
  for filepath in /etc/wptt/vhost/.*.conf; do
    [[ ! -f "$filepath" || "$filepath" == *"/..conf" ]] && continue

    domain="${filepath##*/}"
    domain="${domain%.conf}"
    domain="${domain#.}"

    if [[ "$domain" == ?*.?* ]]; then
      if [[ -f "/usr/local/lsws/$domain/html/wp-config.php" ]]; then
        _runing "Chuyển đổi unix-socket database website $domain"
        (/etc/wptt/wordpress/unix-stocket-wpconfig "$domain" >/dev/null 2>&1)
        _rundone "Chuyển đổi unix-socket database website $domain"
      fi
    fi
  done

  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-wordpress-main 1
  exit
fi

# --- CHỐT CHẶN THOÁT HIỂM ---
[[ "$NAME" == "0" || -z "$NAME" ]] && exec /etc/wptt/wptt-wordpress-main 1

pathcheck="/etc/wptt/vhost/.$NAME.conf"
if [[ ! -f "$pathcheck" ]]; then
  clear
  echoDo "Domain không tồn tại trên hệ thống."
  sleep 3
  exec /etc/wptt/wptt-wordpress-main 1
fi

pathcheckwp="/usr/local/lsws/$NAME/html/wp-load.php"
if [[ ! -f "$pathcheckwp" ]]; then
  clear
  echoDo "Hệ thống xác nhận bạn không sử dụng WordPress"
  echoDo "Tính năng này chỉ có thể hoạt động trên WordPress"
  sleep 3
  exec /etc/wptt/wptt-wordpress-main 1
fi

wp_config_file="/usr/local/lsws/$NAME/html/wp-config.php"
if [[ ! -f "$wp_config_file" ]]; then
  clear
  echoDo "Không tìm thấy file wp-config.php"
  sleep 3
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-wordpress-main 1
  exit 1
fi

# 1. Kiểm tra xem đã kích hoạt socket chưa (Dùng grep -q chạy ngầm)
if grep -qE "^[[:space:]]*define[[:space:]]*\([[:space:]]*['\"]DB_HOST['\"].*\.sock" "$wp_config_file" 2>/dev/null; then
  echo "Đã kích hoạt socket database trước đó."
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-wordpress-main 1
  exit 0
fi

UI_STRING="Chuyển đổi unix socket database cho website $NAME"
_runing "$UI_STRING"

. "$pathcheck"

# 2. Kiểm tra hệ điều hành chuẩn xác và truy vấn Socket MariaDB
if grep -qi "ubuntu" /etc/*release 2>/dev/null; then
  DEFAULT_SOCK="/run/mysqld/mysqld.sock"
else
  DEFAULT_SOCK="/var/lib/mysql/mysql.sock"
fi

# Lấy socket thực tế từ MariaDB, nếu lỗi thì dùng biến dự phòng
REAL_SOCK=$(mariadb -N -e "select @@socket;" 2>/dev/null || echo "$DEFAULT_SOCK")

# Cú pháp Socket của WordPress bắt buộc phải có dấu hai chấm (:) ở đầu
sock_path=":${REAL_SOCK}"

. /etc/wptt/php/php-cli-domain-config $NAME

# 3. Mở khóa file (nếu có tính năng lock_down) trước khi dùng WP-CLI
[[ -n "$lock_down" ]] && chattr -i "$wp_config_file" 2>/dev/null

sudo -u "$User_name_vhost" /usr/local/lsws/lsphp${phien_ban_php_domain_thuc_thi}/bin/php /usr/local/bin/wp config set DB_HOST "$sock_path" --path="/usr/local/lsws/$NAME/html" >/dev/null 2>&1

# 4. Khóa file lại
[[ -n "$lock_down" ]] && chattr +i "$wp_config_file" 2>/dev/null

_rundone "$UI_STRING"

[[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-wordpress-main 1
