#!/bin/bash

function huong_dan() {
  Thiết lập kết nối unix socket cho mã nguồn WordPress
}

echo ""
echo ""
echo ""
echo "========================================================================="
echo "|Quản lý WordPress => Chuyển đổi unix socket database                   |"
echo "========================================================================="
NAME=$1
if [[ $NAME = "98" ]]; then
  NAME=""
fi

if [[ $NAME = "" ]]; then
  . /etc/wptt/tenmien-them-lua-chon-tat-ca-website-by-wordpress
  echo ""
  echo ""
  echo "Lựa chọn website muốn chuyển đổi unix socket database: "
  echo ""
  lua_chon_NAME
fi

if [[ $NAME = 'Tất cả website' ]]; then
  if [ "$(ls -A /etc/wptt/vhost | grep -v '^\.\.conf$' | grep -v '^\.\.conf$' | sort -uV)" ]; then
    for entry in $(ls -A /etc/wptt/vhost | grep -v '^\.\.conf$' | sort -uV); do
      domain=$(echo $entry | sed 's/^.//' | sed 's/.conf//')
      path="/usr/local/lsws/$domain/html/wp-config.php"
      path_html="/usr/local/lsws/$domain/html"
      i=1
      if [ "$domain" != "${domain/./}" ] && [ "$domain" != '.' ]; then #điều kiện domain phải có dấu . và lỗi chỉ có only .
        if [[ -f "$path" ]]; then
          _runing "unix-stocket database website $domain"
          (/etc/wptt/wordpress/unix-stocket-wpconfig $domain >/dev/null 2>&1)
          _rundone "unix-stocket database website $domain"
        fi
      fi
    done
  fi

  check_menu_wptangtoc_active=${1:-}
  if [[ $check_menu_wptangtoc_active = "98" ]]; then
    exec /etc/wptt/wptt-wordpress-main 1
  fi
  exit
fi

. /etc/wptt/echo-color
if [[ "$NAME" = "0" || "$NAME" = "" ]]; then
  exec /etc/wptt/wptt-wordpress-main 1
fi

pathcheck="/etc/wptt/vhost/.$NAME.conf"
if [[ ! -f "$pathcheck" ]]; then
  clear
  echoDo "Domain khong ton tai tren VPS."
  sleep 3
  exec /etc/wptt/wptt-wordpress-main 1
  exit
fi

pathcheckwp="/usr/local/lsws/$NAME/html/wp-load.php"
if [[ ! -f "$pathcheckwp" ]]; then
  clear
  echoDo "Hệ thống xác nhận bạn không sử dụng WordPress"
  echoDo "Tính năng này chỉ có thể hoạt động trên WordPress"
  sleep 3
  exec /etc/wptt/wptt-wordpress-main 1
  exit
fi

wp_config_file="/usr/local/lsws/$NAME/html/wp-config.php"

if [[ ! -f "$wp_config_file" ]]; then
  clear
  echoDo "Hệ thống xác nhận bạn không sử dụng WordPress"
  echoDo "Tính năng này chỉ có thể hoạt động trên WordPress"
  sleep 3
  check_menu_wptangtoc_active=${1:-}
  if [[ $check_menu_wptangtoc_active = "98" ]]; then
    exec /etc/wptt/wptt-wordpress-main 1
  fi
  return 2>/dev/null || exit
fi

# 1. Kiem tra xem da co socket chua (Dung grep -q chay ngam va Regex bọc thép)
# Bỏ qua các dòng comment (//), chỉ tìm đúng dòng lệnh define DB_HOST đang chạy
if grep -qE "^[[:space:]]*define[[:space:]]*\([[:space:]]*['\"]DB_HOST['\"].*\.sock" "$wp_config_file" 2>/dev/null; then
  echo "Đã kích hoạt socket database trước đó"
  check_menu_wptangtoc_active=$1
  if [[ $check_menu_wptangtoc_active = "98" ]]; then
    exec /etc/wptt/wptt-wordpress-main 1
  fi
  return 2>/dev/null || exit
fi

_runing "Chuyển đổi unix socket database"

. /etc/wptt/vhost/.$NAME.conf

# 2. Kiem tra he dieu hanh chuan xac bang file os-release
if grep -iq "ubuntu" /etc/os-release 2>/dev/null; then
  sock_path=":/run/mysqld/mysqld.sock"
else
  sock_path=":/var/lib/mysql/mysql.sock"
fi

# 3. Ghi de thong so DB_HOST bang WP-CLI (An toan 100%)
sudo -u "$User_name_vhost" /usr/local/bin/wp config set DB_HOST "$sock_path" --path="/usr/local/lsws/$NAME/html" >/dev/null 2>&1

_rundone "Chuyển đổi unix socket database"

check_menu_wptangtoc_active=${1:-}
if [[ $check_menu_wptangtoc_active = "98" ]]; then
  exec /etc/wptt/wptt-wordpress-main 1
fi
