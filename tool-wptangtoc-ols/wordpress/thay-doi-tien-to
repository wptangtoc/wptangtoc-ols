#!/bin/bash
# @author: Gia Tuấn
# @website: https://wptangtoc.com
# @since: 2026

function huong_dan() {
  Đây là tính năng thay đổi tiền tố database
  mặc định WordPress sử dụng tiền tố wp_
  tính năng này sẽ thay đổi tiền tố đó sẽ giúp nâng cao bảo mật cho WordPress hơn
}

. /etc/wptt/.wptt.conf
[[ $ngon_ngu == '' ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh

. /etc/wptt/echo-color
. /etc/wptt/core-functions 2>/dev/null

echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_BOLD_WHITE}$quan_ly_wordpress ➜ $thay_doi $tien_to database${C_RESET}"
echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯${C_RESET}\n"

. /etc/wptt/tenmien-only-website-by-wordpress
lua_chon_NAME "$thay_doi $tien_to database"

[[ "$NAME" == "0" || -z "$NAME" ]] && exec /etc/wptt/wptt-wordpress-main 1

path_conf="/etc/wptt/vhost/.$NAME.conf"

# Kiểm tra an toàn bằng khối { ... }
[[ ! -f "$path_conf" ]] && {
  echoDo "Tên miền không tồn tại trên hệ thống này"
  sleep 2
  exec /etc/wptt/wptt-wordpress-main 1
}

path="/usr/local/lsws/$NAME/html"

# Kiểm tra an toàn bằng khối { ... }
[[ ! -f "$path/wp-load.php" ]] && {
  echoDo "Hệ thống xác nhận bạn không sử dụng WordPress"
  echoDo "Tính năng này chỉ có thể hoạt động trên WordPress"
  sleep 2
  exec /etc/wptt/wptt-wordpress-main 1
}

# Kiểm tra Multisite bằng Regex an toàn xuyên comment
check_multisite=$(grep -E "^[[:space:]]*define[[:space:]]*\([[:space:]]*['\"]MULTISITE['\"]" "$path/wp-config.php" 2>/dev/null | awk -F"['\"]" '{print $4}')
if [[ "$check_multisite" == 'true' ]]; then
  echoDo "Tính năng này không hỗ trợ website WordPress Multisite"
  sleep 2
  exec /etc/wptt/wptt-wordpress-main 1
fi

. "$path_conf"
. /etc/wptt/php/php-cli-domain-config $NAME

# Khai báo WP_EXEC chuẩn quyền User
WP_EXEC="sudo -u $User_name_vhost /usr/local/lsws/lsphp${phien_ban_php_domain_thuc_thi}/bin/php /usr/local/bin/wp"

unset NEW_PREFIX OLD_PREFIX dongy

# Sinh tiền tố mới (Sử dụng chữ thường a-z và số để an toàn tuyệt đối với mọi hệ điều hành MySQL)
ramdom_db=$(openssl rand -base64 32 | tr -dc 'a-z0-9' | head -c 5)
NEW_PREFIX="${ramdom_db}_"

# Lấy tiền tố cũ
OLD_PREFIX=$($WP_EXEC db prefix --allow-root --path="$path" 2>/dev/null)
tien_to_cu="$OLD_PREFIX"

# ==============================================================================
# SỬ DỤNG HÀM XÁC NHẬN CHUẨN UX WPTANGTOC OLS
# ==============================================================================
echo ""
if ! wptt_xac_nhan "Bạn có chắc chắn muốn thay đổi tiền tố DB cho $NAME không?" "Tiền tố sẽ được đổi từ ${C_YELLOW}$tien_to_cu${C_RESET} thành ${C_GREEN}${NEW_PREFIX}${C_RESET}" "Lưu ý: Hãy BACKUP website trước khi sử dụng tính năng này! " "Đồng ý (Thay đổi)" "Hủy thao tác"; then
  echo -e "${C_YELLOW}Đã hủy thao tác.${C_RESET}\n"
  [[ ${1:-} == "98" ]] && exec /etc/wptt/wptt-wordpress-main 1
  exit 0
fi

echo ""
wp_config_path="$path/wp-config.php"

# Mở khóa chattr
[[ $lock_down ]] && chattr -i "$wp_config_path"

UI_STRING="$thay_doi $tien_to website $NAME từ $tien_to_cu thành ${NEW_PREFIX}"
_runing "$UI_STRING"

# 1. Lấy danh sách các bảng hiện tại với tiền tố cũ
TABLES=$($WP_EXEC db query "SHOW TABLES LIKE '${OLD_PREFIX}%'" --skip-column-names --allow-root --path="$path" 2>/dev/null)

if [[ -n "$TABLES" ]]; then
  # 2. Đổi tên từng bảng một cách mượt mà (Bịt kín Output)
  for TABLE in $TABLES; do
    NEW_TABLE="${NEW_PREFIX}${TABLE#$OLD_PREFIX}"
    $WP_EXEC db query "RENAME TABLE \`$TABLE\` TO \`$NEW_TABLE\`;" --allow-root --path="$path" >/dev/null 2>&1
  done

  # 3. Cập nhật bảng Options và Usermeta bằng logic SQL chuẩn xác (Bịt kín Output chống rác màn hình)
  $WP_EXEC db query "UPDATE \`${NEW_PREFIX}options\` SET option_name = CONCAT('${NEW_PREFIX}', SUBSTRING(option_name, CHAR_LENGTH('${OLD_PREFIX}') + 1)) WHERE option_name LIKE '${OLD_PREFIX}%';" --allow-root --path="$path" >/dev/null 2>&1
  $WP_EXEC db query "UPDATE \`${NEW_PREFIX}usermeta\` SET meta_key = CONCAT('${NEW_PREFIX}', SUBSTRING(meta_key, CHAR_LENGTH('${OLD_PREFIX}') + 1)) WHERE meta_key LIKE '${OLD_PREFIX}%';" --allow-root --path="$path" >/dev/null 2>&1

  # 4. Sửa file wp-config.php cực an toàn bằng Regex
  sed -i -e "s/\$table_prefix[[:space:]]*=[[:space:]]*['\"][^'\"]*['\"]/\$table_prefix = '${NEW_PREFIX}'/" "$wp_config_path"

  # ================== XÓA CACHE TOÀN DIỆN ==================
  $WP_EXEC eval 'opcache_reset();' --path="$path" --allow-root >/dev/null 2>&1
  (/etc/wptt/cache/wptt-xoa-cache-redis-valkey-keydb >/dev/null 2>&1)
  if [ "$(systemctl is-active memcached.service)" == "active" ]; then
    echo "flush_all" | socat - UNIX-CONNECT:/var/run/memcached/memcached.sock >/dev/null 2>&1
  fi

  # Xác thực lại kết quả
  tien_to_moi=$($WP_EXEC db prefix --allow-root --path="$path" 2>/dev/null)

  if [[ "$tien_to_moi" == "$tien_to_cu" || -z "$tien_to_moi" ]]; then
    _runloi "$UI_STRING"
  else
    _rundone "$UI_STRING"
  fi
else
  _runloi "$UI_STRING (Không tìm thấy Table)"
fi

echo "Thay đổi tiền tố website $NAME: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log

# Đóng khóa chattr
[[ $lock_down ]] && chattr +i "$wp_config_path"

[[ ${1:-} == "98" ]] && exec /etc/wptt/wptt-wordpress-main 1
