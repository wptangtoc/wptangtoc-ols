#!/bin/bash

function huong_dan() {
  Đây là tính năng thay đổi tiền tố database
  mặc định WordPress sử dụng tiền tố wp_
  tính năng này sẽ thay đổi tiền tố đó sẽ giúp nâng cao bảo mật cho WordPress hơn
}

. /etc/wptt/.wptt.conf
[[ $ngon_ngu == '' ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh

. /etc/wptt/echo-color

echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_BOLD_WHITE}$quan_ly_wordpress ➜ $thay_doi $tien_to database${C_RESET}"
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯${C_RESET}\n"

. /etc/wptt/tenmien-only-website-by-wordpress
lua_chon_NAME "$thay_doi $tien_to database"

[[ "$NAME" == "0" || -z "$NAME" ]] && exec /etc/wptt/wptt-wordpress-main 1

path_conf="/etc/wptt/vhost/.$NAME.conf"

# Kiểm tra an toàn bằng khối { ... }
[[ ! -f "$path_conf" ]] && {
  echoDo "Tên miền không tồn tại trên hệ thống này"
  sleep 2
  exec /etc/wptt/wptt-wordpress-main 1
}

path="/usr/local/lsws/$NAME/html"

# Kiểm tra an toàn bằng khối { ... }
[[ ! -f "$path/wp-load.php" ]] && {
  echoDo "Hệ thống xác nhận bạn không sử dụng WordPress"
  echoDo "Tính năng này chỉ có thể hoạt động trên WordPress"
  sleep 2
  exec /etc/wptt/wptt-wordpress-main 1
}

# Kiểm tra Multisite bằng Regex an toàn xuyên comment
check_multisite=$(grep -E "^[[:space:]]*define[[:space:]]*\([[:space:]]*['\"]MULTISITE['\"]" "$path/wp-config.php" 2>/dev/null | awk -F"['\"]" '{print $4}')
if [[ "$check_multisite" == 'true' ]]; then
  echoDo "Tính năng này không hỗ trợ website WordPress Multisite"
  sleep 2
  exec /etc/wptt/wptt-wordpress-main 1
fi

# Kiểm tra và cài đặt Package bằng lệnh WP-CLI chuẩn
if ! /usr/local/bin/wp package list --allow-root 2>/dev/null | grep -qi 'wp-cli-rename-db-prefix'; then
  _runing "Cài đặt WP CLI package rename database"
  /usr/local/bin/wp package install iandunn/wp-cli-rename-db-prefix --allow-root >/dev/null 2>&1
  unset config_download_package_rename_cli && config_download_package_rename_cli='yes'
fi

if [[ $config_download_package_rename_cli = 'yes' ]]; then
  if /usr/local/bin/wp package list --allow-root 2>/dev/null | grep -qi 'wp-cli-rename-db-prefix'; then
    _rundone "Cài đặt WP CLI package rename database"
  else
    _runloi "Cài đặt WP CLI package rename database"
    echo "Chưa cài đặt được WP CLI package rename database"
    echo "Nên không thể sử dụng được tính năng này"
    sleep 3
    [[ ${1:-} == "98" ]] && exec /etc/wptt/wptt-wordpress-main 1
    exit
  fi
fi

. "$path_conf"
. /etc/wptt/php/php-cli-domain-config $NAME

# Khai báo WP_EXEC chuẩn quyền User
WP_EXEC="sudo -u $User_name_vhost /usr/local/lsws/lsphp${phien_ban_php_domain_thuc_thi}/bin/php /usr/local/bin/wp"

unset ramdom_db tien_to_cu dongy
ramdom_db=$(openssl rand -base64 32 | tr -dc 'a-zA-Z0-9' | head -c 5)

# Lấy tiền tố cũ
tien_to_cu=$($WP_EXEC db prefix --allow-root --path="$path" 2>/dev/null)

echo "Lưu ý: Hãy backup website trước khi sử dụng tính năng này!"
echo -e "$xac_nhan $thay_doi $tien_to website $NAME từ $tien_to_cu thành ${ramdom_db}_ ?"
prompt="$nhap_lua_chon_cua_ban [1-2]: "
dongy="n"
options=("$dong_y" "$khong_dong_y")
PS3="$prompt"
select opt in "${options[@]}"; do
  case "$REPLY" in
  1)
    dongy="y"
    break
    ;;
  2)
    dongy="n"
    break
    ;;
  *)
    printf "\n$ban_nhap_sai_he_thong_se_chon_khong_dong_y\n"
    break
    ;;
  esac
done

if [[ "$dongy" == 'y' ]]; then
  wp_config_path="$path/wp-config.php"

  # Mở khóa chattr
  [[ $lock_down ]] && chattr -i "$wp_config_path"

  UI_STRING="$thay_doi $tien_to website $NAME từ $tien_to_cu thành ${ramdom_db}_"
  _runing "$UI_STRING"

  # Thực thi đổi prefix
  $WP_EXEC rename-db-prefix "${ramdom_db}_" --allow-root --path="$path" --no-confirm >/dev/null 2>&1

  # Xóa cache OPcache
  $WP_EXEC eval 'opcache_reset();' --path="$path" --allow-root >/dev/null 2>&1

  #xoa cache object cache
  (/etc/wptt/cache/wptt-xoa-cache-redis-valkey-keydb >/dev/null 2>&1)

  #memcached xoá cache
  if [ "$(systemctl is-active memcached.service)" == "active" ]; then
    echo "flush_all" | socat - UNIX-CONNECT:/var/run/memcached/memcached.sock >/dev/null 2>&1
  fi

  # Xác thực lại tiền tố mới
  tien_to_moi=$($WP_EXEC db prefix --allow-root --path="$path" 2>/dev/null)

  if [[ "$tien_to_moi" == "$tien_to_cu" ]]; then
    _runloi "$UI_STRING"
  else
    _rundone "$UI_STRING"
  fi

  echo "Thay đổi tiền tố website $NAME: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log

  # Đóng khóa chattr
  [[ $lock_down ]] && chattr +i "$wp_config_path"
fi

[[ ${1:-} == "98" ]] && exec /etc/wptt/wptt-wordpress-main 1
