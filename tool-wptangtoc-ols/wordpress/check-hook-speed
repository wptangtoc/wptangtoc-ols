#!/bin/bash

function huong_dan {
  Tính năng kiểm tra tốc độ Hook trong WordPress là công cụ chẩn đoán chuyên sâu [Profiling], giúp đo lường chính xác thời gian thực thi của từng Action và Filter trên website.

  Giải thích ngắn gọn:

  Mọi tính năng của Theme và Plugin đều bám vào các "móc" [Hook] của WordPress để hoạt động. Đôi khi chỉ một đoạn code nhỏ hoặc một Plugin code lởm bám vào hook init hoặc wp_loaded cũng đủ kéo sập toàn bộ tốc độ phản hồi của máy chủ.

  Lợi ích của công cụ này:

  Chỉ điểm chính xác Plugin/Theme nào đang gây nghẽn cổ chai [Nút thắt TTFB].

  Hiển thị thời gian chạy tính bằng giây [s] để bạn quyết định giữ hay xóa Plugin đó.

  Hoạt động ngầm an toàn và không ảnh hưởng đến trải nghiệm của khách truy cập.
}

. /etc/wptt/.wptt.conf
[[ $ngon_ngu == '' ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh

. /etc/wptt/echo-color
tinh_nang_ten="Kiểm tra tốc độ Hook WordPress"

echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_BOLD_WHITE}$quan_ly_wordpress ➜ $tinh_nang_ten${C_RESET}"
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯${C_RESET}\n"

. /etc/wptt/tenmien-only-website-by-wordpress
lua_chon_NAME "$tinh_nang_ten"

[[ "$NAME" == "0" || -z "$NAME" ]] && exec /etc/wptt/wptt-wordpress-main 1

pathcheckwp="/usr/local/lsws/$NAME/html/wp-load.php"
if [[ ! -f "$pathcheckwp" ]]; then
  clear
  echoDo "Hệ thống xác nhận bạn không sử dụng WordPress"
  echoDo "Tính năng này chỉ có thể hoạt động trên WordPress"
  sleep 3
  [[ ${1:-} == "98" ]] && exec /etc/wptt/wptt-wordpress-main 1
  exit
fi

path="/usr/local/lsws/$NAME/html"

# ==============================================================================
# KIỂM TRA VÀ CÀI ĐẶT GÓI WP PROFILE (Bảo vệ Xuyên Thủng Mọi Giới Hạn)
# ==============================================================================

# ==============================================================================
# KIỂM TRA VÀ CÀI ĐẶT GÓI WP PROFILE (Bảo vệ Xuyên Thủng Mọi Giới Hạn)
# ==============================================================================
profile_installed="yes"
if [[ ! -d /root/.wp-cli/packages/vendor/wp-cli/profile-command ]]; then
  echo "Đang cài đặt công cụ chuẩn đoán WP Profile (Vui lòng chờ)..."
  wp package install wp-cli/profile-command --allow-root
fi

echo "-------------------------------------------------------------------------"
echo "Đang phân tích thời gian thực thi Hook của website: $NAME"
echo "MẸO: Hãy chú ý cột 'time'. Danh sách đã được sắp xếp giảm dần,"
echo "những Hook tốn nhiều thời gian nhất sẽ nằm ở trên cùng!"
echo "-------------------------------------------------------------------------"

if [[ "$profile_installed" == "yes" ]]; then
  . /etc/wptt/vhost/.$NAME.conf
  . /etc/wptt/php/php-cli-domain-config $NAME

  # Chạy Profile bằng đúng phiên bản PHP của Domain
  # Thêm các cờ --fields và --orderby để xuất ra kết quả đẹp và dễ đọc nhất
  /usr/local/lsws/lsphp${phien_ban_php_domain_thuc_thi}/bin/php /usr/local/bin/wp profile hook \
    --fields=hook,time,location \
    --orderby=time \
    --reverse \
    --allow-root \
    --path="$path"
else
  echo "❌ Lỗi: Cài đặt gói wp-cli/profile-command thất bại (Do mạng hoặc cấu hình chặn PHP)."
  echo "👉 Vui lòng kiểm tra lại kết nối mạng của VPS hoặc tạm thời tắt chặn các hàm exec/proc_open."
fi

echo "-------------------------------------------------------------------------"
read -p "Bấm phím bất kỳ để quay trở lại menu quản lý WordPress: " enter

[[ ${1:-} == "98" ]] && exec /etc/wptt/wptt-wordpress-main 1
