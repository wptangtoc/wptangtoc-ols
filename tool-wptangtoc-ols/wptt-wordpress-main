# ==============================================================================
# KIỂM TRA SỰ TỒN TẠI CỦA WORDPRESS TRÊN HỆ THỐNG
# ==============================================================================
found_wp=0

for filepath in /etc/wptt/vhost/.*.conf; do

  [[ ! -f "$filepath" || "$filepath" == *"/..conf" ]] && continue

  domain="${filepath##*/}"
  domain="${domain%.conf}"
  domain="${domain#.}"

  if [[ "$domain" == ?*.?* ]] && [[ -f "/usr/local/lsws/$domain/html/wp-load.php" ]]; then
    found_wp=1
    break
  fi

done

if [[ $found_wp -eq 0 ]]; then
  echo ""
  echo -e "\033[1;31m[CẢNH BÁO] Hệ thống chưa phát hiện website WordPress nào!\033[0m"
  echo -e "\033[1;33mVui lòng cài đặt WordPress trước khi sử dụng các tính năng quản trị này.\033[0m"
  echo ""
  echo -e "Đang quay trở lại Menu chính..."
  sleep 3

  exec /usr/bin/wptangtoc 1
fi

