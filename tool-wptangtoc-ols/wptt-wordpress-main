# ==============================================================================
# 4. LOGIC XỬ LÝ (CHẠY SCRIPT CON)
# ==============================================================================
run_action() {
  local index=$1
  local script_path=""
  local script_args="98"

  case $index in
  0) script_path="/etc/wptt/wordpress/wptt-update-wordpress-main" ;;
  1) script_path="/etc/wptt/wordpress/thay-url-option" ;;
  2) script_path="/etc/wptt/wordpress/rewrite" ;;
  3) script_path="/etc/wptt/wordpress/bao-tri-wordpress" ;;
  4) script_path="/etc/wptt/wptt-install-wordpress2" ;;
  5) script_path="/etc/wptt/wordpress/wordpress-multisite" ;;

  6) script_path="/etc/wptt/wordpress/nhap-du-lieu-litespeed-wptangtoc" ;;
  7) script_path="/etc/wptt/wordpress/image" ;;
  8) script_path="/etc/wptt/wordpress/wptt-render-thumbnail" ;;
  9) script_path="/etc/wptt/wordpress/wp-cron-job" ;;
  10) script_path="/etc/wptt/wordpress/plugin-heartbeat-wptangtoc" ;;
  11) script_path="/etc/wptt/wordpress/xoa-binh-luan-spam" ;;

  12) script_path="/etc/wptt/wordpress/passwd-wp" ;;
  13) script_path="/etc/wptt/wordpress/login-wpadmin-magic" ;;
  14) script_path="/etc/wptt/wordpress/chinh-sua-truc-tiep-admin-wordpress" ;;

  15) script_path="/etc/wptt/wordpress/query-truyvan" ;;
  16) script_path="/etc/wptt/wordpress/transient" ;;
  17) script_path="/etc/wptt/wordpress/thay-doi-tien-to" ;;
  18) script_path="/etc/wptt/wordpress/unix-stocket-wpconfig" ;;
  19) script_path="/etc/wptt/wordpress/tang-gioi-han-ram-wordpress" ;;

  20) script_path="/etc/wptt/wordpress/kham-suc-khoe-wordpress" ;;
  21) script_path="/etc/wptt/wordpress/check-autoload" ;;
  22) script_path="/etc/wptt/wordpress/check-hook-speed" ;;
  23) script_path="/etc/wptt/wordpress/check-decode-base64" ;;
  24) script_path="/etc/wptt/wordpress/wp-debug" ;;
  25) script_path="/etc/wptt/wordpress/thay-salt" ;;
  26) script_path="/etc/wptt/wordpress/plugin-xml-rpc-wptangtoc" ;;
  esac

  if [[ -x "$script_path" || -f "$script_path" ]]; then
    exec bash "$script_path" "$script_args"
  else
    echo -e "\n\033[1;31m[!] Lỗi: Không tìm thấy tệp '$script_path'.\033[0m"
    sleep 2
    exec /etc/wptt/wptt-wordpress-main 1
  fi
}

