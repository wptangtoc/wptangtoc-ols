function huong_dan() {
  Tính năng Quản lý Ngôn ngữ trong WPTangToc OLS [nếu có] là một tùy chọn cho phép người dùng thay đổi ngôn ngữ hiển thị của chính giao diện script WPTangToc OLS. 🗣️

  Giới thiệu ngắn gọn:
  Mục đích: Giúp người dùng từ các quốc gia khác nhau hoặc những người không thông thạo ngôn ngữ mặc định của script [ví dụ: tiếng Việt] có thể sử dụng WPTangToc OLS một cách dễ dàng và thuận tiện hơn.

  Cách hoạt động:
  * Cung cấp một tùy chọn trong menu cài đặt hoặc cấu hình của WPTangToc OLS.
  * Người dùng có thể chọn từ danh sách các ngôn ngữ được hỗ trợ [ví dụ: Tiếng Việt, Tiếng Anh, Tiếng việt không dấu].
  * Sau khi chọn, toàn bộ các thông báo, hướng dẫn, và mục menu của script sẽ được hiển thị bằng ngôn ngữ đã chọn.

  Lợi ích:
  * Tăng khả năng tiếp cận: Mở rộng đối tượng người dùng có thể sử dụng script.
  * Nâng cao trải nghiệm người dùng: Giúp người dùng hiểu rõ hơn các tùy chọn và thông báo, giảm thiểu lỗi do rào cản ngôn ngữ.
  * Sử dụng thuận tiện: Cho phép người dùng làm việc với script bằng ngôn ngữ mà họ cảm thấy thoải mái nhất.
  Tính năng này đặc biệt hữu ích nếu WPTangToc OLS được phát triển với mục tiêu hỗ trợ cộng đồng người dùng quốc tế hoặc đa dạng về ngôn ngữ.
}

if [[ -z "$1" ]]; then
  . /etc/wptt/wptt-header-menu
  header_menu
else
  . /etc/wptt/echo-color 2>/dev/null
  echoDo "────────────────────────────────────────────────────────────────────────────────"
fi

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null

echo ""
echo "$quan_ly_ngon_ngu:" > /dev/null # Để wptt-search tổng vẫn bắt được danh mục

# ==============================================================================
# 2. KHAI BÁO TIÊU ĐỀ MENU VÀ OPTIONS (SẮP XẾP LẠI UX)
# ==============================================================================
MENU_TITLE="TRUNG TÂM QUẢN LÝ NGÔN NGỮ (LANGUAGE)"

options=(
  # --- CỘT TRÁI: TIẾNG VIỆT ---
  "$tieng_viet"                 #0 (Hiển thị: 1)
  "$tieng_viet Khong dau"       #1 (Hiển thị: 2)

  # --- CỘT PHẢI: QUỐC TẾ ---
  "$tieng_anh"                  #2 (Hiển thị: 3)
)

# ==============================================================================
# 3. LOGIC XỬ LÝ (ÁNH XẠ CHUẨN VỚI INDEX MỚI)
# ==============================================================================
run_action() {
  local index=$1
  local script_path=""
  local script_args="98"

  case $index in
  0) script_path="/etc/wptt/lang/wptt-set-lang-vi" ;;
  1) script_path="/etc/wptt/lang/wptt-set-lang-vi-khong-dau" ;;
  2) script_path="/etc/wptt/lang/wptt-set-lang-en" ;;
  *)
    echo "${lua_chon_khong_hop_le:-Lựa chọn không hợp lệ}: Index $index."
    return 1
    ;;
  esac

  if [[ -x "$script_path" || -f "$script_path" ]]; then
    exec bash "$script_path" "$script_args"
  else
    echo -e "\n\033[1;31m[!] Lỗi: Không tìm thấy hoặc không thể thực thi script '$script_path'.\033[0m"
    sleep 2
    exec /etc/wptt/wptt-lang-main 1
  fi
}

draw_custom_grid() {
  print_row "" "NGÔN NGỮ BẢN ĐỊA (VI)" "" "NGÔN NGỮ QUỐC TẾ (EN)"
  print_row "1" "${options[0]}" "3" "${options[2]}"
  print_row "2" "${options[1]}" ""  ""
}

. /etc/wptt/wptt-callback-menu-chon
