#!/bin/bash
# @author: Gia Tuấn
# @website: https://wptangtoc.com

huong_dan() {
  Tính năng này giúp bạn tạm thời thoát khỏi giao diện Menu của
  WPTangToc OLS để trở về môi trường dòng lệnh gốc của máy chủ.

  Ứng dụng thực tế:
  - Phù hợp khi bạn cần chạy các lệnh Linux thủ công [ping, htop...].
  - Giúp Power User quản trị server nâng cao ngoài phạm vi Menu.

  Cách quay lại Menu WPTangToc:
  - Bạn chỉ cần gõ phím 1 hoặc lệnh wptangtoc rồi ấn Enter.
}

. /etc/wptt/echo-color
export LANG=en_US.UTF-8
export LC_ALL=en_US.UTF-8

# Bảng màu UI chuẩn WPTangToc
C_RED='\033[1;31m'
C_GREEN='\033[1;32m'
C_YELLOW='\033[1;33m'
C_CYAN='\033[1;36m'
C_RESET='\033[0m'
C_BOLD='\033[1m' # Đã bổ sung biến in đậm

box_inner_width=78

print_line() {
  local text="$1"
  local clean_text=$(echo -e "$text" | sed "s/\x1B\[[0-9;]*[a-zA-Z]//g")
  local text_len=${#clean_text}

  local pad_right=$((box_inner_width - text_len - 2))
  [[ $pad_right -lt 0 ]] && pad_right=0
  local spaces=$(printf '%*s' "$pad_right" "")

  echo -e "${C_CYAN}│${C_RESET}  ${text}${spaces}${C_CYAN}│${C_RESET}"
}

# ==============================================================================
# THỰC THI CHẾ ĐỘ CLI (VẼ BANNER CHUẨN UX)
# ==============================================================================
stty sane 2>/dev/null
tput cnorm 2>/dev/null
USER_SHELL_NAME=$(basename "$SHELL" 2>/dev/null)
if [[ -z "$USER_SHELL_NAME" ]]; then
  USER_SHELL_NAME="bash"
  USER_SHELL_PATH="/bin/bash"
else
  USER_SHELL_PATH="$SHELL"
fi

clear
echo -e "\n${C_GREEN}Đang thiết lập môi trường dòng lệnh...${C_RESET}\n"

echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
print_line "" # Khoảng thở trên
center_text "${C_GREEN}${C_BOLD}BẠN ĐANG Ở CHẾ ĐỘ TERMINAL CLI (DÒNG LỆNH - $USER_SHELL_NAME)${C_RESET}"
print_line "" # Khoảng thở giữa
echo -e "${C_CYAN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
print_line "" # Khoảng thở trên
print_line "  Để quay lại bảng điều khiển WPTangToc OLS bất cứ lúc nào,"
print_line "  hãy gõ lệnh: ${C_GREEN}${C_BOLD}1${C_RESET} hoặc ${C_GREEN}${C_BOLD}wptangtoc${C_RESET} rồi ấn Enter."
print_line "" # Khoảng thở dưới
echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯${C_RESET}"
echo ""

export WPTT_BYPASS=1            # Cấp lệnh bài miễn tử để không bị .bashrc bắt quay lại Menu
exec "$USER_SHELL_PATH" --login # Mở Shell với đầy đủ biến môi trường (Login Shell)
