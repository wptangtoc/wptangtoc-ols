#!/bin/bash

function huong_dan() {
  Hỗ trợ phát triển phần mềm WPTangToc OLS. rất biết ơn sự đóng góp của bạn nhằm hỗ trợ sứ mệnh của chúng tôi trong việc xây dựng một phần mềm thiết lập và quản trị webserver miễn phí mà hiệu suất tốt nhất.

  Bánh mì trên bàn không phải là miễn phí, mặc dù phần mềm này miễn phí, và sẽ luôn như vậy. Mình thích phát triển phần mềm này và hỗ trợ các bạn, nhưng mình cũng cần bánh mì. Vui lòng tạo điều kiện để tôi tiếp tục nỗ lực vào phần mềm này:
}

clear

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null # Nạp thư viện UX Bo Cong

clear
echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}💖 ỦNG HỘ & TÀI TRỢ DỰ ÁN WPTANGTOC OLS 💖${C_RESET}"
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

# ==============================================================================
# LOGO ASCII WPTANGTOC OLS
# ==============================================================================
echo -e "${C_RED}
     .:..........................             
      .::::::::::::::::::::::::::::..         
        ..:::::::::::::::::::::::::::::.      
                             ...:::::::::.    
                                  .:::::::.   
          .:::::::.         .        .:::::::  
         .::::::::::::::::::::..       ::::::: 
         ::::::::::::::::::::::::.      ::::::.
        .::::::::::::::::::::::::::.   .:::::.
        .::::::::::::::::::::::::::::  .:::::.
        .::::::::::::::::::::::::::.   .:::::.
         ::::::::::::::::::::::::.      ::::::.
.::::::  .:::::::::::::::::::::.      ::::::. 
          .:::::::.                 .:::::::  
        ::::::::::::.               .:::::::.   
        ......:::::::::...    ...:::::::::.    
               .:::::::::::::::::::::::.      
  ..............::::::::::::::::::..          
 .:::::::::::::................. ${C_RESET}\n"

center_text "${C_BOLD_WHITE}Bánh mì trên bàn không phải là miễn phí!${C_RESET}"
center_text "Nhưng phần mềm này thì có, và sẽ luôn như vậy."
center_text "Nếu bạn yêu thích dự án, hãy mời tác giả một ly cafe nhé ☕"
echo ""

# ==============================================================================
# FETCH THÔNG TIN TỪ WEBSITE (CÓ SPINNER UX)
# ==============================================================================
_runing "Đang kết nối với máy chủ để tải Bảng Vàng Vinh Danh..."

# Thêm tham số -s (silent) và --connect-timeout để chống treo bash
title_donate=$(curl -s --connect-timeout 5 https://wptangtoc.com/donate/ 2>/dev/null | grep '<h2 class' | head -1 | sed -e 's|</b>|-|g' -e 's|<[^>]*>||g')

# Kéo list vinh danh (Giữ nguyên logic parse cực đỉnh của sếp)
list_donate=$(curl -s --connect-timeout 5 https://wptangtoc.com/donate/ 2>/dev/null | sed -e '/<li>/,/li>/!d' | sed '/footer/d' | sed '/div/d' | sed '/wptangtoc.com/d' | sed '/class/d' | sed '/^$/d' | sed '/wptangtoc/d' | sed '/dieu-khoan-dich-vu/d' | sed '/chinh-sach-thanh-toan/d' | sed '/tel:0/d' | sed 's/<li>//g' | sed 's/<\/li>//g' | sed '/html>/d' | sed '/Vui lòng ghi: nội dung/d' | sed -e 's|</b>|-|g' -e 's|<[^>]*>||g')

_rundone "Tải danh sách vinh danh hoàn tất"

# ==============================================================================
# BẢNG VÀNG VINH DANH
# ==============================================================================
if [[ -n "$title_donate" || -n "$list_donate" ]]; then
  echo -e "\n${C_GREEN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_YELLOW}🏆 BẢNG VÀNG VINH DANH${C_RESET}"
  echo -e "${C_GREEN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
  [[ -n "$title_donate" ]] && center_text "${C_BOLD_WHITE}$title_donate${C_RESET}"
  echo -e "${C_GREEN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
  
  # Đọc từng dòng của biến list_donate và in ra có căn lề
  while IFS= read -r line; do
    if [[ -n "$line" ]]; then
      left_text "  🎁 $line" 2
    fi
  done <<< "$list_donate"
  echo -e "${C_GREEN}╰───────────────────────────────────────────────────────────────────────╯${C_RESET}"
fi

# ==============================================================================
# THÔNG TIN CHUYỂN KHOẢN (ĐÓNG KHUNG NỔI BẬT)
# ==============================================================================
echo -e "\n${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_BOLD_WHITE}THÔNG TIN TÀI TRỢ (DONATE)${C_RESET}"
echo -e "${C_CYAN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
left_text "  ${C_YELLOW}1. NGÂN HÀNG MB BANK${C_RESET}" 2
left_text "  - Số tài khoản : ${C_GREEN}2222223338888${C_RESET}" 2
left_text "  - Chủ tài khoản: ${C_BOLD_WHITE}HOÀNG GIA TUẤN${C_RESET}" 2
echo -e "${C_CYAN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
left_text "  ${C_YELLOW}2. PAYPAL KẾT NỐI TOÀN CẦU${C_RESET}" 2
left_text "  - Link Donate  : ${C_GREEN}https://www.paypal.com/paypalme/wptangtoc${C_RESET}" 2
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

# ==============================================================================
# ĐIỀU HƯỚNG QUAY LẠI
# ==============================================================================
check_menu_wptangtoc_active=${1:-}
if [[ "$check_menu_wptangtoc_active" == "98" ]]; then
  echo -en "${C_GREEN}Nhấn phím [Enter] để quay lại Menu chính...${C_RESET}"
  read -r dummy
  exec /usr/bin/wptangtoc 1
fi
