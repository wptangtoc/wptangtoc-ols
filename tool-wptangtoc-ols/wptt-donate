# ==============================================================================
# HÀM TRỢ GIÚP VẼ KHUNG 78 (ÉP TRÁI & CHỐNG LỆCH BẰNG UTF-8 BYTE-STRIPPING)
# ==============================================================================
box_inner_width=78

get_clean_len() {
  # 1. Xóa toàn bộ mã màu ANSI và dấu enter ẩn
  local clean=$(echo -en "$1" | sed "s/\x1B\[[0-9;]*[a-zA-Z]//g" | tr -d '\r\n')
  
  # 2. TUYỆT CHIÊU: Xóa các byte nối UTF-8 (từ \200 đến \277 Octal)
  # Nhờ đó lệnh wc -c sẽ đếm ra chính xác số lượng KÝ TỰ thay vì số Byte, bất chấp VPS có cài Locale hay không!
  local char_count=$(echo -n "$clean" | tr -d '\200-\277' | wc -c | tr -d ' ')
  
  echo "$char_count"
}

center_text() {
  local text="$1"
  local border_color="${2:-$C_CYAN}"
  # Cắt khoảng trắng thừa ở đuôi để chống lồi khung
  text=$(echo -en "$text" | sed 's/[[:space:]]*$//' | tr -d '\r\n')
  local clean_len=$(get_clean_len "$text")
  
  if ((clean_len >= box_inner_width)); then
    printf "${border_color}│${C_RESET} %b ${border_color}│${C_RESET}\n" "$text"
    return
  fi
  local pad_left=$(((box_inner_width - clean_len) / 2))
  local pad_right=$((box_inner_width - clean_len - pad_left))
  printf "${border_color}│${C_RESET}%*s%b%*s${border_color}│${C_RESET}\n" "$pad_left" "" "$text" "$pad_right" ""
}

center_no_border() {
  local text="$1"
  text=$(echo -en "$text" | sed 's/[[:space:]]*$//' | tr -d '\r\n')
  local clean_len=$(get_clean_len "$text")
  local pad_left=$(((80 - clean_len) / 2))
  [[ $pad_left -lt 0 ]] && pad_left=0
  printf "%*s%b\n" "$pad_left" "" "$text"
}

print_full_line() {
  local text="$1"
  local border_color="${2:-$C_CYAN}"
  text=$(echo -en "$text" | sed 's/[[:space:]]*$//' | tr -d '\r\n')
  local clean_len=$(get_clean_len "$text")
  
  # Khung 78. Đã in 1 dấu cách lề trái nên cần trừ đi 1 cho lề phải
  local pad=$((box_inner_width - clean_len - 1))
  [[ $pad -lt 0 ]] && pad=0
  
  echo -e "${border_color}│${C_RESET} ${text}$(printf '%*s' "$pad" "")${border_color}│${C_RESET}"
}

