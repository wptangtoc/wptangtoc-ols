#!/bin/bash
# @author: Gia Tuấn
# @website: https://wptangtoc.com
# @since: 2026

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null

get_status() {
  local service_name="$1"
  if ! systemctl cat "${service_name}.service" &>/dev/null; then
    echo "not-found"
    return
  fi
  # Lấy trạng thái hoạt động thực tế
  systemctl is-active "$service_name.service" 2>/dev/null || echo "inactive"
}

clean_status() {
  echo "$1" | tr -d '\r' | xargs
}

print_row() {
  local name="$1"
  local raw_status=$(clean_status "$2")
  local color_status=""
  local status_text=""

  case "$raw_status" in
  active)
    color_status="${C_GREEN}"
    status_text="Đang hoạt động (Active)"
    ;;
  inactive)
    color_status="${C_YELLOW}"
    status_text="Đã dừng (Inactive)"
    ;;
  activating)
    color_status="${C_CYAN}"
    status_text="Đang khởi động (Activating)"
    ;;
  failed)
    color_status="${C_RED}"
    status_text="Lỗi sự cố (Failed)"
    ;;
  not-found) return 0 ;; # Bỏ qua không in nếu dịch vụ chưa cài đặt
  *)
    color_status="${C_WHITE}"
    status_text="$raw_status"
    ;;
  esac

  # Căn lề trái 15 ký tự cho Tên Dịch vụ
  local name_padded=$(printf "%-15s" "$name")

  # Tính độ dài chuỗi tiếng Việt chuẩn xác để không bị vỡ khung Box
  local status_len=$(echo -n "$status_text" | awk '{print length($0)}')
  local pad_len=$((50 - status_len))
  [[ $pad_len -lt 0 ]] && pad_len=0
  local padding=$(printf '%*s' "$pad_len" "")

  echo -e "${C_CYAN}│${C_RESET}  ${C_BOLD_WHITE}${name_padded}${C_RESET} : ${color_status}${status_text}${C_RESET}${padding} ${C_CYAN}│${C_RESET}"
}

clear
echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
# Căn giữa Tiêu đề (Độ rộng trong khung là 71 ký tự)
title="BẢNG TRẠNG THÁI CÁC DỊCH VỤ (SERVICES) HỆ THỐNG"
pad=$(((71 - ${#title}) / 2))
printf "${C_CYAN}│${C_RESET}%*s${C_YELLOW}%s${C_RESET}%*s${C_CYAN}│${C_RESET}\n" $pad "" "$title" $((71 - pad - ${#title})) ""
echo -e "${C_CYAN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"

# 1. LiteSpeed Webserver
print_row "LiteSpeed" "$(get_status lshttpd)"

# 2. MariaDB / MySQL
db_service=""
if systemctl cat mariadb.service &>/dev/null; then
  db_service="mariadb"
  db_name="MariaDB"
elif systemctl cat mysql.service &>/dev/null; then
  db_service="mysql"
  db_name="MySQL"
elif systemctl cat mysqld.service &>/dev/null; then
  db_service="mysqld"
  db_name="MySQL"
fi
[[ -n "$db_service" ]] && print_row "$db_name" "$(get_status "$db_service")"

# 3. PHP-FPM (Nếu dùng mô hình khác LSAPI, thường LSPHP chạy ngầm OLS, nhưng cứ check thử)
# print_row "PHP-FPM" "$(get_status php-fpm)" # Mở dòng này nếu bạn dùng Nginx/Apache song song

# 4. Object Cache (Ưu tiên: Valkey -> KeyDB -> Redis)
active_cache=""
active_name_display=""

if systemctl cat valkey.service &>/dev/null; then
  active_cache="valkey"
  active_name_display="Valkey"
elif systemctl cat keydb.service &>/dev/null; then
  active_cache="keydb"
  active_name_display="KeyDB"
elif systemctl cat redis.service &>/dev/null; then
  active_cache="redis"
  active_name_display="Redis"
elif systemctl cat redis-server.service &>/dev/null; then
  active_cache="redis-server"
  active_name_display="Redis"
fi
[[ -n "$active_cache" ]] && print_row "$active_name_display" "$(get_status "$active_cache")"

# 5. Memcached (Standard)
if systemctl cat memcached.service &>/dev/null; then
  print_row "Memcached" "$(get_status memcached)"
fi

# 6. SSH (Bảo mật truy cập)
ssh_service=""
if systemctl cat sshd.service &>/dev/null; then
  ssh_service="sshd"
elif systemctl cat ssh.service &>/dev/null; then
  ssh_service="ssh"
fi
[[ -n "$ssh_service" ]] && print_row "SSH" "$(get_status "$ssh_service")"

# 7. Crond (Lập lịch tự động)
cron_service=""
if systemctl cat crond.service &>/dev/null; then
  cron_service="crond"
elif systemctl cat cron.service &>/dev/null; then
  cron_service="cron"
fi
[[ -n "$cron_service" ]] && print_row "Cron Daemon" "$(get_status "$cron_service")"

# 8. Fail2Ban (Bảo mật Anti-Bruteforce)
if systemctl cat fail2ban.service &>/dev/null; then
  print_row "Fail2Ban" "$(get_status fail2ban)"
fi

# 9. Firewall
if systemctl cat firewalld.service &>/dev/null; then
  print_row "FirewallD" "$(get_status firewalld)"
elif systemctl cat ufw.service &>/dev/null; then
  print_row "UFW Firewall" "$(get_status ufw)"
fi

echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

if [[ -f /etc/wptt/wptt-service-main ]]; then
  exec /etc/wptt/wptt-service-main 1
else
  echo -e "${C_RED}Không tìm thấy script Menu WPTT tại /etc/wptt/wptt-service-main!${C_RESET}"
  exit 1
fi
