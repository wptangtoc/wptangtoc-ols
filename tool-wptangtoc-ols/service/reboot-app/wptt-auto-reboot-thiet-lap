function huong_dan() {
  Tính năng này giúp bạn nhận ngay tin nhắn báo cáo qua Telegram mỗi khi hệ thống giám sát Monit phát hiện dịch vụ bị sập và tự động cứu hộ [Khởi động lại] thành công.

  Lợi ích khi sử dụng:
  * Cập nhật thời gian thực: Nắm bắt ngay lập tức tình trạng sức khỏe của máy chủ mọi lúc, mọi nơi ngay trên điện thoại.
  * An tâm tuyệt đối: Nhìn thấy bot báo cáo, bạn sẽ biết chắc chắn tính năng Auto-Reboot đang hoạt động bền bỉ để bảo vệ website khỏi thời gian chết [Downtime].
  * Phát hiện rủi ro sớm: Nếu thấy một dịch vụ [như MariaDB hay OpenLiteSpeed] liên tục báo sập, bạn sẽ biết ngay để vào server kiểm tra và tối ưu, tránh tình trạng lỗi âm ỉ.
  * Tùy biến linh hoạt: Dễ dàng bật/tắt [Chuyển về chế độ cứu hộ im lặng] nếu bạn không muốn bị bot làm phiền.

  Lưu ý: Bạn cần phải kết nối Bot Telegram trong mục Bảo mât- trước khi kích hoạt tính năng này. >telegram
}
. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null # Nạp thư viện UX Bo Cong

clear
echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}BẢO MẬT ➜ Bật/Tắt Thông Báo Telegram Cho Auto-Reboot (Monit)${C_RESET}"
echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

if [[ "${1:-}" == '98' ]]; then
  WPTT_IN_MENU="yes"
  WPTT_MENU_BACK="/etc/wptt/wptt-bao-mat-main 1"
fi

if [[ -z "$telegram_api" || -z "$telegram_id" ]]; then
  echo -e "${C_RED}❌ Lỗi: Bạn chưa cấu hình Bot Telegram!${C_RESET}"
  echo -e "Vui lòng vào Quản lý Telegram để cài đặt trước khi sử dụng tính năng này."
  sleep 3
  exec /etc/wptt/bao-mat/wptt-telegram 1
  exit 1
fi

if grep -qi "ubuntu" /etc/*release 2>/dev/null; then
  OS_FAMILY="ubuntu"
  DIR_MONIT="/etc/monit/conf.d"
  SOCK_MARIADB="/run/mysqld/mysqld.sock"
  PATH_MEMCACHE_CONF="/etc/memcached.conf"
else
  OS_FAMILY="rhel"
  DIR_MONIT="/etc/monit.d"
  SOCK_MARIADB="/var/lib/mysql/mysql.sock"
  PATH_MEMCACHE_CONF="/etc/sysconfig/memcached"
fi

SCRIPT_TELEGRAM="/etc/wptt/service/reboot-app/wptt-monit-telegram.sh"

# Kiểm tra xem file cấu hình Monit có chứa đoạn gọi Telegram chưa
if grep -q "wptt-monit-telegram.sh" "$DIR_MONIT/lshttpd" 2>/dev/null; then
  TRANG_THAI="ON"
else
  TRANG_THAI="OFF"
fi

echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
if [[ "$TRANG_THAI" == "ON" ]]; then
  left_text "Thông báo Telegram : ${C_GREEN}ĐÃ KÍCH HOẠT${C_RESET}" 2
  echo -e "${C_CYAN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
  left_text "Mỗi khi Monit phát hiện dịch vụ sập và tự động khởi động" 2
  left_text "lại (Auto-Reboot), hệ thống sẽ gửi tin nhắn báo cáo cho bạn." 2
else
  left_text "Thông báo Telegram : ${C_RED}ĐANG TẮT (Chế độ im lặng)${C_RESET}" 2
  echo -e "${C_CYAN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
  left_text "Hệ thống Monit vẫn đang chạy ngầm và tự cứu sống dịch vụ," 2
  left_text "nhưng sẽ KHÔNG làm phiền bạn bằng tin nhắn Telegram." 2
fi
echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

# ==============================================================================
# XỬ LÝ NHÁNH 1: ĐANG BẬT -> YÊU CẦU TẮT (TRẢ VỀ MẶC ĐỊNH)
# ==============================================================================
if [[ "$TRANG_THAI" == "ON" ]]; then
  if ! wptt_xac_nhan "Bạn có muốn TẮT thông báo Telegram của Monit không?" "Monit vẫn sẽ giám sát và cứu hộ dịch vụ bình thường (Im lặng)." "" "Đồng ý Tắt" "Giữ nguyên (Hủy)"; then
    echo -e "${C_YELLOW}Đã hủy thao tác.${C_RESET}\n"
    [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-bao-mat-main 1
    exit 0
  fi

  echo ""
  _runing "Đang gỡ bỏ cấu hình cảnh báo Telegram khỏi Monit..."
  rm -f "$SCRIPT_TELEGRAM"

  # Gọi script cấu hình Monit gốc của WPTangToc để đè lại file config sạch (Không có Telegram)
  /etc/wptt/monit >/dev/null 2>&1

  systemctl restart monit >/dev/null 2>&1
  _rundone "Thiết lập cấu hình Monit về trạng thái Mặc định (Im lặng)"

  sleep 2
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-bao-mat-main 1
  exit 0
fi

# ==============================================================================
# XỬ LÝ NHÁNH 2: ĐANG TẮT -> YÊU CẦU BẬT (CHÈN HOOK TELEGRAM)
# ==============================================================================
if ! wptt_xac_nhan "Bạn có muốn BẬT thông báo Telegram cho Auto-Reboot không?" "Hệ thống sẽ gắn thêm Hook cảnh báo vào các lệnh Start của Monit." "" "Đồng ý BẬT" "Hủy thao tác"; then
  echo -e "${C_YELLOW}Đã hủy thao tác.${C_RESET}\n"
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-bao-mat-main 1
  exit 0
fi

echo ""
_runing "Đang tạo Script cứu hộ & thông báo Telegram..."

rm -f /etc/cron.d/reboot-check-service*
if grep -qi "ubuntu" /etc/*release 2>/dev/null; then systemctl restart cron.service >/dev/null 2>&1; else systemctl restart crond.service >/dev/null 2>&1; fi

mkdir -p /etc/wptt/service/reboot-app
cat >"$SCRIPT_TELEGRAM" <<'EOF'
#!/bin/bash
SERVICE_CMD="$1"
SERVICE_NAME="$2"

# 1. THỰC THI KHỞI ĐỘNG LẠI DỊCH VỤ (ƯU TIÊN SỐ 1 ĐỂ WEB KHÔNG CHẾT)
/usr/bin/systemctl start "$SERVICE_CMD"

# 2. TIẾN HÀNH GỬI THÔNG BÁO TELEGRAM (CHẠY NGẦM ĐỂ KHÔNG CHẶN MONIT)
(
  . /etc/wptt/.wptt.conf
  IP_SERVER=$(curl -skf --connect-timeout 5 https://ipv4.icanhazip.com || curl -skf --connect-timeout 5 https://checkip.amazonaws.com)
  DATE_NOW=$(date "+%d-%m-%Y %H:%M:%S")

  TEXT="🚨 *MONIT CẢNH BÁO: KHÔI PHỤC DỊCH VỤ* 🚨%0A"
  TEXT+="🖥 *Máy chủ:* \`${IP_SERVER}\`%0A"
  TEXT+="⏱ *Thời gian:* ${DATE_NOW}%0A"
  TEXT+="---------------------------%0A"
  TEXT+="⚠️ *Dịch vụ:* ${SERVICE_NAME}%0A"
  TEXT+="⚙️ *Hành động:* Hệ thống phát hiện dịch vụ bị treo/tắt và đã tự động Start lại thành công.%0A"
  TEXT+="---------------------------%0A"
  TEXT+="WPTangToc OLS - Phiên bản: ${version_wptangtoc_ols}%0A"

  URL="https://worker-soft-shape-e788.hoangtuan0137.workers.dev/bot${telegram_api}/sendMessage"
  curl -s -X POST "$URL" -d "chat_id=${telegram_id}" -d "text=${TEXT}" -d "disable_web_page_preview=true" -d "parse_mode=markdown" >/dev/null
) &
EOF
chmod +x "$SCRIPT_TELEGRAM"
_rundone "Khởi tạo Script Telegram hoàn tất"

_runing "Đang chèn Hook cảnh báo vào các dịch vụ của Monit..."
mkdir -p "$DIR_MONIT"

# 1. Bơm Hook vào OpenLiteSpeed
cat >"$DIR_MONIT/lshttpd" <<EOF
check process lshttpd with pidfile /var/run/openlitespeed.pid
  start program = "/bin/bash $SCRIPT_TELEGRAM lshttpd 'OpenLiteSpeed (lshttpd)'"
  stop program  = "/usr/bin/systemctl stop lshttpd"
  if failed host 127.0.0.1 port 80 with timeout 5 seconds then restart
  if 5 restarts within 5 cycles then timeout
EOF

# 2. Bơm Hook vào MariaDB
cat >"$DIR_MONIT/mariadb" <<EOF
check process mariadb matching "mariadbd|mysqld"
  start program = "/bin/bash $SCRIPT_TELEGRAM mariadb 'MariaDB/MySQL'"
  stop program  = "/usr/bin/systemctl stop mariadb"
  if failed unixsocket $SOCK_MARIADB protocol mysql then restart
  if 5 restarts within 5 cycles then timeout
EOF

# 3. Bơm Hook vào Object Cache
for cache_engine in valkey keydb redis; do rm -f "$DIR_MONIT/$cache_engine"; done
ACTIVE_CACHE=""
if systemctl is-enabled --quiet valkey 2>/dev/null || systemctl is-active --quiet valkey 2>/dev/null; then
  ACTIVE_CACHE="valkey"
elif systemctl is-enabled --quiet keydb 2>/dev/null || systemctl is-active --quiet keydb 2>/dev/null; then
  ACTIVE_CACHE="keydb"
elif systemctl is-enabled --quiet redis 2>/dev/null || systemctl is-active --quiet redis 2>/dev/null; then ACTIVE_CACHE="redis"; fi

if [[ -n "$ACTIVE_CACHE" ]]; then
  [[ "$ACTIVE_CACHE" == "valkey" ]] && PROC_MATCH="valkey-server"
  [[ "$ACTIVE_CACHE" == "keydb" ]] && PROC_MATCH="keydb-server"
  [[ "$ACTIVE_CACHE" == "redis" ]] && PROC_MATCH="redis-server"
  cat >"$DIR_MONIT/$ACTIVE_CACHE" <<EOF
check process $ACTIVE_CACHE matching "$PROC_MATCH"
  start program = "/bin/bash $SCRIPT_TELEGRAM $ACTIVE_CACHE 'Object Cache ($ACTIVE_CACHE)'"
  stop program  = "/usr/bin/systemctl stop $ACTIVE_CACHE"
  if failed unixsocket /var/run/$ACTIVE_CACHE/${ACTIVE_CACHE}.sock protocol redis then restart
  if 5 restarts within 5 cycles then timeout
EOF
fi

# 4. Bơm Hook vào Memcached
if [[ -f "$PATH_MEMCACHE_CONF" ]]; then
  cat >"$DIR_MONIT/memcached" <<EOF
check process memcached matching "memcached"
  start program = "/bin/bash $SCRIPT_TELEGRAM memcached 'Memcached'"
  stop program  = "/usr/bin/systemctl stop memcached"
  if failed unixsocket /var/run/memcached/memcached.sock protocol memcache then restart
  if 5 restarts within 5 cycles then timeout
EOF
else
  rm -f "$DIR_MONIT/memcached"
fi

systemctl daemon-reload >/dev/null 2>&1
systemctl restart monit >/dev/null 2>&1
_rundone "Cập nhật Hook và Reload Monit thành công"

echo -e "\n${C_GREEN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_BOLD_WHITE}HOÀN TẤT KÍCH HOẠT THÔNG BÁO TELEGRAM${C_RESET}"
echo -e "${C_GREEN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
left_text "Chế độ Auto-Reboot : ${C_YELLOW}Vẫn đang giám sát (Mỗi 30s)${C_RESET}" 2
left_text "Thông báo khi sập  : ${C_BOLD_WHITE}Đã liên kết với Bot Telegram${C_RESET}" 2
echo -e "${C_GREEN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

[[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-bao-mat-main 1
