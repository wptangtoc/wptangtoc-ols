#!/bin/bash
function huong_dan() {
  Tính năng này sẽ thực hiện khởi động lại [Reboot] toàn bộ VPS/Server.
  💡 Khi nào nên sử dụng?
  1. Khi hệ thống bị treo, giật lag nặng hoặc RAM bị rò rỉ [Memory Leak].
  2. Sau khi cập nhật nhân hệ điều hành [Kernel] hoặc các gói phần mềm lõi.
  3. Khi Database hoặc Web Server gặp lỗi không thể khởi động lại bằng lệnh thường.

  ⚠️ CẢNH BÁO QUAN TRỌNG:
  - Toàn bộ website trên máy chủ sẽ bị gián đoạn truy cập từ 1 đến 5 phút
  tùy thuộc vào tốc độ khởi động của nhà cung cấp VPS.
  - Hãy đảm bảo không có tiến trình nào [như Backup] đang chạy dở dang.
}

check_tu_menu_tuong_tac=$1

. /etc/wptt/.wptt.conf
if [[ $ngon_ngu = '' ]]; then
  ngon_ngu='vi'
fi
. /etc/wptt/lang/$ngon_ngu.sh

. /etc/wptt/echo-color

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
NC='\033[0m'
function khoi_dong_lai() {
  echo -e "${RED}CẢNH BÁO: Máy chủ sẽ khởi động lại ngay lập tức!${NC}"
  echo -e "Toàn bộ website sẽ không thể truy cập trong vài phút."
  echo ""

  # Hỏi xác nhận người dùng
  if [[ $check_tu_menu_tuong_tac = '98' ]]; then #nếu gõ thẳng: /etc/wptt/service/reboot-server thì không cần phải xác nhận lại
    echo -e "$xac_nhan reboot server?: "
    prompt="$nhap_lua_chon_cua_ban [1-2]: "
    dongy="n"
    options=("$dong_y" "$khong_dong_y")
    PS3="$prompt"
    select opt in "${options[@]}"; do
      case "$REPLY" in
      1)
        xac_nhan="y"
        break
        ;;

      2)
        xac_nhan="n"
        break
        ;;

      $((${#options[@]} + 1)))
        printf "\n$ban_nhap_sai_he_thong_se_chon_khong_dong_y\n"
        break
        ;;
      *)
        printf "$ban_nhap_sai_he_thong_se_chon_khong_dong_y\n"
        break
        ;;
      esac
    done
  else
    xac_nhan='y'
  fi

  if [[ "$xac_nhan" == "y" || "$xac_nhan" == "Y" ]]; then
    echo -e "${YELLOW}Đang tiến hành lưu dữ liệu đệm (sync)...${NC}"

    # Tắt an toàn Database trước. Điều này ép MariaDB tự động flush logs
    # và commit mọi giao dịch đang dang dở, chống Corrupt 100%.
    systemctl stop monit 2>/dev/null
    systemctl stop mariadb 2>/dev/null

    # Lệnh sync rất quan trọng: Giúp ghi toàn bộ dữ liệu đang nằm trên RAM xuống ổ cứng
    # để tránh lỗi hỏng Database (MariaDB/MySQL) khi sập nguồn đột ngột.
    #những dữ liệu đang "lơ lửng" trên RAM chưa kịp ghi xuống ổ cứng sẽ bị mất vĩnh viễn,Hậu quả: Gây ra lỗi corrupt (hỏng) file. Đặc biệt với MariaDB/MySQL, việc tắt ngang khi dữ liệu chưa ghi xong là nguyên nhân số 1 gây ra lỗi Database Corruption (hỏng bảng dữ liệu, không thể khởi động lại DB).

    /usr/bin/sync
    # Dân Sysadmin thường gõ sync 2 lần để đảm bảo I/O queue trống rỗng
    /usr/bin/sync
    sleep 1
    echo -e "${GREEN}Máy chủ đang khởi động lại. Vui lòng kết nối lại sau ít phút!${NC}"

    # Lệnh khởi động lại
    /sbin/reboot
  else
    echo -e "${GREEN}Đã hủy thao tác khởi động lại.${NC}"
    echo -e "Đang quay lại menu ..."
    sleep 1

    # Dùng bài học exec để quay lại menu chính mượt mà, không văng SSH
    if [ -f "/etc/wptt/wptt-service-main" ]; then
      exec /etc/wptt/wptt-service-main 98
    else
      exit 0
    fi
  fi
}

khoi_dong_lai
