#!/bin/bash
# @author: Gia Tuấn
# @website: https://wptangtoc.com

function huong_dan() {
  Tính năng này sẽ thực hiện khởi động lại [Reboot] toàn bộ VPS/Server.
  💡 Khi nào nên sử dụng?
  1. Khi hệ thống bị treo, giật lag nặng hoặc RAM bị rò rỉ [Memory Leak].
  2. Sau khi cập nhật nhân hệ điều hành [Kernel] hoặc các gói phần mềm lõi.
  3. Khi Database hoặc Web Server gặp lỗi không thể khởi động lại bằng lệnh thường.

  ⚠️ CẢNH BÁO QUAN TRỌNG:
  - Toàn bộ website trên máy chủ sẽ bị gián đoạn truy cập từ 1 đến 5 phút
  tùy thuộc vào tốc độ khởi động của nhà cung cấp VPS.
  - Hãy đảm bảo không có tiến trình nào [như Backup] đang chạy dở dang.
}

check_tu_menu_tuong_tac=$1

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null # Nạp thư viện UI Xác nhận

clear
echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}QUẢN LÝ DỊCH VỤ ➜ Khởi động lại Máy chủ (Reboot)${C_RESET}"
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯${C_RESET}\n"

function khoi_dong_lai() {
  local xac_nhan="y"

  # Nếu gọi từ Menu (98), hiển thị Popup xác nhận an toàn
  if [[ "$check_tu_menu_tuong_tac" == '98' ]]; then
    msg_title="CẢNH BÁO: Máy chủ sẽ khởi động lại ngay lập tức!  "
    msg_info1="${C_BOLD_WHITE}Hậu quả:${C_RESET} Toàn bộ website sẽ bị gián đoạn truy cập trong vài phút."
    msg_info2="${C_BOLD_WHITE}Lưu ý:${C_RESET} Hãy đảm bảo không có tiến trình Backup nào đang chạy."

    if wptt_xac_nhan "$msg_title" "$msg_info1" "$msg_info2" "Đồng ý (Khởi động lại ngay)" "Không đồng ý (Hủy thao tác)"; then
      xac_nhan="y"
    else
      xac_nhan="n"
    fi
  fi

  # Xử lý Logic sau khi xác nhận
  if [[ "$xac_nhan" == "y" || "$xac_nhan" == "Y" ]]; then
    echo ""
    _runing "Đang tiến hành lưu dữ liệu đệm và tắt dịch vụ an toàn..."

    # Tắt an toàn Database trước. Ép MariaDB tự động flush logs
    # và commit mọi giao dịch đang dang dở, chống Corrupt 100%.
    systemctl stop monit 2>/dev/null
    systemctl stop mariadb 2>/dev/null

    # Lệnh sync rất quan trọng: Ghi toàn bộ dữ liệu từ RAM xuống ổ cứng
    /usr/bin/sync
    # Dân Sysadmin thường gõ sync 2 lần để đảm bảo I/O queue trống rỗng
    /usr/bin/sync
    sleep 1

    _rundone "Dữ liệu đã an toàn. Lệnh Reboot đang được thực thi!"

    echo -e "\n${C_GREEN}=======================================================================${C_RESET}"
    echo -e "${C_BOLD_WHITE}Máy chủ đang khởi động lại. SSH sẽ bị ngắt kết nối ngay bây giờ.${C_RESET}"
    echo -e "${C_GREEN}Vui lòng kết nối lại sau 1-5 phút tùy tốc độ của nhà cung cấp VPS.${C_RESET}"
    echo -e "${C_GREEN}=======================================================================${C_RESET}\n"
    sleep 2

    # Lệnh khởi động lại
    /sbin/reboot
  else
    echo -e "\n${C_YELLOW}Đã hủy thao tác khởi động lại máy chủ.${C_RESET}"
    sleep 1.5

    # Dùng exec để quay lại menu chính mượt mà, không văng SSH
    if [ -f "/etc/wptt/wptt-service-main" ]; then
      exec /etc/wptt/wptt-service-main 98
    fi
  fi
}

khoi_dong_lai
