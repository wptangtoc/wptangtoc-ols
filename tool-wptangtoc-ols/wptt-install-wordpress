#!/bin/bash
# @author: Gia Tuấn
# @website: https://wptangtoc.com
# @email: giatuan@wptangtoc.com
# @since: 2026

export LC_ALL=C.UTF-8 2>/dev/null || export LC_ALL=en_US.UTF-8 2>/dev/null

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null

domain=$1
[[ "$domain" == "98" ]] && domain=""

if [[ -z "$domain" ]]; then
  clear
  echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_YELLOW}CÀI ĐẶT MỚI MÃ NGUỒN WORDPRESS${C_RESET}"
  echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"
  . /etc/wptt/tenmien
  lua_chon_NAME "Tải và cài đặt WordPress mới"
  domain="$NAME"
fi

path="/etc/wptt/vhost/.$domain.conf"
if [[ ! -f "$path" ]]; then
  echo -e "\n${C_RED}❌ Lỗi: Tên miền '$domain' không tồn tại trên hệ thống.${C_RESET}"
  echo -e "${C_YELLOW}Vui lòng thêm website vào hệ thống trước khi cài đặt.${C_RESET}"
  sleep 2
  exit 1
fi

. "/etc/wptt/vhost/.$domain.conf"

# ==============================================================================
# BƯỚC 1: XÁC NHẬN CÀI ĐẶT
# ==============================================================================
dongy="n"
if [[ -z "$@" ]]; then
  echo ""
  if wptt_xac_nhan "Sếp có chắc chắn muốn cài đặt WordPress mới cho domain: $domain?" "Lưu ý: Toàn bộ dữ liệu hiện tại trong thư mục html sẽ bị XÓA SẠCH!" "" "Có, Xóa & Cài đặt" "Không, Hủy bỏ"; then
    dongy="y"
  fi
else
  dongy="y"
fi

if [[ "$dongy" == "y" ]]; then
  echo "Install mã nguồn Wordpress website $NAME : $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log
  
  _runing "Đang dọn dẹp sạch sẽ toàn bộ thư mục Public HTML của $domain..."
  cd "/usr/local/lsws/$domain/html/" || exit 1
  rm -rf /usr/local/lsws/"$domain"/html/*
  [[ -d "/usr/local/lsws/$domain/luucache" ]] && rm -rf "/usr/local/lsws/$domain/luucache"
  _rundone "Dọn dẹp hoàn tất."

  _runing "Đang tải mã nguồn WordPress mới nhất từ máy chủ..."
  wget -q --timeout=15 --tries=3 https://wordpress.org/latest.tar.gz
  [[ ! -f latest.tar.gz ]] && wget -q --timeout=15 --tries=3 http://wordpress.org/latest.tar.gz
  _rundone "Tải thành công phiên bản WordPress."

  _runing "Đang bung nén và cấu hình thư mục hệ thống..."
  tar -zxf latest.tar.gz
  mv wordpress/* "/usr/local/lsws/$domain/html/"
  rm -rf wordpress && rm -f latest.tar.gz
  _rundone "Bung nén mã nguồn thành công."

# ==============================================================================
# BƯỚC 2: CẤU HÌNH WP-CONFIG VÀ TÀI KHOẢN ADMIN (GIAO DIỆN KHUNG CHUẨN)
# ==============================================================================
  dongyconfig="n"
  if [[ -n "$DB_Name_web" ]]; then
    echo ""
    if wptt_xac_nhan "Sếp có muốn tự động cấu hình Database và tạo tài khoản Admin ngay bây giờ không?" "" "" "Có, cấu hình ngay" "Để sau tôi tự làm"; then
      dongyconfig="y"
      
      echo -e "\n${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
      center_text "${C_YELLOW}THIẾT LẬP THÔNG TIN WEBSITE & ADMIN${C_RESET}"
      echo -e "${C_CYAN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
      
      # 1. Tên Website
      echo -en "${C_CYAN}│${C_RESET} ${C_BOLD_WHITE}1. Tên tiêu đề Website (Site Title)${C_RESET} : "
      read -r SiteTitle
      
      # 2. ID Admin
      echo -en "${C_CYAN}│${C_RESET} ${C_BOLD_WHITE}2. Tên đăng nhập Admin (Username)  ${C_RESET} : "
      read -r idusername
      
      # 3. Mật khẩu (Ẩn ký tự)
      mypassword=""
      echo -en "${C_CYAN}│${C_RESET} ${C_BOLD_WHITE}3. Mật khẩu Admin (Password)       ${C_RESET} : "
      while IFS= read -r -s -N 1 char; do
        if [[ -z "$char" ]] || [[ "$char" == $'\n' ]] || [[ "$char" == $'\r' ]]; then
          echo
          break
        elif [[ "$char" == $'\x7f' ]]; then # Backspace
          if [[ -n "$mypassword" ]]; then
            mypassword="${mypassword%?}"
            echo -ne '\b \b'
          fi
        else
          mypassword+="$char"
          echo -n '*'
        fi
      done
      
      # 4. Email Quản trị
      while true; do
        echo -en "${C_CYAN}│${C_RESET} ${C_BOLD_WHITE}4. Email của Admin (admin@domain)  ${C_RESET} : "
        read -r emailwp
        if [[ "$emailwp" == *@*.* ]]; then
          break
        else
          echo -e "${C_CYAN}│${C_RESET} ${C_RED}   [!] Lỗi: Email không đúng định dạng. Vui lòng thử lại.${C_RESET}"
        fi
      done
      echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯${C_RESET}"

      _runing "Đang kết nối Database và chạy trình cài đặt WordPress..."
      tien_to_db=$(openssl rand -base64 32 | tr -dc 'a-zA-Z0-9' | head -c 6)

      wp core config --dbname="$DB_Name_web" --dbuser="$DB_User_web" --dbpass="$DB_Password_web" --dbhost=localhost --dbprefix="${tien_to_db}_" --dbcharset='utf8mb4' --dbcollate='utf8mb4_unicode_ci' --allow-root --extra-php >/dev/null 2>&1 <<PHP
define( 'WP_DEBUG_LOG', false );
define( 'WP_DEBUG_DISPLAY', false );
PHP

      wp core install --url="http://${domain}" --title="$SiteTitle" --admin_user="$idusername" --admin_password="$mypassword" --admin_email="$emailwp" --allow-root >/dev/null 2>&1
      wp language core install vi --path="/usr/local/lsws/$domain/html" --activate --allow-root >/dev/null 2>&1
      wp option update timezone_string "Asia/Ho_Chi_Minh" --path="/usr/local/lsws/$domain/html" --allow-root >/dev/null 2>&1
      wp rewrite structure '/%postname%/' --path="/usr/local/lsws/$domain/html" --allow-root >/dev/null 2>&1
      _rundone "Cấu hình Website và Database thành công."
    fi
  fi

# ==============================================================================
# BƯỚC 3: PHÂN QUYỀN VÀ KHỞI TẠO FILE HTACCESS LÕI
# ==============================================================================
  echo '# BEGIN WordPress
<IfModule mod_rewrite.c>
RewriteEngine On
RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]
RewriteBase /
RewriteRule ^index\.php$ - [L]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . /index.php [L]
</IfModule>
# END WordPress' > "/usr/local/lsws/$domain/html/.htaccess"

  _runing "Phân quyền thư mục và Khởi động lại OpenLiteSpeed..."
  chown -R "$User_name_vhost":"$User_name_vhost" "/usr/local/lsws/$domain/html"
  /usr/local/lsws/bin/lswsctrl restart >/dev/null 2>&1
  _rundone "Phân quyền và khởi động hệ thống hoàn tất."

# ==============================================================================
# BƯỚC 4: BẢNG TỔNG KẾT (SUMMARY REPORT) ĐẸP MẮT
# ==============================================================================
  echo -e "\n${C_GREEN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_BOLD_WHITE}CHÚC MỪNG SẾP ĐÃ CÀI ĐẶT WORDPRESS THÀNH CÔNG!${C_RESET}" "$C_GREEN"
  echo -e "${C_GREEN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
  
  # Căn lề thông tin Database
  pad_db=$((46 - ${#DB_Name_web}))
  [[ $pad_db -lt 0 ]] && pad_db=0
  echo -e "${C_GREEN}│${C_RESET} ${C_YELLOW}Tên miền (Domain)${C_RESET}   : ${C_CYAN}http://$domain${C_RESET}$(printf '%*s' $((46 - ${#domain})) "") ${C_GREEN}│${C_RESET}"
  echo -e "${C_GREEN}│${C_RESET} ${C_YELLOW}Đường dẫn thư mục${C_RESET}   : ${C_BOLD_WHITE}/usr/local/lsws/$domain/html${C_RESET}$(printf '%*s' $((46 - ${#domain} - 21)) "") ${C_GREEN}│${C_RESET}"
  echo -e "${C_GREEN}│${C_RESET} ${C_YELLOW}Tên Database     ${C_RESET}   : ${C_BOLD_WHITE}$DB_Name_web${C_RESET}$(printf '%*s' "$pad_db" "") ${C_GREEN}│${C_RESET}"
  echo -e "${C_GREEN}│${C_RESET} ${C_YELLOW}User Database    ${C_RESET}   : ${C_BOLD_WHITE}$DB_User_web${C_RESET}$(printf '%*s' $((46 - ${#DB_User_web})) "") ${C_GREEN}│${C_RESET}"
  echo -e "${C_GREEN}│${C_RESET} ${C_YELLOW}Mật khẩu Database${C_RESET}   : ${C_BOLD_WHITE}Đã cấu hình vào wp-config.php${C_RESET}               ${C_GREEN}│${C_RESET}"
  
  if [[ "$dongyconfig" == "y" ]]; then
    echo -e "${C_GREEN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
    center_text "${C_CYAN}THÔNG TIN ĐĂNG NHẬP (LƯU TRỮ LẠI BẢN NÀY)${C_RESET}" "$C_GREEN"
    echo -e "${C_GREEN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
    
    pad_title=$((46 - ${#SiteTitle}))
    [[ $pad_title -lt 0 ]] && pad_title=0
    
    echo -e "${C_GREEN}│${C_RESET} ${C_YELLOW}Tiêu đề Website  ${C_RESET}   : ${C_BOLD_WHITE}$SiteTitle${C_RESET}$(printf '%*s' "$pad_title" "") ${C_GREEN}│${C_RESET}"
    echo -e "${C_GREEN}│${C_RESET} ${C_YELLOW}Đường dẫn Admin  ${C_RESET}   : ${C_CYAN}http://$domain/wp-admin${C_RESET}$(printf '%*s' $((46 - ${#domain} - 9)) "") ${C_GREEN}│${C_RESET}"
    echo -e "${C_GREEN}│${C_RESET} ${C_YELLOW}Tài khoản (User) ${C_RESET}   : ${C_BOLD_WHITE}$idusername${C_RESET}$(printf '%*s' $((46 - ${#idusername})) "") ${C_GREEN}│${C_RESET}"
    echo -e "${C_GREEN}│${C_RESET} ${C_YELLOW}Mật khẩu (Pass)  ${C_RESET}   : ${C_RED}******** (Bảo mật)${C_RESET}                          ${C_GREEN}│${C_RESET}"
    echo -e "${C_GREEN}│${C_RESET} ${C_YELLOW}Email Quản trị   ${C_RESET}   : ${C_BOLD_WHITE}$emailwp${C_RESET}$(printf '%*s' $((46 - ${#emailwp})) "") ${C_GREEN}│${C_RESET}"
  fi
  
  echo -e "${C_GREEN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"
fi
