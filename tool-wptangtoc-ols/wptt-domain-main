  "$xoa_domain"                                          #2
  "$danh_sach_domain"                                    #3
  "$them_parked_alias_domain"                            #4
  "$xoa_parked_alias_domain"                             #5
  "$chuyen_huong_domain"                                 #6
  "$xoa_chuyen_huong_domain"                             #7
