# 3. LOGIC XỬ LÝ (CHẠY SCRIPT CON)
run_action() {
  local index=$1
  local script_path=""
  local script_args="98"

  case $index in
  0) script_path="/etc/wptt/domain/wptt-themwebsite" ;;
  1) script_path="/etc/wptt/domain/thay-doi-domain" ;;
  2) script_path="/etc/wptt/domain/wptt-xoa-website" ;;
  3) script_path="/etc/wptt/domain/wptt-list-domain" ;;
  4) script_path="/etc/wptt/domain/wptt-alias-domain" ;;
  5) script_path="/etc/wptt/domain/wptt-xoa-alias-domain" ;;
  6) script_path="/etc/wptt/domain/wptt-chuyen-huong" ;;
  7) script_path="/etc/wptt/domain/wptt-xoa-domain-chuyen-huong" ;;
  8) script_path="/etc/wptt/domain/wptt-thay-doi-user" ;;
  9) script_path="/etc/wptt/domain/wptt-khoi-tao-user" ;;
  10) script_path="/etc/wptt/domain/wptt-subfolder-website" ;;
  11) script_path="/etc/wptt/wptt-phanquyen" ;;
  12) script_path="/etc/wptt/domain/wptt-bat-tat-domain" ;;
  13) script_path="/etc/wptt/domain/wptt-kiemtra-hoat-dong" ;;
  14) script_path="/etc/wptt/domain/real-time-check" ;;
  esac

  if [[ -x "$script_path" || -f "$script_path" ]]; then
    exec bash "$script_path" "$script_args"
  else
    echo -e "\n\033[1;31m[!] Lỗi: Không tìm thấy tệp '$script_path'.\033[0m"
    sleep 2
    exec /etc/wptt/wptt-domain-main 1
  fi
}

