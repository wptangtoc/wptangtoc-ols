#!/bin/bash
function header_menu() {
  clear
  . /etc/wptt/.wptt.conf
  if [[ -z "$ngon_ngu" ]]; then
    ngon_ngu='vi'
  fi
  . /etc/wptt/lang/$ngon_ngu.sh

  # Bảng màu UI chuẩn WPTangToc
  C_RED='\033[1;31m'
  C_GREEN='\033[1;32m'
  C_YELLOW='\033[1;33m'
  C_CYAN='\033[1;36m'
  C_RESET='\033[0m'

  # Xác định chiều rộng lọt lòng của hộp (71 ký tự cho cân đối)
  box_inner_width=71

  # Hàm căn giữa văn bản nâng cao (Tránh vỡ khung khi truyền mã màu)
  center_text() {
    local text="$1"
    local color_code="$2"
    local text_len=${#text}

    # Nếu text quá dài, tự động in sát lề
    if ((text_len >= box_inner_width)); then
      printf "${C_CYAN}│${C_RESET} ${color_code}%s${C_RESET} ${C_CYAN}│${C_RESET}\n" "$text"
      return
    fi

    local total_padding=$((box_inner_width - text_len))
    local pad_left=$((total_padding / 2))
    local pad_right=$((total_padding - pad_left))

    # In viền trái -> padding trái -> Text có màu -> padding phải -> viền phải
    printf "${C_CYAN}│${C_RESET}%*s${color_code}%s${C_RESET}%*s${C_CYAN}│${C_RESET}\n" "$pad_left" "" "$text" "$pad_right" ""
  }

  # Hàm in dòng trạng thái căn trái (Tính toán chuẩn xác khoảng trắng)
  print_status() {
    local label="$1"
    local value="$2"
    local color_code="$3"

    # Ghép chuỗi để đếm độ dài thực tế (không tính mã màu ANSI)
    local raw_text="${label}${value}"
    local text_len=${#raw_text}

    # Tính khoảng trống còn lại (-2 là trừ đi 2 dấu cách lề trái cho thoáng)
    local pad_right=$((box_inner_width - text_len - 2))
    local spaces=$(printf '%*s' "$pad_right" "")

    echo -e "${C_CYAN}│${C_RESET}  ${label}${color_code}${value}${C_RESET}${spaces}${C_CYAN}│${C_RESET}"
  }

  # ==============================================================================
  # 1. KIỂM TRA TRẠNG THÁI DỊCH VỤ (Chạy ngầm trước)
  # ==============================================================================
  ols_status=$(/usr/local/lsws/bin/lswsctrl status 2>/dev/null | grep -i 'litespeed is running')
  mariadb_status=$(systemctl is-active mariadb.service 2>/dev/null)

  # ==============================================================================
  # 2. RENDER GIAO DIỆN HEADER (UI)
  # ==============================================================================
  echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "" ""
  center_text "WPTANGTOC OLS $phien_ban: $version_wptangtoc_ols" "$C_YELLOW"
  center_text "$phat_trien_boi_gia_tuan" ""

  # Logic hiển thị phân khúc phần mềm
  if [[ "$wptangtoc_ols_giatuan" == "1" && -n "$key_activate" ]]; then
    center_text "WPTangToc OLS Enterprise + Premium" "$C_RESET"
  elif [[ "$wptangtoc_ols_giatuan" == "1" ]]; then
    center_text "WPTangToc OLS Enterprise" "$C_RESET"
  elif [[ -n "$key_activate" ]]; then
    center_text "WPTangToc OLS Premium" "$C_RESET"
  fi

  center_text "WPTangToc OLS Beta" "$C_RESET"

  center_text ""
  echo -e "${C_CYAN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"

  # ==============================================================================
  # 3. RENDER TRẠNG THÁI MÁY CHỦ BÊN TRONG HỘP (UX Tối ưu)
  # ==============================================================================
  if [[ -n "$ols_status" && "$mariadb_status" == "active" ]]; then
    print_status "$tinh_trang_may_chu: " "$hoat_dong_tot" "$C_GREEN"
  else
    print_status "$tinh_trang_may_chu: " "$may_chu_dang_gap_van_de" "$C_RED"

    # Báo lỗi chi tiết thụt lề vào trong
    if [[ -z "$ols_status" ]]; then
      print_status " ↳ Cảnh báo: " "Webserver LiteSpeed đang ngừng hoạt động!" "$C_RED"
    fi
    if [[ "$mariadb_status" != "active" ]]; then
      print_status " ↳ Cảnh báo: " "MariaDB Database đang ngừng hoạt động!" "$C_RED"
    fi
  fi

  echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯${C_RESET}"
}

