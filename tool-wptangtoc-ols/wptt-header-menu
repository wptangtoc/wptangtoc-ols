#!/bin/bash
# @author: Gia Tuấn
# @website: https://wptangtoc.com
# @since: 2026

function header_menu() {
  clear
  . /etc/wptt/.wptt.conf 2>/dev/null
  [[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
  . /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
  . /etc/wptt/echo-color 2>/dev/null
  . /etc/wptt/core-functions 2>/dev/null

  # ==============================================================================
  # 1. KIỂM TRA TRẠNG THÁI DỊCH VỤ
  # ==============================================================================
  ols_status=$(/usr/local/lsws/bin/lswsctrl status 2>/dev/null | grep -i 'litespeed is running')
  mariadb_status=$(systemctl is-active mariadb.service 2>/dev/null)

  # Cố gắng start lại nếu đang sập để kiểm tra lần cuối
  if [[ -z "$ols_status" ]]; then
    /usr/local/lsws/bin/lswsctrl restart >/dev/null 2>&1
    ols_status=$(/usr/local/lsws/bin/lswsctrl status 2>/dev/null | grep -i 'litespeed is running')
  fi
  if [[ "$mariadb_status" != "active" ]]; then
    systemctl restart mariadb.service >/dev/null 2>&1
    mariadb_status=$(systemctl is-active mariadb.service 2>/dev/null)
  fi

  # ==============================================================================
  # 2. XÁC ĐỊNH NHÃN BẢN QUYỀN
  # ==============================================================================
  local license_label=""
  if [[ "$wptangtoc_ols_giatuan" == "1" && -n "$key_activate" ]]; then
    license_label="Bản Quyền: Enterprise + Premium"
  elif [[ "$wptangtoc_ols_giatuan" == "1" ]]; then
    license_label="Bản Quyền: Enterprise"
  elif [[ -n "$key_activate" ]]; then
    license_label="Bản Quyền: Premium"
  fi

  # ==============================================================================
  # 3. RENDER GIAO DIỆN HEADER (FORM 78 CHUẨN UX)
  # ==============================================================================
  print_border_top "$C_CYAN"
  
  # Khối 1: Tên phần mềm & Phiên bản
  center_text "${C_BOLD_WHITE}WPTANGTOC OLS ${phien_ban:-phiên bản}: $version_wptangtoc_ols${C_RESET}" "$C_CYAN"
  print_border_mid "$C_CYAN"

  # Khối 2: Tác giả & Bản quyền (Đã thêm khoảng trống trên/dưới cho thoáng đãng)
  center_text "" "$C_CYAN"
  center_text "${C_BOLD_WHITE}${phat_trien_boi_gia_tuan:-Phát triển bởi: Gia Tuấn}${C_RESET}" "$C_CYAN"
  [[ -n "$license_label" ]] && center_text "${C_BOLD_WHITE}$license_label${C_RESET}" "$C_CYAN"
  [[ "$beta_wptangtoc_ols" == "1" ]] && center_text "${C_BOLD_WHITE}[Phiên bản Beta]${C_RESET}" "$C_CYAN"
  center_text "" "$C_CYAN"
  
  print_border_mid "$C_CYAN"

  # Khối 3: Trạng thái Server (Lùi lề 2 khoảng trắng giống file wptangtoc gốc)
  if [[ -n "$ols_status" && "$mariadb_status" == "active" ]]; then
    left_text "${C_BOLD_WHITE}${tinh_trang_may_chu:-Tình trạng máy chủ}: ${C_GREEN}${hoat_dong_tot:-Hoạt động tốt}${C_RESET}" 2 "$C_CYAN"
  elif [[ "$ols_status" == "unknown" || "$mariadb_status" == "unknown" ]]; then
    left_text "${C_BOLD_WHITE}${tinh_trang_may_chu:-Tình trạng máy chủ}: ${C_YELLOW}Không thể xác định${C_RESET}" 2 "$C_CYAN"
  else
    left_text "${C_BOLD_WHITE}${tinh_trang_may_chu:-Tình trạng máy chủ}: ${C_RED}${may_chu_dang_gap_van_de:-Đang gặp sự cố!}${C_RESET}" 2 "$C_CYAN"
    
    # Cảnh báo chi tiết (Lùi lề 5 khoảng trắng để thụt vào trong)
    [[ -z "$ols_status" ]] && left_text "${C_YELLOW}↳ Cảnh báo: ${C_RED}Webserver LiteSpeed ngừng hoạt động!${C_RESET}" 5 "$C_CYAN"
    [[ "$mariadb_status" != "active" ]] && left_text "${C_YELLOW}↳ Cảnh báo: ${C_RED}Database MariaDB ngừng hoạt động!${C_RESET}" 5 "$C_CYAN"
  fi

  print_border_bot "$C_CYAN"
}
