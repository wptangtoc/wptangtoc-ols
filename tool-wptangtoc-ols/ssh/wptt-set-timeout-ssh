#!/bin/bash

function huong_dan() {
  Thời gian chờ SSH [SSH timeout] là khoảng thời gian được định cấu hình mà sau đó một kết nối SSH không hoạt động sẽ tự động bị ngắt bởi máy chủ hoặc máy khách.
  Mục đích chính của việc này là để tăng cường bảo mật bằng cách đóng các phiên không sử dụng và giải phóng tài nguyên hệ thống.
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null # Nạp thư viện UI Xác nhận

clear
echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}${quan_ly_ssh} ➜ Cấu hình Thời gian chờ SSH (Timeout)${C_RESET}"
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

echo "Thiết lập SSH TIME OUT: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log

sshd_file="/etc/ssh/sshd_config"
is_active=false

if grep -q "^ClientAliveInterval [1-9]" "$sshd_file"; then
  is_active=true
fi

echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_BOLD_WHITE}TRẠNG THÁI SSH TIMEOUT HIỆN TẠI${C_RESET}"
echo -e "${C_CYAN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
if $is_active; then
  left_text "Trạng thái : ${C_GREEN}ĐANG BẬT (Giữ kết nối liên tục 24 Giờ)${C_RESET}" 2
  left_text "Mô tả      : Hệ thống sẽ gửi gói tin duy trì để bạn không bị văng" 2
  left_text "             ra ngoài khi treo máy (Không thao tác gì)." 2
else
  left_text "Trạng thái : ${C_YELLOW}MẶC ĐỊNH (Tự động ngắt kết nối)${C_RESET}" 2
  left_text "Mô tả      : Kết nối SSH sẽ tự động bị ngắt (Timeout) nếu bạn" 2
  left_text "             không gõ phím hoặc thao tác gì sau một thời gian ngắn." 2
fi
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

# ==============================================================================
# XỬ LÝ LỰA CHỌN ĐẢO TRẠNG THÁI (TOGGLE)
# ==============================================================================
thao_tac_thanh_cong=false
msg_action=""

if $is_active; then
  # ĐANG BẬT -> HỎI KHÔI PHỤC MẶC ĐỊNH
  if wptt_xac_nhan "Bạn có muốn TẮT giữ kết nối và khôi phục về cấu hình Mặc định không?" "" "" "Đồng ý TẮT" "Hủy bỏ"; then
    echo ""
    _runing "Đang khôi phục cấu hình SSH về mặc định..."

    # Dùng Regex thay thế thông minh (Bao trọn mọi giá trị cũ)
    sed -i -E 's/^#?ClientAliveInterval.*/#ClientAliveInterval 0/g' "$sshd_file"
    sed -i -E 's/^#?ClientAliveCountMax.*/#ClientAliveCountMax 3/g' "$sshd_file"

    systemctl restart sshd 2>/dev/null || systemctl restart ssh 2>/dev/null
    _rundone "Đã khôi phục thành công"

    thao_tac_thanh_cong=true
    msg_action="TẮT giữ kết nối (Trở về Mặc định)"
  fi
else
  # ĐANG TẮT -> HỎI BẬT LÊN 24H
  if wptt_xac_nhan "Bạn có muốn BẬT tính năng giữ kết nối SSH liên tục 24 giờ không?" "" "" "Đồng ý BẬT" "Hủy bỏ"; then
    echo ""
    _runing "Đang thiết lập thông số ClientAliveInterval (28800)..."

    # Kiểm tra xem tham số có tồn tại trong file chưa
    if grep -q -E "^#?ClientAliveInterval" "$sshd_file"; then
      sed -i -E 's/^#?ClientAliveInterval.*/ClientAliveInterval 28800/g' "$sshd_file"
    else
      echo "ClientAliveInterval 28800" >>"$sshd_file"
    fi

    if grep -q -E "^#?ClientAliveCountMax" "$sshd_file"; then
      sed -i -E 's/^#?ClientAliveCountMax.*/ClientAliveCountMax 3/g' "$sshd_file"
    else
      echo "ClientAliveCountMax 3" >>"$sshd_file"
    fi

    systemctl restart sshd 2>/dev/null || systemctl restart ssh 2>/dev/null
    _rundone "Áp dụng cấu hình thành công"

    thao_tac_thanh_cong=true
    msg_action="BẬT giữ kết nối 24 Giờ (28800s * 3)"
  fi
fi

# ==============================================================================
# BẢNG THÔNG BÁO HOÀN TẤT
# ==============================================================================
if $thao_tac_thanh_cong; then
  echo -e "\n${C_GREEN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_BOLD_WHITE}CẤU HÌNH SSH TIMEOUT HOÀN TẤT${C_RESET}"
  echo -e "${C_GREEN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
  left_text "Hành động    : ${C_YELLOW}$msg_action${C_RESET}" 2
  left_text "Dịch vụ SSH  : Đã được khởi động lại để áp dụng thay đổi." 2
  echo -e "${C_GREEN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"
else
  echo -e "${C_YELLOW}Đã hủy thao tác cấu hình SSH Timeout.${C_RESET}"
fi

[[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-ssh-main 1
