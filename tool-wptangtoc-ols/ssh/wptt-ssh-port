#!/bin/bash
function huong_dan() {
  Việc thay đổi cổng [port] SSH mặc định [thường là cổng 22] là một trong những biện pháp bảo mật cơ bản và hiệu quả cho máy chủ Linux.

  Dưới đây là giới thiệu ngắn gọn về tính năng này:

  Tại sao cần thay đổi cổng SSH?
  * Giảm thiểu tấn công tự động [Automated Attacks]: Rất nhiều bot và script độc hại trên internet tự động quét cổng 22 để tìm kiếm các máy chủ SSH có mật khẩu yếu hoặc lỗ hổng đã biết. Việc đổi sang một cổng khác, ít phổ biến hơn, sẽ làm giảm đáng kể số lượng các cuộc tấn công tự động này.
  * Tăng cường bảo mật qua việc ẩn náu [Security through obscurity]: Mặc dù không phải là biện pháp bảo mật duy nhất và toàn diện, việc ẩn dịch vụ SSH trên một cổng không chuẩn sẽ khiến kẻ tấn công khó khăn hơn trong việc phát hiện và nhắm mục tiêu vào máy chủ của bạn.
  * Tránh xung đột cổng [Port Conflicts]: Trong một số trường hợp hiếm, cổng 22 có thể cần thiết cho một dịch vụ khác [mặc dù điều này không phổ biến].

  Lợi ích chính:
  * Giảm đáng kể log tấn công brute-force.
  * Làm cho máy chủ của bạn ít bị chú ý hơn.

  Đây là một bước đơn giản nhưng mang lại hiệu quả bảo mật đáng kể cho máy chủ của bạn.
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null # Nạp thư viện UI Xác nhận

clear
echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}QUẢN LÝ SSH ➜ $thay_doi_port_ssh${C_RESET}"
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯${C_RESET}\n"

# ==============================================================================
# LẤY PORT HIỆN TẠI VÀ LẤY INPUT TỪ NGƯỜI DÙNG
# ==============================================================================
unset port_checkssh
port_checkssh=$(grep -E '^\s*Port\s+[0-9]+' /etc/ssh/sshd_config | awk '{print $2}' | head -n 1)
port_checkssh=${port_checkssh:-22} # Trả về 22 nếu kết quả rỗng

port=$1 # Xác định port đối số
[[ "$port" == '98' ]] && port=''

echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
left_text "Cổng SSH hiện tại: ${C_GREEN}$port_checkssh${C_RESET}"
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯${C_RESET}"

if [[ -z "$port" ]]; then
  echo -en "${C_CYAN}Nhập Port SSH mới bạn muốn thay đổi (1-65535) [0=Thoát]: ${C_RESET}"
  read -r port

  if [[ "$port" == "0" || -z "$port" ]]; then
    [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-ssh-main 1
    return 2>/dev/null || exit
  fi
fi

# ==============================================================================
# KIỂM TRA ĐIỀU KIỆN (VALIDATION)
# ==============================================================================
# 1. Kiểm tra định dạng
if ! [[ "$port" =~ ^[0-9]+$ ]] || ((port < 1 || port > 65535)); then
  echo -e "\n${C_RED}❌ Lỗi: Cổng (Port) không hợp lệ! Vui lòng nhập số nguyên từ 1 đến 65535.${C_RESET}"
  sleep 2
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-ssh-main 1
  return 2>/dev/null || exit 1
fi

# 2. Kiểm tra trùng lặp với OLS
if [[ "$port" == "$port_checkssh" || "$port" == "80" || "$port" == "443" ]]; then
  echo -e "\n${C_RED}❌ Lỗi: Bạn vui lòng chọn Port khác! Cổng $port đang được sử dụng bởi hệ thống hoặc Webserver.${C_RESET}"
  sleep 2
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-ssh-main 1
  return 2>/dev/null || exit 1
fi

# 3. Kiểm tra trùng lặp với WebGUI OLS
if [[ ! -f /usr/local/lsws/conf/disablewebconsole ]]; then
  port_webgui_openlitespeed=$(cat /usr/local/lsws/admin/conf/admin_config.conf | grep "address" | grep -o '[0-9]\+$')
  if [[ "$port" == "$port_webgui_openlitespeed" ]]; then
    echo -e "\n${C_RED}❌ Lỗi: Bạn vui lòng chọn Port khác! Cổng $port đang được sử dụng bởi OpenLiteSpeed WebGUI.${C_RESET}"
    sleep 2
    [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-ssh-main 1
    return 2>/dev/null || exit 1
  fi
fi

# 4. Kiểm tra trùng lặp Database
if $(cat /etc/*release | grep -q "Ubuntu"); then
  duong_dan_cau_hinh_mariadb="/etc/mysql/my.cnf"
else
  duong_dan_cau_hinh_mariadb="/etc/my.cnf.d/server.cnf"
fi
port_mariadb_remote=$(cat $duong_dan_cau_hinh_mariadb 2>/dev/null | grep 'port=' | grep -o '[0-9]\+$')
if [[ -n "$port_mariadb_remote" && "$port" == "$port_mariadb_remote" ]]; then
  echo -e "\n${C_RED}❌ Lỗi: Bạn vui lòng chọn Port khác! Cổng $port đang được sử dụng bởi MariaDB Remote.${C_RESET}"
  sleep 2
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-ssh-main 1
  return 2>/dev/null || exit 1
fi

# ==============================================================================
# XÁC NHẬN VÀ THỰC THI THAY ĐỔI
# ==============================================================================
echo ""
msg_title="Xác nhận thay đổi cổng kết nối SSH của máy chủ?"
msg_info1="${C_BOLD_WHITE}Port cũ:${C_RESET} ${C_YELLOW}$port_checkssh${C_RESET}"
msg_info2="${C_BOLD_WHITE}Port mới:${C_RESET} ${C_GREEN}$port${C_RESET}"

if wptt_xac_nhan "$msg_title" "$msg_info1" "$msg_info2" "Đồng ý (Lưu cấu hình ngay)" "Không đồng ý (Hủy thao tác)"; then
  echo ""
  echo "Thiết lập thay đổi port SSH: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log
  _runing "Đang thiết lập tường lửa và mở Port $port..."

  # Cấu hình SSHD
  sed -i "/Port/d" /etc/ssh/sshd_config
  sed -i "1 i Port $port" /etc/ssh/sshd_config

  yum -y install policycoreutils-python >/dev/null 2>&1
  semanage port -a -t ssh_port_t -p tcp $port 2>/dev/null

  # Cấu hình Firewalld
  firewalld_service=$(systemctl status firewalld.service 2>/dev/null | grep 'Active' | cut -f2 -d':' | xargs | cut -f1 -d' ' | xargs)
  if [[ "$firewalld_service" == "active" ]]; then
    firewall-cmd --permanent --zone=public --add-port=$port/tcp >/dev/null 2>&1
    firewall-cmd --permanent --zone=public --remove-port=$port_checkssh/tcp >/dev/null 2>&1
    firewall-cmd --reload >/dev/null 2>&1
  fi

  # Cấu hình Fail2ban
  cat >"/etc/fail2ban/jail.d/sshd.local" <<END
[sshd]
enabled = true
port = $port
backend = systemd
logpath = %(sshd_log)s
maxretry = 5
bantime = 3600
END

  # Cấu hình CSF
  if [[ -f /etc/csf/csf.conf ]]; then
    if ! grep -q "^TCP_IN.*$port," /etc/csf/csf.conf; then
      sed -i -r '/^TCP_IN /s/"'$port_checkssh'"/""/; s/([",])'$port_checkssh',|,'$port_checkssh'([,"])/\1\2/' /etc/csf/csf.conf
      sed -i "s/^TCP_IN = \"/TCP_IN = \"$port,/g" /etc/csf/csf.conf
      csf -x >/dev/null 2>&1
      csf -e >/dev/null 2>&1
    fi
  fi

  # Cấu hình NFTables
  nftables_service=$(systemctl status nftables.service 2>/dev/null | grep 'Active' | cut -f2 -d':' | xargs | cut -f1 -d' ' | xargs)
  if [[ "$nftables_service" == "active" ]]; then
    if $(cat /etc/*release | grep -q "Ubuntu"); then
      path_nftables_config="/etc/nftables.conf"
    else
      path_nftables_config="/etc/sysconfig/nftables.conf"
    fi
    if [[ -f "$path_nftables_config" ]]; then
      sed -i '/#port ssh/d' "$path_nftables_config"
      sed -i "/chain input /a\ \ tcp dport $port accept #port ssh" "$path_nftables_config"
      systemctl restart nftables >/dev/null 2>&1
    fi
  fi

  _rundone "Cấu hình tường lửa cho Port $port"

  _runing "Đang nạp lại dịch vụ SSHD và Fail2ban..."
  fail2ban-client reload >/dev/null 2>&1 || systemctl restart fail2ban >/dev/null 2>&1
  systemctl reload sshd 2>/dev/null || systemctl reload ssh 2>/dev/null
  systemctl restart sshd 2>/dev/null || systemctl restart ssh 2>/dev/null

  sed -i "/port_ssh=/d" /etc/wptt/.wptt.conf
  echo "port_ssh=$port" >>/etc/wptt/.wptt.conf
  _rundone "Khởi động lại dịch vụ"

  echo -e "\n${C_GREEN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_BOLD_WHITE}THAY ĐỔI CỔNG SSH THÀNH CÔNG${C_RESET}"
  echo -e "${C_GREEN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
  left_text "${C_BOLD_WHITE}Cổng SSH Mới:${C_RESET} ${C_YELLOW}$port${C_RESET}"
  left_text "${C_RESET}  Bạn cần kết nối lại SSH bằng cổng mới ở lần đăng nhập sau."
  echo -e "${C_GREEN}╰───────────────────────────────────────────────────────────────────────╯${C_RESET}\n"

else
  echo -e "${C_YELLOW}Đã hủy thao tác đổi cổng SSH.${C_RESET}"
fi

[[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-ssh-main 1
