#!/bin/bash
# @author: Gia Tuấn
# @website: https://wptangtoc.com
# @since: 2026

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null

export box_inner_width=78
cron_path="/etc/cron.d/wptangtoc_autologs"

clear
echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}QUẢN LÝ LOGS ➜ Bật / Tắt Tự động dọn dẹp Logs${C_RESET}"
echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

# ==============================================================================
# KIỂM TRA TRẠNG THÁI HIỆN TẠI (STATE DETECTION)
# ==============================================================================
is_autolog_active=0
if [[ -f "$cron_path" ]]; then
    is_autolog_active=1
    # Bóc tách lịch trình hiện tại
    cron_line=$(grep -v "^#" "$cron_path" 2>/dev/null)
    c_phut=$(echo "$cron_line" | awk '{print $1}')
    c_gio=$(echo "$cron_line" | awk '{print $2}')
    c_ngay=$(echo "$cron_line" | awk '{print $3}')
    c_thu=$(echo "$cron_line" | awk '{print $5}')

    if [[ "$c_ngay" != "*" && -n "$c_ngay" ]]; then
        lich_hien_tai="Lúc $c_gio giờ $c_phut phút - Ngày $c_ngay hàng tháng"
    elif [[ "$c_thu" != "*" && -n "$c_thu" ]]; then
        case "$c_thu" in
            0 | 7) lich_hien_tai="Lúc $c_gio giờ $c_phut phút - CN hàng tuần" ;;
            1) lich_hien_tai="Lúc $c_gio giờ $c_phut phút - T2 hàng tuần" ;;
            2) lich_hien_tai="Lúc $c_gio giờ $c_phut phút - T3 hàng tuần" ;;
            3) lich_hien_tai="Lúc $c_gio giờ $c_phut phút - T4 hàng tuần" ;;
            4) lich_hien_tai="Lúc $c_gio giờ $c_phut phút - T5 hàng tuần" ;;
            5) lich_hien_tai="Lúc $c_gio giờ $c_phut phút - T6 hàng tuần" ;;
            6) lich_hien_tai="Lúc $c_gio giờ $c_phut phút - T7 hàng tuần" ;;
        esac
    else
        lich_hien_tai="Lúc $c_gio giờ $c_phut phút - Hàng ngày"
    fi
fi

# In Dashboard Trạng Thái
echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
if [[ $is_autolog_active -eq 1 ]]; then
    left_text "Trạng thái Dọn rác : ${C_GREEN}ĐANG BẬT (Active)${C_RESET}" 2
    left_text "Lịch trình chạy    : ${C_YELLOW}$lich_hien_tai${C_RESET}" 2
else
    left_text "Trạng thái Dọn rác : ${C_YELLOW}ĐANG TẮT (Inactive)${C_RESET}" 2
fi
echo -e "${C_CYAN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
left_text "Tính năng này giúp tự động dọn dẹp các file Log của Web và Server," 2
left_text "ngăn chặn triệt để tình trạng sập Database do đầy ổ cứng." 2
echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

# ==============================================================================
# NHÁNH 1: ĐANG TẮT -> HỎI ĐỂ BẬT LÊN
# ==============================================================================
if [[ $is_autolog_active -eq 0 ]]; then
    if wptt_xac_nhan "Sếp có muốn KÍCH HOẠT Hẹn giờ dọn dẹp Logs không?" "Hệ thống sẽ chạy ngầm vào thời gian sếp chỉ định," "xóa sạch mọi dung lượng rác mà không ảnh hưởng tốc độ web." "Đồng ý BẬT" "Hủy thao tác"; then
        echo ""
        
        # Nhập thời gian
        while true; do
            echo -en "${C_CYAN}Nhập Giờ muốn chạy tự động xóa log (0-23) [Enter=2h sáng]: ${C_RESET}"
            read gio
            [[ -z "$gio" ]] && gio="2"
            if [[ ! "$gio" =~ ^[0-9]+$ ]] || ((gio < 0 || gio > 23)); then
                echo -e "${C_RED}❌ Lỗi: Giờ không hợp lệ! Vui lòng nhập từ 0 đến 23.${C_RESET}"
            else
                break
            fi
        done

        . /etc/wptt/wptt-times-tuan
        tuan

        case "$thu" in
            0 | 7) thu12="Chủ nhật hàng tuần" ;;
            1) thu12="Thứ hai hàng tuần" ;;
            2) thu12="Thứ ba hàng tuần" ;;
            3) thu12="Thứ tư hàng tuần" ;;
            4) thu12="Thứ năm hàng tuần" ;;
            5) thu12="Thứ sáu hàng tuần" ;;
            6) thu12="Thứ bảy hàng tuần" ;;
            *) thu12="Hàng ngày" ;;
        esac
        [[ "$thu" == "9" ]] && thu12="Ngày $ngay_cua_thang hàng tháng"

        phut=$(shuf -i2-58 -n1)
        [[ -z "$phut" ]] && phut='0'
        
        cron_thuc_thi="$phut $gio * * $thu"
        [[ "$thu" == '9' ]] && cron_thuc_thi="$phut $gio $ngay_cua_thang * *"

        _runing "Đang thiết lập Cronjob hệ thống..."
        cat >"$cron_path" <<END
$cron_thuc_thi root /bin/bash /etc/wptt/logs/wptt-xoa-logs cron >/dev/null 2>&1
END
        chmod 644 "$cron_path"

        if grep -q "Ubuntu" /etc/*release 2>/dev/null; then
            systemctl restart cron.service >/dev/null 2>&1
        else
            systemctl restart crond.service >/dev/null 2>&1
        fi
        echo "Bật tự động dọn logs: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log
        _rundone "Cấu hình Cronjob thành công"

        # BẢNG BÁO CÁO BẬT
        echo -e "\n${C_GREEN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
        center_text "${C_BOLD_WHITE}HOÀN TẤT KÍCH HOẠT TỰ ĐỘNG DỌN LOGS${C_RESET}"
        echo -e "${C_GREEN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
        left_text "Chu kỳ chạy : ${C_GREEN}$gio giờ $phut phút - $thu12${C_RESET}" 2
        left_text "Trạng thái  : Chạy ẩn nền (Silent Mode) không làm phiền." 2
        echo -e "${C_GREEN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"
    else
        echo -e "${C_YELLOW}Đã hủy thao tác bật tính năng dọn rác.${C_RESET}\n"
    fi

# ==============================================================================
# NHÁNH 2: ĐANG BẬT -> HỎI ĐỂ TẮT ĐI
# ==============================================================================
else
    if wptt_xac_nhan "Sếp có CHẮC CHẮN muốn TẮT tự động dọn dẹp Logs không?" "Nếu tắt, sếp sẽ phải tự gõ lệnh dọn dẹp bằng tay." "Hãy cẩn thận theo dõi dung lượng ổ cứng để tránh đầy!" "Đồng ý TẮT" "Hủy thao tác"; then
        echo ""
        
        _runing "Đang gỡ bỏ cấu hình Hẹn giờ dọn dẹp..."
        rm -f "$cron_path"
        
        if grep -q "Ubuntu" /etc/*release 2>/dev/null; then
            systemctl restart cron.service >/dev/null 2>&1
        else
            systemctl restart crond.service >/dev/null 2>&1
        fi
        echo "Tắt tự động dọn logs: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log
        _rundone "Gỡ bỏ cấu hình thành công"

        # BẢNG BÁO CÁO TẮT
        echo -e "\n${C_GREEN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
        center_text "${C_BOLD_WHITE}HOÀN TẤT GỠ BỎ TỰ ĐỘNG DỌN LOGS${C_RESET}"
        echo -e "${C_GREEN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
        left_text "Hệ thống sẽ không tự động xóa log nữa. Sếp nhớ kiểm tra" 2
        left_text "dung lượng định kỳ bằng lệnh df -h nhé!" 2
        echo -e "${C_GREEN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"
    else
        echo -e "${C_YELLOW}Đã hủy thao tác tắt tính năng dọn rác.${C_RESET}\n"
    fi
fi

[[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-logs-main 1
