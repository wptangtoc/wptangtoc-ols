#!/bin/bash
# @author: Gia Tuấn
# @website: https://wptangtoc.com
# @since: 2026

function huong_dan() {
  Việc xem log cho database server thông qua WPTangToc OLS thường sẽ tận dụng các công cụ sẵn có của hệ điều hành Linux.

  Tính năng xem log database trong WPTangToc OLS có thể được hiểu ngắn gọn như sau:

  Xác định vị trí file log: Đường dẫn phổ biến thường là /var/log/mysql/mysql.log. Script cung cấp trình đọc chuyên nghiệp [Less] để truy cập an toàn vào file log này mà không làm treo máy chủ.

  Tính năng này hỗ trợ người dùng dễ dàng hơn trong việc tìm và sử dụng các công cụ có sẵn của hệ thống để xem toàn bộ các truy vấn SQL đang diễn ra. Điều này giúp quản trị viên hệ thống nhanh chóng kiểm tra, phát hiện các truy vấn bất thường hoặc gỡ lỗi [Debug] ứng dụng kết nối tới database.
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null # Nạp thư viện UI Xác nhận

clear
echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}QUẢN LÝ LOGS ➜ Xem General Log Database (Trình đọc Less)${C_RESET}"
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

LOG_FILE="/var/log/mysql/mysql.log"

# ==============================================================================
# KIỂM TRA ĐIỀU KIỆN (UX BO CONG)
# ==============================================================================
if [[ ! -f "$LOG_FILE" ]]; then
  echo -e "${C_RED}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_BOLD_WHITE}DATABASE CHƯA ĐƯỢC BẬT TÍNH NĂNG GHI LOGS${C_RESET}"
  echo -e "${C_RED}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
  left_text "${C_YELLOW}Hệ thống không tìm thấy file: $LOG_FILE${C_RESET}" 2
  left_text "Mặc định tính năng ghi Log DB bị TẮT để bảo vệ ổ cứng và CPU." 2
  left_text "Để xem Log, bạn cần vào [Menu Quản lý Logs] -> Chọn tính năng" 2
  left_text "[Bật/Tắt Ghi Logs Database] và kích hoạt nó lên trước nhé." 2
  echo -e "${C_RED}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-logs-main 1
  exit 0
fi

# ==============================================================================
# HƯỚNG DẪN TRÌNH ĐỌC LESS CHUYÊN NGHIỆP
# ==============================================================================
echo -e "${C_GREEN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_BOLD_WHITE}HƯỚNG DẪN SỬ DỤNG TRÌNH ĐỌC LOG (LESS)${C_RESET}"
echo -e "${C_GREEN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
left_text "File đang xem : ${C_YELLOW}$LOG_FILE${C_RESET}" 2
echo -e "${C_GREEN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
left_text " ⬇️ ⬆️  Nhấn phím mũi tên [Lên/Xuống] để cuộn từng dòng." 2
left_text " ␣    Nhấn phím [Space] để cuộn nhanh từng trang." 2
left_text " 🔍   Nhấn phím [/] và nhập từ khóa để TÌM KIẾM (Bấm 'n' tìm tiếp)." 2
left_text " ❌   ${C_RED}Nhấn phím [q] để THOÁT${C_RESET} và quay lại Menu." 2
echo -e "${C_GREEN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

echo -e "${C_CYAN}Đang chuẩn bị dữ liệu và mở trình đọc log...${C_RESET}"
sleep 3

# Làm sạch màn hình trước khi gọi less để giao diện log tràn viền sạch sẽ
clear

# Sử dụng less với tham số +G để tự động nhảy xuống dòng log mới nhất ở cuối file
less +G "$LOG_FILE"

# Sau khi bấm q thoát khỏi less, làm sạch màn hình và tự động quay lại Menu
clear
[[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-logs-main 1
