#!/bin/bash
# @author: Gia Tuấn
# @website: https://wptangtoc.com
# @since: 2026

function huong_dan() {
  Việc xem log cho database server thông qua WPTangToc OLS thường sẽ tận dụng các công cụ sẵn có của hệ điều hành Linux.

  Tính năng xem log database trong WPTangToc OLS có thể được hiểu ngắn gọn như sau:

  Xác định vị trí file log: Đường dẫn phổ biến thường là /var/log/mysql/mysql.log. Script cung cấp trình đọc chuyên nghiệp [Less] để truy cập an toàn vào file log này mà không làm treo máy chủ.

  Tính năng này hỗ trợ người dùng dễ dàng hơn trong việc tìm và sử dụng các công cụ có sẵn của hệ thống để xem toàn bộ các truy vấn SQL đang diễn ra. Điều này giúp quản trị viên hệ thống nhanh chóng kiểm tra, phát hiện các truy vấn bất thường hoặc gỡ lỗi [Debug] ứng dụng kết nối tới database.
}

. /etc/wptt/.wptt.conf
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh
. /etc/wptt/echo-color

clear
echo -e "\n========================================================================="
echo -e "| Quản lý Logs => Xem Logs Database (Trình đọc Less)                    |"
echo -e "=========================================================================\n"

LOG_FILE="/var/log/mysql/mysql.log"

# ==============================================================================
# KIỂM TRA ĐIỀU KIỆN
# ==============================================================================
if [[ ! -f "$LOG_FILE" ]]; then
  echo -e "\033[1;33m[!] Bạn chưa kích hoạt ghi Log Database hoặc file log chưa được tạo!\033[0m"
  echo "Tính năng ghi Log DB thường bị tắt mặc định để tránh làm đầy ổ cứng."
  echo "Nếu muốn xem, vui lòng kích hoạt trong: Menu Quản lý Logs => Kích hoạt ghi logs database."
  echo ""
  read -p "Nhấn phím [Enter] để quay lại menu..." dummy
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-logs-main 1
  exit 0
fi

# ==============================================================================
# SỬ DỤNG TRÌNH ĐỌC LESS CHUYÊN NGHIỆP
# ==============================================================================
echo -e "\033[1;36m=========================================================================\033[0m"
echo -e "\033[1;33m ĐANG XEM FILE LOG DATABASE:\033[0m $LOG_FILE"
echo -e "\033[1;36m=========================================================================\033[0m"
echo -e "\033[1;32m HƯỚNG DẪN SỬ DỤNG TRÌNH ĐỌC (LESS):\033[0m"
echo " - Nhấn phím mũi tên [Lên/Xuống] để cuộn từng dòng."
echo " - Nhấn phím [Space] để cuộn từng trang."
echo " - Nhấn phím [/] và nhập từ khóa để TÌM KIẾM (Nhấn 'n' để tìm tiếp)."
echo -e " - \033[1;31mNhấn phím [q] để THOÁT\033[0m và quay lại Menu."
echo -e "\033[1;36m=========================================================================\033[0m"
echo "Đang mở trình đọc log trong 3 giây..."
sleep 3

# Sử dụng less với tham số +G để tự động nhảy xuống dòng log mới nhất ở cuối file
less +G "$LOG_FILE"

# Sau khi bấm q thoát khỏi less, tự động quay lại Menu
[[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-logs-main 1
