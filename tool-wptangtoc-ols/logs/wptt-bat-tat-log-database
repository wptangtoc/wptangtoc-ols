#!/bin/bash
# @author: Gia Tuấn
# @website: https://wptangtoc.com
# @since: 2026

function huong_dan() {
  Tính năng Bật / Tắt ghi log database cho phép người dùng cấu hình hệ quản trị cơ sở dữ liệu MariaDB để bật hoặc ngừng việc ghi lại các hoạt động, truy vấn, hoặc lỗi vào các tệp nhật ký.

  Các loại log database phổ biến bao gồm:
  * General Query Log: Ghi lại mọi truy vấn được gửi đến database.
  * Slow Query Log: Ghi lại các truy vấn chạy chậm hơn một ngưỡng thời gian nhất định [giúp tìm ra các plugin hoặc theme làm chậm web].
  * Error Log: Ghi lại các lỗi khi khởi động, chạy, hoặc dừng database.
  * Binary Log [Binlog]: Ghi lại mọi thay đổi đối với dữ liệu.

  Mục đích chính của việc TẮT ghi log database là:
  * Cải thiện hiệu suất [Performance]: 🚀 Việc ghi log tiêu tốn tài nguyên I/O và CPU. Tắt chúng giúp database chạy nhanh hơn.
  * Tiết kiệm dung lượng ổ cứng: 💾 Các tệp log có thể phình to rất nhanh. Tắt chúng giúp bảo vệ không gian lưu trữ.

  Tóm lại, đây là một công cụ giúp tối ưu hiệu suất và dung lượng. Mặc định nên TẮT để web chạy nhanh nhất, chỉ BẬT khi bạn cần bắt bệnh [debug] lỗi truy vấn chậm của website.
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null # Nạp thư viện UI Xác nhận

clear
echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}QUẢN LÝ LOGS ➜ Bật / Tắt Ghi Logs Database (MariaDB/MySQL)${C_RESET}"
echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

# ==============================================================================
# 1. NHẬN DIỆN ĐƯỜNG DẪN CẤU HÌNH TỰ ĐỘNG
# ==============================================================================
if grep -qi "ubuntu" /etc/os-release 2>/dev/null; then
  CONF_DB="/etc/mysql/my.cnf"
else
  CONF_DB="/etc/my.cnf.d/server.cnf"
fi

if [[ ! -f "$CONF_DB" ]]; then
  echo -e "${C_RED}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_BOLD_WHITE}LỖI: KHÔNG TÌM THẤY FILE CẤU HÌNH DATABASE${C_RESET}"
  echo -e "${C_RED}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
  left_text "${C_YELLOW}Đường dẫn kiểm tra : $CONF_DB${C_RESET}" 2
  left_text "Vui lòng kiểm tra lại dịch vụ MariaDB/MySQL trên máy chủ." 2
  echo -e "${C_RED}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"
  sleep 3
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-logs-main 1
  exit 1
fi

# Nếu có dòng skip-log-bin thì tức là đang TẮT
trang_thai="1"
if grep -q "skip-log-bin" "$CONF_DB" 2>/dev/null; then
  trang_thai="0"
fi

echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
if [[ "$trang_thai" == "1" ]]; then
  left_text "Trạng thái Database : ${C_GREEN}ĐANG GHI LOGS (Bật)${C_RESET}" 2
  left_text "Cảnh báo hiệu suất  : ${C_YELLOW}Tốc độ bị giảm, tiêu tốn CPU & Ổ cứng${C_RESET}" 2
else
  left_text "Trạng thái Database : ${C_YELLOW}KHÔNG GHI LOGS (Tắt)${C_RESET}" 2
  left_text "Hiệu suất hoạt động : ${C_GREEN}Tối đa (Raw Performance)${C_RESET}" 2
fi
echo -e "${C_CYAN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
left_text "WPTangToc OLS khuyến nghị TẮT Logs DB để tiết kiệm tài nguyên." 2
left_text "Chỉ nên BẬT khi bạn cần bắt bệnh (Debug) web lỗi hoặc truy vấn chậm." 2
echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

# ==============================================================================
# 3. XỬ LÝ LÔGIC ĐẢO TRẠNG THÁI (TOGGLE)
# ==============================================================================
if [[ "$trang_thai" == "1" ]]; then
  # NHÁNH ĐANG BẬT -> HỎI TẮT
  if wptt_xac_nhan "Tính năng ghi Logs Database đang BẬT. Bạn có muốn TẮT không?" "Lưu ý: Hệ thống sẽ tự động xóa sạch các file Log hiện tại" "trong /var/log/mysql/ để giải phóng dung lượng đĩa." "Đồng ý TẮT Logs" "Hủy thao tác"; then
    echo ""
    _runing "Đang gỡ bỏ cấu hình ghi Log khỏi MariaDB..."

    # Dọn dẹp sạch sẽ cấu hình cũ
    sed -i '/log-bin/d' "$CONF_DB"
    sed -i '/slow-query-log/d' "$CONF_DB"
    sed -i '/long_query_time/d' "$CONF_DB"
    sed -i '/general_log/d' "$CONF_DB"
    sed -i '/general-log/d' "$CONF_DB"
    sed -i '/log-error/d' "$CONF_DB"

    # Thêm cờ bỏ qua ghi log (skip-log-bin)
    sed -i '/skip-log-bin/d' "$CONF_DB"
    sed -i '/\[mysqld\]/a skip-log-bin' "$CONF_DB"
    _rundone "Cập nhật file cấu hình my.cnf thành công"

    _runing "Đang xóa dữ liệu rác và khởi động lại dịch vụ MariaDB..."
    # Giải phóng ổ cứng ngay lập tức
    rm -rf /var/log/mysql/* >/dev/null 2>&1

    # Khởi động lại
    systemctl restart mariadb.service >/dev/null 2>&1

    echo "Tắt ghi Log Database: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log
    _rundone "Dịch vụ đã được nạp lại. I/O đĩa được tối ưu."

    # BẢNG BÁO CÁO TẮT
    echo -e "\n${C_GREEN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
    center_text "${C_BOLD_WHITE}HOÀN TẤT TẮT LOGS DATABASE${C_RESET}"
    echo -e "${C_GREEN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
    left_text "Dịch vụ MariaDB đã trở lại trạng thái hoạt động hiệu suất cao." 2
    left_text "Dữ liệu logs cũ đã được xóa bỏ để giải phóng ổ cứng." 2
    echo -e "${C_GREEN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"
  else
    echo -e "${C_YELLOW}Đã hủy thao tác tắt Log Database.${C_RESET}\n"
    [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-logs-main 1
    exit 0
  fi

else
  # NHÁNH ĐANG TẮT -> HỎI BẬT
  if wptt_xac_nhan "Tính năng ghi Logs Database đang TẮT. Bạn có muốn BẬT không?" "Lưu ý: Bật log sẽ làm Database chậm lại đôi chút và tiêu tốn" "dung lượng đĩa (Do phải ghi Binlog, Error log, Slow Query log)." "Đồng ý BẬT Logs" "Hủy thao tác"; then
    echo ""
    _runing "Đang thiết lập thư mục và phân quyền chứa Logs..."

    # Tạo thư mục và cấp quyền
    mkdir -p /var/log/mysql
    chown -R mysql:mysql /var/log/mysql
    _rundone "Thiết lập thư mục /var/log/mysql thành công"

    _runing "Đang tiêm cấu hình Tracking (Binlog, Slow Query, Error)..."
    # Dọn dẹp cấu hình cũ
    sed -i '/skip-log-bin/d' "$CONF_DB"
    sed -i '/log-bin/d' "$CONF_DB"
    sed -i '/slow-query-log/d' "$CONF_DB"
    sed -i '/long_query_time/d' "$CONF_DB"
    sed -i '/general_log/d' "$CONF_DB"
    sed -i '/general-log/d' "$CONF_DB"
    sed -i '/log-error/d' "$CONF_DB"

    # Tiêm cấu hình mới
    sed -i '/\[mysqld\]/a log-bin=/var/log/mysql/mysql-bin.log\ngeneral-log=1\ngeneral_log_file=/var/log/mysql/mysql.log\nlog-error=/var/log/mysql/mysql-error.log\nslow-query-log=1\nslow-query-log-file=/var/log/mysql/mysql-slow.log\nlong_query_time=1' "$CONF_DB"
    _rundone "Đã tiêm thông số vào my.cnf"

    _runing "Đang nạp lại dịch vụ MariaDB để áp dụng..."
    systemctl restart mariadb.service >/dev/null 2>&1
    echo "Bật ghi Log Database: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log
    _rundone "Dịch vụ đã được kích hoạt chế độ theo dõi Logs"

    # BẢNG BÁO CÁO BẬT KÈM DANH SÁCH FILE
    echo -e "\n${C_GREEN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
    center_text "${C_BOLD_WHITE}HOÀN TẤT KÍCH HOẠT LOGS DATABASE${C_RESET}"
    echo -e "${C_GREEN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
    left_text "Hệ thống đã bắt đầu ghi nhận hoạt động của Database." 2
    left_text "Bạn có thể kiểm tra lỗi/truy vấn chậm tại các file sau:" 2
    echo -e "${C_GREEN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
    left_text " ${C_CYAN}1.${C_RESET} General Log: ${C_YELLOW}/var/log/mysql/mysql.log${C_RESET}" 2
    left_text " ${C_CYAN}2.${C_RESET} Slow Log   : ${C_YELLOW}/var/log/mysql/mysql-slow.log${C_RESET}" 2
    left_text " ${C_CYAN}3.${C_RESET} Error Log  : ${C_YELLOW}/var/log/mysql/mysql-error.log${C_RESET}" 2
    left_text " ${C_CYAN}4.${C_RESET} Binlog     : ${C_YELLOW}/var/log/mysql/mysql-bin.log${C_RESET}" 2
    echo -e "${C_GREEN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

  else
    echo -e "${C_YELLOW}Đã hủy thao tác bật Log Database.${C_RESET}\n"
    [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-logs-main 1
    exit 0
  fi
fi

[[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-logs-main 1
