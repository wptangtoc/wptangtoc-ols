#!/bin/bash
# @author: Gia Tuấn
# @website: https://wptangtoc.com
# @since: 2026

function huong_dan() {
  Việc xem access log server cho IP public thông qua WPTangToc OLS thường sẽ tận dụng các công cụ sẵn có của hệ điều hành Linux.

  Tính năng xem access log server trong WPTangToc OLS có thể được hiểu ngắn gọn như sau:

  Xác định vị trí file log: OpenLiteSpeed thường lưu access log server trong một file riêng biệt. Đường dẫn phổ biến có thể là /usr/local/lsws/logs/access.log. Script cung cấp một trình đọc chuyên nghiệp để truy cập vào file log này.

  Tính năng này hỗ trợ người dùng dễ dàng hơn trong việc tìm và sử dụng các công cụ có sẵn của hệ thống để xem access log tổng của OpenLiteSpeed. Điều này giúp quản trị viên hệ thống nhanh chóng kiểm tra lưu lượng truy cập toàn cục, phát hiện lỗi hoặc các hoạt động quét cổng/IP bất thường.
}

. /etc/wptt/.wptt.conf
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh
. /etc/wptt/echo-color

clear
echo -e "\n========================================================================="
echo -e "| Quản lý Logs => Xem Access Log Server Tổng (Trình đọc Less)           |"
echo -e "=========================================================================\n"

CONF_FILE="/usr/local/lsws/conf/httpd_config.conf"
LOG_FILE="/usr/local/lsws/logs/access.log"

# ==============================================================================
# KIỂM TRA ĐIỀU KIỆN
# ==============================================================================
if ! grep -q 'accesslog' "$CONF_FILE" 2>/dev/null; then
  echo -e "\033[1;33m[!] Bạn chưa kích hoạt ghi Access Log Server!\033[0m"
  echo "Tính năng này mặc định được tắt để bảo vệ hiệu suất hệ thống và ổ cứng."
  echo "Nếu muốn xem, vui lòng kích hoạt trong: Menu Quản lý Logs => Bật/Tắt ghi Access log server."
  echo ""
  read -p "Nhấn phím [Enter] để quay lại menu..." dummy
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-logs-main 1
  exit 0
fi

if [[ ! -f "$LOG_FILE" ]]; then
  echoDo "Lỗi: File $LOG_FILE không tồn tại hoặc chưa có dữ liệu!"
  sleep 3
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-logs-main 1
  exit 0
fi

# ==============================================================================
# SỬ DỤNG TRÌNH ĐỌC LESS CHUYÊN NGHIỆP
# ==============================================================================
echo -e "\033[1;36m=========================================================================\033[0m"
echo -e "\033[1;33m ĐANG XEM FILE LOG SERVER TỔNG:\033[0m $LOG_FILE"
echo -e "\033[1;36m=========================================================================\033[0m"
echo -e "\033[1;32m HƯỚNG DẪN SỬ DỤNG TRÌNH ĐỌC (LESS):\033[0m"
echo " - Nhấn phím mũi tên [Lên/Xuống] để cuộn từng dòng."
echo " - Nhấn phím [Space] để cuộn từng trang."
echo " - Nhấn phím [/] và nhập từ khóa để TÌM KIẾM (Nhấn 'n' để tìm tiếp)."
echo -e " - \033[1;31mNhấn phím [q] để THOÁT\033[0m và quay lại Menu."
echo -e "\033[1;36m=========================================================================\033[0m"
echo "Đang mở trình đọc log trong 3 giây..."
sleep 3

# Sử dụng less với tham số +G để tự động nhảy xuống dòng log mới nhất ở cuối file
less +G "$LOG_FILE"

# Sau khi bấm q thoát khỏi less, tự động quay lại Menu
[[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-logs-main 1
