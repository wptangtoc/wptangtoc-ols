#!/bin/bash
# @author: Gia Tuấn
# @website: https://wptangtoc.com
# @since: 2026

function huong_dan() {
  Việc xem log truy vấn chậm [Slow Query Log] cho database server thông qua WPTangToc OLS thường sẽ tận dụng các công cụ sẵn có của hệ điều hành Linux.

  Tính năng xem log database truy vấn chậm trong WPTangToc OLS có thể được hiểu ngắn gọn như sau:

  Xác định vị trí file log: Đường dẫn chuẩn là /var/log/mysql/mysql-slow.log. Script cung cấp một trình đọc chuyên nghiệp [Less] để truy cập an toàn vào file log này.

  Tính năng này hỗ trợ người dùng dễ dàng theo dõi các câu lệnh SQL mất nhiều thời gian để thực thi. Điều này giúp quản trị viên website nhanh chóng kiểm tra, phát hiện các plugin/theme hoặc đoạn code gây nghẽn cổ chai [bottleneck] và làm chậm website.
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null # Nạp thư viện UX Bo Cong

clear
echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}QUẢN LÝ LOGS ➜ Xem Slow Query Log Database (Truy vấn chậm)${C_RESET}"
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

LOG_FILE="/var/log/mysql/mysql-slow.log"

# ==============================================================================
# KIỂM TRA ĐIỀU KIỆN (UX BO CONG)
# ==============================================================================
if [[ ! -f "$LOG_FILE" ]]; then
  echo -e "${C_RED}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_BOLD_WHITE}KHÔNG TÌM THẤY FILE LOG TRUY VẤN CHẬM${C_RESET}"
  echo -e "${C_RED}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
  left_text "${C_YELLOW}Hệ thống không tìm thấy file: $LOG_FILE${C_RESET}" 2
  left_text "Điều này thường do 2 nguyên nhân:" 2
  left_text " 1. Bạn chưa kích hoạt tính năng [Ghi Logs Database]." 2
  left_text " 2. Hoặc website của bạn đang chạy rất mượt, chưa có truy vấn" 2
  left_text "    SQL nào vượt quá thời gian cho phép để bị ghi vào Log." 2
  echo -e "${C_RED}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-logs-main 1
  exit 0
fi

# ==============================================================================
# HƯỚNG DẪN TRÌNH ĐỌC LESS CHUYÊN NGHIỆP
# ==============================================================================
echo -e "${C_GREEN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_BOLD_WHITE}HƯỚNG DẪN SỬ DỤNG TRÌNH ĐỌC LOG (LESS)${C_RESET}"
echo -e "${C_GREEN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
left_text "File đang xem : ${C_YELLOW}$LOG_FILE${C_RESET}" 2
echo -e "${C_GREEN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
left_text " ⬇️ ⬆️  Nhấn phím mũi tên [Lên/Xuống] để cuộn từng dòng." 2
left_text " ␣    Nhấn phím [Space] để cuộn nhanh từng trang." 2
left_text " 🔍   Nhấn phím [/] và nhập từ khóa để TÌM KIẾM (Bấm 'n' tìm tiếp)." 2
left_text " ❌   ${C_RED}Nhấn phím [q] để THOÁT${C_RESET} và quay lại Menu." 2
echo -e "${C_GREEN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

echo -e "${C_CYAN}Đang chuẩn bị dữ liệu và mở trình đọc log...${C_RESET}"
sleep 3

# Làm sạch màn hình trước khi gọi less để giao diện log tràn viền sạch sẽ
clear

# Sử dụng less với tham số +G để tự động nhảy xuống dòng log mới nhất ở cuối file
less +G "$LOG_FILE"

# Sau khi bấm q thoát khỏi less, làm sạch màn hình và tự động quay lại Menu
clear
[[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-logs-main 1
