#!/bin/bash
# @author: Gia Tuấn
# @website: https://wptangtoc.com
# @since: 2026

function huong_dan() {
  Việc xem log truy vấn chậm [Slow Query Log] cho database server thông qua WPTangToc OLS thường sẽ tận dụng các công cụ sẵn có của hệ điều hành Linux.

  Tính năng xem log database truy vấn chậm trong WPTangToc OLS có thể được hiểu ngắn gọn như sau:

  Xác định vị trí file log: Đường dẫn chuẩn là /var/log/mysql/mysql-slow.log. Script cung cấp một trình đọc chuyên nghiệp [Less] để truy cập an toàn vào file log này.

  Tính năng này hỗ trợ người dùng dễ dàng theo dõi các câu lệnh SQL mất nhiều thời gian để thực thi. Điều này giúp quản trị viên website nhanh chóng kiểm tra, phát hiện các plugin/theme hoặc đoạn code gây nghẽn cổ chai [bottleneck] và làm chậm website.
}

. /etc/wptt/.wptt.conf
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh
. /etc/wptt/echo-color

clear
echo -e "\n========================================================================="
echo -e "| Quản lý Logs => Xem Log Database Truy Vấn Chậm (Trình đọc Less)       |"
echo -e "=========================================================================\n"

# Đã sửa lại đường dẫn cho khớp với cấu hình file wptt-bat-tat-log-db
LOG_FILE="/var/log/mysql/mysql-slow.log"

# ==============================================================================
# KIỂM TRA ĐIỀU KIỆN
# ==============================================================================
if [[ ! -f "$LOG_FILE" ]]; then
  echo -e "\033[1;33m[!] Bạn chưa kích hoạt ghi Log Database hoặc chưa có truy vấn chậm nào xảy ra!\033[0m"
  echo "Vui lòng đảm bảo bạn đã BẬT tính năng ghi log trong: Menu Quản lý Logs => Bật / Tắt ghi Logs Database."
  echo ""
  read -p "Nhấn phím [Enter] để quay lại menu..." dummy
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-logs-main 1
  exit 0
fi

# ==============================================================================
# SỬ DỤNG TRÌNH ĐỌC LESS CHUYÊN NGHIỆP
# ==============================================================================
echo -e "\033[1;36m=========================================================================\033[0m"
echo -e "\033[1;33m ĐANG XEM FILE LOG TRUY VẤN CHẬM:\033[0m $LOG_FILE"
echo -e "\033[1;36m=========================================================================\033[0m"
echo -e "\033[1;32m HƯỚNG DẪN SỬ DỤNG TRÌNH ĐỌC (LESS):\033[0m"
echo " - Nhấn phím mũi tên [Lên/Xuống] để cuộn từng dòng."
echo " - Nhấn phím [Space] để cuộn từng trang."
echo " - Nhấn phím [/] và nhập từ khóa để TÌM KIẾM (Nhấn 'n' để tìm tiếp)."
echo -e " - \033[1;31mNhấn phím [q] để THOÁT\033[0m và quay lại Menu."
echo -e "\033[1;36m=========================================================================\033[0m"
echo "Đang mở trình đọc log trong 3 giây..."
sleep 3

# Sử dụng less với tham số +G để tự động nhảy xuống dòng log mới nhất ở cuối file
less +G "$LOG_FILE"

# Sau khi bấm q thoát khỏi less, tự động quay lại Menu
[[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-logs-main 1
