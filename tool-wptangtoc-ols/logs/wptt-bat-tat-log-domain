# @since: 2026

function huong_dan() {
  Tính năng Bật / Tắt ghi access.log và error.log cho phép bạn kiểm soát việc ghi lại nhật ký truy cập và lỗi cho một website cụ thể trên OpenLiteSpeed.

  1. Kích hoạt [Bật]:
  * access.log: Ghi lại mọi yêu cầu truy cập [IP, thời gian, URL, trình duyệt...]. Rất tốt để phân tích lưu lượng.
  * error.log: Ghi lại các lỗi máy chủ, cấu hình, PHP... Là công cụ bắt buộc phải có khi web bị lỗi 500, trắng trang.

  2. Hủy kích hoạt [Tắt]:
  * Giúp tiết kiệm dung lượng ổ cứng [đặc biệt với web traffic khủng].
  * Giảm tải thao tác ghi đĩa [I/O] và tiết kiệm một chút CPU.
  * KHÔNG KHUYẾN KHÍCH tắt error.log trừ khi bạn thực sự không bao giờ xem log và muốn tối ưu 100% tài nguyên phần cứng.

  Bạn có thể dễ dàng Bật/Tắt bằng 1 cú chạm. Hệ thống sẽ tự động nhận diện trạng thái hiện tại để thao tác đảo ngược [Toggle].
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null # Nạp thư viện UI Xác nhận

clear
echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}QUẢN LÝ LOGS ➜ Bật / Tắt ghi Error & Access Logs Domain${C_RESET}"
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

# ==============================================================================
# HÀM MENU LỌC THÔNG MINH (CÓ TRẠNG THÁI + FZF) - UX BO CONG
# ==============================================================================
function lua_chon_NAME() {
  unset NAME selects
  selects=()
  local box_inner_width=${box_inner_width:-71}

  # Gộp danh sách file từ cả 2 thư mục (vhost thường và chuyển hướng)
  local file_list=()
  [[ -d /etc/wptt/vhost ]] && file_list+=(/etc/wptt/vhost/.*.conf)
  [[ -d /etc/wptt/chuyen-huong ]] && file_list+=(/etc/wptt/chuyen-huong/*)

  # Vòng lặp Globbing siêu tốc không qua sub-shell
  for filepath in "${file_list[@]}"; do
    [[ ! -f "$filepath" || "$filepath" == *"/..conf" || "$filepath" == *"*"* ]] && continue

    local dom="${filepath##*/}"
    dom="${dom%.conf}"
    dom="${dom#.}"

    if [[ "$dom" == ?*.?* ]]; then
      local vhost_conf="/usr/local/lsws/conf/vhosts/$dom/$dom.conf"

      if [[ -f "$vhost_conf" ]]; then
        # Kiểm tra trạng thái xem file cấu hình có đang bật errorlog không
        if grep -q 'errorlog ' "$vhost_conf" 2>/dev/null; then
          selects+=("$dom|1") # 1 = Đang Bật
        else
          selects+=("$dom|0") # 0 = Đang Tắt
        fi
      fi
    fi
  done

  # Lọc trùng lặp và sắp xếp mảng
  if [[ ${#selects[@]} -eq 0 ]]; then
    echo -e "${C_YELLOW}Không tìm thấy website nào trên hệ thống để thao tác!${C_RESET}"
    sleep 3
    exec /etc/wptt/wptt-logs-main 1
  fi

  # Lọc mảng trùng và sắp xếp (Loại bỏ các item trùng lặp do vừa có ở Vhost vừa có ở Chuyen-huong)
  mapfile -t selects < <(printf "%s\n" "${selects[@]}" | sort -uV)

  # Render Menu Bo Cong
  echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
  local title_text="Trạng thái hiện tại & Chọn Website muốn thao tác Logs:"
  local len=$(echo -n "$title_text" | awk '{print length($0)}')
  local pad_r=$((box_inner_width - len - 2))
  [[ $pad_r -lt 0 ]] && pad_r=0
  echo -e "${C_CYAN}│${C_RESET}  ${C_YELLOW}${title_text}${C_RESET}$(printf '%*s' "$pad_r" "")${C_CYAN}│${C_RESET}"

  local line_len=$((len + 3))
  local pad_line_r=$((box_inner_width - line_len))
  [[ $pad_line_r -lt 0 ]] && pad_line_r=0
  local short_line=$(printf "%${line_len}s" "" | sed 's/ /─/g')
  echo -e "${C_CYAN}├${short_line}$(printf '%*s' "$pad_line_r" "")│${C_RESET}"

  local i=1
  for item in "${selects[@]}"; do
    local dom=$(echo "$item" | cut -d'|' -f1)
    local stt=$(echo "$item" | cut -d'|' -f2)

    local color_stt="${C_GREEN}[Đang BẬT]"
    local clean_stt="[Đang BẬT]"
    if [[ "$stt" == "0" ]]; then
      color_stt="${C_YELLOW}[Đang TẮT (Tối ưu I/O)]"
      clean_stt="[Đang TẮT (Tối ưu I/O)]"
    fi

    local item_text=$(printf "  ${C_CYAN}%3d)${C_RESET} ${C_BOLD_WHITE}%-30s${C_RESET} %s" "$i" "$dom" "${color_stt}${C_RESET}")
    local clean_text=$(printf "  %3d) %-30s %s" "$i" "$dom" "$clean_stt")
    local item_len=$(echo -n "$clean_text" | awk '{print length($0)}')
    local pad=$((box_inner_width - item_len))
    [[ $pad -lt 0 ]] && pad=0
    echo -e "${C_CYAN}│${C_RESET}${item_text}$(printf '%*s' "$pad" "")${C_CYAN}│${C_RESET}"
    ((i++))
  done

  # Thêm dòng chọn TẤT CẢ nếu có >= 2 website
  if [[ ${#selects[@]} -ge 2 ]]; then
    echo -e "${C_CYAN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
    local all_text=$(printf "  ${C_CYAN}999)${C_RESET} ${C_YELLOW}TẤT CẢ WEBSITE (Thao tác đồng loạt)${C_RESET}")
    local clean_all_text=$(printf "  999) TẤT CẢ WEBSITE (Thao tác đồng loạt)")
    local pad_all=$((box_inner_width - $(echo -n "$clean_all_text" | awk '{print length($0)}')))
    echo -e "${C_CYAN}│${C_RESET}${all_text}$(printf '%*s' "$pad_all" "")${C_CYAN}│${C_RESET}"
  fi
  echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯${C_RESET}"

  local fzf_installed=false
  if command -v fzf &>/dev/null; then
    fzf_installed=true
    PROMPT_TEXT="Nhập lựa chọn (1-${#selects[@]}) [00=Tìm nhanh] [0=Thoát]: "
    [[ ${#selects[@]} -ge 2 ]] && PROMPT_TEXT="Nhập lựa chọn (1-${#selects[@]}) hoặc 999 [00=Tìm nhanh] [0=Thoát]: "
  else
    PROMPT_TEXT="Nhập lựa chọn (1-${#selects[@]}) [0=Thoát]: "
    [[ ${#selects[@]} -ge 2 ]] && PROMPT_TEXT="Nhập lựa chọn (1-${#selects[@]}) hoặc 999 [0=Thoát]: "
  fi

  while true; do
    echo -en "${C_CYAN}${PROMPT_TEXT}${C_RESET}"
    if ! read -r REPLY; then exit 1; fi
    REPLY=$(echo "$REPLY" | tr -d ' ' | tr '[:upper:]' '[:lower:]')

    case "$REPLY" in
    0)
      echo -e "\n${C_GREEN}Đang thoát...${C_RESET}"
      NAME="0"
      return 0
      ;;
    999)
      if [[ ${#selects[@]} -ge 2 ]]; then
        NAME="TẤT_CẢ"
        return 0
      else
        echo -e "\n${C_RED}❌ Lựa chọn không hợp lệ! Vui lòng chọn lại.${C_RESET}"
      fi
      ;;
    00)
      if $fzf_installed; then
        local selected_item=$(printf '%s\n' "${selects[@]}" | nl -w 3 -s ': ' | fzf --prompt="Tìm website Logs >> " --height=40% --border=rounded --color=border:red --cycle --reverse)
        local extracted_data=$(echo "$selected_item" | sed 's/^[[:space:]]*[0-9]\+\:[[:space:]]*//')
        if [[ -n "$extracted_data" ]]; then
          NAME=$(echo "$extracted_data" | cut -d'|' -f1)
          return 0
        else
          echo -e "${C_YELLOW}Đã hủy chọn. Vui lòng chọn lại.${C_RESET}"
        fi
      else
        echo -e "${C_RED}Lỗi: FZF chưa cài đặt.${C_RESET}"
      fi
      ;;
    *)
      if [[ "$REPLY" =~ ^[0-9]+$ ]] && [ "$REPLY" -ge 1 ] && [ "$REPLY" -le ${#selects[@]} ]; then
        local action_index=$((REPLY - 1))
        local extracted_data="${selects[$action_index]}"
        NAME=$(echo "$extracted_data" | cut -d'|' -f1)
        return 0
      else
        echo -e "\n${C_RED}❌ Lựa chọn không hợp lệ! Vui lòng chọn lại.${C_RESET}"
      fi
      ;;
    esac
  done
}

# Nếu gọi script kèm tên domain từ command line
if [[ -n "$1" && "$1" != "98" ]]; then
  NAME="$1"
else
  lua_chon_NAME
fi

# Tách lấy tên chuẩn (nếu truyền biến từ ngoài)
NAME=$(echo "$NAME" | cut -f1 -d ' ')

# --- CHỐT CHẶN THOÁT HIỂM ---
[[ "$NAME" == "0" || -z "$NAME" ]] && {
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-logs-main 1
  return 2>/dev/null || exit
}

# ==============================================================================
# HÀM XÁC ĐỊNH USER LITESPEED
# ==============================================================================
tuong_thich_nhom_litespeed="nobody"
if cat /etc/*release 2>/dev/null | grep -qi "ubuntu"; then
  tuong_thich_nhom_litespeed="nogroup"
fi

# ==============================================================================
# HÀM THỰC THI BẬT/TẮT LOGS CHO 1 DOMAIN
# ==============================================================================
function process_logs_domain() {
  local target_domain=$1
  local action=$2 # "bat" hoac "tat"
  local vhost_conf="/usr/local/lsws/conf/vhosts/$target_domain/$target_domain.conf"

  if [[ ! -f "$vhost_conf" ]]; then
    return
  fi

  if [[ "$action" == "bat" ]]; then
    if grep -q 'errorlog ' "$vhost_conf" 2>/dev/null; then return; fi

    # Xóa cấu hình rác (nếu có) trước khi tiêm
    sed -i -e '/^errorlog /,/^}$/d' "$vhost_conf"
    sed -i -e '/^accesslog /,/^}$/d' "$vhost_conf"

    # Tiêm cấu hình log
    cat <<EOF >>"$vhost_conf"

errorlog \$VH_ROOT/logs/error.log {
  useServer               1
  logLevel                ERROR
  rollingSize             10M
}

accesslog \$VH_ROOT/logs/access.log {
  useServer               0
  rollingSize             10M
  keepDays                30
  compressArchive         1
}
EOF

    # Tạo thư mục và cấp quyền
    mkdir -p "/usr/local/lsws/$target_domain/logs"
    chown -R nobody:$tuong_thich_nhom_litespeed "/usr/local/lsws/$target_domain/logs"
    chmod 700 "/usr/local/lsws/$target_domain/logs"

    # Update cache biến WPTangToc
    [[ -f "/etc/wptt/vhost/.$target_domain.conf" ]] && sed -i '/bat_log_domain/d' "/etc/wptt/vhost/.$target_domain.conf" && echo 'bat_log_domain=1' >>"/etc/wptt/vhost/.$target_domain.conf"
    [[ -f "/etc/wptt/vhost_bk/.$target_domain.conf" ]] && sed -i '/bat_log_domain/d' "/etc/wptt/vhost_bk/.$target_domain.conf" && echo 'bat_log_domain=1' >>"/etc/wptt/vhost_bk/.$target_domain.conf"

    echo "Bật log website $target_domain: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log

  elif [[ "$action" == "tat" ]]; then
    if ! grep -q 'errorlog ' "$vhost_conf" 2>/dev/null; then return; fi

    # Dọn dẹp block cấu hình bằng SED
    sed -i -e '/^errorlog /,/^}$/d' "$vhost_conf"
    sed -i -e '/^accesslog /,/^}$/d' "$vhost_conf"

    # Xóa thư mục logs của domain (Chặn xóa nhầm /)
    if [[ -n "$target_domain" && "$target_domain" != "/" ]]; then
      rm -rf "/usr/local/lsws/$target_domain/logs"
    fi

    # Failsafe: Đề phòng mất thư mục logs tổng của server
    if [[ ! -d "/usr/local/lsws/logs" ]]; then
      mkdir -p /usr/local/lsws/logs
      chown root:$tuong_thich_nhom_litespeed /usr/local/lsws/logs
    fi

    # Gỡ cache biến WPTangToc
    [[ -f "/etc/wptt/vhost/.$target_domain.conf" ]] && sed -i '/bat_log_domain/d' "/etc/wptt/vhost/.$target_domain.conf"
    [[ -f "/etc/wptt/vhost_bk/.$target_domain.conf" ]] && sed -i '/bat_log_domain/d' "/etc/wptt/vhost_bk/.$target_domain.conf"

    echo "Tắt log website $target_domain: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log
  fi
}

# ==============================================================================
# XỬ LÝ LÔGIC RẼ NHÁNH
# ==============================================================================
action_msg=""
action_color=""

if [[ "$NAME" == "TẤT_CẢ" ]]; then
  echo ""

  while true; do
    echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
    left_text "  Bạn muốn ${C_GREEN}BẬT${C_RESET} hay ${C_YELLOW}TẮT${C_RESET} ghi Logs cho ${C_BOLD_WHITE}TẤT CẢ WEBSITE${C_RESET}?" 2
    echo -e "${C_CYAN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
    left_text "  ${C_CYAN}1)${C_RESET} ${C_GREEN}Đồng ý BẬT đồng loạt${C_RESET}" 2
    left_text "  ${C_CYAN}2)${C_RESET} ${C_YELLOW}Đồng ý TẮT đồng loạt${C_RESET}" 2
    left_text "  ${C_CYAN}0)${C_RESET} Hủy bỏ (Thoát)" 2
    echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯${C_RESET}"
    echo -en "${C_CYAN}Nhập lựa chọn của bạn [1-2] [0=Thoát]: ${C_RESET}"
    read -r mass_reply

    if [[ "$mass_reply" == "0" ]]; then
      echo -e "${C_YELLOW}Đã hủy thao tác.${C_RESET}"
      [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-logs-main 1
      exit 0
    elif [[ "$mass_reply" == "1" ]]; then
      mass_action="bat"
      action_msg="Đã BẬT Logs cho toàn bộ Website."
      action_color="${C_GREEN}"
      break
    elif [[ "$mass_reply" == "2" ]]; then
      mass_action="tat"
      action_msg="Đã TẮT Logs cho toàn bộ Website (Tối ưu I/O)."
      action_color="${C_YELLOW}"
      break
    else
      echo -e "${C_RED}❌ Lựa chọn không hợp lệ!${C_RESET}\n"
    fi
  done

  echo ""
  _runing "Đang cấu hình Logs đồng loạt cho toàn bộ Website..."

  # Thao tác hàng loạt (Sửa lỗi biến local file_list của bản gốc)
  file_list_mass=()
  [[ -d /etc/wptt/vhost ]] && file_list_mass+=(/etc/wptt/vhost/.*.conf)
  [[ -d /etc/wptt/chuyen-huong ]] && file_list_mass+=(/etc/wptt/chuyen-huong/*)

  for filepath in "${file_list_mass[@]}"; do
    [[ ! -f "$filepath" || "$filepath" == *"/..conf" || "$filepath" == *"*"* ]] && continue
    dom="${filepath##*/}"
    dom="${dom%.conf}"
    dom="${dom#.}"
    if [[ "$dom" == ?*.?* ]]; then
      process_logs_domain "$dom" "$mass_action"
    fi
  done

  _rundone "Cập nhật cấu hình Logs đồng loạt thành công"

else
  # Đảo trạng thái (Toggle) cho 1 website cụ thể
  vhost_conf="/usr/local/lsws/conf/vhosts/$NAME/$NAME.conf"
  [[ ! -f "$vhost_conf" ]] && {
    echo -e "\n${C_RED}❌ Tên miền không tồn tại hoặc chưa được khởi tạo cấu hình Vhost!${C_RESET}"
    sleep 3
    [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-logs-main 1
    exit 1
  }

  if grep -q 'errorlog ' "$vhost_conf" 2>/dev/null; then
    if wptt_xac_nhan "Website này đang BẬT ghi Logs. Bạn có muốn TẮT đi không?" "${C_BOLD_WHITE}Website:${C_RESET} $NAME" "Tắt log giúp giảm tải đĩa cứng nhưng khó bắt lỗi nếu web bị sập 500." "Đồng ý TẮT Log" "Hủy thao tác"; then
      echo ""
      _runing "TẮT (Hủy) ghi Error & Access Logs cho $NAME..."
      process_logs_domain "$NAME" "tat"
      action_msg="Đã TẮT chức năng ghi Logs cho website."
      action_color="${C_YELLOW}"
      _rundone "TẮT (Hủy) ghi Error & Access Logs cho $NAME..."
    else
      echo -e "${C_YELLOW}Đã hủy thao tác tắt Log.${C_RESET}\n"
      [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-logs-main 1
      exit 0
    fi
  else
    if wptt_xac_nhan "Website này đang TẮT ghi Logs. Bạn có muốn BẬT lên không?" "${C_BOLD_WHITE}Website:${C_RESET} $NAME" "Bật log sẽ lưu nhật ký tại: /usr/local/lsws/$NAME/logs/" "Đồng ý BẬT Log" "Hủy thao tác"; then
      echo ""
      _runing "KÍCH HOẠT ghi Error & Access Logs cho $NAME..."
      process_logs_domain "$NAME" "bat"
      action_msg="Đã BẬT chức năng ghi Logs cho website."
      action_color="${C_GREEN}"
      _rundone "KÍCH HOẠT ghi Error & Access Logs cho $NAME..."
    else
      echo -e "${C_YELLOW}Đã hủy thao tác bật Log.${C_RESET}\n"
      [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-logs-main 1
      exit 0
    fi
  fi
fi

/usr/local/lsws/bin/lswsctrl reload >/dev/null 2>&1

echo -e "\n${C_GREEN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_BOLD_WHITE}HOÀN TẤT THIẾT LẬP LOGS${C_RESET}"
echo -e "${C_GREEN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
if [[ "$NAME" == "TẤT_CẢ" ]]; then
  left_text "Phạm vi tác động : ${C_YELLOW}TẤT CẢ WEBSITE${C_RESET}" 2
else
  left_text "Website thao tác : ${C_YELLOW}$NAME${C_RESET}" 2
fi
left_text "Trạng thái mới   : ${action_color}${action_msg}${C_RESET}" 2
echo -e "${C_GREEN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

[[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-logs-main 1
