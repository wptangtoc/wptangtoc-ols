#!/bin/bash
# @author: Gia Tuấn
# @website: https://wptangtoc.com
# @since: 2026

function huong_dan() {
  Việc xem error log cho server litespeed thông qua wptangtoc ols thường sẽ tận dụng các công cụ sẵn có của hệ điều hành Linux.

  Tính năng xem error log server trong wptangtoc ols có thể được hiểu ngắn gọn như sau:

  Xác định vị trí file log: OpenLiteSpeed thường lưu error log server trong một file riêng biệt. Đường dẫn phổ biến có thể là /usr/local/lsws/logs/error.log. Script wptangtoc ols cung cấp trình đọc chuyên nghiệp để nhanh chóng xác định và truy cập vào file log này.

  Tính năng này hỗ trợ người dùng dễ dàng hơn trong việc tìm và sử dụng các công cụ có sẵn của hệ thống để xem error log của OpenLiteSpeed cho hệ thống. Điều này giúp quản trị viên nhanh chóng kiểm tra, phát hiện lỗi, phục vụ công việc gỡ lỗi hoặc các hoạt động bất thường liên quan đến webserver.
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null # Nạp thư viện UI Xác nhận

clear
echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}QUẢN LÝ LOGS ➜ Xem Error Log Server Tổng (Trình đọc Less)${C_RESET}"
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

LOG_FILE="/usr/local/lsws/logs/error.log"

# ==============================================================================
# HÀM PHỤC HỒI NẾU MẤT FILE ERROR.LOG (UX BO CONG)
# ==============================================================================
if [[ ! -f "$LOG_FILE" ]]; then
  echo -e "${C_RED}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_BOLD_WHITE}LỖI: KHÔNG TÌM THẤY FILE ERROR LOG SERVER${C_RESET}"
  echo -e "${C_RED}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
  left_text "${C_YELLOW}Mặc định Error Log Server là tệp BẮT BUỘC phải có để hoạt động.${C_RESET}" 2
  left_text "Nếu bị mất file này, tiến trình Webserver có thể bị treo." 2
  echo -e "${C_RED}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

  if wptt_xac_nhan "Bạn có muốn TÁI TẠO lại Error Log Server để hệ thống chạy bình thường không?" "" "" "Đồng ý Tái tạo" "Thoát ra"; then
    echo ""
    _runing "Đang khởi tạo lại Error Log Server và phân quyền..."

    # Nhận diện OS chuẩn xác
    tuong_thich_nhom_litespeed="nobody"
    if grep -qi "ubuntu" /etc/os-release 2>/dev/null; then
      tuong_thich_nhom_litespeed="nogroup"
    fi

    # Tái tạo thư mục và cấp quyền
    mkdir -p /usr/local/lsws/logs
    chown "root:$tuong_thich_nhom_litespeed" /usr/local/lsws/logs

    # Tái tạo file và sửa quyền sở hữu (fix lỗi typo nodoby thành nobody)
    rm -f "$LOG_FILE" >/dev/null 2>&1
    touch "$LOG_FILE"
    chown "nobody:$tuong_thich_nhom_litespeed" "$LOG_FILE"
    chmod 644 "$LOG_FILE"

    # Khởi động lại dịch vụ để nhận file log mới
    /usr/local/lsws/bin/lswsctrl restart >/dev/null 2>&1

    _rundone "Đã khôi phục thành công Error Log Server!"
    sleep 2
    echo ""
  else
    echo -e "${C_YELLOW}Đã hủy thao tác khôi phục.${C_RESET}"
    [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-logs-main 1
    exit 0
  fi
fi

# ==============================================================================
# HƯỚNG DẪN TRÌNH ĐỌC LESS CHUYÊN NGHIỆP
# ==============================================================================
echo -e "${C_GREEN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_BOLD_WHITE}HƯỚNG DẪN SỬ DỤNG TRÌNH ĐỌC LOG (LESS)${C_RESET}"
echo -e "${C_GREEN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
left_text "File đang xem: ${C_YELLOW}$LOG_FILE${C_RESET}" 2
echo -e "${C_GREEN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
left_text " ⬇️ ⬆️  Nhấn phím mũi tên [Lên/Xuống] để cuộn từng dòng." 2
left_text " ␣    Nhấn phím [Space] để cuộn nhanh từng trang." 2
left_text " 🔍   Nhấn phím [/] và nhập từ khóa để TÌM KIẾM (Bấm 'n' tìm tiếp)." 2
left_text " ❌   ${C_RED}Nhấn phím [q] để THOÁT${C_RESET} và quay lại Menu." 2
echo -e "${C_GREEN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

echo -e "${C_CYAN}Đang chuẩn bị dữ liệu và mở trình đọc log...${C_RESET}"
sleep 3

# Làm sạch màn hình trước khi gọi less để giao diện log tràn viền sạch sẽ
clear

# Sử dụng less với tham số +G để tự động nhảy xuống dòng log mới nhất ở cuối file
less +G "$LOG_FILE"

# Sau khi bấm q thoát khỏi less, làm sạch màn hình và tự động quay lại Menu
clear
[[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-logs-main 1
