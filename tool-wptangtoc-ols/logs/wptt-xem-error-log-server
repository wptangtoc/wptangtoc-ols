#!/bin/bash
# @author: Gia Tuấn
# @website: https://wptangtoc.com
# @since: 2026

function huong_dan() {
  Việc xem error log cho server litespeed thông qua wptangtoc ols thường sẽ tận dụng các công cụ sẵn có của hệ điều hành Linux.

  Tính năng xem error log server trong wptangtoc ols có thể được hiểu ngắn gọn như sau:

  Xác định vị trí file log: OpenLiteSpeed thường lưu error log server trong một file riêng biệt. Đường dẫn phổ biến có thể là /usr/local/lsws/logs/error.log. Script wptangtoc ols cung cấp trình đọc chuyên nghiệp để nhanh chóng xác định và truy cập vào file log này.

  Tính năng này hỗ trợ người dùng dễ dàng hơn trong việc tìm và sử dụng các công cụ có sẵn của hệ thống để xem error log của OpenLiteSpeed cho hệ thống. Điều này giúp quản trị viên nhanh chóng kiểm tra, phát hiện lỗi, phục vụ công việc gỡ lỗi hoặc các hoạt động bất thường liên quan đến webserver.
}

. /etc/wptt/.wptt.conf
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh
. /etc/wptt/echo-color

clear
echo -e "\n========================================================================="
echo -e "| Quản lý Logs => Xem Error Log Server Tổng (Trình đọc Less)            |"
echo -e "=========================================================================\n"

LOG_FILE="/usr/local/lsws/logs/error.log"

# ==============================================================================
# HÀM PHỤC HỒI NẾU MẤT FILE ERROR.LOG
# ==============================================================================
if [[ ! -f "$LOG_FILE" ]]; then
  echo -e "\033[1;31m[!] LỖI: FILE ERROR LOG SERVER KHÔNG TỒN TẠI!\033[0m"
  echo "Mặc định Error Log Server phải được kích hoạt và không thể tắt."
  echo "Nếu bị mất file error.log, tiến trình Litespeed Webserver sẽ ngừng hoạt động."
  echo ""

  prompt="Bạn có muốn TÁI TẠO lại Error Log Server để Litespeed hoạt động bình thường không? [1-2]: "
  options=("$dong_y" "$khong_dong_y")
  dongy="n"
  PS3="$prompt"
  select opt in "${options[@]}"; do
    case "$REPLY" in
    1)
      dongy="y"
      break
      ;;
    2) exec /etc/wptt/wptt-logs-main 1 ;;
    *)
      echo -e "\n$ban_nhap_sai_he_thong_se_chon_khong_dong_y\n"
      break
      ;;
    esac
  done

  if [[ "$dongy" == "y" ]]; then
    _runing "Đang khởi tạo lại Error Log Server"

    # Nhận diện OS chuẩn xác
    if grep -qi "ubuntu" /etc/os-release 2>/dev/null; then
      tuong_thich_nhom_litespeed="nogroup"
    else
      tuong_thich_nhom_litespeed="nobody"
    fi

    # Tái tạo thư mục và cấp quyền
    mkdir -p /usr/local/lsws/logs
    chown root:$tuong_thich_nhom_litespeed /usr/local/lsws/logs

    # Tái tạo file và sửa lỗi Typo quyền sở hữu
    rm -f "$LOG_FILE" >/dev/null 2>&1
    touch "$LOG_FILE"
    chown nobody:$tuong_thich_nhom_litespeed "$LOG_FILE" # Đã sửa nobody (Bản cũ ghi sai thành nodoby)

    # Khởi động lại dịch vụ
    /usr/local/lsws/bin/lswsctrl restart >/dev/null 2>&1

    _rundone "Đã khôi phục thành công Error Log Server!"
    sleep 2
  else
    [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-logs-main 1
    exit 0
  fi
fi

# ==============================================================================
# SỬ DỤNG TRÌNH ĐỌC LESS CHUYÊN NGHIỆP
# ==============================================================================
echo -e "\033[1;36m=========================================================================\033[0m"
echo -e "\033[1;33m ĐANG XEM FILE ERROR LOG SERVER:\033[0m $LOG_FILE"
echo -e "\033[1;36m=========================================================================\033[0m"
echo -e "\033[1;32m HƯỚNG DẪN SỬ DỤNG TRÌNH ĐỌC (LESS):\033[0m"
echo " - Nhấn phím mũi tên [Lên/Xuống] để cuộn từng dòng."
echo " - Nhấn phím [Space] để cuộn từng trang."
echo " - Nhấn phím [/] và nhập từ khóa để TÌM KIẾM (Nhấn 'n' để tìm tiếp)."
echo -e " - \033[1;31mNhấn phím [q] để THOÁT\033[0m và quay lại Menu."
echo -e "\033[1;36m=========================================================================\033[0m"
echo "Đang mở trình đọc log trong 3 giây..."
sleep 3

# Sử dụng less với tham số +G để tự động nhảy xuống dòng log mới nhất ở cuối file
less +G "$LOG_FILE"

# Sau khi bấm q thoát khỏi less, tự động quay lại Menu
[[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-logs-main 1
