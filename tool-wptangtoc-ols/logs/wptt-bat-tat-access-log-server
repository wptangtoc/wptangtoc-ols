#!/bin/bash
# @author: Gia Tuấn
# @website: https://wptangtoc.com
# @since: 2026

function huong_dan() {
  Access log server giúp ích gì:
  * Chức năng: Ghi lại mọi yêu cầu [request] mà máy chủ nhận được cho địa chỉ IP public hiện tại của bạn.
  * Thông tin: Thường bao gồm địa chỉ IP của khách truy cập, thời gian truy cập, trang/tệp được yêu cầu, mã trạng thái phản hồi [như 200 - OK, 404 - Not Found, 500 - Server Error], trình duyệt người dùng, v.v.
  * Lợi ích: Giúp bạn hiểu được ai đang truy cập địa chỉ IP, họ xem gì, tần suất truy cập, phát hiện các truy cập bất thường.

  Lợi ích và cân nhắc:
  * Tắt log: Giúp giảm tải I/O cho ổ cứng, tiết kiệm dung lượng lưu trữ. Tuy nhiên, bạn sẽ mất thông tin về các lượt truy cập, gây khó khăn cho việc phân tích traffic, gỡ lỗi hoặc điều tra các vấn đề bảo mật.
  * Bật log: Cung cấp dữ liệu chi tiết về mọi yêu cầu đến server, hữu ích cho việc theo dõi, phân tích và bảo mật.

  Ghi chú: Access log domain hoàn toàn khác với access log server.
  Access log server ghi lại khi ai đó truy cập vào địa chỉ IP của bạn.
  Access log domain ghi lại khi ai đó truy cập vào domain của bạn.

  Đường dẫn file access log server tại: /usr/local/lsws/logs/access.log
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null # Nạp thư viện UI Xác nhận

clear
echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}QUẢN LÝ LOGS ➜ Bật / Tắt Access Logs của toàn Server${C_RESET}"
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

CONF_FILE="/usr/local/lsws/conf/httpd_config.conf"
LOG_FILE="/usr/local/lsws/logs/access.log"

# ==============================================================================
# 1. KIỂM TRA TRẠNG THÁI HIỆN TẠI (UX BO CONG)
# ==============================================================================
trang_thai="0"

if grep -q 'accesslog ' "$CONF_FILE" 2>/dev/null; then
  trang_thai="1"
fi

echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
if [[ "$trang_thai" == "1" ]]; then
  left_text "Trạng thái Log : ${C_GREEN}ĐANG BẬT (Active)${C_RESET}" 2
else
  left_text "Trạng thái Log : ${C_YELLOW}ĐANG TẮT (Inactive)${C_RESET}" 2
fi
left_text "File lưu trữ   : ${C_YELLOW}$LOG_FILE${C_RESET}" 2
echo -e "${C_CYAN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
left_text "Access Log Server ghi lại mọi yêu cầu truy cập vào IP Public" 2
left_text "của máy chủ (Không liên quan đến Log của từng Website/Domain)." 2
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

# ==============================================================================
# 2. XỬ LÝ LÔGIC ĐẢO TRẠNG THÁI (TOGGLE)
# ==============================================================================
action_msg=""
action_color=""

if [[ "$trang_thai" == "1" ]]; then
  # NHÁNH ĐANG BẬT -> HỎI TẮT
  if wptt_xac_nhan "Tính năng ghi Access Log Server đang BẬT. Bạn có muốn TẮT không?" "Lưu ý: Việc tắt sẽ giúp tiết kiệm I/O ổ cứng, nhưng bạn sẽ không" "thể phân tích được các truy cập độc hại nhắm thẳng vào IP." "Đồng ý TẮT Log" "Hủy thao tác"; then
    echo ""
    _runing "Đang tắt tính năng ghi Access Log trên Server..."

    # Xóa block cấu hình accesslog
    sed -i -e '/^accesslog /,/^}$/d' "$CONF_FILE"

    _rundone "Đã gỡ bỏ cấu hình Log thành công"

    _runing "Đang xả rỗng (truncate) file Log để giải phóng dung lượng đĩa..."
    # Làm rỗng file log để giải phóng dung lượng ngay lập tức
    if [[ -f "$LOG_FILE" ]]; then
      truncate -s 0 "$LOG_FILE" >/dev/null 2>&1
    fi
    _rundone "Dọn dẹp rác bộ nhớ hoàn tất"

    echo "Tắt Access Log Server: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log
    action_msg="Đã TẮT Access Log Server (Tối ưu I/O)."
    action_color="${C_YELLOW}"

  else
    echo -e "${C_YELLOW}Đã hủy thao tác tắt Log.${C_RESET}\n"
    [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-logs-main 1
    exit 0
  fi

else
  # NHÁNH ĐANG TẮT -> HỎI BẬT
  if wptt_xac_nhan "Tính năng ghi Access Log Server đang TẮT. Bạn có muốn BẬT không?" "Lưu ý: Bật tính năng này sẽ tiêu tốn thêm một chút dung lượng" "ổ cứng để ghi nhận các lượt truy cập vào IP." "Đồng ý BẬT Log" "Hủy thao tác"; then
    echo ""
    _runing "Đang kích hoạt tính năng ghi Access Log trên Server..."

    # Tiêm cấu hình vào file config tổng của OLS
    cat <<EOF >>"$CONF_FILE"
accesslog logs/access.log {
  rollingSize             10M
  keepDays                30
  compressArchive         0
}
EOF

    # Xác định nhóm tương thích
    tuong_thich_nhom_litespeed="nobody"
    if cat /etc/*release 2>/dev/null | grep -qi "ubuntu"; then
      tuong_thich_nhom_litespeed="nogroup"
    fi

    # Đảm bảo file tồn tại và đúng quyền
    if [[ ! -f "$LOG_FILE" ]]; then
      touch "$LOG_FILE"
      chown "nobody:$tuong_thich_nhom_litespeed" "$LOG_FILE"
      chmod 644 "$LOG_FILE"
    fi

    echo "Bật Access Log Server: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log
    action_msg="Đã BẬT Access Log Server."
    action_color="${C_GREEN}"
    _rundone "Cấu hình Log mới đã được thiết lập"

  else
    echo -e "${C_YELLOW}Đã hủy thao tác bật Log.${C_RESET}\n"
    [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-logs-main 1
    exit 0
  fi
fi

/usr/local/lsws/bin/lswsctrl reload >/dev/null 2>&1

# BẢNG BÁO CÁO THÀNH CÔNG
echo -e "\n${C_GREEN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_BOLD_WHITE}HOÀN TẤT THIẾT LẬP LOG SERVER${C_RESET}"
echo -e "${C_GREEN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
left_text "Phạm vi tác động : ${C_CYAN}Toàn bộ máy chủ (Truy cập IP Public)${C_RESET}" 2
left_text "Trạng thái mới   : ${action_color}${action_msg}${C_RESET}" 2
echo -e "${C_GREEN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

[[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-logs-main 1
