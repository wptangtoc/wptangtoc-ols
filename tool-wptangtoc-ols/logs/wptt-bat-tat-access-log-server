#!/bin/bash
# @author: Gia Tuấn
# @website: https://wptangtoc.com
# @since: 2026

function huong_dan() {
  Access log server giúp ích gì:
  * Chức năng: Ghi lại mọi yêu cầu [request] mà máy chủ nhận được cho địa chỉ IP public hiện tại của bạn.
  * Thông tin: Thường bao gồm địa chỉ IP của khách truy cập, thời gian truy cập, trang/tệp được yêu cầu, mã trạng thái phản hồi [như 200 - OK, 404 - Not Found, 500 - Server Error], trình duyệt người dùng, v.v.
  * Lợi ích: Giúp bạn hiểu được ai đang truy cập địa chỉ IP, họ xem gì, tần suất truy cập, phát hiện các truy cập bất thường.

  Lợi ích và cân nhắc:
  * Tắt log: Giúp giảm tải I/O cho ổ cứng, tiết kiệm dung lượng lưu trữ. Tuy nhiên, bạn sẽ mất thông tin về các lượt truy cập, gây khó khăn cho việc phân tích traffic, gỡ lỗi hoặc điều tra các vấn đề bảo mật.
  * Bật log: Cung cấp dữ liệu chi tiết về mọi yêu cầu đến server, hữu ích cho việc theo dõi, phân tích và bảo mật.

  Ghi chú: Access log domain hoàn toàn khác với access log server.
  Access log server ghi lại khi ai đó truy cập vào địa chỉ IP của bạn.
  Access log domain ghi lại khi ai đó truy cập vào domain của bạn.

  Đường dẫn file access log server tại: /usr/local/lsws/logs/access.log
}

. /etc/wptt/.wptt.conf
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh
. /etc/wptt/echo-color

clear
echo -e "\n========================================================================="
echo -e "| Quản lý Logs => Bật / Tắt Access Logs Server                          |"
echo -e "=========================================================================\n"

CONF_FILE="/usr/local/lsws/conf/httpd_config.conf"
LOG_FILE="/usr/local/lsws/logs/access.log"

# ==============================================================================
# 1. KIỂM TRA TRẠNG THÁI HIỆN TẠI
# ==============================================================================
trang_thai="TẮT"
mau_trang_thai="\033[1;31m" # Màu đỏ

if grep -q 'accesslog ' "$CONF_FILE" 2>/dev/null; then
  trang_thai="ĐANG BẬT"
  mau_trang_thai="\033[1;32m" # Màu xanh
fi

echo -e "Trạng thái Access Logs Server hiện tại: ${mau_trang_thai}${trang_thai}\033[0m\n"

# ==============================================================================
# 2. HIỂN THỊ MENU LỰA CHỌN (SMART TOGGLE)
# ==============================================================================
if [[ "$trang_thai" == "ĐANG BẬT" ]]; then
  echo "Bạn có muốn TẮT tính năng ghi Access Log Server không?"
  options=("Xác nhận TẮT" "$khong_dong_y")
  hanh_dong="tat"
else
  echo "Bạn có muốn BẬT tính năng ghi Access Log Server không?"
  options=("Xác nhận BẬT" "$khong_dong_y")
  hanh_dong="bat"
fi

PS3=$'\n'"$nhap_lua_chon_cua_ban [1-2]: "
select opt in "${options[@]}"; do
  case "$REPLY" in
  1) break ;;
  2 | 0)
    [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-logs-main 1
    exit
    ;;
  *)
    echo -e "\033[1;31m$ban_nhap_sai_he_thong_se_chon_khong_dong_y\033[0m"
    break
    ;;
  esac
done

# ==============================================================================
# 3. THỰC THI THAY ĐỔI
# ==============================================================================
if [[ "$hanh_dong" == "tat" ]]; then
  _runing "Đang tắt Access Log Server"

  # Xóa block cấu hình accesslog
  sed -i -e '/^accesslog /,/^}$/d' "$CONF_FILE"

  # Làm rỗng file log để giải phóng dung lượng ngay lập tức
  if [[ -f "$LOG_FILE" ]]; then
    truncate -s 0 "$LOG_FILE" >/dev/null 2>&1
  fi

  echo "Tắt Access Log Server: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log
  _rundone "Đã tắt Access Log Server thành công!"

elif [[ "$hanh_dong" == "bat" ]]; then
  _runing "Đang bật Access Log Server"

  # Tiêm cấu hình vào file config tổng của OLS
  echo "accesslog logs/access.log {
  rollingSize             10M
  keepDays                30
  compressArchive         0
}" >>"$CONF_FILE"

  # Xác định nhóm tương thích
  if grep -qi "ubuntu" /etc/os-release 2>/dev/null; then
    tuong_thich_nhom_litespeed="nogroup"
  else
    tuong_thich_nhom_litespeed="nobody"
  fi

  # Đảm bảo file tồn tại và đúng quyền
  if [[ ! -f "$LOG_FILE" ]]; then
    touch "$LOG_FILE"
    chown nobody:$tuong_thich_nhom_litespeed "$LOG_FILE"
  fi

  echo "Bật Access Log Server: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log
  _rundone "Đã bật Access Log Server thành công!"
fi

# ==============================================================================
# 4. NẠP LẠI CẤU HÌNH VÀ QUAY LẠI MENU
# ==============================================================================
/usr/local/lsws/bin/lswsctrl reload >/dev/null 2>&1

if [[ "${1:-}" == "98" ]]; then
  exec /etc/wptt/wptt-logs-main 1
fi
