#!/bin/bash
# @author: Gia Tuấn
# @website: https://wptangtoc.com
# @since: 2025

function huong_dan() {
  Việc xem access log theo thời gian thực cho một domain cụ thể thông qua WPTangToc OLS.

  Tính năng xem access log domain theo thời gian thực trong wptangtoc ols có thể được hiểu ngắn gọn như sau:

  Xác định vị trí file log: OpenLiteSpeed thường lưu access log cho mỗi virtual host [tương ứng với mỗi domain] trong một file riêng biệt. Đường dẫn phổ biến có thể là /usr/local/lsws/domain.com/logs/access.log. Script wptangtoc ols cung cấp lệnh để xem nhật ký ngay khi có người truy cập vào website.

  Tính năng này hỗ trợ người dùng dễ dàng hơn trong việc tìm và sử dụng các công cụ có sẵn của hệ thống để xem access log của OpenLiteSpeed cho từng domain. Điều này giúp quản trị viên website nhanh chóng kiểm tra lưu lượng truy cập, phát hiện lỗi hoặc các hoạt động bất thường liên quan đến một website cụ thể.
}

. /etc/wptt/.wptt.conf
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh
. /etc/wptt/echo-color

clear
echo -e "\n========================================================================="
echo -e "| Quản lý Logs => Theo dõi Access Log Domain [Thời Gian Thực]           |"
echo -e "=========================================================================\n"

. /etc/wptt/tenmien
echo -e "Lựa chọn website bạn muốn xem Access Logs:\n"
lua_chon_NAME

# Chốt chặn thoát hiểm
[[ "$NAME" == "0" || -z "$NAME" ]] && exec /etc/wptt/wptt-logs-main 1

LOG_DIR="/usr/local/lsws/$NAME/logs"
LOG_FILE="$LOG_DIR/access.log"
VHOST_CONF="/usr/local/lsws/conf/vhosts/$NAME/$NAME.conf"

# ==============================================================================
# KIỂM TRA VÀ KÍCH HOẠT LOG NẾU CHƯA CÓ
# ==============================================================================
if [[ ! -d "$LOG_DIR" || ! -f "$LOG_FILE" ]]; then
  echo -e "\033[1;33mWebsite $NAME chưa được bật tính năng ghi Access Log!\033[0m"
  echo "Tính năng này mặc định tắt để bảo vệ hiệu suất CPU/Ổ cứng."
  echo ""

  prompt="Bạn có muốn BẬT ghi log cho website $NAME ngay bây giờ không? [1-2]: "
  options=("$dong_y" "$khong_dong_y")
  dongy="n"
  PS3="$prompt"
  select opt in "${options[@]}"; do
    case "$REPLY" in
    1)
      dongy="y"
      break
      ;;
    2) exec /etc/wptt/wptt-logs-main 1 ;;
    *)
      echo -e "\n$ban_nhap_sai_he_thong_se_chon_khong_dong_y\n"
      break
      ;;
    esac
  done

  if [[ "$dongy" == "y" ]]; then
    _runing "Kích hoạt ghi Access Log cho domain $NAME"

    # Lấy chuẩn nhóm Litespeed
    if grep -qi "ubuntu" /etc/os-release 2>/dev/null; then
      tuong_thich_nhom_litespeed="nogroup"
    else
      tuong_thich_nhom_litespeed="nobody"
    fi

    # Ghi cấu hình thẳng vào Vhost an toàn
    sed -i -e '/^errorlog /,/^}$/d' "$VHOST_CONF" 2>/dev/null
    sed -i -e '/^accesslog /,/^}$/d' "$VHOST_CONF" 2>/dev/null
    cat <<EOF >>"$VHOST_CONF"

errorlog \$VH_ROOT/logs/error.log {
  useServer               1
  logLevel                ERROR
  rollingSize             10M
}

accesslog \$VH_ROOT/logs/access.log {
  useServer               0
  rollingSize             10M
  keepDays                30
  compressArchive         1
}
EOF

    mkdir -p "$LOG_DIR"
    chown -R nobody:$tuong_thich_nhom_litespeed "$LOG_DIR"
    chmod 700 "$LOG_DIR"

    # Reload OLS để nhận cấu hình mới
    /usr/local/lsws/bin/lswsctrl reload >/dev/null 2>&1

    # [TUYỆT CHIÊU] Tự động gửi 1 request ảo để ép OLS sinh ra file access.log ngay lập tức
    curl -s -k "http://127.0.0.1" -H "Host: $NAME" >/dev/null 2>&1

    # Cập nhật cache WPTangToc
    [[ -f "/etc/wptt/vhost/.$NAME.conf" ]] && sed -i '/bat_log_domain/d' "/etc/wptt/vhost/.$NAME.conf" && echo 'bat_log_domain=1' >>"/etc/wptt/vhost/.$NAME.conf"

    _rundone "Kích hoạt ghi Access Log cho domain $NAME"
    sleep 1
  fi
fi

# Chốt chặn cuối cùng kiểm tra file
if [[ ! -f "$LOG_FILE" ]]; then
  echoDo "Lỗi: Không tìm thấy file access.log! Vui lòng kiểm tra lại cấu hình."
  sleep 3
  exec /etc/wptt/wptt-logs-main 1
fi

# ==============================================================================
# HIỂN THỊ LOG VÀ BẮT TÍN HIỆU CTRL+C (TRAP)
# ==============================================================================
clear
echo -e "\033[1;36m=========================================================================\033[0m"
echo -e " \033[1;32mĐANG XEM ACCESS LOG THEO THỜI GIAN THỰC (REAL-TIME)\033[0m"
echo -e " Website : \033[1;33m$NAME\033[0m"
echo -e " File Log: \033[1;33m$LOG_FILE\033[0m"
echo -e "\033[1;36m=========================================================================\033[0m"
echo -e "\033[1;31m [!] HƯỚNG DẪN: Bấm phím Ctrl + C để THOÁT và quay lại Menu.\033[0m"
echo -e "\033[1;36m=========================================================================\033[0m\n"

# Bắt tín hiệu Ctrl+C (SIGINT) để trở về Menu thay vì tắt script
trap '
  echo -e "\n\n\033[1;32mĐã dừng theo dõi Log.\033[0m"
  sleep 1
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-logs-main 1
  exit 0
' INT

# Chạy theo dõi thời gian thực
tail -f "$LOG_FILE"
