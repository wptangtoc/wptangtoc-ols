#!/bin/bash
# @author: Gia Tuấn
# @website: https://wptangtoc.com
# @since: 2025

function huong_dan() {
  Việc xem access log cho một domain cụ thể thông qua WPTangToc OLS thường sẽ tận dụng các công cụ sẵn có của hệ điều hành Linux.

  Tính năng xem access log domain trong wptangtoc ols có thể được hiểu ngắn gọn như sau:

  Xác định vị trí file log: OpenLiteSpeed thường lưu access log cho mỗi virtual host [tương ứng với mỗi domain] trong một file riêng biệt. Đường dẫn phổ biến có thể là /usr/local/lsws/domain.com/logs/access.log. Script wptangtoc ols cung cấp một trình đọc Log chuyên nghiệp giúp bạn phân trang và tìm kiếm dễ dàng.

  Tính năng này hỗ trợ người dùng dễ dàng hơn trong việc tìm và sử dụng các công cụ có sẵn của hệ thống để xem access log của OpenLiteSpeed cho từng domain. Điều này giúp quản trị viên website nhanh chóng kiểm tra lưu lượng truy cập, phát hiện lỗi hoặc các hoạt động bất thường liên quan đến một website cụ thể.
}

. /etc/wptt/.wptt.conf
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh
. /etc/wptt/echo-color

clear
echo -e "\n========================================================================="
echo -e "| Quản lý Logs => Xem Access Log Domain (Trình đọc Less)                  |"
echo -e "=========================================================================\n"

# ==============================================================================
# HÀM MENU LỌC THÔNG MINH (CÓ TRẠNG THÁI + FZF)
# ==============================================================================
function lua_chon_NAME() {
  unset NAME domain selects
  selects=()

  local file_list=()
  [[ -d /etc/wptt/vhost ]] && file_list+=(/etc/wptt/vhost/.*.conf)
  [[ -d /etc/wptt/chuyen-huong ]] && file_list+=(/etc/wptt/chuyen-huong/*)

  for filepath in "${file_list[@]}"; do
    [[ ! -f "$filepath" || "$filepath" == *"/..conf" || "$filepath" == *"*"* ]] && continue

    local domain="${filepath##*/}"
    domain="${domain%.conf}"
    domain="${domain#.}"

    if [[ "$domain" == ?*.?* ]]; then
      local vhost_conf="/usr/local/lsws/conf/vhosts/$domain/$domain.conf"
      if [[ -f "$vhost_conf" ]]; then
        if grep -q 'accesslog ' "$vhost_conf" 2>/dev/null; then
          selects+=("$domain [Đang BẬT Log]")
        else
          selects+=("$domain [Đang TẮT]")
        fi
      fi
    fi
  done

  if [[ ${#selects[@]} -eq 0 ]]; then
    echo -e "\n\033[1;33mKhông tìm thấy website nào trên hệ thống để thao tác!\033[0m"
    sleep 3
    exec /etc/wptt/wptt-logs-main 1
  fi

  mapfile -t selects < <(printf "%s\n" "${selects[@]}" | sort -uV)

  if [[ ${#selects[@]} -ge 2 ]]; then
    selects+=("TẤT CẢ WEBSITE (Không hỗ trợ mục này)")
  fi

  if command -v fzf &>/dev/null; then
    PS3="$(tput setab 0)-//- Lựa chọn website muốn xem Log [00=Tìm nhanh] [0=Thoát]:$(tput sgr0) "
  else
    PS3="$(tput setab 0)-//- Lựa chọn website muốn xem Log [0=Thoát]:$(tput sgr0) "
  fi

  select selected_domain in "${selects[@]}"; do
    NAME="$selected_domain"
    break
  done

  # XỬ LÝ CHỌN NHANH [00] VỚI FZF
  if [[ "$REPLY" == "00" ]] && command -v fzf &>/dev/null; then
    local selected_name
    selected_name=$(printf "%s\n" "${selects[@]}" | nl -w 3 -s ': ' | fzf --height 40% --border=rounded --color=border:red --reverse --prompt=">> Tìm website xem Log [0=Thoát]: ")
    selected_name=$(echo "$selected_name" | sed 's/^[[:space:]]*[0-9]\+\:[[:space:]]*//')

    if [[ -z "$selected_name" ]]; then
      echo "Đã hủy chọn."
      exec /etc/wptt/wptt-logs-main 1
    fi
    NAME="$selected_name"
  fi

  if [[ -z "$NAME" && "$REPLY" != "0" && "$REPLY" != "00" ]]; then
    REPLY=$(echo "$REPLY" | tr '[:upper:]' '[:lower:]' | xargs)
    for item in "${selects[@]}"; do
      local check_dom=$(echo "$item" | cut -f1 -d ' ')
      if [[ "$check_dom" == "$REPLY" ]]; then
        NAME="$item"
        break
      fi
    done
  fi
}

# Nếu gọi script kèm tên domain từ command line
if [[ -n "$1" && "$1" != "98" ]]; then
  NAME="$1"
else
  lua_chon_NAME
fi

# Tách lấy tên chuẩn
NAME=$(echo "$NAME" | cut -f1 -d ' ')

# Chốt chặn thoát hiểm
[[ "$NAME" == "0" || -z "$NAME" ]] && exec /etc/wptt/wptt-logs-main 1
[[ "$NAME" == "TẤT" ]] && {
  echoDo "Chức năng này chỉ hỗ trợ xem log từng website cụ thể!"
  sleep 2
  exec /etc/wptt/wptt-logs-main 1
}

LOG_DIR="/usr/local/lsws/$NAME/logs"
LOG_FILE="$LOG_DIR/access.log"
VHOST_CONF="/usr/local/lsws/conf/vhosts/$NAME/$NAME.conf"

# ==============================================================================
# KIỂM TRA VÀ KÍCH HOẠT LOG NẾU CHƯA CÓ
# ==============================================================================
if [[ ! -d "$LOG_DIR" || ! -f "$LOG_FILE" ]]; then
  echo -e "\033[1;33mWebsite $NAME chưa được bật tính năng ghi Access Log!\033[0m"
  echo "Tính năng này mặc định tắt để bảo vệ hiệu suất CPU/Ổ cứng."
  echo ""

  prompt="Bạn có muốn BẬT ghi log cho website $NAME ngay bây giờ không? [1-2]: "
  options=("$dong_y" "$khong_dong_y")
  dongy="n"
  PS3="$prompt"
  select opt in "${options[@]}"; do
    case "$REPLY" in
    1)
      dongy="y"
      break
      ;;
    2) exec /etc/wptt/wptt-logs-main 1 ;;
    *)
      echo -e "\n$ban_nhap_sai_he_thong_se_chon_khong_dong_y\n"
      break
      ;;
    esac
  done

  if [[ "$dongy" == "y" ]]; then
    _runing "Kích hoạt ghi Access Log cho domain $NAME"

    if grep -qi "ubuntu" /etc/os-release 2>/dev/null; then
      tuong_thich_nhom_litespeed="nogroup"
    else
      tuong_thich_nhom_litespeed="nobody"
    fi

    sed -i -e '/^errorlog /,/^}$/d' "$VHOST_CONF" 2>/dev/null
    sed -i -e '/^accesslog /,/^}$/d' "$VHOST_CONF" 2>/dev/null
    cat <<EOF >>"$VHOST_CONF"

errorlog \$VH_ROOT/logs/error.log {
  useServer               1
  logLevel                ERROR
  rollingSize             10M
}

accesslog \$VH_ROOT/logs/access.log {
  useServer               0
  rollingSize             10M
  keepDays                30
  compressArchive         1
}
EOF

    mkdir -p "$LOG_DIR"
    chown -R nobody:$tuong_thich_nhom_litespeed "$LOG_DIR"
    chmod 700 "$LOG_DIR"

    /usr/local/lsws/bin/lswsctrl reload >/dev/null 2>&1

    # Ép tạo file bằng 1 HTTP request
    curl -s -k "http://127.0.0.1" -H "Host: $NAME" >/dev/null 2>&1

    [[ -f "/etc/wptt/vhost/.$NAME.conf" ]] && sed -i '/bat_log_domain/d' "/etc/wptt/vhost/.$NAME.conf" && echo 'bat_log_domain=1' >>"/etc/wptt/vhost/.$NAME.conf"

    _rundone "Kích hoạt ghi Access Log cho domain $NAME"
    sleep 1
  fi
fi

if [[ ! -f "$LOG_FILE" ]]; then
  echoDo "Lỗi: Không tìm thấy file access.log! Vui lòng kiểm tra lại cấu hình."
  sleep 3
  exec /etc/wptt/wptt-logs-main 1
fi

# ==============================================================================
# SỬ DỤNG TRÌNH ĐỌC LESS CHUYÊN NGHIỆP
# ==============================================================================
clear
echo -e "\033[1;36m=========================================================================\033[0m"
echo -e "\033[1;33m ĐANG XEM FILE LOG:\033[0m $LOG_FILE"
echo -e "\033[1;36m=========================================================================\033[0m"
echo -e "\033[1;32m HƯỚNG DẪN SỬ DỤNG TRÌNH ĐỌC (LESS):\033[0m"
echo " - Nhấn phím mũi tên [Lên/Xuống] để cuộn từng dòng."
echo " - Nhấn phím [Space] để cuộn từng trang."
echo " - Nhấn phím [/] và nhập từ khóa để TÌM KIẾM (Nhấn 'n' để tìm tiếp)."
echo -e " - \033[1;31mNhấn phím [q] để THOÁT\033[0m và quay lại Menu."
echo -e "\033[1;36m=========================================================================\033[0m"
echo "Đang mở trình đọc log trong 3 giây..."
sleep 3

# Sử dụng less với tham số +G để tự động nhảy xuống dòng log mới nhất ở cuối file
less +G "$LOG_FILE"

# Sau khi bấm q thoát khỏi less, tự động quay lại Menu
[[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-logs-main 1
