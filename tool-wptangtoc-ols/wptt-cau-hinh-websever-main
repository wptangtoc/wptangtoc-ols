function huong_dan() {
  Tính năng Cấu hình Webserver trong WPTangToc OLS là một bộ công cụ và tùy chọn giúp bạn điều chỉnh các thiết lập cốt lõi của máy chủ web một cách thuận tiện ngay từ giao diện dòng lệnh của script. ⚙️🌐

  Giới thiệu ngắn gọn:
  Mục đích: Đơn giản hóa việc tùy chỉnh các khía cạnh quan trọng của OpenLiteSpeed, cho phép người dùng tinh chỉnh hiệu suất, bảo mật, và hành vi của máy chủ web mà không cần phải can thiệp sâu vào các file cấu hình phức tạp hoặc hoàn toàn dựa vào WebAdmin GUI của OLS.
  Cách hoạt động [thường thấy có thể bao gồm]:
  * Quản lý Virtual Host [vHost]: Hỗ trợ tạo, sửa, xóa cấu hình cho từng website [domain], bao gồm thiết lập thư mục gốc, liên kết tên miền [đã được đề cập trong quản lý domain].
  * Cấu hình Listener: Điều chỉnh cơ bản các cổng lắng nghe [ví dụ: port 80, 443] và cách OLS xử lý kết nối đến.
  * Tối ưu hóa cơ bản: Cung cấp tùy chọn để áp dụng các thiết lập tối ưu hóa hiệu suất phổ biến cho OLS.
  * Rewrite Rules: Có thể cung cấp giao diện để quản lý hoặc thêm các quy tắc viết lại URL [rewrite rules] cho từng vHost hoặc toàn cục.
  * Cấu hình PHP Handler: Liên kết các phiên bản PHP với các website cụ thể [đã đề cập trong quản lý PHP].
  * Thiết lập bảo mật cơ bản: Áp dụng một số tiêu đề bảo mật [security headers] hoặc các cấu hình bảo mật ở cấp độ máy chủ.
  * Truy cập file cấu hình OLS: Có thể cung cấp lối tắt để chỉnh sửa trực tiếp các file cấu hình quan trọng của OLS [với cảnh báo].
  Lợi ích:
  * Kiểm soát linh hoạt: Cho phép tùy chỉnh máy chủ web theo nhu cầu cụ thể.
  * Đơn giản hóa: Giảm độ phức tạp so với việc chỉnh sửa thủ công file cấu hình gốc của OpenLiteSpeed.
  * Tiện lợi: Thực hiện các thay đổi nhanh chóng ngay từ WPTangToc OLS.
  * Tối ưu hóa: Giúp người dùng áp dụng các cấu hình tốt nhất cho hiệu suất và bảo mật.
  Tính năng này là trung tâm của việc quản trị máy chủ web, giúp bạn định hình cách OpenLiteSpeed hoạt động và phục vụ các website của mình một cách hiệu quả.
}

if [[ -z "$1" ]]; then
  . /etc/wptt/wptt-header-menu
  header_menu
  echo ""
  echo ""
  echo "$ghi_chu_muc_nay_chi_danh_cho_nguoi_nang_cao"
  echo "$hay_het_suc_can_than_trong_qua_trinh_chinh_sua"
else
  . /etc/wptt/echo-color 2>/dev/null
  echoDo "=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-="
fi

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null

echo ""
echo "$cau_hinh_webserver:" > /dev/null

MENU_TITLE="TRUNG TÂM CẤU HÌNH HỆ THỐNG (ADVANCED)"

# =========================================================================
# 2. KHỐI OPTIONS TĨNH (GIỮ NGUYÊN ĐỂ WPTANGTOC-SEARCH ĐỌC ĐƯỢC)
# Đừng thay đổi khoảng cách hay ký tự ở khối này
# =========================================================================
options=(
  "$chinh_sua LiteSpeed"          #0
  "$chinh_sua Vhost"              #1
  "$chinh_sua Maria Database"     #2
  "$chinh_sua .htaccess"          #3
  "$chinh_sua PHP.ini"            #4
  "$chinh_sua Cron JOB"           #5
  "$chinh_sua Redis/Valkey/KeyDB" #6
  "$chinh_sua Memcached"          #7
  "$chinh_sua Fail2ban"           #8
  "$chinh_sua Hostname"           #9
  "$thay_doi $cong_cu_cau_hinh"   #10
)

# =========================================================================
# 3. BỘ LỌC ĐỘNG (XÓA MENU KHÔNG DÙNG + ÁNH XẠ INDEX GỐC)
# =========================================================================
map_index=()
real_options=()

for i in "${!options[@]}"; do
  item="${options[$i]}"

  # Lọc ẩn Redis/Valkey/KeyDB
  if [[ "$item" == *Redis* ]]; then
    if ! systemctl is-active --quiet valkey 2>/dev/null &&
      ! systemctl is-active --quiet keydb 2>/dev/null &&
      ! systemctl is-active --quiet redis 2>/dev/null &&
      ! systemctl is-active --quiet redis-server 2>/dev/null &&
      [[ ! -d /etc/valkey ]] && [[ ! -d /etc/keydb ]] && [[ ! -d /etc/redis ]]; then
      continue # Nhảy qua, không add vào menu hiển thị
    fi
  fi

  # Lọc ẩn Memcached
  if [[ "$item" == *Memcached* ]]; then
    if ! systemctl is-active --quiet memcached 2>/dev/null &&
      [[ ! -f /etc/memcached.conf ]] && [[ ! -f /etc/sysconfig/memcached ]]; then
      continue # Nhảy qua, không add vào menu hiển thị
    fi
  fi

  # Nếu phần mềm có tồn tại, đẩy vào mảng thực tế và nhớ cái index gốc
  real_options+=("$item")
  map_index+=("$i")
done

# VÁ LỖI WPTANGTOC-SEARCH (Tránh việc tạo cú pháp options=() làm sed nhận nhầm)
unset options
for opt in "${real_options[@]}"; do
  options+=("$opt")
done

# =========================================================================
# 4. LOGIC XỬ LÝ (TỰ ĐỘNG KHỚP LẠI INDEX)
# =========================================================================
run_action() {
  local display_index=$1

  # CHÌA KHÓA: Phục hồi lại index gốc từ mảng ánh xạ để khớp với case bên dưới
  local index=${map_index[$display_index]}

  local script_path=""
  local script_args=""

  # QUAN TRỌNG NHẤT: Bắt buộc để số Label N) và script_path trên CÙNG 1 DÒNG
  case $index in
  0)
    script_path="/etc/wptt/cau-hinh/wptt-sua-websever"
    script_args="98"
    ;;
  1)
    script_path="/etc/wptt/cau-hinh/wptt-cau-hinh-vhost"
    script_args="98"
    ;;
  2)
    script_path="/etc/wptt/cau-hinh/wptt-sua-mariadb"
    script_args="98"
    ;;
  3)
    script_path="/etc/wptt/cau-hinh/wptt-cau-hinh-htaccess"
    script_args="98"
    ;;
  4)
    script_path="/etc/wptt/php/wptt-sua-phpini"
    script_args="99"
    ;;
  5)
    script_path="/etc/wptt/cau-hinh/wptt-cron"
    script_args="98"
    ;;
  6)
    script_path="/etc/wptt/cau-hinh/wptt-cau-hinh-redis"
    script_args="98"
    ;;
  7)
    script_path="/etc/wptt/cau-hinh/wptt-cau-hinh-memcached"
    script_args="98"
    ;;
  8)
    script_path="/etc/wptt/cau-hinh/wptt-cau-hinh-fail2ban"
    script_args="98"
    ;;
  9)
    script_path="/etc/wptt/cau-hinh/wptt-hostname"
    script_args="98"
    ;;
  10)
    script_path="/etc/wptt/cau-hinh/wptt-editor-cau-hinh"
    script_args="98"
    ;;
  *)
    echo "${lua_chon_khong_hop_le:-Lựa chọn không hợp lệ}: Index $index."
    return 1
    ;;
  esac

  if [[ -x "$script_path" ]]; then
    if [[ -n "$script_args" ]]; then
      exec "$script_path" "$script_args"
    else
      exec "$script_path"
    fi
  else
    echo -e "\n\033[1;31m[!] Lỗi: Không tìm thấy script '$script_path'.\033[0m"
    sleep 2
    exec /etc/wptt/wptt-cau-hinh-websever-main 1
  fi
}

# ==============================================================================
# 5. GIAO DIỆN TÙY CHỈNH (THUẬT TOÁN CHIA CỘT ĐỘNG)
# ==============================================================================
draw_custom_grid() {
  print_row "" "CẤU HÌNH LÕI (CORE)" "" "HỆ THỐNG & TIỆN ÍCH"
  
  local total=${#options[@]}
  local half=$(( (total + 1) / 2 ))
  
  for ((i=0; i<half; i++)); do
    local l_num=$((i+1))
    local l_text="${options[$i]}"
    local r_num=""
    local r_text=""
    local r_idx=$((i+half))

    # Nếu cột phải vẫn còn item thì mới gán dữ liệu
    if [[ $r_idx -lt $total ]]; then
       r_num=$((r_idx+1))
       r_text="${options[$r_idx]}"
    fi
    
    print_row "$l_num" "$l_text" "$r_num" "$r_text"
  done
}

# ==============================================================================
# 6. KÍCH HOẠT THƯ VIỆN UI ENGINE (BỘ NÃO HIỂN THỊ KHUNG 78)
# ==============================================================================
. /etc/wptt/wptt-callback-menu-chon
