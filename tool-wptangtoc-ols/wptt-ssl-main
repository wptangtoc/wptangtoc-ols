echo ""
echo "$quan_ly_ssl:" > /dev/null # Ẩn đi nhưng giữ cho wptt-search tổng bắt được danh mục

# ==============================================================================
# 2. KHAI BÁO TIÊU ĐỀ MENU VÀ OPTIONS (SẠCH 100%)
# ==============================================================================
MENU_TITLE="TRUNG TÂM QUẢN LÝ SSL (HTTPS)"

options=(
  "$cai_dat_ssl_letencrypt"                       #0 (Hiển thị: 1)
  "$mo_rong_ssl_letencrypt"                       #1 (Hiển thị: 2)
  "$xoa_chung_chi_ssl_letencrypt"                 #2 (Hiển thị: 3)
  "$ket_noi_cloudflare_dns_api_letencrypt"        #3 (Hiển thị: 4)
  "$gia_han_thu_cong_ssl_letencrypt"              #4 (Hiển thị: 5)
  "$thiet_lap_ssl_tra_phi"                        #5 (Hiển thị: 6)
  "$xoa_chung_chi_ssl_tra_phi"                    #6 (Hiển thị: 7)
  "$kiem_tra_chung_chi_ssl_dang_su_dung"          #7 (Hiển thị: 8)
  "$renew_thiet_lap_chuyen_huong_http_sang_https" #8 (Hiển thị: 9)
)

# ==============================================================================
# 3. LOGIC XỬ LÝ (MAPPING INDEX 0-8)
# ==============================================================================
run_action() {
  local index=$1
  local script_path=""
  local script_args="98"

  case $index in
  0) script_path="/etc/wptt/ssl/wptt-caissl" ;;
  1) script_path="/etc/wptt/ssl/wptt-mo-rong-ssl-free" ;;
  2) script_path="/etc/wptt/ssl/wptt-xoa-ssl" ;;
  3) script_path="/etc/wptt/ssl/cloudflare-api-dns-main" ;;
  4) script_path="/etc/wptt/ssl/wptt-gia-han-ssl" ;;
  5) script_path="/etc/wptt/ssl/wptt-caissl-traphi" ;;
  6) script_path="/etc/wptt/ssl/wptt-caissl-traphi-xoa" ;;
  7) script_path="/etc/wptt/ssl/wptt-kiem-tra-ssl" ;;
  8) script_path="/etc/wptt/ssl/wptt-renew-chuyen-huong" ;;
  esac

  if [[ -x "$script_path" || -f "$script_path" ]]; then
    exec bash "$script_path" "$script_args"
  else
    echo -e "\n\033[1;31m[!] Lỗi: Không tìm thấy tệp '$script_path'.\033[0m"
    sleep 2
    exec /etc/wptt/wptt-ssl-main 1
  fi
}

# ==============================================================================
# 4. GIAO DIỆN TÙY CHỈNH (CĂN CHỈNH 2 CỘT)
