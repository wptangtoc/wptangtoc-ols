# ==============================================================================
# 3. LOGIC XỬ LÝ (ÁNH XẠ CHUẨN 100% VỚI INDEX MỚI & TRUYỀN THAM SỐ)
# ==============================================================================
run_action() {
  local index=$1
  local script_path=""
  local script_args="98" # Tham số thứ hai mặc định
  local extra_arg=""     # Biến để lưu tham số thứ ba (nếu có)

  case $index in
  0) script_path="/etc/wptt/add-one/activate-key" ;;
  1) script_path="/etc/wptt/add-one/thiet-lap-downtimes" ;;
  2) script_path="/etc/wptt/add-one/thiet-lap-check-ssl" ;;
  3) script_path="/etc/wptt/add-one/thiet-lap-check-domain-het-han" ;;
  4) script_path="/etc/wptt/add-one/add-premium"; extra_arg="backup" ;;
  5) script_path="/etc/wptt/add-one/add-premium"; extra_arg="restore" ;;
  6) script_path="/etc/wptt/add-one/add-premium"; extra_arg="auto-backup-setup" ;;
  7) script_path="/etc/wptt/add-one/add-premium"; extra_arg="tat-auto-backup" ;;
  8) script_path="/etc/wptt/add-one/add-premium"; extra_arg="quet-bao-mat-wordpress" ;;
  9) script_path="/etc/wptt/add-one/thiet-lap-auto-htaccess-optimize" ;;
  10) script_path="/etc/wptt/cloudflare-cdn-ip-show-real"; extra_arg="premium" ;;
  11) script_path="/etc/wptt/add-one/add-premium"; extra_arg="custom-x-powered-by" ;;
  12) script_path="/etc/wptt/proxy-setup"; extra_arg="premium" ;;
  13) script_path="/etc/wptt/ip-scan-block"; extra_arg="premium" ;;
  14) script_path="/etc/wptt/wptt-reset"; extra_arg="premium" ;;
  15) script_path="/etc/wptt/wptt-htaccess-reset"; extra_arg="premium" ;;
  esac

  # Kiểm tra và chạy script con (Đã tháo exec theo chuẩn mới chống văng SSH)
  if [[ -x "$script_path" || -f "$script_path" ]]; then
    if [[ -n "$extra_arg" ]]; then
      bash "$script_path" "$script_args" "$extra_arg"
    else
      bash "$script_path" "$script_args"
    fi
  else
    echo -e "\n\033[1;31m[!] Lỗi: Không tìm thấy hoặc không thể thực thi script '$script_path'.\033[0m"
    sleep 2
    bash /etc/wptt/wptt-add-one-main 1
  fi
}

