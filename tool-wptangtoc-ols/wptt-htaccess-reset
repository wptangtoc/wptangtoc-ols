#!/bin/bash
# @author: Gia Tuấn
# @website: https://wptangtoc.com
# @email: giatuan@wptangtoc.com
# @since: 2025

function huong_dan() {
  Tính năng Factory Reset .htaccess [Khôi phục cài đặt gốc cho tệp .htaccess] trong WPTangToc OLS là một công cụ giúp bạn đưa nội dung của tệp .htaccess trong thư mục gốc của một website [thường là website WordPress] trở về trạng thái mặc định, chuẩn của WordPress.

  🤔 Tệp .htaccess là gì?
  Mặc dù WPTangToc OLS quản lý OpenLiteSpeed [OLS], OLS vẫn có khả năng đọc và xử lý các chỉ thị trong tệp .htaccess để tương thích với các ứng dụng phổ biến như WordPress. Tệp này kiểm soát nhiều thứ, quan trọng nhất là cấu trúc đường dẫn tĩnh [permalinks] và các quy tắc bảo mật hoặc chuyển hướng do plugin thêm vào. Plugin Cache thêm vào...

  🎯 Mục đích chính
  Việc reset .htaccess về mặc định thường hữu ích khi:
  * Sửa lỗi 404 [Not Found]: Khi các trang con của website WordPress đột nhiên báo lỗi 404, nguyên nhân phổ biến là do tệp .htaccess bị lỗi hoặc thiếu quy tắc chuẩn.
  * Loại bỏ quy tắc xung đột: Các quy tắc tùy chỉnh hoặc do plugin thêm vào có thể gây xung đột, làm website hoạt động không đúng. Reset sẽ xóa bỏ chúng.
  * Khắc phục sự cố sau khi bị tấn công: Đôi khi, mã độc có thể được chèn vào tệp .htaccess. Việc reset về mặc định giúp loại bỏ các thay đổi trái phép này [nhưng bạn vẫn cần kiểm tra bảo mật toàn diện].
  * Chuẩn hóa cấu hình: Đưa .htaccess về trạng thái gốc của WordPress để đảm bảo các chức năng cơ bản hoạt động đúng.
  * Sửa lỗi lỗi 404 ngoài trừ trang chủ hãy sử dụng tính năng này.
  * Sửa lỗi website của bạn bị lỗi: download.php

  Tính năng Factory Reset .htaccess là một công cụ gỡ rối nhanh và hiệu quả cho nhiều vấn đề phổ biến của WordPress liên quan đến đường dẫn và các quy tắc trong .htaccess.
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null

# Nếu truyền vào tham số "no-ui" (khi chạy vòng lặp), bỏ qua clear screen
if [[ "$2" != "no-ui" ]]; then
  clear
  echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_YELLOW}QUẢN LÝ WORDPRESS -> Khôi Phục Cài Đặt Gốc .htaccess${C_RESET}"
  echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"
fi

# ==============================================================================
# KIỂM TRA ĐIỀU KIỆN PREMIUM
# ==============================================================================
if [[ "$2" == 'premium' ]]; then
  unset key_activate
  . /etc/wptt/.wptt.conf 2>/dev/null
  if [[ -z "$key_activate" ]]; then
    echo -e "${C_RED}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
    center_text "${C_BOLD_WHITE}[!] TÍNH NĂNG PREMIUM BỊ KHÓA${C_RESET}"
    echo -e "${C_RED}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
    left_text "  Đây là tính năng Premium. Bạn cần phải mua Active Key" 2
    left_text "  để sử dụng tính năng này cùng các Add-ons cao cấp khác." 2
    echo -e "${C_RED}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"
    
    check_menu_wptangtoc_active=${1:-}
    if [[ "$check_menu_wptangtoc_active" == "98" ]]; then
      echo -en "${C_YELLOW}>> Nhấn phím [Enter] để đến Menu Add-ons...${C_RESET}"
      read -r dummy
      exec /etc/wptt/wptt-add-one-main 1
    fi
    exit 1
  fi
fi

NAME=$1
[[ "$NAME" == '98' ]] && NAME=''

if [[ -z "$NAME" ]]; then
  . /etc/wptt/tenmien-them-lua-chon-tat-ca-website-by-wordpress
  lua_chon_NAME "Khôi phục .htaccess"
fi

[[ "$NAME" == "0" || -z "$NAME" ]] && exec /usr/bin/wptangtoc 1

if [[ "$NAME" == 'Tất cả website' ]]; then
  echo -e "\n${C_YELLOW}[!] Bắt đầu khôi phục .htaccess cho TOÀN BỘ website WordPress...${C_RESET}\n"
  if [ "$(ls -A /etc/wptt/vhost 2>/dev/null | grep -v '^\.\.conf$' | sort -uV)" ]; then
    for entry in $(ls -A /etc/wptt/vhost | grep -v '^\.\.conf$' | sort -uV); do
      domain=$(echo "$entry" | sed 's/^\.//' | sed 's/\.conf$//')
      path_config="/usr/local/lsws/$domain/html/wp-config.php"
      
      if [[ -f "$path_config" ]]; then
        _runing "Đang xử lý khôi phục .htaccess cho: $domain"
        bash /etc/wptt/wptt-htaccess-reset "$domain" "no-ui" >/dev/null 2>&1
        _rundone "Khôi phục .htaccess cho $domain [OK]"
      fi
    done
  fi
  
  echo -e "\n${C_GREEN}[HOÀN TẤT] Đã xử lý toàn bộ website trên máy chủ.${C_RESET}\n"
  exec /etc/wptt/wptt-wordpress-main 1
  exit 0
fi

# ==============================================================================
# KIỂM TRA TÍNH HỢP LỆ CỦA WEBSITE ĐƠN
# ==============================================================================
pathcheck="/etc/wptt/vhost/.$NAME.conf"
if [[ ! -f "$pathcheck" ]]; then
  echo -e "\n${C_RED}[!] Lỗi: Tên miền ($NAME) không tồn tại trên hệ thống này.${C_RESET}"
  sleep 2
  exec /usr/bin/wptangtoc 1
  exit 1
fi

pathcheckwp="/usr/local/lsws/$NAME/html/wp-load.php"
if [[ ! -f "$pathcheckwp" ]]; then
  echo -e "\n${C_RED}[!] Lỗi: Tên miền ($NAME) không sử dụng mã nguồn WordPress.${C_RESET}"
  echo -e "Tính năng này chỉ hỗ trợ khôi phục .htaccess cho cấu trúc WordPress."
  sleep 3
  exec /usr/bin/wptangtoc 1
  exit 1
fi

echo "Reset Htaccess website $NAME : $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log

# ==============================================================================
# THỰC THI KHÔI PHỤC .HTACCESS VÀ CẤU HÌNH LIÊN QUAN
# ==============================================================================
. "/etc/wptt/vhost/.$NAME.conf"

_runing "Đang ghi đè cấu hình .htaccess chuẩn của WordPress..."
cat << 'EOF' > "/usr/local/lsws/$NAME/html/.htaccess"
# BEGIN WordPress
<IfModule mod_rewrite.c>
RewriteEngine On
RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]
RewriteBase /
RewriteRule ^index\.php$ - [L]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . /index.php [L]
</IfModule>
# END WordPress
EOF
_rundone "Ghi đè cấu hình .htaccess chuẩn [OK]"

if [[ -f "/etc/letsencrypt/live/$NAME/cert.pem" || -d "/usr/local/lsws/$NAME/ssl" || -f "/etc/letsencrypt/live/www.$NAME/cert.pem" ]]; then
  _runing "Đang thiết lập lại quy tắc chuyển hướng HTTPS..."
  . /etc/wptt/ssl/wptt-renew-chuyen-huong "$NAME" >/dev/null 2>&1
  _rundone "Thiết lập chuyển hướng HTTPS [OK]"
fi

. /etc/wptt/php/php-cli-domain-config "$NAME"

if [[ -d "/usr/local/lsws/$NAME/html/wp-content/plugins/litespeed-cache" ]]; then
  _runing "Đang đồng bộ cấu hình LiteSpeed Cache..."
  /usr/local/lsws/lsphp${phien_ban_php_domain_thuc_thi}/bin/php /usr/local/bin/wp litespeed-option set cache-browser false --allow-root --path="/usr/local/lsws/$NAME/html" >/dev/null 2>&1
  _rundone "Đồng bộ LiteSpeed Cache [OK]"
fi

if [[ -n "$tuong_lua_7g" ]]; then
  _runing "Đang nạp lại quy tắc Tường lửa 7G Firewall..."
  . /etc/wptt/bao-mat/wptt-firewall-7g "$NAME" >/dev/null 2>&1
  _rundone "Nạp lại Tường lửa 7G Firewall [OK]"
fi

if [[ -f "/usr/local/lsws/$NAME/html/wp-content/plugins/wptangtoc/class/Cache.php" ]]; then
  _runing "Đang nạp lại quy tắc WPTangToc Cache..."
  . /etc/wptt/cache/cache-wptangtoc-page-html "$NAME" >/dev/null 2>&1
  _rundone "Nạp lại WPTangToc Cache [OK]"
fi

# ==============================================================================
# PHÂN QUYỀN VÀ FLUSH REWRITE
# ==============================================================================
_runing "Đang xử lý phân quyền bảo mật thư mục và tệp tin..."
chown -R "$User_name_vhost":"$User_name_vhost" "/usr/local/lsws/$NAME/html"

if [[ "$2" != 'no-ui' && "$2" != 'premium' ]]; then
  . /etc/wptt/wptt-phanquyen "$NAME" >/dev/null 2>&1
fi

chmod 444 "/usr/local/lsws/$NAME/html/index.php"
chmod 600 "/usr/local/lsws/$NAME/html/wp-config.php"

if grep -qi "ubuntu" /etc/*release 2>/dev/null; then
  tuong_thich_nhom_litespeed="nogroup"
else
  tuong_thich_nhom_litespeed="nobody"
fi

if [[ -n "$id_dang_nhap_phpmyadmin" && "$Website_chinh" == "$NAME" && -d "/usr/local/lsws/$NAME/html/phpmyadmin" ]]; then
  chown -R nobody:$tuong_thich_nhom_litespeed "/usr/local/lsws/$NAME/html/phpmyadmin"
fi
_rundone "Phân quyền bảo mật tệp tin [OK]"

_runing "Đang làm mới Permalink (Flush Rewrite Rules) và khởi động OLS..."
/usr/local/lsws/lsphp${phien_ban_php_domain_thuc_thi}/bin/php /usr/local/bin/wp rewrite flush --allow-root --path="/usr/local/lsws/$NAME/html" >/dev/null 2>&1
/usr/local/lsws/bin/lswsctrl restart >/dev/null 2>&1
_rundone "Khởi động lại máy chủ Web [OK]"

# ==============================================================================
# BẢNG BÁO CÁO KẾT QUẢ
# ==============================================================================
if [[ "$2" != "no-ui" ]]; then
  echo -e "\n${C_GREEN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_BOLD_WHITE}[HOÀN TẤT] KHÔI PHỤC .HTACCESS${C_RESET}"
  echo -e "${C_GREEN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
  left_text "  - Website xử lý : ${C_YELLOW}$NAME${C_RESET}" 2
  left_text "  - Trạng thái    : Đã khôi phục về chuẩn gốc WordPress" 2
  left_text "  - Bảo mật       : Đã nạp lại các rule HTTPS, 7G Firewall" 2
  echo -e "${C_GREEN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

  check_menu_wptangtoc_active=${1:-}
  if [[ "$check_menu_wptangtoc_active" == "98" ]]; then
    exec /usr/bin/wptangtoc 1
  fi
fi
