function huong_dan() {
  Tính năng Thông tin Webserver trong WPTangToc OLS là một công cụ tiện ích cung cấp cho người quản trị cái nhìn tổng quan và nhanh chóng về các thông số kỹ thuật cũng như trạng thái hiện tại của máy chủ.
}

. /etc/wptt/echo-color
_runing "Đang quét sâu hệ thống (thể mất 10-20 giây)..."
echo "Kiểm tra hệ thống: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log

# Định nghĩa màu sắc nội bộ cho UI
C_RED='\033[1;31m'
C_GREEN='\033[1;32m'
C_YELLOW='\033[1;33m'
C_CYAN='\033[1;36m'
C_RESET='\033[0m'

kiemtra() {
  . /etc/wptt/.wptt.conf

  virtua=$(virt-what 2>/dev/null)
  if [[ -n ${virtua} ]]; then
    virt=$(echo "$virtua" | tr '\n' ' ')
  else
    virt="Dedicated (Máy chủ vật lý)"
  fi

  # Hàm đo I/O linh hoạt theo Block Size
  do_io() {
    local bs=$1
    local count=$2
    (
      LANG=C dd if=/dev/zero of=test_$$ bs=$bs count=$count conv=fdatasync 2>&1
      rm -f test_$$
    ) | awk -F, '/copied/ {print $NF}' | sed 's/^[ \t]*//;s/[ \t]*$//'
  }

  io_4k=$(do_io 4k 25600)    # Test 100MB cho Database
  io_128k=$(do_io 128k 2048) # Test 256MB cho File Web
  io_1m=$(do_io 1M 1024)     # Test 512MB cho Backup

  # Thông tin Network & IP
  ip=$(curl -sf --connect-timeout 5 --max-time 10 https://ipv4.icanhazip.com || curl -sf --connect-timeout 5 --max-time 10 https://checkip.amazonaws.com || echo "Không xác định được IP")
  org="$(wget -q -T5 -O- ipinfo.io/org)"
  city="$(wget -q -T5 -O- ipinfo.io/city)"
  country="$(wget -q -T5 -O- ipinfo.io/country)"

  # Thông tin Stack WPTangToc
  phpcheck=$(php -v 2>/dev/null | head -n 1 | awk '{print $2}' | cut -d'-' -f1)
  mariacheck=$(mariadbd --version 2>/dev/null | awk '{print $3}' | cut -d'-' -f1)
  olscheck=$(/usr/local/lsws/bin/lshttpd -v 2>/dev/null | grep -o 'LiteSpeed/[0-9.]*' | cut -d'/' -f2)

  sys_vendor=$(dmidecode -s system-manufacturer 2>/dev/null | head -n 1 | sed 's/^[ \t]*//')
  sys_product=$(dmidecode -s system-product-name 2>/dev/null | head -n 1 | sed 's/^[ \t]*//')
  [[ -z "$sys_vendor" ]] && sys_vendor="N/A"

  nic_card=$(lspci 2>/dev/null | grep -i 'ethernet' | awk -F': ' '{print $2}' | head -1)
  [[ -z "$nic_card" ]] && nic_card="Virtual NIC (KVM/VMware)"

  # CPU Info & Features
  hedieuhanh=$(hostnamectl | grep 'Operating System' | cut -f2 -d':' | sed 's/^ //g')
  cname=$(lscpu | grep 'Model name:' | awk -F: '{print $2}' | sed 's/^[ \t]*//' | head -1)
  cores=$(awk -F: '/model name/ {core++} END {print core}' /proc/cpuinfo)
  [[ -z $cores ]] && cores=$(awk '/^processor/ {core++} END {print core}' /proc/cpuinfo)

  freq=$(awk -F: '/cpu MHz/ {freq=$2} END {print freq}' /proc/cpuinfo | sed 's/^[ \t]*//;s/[ \t]*$//' | head -n 1)
  if [[ -z $freq || $freq == "0.000" ]]; then
    freq=$(awk '{print $1 / 1000}' /sys/devices/system/cpu/cpu0/cpufreq/scaling_max_freq 2>/dev/null)
    [[ -z $freq ]] && freq="N/A"
  fi

  cpu_cache=$(lscpu 2>/dev/null | grep -i "L3 cache" | awk -F: '{print $2}' | xargs)
  [[ -z "$cpu_cache" ]] && cpu_cache=$(awk -F: '/cache size/ {print $2}' /proc/cpuinfo | head -1 | xargs)
  [[ -z "$cpu_cache" ]] && cpu_cache="N/A"

  # Nâng cấp hiển thị màu sắc cho tính năng AVX
  cpu_aes=$(grep -m1 -q aes /proc/cpuinfo && echo "${C_GREEN}Có${C_RESET}" || echo "${C_RED}Không (CPU Đời cũ)${C_RESET}")
  cpu_avx=$(grep -m1 -q avx2 /proc/cpuinfo && echo "${C_GREEN}Có (AVX2)${C_RESET}" || (grep -m1 -q avx /proc/cpuinfo && echo "${C_GREEN}Có (AVX)${C_RESET}" || echo "${C_RED}Không${C_RESET}"))

  # RAM Info
  check_ddr_ram=$(dmidecode -t memory 2>/dev/null | awk '/Type: DDR/ {print $2}' | head -n 1)
  check_ram_bus=$(dmidecode -t memory 2>/dev/null | awk '/Speed:/ && $2 != "Unknown" {print $2" "$3}' | head -n 1)
  if [[ -n "$check_ddr_ram" && -n "$check_ram_bus" ]]; then
    ram_type_bus="$check_ddr_ram / $check_ram_bus"
  elif [[ -n "$check_ddr_ram" ]]; then
    ram_type_bus="$check_ddr_ram"
  else
    ram_type_bus="N/A (Virtual RAM)"
  fi

  tram=$(free -m | awk '/Mem/ {print $2}')
  uram=$(free -m | awk '/Mem/ {print $3}')
  ram_percent=$(echo "scale=0; $uram * 100 / $tram" | bc 2>/dev/null)

  ram_color=$C_GREEN
  [[ $ram_percent -gt 75 ]] && ram_color=$C_YELLOW
  [[ $ram_percent -gt 90 ]] && ram_color=$C_RED

  swap=$(free -m | awk '/Swap/ {print $2}')
  uswap=$(free -m | awk '/Swap/ {print $3}')

  if command -v zramctl &>/dev/null && grep -q "^/dev/zram" /proc/swaps 2>/dev/null; then
    z_disk=$(zramctl --bytes -n -o DISKSIZE 2>/dev/null | awk '{sum+=$1} END {print int(sum/1024/1024)}')
    zram_info="${z_disk} MB (Active)"
  fi

  up=$(awk '{a=$1/86400;b=($1%86400)/3600;c=($1%3600)/60} {printf("%d ngày, %d giờ %d phút\n",a,b,c)}' /proc/uptime)
  load=$(w | head -1 | awk -F'load average:' '{print $2}' | sed 's/^[ \t]*//;s/[ \t]*$//')

  arch=$(uname -m)
  lbit=$(getconf LONG_BIT)
  date_now=$(date '+%d-%m-%Y %H:%M:%S %Z')

  disk_total=$(df -BG / | tail -n 1 | awk '{print $2}' | tr -d 'G')
  disk_used=$(df -BG / | tail -n 1 | awk '{print $3}' | tr -d 'G')
  disk_percent=$(df -h / | tail -n 1 | awk '{print $5}' | tr -d '%')

  disk_color=$C_GREEN
  [[ $disk_percent -gt 80 ]] && disk_color=$C_YELLOW
  [[ $disk_percent -gt 90 ]] && disk_color=$C_RED

  _rundone "Đang quét sâu hệ thống (thể mất 10-20 giây)..."
  clear
  echo -e "${C_CYAN}╭────────────────────────────────────────────────────────╮${C_RESET}"
  echo -e "${C_CYAN}│${C_RESET}             ${C_YELLOW}THÔNG TIN MÁY CHỦ - WPTANGTOC OLS${C_RESET}          ${C_CYAN}│${C_RESET}"
  echo -e "${C_CYAN}├────────────────────────────────────────────────────────┤${C_RESET}"
  echo -e "${C_CYAN}│${C_RESET} ${C_GREEN}PHẦN MỀM LÕI (STACK)${C_RESET}                                   ${C_CYAN}│${C_RESET}"
  echo -e "${C_CYAN}│${C_RESET} WPTangToc OLS    : $version_wptangtoc_ols"
  echo -e "${C_CYAN}│${C_RESET} OpenLiteSpeed    : ${olscheck:-N/A}"
  echo -e "${C_CYAN}│${C_RESET} PHP              : ${phpcheck:-N/A}"
  echo -e "${C_CYAN}│${C_RESET} MariaDB          : ${mariacheck:-N/A}"
  echo -e "${C_CYAN}├────────────────────────────────────────────────────────┤${C_RESET}"
  echo -e "${C_CYAN}│${C_RESET} ${C_GREEN}TÀI NGUYÊN PHẦN CỨNG CHI TIẾT${C_RESET}                          ${C_CYAN}│${C_RESET}"
  echo -e "${C_CYAN}│${C_RESET} Mainboard/Vendor : $sys_vendor $sys_product"
  echo -e "${C_CYAN}│${C_RESET} CPU Model        : $cname"
  echo -e "${C_CYAN}│${C_RESET} CPU Cores / Freq : $cores Cores / $freq MHz"
  echo -e "${C_CYAN}│${C_RESET} CPU Cache (L3)   : $cpu_cache"
  echo -e "${C_CYAN}│${C_RESET} CPU Hỗ trợ AES   : $cpu_aes"
  echo -e "${C_CYAN}│${C_RESET} CPU Hỗ trợ AVX   : $cpu_avx"
  echo -e "${C_CYAN}│${C_RESET} RAM Type / Bus   : $ram_type_bus"
  echo -e "${C_CYAN}│${C_RESET} RAM Usage        : ${ram_color}${uram} MB / ${tram} MB (${ram_percent}%)${C_RESET}"
  if [[ -n $zram_info ]]; then
    echo -e "${C_CYAN}│${C_RESET} ZRAM Swap        : $zram_info"
  fi
  echo -e "${C_CYAN}│${C_RESET} Disk Usage       : ${disk_color}${disk_used}GB / ${disk_total}GB (${disk_percent}%)${C_RESET}"
  echo -e "${C_CYAN}│${C_RESET} Disk Speed (4K)  : $io_4k"
  echo -e "${C_CYAN}│${C_RESET} Disk Speed (128K): $io_128k"
  echo -e "${C_CYAN}│${C_RESET} Disk Speed (1M)  : $io_1m"
  echo -e "${C_CYAN}│${C_RESET} Network Card     : $nic_card"
  echo -e "${C_CYAN}├────────────────────────────────────────────────────────┤${C_RESET}"
  echo -e "${C_CYAN}│${C_RESET} ${C_GREEN}HỆ ĐIỀU HÀNH & MẠNG${C_RESET}                                    ${C_CYAN}│${C_RESET}"
  echo -e "${C_CYAN}│${C_RESET} OS / Arch        : $hedieuhanh ($arch / $lbit-bit)"
  echo -e "${C_CYAN}│${C_RESET} Virtualization   : $virt"
  echo -e "${C_CYAN}│${C_RESET} Uptime           : $up"
  echo -e "${C_CYAN}│${C_RESET} Load Average     : $load"
  echo -e "${C_CYAN}│${C_RESET} IP Address       : $ip"
  [[ -n "$org" ]] && echo -e "${C_CYAN}│${C_RESET} Datacenter       : $org"
  [[ -n "$city" ]] && echo -e "${C_CYAN}│${C_RESET} Location         : $city, $country"
  echo -e "${C_CYAN}╰────────────────────────────────────────────────────────╯${C_RESET}"
}

kiemtra

echo -e "\n${C_YELLOW}================================================================${C_RESET}"
echo -e "${C_GREEN}⚡ KIỂM TRA BĂNG THÔNG & ĐỘ TRỄ MẠNG (NETWORK ROUTING)${C_RESET}"

speed_internet_test() {
  local url=$1
  local nodeName=$2

  # Bóc tách Domain từ URL để đo Ping
  local domain=$(echo "$url" | awk -F/ '{print $3}')

  # Đo Ping (Gửi 2 gói, timeout 2 giây)
  local ping_time=$(ping -c 2 -W 2 "$domain" 2>/dev/null | tail -1 | awk -F '/' '{print $5}')
  local ping_str=""

  # Phân loại độ trễ bằng màu sắc
  if [[ "$ping_time" =~ ^[0-9]+(\.[0-9]+)?$ ]]; then
    local p_val=${ping_time%.*} # Cắt bỏ phần thập phân để so sánh
    if [[ "$p_val" -lt 60 ]]; then
      ping_str="${C_GREEN}(Ping: ${ping_time} ms)${C_RESET}"
    elif [[ "$p_val" -lt 150 ]]; then
      ping_str="${C_YELLOW}(Ping: ${ping_time} ms)${C_RESET}"
    else
      ping_str="${C_RED}(Ping: ${ping_time} ms)${C_RESET}"
    fi
  else
    ping_str="${C_YELLOW}(Ping: N/A)${C_RESET}"
  fi

  # Đo tốc độ Download
  local speedtest=$(wget -4O /dev/null -T15 "$url" 2>&1 | awk '/\/dev\/null/ {speed=$3 $4} END {gsub(/\(|\)/,"",speed); print speed}')

  # THUẬT TOÁN CĂN LỀ UNICODE (Đảm bảo lề thẳng tắp)
  local target_width=30
  local current_len=${#nodeName}
  local pad_len=$((target_width - current_len))
  [[ $pad_len -lt 0 ]] && pad_len=0
  local pad_spaces=$(printf '%*s' "$pad_len" "")

  # Render UI
  if [[ -z "$speedtest" ]]; then
    printf " %s%s: ${C_RED}%-12s${C_RESET} %b\n" "$nodeName" "$pad_spaces" "Lỗi kết nối" "$ping_str"
  else
    printf " %s%s: ${C_CYAN}%-12s${C_RESET} %b\n" "$nodeName" "$pad_spaces" "$speedtest" "$ping_str"
  fi
}

speed() {
  echo -e "\n${C_YELLOW}[ Mạng - Việt Nam ]${C_RESET}"
  speed_internet_test 'http://speedtest1.vtn.com.vn/speedtest/random4000x4000.jpg' 'VNPT, Hà Nội'
  speed_internet_test 'http://speedtest5.vtn.com.vn/speedtest/random4000x4000.jpg' 'VNPT, Đà Nẵng'
  speed_internet_test 'http://speedtest3.vtn.com.vn/speedtest/random4000x4000.jpg' 'VNPT, Hồ Chí Minh'
  speed_internet_test 'http://speedtestkv1a.viettel.vn/speedtest/random4000x4000.jpg' 'Viettel, Hà Nội'
  speed_internet_test 'http://speedtestkv2a.viettel.vn/speedtest/random4000x4000.jpg' 'Viettel, Đà Nẵng'
}

speed
echo -e "${C_YELLOW}================================================================${C_RESET}\n"

check_menu_wptangtoc_active=$1
if [[ $check_menu_wptangtoc_active = "98" ]]; then
  exec /usr/bin/wptangtoc 1
fi
