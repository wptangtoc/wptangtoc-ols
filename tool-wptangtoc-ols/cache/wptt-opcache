#!/bin/bash
# @author: Gia Tuấn
# @website: https://wptangtoc.com
# @since: 2026

function huong_dan {
  Tính Năng Thiết Lập Bật OPcache và Tắt OpCache

  1: Tính Năng Thiết Lập Bật OPcache [Enable OPcache]
  OPcache là quá trình kích hoạt phần mở rộng OPcache trong PHP để nó bắt đầu lưu trữ mã kịch bản PHP đã được biên dịch sẵn [bytecode] vào bộ nhớ RAM.
  OPcache là một công cụ giúp tăng tốc độ thực thi của các ứng dụng PHP một cách đáng kể.

  Mục đích chính:
  * Tăng tốc độ website/ứng dụng: Loại bỏ việc PHP phải biên dịch lại mã nguồn mỗi khi có yêu cầu, thay vào đó sử dụng bytecode đã lưu trong bộ nhớ.
  * Giảm tải cho CPU: Việc biên dịch PHP tốn tài nguyên CPU, OPcache giúp giảm bớt gánh nặng này.

  2: Tính Năng Thiết Lập Tắt OPcache [Disable OPcache]
  Thiết lập tắt OPcache [bằng cách set revalidate_freq=0] khiến hệ thống liên tục kiểm tra file thay đổi, ngăn chặn việc nạp code cũ từ bộ đệm.

  Mục đích chính [thường dùng tạm thời]:
  * Môi trường phát triển [Development]: Đảm bảo code mới nhất luôn được thực thi ngay lập tức sau khi bạn sửa file.
  * Gỡ lỗi [Troubleshooting]: Giúp loại trừ các sự cố do cache gây ra.
}

. /etc/wptt/.wptt.conf
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh
. /etc/wptt/echo-color

clear
echo -e "\n========================================================================="
echo -e "| $quan_ly_cache => $bat_tat_opcache_php"
echo -e "=========================================================================\n"

# Kiểm tra OS một lần duy nhất để dùng chung
if grep -qi "ubuntu" /etc/os-release 2>/dev/null; then
  OS_UBUNTU=1
else
  OS_UBUNTU=0
fi

# ==============================================================================
# QUÉT VÀ HIỂN THỊ TRẠNG THÁI OPCACHE CÁC BẢN PHP
# ==============================================================================
# Sử dụng Globbing cực nhanh thay cho ls | grep
for dir in /usr/local/lsws/lsphp*/; do
  [[ ! -d "$dir" ]] && continue

  php_name=$(basename "$dir") # Kết quả: lsphp81

  # Tương thích ngược bản 74
  if [[ "$php_name" == "lsphp74" && ! -f "$dir/lib64/php/modules/json.so" ]]; then
    continue
  fi

  # Cắt chuỗi nội bộ Bash siêu tốc (Không dùng Perl)
  num_ver=${php_name#lsphp} # 81
  ver_len=${#num_ver}
  phien_ban_php_co_cham="${num_ver:0:$ver_len-1}.${num_ver: -1}" # 8.1
  LSPHP2="PHP $phien_ban_php_co_cham"

  # Xác định đường dẫn php.ini
  if [[ "$OS_UBUNTU" == 1 ]]; then
    duong_dan_php_ini="$dir/etc/php/$phien_ban_php_co_cham/litespeed/php.ini"
  else
    duong_dan_php_ini="$dir/etc/php.ini"
  fi

  if [[ -f "$duong_dan_php_ini" ]]; then
    if grep -q 'opcache.revalidate_freq=0' "$duong_dan_php_ini" 2>/dev/null; then
      echo -e "$he_thong $kiem_tra OPcache $LSPHP2 :\033[1;31m $dang_duoc_tat \033[0m"
    else
      echo -e "$he_thong $kiem_tra OPcache $LSPHP2 :\033[1;32m $dang_duoc_bat \033[0m"
    fi
  fi
done

echo -e "=========================================================================\n"
echo "$nhap $phien_ban PHP $ban_muon $bat/$tat opcache"

# Nạp module chọn tên miền/PHP của bạn
. /etc/wptt/php/tenmien-php

# Chốt chặn nếu không chọn
if [[ "$LSPHP" == "0" || -z "$LSPHP" ]]; then
  exec /etc/wptt/wptt-cache-main 1
fi

# ==============================================================================
# THỰC THI BẬT/TẮT OPCACHE CHO PHIÊN BẢN ĐÃ CHỌN
# ==============================================================================
num_ver=${LSPHP#lsphp}
ver_len=${#num_ver}
phien_ban_php_co_cham="${num_ver:0:$ver_len-1}.${num_ver: -1}"
LSPHP2="PHP $phien_ban_php_co_cham"

if [[ "$OS_UBUNTU" == 1 ]]; then
  duong_dan_php_ini="/usr/local/lsws/$LSPHP/etc/php/$phien_ban_php_co_cham/litespeed/php.ini"
else
  duong_dan_php_ini="/usr/local/lsws/$LSPHP/etc/php.ini"
fi

if [[ -f "$duong_dan_php_ini" ]]; then
  # Kiểm tra trạng thái hiện tại bằng lệnh grep siêu tốc
  if grep -q 'opcache.revalidate_freq=0' "$duong_dan_php_ini" 2>/dev/null; then
    _runing "$bat OPcache $LSPHP2"
    sed -i '/opcache.revalidate_freq/d' "$duong_dan_php_ini"
    echo 'opcache.revalidate_freq=100' >>"$duong_dan_php_ini"
    _rundone "$bat OPcache $LSPHP2"
  else
    _runing "$tat OPcache $LSPHP2"
    sed -i '/opcache.revalidate_freq/d' "$duong_dan_php_ini"
    echo 'opcache.revalidate_freq=0' >>"$duong_dan_php_ini"
    _rundone "$tat OPcache $LSPHP2"
  fi

  # Touch file để OLS tự khởi động lại các tiến trình lsphp của riêng phiên bản này mà không làm gián đoạn web khác
  touch "/usr/local/lsws/admin/tmp/.lsphp_restart.txt" 2>/dev/null
  # Reload OLS (Không dùng restart để đạt Zero-Downtime)
  /usr/local/lsws/bin/lswsctrl reload >/dev/null 2>&1
fi

if [[ "${1:-}" == "98" ]]; then
  exec /etc/wptt/wptt-cache-main 1
fi
