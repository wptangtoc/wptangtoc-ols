#!/bin/bash
# @author: Gia Tuấn
# @website: https://wptangtoc.com
# @since: 2025

function huong_dan() {
  1. Tính Năng Cài Đặt Memcached [Install Memcached]
  Cài đặt Memcached là quá trình thiết lập và chạy phần mềm máy chủ Memcached trên một hệ thống [thường là máy chủ Linux] để các ứng dụng có thể kết nối và sử dụng nó làm một hệ thống lưu trữ đối tượng trong bộ nhớ [in-memory object caching system] hiệu suất cao. 🚀

  Memcached là một công cụ mã nguồn mở, được thiết kế để tăng tốc các ứng dụng web động bằng cách giảm tải cho cơ sở dữ liệu. Nó lưu trữ các cặp key-value [khóa-giá trị] trong RAM, giúp truy xuất dữ liệu cực kỳ nhanh.

  Mục đích chính:
  * Caching dữ liệu: Lưu kết quả của các truy vấn database tốn kém, các lệnh gọi API, hoặc các đoạn HTML đã được render để tăng tốc độ phản hồi của website.
  * Giảm tải cho database: Giảm số lượng truy vấn đọc trực tiếp đến database.
  * Cải thiện hiệu suất ứng dụng: Giúp website/ứng dụng tải nhanh hơn và đáp ứng tốt hơn.
  Kết quả: Sau khi cài đặt, bạn sẽ có một máy chủ Memcached đang chạy, lắng nghe trên cổng unix stocket path: /var/run/memcached/memcached.sock, sẵn sàng để các ứng dụng kết nối và sử dụng cho việc caching.

  2. Tính Năng Hủy Cài Đặt Memcached [Uninstall Memcached]
  Hủy cài đặt Memcached là quá trình gỡ bỏ phần mềm máy chủ Memcached và có thể cả các tệp cấu hình của nó khỏi một hệ thống. 🗑️

  Mục đích chính:
  * Không còn nhu cầu sử dụng: Khi không còn ứng dụng nào cần đến Memcached hoặc chuyển sang giải pháp caching khác.
  * Giải phóng tài nguyên: Thu hồi bộ nhớ RAM [vì Memcached chủ yếu dùng RAM] và một ít không gian đĩa.
  * Cấu hình lại hoặc dọn dẹp hệ thống: Khi ngừng hoạt động máy chủ hoặc thực hiện thay đổi lớn.
  Kết quả: Phần mềm Memcached sẽ được gỡ bỏ khỏi hệ thống, dịch vụ của nó sẽ không còn chạy và các ứng dụng sẽ không thể sử dụng nó để caching nữa.
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null # Nạp thư viện UI Xác nhận

clear
echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}${quan_ly_cache} ➜ Memcached (Object Cache)${C_RESET}"
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

if cat /etc/*release 2>/dev/null | grep -qi "ubuntu"; then
  duong_path_memcached_config="/etc/memcached.conf"
else
  duong_path_memcached_config="/etc/sysconfig/memcached"
fi

is_installed=false
if [[ -f "$duong_path_memcached_config" ]]; then
  is_installed=true
fi

# BẢNG ĐIỀU KHIỂN
echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
if $is_installed; then
  left_text "Trạng thái    : ${C_GREEN}Đang hoạt động (Memcached)${C_RESET}" 2
  left_text "Unix Socket   : ${C_YELLOW}/var/run/memcached/memcached.sock${C_RESET}" 2
else
  left_text "Trạng thái    : ${C_RED}Chưa cài đặt Memcached${C_RESET}" 2
fi
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

# ==============================================================================
# NHÁNH 1: CHƯA CÀI ĐẶT -> TIẾN HÀNH CÀI ĐẶT
# ==============================================================================
if ! $is_installed; then

  if wptt_xac_nhan "Bạn có muốn CÀI ĐẶT Memcached làm Object Cache không?" "" "" "Đồng ý Cài đặt" "Hủy bỏ"; then
    echo ""

    tong_ram_byte=$(awk '/MemTotal/ {print $2}' /proc/meminfo)
    rong_ram_mb=$(echo "scale=0;${tong_ram_byte}/1024" | bc)
    [[ -z "$rong_ram_mb" ]] && rong_ram_mb="2048"

    if ((rong_ram_mb < 1024)); then
      echo -e "${C_RED}❌ Lỗi: ${chi_nen_su_dung_object_cache_toi_thieu_2gb_ram:-Chỉ nên sử dụng Object Cache khi VPS có tối thiểu 2GB RAM!}${C_RESET}"
      sleep 3
      exec /etc/wptt/wptt-cache-main 1
    fi

    _runing "Cài đặt và cấu hình Memcached"
    echo "Kích hoạt Memcached: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log

    # Cài đặt Package cơ bản
    yum install memcached -y >/dev/null 2>&1

    # Cài đặt PHP Extension tương thích OS
    if cat /etc/*release 2>/dev/null | grep -qi "ubuntu"; then
      apt-get update >/dev/null 2>&1
      apt-get install memcached -y >/dev/null 2>&1
      lsphp=($(ls -A /usr/local/lsws | grep -oP '^lsphp\K[0-9]+$'))
      for phpmemcached in "${lsphp[@]}"; do
        apt-get install lsphp${phpmemcached}-memcached -y >/dev/null 2>&1
        apt-get install lsphp${phpmemcached}-igbinary -y >/dev/null 2>&1
      done
    else
      yum install memcached -y --disablerepo="mariadb" >/dev/null 2>&1
      lsphp=($(ls -A /usr/local/lsws | grep -oP '^lsphp\K[0-9]+$'))
      (/etc/wptt/php/kho-luu-tru-litespeed)

      for phpmemcached in "${lsphp[@]}"; do
        if [[ $(dnf list available 2>/dev/null | grep "lsphp${phpmemcached}-pecl-memcached") ]]; then
          yum install lsphp${phpmemcached}-pecl-memcached -y --nogpgcheck --disablerepo="mariadb" >/dev/null 2>&1
          yum install lsphp${phpmemcached}-pecl-igbinary -y --nogpgcheck --disablerepo="mariadb" >/dev/null 2>&1
        else
          url_repo_litespeed=$(
            cat /tmp/php_extension_call_eol 2>/dev/null | grep lsphp${phpmemcached} | grep -oP 'href="\K[^"]+' | grep -v 'debuginfo\|-devel\|-debugsource' | awk '
BEGIN { FS = "/" }
{
    filename = $NF
    split(filename, parts, "-")
    pkg_name = ""
    version = ""
    if (parts[2] == "pecl") {
        pkg_name = parts[1] "-" parts[2] "-" parts[3]
        version = parts[4]
    } else if (parts[2] ~ /^[0-9]+\.[0-9]+/) {
        pkg_name = parts[1]
        version = parts[2]
    } else {
        pkg_name = parts[1] "-" parts[2]
        version = parts[3]
    }
    if (version > versions[pkg_name]) {
        versions[pkg_name] = version
        latest_lines[pkg_name] = $0
    }
}
END {
    PROCINFO["sorted_in"] = "@ind_str_asc"
    for (pkg in latest_lines) {
        print latest_lines[pkg]
    }
}'
          )
          extensions_memcached=(pecl-igbinary pecl-msgpack pecl-memcached)
          for extension in "${extensions_memcached[@]}"; do
            if [[ $(printf "%s\n" "${url_repo_litespeed[@]}" | grep "lsphp${phpmemcached}-${extension}-") ]]; then
              dnf install http://rpms.litespeedtech.com$(printf "%s\n" "${url_repo_litespeed[@]}" | grep "lsphp${phpmemcached}-${extension}-") -y >/dev/null 2>&1
              if [[ -z $(rpm -aq | grep "lsphp${phpmemcached}-${extension}-") ]]; then
                sed -i '/rpms.litespeedtech.com/d' /etc/hosts
                echo $'\n52.55.120.73 rpms.litespeedtech.com\n' >>/etc/hosts
                dnf install http://rpms.litespeedtech.com$(printf "%s\n" "${url_repo_litespeed[@]}" | grep "lsphp${phpmemcached}-${extension}-") -y >/dev/null 2>&1
              fi
            fi
          done
        fi
      done
      rm -f /tmp/php_extension_call_eol
    fi

    # Cấu hình Unix Socket
    mkdir -p /var/run/memcached

    if cat /etc/*release 2>/dev/null | grep -qi "ubuntu"; then
      chown -R memcache:memcache /var/run/memcached
      echo '-d
logfile /var/log/memcached.log
-m 128
-u memcache
-s /var/run/memcached/memcached.sock
-a 0766
-c 10240
-P /var/run/memcached/memcached.pid' >"$duong_path_memcached_config"
      dnf install nc -y >/dev/null 2>&1
    else
      chown -R memcached:memcached /var/run/memcached
      echo "USER=\"memcached\"
MAXCONN=\"10240\"
CACHESIZE=\"128\"
OPTIONS=\"-s '/var/run/memcached/memcached.sock' -a 0766\"" >>"$duong_path_memcached_config"
      semanage permissive -a memcached_t >/dev/null 2>&1
      dnf install nc -y --disablerepo=mariadb >/dev/null 2>&1
    fi

    (/etc/wptt/monit >/dev/null 2>&1)

    systemctl enable memcached.service >/dev/null 2>&1
    systemctl start memcached.service >/dev/null 2>&1
    systemctl restart lsws >/dev/null 2>&1

    _rundone "Cài đặt và cấu hình Memcached"

    # BẢNG BÁO CÁO CÀI ĐẶT
    echo -e "\n${C_GREEN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
    center_text "${C_BOLD_WHITE}HOÀN TẤT CÀI ĐẶT MEMCACHED${C_RESET}"
    echo -e "${C_GREEN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
    left_text "Trạng thái  : ${C_GREEN}Đã kích hoạt thành công${C_RESET}" 2
    left_text "Unix Socket : ${C_CYAN}/var/run/memcached/memcached.sock${C_RESET}" 2
    echo -e "${C_GREEN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

  else
    echo -e "${C_YELLOW}Đã hủy thao tác Cài đặt.${C_RESET}"
  fi

else
  if wptt_xac_nhan "Hệ thống đang chạy Memcached. Bạn có chắc chắn muốn GỠ BỎ không?" "" "" "Đồng ý Gỡ bỏ" "Hủy thao tác"; then
    echo "Huỷ kích hoạt Memcached: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log
    _runing "Gỡ bỏ Memcached"
    systemctl stop memcached.service >/dev/null 2>&1
    systemctl disable memcached.service >/dev/null 2>&1

    if cat /etc/*release 2>/dev/null | grep -qi "ubuntu\|debian"; then
      apt-get remove --purge memcached -y >/dev/null 2>&1
    else
      yum remove memcached -y >/dev/null 2>&1
    fi

    # Gỡ bỏ các Extension PHP liên quan (Giữ nguyên logic của Gia Tuấn)
    if [[ ! -d /usr/local/lsmcd ]]; then
      lsphp=($(ls /usr/local/lsws | grep 'lsphp' | sed 's/^lsphp//g'))
      for phpmemcached in "${lsphp[@]}"; do
        if cat /etc/*release 2>/dev/null | grep -qi "ubuntu\|debian"; then
          apt-get remove --purge lsphp${phpmemcached}-memcached -y >/dev/null 2>&1
        else
          yum remove lsphp${phpmemcached}-pecl-memcached -y >/dev/null 2>&1
          yum remove lsphp${phpmemcached}-memcached -y >/dev/null 2>&1
        fi
      done
    fi

    rm -rf /usr/local/lsws/memcached
    rm -f "$duong_path_memcached_config"

    # Xóa Monit rule
    if cat /etc/*release 2>/dev/null | grep -qi "ubuntu\|debian"; then
      DIR_MONIT="/etc/monit/conf.d"
    else
      DIR_MONIT="/etc/monit.d"
    fi
    FILE_MONIT_RULE="$DIR_MONIT/memcached"
    [[ -f "$FILE_MONIT_RULE" ]] && rm -f "$FILE_MONIT_RULE"

    if systemctl is-active --quiet monit 2>/dev/null; then
      systemctl reload monit >/dev/null 2>&1
    fi

    systemctl restart lsws >/dev/null 2>&1

    _rundone "Gỡ bỏ Memcached"

    # BẢNG BÁO CÁO GỠ BỎ
    echo -e "\n${C_GREEN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
    center_text "${C_BOLD_WHITE}HOÀN TẤT GỠ BỎ MEMCACHED${C_RESET}"
    echo -e "${C_GREEN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
    left_text "Hệ thống đã xóa sạch Memcached và các PHP Extension liên quan." 2
    echo -e "${C_GREEN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

  else
    echo -e "${C_YELLOW}Đã hủy thao tác Gỡ bỏ.${C_RESET}"
  fi
fi

[[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-cache-main 1
