#!/bin/bash
# @author: Gia Tuấn
# @website: https://wptangtoc.com

function huong_dan() {
  Giới thiệu ngắn gọn tính năng Xóa Cache Object Cache trong WPTangToc OLS

  Object Cache [Redis/Valkey/KeyDB] là hệ thống lưu trữ key-value trong bộ nhớ [in-memory data structure store] tốc độ cao, thường được sử dụng để làm cơ chế caching cho website nhằm tăng tốc độ tải trang và giảm tải cho máy chủ Database.

  Tại sao cần xóa cache?
  * Cập nhật nội dung: Khi thay đổi quan trọng trên website, cache có thể vẫn giữ bản cũ. Xóa cache buộc tải lại dữ liệu mới nhất.
  * Gỡ lỗi: Giải quyết sự cố hiển thị do dữ liệu cache bị kẹt hoặc lỗi đồng bộ.
  * Giải phóng RAM: Làm sạch bộ nhớ đệm rác tích tụ lâu ngày.

  Tính năng này tự động nhận diện Engine đang chạy [Valkey, KeyDB, Redis], kết nối an toàn qua Unix Socket và dọn sạch dữ liệu mà không làm gián đoạn máy chủ.
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null # Nạp thư viện UI Xác nhận

echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}${quan_ly_cache} ➜ $xoa_cache_redis/ KeyDB / Valkey)${C_RESET}"
echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

ACTIVE_CACHE=""
CLI_TOOL=""
SOCKET_PATH=""

if systemctl is-active --quiet valkey 2>/dev/null; then
  ACTIVE_CACHE="Valkey"
  CLI_TOOL="valkey-cli"
  SOCKET_PATH="/var/run/valkey/valkey.sock"
elif systemctl is-active --quiet keydb 2>/dev/null; then
  ACTIVE_CACHE="KeyDB"
  CLI_TOOL="keydb-cli"
  SOCKET_PATH="/var/run/keydb/keydb.sock"
elif systemctl is-active --quiet redis 2>/dev/null; then
  ACTIVE_CACHE="Redis"
  CLI_TOOL="redis-cli"
  SOCKET_PATH="/var/run/redis/redis.sock"
fi

if [[ -z "$ACTIVE_CACHE" ]]; then
  echo "$ban_chua_kich_hoat Object Cache (Valkey/KeyDB/Redis)"
  sleep 3
  check_menu_wptangtoc_active=$1
  if [[ $check_menu_wptangtoc_active = "98" ]]; then
    exec /etc/wptt/wptt-cache-main 1
  fi
  return 2>/dev/null || exit 1
fi

if [[ -S "$SOCKET_PATH" ]]; then
  PING_CMD="$CLI_TOOL -s $SOCKET_PATH ping"
  FLUSH_CMD="$CLI_TOOL -s $SOCKET_PATH flushall"
else
  # Fallback nếu ai đó lỡ cấu hình TCP thủ công
  PING_CMD="$CLI_TOOL ping"
  FLUSH_CMD="$CLI_TOOL flushall"
fi

if [ ! "$($PING_CMD 2>/dev/null)" = "PONG" ]; then
  clear
  echo -e "${C_RED}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
  left_text "Dịch vụ $ACTIVE_CACHE $dang_gap_su_co (Không phản hồi PING)"
  echo -e "${C_RED}╰──────────────────────────────────────────────────────────────────────────────╯${C_RESET}\n"
  check_menu_wptangtoc_active=$1
  if [[ $check_menu_wptangtoc_active = "98" ]]; then
    exec /etc/wptt/wptt-cache-main 1
  fi
  return 2>/dev/null || exit
fi

. /etc/wptt/echo-color
_runing "$don_dep cache $ACTIVE_CACHE"

# Thực thi lệnh xả RAM
$FLUSH_CMD >/dev/null 2>&1

_rundone "$don_dep cache $ACTIVE_CACHE"

check_menu_wptangtoc_active=$1
if [[ $check_menu_wptangtoc_active = "98" ]]; then
  exec /etc/wptt/wptt-cache-main 1
fi
