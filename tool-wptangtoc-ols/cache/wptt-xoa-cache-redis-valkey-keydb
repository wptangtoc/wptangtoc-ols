#!/bin/bash
# @author: Gia Tuấn
# @website: https://wptangtoc.com

function huong_dan() {
  Tính năng xóa Object Cache là công cụ dọn dẹp bộ nhớ đệm RAM [Redis/Valkey/KeyDB] của website.

  Giải thích đơn giản:
  * Object Cache lưu trữ các truy vấn cơ sở dữ liệu [Database] trực tiếp lên RAM, giúp giảm tải cho MariaDB/MySQL và tăng tốc độ xử lý PHP.
  * Tại sao cần xóa? Khi bạn cập nhật dữ liệu lớn, đổi theme, hoặc website bị kẹt dữ liệu cũ, việc xóa Object Cache sẽ ép hệ thống phải truy vấn lại Database để lấy dữ liệu mới nhất.
}

. /etc/wptt/echo-color

NAME=$1
if [[ "$NAME" == "98" ]]; then
  NAME=""
fi

. /etc/wptt/.wptt.conf

if [[ -z "$ngon_ngu" ]]; then
  ngon_ngu='vi'
fi
. /etc/wptt/lang/$ngon_ngu.sh

# ==============================================================================
# 1. KIỂM TRA TRẠNG THÁI VÀ ĐỊNH DANH ENGINE (REDIS / VALKEY / KEYDB)
# ==============================================================================
ACTIVE_CACHE=""
CLI_TOOL=""
SOCKET_PATH=""

if systemctl is-active --quiet valkey 2>/dev/null; then
  ACTIVE_CACHE="Valkey"
  CLI_TOOL="valkey-cli"
  SOCKET_PATH="/var/run/valkey/valkey.sock"
elif systemctl is-active --quiet keydb 2>/dev/null; then
  ACTIVE_CACHE="KeyDB"
  CLI_TOOL="keydb-cli"
  SOCKET_PATH="/var/run/keydb/keydb.sock"
elif systemctl is-active --quiet redis 2>/dev/null; then
  ACTIVE_CACHE="Redis"
  CLI_TOOL="redis-cli"
  SOCKET_PATH="/var/run/redis/redis.sock"
fi

if [[ -z "$ACTIVE_CACHE" ]]; then
  echo -e "\n${C_YELLOW}Hệ thống chưa kích hoạt Object Cache (Valkey/KeyDB/Redis).${C_RESET}"
  sleep 2
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-cache-main 1
  return 2>/dev/null || exit 1
fi

# Thiết lập lệnh Ping và Flush dựa trên Socket hoặc TCP
if [[ -S "$SOCKET_PATH" ]]; then
  PING_CMD="$CLI_TOOL -s $SOCKET_PATH ping"
  FLUSH_CMD="$CLI_TOOL -s $SOCKET_PATH flushall"
else
  PING_CMD="$CLI_TOOL ping"
  FLUSH_CMD="$CLI_TOOL flushall"
fi

# ==============================================================================
# 2. KHỞI TẠO GIAO DIỆN VÀ MENU LỰA CHỌN
# ==============================================================================
if [[ -z "$NAME" ]]; then
  echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_BOLD_WHITE}$quan_ly_cache ➜ Xóa Object Cache ($ACTIVE_CACHE)${C_RESET}"
  echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"
  . /etc/wptt/tenmien-them-lua-chon-tat-ca-website-by-wordpress
  lua_chon_NAME "xóa Object Cache"
fi

# ==============================================================================
# 3. NHÁNH THỰC THI HÀNG LOẠT (TẤT CẢ WEBSITE) => DÙNG FLUSHALL SIÊU TỐC
# ==============================================================================
if [[ "$NAME" == 'Tất cả website' ]]; then
  # $tong_so_web được gọi từ thư viện tenmien

  print_border_top
  center_text "${C_YELLOW}DASHBOARD THAO TÁC HÀNG LOẠT${C_RESET}"
  print_border_mid
  left_text "▪ Tổng số   : ${C_GREEN}$tong_so_web website (Toàn bộ Server)${C_RESET}" 2
  left_text "▪ Nhiệm vụ  : ${C_GREEN}Clear All RAM $ACTIVE_CACHE (FlushAll)${C_RESET}" 2
  print_border_bot
  echo ""

  # Kiểm tra sống còn trước khi nổ bom
  if [ "$($PING_CMD 2>/dev/null)" = "PONG" ]; then
    _runing "$don_dep toàn bộ bộ nhớ Cache $ACTIVE_CACHE"
    
    # Kích nổ bom hạt nhân dọn sạch RAM trong 1 nốt nhạc
    $FLUSH_CMD >/dev/null 2>&1
    
    _rundone "$don_dep toàn bộ bộ nhớ Cache $ACTIVE_CACHE"
  else
    echo -e "${C_RED}❌ Dịch vụ $ACTIVE_CACHE không phản hồi, không thể dọn dẹp!${C_RESET}"
    sleep 2
  fi

  check_menu_wptangtoc_active=$1
  if [[ "$check_menu_wptangtoc_active" == "98" ]]; then
    exec /etc/wptt/wptt-cache-main 1
  fi
  return 2>/dev/null || exit
fi

# Chốt chặn thoát an toàn
if [[ "$NAME" == "0" || -z "$NAME" ]]; then
  exec /etc/wptt/wptt-cache-main 1
fi

# ==============================================================================
# 4. NHÁNH THỰC THI ĐỘC LẬP (MỘT WEBSITE) => DÙNG WP-CLI BẮN TỈA
# ==============================================================================
# Đảm bảo Engine vẫn sống trước khi gọi WP-CLI
if [ "$($PING_CMD 2>/dev/null)" != "PONG" ]; then
  echo -e "\n${C_RED}❌ Dịch vụ $ACTIVE_CACHE không phản hồi. Vui lòng kiểm tra lại.${C_RESET}"
  sleep 2
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-cache-main 1
  exit 1
fi

_runing "$don_dep Object Cache cho $NAME"

. /etc/wptt/vhost/.$NAME.conf 2>/dev/null
. /etc/wptt/php/php-cli-domain-config "$NAME" 2>/dev/null
WP_PATH="/usr/local/lsws/$NAME/html"

sudo -u "$User_name_vhost" /usr/local/lsws/lsphp${phien_ban_php_domain_thuc_thi}/bin/php /usr/local/bin/wp cache flush --path="$WP_PATH" >/dev/null 2>&1

_rundone "$don_dep Object Cache cho $NAME"

check_menu_wptangtoc_active=$1
if [[ "$check_menu_wptangtoc_active" == "98" ]]; then
  exec /etc/wptt/wptt-cache-main 1
fi
