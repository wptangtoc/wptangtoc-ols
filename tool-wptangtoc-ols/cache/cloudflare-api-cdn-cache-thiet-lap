#!/bin/bash

function huong_dan() {
  Việc sử dụng API của Cloudflare để xóa cache [bộ nhớ đệm] CDN là một tính năng mạnh mẽ và linh hoạt, cho phép bạn tự động hóa và kiểm soát chính xác việc làm mới nội dung trên mạng lưới của Cloudflare.

  Dưới đây là giới thiệu về tính năng này:

  Tại sao cần xóa cache CDN qua API?

  Khi bạn cập nhật nội dung trên máy chủ gốc [origin server], Cloudflare CDN có thể vẫn đang phục vụ phiên bản cũ của nội dung đó từ các máy chủ biên của họ để tăng tốc độ tải trang cho người dùng. Việc xóa cache sẽ buộc Cloudflare lấy phiên bản mới nhất từ máy chủ gốc của bạn.

  Sử dụng API cho phép bạn:
  * Tự động hóa: Tích hợp việc xóa cache vào quy trình triển khai [deployment pipeline] của bạn. Ví dụ, sau khi cập nhật mã nguồn hoặc nội dung, một script có thể tự động gọi API để xóa cache liên quan.
  * Kiểm soát chi tiết: Quản lý việc làm mới nội dung một cách chính xác, đảm bảo người dùng luôn thấy được phiên bản mới nhất khi cần thiết.
  * Tích hợp với các hệ thống khác: Kết nối với hệ thống quản lý wptangtoc ols.

  Bằng cách tận dụng API của Cloudflare, bạn có thể nâng cao đáng kể hiệu quả quản lý cache cho website của mình, đảm bảo nội dung luôn được cập nhật và trải nghiệm người dùng được tối ưu.
}
# ==============================================================================
# NẠP CẤU HÌNH, NGÔN NGỮ VÀ MÀU SẮC
# ==============================================================================
. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null # Nạp thư viện UI Xác nhận

clear
echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}${quan_ly_cache} ➜ Thiết lập API Cache Cloudflare CDN${C_RESET}"
echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

mkdir -p /etc/wptt/cloudflare-cdn-cache

# ==============================================================================
# HÀM MENU LỌC TRẠNG THÁI THIẾT LẬP (UX BO CONG)
# ==============================================================================
function lua_chon_NAME() {
  unset NAME selects
  selects=()
  local box_inner_width=${box_inner_width:-71}

  if [ "$(ls -At /etc/wptt/vhost 2>/dev/null | grep -v '^\.\.conf$' | sort -uV)" ]; then
    for entry in $(ls -A /etc/wptt/vhost | grep -v '^\.\.conf$' | sort -uV); do
      local dom=$(echo "$entry" | sed 's/^.//' | sed 's/.conf//')
      if [[ "$dom" == ?*.?* ]]; then
        # Fix lỗi biến của bản gốc: Dùng dom thay vì domain
        if [[ -f "/etc/wptt/cloudflare-cdn-cache/.wptt-$dom.conf" ]]; then
          selects+=("$dom|1") # 1 = Đã thiết lập
        else
          selects+=("$dom|0") # 0 = Chưa thiết lập
        fi
      fi
    done
  fi

  if [[ ${#selects[@]} -eq 0 ]]; then
    echo -e "${C_YELLOW}⚠️ Hệ thống chưa có website nào được khởi tạo!${C_RESET}"
    sleep 3
    exec /etc/wptt/wptt-cache-main 1
  fi

  # Render Khung Bo Cong
  echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
  local title_text="Lựa chọn Website để thiết lập/gỡ bỏ API Cloudflare:"
  local len=$(echo -n "$title_text" | awk '{print length($0)}')
  local pad_r=$((box_inner_width - len - 2))
  [[ $pad_r -lt 0 ]] && pad_r=0
  echo -e "${C_CYAN}│${C_RESET}  ${C_YELLOW}${title_text}${C_RESET}$(printf '%*s' "$pad_r" "")${C_CYAN}│${C_RESET}"

  local line_len=$((len + 3))
  local pad_line_r=$((box_inner_width - line_len))
  [[ $pad_line_r -lt 0 ]] && pad_line_r=0
  local short_line=$(printf "%${line_len}s" "" | sed 's/ /─/g')
  echo -e "${C_CYAN}├${short_line}$(printf '%*s' "$pad_line_r" "")│${C_RESET}"

  local i=1
  for item in "${selects[@]}"; do
    local dom=$(echo "$item" | cut -d'|' -f1)
    local stt=$(echo "$item" | cut -d'|' -f2)

    if [[ "$stt" == "1" ]]; then
      local item_text=$(printf "  ${C_CYAN}%3d)${C_RESET} ${C_BOLD_WHITE}%-30s${C_RESET} ${C_GREEN}[Đã thiết lập]${C_RESET}" "$i" "$dom")
      local clean_text=$(printf "  %3d) %-30s [Đã thiết lập]" "$i" "$dom")
    else
      local item_text=$(printf "  ${C_CYAN}%3d)${C_RESET} ${C_BOLD_WHITE}%-30s${C_RESET} ${C_YELLOW}[Chưa thiết lập]${C_RESET}" "$i" "$dom")
      local clean_text=$(printf "  %3d) %-30s [Chưa thiết lập]" "$i" "$dom")
    fi

    local item_len=$(echo -n "$clean_text" | awk '{print length($0)}')
    local pad=$((box_inner_width - item_len))
    [[ $pad -lt 0 ]] && pad=0
    echo -e "${C_CYAN}│${C_RESET}${item_text}$(printf '%*s' "$pad" "")${C_CYAN}│${C_RESET}"
    ((i++))
  done
  echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯${C_RESET}"

  local fzf_installed=false
  if command -v fzf &>/dev/null; then
    fzf_installed=true
    PROMPT_TEXT="Nhập lựa chọn (1-${#selects[@]}) [00=Tìm nhanh] [0=${exit_thoat:-Thoát}]: "
  else
    PROMPT_TEXT="Nhập lựa chọn (1-${#selects[@]}) [0=${exit_thoat:-Thoát}]: "
  fi

  while true; do
    echo -en "${C_CYAN}${PROMPT_TEXT}${C_RESET}"
    if ! read -r REPLY; then exit 1; fi
    REPLY=$(echo "$REPLY" | tr -d ' ' | tr '[:upper:]' '[:lower:]')

    case "$REPLY" in
    0)
      echo -e "\n${C_GREEN}Đang thoát...${C_RESET}"
      NAME="0"
      return 0
      ;;
    00)
      if $fzf_installed; then
        local selected_item=$(printf '%s\n' "${selects[@]}" | nl -w 3 -s ': ' | fzf --prompt="Tìm website >> " --height=40% --border=rounded --color=border:red --cycle --reverse)
        local dom=$(echo "$selected_item" | sed 's/^[[:space:]]*[0-9]\+\:[[:space:]]*//' | cut -d'|' -f1)
        if [[ -n "$dom" ]]; then
          NAME="$dom"
          return 0
        else echo -e "${C_YELLOW}Đã hủy chọn. Vui lòng chọn lại.${C_RESET}"; fi
      else
        echo -e "${C_RED}Lỗi: FZF chưa cài đặt.${C_RESET}"
      fi
      ;;
    *)
      if [[ "$REPLY" =~ ^[0-9]+$ ]] && [ "$REPLY" -ge 1 ] && [ "$REPLY" -le ${#selects[@]} ]; then
        local action_index=$((REPLY - 1))
        NAME=$(echo "${selects[$action_index]}" | cut -d'|' -f1)
        return 0
      else
        echo -e "\n${C_RED}❌ Lựa chọn không hợp lệ! Vui lòng chọn lại.${C_RESET}"
      fi
      ;;
    esac
  done
}

lua_chon_NAME

[[ "$NAME" == "0" || -z "$NAME" ]] && {
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-cache-main 1
  return 2>/dev/null || exit
}

pathcheck="/etc/wptt/vhost/.$NAME.conf"
if [[ ! -f "$pathcheck" ]]; then
  echo -e "\n${C_RED}❌ Tên miền không tồn tại trên hệ thống này!${C_RESET}"
  sleep 3
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-cache-main 1
  return 2>/dev/null || exit
fi

# ==============================================================================
# XỬ LÝ LOGIC (CÀI ĐẶT MỚI HOẶC GỠ BỎ)
# ==============================================================================
echo ""

if [[ ! -f "/etc/wptt/cloudflare-cdn-cache/.wptt-$NAME.conf" ]]; then
  # ---------------------------------------------------------
  # NHÁNH 1: CHƯA THIẾT LẬP -> TIẾN HÀNH SETUP
  # ---------------------------------------------------------
  _runing "Đang kiểm tra kết nối Cloudflare Proxy cho website $NAME..."
  TRACE_OUTPUT=$(curl -Is --connect-timeout 5 --max-time 10 "https://$NAME/cdn-cgi/trace" 2>/dev/null)

  # Fix lỗi grep -q của bản gốc
  if ! echo "$TRACE_OUTPUT" | grep -qi 'cloudflare\|cf-ray'; then
    _runloi "Kiểm tra Cloudflare thất bại"
    echo -e "${C_RED}❌ Lỗi: Website $NAME hiện KHÔNG hoạt động qua Proxy của Cloudflare (Đám mây cam).${C_RESET}"
    echo -e "${C_YELLOW}Tính năng này yêu cầu website phải bật Proxy Cloudflare để hoạt động.${C_RESET}"
    sleep 3
    exec /etc/wptt/wptt-cache-main 1
  fi
  _rundone "Website đã kết nối Cloudflare CDN"
  echo ""

  echo -e "${C_YELLOW}Hướng dẫn lấy API:${C_RESET} Truy cập https://dash.cloudflare.com/profile/api-tokens ➜ Xem mục ${C_BOLD_WHITE}Global API Key${C_RESET}"

  echo -en "${C_CYAN}Nhập Email đăng nhập Cloudflare [0=Thoát]: ${C_RESET}"
  read -r email_cloudflare
  [[ "$email_cloudflare" == "0" || -z "$email_cloudflare" ]] && exec /etc/wptt/wptt-cache-main 1

  echo -en "${C_CYAN}Nhập Global API Key [0=Thoát]: ${C_RESET}"
  read -r KEY
  [[ "$KEY" == "0" || -z "$KEY" ]] && exec /etc/wptt/wptt-cache-main 1

  echo ""
  _runing "Đang xác thực thông tin và lấy Zone ID từ Cloudflare..."
  echo "Thiết lập Cloudflare CDN xoá cache website $NAME : $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log

  echo "dns_cloudflare_email = $email_cloudflare
dns_cloudflare_api_key = $KEY" >"/etc/wptt/cloudflare-cdn-cache/.wptt-$NAME.conf"

  chmod 700 -R /etc/wptt/cloudflare-cdn-cache
  chmod 400 "/etc/wptt/cloudflare-cdn-cache/.wptt-$NAME.conf"

  function dns_coudflare_xac_thuc_zones() {
    local check_domain="$1"
    curl -s -X GET "https://api.cloudflare.com/client/v4/zones?name=$check_domain" \
      -H "X-Auth-Email: $email_cloudflare" \
      -H "X-Auth-Key: $KEY" \
      -H "Content-Type: application/json" |
      python3 -c "import sys,json;data=json.loads(sys.stdin.read()); print(data['result'][0]['id'] if 'result' in data and data['result'] else '')" >/tmp/check-dns-cloudflare 2>&1
  }

  # Logic tìm kiếm Zone thông minh
  dns_coudflare_xac_thuc_zones "$NAME"

  # Nếu không tìm thấy Zone của Subdomain, thử lấy Zone của Root domain
  if [[ -z $(cat /tmp/check-dns-cloudflare 2>/dev/null) ]]; then
    parent_domain=$(echo "$NAME" | cut -d. -f2-)
    if [[ "$parent_domain" == *.* ]]; then
      dns_coudflare_xac_thuc_zones "$parent_domain"
    fi
  fi

  if [[ -n $(cat /tmp/check-dns-cloudflare 2>/dev/null) ]]; then
    _rundone "Xác thực API Cloudflare thành công"

    echo -e "\n${C_GREEN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
    center_text "${C_BOLD_WHITE}HOÀN TẤT THIẾT LẬP CLOUDFLARE CDN CACHE${C_RESET}"
    echo -e "${C_GREEN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
    left_text "Website thao tác : ${C_YELLOW}$NAME${C_RESET}" 2
    left_text "Trạng thái mới   : Hệ thống sẽ tự động quét và xóa cache Cloudflare" 2
    left_text "                   mỗi khi bạn sử dụng Menu Xóa Cache của WPTangToc." 2
    echo -e "${C_GREEN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"
  else
    rm -f "/etc/wptt/cloudflare-cdn-cache/.wptt-$NAME.conf"
    _runloi "Xác thực thông tin API thất bại"
    echo -e "${C_RED}❌ Lỗi: Email hoặc Global API Key không chính xác, hoặc không có quyền truy cập vào Domain này.${C_RESET}"
    echo -e "Vui lòng kiểm tra lại thông tin và thử lại sau."
  fi

else
  # ---------------------------------------------------------
  # NHÁNH 2: ĐÃ THIẾT LẬP -> HỎI GỠ BỎ
  # ---------------------------------------------------------
  if wptt_xac_nhan "Website này đang được tự động xóa cache CDN. Bạn có muốn GỠ BỎ thiết lập này không?" "${C_BOLD_WHITE}Website:${C_RESET} $NAME" "" "Đồng ý Gỡ bỏ" "Hủy thao tác"; then
    echo ""
    _runing "Đang xóa bỏ cấu hình API Cloudflare cho $NAME..."
    rm -f "/etc/wptt/cloudflare-cdn-cache/.wptt-$NAME.conf"
    _rundone "Đã gỡ bỏ thiết lập thành công"

    echo -e "\n${C_GREEN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
    center_text "${C_BOLD_WHITE}HOÀN TẤT GỠ BỎ CẤU HÌNH API${C_RESET}"
    echo -e "${C_GREEN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
    left_text "Kể từ giờ, WPTangToc OLS sẽ không can thiệp vào cache của" 2
    left_text "Cloudflare cho website ${C_YELLOW}$NAME${C_RESET} nữa." 2
    echo -e "${C_GREEN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"
  else
    echo -e "${C_YELLOW}Đã hủy thao tác gỡ bỏ.${C_RESET}"
  fi
fi

[[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-cache-main 1
