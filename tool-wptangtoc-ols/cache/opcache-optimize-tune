#!/bin/bash
# @author: Gia Tuấn
# @website: https://wptangtoc.com
# @since: 2026
# ==========================================
# AUTO-TUNE PHP OPCACHE & JIT
# ==========================================

# 1. Lấy tổng RAM (Tối ưu Zero-forking đọc thẳng từ /proc/meminfo)
while read -r name value unit; do
  if [[ "$name" == "MemTotal:" ]]; then
    TOTAL_RAM_MB=$((value / 1024))
    break
  fi
done </proc/meminfo

if [ "$TOTAL_RAM_MB" -le 1200 ]; then
  OPCACHE_MEM="64"
  JIT_BUFFER="0M"      # Tắt JIT cho máy siêu yếu (1GB) để tiết kiệm RAM
  REALPATH_SIZE="512K" # VPS 1GB: 512K là quá đủ cho 1000+ file
elif [ "$TOTAL_RAM_MB" -le 2500 ]; then
  OPCACHE_MEM="128"
  JIT_BUFFER="64M"      # VPS 2GB: OPcache 128MB (JIT ăn 64MB, còn 64MB lưu file)
  REALPATH_SIZE="1024K" # VPS 2GB: 1MB
elif [ "$TOTAL_RAM_MB" -le 4500 ]; then
  OPCACHE_MEM="256"
  JIT_BUFFER="128M"     # VPS 4GB
  REALPATH_SIZE="2048K" # VPS to: 2MB (Mức trần thực tế, 4M là hơi quá tay)
else
  OPCACHE_MEM="512"
  JIT_BUFFER="256M"     # Mức trần cho VPS >= 8GB
  REALPATH_SIZE="2048K" # VPS to: 2MB (Mức trần thực tế)
fi

# 2. KIỂM TRA OS MỘT LẦN DUY NHẤT Ở NGOÀI VÒNG LẶP
if grep -qi "ubuntu" /etc/os-release 2>/dev/null; then
  OS_UBUNTU=1
else
  OS_UBUNTU=0
fi

# 3. QUÉT VÀ CẤU HÌNH (Sử dụng Globbing siêu tốc)
shopt -s nullglob
for dir in /usr/local/lsws/lsphp*/; do
  [[ ! -d "$dir" ]] && continue

  # Cắt tên thư mục thuần Bash (VD: lsphp81)
  php_dir="${dir%/}"
  php_dir="${php_dir##*/}"

  # Lấy phần số của phiên bản (VD: 81)
  version_num="${php_dir#lsphp}"

  # Tạo chuỗi có dấu chấm cho Ubuntu (VD: 8.1)
  ver_len=${#version_num}
  phien_ban_php_co_cham="${version_num:0:$ver_len-1}.${version_num: -1}"

  # Đường dẫn chuẩn xác tới file php.ini
  if [[ "$OS_UBUNTU" == 1 ]]; then
    php_ini_path="/usr/local/lsws/$php_dir/etc/php/$phien_ban_php_co_cham/litespeed/php.ini"
  else
    php_ini_path="/usr/local/lsws/$php_dir/etc/php.ini"
  fi

  if [[ -f "$php_ini_path" ]]; then

    # --- ÁP DỤNG OPCACHE & JIT ---

    # Gom 7 lệnh SED cũ thành 1 lệnh duy nhất (Tối ưu I/O ổ cứng cực mạnh)
    sed -i -E '/^(opcache\.memory_consumption|opcache\.interned_strings_buffer|opcache\.max_accelerated_files|realpath_cache_size|realpath_cache_ttl|opcache\.jit|opcache\.jit_buffer_size)=/d' "$php_ini_path"

    # Chuẩn bị khối cấu hình chung
    CONFIG_BLOCK="opcache.memory_consumption=$OPCACHE_MEM
opcache.interned_strings_buffer=16
opcache.max_accelerated_files=16229
realpath_cache_size=${REALPATH_SIZE}
realpath_cache_ttl=7200"

    # Xử lý JIT (Chỉ cho PHP >= 8.0)
    if ((version_num >= 80)); then
      if [[ "$JIT_BUFFER" != "0M" ]]; then
        CONFIG_BLOCK="$CONFIG_BLOCK
opcache.jit=tracing
opcache.jit_buffer_size=$JIT_BUFFER"
        echo "Đã Tune OPcache=${OPCACHE_MEM}M & JIT=${JIT_BUFFER} cho $php_dir" >>/var/log/wptangtoc-ols.log
      else
        echo "Đã Tune OPcache=${OPCACHE_MEM}M (Tắt JIT vì RAM thấp) cho $php_dir" >>/var/log/wptangtoc-ols.log
      fi
    else
      echo "Đã Tune OPcache=${OPCACHE_MEM}M (Bỏ qua JIT vì bản cũ) cho $php_dir" >>/var/log/wptangtoc-ols.log
    fi

    # Nối toàn bộ cấu hình vào file 1 lần duy nhất
    echo "$CONFIG_BLOCK" >>"$php_ini_path"
  fi
done
shopt -u nullglob

/usr/local/lsws/bin/lswsctrl reload >/dev/null 2>&1
