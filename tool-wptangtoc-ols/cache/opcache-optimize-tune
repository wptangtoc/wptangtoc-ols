#!/bin/bash
# @author: Gia Tuấn
# @website: https://wptangtoc.com
# @since: 2026

# 1. Lấy tổng RAM (Tối ưu Zero-forking đọc thẳng từ /proc/meminfo)
while read -r name value unit; do
  if [[ "$name" == "MemTotal:" ]]; then
    TOTAL_RAM_MB=$((value / 1024))
    break
  fi
done </proc/meminfo

# BẢNG PHÂN BỔ TÀI NGUYÊN (Ưu tiên hiệu suất tối đa)
if [ "$TOTAL_RAM_MB" -le 1200 ]; then
  OPCACHE_MEM="64"
  JIT_BUFFER="0M" # BẮT BUỘC TẮT JIT cho máy siêu yếu (1GB) để giữ mạng sống cho Database
  REALPATH_SIZE="512K"
elif [ "$TOTAL_RAM_MB" -le 2500 ]; then
  OPCACHE_MEM="128"
  JIT_BUFFER="64M" # VPS 2GB: Bật JIT 64MB
  REALPATH_SIZE="1024K"
elif [ "$TOTAL_RAM_MB" -le 4500 ]; then
  OPCACHE_MEM="256"
  JIT_BUFFER="128M" # VPS 4GB: Bật JIT 128MB
  REALPATH_SIZE="2048K"
else
  OPCACHE_MEM="512"
  JIT_BUFFER="256M" # VPS >= 8GB: Bật JIT 256MB (Max Speed)
  REALPATH_SIZE="2048K"
fi

# 2. KIỂM TRA OS MỘT LẦN DUY NHẤT
if grep -qi "ubuntu" /etc/os-release 2>/dev/null; then
  OS_UBUNTU=1
else
  OS_UBUNTU=0
fi

# 3. QUÉT VÀ BƠM CẤU HÌNH
shopt -s nullglob
for dir in /usr/local/lsws/lsphp*/; do
  [[ ! -d "$dir" ]] && continue

  php_dir="${dir%/}"
  php_dir="${php_dir##*/}"
  version_num="${php_dir#lsphp}"
  ver_len=${#version_num}
  phien_ban_php_co_cham="${version_num:0:$ver_len-1}.${version_num: -1}"

  if [[ "$OS_UBUNTU" == 1 ]]; then
    php_ini_path="/usr/local/lsws/$php_dir/etc/php/$phien_ban_php_co_cham/litespeed/php.ini"
  else
    php_ini_path="/usr/local/lsws/$php_dir/etc/php.ini"
  fi

  if [[ -f "$php_ini_path" ]]; then

    # ==============================================================
    # TRẠM KIỂM SOÁT QUYỀN PHỦ QUYẾT CỦA NGƯỜI DÙNG
    # ==============================================================
    USER_DISABLED_JIT=0
    # Quét xem khách có DÙNG MENU wptt-jit ép JIT về 0 không?
    if grep -qE '^opcache\.jit_buffer_size[ \t]*=[ \t]*0' "$php_ini_path" 2>/dev/null; then
      USER_DISABLED_JIT=1
    fi

    # Dọn dẹp cấu hình rác cũ bằng 1 đường kiếm
    sed -i -E '/^(opcache\.memory_consumption|opcache\.interned_strings_buffer|opcache\.max_accelerated_files|realpath_cache_size|realpath_cache_ttl|opcache\.jit|opcache\.jit_buffer_size)=/d' "$php_ini_path"

    # Lõi cấu hình "Bê tông cốt thép"
    CONFIG_BLOCK="opcache.memory_consumption=$OPCACHE_MEM
opcache.interned_strings_buffer=16
opcache.max_accelerated_files=16229
realpath_cache_size=${REALPATH_SIZE}
realpath_cache_ttl=7200"

    # XỬ LÝ JIT COMPILER (Từ PHP 8.0 trở lên)
    if ((version_num >= 80)); then
      if [[ "$USER_DISABLED_JIT" == "1" ]]; then
        # KHÁCH GHÉT JIT: Tôn trọng quyền của khách, khóa JIT lại
        CONFIG_BLOCK="$CONFIG_BLOCK
opcache.jit_buffer_size=0"
        echo "Đã Tune OPcache=${OPCACHE_MEM}M (Tôn trọng User: Giữ TẮT JIT) cho $php_dir" >>/var/log/wptangtoc-ols.log

      elif [[ "$JIT_BUFFER" != "0M" ]]; then
        # BẬT MẶC ĐỊNH (DEFAULT ON): Đẩy max tốc độ
        CONFIG_BLOCK="$CONFIG_BLOCK
opcache.jit=tracing
opcache.jit_buffer_size=$JIT_BUFFER"
        echo "Đã Tune OPcache=${OPCACHE_MEM}M & JIT=${JIT_BUFFER} (Mặc định BẬT) cho $php_dir" >>/var/log/wptangtoc-ols.log

      else
        # VPS 1GB: Bất khả kháng, phải tắt để bảo vệ Server
        CONFIG_BLOCK="$CONFIG_BLOCK
opcache.jit_buffer_size=0"
        echo "Đã Tune OPcache=${OPCACHE_MEM}M (Ép tắt JIT vì VPS <= 1GB RAM) cho $php_dir" >>/var/log/wptangtoc-ols.log
      fi
    else
      # PHP 7.x
      echo "Đã Tune OPcache=${OPCACHE_MEM}M (Bỏ qua JIT do PHP cũ) cho $php_dir" >>/var/log/wptangtoc-ols.log
    fi

    # Ghi toàn bộ vào file
    echo "$CONFIG_BLOCK" >>"$php_ini_path"
  fi
done
shopt -u nullglob

/usr/local/lsws/bin/lswsctrl reload >/dev/null 2>&1
