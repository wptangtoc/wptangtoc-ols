#!/bin/bash
# ==============================================================================
# HÀM XÓA OPCACHE WEBSITE KHÔNG GÂY DOWNTIME (ZERO DOWNTIME)
# Gọi hàm: wptt_xoa_opcache "wptangtoc.com"
# sử dụng bằng thư viện PHP rồi curl nó hoạt động tuyệt vời hơn dùng wp cli opcache_reset, nó bao hàm tiến trình lsphp exec hơn
# ==============================================================================
function wptt_xoa_opcache() {
    local domain="$1"
    local web_root="/usr/local/lsws/$domain/html"

    if [[ ! -d "$web_root" ]]; then
        echo -e "${C_RED}Lỗi: Không tìm thấy thư mục của domain $domain${C_RESET}"
        return 1
    fi

	if [[ ! -f $web_root/index.php ]];then #nếu website không sử dụng mã nguồn index.php thì chả cần phải xoá opcache làm gì
        return 1
	fi

    # 1. Tạo chuỗi bí mật ngẫu nhiên (16 ký tự) để chống bị dò rỉ file
    local secret_key=$(tr -dc 'a-zA-Z0-9' < /dev/urandom | head -c 16)
    local file_name="wptt_opcache_clear_${secret_key}.php"
    local file_path="${web_root}/${file_name}"

    # 2. Tạo file PHP chứa lệnh reset OPcache
    cat <<'EOF' > "$file_path"
<?php
if (function_exists('opcache_reset')) {
    opcache_reset();
}
EOF

	. /etc/wptt/vhost/.$domain.conf
    
    # 3. chmod
    chown "${User_name_vhost}:${User_name_vhost}" "$file_path" 2>/dev/null
    chmod 644 "$file_path" 2>/dev/null

    # 4. Kích hoạt File bằng cURL nội bộ
    local result=$(curl -s -k -m 5 -H "Host: $domain" "http://127.0.0.1/$file_name")

    # 5. Thủ tiêu file bí mật ngay lập tức
    rm -f "$file_path"
}

