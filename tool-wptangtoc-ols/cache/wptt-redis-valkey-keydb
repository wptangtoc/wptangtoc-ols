#!/bin/bash
# @author: Gia Tuấn
# @website: https://wptangtoc.com
# @since: 2026

function huong_dan() {
  1. Tính Năng Cài Đặt [Install Object Cache]
  Cài đặt Valkey/KeyDB/Redis là quá trình thiết lập và chạy phần mềm máy chủ trên hệ thống để các ứng dụng có thể kết nối và sử dụng nó.

  Đây là các kho lưu trữ cấu trúc dữ liệu trong bộ nhớ [in-memory], mã nguồn mở, rất nhanh và đa năng. Thường được dùng làm:
  * Cơ sở dữ liệu, bộ nhớ đệm [Cache]: Tăng tốc website, ứng dụng.
  * Message Broker: Trung gian truyền tin nhắn.
  * Quản lý phiên [Session Management], hàng đợi tác vụ [Job Queues], và nhiều ứng dụng thời gian thực khác.

  Kết quả: Sau khi cài đặt, bạn sẽ có một máy chủ Cache đang chạy, lắng nghe trên cổng unix socket path: /var/run/ <tên_dịch_vụ >/ <tên_dịch_vụ >.sock

  2. Tính Năng Hủy Cài Đặt [Uninstall]
  Hủy cài đặt là quá trình gỡ bỏ phần mềm, các tệp cấu hình và có thể cả dữ liệu của nó khỏi hệ thống.

  Mục đích chính:
  * Không còn nhu cầu sử dụng.
  * Giải phóng tài nguyên [RAM, dung lượng đĩa].
  * Cấu hình lại hoặc dọn dẹp hệ thống.

  Kết quả: Phần mềm sẽ được gỡ bỏ, dịch vụ sẽ dừng và không còn khả dụng cho ứng dụng.
}

. /etc/wptt/.wptt.conf
if [[ $ngon_ngu = '' ]]; then
  ngon_ngu='vi'
fi
. /etc/wptt/lang/$ngon_ngu.sh

. /etc/wptt/echo-color

# =========================================================================
# NHẬN DIỆN ENGINE ĐANG HOẠT ĐỘNG
# =========================================================================
active_cache="Chưa cài đặt"
socket_path="Không có"

if systemctl is-active --quiet valkey 2>/dev/null; then
  active_cache="Valkey"
  socket_path="/var/run/valkey/valkey.sock"
elif systemctl is-active --quiet keydb 2>/dev/null; then
  active_cache="KeyDB"
  socket_path="/var/run/keydb/keydb.sock"
elif systemctl is-active --quiet redis 2>/dev/null; then
  active_cache="Redis"
  socket_path="/var/run/redis/redis.sock"
fi

echo "========================================================================="
echo "|$quan_ly_cache => Object Cache (Valkey - Redis - KeyDB):"
echo "========================================================================="
echo "|$quan_ly_cache => Vui lòng chọn hệ thống Object Cache bạn muốn quản lý:"
echo "========================================================================="
if [[ "$active_cache" != "Chưa cài đặt" ]]; then
  echo -e " \e[1;32m[Trạng thái]\e[0m Đang hoạt động: \e[1;33m$active_cache\e[0m"
  echo -e " \e[1;32m[Unix Socket]\e[0m $socket_path"
  echo "-------------------------------------------------------------------------"
fi
OUTPUT=$(cat /etc/*release)
if echo $OUTPUT | grep -q "AlmaLinux 10\|Rocky Linux 10\|Red Hat Enterprise Linux 10\|Oracle Linux Server 10"; then #redis không support almalinux 10
  echo " 1) Valkey (Khuyên dùng - Nhanh, nhẹ, ổn định nhất)"
  echo " 2) KeyDB  (Tối ưu ép xung Đa luồng cho VPS nhiều Core)"
  echo " 3) Thoát"
  echo "========================================================================="
  read -p "Nhập lựa chọn của bạn [1-4]: " cache_choice

  case "$cache_choice" in
  1) name_service="valkey" ;;
  2) name_service="keydb" ;;
  3)
    exec /etc/wptt/wptt-cache-main 1
    ;;
  *)
    echo "$ban_nhap_sai_he_thong_se_chon_khong_dong_y"
    exec /etc/wptt/wptt-cache-main 1
    ;;
  esac
else
  echo " 1) Valkey (Khuyên dùng - Nhanh, nhẹ, ổn định nhất)"
  echo " 2) KeyDB  (Tối ưu ép xung Đa luồng cho VPS nhiều Core)"
  echo " 3) Redis  (Phiên bản truyền thống)"
  echo " 4) Thoát"
  echo "========================================================================="
  read -p "Nhập lựa chọn của bạn [1-4]: " cache_choice

  case "$cache_choice" in
  1) name_service="valkey" ;;
  2) name_service="keydb" ;;
  3) name_service="redis" ;;
  4)
    exec /etc/wptt/wptt-cache-main 1
    ;;
  *)
    echo "$ban_nhap_sai_he_thong_se_chon_khong_dong_y"
    exec /etc/wptt/wptt-cache-main 1
    ;;
  esac
fi

duong_dan_config_redis="/etc/$name_service/$name_service.conf"

if $(cat /etc/*release | grep -q "AlmaLinux 8\|Rocky Linux 8\|Red Hat Enterprise Linux 8\|Oracle Linux Server 8") && [[ $name_service = 'redis' ]]; then #trường hợp đặc b riêng redis almalinux 8 thì nó đường dẫn hơi khác
  duong_dan_config_redis="/etc/$name_service.conf"
fi

# Fallback sửa lỗi đường dẫn nếu package cài đặt tự động nhét vào thư mục con
if [[ ! -f "$duong_dan_config_redis" && -f "/etc/$name_service.conf" ]]; then
  duong_dan_config_redis="/etc/$name_service.conf"
elif [[ ! -f "$duong_dan_config_redis" && -f "/etc/$name_service/$name_service.conf" ]]; then
  duong_dan_config_redis="/etc/$name_service/$name_service.conf"
fi

# TIẾN HÀNH KIỂM TRA ĐỂ CÀI ĐẶT HOẶC XÓA BỎ
if [[ ! -f "$duong_dan_config_redis" ]]; then
  echo "$xac_nhan $ban_co_muon $cai $name_service?"

  prompt="$nhap_lua_chon_cua_ban [1-2]: "
  bien=$1
  dongyconfig='n'
  options=("$dong_y" "$khong_dong_y")

  PS3="$prompt"
  select opt in "${options[@]}"; do
    case "$REPLY" in
    1)
      dongyconfig="y"
      break
      ;;

    2)
      dongyconfig="n"
      break
      ;;

    $((${#options[@]} + 1)))
      printf "\n$ban_nhap_sai_he_thong_se_chon_khong_dong_y\n"
      break
      ;;
    *)
      printf "$ban_nhap_sai_he_thong_se_chon_khong_dong_y\n"
      break
      ;;
    esac
  done

  if [[ "$dongyconfig" != "y" ]]; then
    check_menu_wptangtoc_active=$1
    if [[ $check_menu_wptangtoc_active = "98" ]]; then
      exec /etc/wptt/wptt-cache-main 1
    fi
    exit
  fi

  tong_ram_byte=$(awk '/MemTotal/ {print $2}' /proc/meminfo)
  rong_ram_mb=$(echo "scale=0;${tong_ram_byte}/1024" | bc)
  if [[ "$rong_ram_mb" = "" ]]; then
    rong_ram_mb="2048"
  fi
  if (($rong_ram_mb < 1024)); then
    echo "$chi_nen_su_dung_object_cache_toi_thieu_2gb_ram"
    exec /etc/wptt/wptt-cache-main 1
  fi

  . /etc/wptt/echo-color
  if [[ -f $duong_dan_config_redis ]]; then
    echoDo "$ban_da_kich_hoat $name_service $truoc_do_roi"
    exec /etc/wptt/wptt-cache-main 1
    exit
  fi

  _runing "$cai $name_service"
  echo "Kích hoạt $name_service: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log

  # =========================================================
  # GỠ BỎ TẬN GỐC CÁC DỊCH VỤ CŨ TRƯỚC KHI CÀI DỊCH VỤ MỚI
  # =========================================================
  for other_service in redis valkey keydb; do
    if [[ "$other_service" != "$name_service" ]]; then
      # Tắt dịch vụ và gỡ package
      systemctl stop $other_service >/dev/null 2>&1
      systemctl disable $other_service >/dev/null 2>&1
      killall -9 ${other_service}-server >/dev/null 2>&1

      if $(cat /etc/*release | grep -q "Ubuntu\|Debian"); then
        apt-get remove --purge $other_service ${other_service}-server -y >/dev/null 2>&1
      else
        yum remove $other_service -y >/dev/null 2>&1
      fi

      # Dọn dẹp tàn dư (File cấu hình, Data, Socket, Log, Monit)
      rm -rf /etc/${other_service}.conf /etc/${other_service}
      rm -rf /var/run/${other_service} /var/lib/${other_service} /var/log/${other_service}
      rm -f /etc/monit.d/${other_service} /etc/monit/conf.d/${other_service}
    fi
  done
  # =========================================================

  if $(cat /etc/*release | grep -q "Ubuntu"); then
    apt-get update >/dev/null 2>&1
    apt-get install $name_service -y >/dev/null 2>&1
    apt-get install ${name_service}-server -y >/dev/null 2>&1
    lsphp=($(ls -A /usr/local/lsws | grep -oP '^lsphp\K[0-9]+$'))
    for phpredis in ${lsphp[@]}; do
      apt-get install lsphp${phpredis}-redis -y >/dev/null 2>&1
      apt-get install lsphp${phpredis}-igbinary -y >/dev/null 2>&1
    done
  else
    # Bật EPEL để đảm bảo luôn tải được KeyDB/Valkey
    dnf install epel-release -y >/dev/null 2>&1
    yum install ${name_service} -y --disablerepo="mariadb" >/dev/null 2>&1

    lsphp=($(ls -A /usr/local/lsws | grep -oP '^lsphp\K[0-9]+$'))
    (/etc/wptt/php/kho-luu-tru-litespeed) #subshell tránh đè biến

    for phpredis in ${lsphp[@]}; do
      if [[ $(dnf list available 2>/dev/null | grep "lsphp${phpredis}-pecl-redis") ]]; then #điều kiện PHP đang được hỗ trợ
        yum install lsphp${phpredis}-pecl-redis -y --nogpgcheck --disablerepo="mariadb" 2>/dev/null
        yum install lsphp${phpredis}-pecl-igbinary -y --nogpgcheck --disablerepo="mariadb" 2>/dev/null
      else
        url_repo_litespeed=$(
          cat /tmp/php_extension_call_eol | grep lsphp${phpredis} | grep -oP 'href="\K[^"]+' | grep -v 'debuginfo\|-devel\|-debugsource' | awk '
BEGIN { FS = "/" }
{
    filename = $NF
    split(filename, parts, "-")

    pkg_name = ""
    version = ""

    if (parts[2] == "pecl") {
        pkg_name = parts[1] "-" parts[2] "-" parts[3]
        version = parts[4]
    } else if (parts[2] ~ /^[0-9]+\.[0-9]+/) {
        pkg_name = parts[1]
        version = parts[2]
    } else {
        pkg_name = parts[1] "-" parts[2]
        version = parts[3]
    }

    if (version > versions[pkg_name]) {
        versions[pkg_name] = version
        latest_lines[pkg_name] = $0
    }
}
END {
    PROCINFO["sorted_in"] = "@ind_str_asc"
    for (pkg in latest_lines) {
        print latest_lines[pkg]
    }
}'
        )
        # pecl-igbinary giúp cải thiện hiệu suất từ 30% đến 50%
        # Dù là Valkey hay KeyDB thì PHP Extension vẫn là pecl-redis
        extensions_redis=(pecl-igbinary pecl-redis)
        for extension in ${extensions_redis[@]}; do
          if [[ $(printf "%s\n" "${url_repo_litespeed[@]}" | grep "lsphp${phpredis}-${extension}-") ]]; then
            dnf install http://rpms.litespeedtech.com$(printf "%s\n" "${url_repo_litespeed[@]}" | grep "lsphp${phpredis}-${extension}-") -y
            if [[ -z $(rpm -aq | grep "lsphp${phpredis}-${extension}-") ]]; then
              sed -i '/rpms.litespeedtech.com/d' /etc/hosts
              echo $'\n52.55.120.73 rpms.litespeedtech.com\n' >>/etc/hosts
              dnf install http://rpms.litespeedtech.com$(printf "%s\n" "${url_repo_litespeed[@]}" | grep "lsphp${phpredis}-${extension}-") -y
            fi
          fi
        done
      fi
    done
    rm -f /tmp/php_extension_call_eol
  fi

  # Cập nhật lại biến đường dẫn config sau khi cài để đảm bảo độ chính xác
  if [[ ! -f "$duong_dan_config_redis" ]]; then
    if [[ -f "/etc/$name_service/$name_service.conf" ]]; then
      duong_dan_config_redis="/etc/$name_service/$name_service.conf"
    elif [[ -f "/etc/$name_service.conf" ]]; then
      duong_dan_config_redis="/etc/$name_service.conf"
    fi
  fi

  _rundone "$cai $name_service"

  _runing "$thiet_lap $name_service"

  # Thêm "port 0" để cắt đứt cổng 6379, ép chạy 100% bằng Socket chống xung đột và hack
  echo "port 0
unixsocket /var/run/$name_service/$name_service.sock
unixsocketperm 777
maxmemory 128mb
maxmemory-policy allkeys-lfu
save \"\"
appendonly no
activedefrag yes
tcp-keepalive 60" >>$duong_dan_config_redis

  sed -i 's/^port 6379/#port 6379/g' $duong_dan_config_redis # Vô hiệu hóa port mặc định nếu có sẵn
  sed -i 's/tcp-keepalive 300/tcp-keepalive 0/g' $duong_dan_config_redis
  sed -i 's/rdbcompression yes/rdbcompression no/g' $duong_dan_config_redis
  sed -i 's/rdbchecksum yes/rdbchecksum no/g' $duong_dan_config_redis

  # Xử lý thư mục chạy và phân quyền động
  mkdir -p /var/run/$name_service /var/lib/$name_service /var/log/$name_service
  chmod 700 /var/lib/$name_service
  chown -R $name_service:$name_service /var/run/$name_service 2>/dev/null
  chown -R $name_service:$name_service /var/log/$name_service /var/lib/$name_service 2>/dev/null
  chown $name_service:$name_service $duong_dan_config_redis 2>/dev/null

  chmod 600 $duong_dan_config_redis

  systemctl enable $name_service.service >/dev/null 2>&1
  systemctl start $name_service.service >/dev/null 2>&1

  systemctl restart lsws >/dev/null 2>&1

  #setup monit cho dịch vụ (sẽ tự động reload nếu có monit)
  (/etc/wptt/monit >/dev/null 2>&1)

  _rundone "$thiet_lap $name_service"
  echo "========================================================================="
  echo "HOST unix socket path: /var/run/$name_service/$name_service.sock"
  echo "========================================================================="
else

  echo "$xac_nhan $ban_co_muon $xoa $name_service?"
  prompt="$nhap_lua_chon_cua_ban [1-2]: "
  bien=$1
  dongyconfig='n'
  options=("$dong_y" "$khong_dong_y")

  PS3="$prompt"
  select opt in "${options[@]}"; do
    case "$REPLY" in
    1)
      dongyconfig="y"
      break
      ;;

    2)
      dongyconfig="n"
      break
      ;;

    $((${#options[@]} + 1)))
      printf "\n$ban_nhap_sai_he_thong_se_chon_khong_dong_y\n"
      break
      ;;
    *)
      printf "$ban_nhap_sai_he_thong_se_chon_khong_dong_y\n"
      break
      ;;
    esac
  done

  if [[ "$dongyconfig" != "y" ]]; then
    check_menu_wptangtoc_active=$1
    if [[ $check_menu_wptangtoc_active = "98" ]]; then
      exec /etc/wptt/wptt-cache-main 1
    fi
    exit
  fi

  echo "Huỷ kích hoạt $name_service: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log

  _runing "$xoa ${name_service}"
  systemctl stop ${name_service} >/dev/null 2>&1
  systemctl disable ${name_service} >/dev/null 2>&1

  if $(cat /etc/*release | grep -q "Ubuntu\|Debian"); then
    apt-get remove --purge ${name_service} ${name_service}-server -y >/dev/null 2>&1
  else
    yum remove ${name_service} -y >/dev/null 2>&1
  fi

  # Vì bây giờ trên máy chủ chắc chắn CHỈ CÓ 1 dịch vụ Cache tồn tại.
  # Nên khi user chọn "Uninstall", nghĩa là họ xóa sạch không dùng Object Cache nữa.
  # Do đó, ta gỡ luôn PHP Extension pecl-redis cho sạch.
  lsphp=($(ls /usr/local/lsws | grep -oP '^lsphp\K[0-9]+$'))
  for php_redis in ${lsphp[@]}; do
    yum remove lsphp${php_redis}-pecl-redis -y --disablerepo="*" --enablerepo="litespeed,litespeed-update" >/dev/null 2>&1
  done

  # Dọn dẹp tàn dư
  rm -rf $duong_dan_config_redis
  rm -rf /etc/$name_service
  rm -rf /var/run/$name_service /var/lib/$name_service /var/log/$name_service

  # Xoá monit
  if grep -qi "ubuntu\|debian" /etc/*release; then
    DIR_MONIT="/etc/monit/conf.d"
  else
    DIR_MONIT="/etc/monit.d"
  fi

  FILE_MONIT_RULE="$DIR_MONIT/$name_service"
  if [[ -f $FILE_MONIT_RULE ]]; then
    rm -f "$FILE_MONIT_RULE"
  fi

  if systemctl is-active --quiet monit; then
    systemctl reload monit >/dev/null 2>&1
  fi

  _rundone "$xoa ${name_service}"
fi

check_menu_wptangtoc_active=$1
if [[ $check_menu_wptangtoc_active = "98" ]]; then
  exec /etc/wptt/wptt-cache-main 1
fi
