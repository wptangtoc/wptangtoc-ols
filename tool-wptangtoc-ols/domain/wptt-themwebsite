#!/bin/bash
# @author: Gia Tuấn
# @website: https://wptangtoc.com
# @since: 2025

function huong_dan() {
  Đây là tính năng thêm domain mới vào hệ thống.
  Khi khởi tạo: phần mềm sẽ cung cấp cho bạn tài khoản database, đường dẫn đặt mã nguồn... để phục vụ bạn thiết lập website

  Tính năng Thêm domain [hay Thêm tên miền] trong quản lý máy chủ là quá trình cấu hình hệ thống để nhận diện và xử lý các yêu cầu truy cập đến một tên miền mới mà bạn muốn sử dụng. Điều này cho phép bạn lưu trữ và chạy một website mới, hoặc trỏ một tên miền mới tới một ứng dụng/website đã có trên máy chủ đó.

  Nói một cách đơn giản, đây là bước khai báo với máy chủ rằng tôi có một tên miền mới là tenmienmoi.com, hãy chuẩn bị để phục vụ website cho nó.

  Mục Đích Chính
  * Lưu trữ [Host] một website mới: Đây là lý do phổ biến nhất, cho phép website của bạn có một địa chỉ riêng trên Internet.
  * Chạy nhiều website trên một server: Mỗi tên miền có thể tương ứng với một website riêng biệt.
  * Phân tách các ứng dụng hoặc dịch vụ khác nhau: Mỗi tên miền có thể phục vụ một mục đích riêng.

  Sau khi thêm thành công, máy chủ sẽ sẵn sàng phục vụ nội dung website khi có người truy cập vào tên miền mới đó.

  Ghi chú: WPTangTocOLS không giới hạn số lượng domain bạn thêm vào.
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null
PATH='/root/.local/bin:/root/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin'

export LANG=en_US.UTF-8
export LC_ALL=en_US.UTF-8
stty iutf8

# Xử lý khi sử dụng template/chuyển hướng
if [[ "$1" == '98' ]]; then
  if [[ $(ls -At /etc/wptt/vhost | wc -l) == '1' && $(ls -At /etc/wptt/vhost | sed 's/^.//' | sed 's/.conf//' | grep -x '^wptangtoc-ols.com$') ]]; then
    echo -e "${C_CYAN}Đang tiến hành cập nhật... vui lòng chờ đợi.${C_RESET}"
    . /etc/wptt/domain/wptt-thay-domain-chinh-wptangtoc-ols-com
    exec /etc/wptt/wptt-domain-main 1
    exit
  fi
fi

NAME=$1
[[ "$NAME" == "98" ]] && NAME=""

if [[ "$1" == '98' ]]; then
  WPTT_IN_MENU="yes"
  WPTT_MENU_BACK="/etc/wptt/wptt-domain-main 1"
fi

clear
echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}${quan_ly_domain} ➜ ${them_domain}${C_RESET}"
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

# ==============================================================================
# NHẬP VÀ KIỂM TRA ĐỊNH DẠNG TÊN MIỀN
# ==============================================================================
if [[ -z "$NAME" ]]; then
  echo -e "${C_YELLOW}Ví dụ: wptangtoc.com, abc.wptangtoc.com...${C_RESET}"
  echo -en "${C_CYAN}${nhap:-Nhập} Domain ${hoac:-hoặc} Subdomain ${ban_muon_them:-bạn muốn thêm} [0=${exit_thoat:-Thoát}]: ${C_RESET}"
  read -r NAME
fi

[[ "$NAME" == "0" || -z "$NAME" ]] && {
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-domain-main 1
  return 2>/dev/null || exit
}

# Loại bỏ khoảng trắng và chuẩn hóa
NAME="${NAME//[[:space:]]/}"
if [[ "$NAME" == "${NAME/./}" ]]; then
  echo -e "\n${C_RED}❌ Lỗi: ${domain_nhap_khong_dung_dinh_dang:-Tên miền nhập không đúng định dạng (thiếu dấu chấm)!}${C_RESET}"
  [[ "${1:-}" == "98" ]] && {
    read -r -p "Bấm phím Enter để quay lại Menu... " dummy
    exec /etc/wptt/wptt-domain-main 1
  }
  return 2>/dev/null || exit 1
fi

if [[ ! "$NAME" =~ ^[a-z0-9]+([a-z0-9.-]*[a-z0-9]+)?\.[a-z]{2,}$ ]]; then
  echo -e "\n${C_RED}❌ Lỗi: Tên miền chứa ký tự không hợp lệ hoặc sai cấu trúc.${C_RESET}"
  [[ "${1:-}" == "98" ]] && {
    read -r -p "Bấm phím Enter để quay lại Menu... " dummy
    exec /etc/wptt/wptt-domain-main 1
  }
  return 2>/dev/null || exit 1
fi

# Chuyển domain punycode và chuyển thường
NAME=$(/usr/bin/php /etc/wptt/domain/punycode.php "$NAME" 2>/dev/null)
if [[ -z "$NAME" ]]; then
  echo -e "\n${C_RED}❌ Lỗi PHP: Không thể xử lý tên miền $NAME${C_RESET}"
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-domain-main 1
  return 2>/dev/null || exit 1
fi
NAME=$(echo "$NAME" | tr '[:upper:]' '[:lower:]')

# Loại bỏ scheme/www
if [[ $(echo "$NAME" | grep '://') ]]; then NAME=$(echo "$NAME" | cut -f3 -d '/'); fi
if [[ $(echo "$NAME" | grep '^www\.') ]]; then NAME=$(echo "$NAME" | sed 's/^www.//g'); fi

USER=${NAME//[-._]/wp}

# ==============================================================================
# KIỂM TRA TRÙNG LẶP VÀ DỊCH VỤ
# ==============================================================================
path="/etc/wptt/vhost/.$NAME.conf"
if [[ -f "$path" ]]; then
  echo -e "\n${C_RED}❌ Lỗi: ${ten_mien_da_ton_tai_he_thong_nay:-Tên miền đã tồn tại trên hệ thống!}${C_RESET}"
  sleep 3
  exec /etc/wptt/wptt-domain-main 1
fi

pathcheck_chuyen_huong="/etc/wptt/chuyen-huong/.$NAME.conf"
if [[ -f "$pathcheck_chuyen_huong" ]]; then
  echo -e "\n${C_YELLOW}Lỗi: Domain $NAME ${da_duoc_chuyen_huong_truoc_do_roi:-đã được cấu hình Chuyển hướng (301) trước đó!}${C_RESET}"
  echo -e "Vui lòng gỡ bỏ Chuyển hướng trước khi thêm thành một Website độc lập."
  sleep 4
  exec /etc/wptt/wptt-domain-main 1
  return 2>/dev/null || exit 1
fi

wptt_check_mariadb || wptt_die "MariaDB đang bị sập! Hệ thống từ chối tạo thêm domain mới."
wptt_check_lsws || wptt_die "OpenLiteSpeed đang bị sập! Đã hủy thao tác để an toàn!"

# ==============================================================================
# TÍNH TOÁN TÀI NGUYÊN (CPU/RAM) VÀ TẠO USER
# ==============================================================================
echo ""
_runing "${them:-Đang thêm} domain $NAME ${vao_he_thong:-vào hệ thống}..."

. /etc/wptt/.wptt.conf
work_cpucore='1024'
cpucore=$(grep -c ^processor /proc/cpuinfo)
max_client=$((work_cpucore * cpucore * 2))
max_client_max=$((work_cpucore * cpucore * 3))
max_client_php=$((work_cpucore * cpucore / 8))
tong_ram_byte=$(awk '/MemTotal/ {print $2}' /proc/meminfo)
rong_ram_mb=$(echo "scale=0;${tong_ram_byte}/1024" | bc)
gioi_han_tien_trinh_bao_loi_503=$((max_client / 8))
core_tien_lsphp_child=$((cpucore * 2))
[[ -z "$rong_ram_mb" ]] && rong_ram_mb="2048"

# Tạo User Linux độc lập (Giới hạn 32 ký tự)
check_ky_tu=${#USER}
if ((check_ky_tu > 32)); then USER=$(echo "$USER" | cut -c 1-30); fi

useradd -p -m -d "/usr/local/lsws/$NAME" "$USER" >/dev/null 2>&1
if ! id "$USER" &>/dev/null; then
  random=$(openssl rand -base64 32 | tr -dc 'a-zA-Z0-9' | head -c 2)
  USER=${NAME//[-._]/$random}
  USER=$(echo "$USER" | tr '[:upper:]' '[:lower:]')
  check_ky_tu2=${#USER}
  if ((check_ky_tu2 > 32)); then USER=$(echo "$USER" | cut -c 1-30); fi
  useradd -p -m -d "/usr/local/lsws/$NAME" "$USER" >/dev/null 2>&1
fi

if ! id "$USER" &>/dev/null; then
  _runloi "${them:-Thêm} domain $NAME ${vao_he_thong:-vào hệ thống}"
  echo -e "${C_RED}❌ Lỗi: Hệ điều hành không thể tạo user mới!${C_RESET}"
  exec /etc/wptt/wptt-domain-main 1
  exit 1
fi

# Tối ưu KeepAlive dựa trên RAM
TOTAL_RAM_MB=$(free -m | awk '/^Mem:/{print $2}')
if [ "$TOTAL_RAM_MB" -le 1200 ]; then KA_REQS="1000"; elif [ "$TOTAL_RAM_MB" -le 4500 ]; then KA_REQS="5000"; else KA_REQS="10000"; fi

# ==============================================================================
# KHỞI TẠO VHOST & SSL TỰ KÝ
# ==============================================================================
echo "virtualhost $NAME {
vhRoot                  /usr/local/lsws/$NAME/
configFile              /usr/local/lsws/conf/vhosts/$NAME/$NAME.conf
allowSymbolLink         1
enableScript            1
restrained              1
maxKeepAliveReq         $KA_REQS
setUIDMode              2
user                    $USER
group                   $USER
}" >>/usr/local/lsws/conf/httpd_config.conf

sed -i "/listener http/a map 		$NAME $NAME" /usr/local/lsws/conf/httpd_config.conf
mkdir -p "/usr/local/lsws/conf/vhosts/$NAME/"
touch "/usr/local/lsws/conf/vhosts/$NAME/$NAME.conf"

NAMEPHP=${NAME//[-._]/}

echo "docRoot                   /usr/local/lsws/$NAME/html
vhDomain                  $NAME
enableGzip                1
cgroups                   0
index  {
useServer               0
indexFiles              index.html index.php
autoIndex               0
}
scripthandler  {
add                     lsapi:$NAMEPHP php
}
accessControl  {
allow                   *
}
lsrecaptcha  {
enabled                 1
type                    0
}
namespace               2
extprocessor $NAMEPHP {
type                    lsapi
address                 uds://tmp/lshttpd/$NAMEPHP.sock
maxConns                $core_tien_lsphp_child
env                     PHP_LSAPI_CHILDREN=$core_tien_lsphp_child
env                     LSAPI_ACCEPT_NOTIFY=1
env                     LSAPI_MAX_CMD_SCRIPT_PATH_LEN=200
env                     LSAPI_AVOID_FORK=300M
initTimeout             60
retryTimeout            0
pcKeepAliveTimeout      5
respBuffer              0
autoStart               1
path                    /usr/local/lsws/lsphp74/bin/lsphp
backlog                 100
instances               1
extUser                 $USER
extGroup                $USER
runOnStartUp            2
priority                0
memSoftLimit            ${rong_ram_mb}M
memHardLimit            ${rong_ram_mb}M
procSoftLimit           $gioi_han_tien_trinh_bao_loi_503
procHardLimit           $gioi_han_tien_trinh_bao_loi_503
}
context / {
  location                /usr/local/lsws/$NAME/html
  allowBrowse             1
  extraHeaders            <<<END_extraHeaders
X-XSS-Protection 1;mode=block
X-Frame-Options SAMEORIGIN
Referrer-Policy strict-origin-when-cross-origin
X-Content-Type-Options nosniff
X-Powered-By WPTangTocOLS
permissions-policy accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=()
  END_extraHeaders
  rewrite  {
  }
  addDefaultCharset       off
  phpIniOverride  {
  }
}
rewrite  {
enable                  1
autoLoadHtaccess        1
/usr/local/lsws/$NAME/html/.htaccess
}
vhssl  {
  keyFile                 /etc/wptt-ssl-tu-ky/$NAME/$NAME.key
  certFile                /etc/wptt-ssl-tu-ky/$NAME/cert.crt
  certChain               0
  sslProtocol             24
  renegProtection         1
  sslSessionCache         1
  sslSessionTickets       1
  enableSpdy              15
  enableQuic              1
}
module cache {
checkPrivateCache   1
checkPublicCache    1
maxCacheObjSize     10000000
maxStaleAge         200
qsCache             1
reqCookieCache      1
respCookieCache     1
ignoreReqCacheCtrl  1
ignoreRespCacheCtrl 0
storagePath /usr/local/lsws/$NAME/luucache
enableCache         0
expireInSeconds     3600
enablePrivateCache  0
privateExpireInSeconds 3600
ls_enabled              1
}" >"/usr/local/lsws/conf/vhosts/$NAME/$NAME.conf"

hostname_custom=$(cat "/usr/local/lsws/conf/vhosts/$Website_chinh/$Website_chinh.conf" 2>/dev/null | grep 'X-Powered-By' | cut -f2 -d ' ' | sort -u)
if [[ -z "$hostname_custom" || "$hostname_custom" != 'WPTangTocOLS' ]]; then
  sed -i '/X-Powered-By/d' "/usr/local/lsws/conf/vhosts/$NAME/$NAME.conf"
fi
if [[ "$hostname_custom" != 'WPTangTocOLS' && -n "$hostname_custom" ]]; then
  sed -i "/extraHeaders /a X-Powered-By $hostname_custom" "/usr/local/lsws/conf/vhosts/$NAME/$NAME.conf"
fi
unset hostname_custom

# Khởi tạo SSL tự ký
mkdir -p "/etc/wptt-ssl-tu-ky/$NAME"
cd "/etc/wptt-ssl-tu-ky/$NAME" || exit
openssl req -new -newkey rsa:2048 -nodes -keyout "$NAME.key" -out "$NAME.csr" -subj "/C=VN/ST=Hanoi/L=Hanoi/O=wptangtoc ols/OU=IT Department/CN=$NAME/emailAddress=admin@example.com" >/dev/null 2>&1
openssl x509 -req -in "$NAME.csr" -signkey "$NAME.key" -out cert.crt -days 3650 >/dev/null 2>&1

if [[ -f "/etc/letsencrypt/live/$NAME/cert.pem" ]]; then
  sed -i -e '/^vhssl /,/^}$/d' "/usr/local/lsws/conf/vhosts/$NAME/$NAME.conf"
  echo "vhssl  {
keyFile                 /etc/letsencrypt/live/$NAME/privkey.pem
certFile                /etc/letsencrypt/live/$NAME/cert.pem
certChain               0
CACertFile              /etc/letsencrypt/live/$NAME/chain.pem
sslProtocol             24
renegProtection         1
sslSessionCache         1
sslSessionTickets       1
enableSpdy              15
enableQuic              1
}
" >>"/usr/local/lsws/conf/vhosts/$NAME/$NAME.conf"
fi

if $(cat /etc/*release | grep -q "Ubuntu"); then tuong_thich_nhom_litespeed="nogroup"; else tuong_thich_nhom_litespeed="nobody"; fi
chown -R lsadm:$tuong_thich_nhom_litespeed "/usr/local/lsws/conf/vhosts/$NAME"
chmod -R 750 "/usr/local/lsws/conf/vhosts/$NAME"

# Tạo thư mục gốc
mkdir -p "/usr/local/lsws/$NAME/html" "/usr/local/lsws/$NAME/luucache" "/usr/local/lsws/$NAME/backup-website" "/usr/local/backup-website/$NAME"
chmod 755 "/usr/local/lsws/$NAME" "/usr/local/lsws/$NAME/html"
chmod 700 "/usr/local/backup-website/$NAME" "/usr/local/lsws/$NAME/backup-website"

# Cài đặt file index mẫu
if [[ -z "$wptangtoc_ols_giatuan" && ! -f "/usr/local/lsws/$NAME/html/index.php" ]]; then
  cp -f /etc/wptt/index.php "/usr/local/lsws/$NAME/html/"
  chown "$USER:$USER" "/usr/local/lsws/$NAME/html/index.php"
  chmod 644 "/usr/local/lsws/$NAME/html/index.php"
fi

chown -R "$USER:$USER" "/usr/local/lsws/$NAME/html" "/usr/local/lsws/$NAME/backup-website"
chown root:root /usr/local/lsws "/usr/local/lsws/$NAME"
chmod 755 "/usr/local/lsws/$NAME"

# CHROOT SSH
sed -i -e "/^#begin-WPTT_JAIL_$USER/,/^#end-WPTT_JAIL_$USER$/d" /etc/ssh/sshd_config 2>/dev/null || true
cat <<EOF >>/etc/ssh/sshd_config
#begin-WPTT_JAIL_$USER
Match User $USER
    ChrootDirectory /usr/local/lsws/$NAME
    ForceCommand internal-sftp
    AllowTcpForwarding no
    X11Forwarding no
#end-WPTT_JAIL_$USER
EOF
systemctl restart sshd 2>/dev/null || systemctl restart ssh 2>/dev/null

if [[ ! -f "/usr/local/lsws/$NAME/html/.htaccess" ]]; then
  echo '# BEGIN WordPress
<IfModule mod_rewrite.c>
RewriteEngine On
RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]
RewriteBase /
RewriteRule ^index\.php$ - [L]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . /index.php [L]
</IfModule>
# END WordPress' >"/usr/local/lsws/$NAME/html/.htaccess"
fi

_rundone "${them:-Đã thêm} domain $NAME ${vao_he_thong:-vào hệ thống}"

# ==============================================================================
# KHỞI TẠO DATABASE MARIADB
# ==============================================================================
_runing "${them:-Khởi tạo} database ${cho:-cho website} $NAME..."

name_db=${NAME//[-._]/}
ramdom_db=$(openssl rand -base64 32 | tr -dc 'a-zA-Z0-9' | head -c 18)
database=${name_db}_${ramdom_db}_dbname
username=${name_db}_${ramdom_db}_username
password=$(openssl rand -base64 48 | tr -dc 'a-zA-Z0-9' | head -c 36)

if ((${#database} > 60)); then database=$(echo "$database" | cut -c 1-60); fi
if ((${#username} > 60)); then username=$(echo "$username" | cut -c 1-60); fi

TEMP_CNF_ROOT=$(mktemp)
chmod 600 "$TEMP_CNF_ROOT"
cat >"$TEMP_CNF_ROOT" <<EOF
[client]
user=${database_admin_username}
password=${database_admin_password}
host=localhost
max_allowed_packet=1G
default-character-set=utf8mb4

[mysqldump]
quick
quote-names
max_allowed_packet=1G
EOF
trap "rm -f $TEMP_CNF_ROOT" EXIT

mariadb --defaults-extra-file="$TEMP_CNF_ROOT" --ssl-verify-server-cert=false -e "DROP DATABASE IF EXISTS ${database}"
mariadb --defaults-extra-file="$TEMP_CNF_ROOT" --ssl-verify-server-cert=false -e "CREATE DATABASE IF NOT EXISTS ${database}"
mariadb --defaults-extra-file="$TEMP_CNF_ROOT" --ssl-verify-server-cert=false -e "DROP USER IF EXISTS '${username}'@'localhost'"
mariadb --defaults-extra-file="$TEMP_CNF_ROOT" --ssl-verify-server-cert=false -e "CREATE USER IF NOT EXISTS '${username}'@'localhost' IDENTIFIED BY '${password}'"
mariadb --defaults-extra-file="$TEMP_CNF_ROOT" --ssl-verify-server-cert=false -e "GRANT ALL PRIVILEGES ON ${database}.* TO '${username}'@'localhost';"
mariadb --defaults-extra-file="$TEMP_CNF_ROOT" --ssl-verify-server-cert=false -e "FLUSH PRIVILEGES"
rm -rf "$TEMP_CNF_ROOT"
_rundone "${them:-Khởi tạo thành công} database ${cho:-cho website} $NAME"

# ==============================================================================
# LƯU CẤU HÌNH VÀ RELOAD
# ==============================================================================
php_version=$(php -v | grep cli | grep -oP 'PHP \K[0-9]+\.[0-9]+')
touch "/etc/wptt/vhost/.$NAME.conf"
echo "DB_Name_web=$database
DB_User_web=$username
DB_Password_web=$password
Duong_Dan_thu_muc_web=/usr/local/lsws/$NAME/html
User_name_vhost=$USER
phien_ban_php_domain=$php_version" >"/etc/wptt/vhost/.$NAME.conf"

chown root:root "/etc/wptt/vhost/.$NAME.conf"
chmod 700 "/etc/wptt/vhost/.$NAME.conf"

# Liên kết Shortcut
mkdir -p /wptangtoc-ols/"$NAME"/backup-website
ln -sf "/usr/local/lsws/$NAME/html" "/wptangtoc-ols/$NAME" 2>/dev/null
ln -sf "/usr/local/backup-website/$NAME/" "/wptangtoc-ols/$NAME/backup-website" 2>/dev/null
ln -sf "/usr/local/lsws/$NAME" "/home/$NAME" 2>/dev/null

if [[ ! -f "/usr/local/lsws/$NAME/.bashrc" ]]; then
  cp -rf /etc/skel/. "/usr/local/lsws/$NAME/"
fi
chown "$USER:$USER" /usr/local/lsws/$NAME/.*

echo '[[ $- != *i* ]] && return' >>"/usr/local/lsws/$NAME/.bashrc"
echo "alias 1='wptangtoc-user'" >>"/usr/local/lsws/$NAME/.bashrc"
echo "alias 11='wptangtoc-user'" >>"/usr/local/lsws/$NAME/.bashrc"
echo ". /etc/wptt-user/wptt-status" >>"/usr/local/lsws/$NAME/.bashrc"

chown "$USER:$USER" "/usr/local/lsws/$NAME/html/.htaccess"
usermod "$USER" -s /sbin/nologin

if [[ -f "/usr/local/lsws/$NAME/html/index.html" ]]; then
  sed -i "s/domain.com/$NAME/g" "/usr/local/lsws/$NAME/html/index.html"
  chown "$USER:$USER" "/usr/local/lsws/$NAME/html/index.html"
  chmod 644 "/usr/local/lsws/$NAME/html/index.html"
fi

# Cập nhật PHP mặc định
if [[ -z "$php_version_check" ]]; then php_version_check='8.1'; fi
php_ver_chon=${php_version_check//[-._]/}
sed -E -i "s/lsphp[0-9]+/lsphp${php_ver_chon}/g" "/usr/local/lsws/conf/vhosts/$NAME/$NAME.conf"

# Tính toán Optimize nhiều website
tong_ram_mb=$(echo "scale=0;${tong_ram_byte}/1024" | bc)
if (($(ls -A /etc/wptt/vhost | wc -l) > 10 || tong_ram_mb < 1024)); then
  . /etc/wptt/cau-hinh/wptt-litespeed-config-cau-hinh-optimize-nhieu-web >/dev/null 2>&1
fi

# _runing "Đang nạp lại hệ thống OpenLiteSpeed..."
/usr/local/lsws/bin/lswsctrl restart >/dev/null 2>&1
# _rundone "Cập nhật dịch vụ hệ thống hoàn tất"

# ==============================================================================
# BẢNG BÁO CÁO KẾT QUẢ BO CONG
# ==============================================================================
echo -e "\n${C_GREEN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_BOLD_WHITE}HOÀN TẤT THÊM WEBSITE MỚI${C_RESET}"
echo -e "${C_GREEN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
left_text "Tên miền     : ${C_YELLOW}$NAME${C_RESET}" 2
left_text "Thư mục Web  : /usr/local/lsws/$NAME/html" 2
# left_text "File cấu hình: /etc/wptt/vhost/.$NAME.conf" 2
echo -e "${C_GREEN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
center_text "${C_BOLD_WHITE}Tài khoản database được biên chế cho website ${NAME}${C_RESET}"
left_text "DB Name      : ${C_YELLOW}$database${C_RESET}" 2
left_text "DB User      : ${C_YELLOW}$username${C_RESET}" 2
left_text "DB Password  : ${C_YELLOW}$password${C_RESET}" 2
echo -e "${C_GREEN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
disk_info=$(df -BG | awk '$NF=="/"{printf "%d/%dGB (%s)", $3,$2,$5}')
ram_info=$(free -m | awk 'NR==2{printf "%s/%sMB (%.2f%%)", $3,$2,$3*100/$2 }')
left_text "RAM sử dụng  : $ram_info" 2
left_text "Disk sử dụng : $disk_info" 2
echo -e "${C_GREEN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

# ==============================================================================
# KIỂM TRA DNS VÀ CRON
# ==============================================================================
checkdns=$(host "$NAME" 2>/dev/null | grep -Eo -m 1 '[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}')
if [[ -z "$checkdns" ]]; then
  checkdns=$(nslookup "$NAME" 2>/dev/null | grep Address | cut -f5 | grep -Eo -m 1 '[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}')
fi

ip=$(curl -sf --connect-timeout 5 --max-time 10 https://ipv4.icanhazip.com || curl -sf --connect-timeout 5 --max-time 10 https://checkip.amazonaws.com)

if [[ "$checkdns" != "$ip" ]]; then
  echo -e "${C_YELLOW}CHÚ Ý QUAN TRỌNG VỀ DNS:${C_RESET}"
  if [[ -z "$checkdns" ]]; then
    echo -e "Tên miền ${C_BOLD_WHITE}$NAME${C_RESET} hiện chưa được trỏ IP. Vui lòng trỏ bản ghi A về IP: ${C_GREEN}$ip${C_RESET}"
  else
    echo -e "Tên miền ${C_BOLD_WHITE}$NAME${C_RESET} đang trỏ đến IP: $checkdns"
    echo -e "Vui lòng trỏ lại bản ghi A về IP máy chủ hiện tại: ${C_GREEN}$ip${C_RESET} để website hoạt động."
  fi
  echo ""
fi

echo "Thêm website $NAME thời gian: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log

if [[ -n "$download_api" && "$1" != '98' ]]; then
  if [[ -f /etc/wptt/add-one/check.sh ]]; then
    if [[ $email_check_downtime && $telegram_id ]]; then
      . /etc/wptt/add-one/check.sh $telegram_id $telegram_api $email >/dev/null 2>&1
    fi
    if [[ -z $email_check_downtime && $telegram_id ]]; then
      . /etc/wptt/add-one/check.sh $telegram_id $telegram_api >/dev/null 2>&1
    fi
    if [[ $email_check_downtime && -z $telegram_id ]]; then
      . /etc/wptt/add-one/check.sh $email_check_downtime >/dev/null 2>&1
    fi
  fi
fi

[[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-domain-main 1
