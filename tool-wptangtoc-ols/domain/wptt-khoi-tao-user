#!/bin/bash
# @author: Gia Tuấn
# @website: https://wptangtoc.com
# @since: 2026

function huong_dan() {
  Đây là tính năng khởi tạo đăng nhập username riêng.
  Rất hữu ích ví dụ: trên hệ thống của bạn có 10 website, bạn thuê IT ngoài xử lý công việc gì đó trong 1 website thôi.
  Thì đưa cho họ tài khoản root thì quá nguy hiểm họ có toàn quyền kiểm soát cả 10 web. Tính năng này ra đời giải quyết vấn đề đó, bạn chỉ cấp cho họ tài khoản username riêng domain này, họ chỉ có quyền kiểm soát 1 website đó mà thôi và không có quyền tác động vào 9 website còn lại.
  Giúp nâng cao bảo mật tuyệt đối bằng công nghệ Chroot Jail.
}

. /etc/wptt/.wptt.conf
if [[ $ngon_ngu = '' ]]; then
  ngon_ngu='vi'
fi
. /etc/wptt/lang/$ngon_ngu.sh

. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null

echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}${quan_ly_domain} ➜ $bat_tat_dang_nhap_username_rieng_domain${C_RESET}"
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

. /etc/wptt/tenmien
lua_chon_NAME "$bat_tat_dang_nhap_username_rieng_domain"

. /etc/wptt/echo-color

if [[ "$NAME" = "0" || "$NAME" = "" ]]; then
  exec /etc/wptt/wptt-domain-main 1
fi

pathcheck="/etc/wptt/vhost/.$NAME.conf"
if [[ ! -f "$pathcheck" ]]; then
  clear
  echoDo "$ten_mien_nay_khong_ton_tai_tren_he_thong"
  sleep 3
  exec /etc/wptt/wptt-domain-main 1
  exit
fi
. /etc/wptt/vhost/.$NAME.conf

check=$(cat /etc/passwd | grep "${User_name_vhost}:x" | grep 'nologin')

if [[ $check ]]; then
  if ! wptt_xac_nhan "$xac_nhan $ban_muon $thiet_lap $dang_nhap username của website $NAME" "" "" "Đồng ý (Khởi tạo Username đăng nhập)" "Không đồng ý (Hủy thao tác)"; then
    [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-domain-main 1
    exit
  fi

  echo "Bật đăng nhập username domain $NAME: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log

  . /etc/wptt/echo-color
  check_thay_doi=$(md5sum /etc/shadow | cut -f1 -d ' ' >/tmp/passwd_user_thay_doi)
  passwd $User_name_vhost

  if [[ $(cat /tmp/passwd_user_thay_doi) != $(md5sum /etc/shadow | cut -f1 -d ' ') ]]; then
    _rundone "$thiet_lap PassWord cho username $User_name_vhost"

    kiem_tra_ton_tai_nhom=$(cat /etc/group | grep '^wptangtoc-ols:')
    if [[ $kiem_tra_ton_tai_nhom = '' ]]; then
      groupadd wptangtoc-ols >/dev/null 2>&1
    fi

    pkill -9 -u $User_name_vhost >/dev/null 2>&1
    usermod -a -G wptangtoc-ols $User_name_vhost

    # Copy file gốc của hệ thống
    cp -rf /etc/skel/. /usr/local/lsws/$NAME
    chown $User_name_vhost:$User_name_vhost /usr/local/lsws/$NAME/.*

    chown $User_name_vhost:$User_name_vhost /etc/wptt/vhost/.$NAME.conf
    chown -R root:wptangtoc-ols /etc/wptt-user
    chmod -R 750 /etc/wptt-user
    chown root:wptangtoc-ols /etc/wptt
    chown root:wptangtoc-ols /etc/wptt/vhost
    chown root:wptangtoc-ols /usr/bin/wptangtoc-user
    chmod 750 /usr/bin/wptangtoc-user
    chmod 750 /etc/wptt
    chmod 750 /etc/wptt/vhost

    sed -i '/wptangtoc/d' /usr/local/lsws/$NAME/.bashrc
    sed -i '/wptt/d' /usr/local/lsws/$NAME/.bashrc
    sed -i '/return/d' /usr/local/lsws/$NAME/.bashrc
    echo '[[ $- != *i* ]] && return' >>/usr/local/lsws/$NAME/.bashrc
    echo "alias 1='/etc/wptt-user/wptt-status'" >>/usr/local/lsws/$NAME/.bashrc
    echo "/etc/wptt-user/wptt-status" >>/usr/local/lsws/$NAME/.bashrc
    echo "export EDITOR=vi" >>/usr/local/lsws/$NAME/.bashrc

    # -----------------------------------------------------------------
    # SÁT CHIÊU ENTERPRISE: XÂY DỰNG CHROOT JAIL
    # -----------------------------------------------------------------
    JAIL_PATH="/usr/local/lsws/$NAME"
    echo "Đang đúc hệ điều hành thu nhỏ (Chroot Jail) cho $User_name_vhost..."

    # Nắn quyền chuỗi thư mục cha
    chown root:root /usr/local/lsws
    chmod 755 /usr/local/lsws
    chown root:root $JAIL_PATH
    chmod 755 $JAIL_PATH

    # =================================================================
    # [VÁ LỖI OLS NAMESPACE] Phá Namespace trước khi đập bỏ lồng cũ
    # =================================================================
    OLS_NS_PATH="/var/lsns/*/$NAME"
    if ls $OLS_NS_PATH 1>/dev/null 2>&1; then
      fuser -k -9 $OLS_NS_PATH/* $OLS_NS_PATH/*/mnt 2>/dev/null || true
      umount -fl $OLS_NS_PATH/*/mnt 2>/dev/null || true
      umount -fl $OLS_NS_PATH/* 2>/dev/null || true
      rm -rf /var/lsns/*/$NAME 2>/dev/null || true
    fi
    # =================================================================

    # 1. Dọn dẹp nhà giam cũ (nếu có)
    rm -rf $JAIL_PATH/{bin,lib,lib64,sbin,usr,dev,etc,tmp}

    # 2. Đổ móng chuẩn kiến trúc AlmaLinux 9
    mkdir -p $JAIL_PATH/usr/{bin,sbin,lib,lib64}
    mkdir -p $JAIL_PATH/{dev,etc,tmp,dev/pts}
    chmod 1777 $JAIL_PATH/tmp

    ln -s usr/bin $JAIL_PATH/bin
    ln -s usr/sbin $JAIL_PATH/sbin
    ln -s usr/lib $JAIL_PATH/lib
    ln -s usr/lib64 $JAIL_PATH/lib64

    # Rèn phần cứng ảo
    mknod -m 666 $JAIL_PATH/dev/null c 1 3 >/dev/null 2>&1 || true
    mknod -m 666 $JAIL_PATH/dev/zero c 1 5 >/dev/null 2>&1 || true
    mknod -m 666 $JAIL_PATH/dev/urandom c 1 9 >/dev/null 2>&1 || true
    mknod -m 666 $JAIL_PATH/dev/tty c 5 0 >/dev/null 2>&1 || true
    mknod -m 666 $JAIL_PATH/dev/ptmx c 5 2 >/dev/null 2>&1 || true

    # 3. Hàm Bốc Thuốc
    copy_to_jail() {
      local src="$1"
      local dest="$src"
      if [[ "$dest" == /lib64/* ]]; then dest="/usr/lib64/${dest#/lib64/}"; fi
      if [[ "$dest" == /lib/* ]]; then dest="/usr/lib/${dest#/lib/}"; fi
      if [[ "$dest" == /bin/* ]]; then dest="/usr/bin/${dest#/bin/}"; fi
      if [[ "$dest" == /sbin/* ]]; then dest="/usr/sbin/${dest#/sbin/}"; fi

      mkdir -p "$JAIL_PATH$(dirname "$dest")"
      cp -L "$src" "$JAIL_PATH$dest" 2>/dev/null
    }

    # 4. Bơm công cụ cho IT
    COMMANDS=(
      "/bin/bash" "/bin/ls" "/bin/mkdir" "/bin/cat" "/bin/rm" "/bin/cp" "/bin/mv" "/usr/bin/zip" "/usr/bin/unzip"
      "/usr/bin/mysql" "/usr/bin/mariadb" "/usr/bin/curl" "/usr/bin/clear"
      "/usr/bin/grep" "/usr/bin/tail" "/usr/bin/vi" "/usr/bin/nano" "/usr/bin/stat" "/usr/bin/tar" "/usr/bin/head" "/usr/bin/openssl"
      "/usr/bin/sed" "/usr/bin/awk" "/usr/bin/cut" "/usr/bin/tr" "/usr/bin/wc" "/usr/bin/gzip" "/usr/bin/du" "/usr/bin/nice" "/usr/bin/ionice"
      "/usr/bin/tput" "/usr/bin/php" "/usr/bin/find" "/usr/bin/xargs" "/usr/bin/chmod" "/usr/bin/mktemp" "/usr/bin/sleep" "/usr/bin/chown" "/usr/bin/nl"
      "/usr/bin/wget" "/usr/bin/env" "/usr/bin/date" "/usr/bin/which" "/usr/bin/mysqldump" "/usr/bin/mariadb-dump" "/usr/bin/stty" "/usr/bin/zcat" "/usr/bin/top"
    )
    if [ -f "/usr/local/bin/wp" ]; then COMMANDS+=("/usr/local/bin/wp"); fi
    if [ -f "/usr/bin/vim" ]; then COMMANDS+=("/usr/bin/vim"); fi
    if [ -f "/usr/bin/rsync" ]; then COMMANDS+=("/usr/bin/rsync"); fi
    if [ -f "/usr/bin/rclone" ]; then COMMANDS+=("/usr/bin/rclone"); fi
    if [ -f "/usr/bin/fzf" ]; then COMMANDS+=("/usr/bin/fzf"); fi
    if [ -f "/usr/bin/zstd" ]; then COMMANDS+=("/usr/bin/zstd"); fi
    if [ -f "/usr/bin/pv" ]; then COMMANDS+=("/usr/bin/pv"); fi

    for CMD in "${COMMANDS[@]}"; do
      if [ -x "$(readlink -f "$CMD" 2>/dev/null || echo "$CMD")" ]; then
        copy_to_jail "$CMD"
        LIBS=$(ldd "$CMD" 2>/dev/null | grep -oE '/[^ ]+')
        for LIB in $LIBS; do
          copy_to_jail "$LIB"
        done
      fi
    done

    # Bơm PHP
    PHP_INI=$(php -i 2>/dev/null | grep 'Loaded Configuration File' | awk '{print $NF}')
    PHP_SCAN_DIR=$(php -i 2>/dev/null | grep 'Scan this dir for additional .ini files' | awk '{print $NF}')
    PHP_EXT_DIR=$(php -i 2>/dev/null | grep '^extension_dir' | awk '{print $3}')

    if [[ -f "$PHP_INI" ]]; then copy_to_jail "$PHP_INI"; fi
    if [[ -d "$PHP_SCAN_DIR" ]]; then
      mkdir -p "$JAIL_PATH$PHP_SCAN_DIR"
      cp -a "$PHP_SCAN_DIR"/* "$JAIL_PATH$PHP_SCAN_DIR/" 2>/dev/null || true
    fi
    if [[ -d "$PHP_EXT_DIR" ]]; then
      mkdir -p "$JAIL_PATH$PHP_EXT_DIR"
      cp -a "$PHP_EXT_DIR"/* "$JAIL_PATH$PHP_EXT_DIR/" 2>/dev/null || true
      for ext in "$PHP_EXT_DIR"/*.so; do
        if [[ -f "$ext" ]]; then
          LIBS=$(ldd "$ext" 2>/dev/null | grep -oE '/[^ ]+')
          for LIB in $LIBS; do
            copy_to_jail "$LIB"
          done
        fi
      done
    fi

    copy_to_jail "/lib64/libtinfo.so.6"
    copy_to_jail "/lib64/libncursesw.so.6"
    ln -s bash $JAIL_PATH/usr/bin/sh 2>/dev/null || true

    copy_to_jail "/lib64/libnss_files.so.2"
    copy_to_jail "/lib64/libnss_dns.so.2"
    copy_to_jail "/lib64/libresolv.so.2"

    cp -L /etc/resolv.conf $JAIL_PATH/etc/ >/dev/null 2>&1 || true
    cp -L /etc/nsswitch.conf $JAIL_PATH/etc/ >/dev/null 2>&1 || true

    mkdir -p $JAIL_PATH/usr/share/terminfo
    cp -a /usr/share/terminfo/* $JAIL_PATH/usr/share/terminfo/ 2>/dev/null || true
    echo 'export TERM=xterm-256color' >>$JAIL_PATH/.bashrc

    # Từ điển
    mkdir -p $JAIL_PATH/usr/lib/locale $JAIL_PATH/usr/share/locale $JAIL_PATH/usr/lib64/gconv
    cp -a /usr/lib/locale/* $JAIL_PATH/usr/lib/locale/ 2>/dev/null || true
    cp -a /usr/share/locale/en_US* $JAIL_PATH/usr/share/locale/ 2>/dev/null || true
    cp -a /usr/lib64/gconv/* $JAIL_PATH/usr/lib64/gconv/ 2>/dev/null || true

    # Nối ống nước Database
    if grep -qi "ubuntu" /etc/*release 2>/dev/null; then
      DEFAULT_SOCK="/run/mysqld/mysqld.sock"
    else
      DEFAULT_SOCK="/var/lib/mysql/mysql.sock"
    fi
    REAL_SOCK=$(mariadb -N -e "select @@socket;" 2>/dev/null || echo "$DEFAULT_SOCK")

    if [ -S "$REAL_SOCK" ]; then
      mkdir -p $JAIL_PATH$(dirname "$REAL_SOCK")
      touch $JAIL_PATH$REAL_SOCK
      mount --bind "$REAL_SOCK" "$JAIL_PATH$REAL_SOCK"
    fi

    # Phân quyền User
    grep "^root:" /etc/passwd >$JAIL_PATH/etc/passwd
    grep "^$User_name_vhost:" /etc/passwd | sed "s|$JAIL_PATH|/|g" >>$JAIL_PATH/etc/passwd
    grep "^root:" /etc/group >$JAIL_PATH/etc/group
    grep "^wptangtoc-ols:" /etc/group >>$JAIL_PATH/etc/group
    grep "^$User_name_vhost:" /etc/group >>$JAIL_PATH/etc/group
    chown -R $User_name_vhost:$User_name_vhost $JAIL_PATH/bin

    # =======================================================
    # BƠM HỆ SINH THÁI MENU VÀO LỒNG (REAL-TIME CẬP NHẬT TỪ MÁY THẬT)
    # =======================================================
    mkdir -p $JAIL_PATH/etc/wptt
    mkdir -p $JAIL_PATH/etc/wptt-user
    mount --bind /etc/wptt $JAIL_PATH/etc/wptt
    mount --bind /etc/wptt-user $JAIL_PATH/etc/wptt-user
    touch $JAIL_PATH/usr/bin/wptangtoc-user 2>/dev/null || true
    mount --bind /usr/bin/wptangtoc-user $JAIL_PATH/usr/bin/wptangtoc-user

    # Inception OpenSSH
    mkdir -p $JAIL_PATH/usr/local/lsws
    ln -s / $JAIL_PATH/usr/local/lsws/$NAME 2>/dev/null || true

    # -----------------------------------------------------------------
    # NỐI ỐNG CRON (Bypass hoàn toàn PAM và Auditd bằng Fake Crontab)
    # -----------------------------------------------------------------
    # 1. Khởi tạo file cron thật trên Host
    touch /var/spool/cron/$User_name_vhost
    chown $User_name_vhost:root /var/spool/cron/$User_name_vhost
    chmod 600 /var/spool/cron/$User_name_vhost

    # 2. Tạo điểm nối trong lồng (Nằm ngay gốc / của User)
    CRON_JAIL_FILE="$JAIL_PATH/.cron_spool"
    touch "$CRON_JAIL_FILE"
    chown $User_name_vhost:$User_name_vhost "$CRON_JAIL_FILE"
    chmod 600 "$CRON_JAIL_FILE"

    # 3. Nối ống thông nhau
    mount --bind /var/spool/cron/$User_name_vhost "$CRON_JAIL_FILE"

    # 4. Xóa file crontab gốc bị dính lỗi PAM (nếu có)
    rm -f $JAIL_PATH/usr/bin/crontab

    # 5. Đúc lệnh Fake Crontab (Hoạt động mượt mà 100%)
    cat <<'EOF' >$JAIL_PATH/usr/bin/crontab
#!/bin/bash
USER_CRON="/.cron_spool"

if [[ "$1" == "-e" ]]; then
    TMP_FILE=$(mktemp)
    cat "$USER_CRON" > "$TMP_FILE" 2>/dev/null
    ${EDITOR:-vi} "$TMP_FILE"
    cat "$TMP_FILE" > "$USER_CRON"
    rm -f "$TMP_FILE"
    echo "crontab: installing new crontab"
elif [[ "$1" == "-l" ]]; then
    cat "$USER_CRON" 2>/dev/null
elif [[ "$1" == "-r" ]]; then
    > "$USER_CRON"
    echo "crontab: removing crontab"
elif [[ "$1" == "-" ]] || [[ ! -t 0 && -z "$1" ]]; then
    cat > "$USER_CRON"
    echo "crontab: installing new crontab"
else
    echo "crontab: usage error: unrecognized option"
    echo "usage: crontab [-e | -l | -r | -]"
fi
EOF
    chmod 755 $JAIL_PATH/usr/bin/crontab
    # -----------------------------------------------------------------

    usermod $User_name_vhost -s /bin/bash
    sed -i -e "/^#begin-WPTT_JAIL_$User_name_vhost/,/^#end-WPTT_JAIL_$User_name_vhost$/d" /etc/ssh/sshd_config 2>/dev/null || true
    sed -i "/# WPTT_JAIL_$User_name_vhost/,+6d" /etc/ssh/sshd_config 2>/dev/null || true

    cat <<EOF >>/etc/ssh/sshd_config
#begin-WPTT_JAIL_$User_name_vhost
Match User $User_name_vhost
    ChrootDirectory $JAIL_PATH
    AllowTcpForwarding no
    X11Forwarding no
#end-WPTT_JAIL_$User_name_vhost
EOF
    systemctl restart sshd 2>/dev/null || systemctl restart ssh 2>/dev/null
  else
    _runloi "$thiet_lap PassWord cho username $User_name_vhost"
    check_menu_wptangtoc_active=$1
    if [[ $check_menu_wptangtoc_active = "98" ]]; then
      exec /etc/wptt/wptt-domain-main 1
    fi
    exit
  fi

  /usr/local/lsws/bin/lswsctrl restart >/dev/null 2>&1
  clear

  echo -e "\n${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "Thông tin đăng nhập website $NAME"
  echo -e "${C_CYAN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
  left_text "Tài khoản USERNAME: $User_name_vhost"
  left_text "PassWord: ***************** (bạn vừa thiết lập vừa nãy)"
  port_ssh=$(grep -E '^\s*Port\s+[0-9]+' /etc/ssh/sshd_config | awk '{print $2}' | head -n 1)
  port_ssh=${port_ssh:-22} # Trả về 22 nếu kết quả rỗng

  ip=$(curl -sf --connect-timeout 5 --max-time 10 https://ipv4.icanhazip.com || curl -sf --connect-timeout 5 --max-time 10 https://checkip.amazonaws.com)
  left_text "Truy cập vào ssh  : ssh -p $port_ssh $User_name_vhost@$ip"
  left_text "Truy cập vào sftp : sftp -oPort=$port_ssh $User_name_vhost@$ip"
  left_text "Ghi chú: Môi trường hoạt động của tài khoản này đã được bảo vệ tuyệt đối (Chroot)."
  echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"
fi

# =================================================================
# TẮT ĐĂNG NHẬP (Khóa mõm, Rút Ống, Xóa lồng)
# =================================================================
if [[ $check = '' ]]; then
  if ! wptt_xac_nhan "Xác nhận bạn muốn tắt đăng nhập username của website $NAME" "Mã nguồn, DB đều được giữ nguyên" "Username của website $NAME không được phép trực tiếp login nữa" "Đồng ý (tắt đăng nhập riêng)" "Không đồng ý (Hủy thao tác)"; then
    [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-domain-main 1
    exit
  fi

  echo "Tắt đăng nhập username domain $NAME: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log
  _runing "$tat $dang_nhap domain user"

  usermod $User_name_vhost -s /sbin/nologin
  pkill -u $User_name_vhost >/dev/null 2>&1
  usermod -R wptangtoc-ols "$User_name_vhost" >/dev/null 2>&1
  chmod 700 /etc/wptt/vhost/.$NAME.conf
  chown root:root /etc/wptt/vhost/.$NAME.conf

  kiem_tra_ton_tai_nhom_con_thanh_vien_khac_khong=$(cat /etc/group | grep '^wptangtoc-ols:' | grep ',')
  if [[ $kiem_tra_ton_tai_nhom_con_thanh_vien_khac_khong = '' ]]; then
    groupdel wptangtoc-ols >/dev/null 2>&1
    chmod -R 700 /etc/wptt
    chown root:root /etc/wptt
    chown root:root /etc/wptt/vhost
    chmod 700 /etc/wptt
    chmod 700 /etc/wptt/vhost
    chown -R root:root /etc/wptt-user
    chmod -R 700 /etc/wptt-user
    chown root:root /usr/bin/wptangtoc-user
    chmod 700 /usr/bin/wptangtoc-user
  fi

  # Dọn dẹp SSH
  sed -i -e "/^#begin-WPTT_JAIL_$User_name_vhost/,/^#end-WPTT_JAIL_$User_name_vhost$/d" /etc/ssh/sshd_config 2>/dev/null || true
  sed -i "/# WPTT_JAIL_$User_name_vhost/,+6d" /etc/ssh/sshd_config 2>/dev/null || true
  systemctl restart sshd 2>/dev/null || systemctl restart ssh 2>/dev/null

  # [BẮT BUỘC] PHẢI KHAI BÁO BIẾN TRƯỚC VÀ RÚT ỐNG TRƯỚC KHI RM -RF
  JAIL_PATH="/usr/local/lsws/$NAME"

  # 1. Rút ống Menu WPTangToc
  umount -fl $JAIL_PATH/etc/wptt 2>/dev/null || true
  umount -fl $JAIL_PATH/etc/wptt-user 2>/dev/null || true
  umount -fl $JAIL_PATH/usr/bin/wptangtoc-user 2>/dev/null || true

  # Rút ống Cron (Tháo chốt trước khi đập)
  umount -fl $JAIL_PATH/.cron_spool 2>/dev/null || true

  # 2. Rút ống Database MariaDB
  # Nối ống nước Database
  if grep -qi "ubuntu" /etc/*release 2>/dev/null; then
    DEFAULT_SOCK="/run/mysqld/mysqld.sock"
  else
    DEFAULT_SOCK="/var/lib/mysql/mysql.sock"
  fi
  REAL_SOCK=$(mariadb -N -e "select @@socket;" 2>/dev/null || echo "$DEFAULT_SOCK")

  umount -fl "$JAIL_PATH$REAL_SOCK" 2>/dev/null || true

  # =================================================================
  # [VÁ LỖI OLS NAMESPACE] Phá Namespace trước khi đập bỏ lồng
  # =================================================================
  OLS_NS_PATH="/var/lsns/*/$NAME"
  if ls $OLS_NS_PATH 1>/dev/null 2>&1; then
    fuser -k -9 $OLS_NS_PATH/* $OLS_NS_PATH/*/mnt 2>/dev/null || true
    umount -fl $OLS_NS_PATH/*/mnt 2>/dev/null || true
    umount -fl $OLS_NS_PATH/* 2>/dev/null || true
    rm -rf /var/lsns/*/$NAME 2>/dev/null || true
  fi
  # =================================================================

  # 3. Đập bỏ lồng
  rm -rf $JAIL_PATH/{bin,lib,lib64,sbin,usr,dev,etc,tmp,var}

  # 4. Restart lại OLS để trả lại socket mượt mà
  /usr/local/lsws/bin/lswsctrl restart >/dev/null 2>&1

  _rundone "$tat $dang_nhap domain user"
fi

check_menu_wptangtoc_active=$1
if [[ $check_menu_wptangtoc_active = "98" ]]; then
  exec /etc/wptt/wptt-domain-main 1
fi
