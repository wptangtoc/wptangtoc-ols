function huong_dan() {
  Tính năng Chuyển hướng domain [Domain Redirection] là một kỹ thuật tự động điều hướng người dùng và các công cụ tìm kiếm từ một địa chỉ tên miền này sang một địa chỉ tên miền khác.

  Nói một cách đơn giản, khi ai đó gõ vào hoặc nhấp vào một tên miền A, thay vì hiển thị nội dung của tên miền A, trình duyệt của họ sẽ tự động được chuyển đến tên miền B [hoặc một trang cụ thể trên tên miền B].

  Mục Đích Chính
  * Trỏ nhiều tên miền về một website: Nếu bạn sở hữu nhiều biến thể tên miền [ví dụ: tencongty.com, tencongty.vn, ten-cong-ty.com], bạn có thể chuyển hướng tất cả chúng về một tên miền chính duy nhất.
  * Sau khi đổi tên miền website: Chuyển hướng từ tên miền cũ sang tên miền mới để không mất khách truy cập và duy trì giá trị SEO.
  * Chuyển hướng tên miền phụ [subdomain]: Ví dụ, chuyển blog.tenmien.com sang blog-tenmien.com.
  * URL thân thiện/Rút gọn link: Tạo các đường link ngắn, dễ nhớ để chuyển hướng đến các URL dài hơn, phức tạp hơn.
  * Thông báo bảo trì website: Tạm thời chuyển hướng người dùng đến một trang thông báo khi website đang được bảo trì.

  Tính năng chuyển hướng domain rất quan trọng để quản lý truy cập, đảm bảo trải nghiệm người dùng tốt và duy trì hiệu quả SEO cho website của bạn.
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null # Nạp thư viện UI Xác nhận

clear
echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}${quan_ly_domain} ➜ ${chuyen_huong_domain}${C_RESET}"
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

NAME=$1
NAME2=$2
[[ "$NAME" == "98" ]] && NAME=""

export LC_ALL=en_US.UTF-8
export LANG=en_US.UTF-8
stty iutf8

# ==============================================================================
# BƯỚC 1: NHẬP VÀ KIỂM TRA DOMAIN GỐC (NGUỒN)
# ==============================================================================
if [[ -z "$NAME" ]]; then
  echo -e "${C_YELLOW}Nhập domain bạn muốn chuyển hướng đi (Ví dụ: cu.com, old.vn)${C_RESET}"
  echo -en "${C_CYAN}Tên miền Nguồn [0=${exit_thoat:-Thoát}]: ${C_RESET}"
  read -r NAME
fi

[[ "$NAME" == "0" || -z "$NAME" ]] && {
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-domain-main 1
  return 2>/dev/null || exit
}

NAME=$(echo "$NAME" | tr '[:upper:]' '[:lower:]' | xargs)
if [[ $(echo "$NAME" | grep '://') ]]; then NAME=$(echo "$NAME" | cut -f3 -d '/'); fi
if [[ $(echo "$NAME" | grep '^www\.') ]]; then NAME=$(echo "$NAME" | sed 's/^www.//g'); fi

if [ $(echo "$NAME" | wc -w) -gt 1 ] || [[ "$NAME" == "${NAME/./}" ]]; then
  echo -e "\n${C_RED}❌ Lỗi: Domain $NAME nhập không đúng định dạng (có khoảng trắng hoặc thiếu dấu chấm)!${C_RESET}"
  sleep 3
  exec /etc/wptt/wptt-domain-main 1
fi

if [[ ! "$NAME" =~ ^[a-z0-9]+([a-z0-9.-]*[a-z0-9]+)?\.[a-z]{2,}$ ]]; then
  echo -e "\n${C_RED}❌ Lỗi: Domain $NAME chứa ký tự không hợp lệ hoặc sai cấu trúc.${C_RESET}"
  [[ "${1:-}" == "98" ]] && {
    read -r -p "Bấm phím Enter để quay lại Menu... " dummy
    exec /etc/wptt/wptt-domain-main 1
  }
  return 2>/dev/null || exit 1
fi

# ==============================================================================
# BƯỚC 2: NHẬP VÀ KIỂM TRA DOMAIN ĐÍCH
# ==============================================================================
echo ""
if [[ -z "$NAME2" ]]; then
  echo -e "${C_YELLOW}Nhập domain bạn muốn chuyển hướng tới (Ví dụ: moi.com, www.moi.vn)${C_RESET}"
  echo -en "${C_CYAN}Tên miền Đích [0=${exit_thoat:-Thoát}]: ${C_RESET}"
  read -r NAME2
fi

[[ "$NAME2" == "0" || -z "$NAME2" ]] && {
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-domain-main 1
  return 2>/dev/null || exit
}

NAME2=$(echo "$NAME2" | tr '[:upper:]' '[:lower:]' | xargs)
if [[ $(echo "$NAME2" | grep '://') ]]; then NAME2=$(echo "$NAME2" | cut -f3 -d '/'); fi

NAME2www=""
if [[ $(echo "$NAME2" | grep '^www\.') ]]; then
  NAME2=$(echo "$NAME2" | sed 's/^www.//g')
  NAME2www='www.'
fi

if [[ ! "$NAME2" =~ ^[a-z0-9]+([a-z0-9.-]*[a-z0-9]+)?\.[a-z]{2,}$ ]]; then
  echo -e "\n${C_RED}❌ Lỗi: Domain Đích chứa ký tự không hợp lệ hoặc sai cấu trúc.${C_RESET}"
  [[ "${1:-}" == "98" ]] && {
    read -r -p "Bấm phím Enter để quay lại Menu... " dummy
    exec /etc/wptt/wptt-domain-main 1
  }
  return 2>/dev/null || exit 1
fi

if [[ "$NAME" == "$NAME2" ]]; then
  echo -e "\n${C_RED}❌ Lỗi: Bạn không thể chuyển hướng vòng lặp từ $NAME sang chính nó!${C_RESET}"
  sleep 3
  exec /etc/wptt/wptt-domain-main 1
fi

# ==============================================================================
# BƯỚC 3: KIỂM TRA TRẠNG THÁI VÀ XÁC NHẬN GHI ĐÈ
# ==============================================================================
path="/etc/wptt/vhost/.$NAME.conf"
pathcheck_chuyen_huong="/etc/wptt/chuyen-huong/.$NAME.conf"
USER=${NAME//[-._]/}

if [[ -f "$pathcheck_chuyen_huong" ]]; then
  current_target=$(sed '/^#begin-chuyen-huong-domain-wptangtoc/,/^#end-chuyen-huong-domain-wptangtoc$/!d' "/usr/local/lsws/$NAME/html/.htaccess" | grep '301' | grep -o -E '([a-zA-Z0-9-]+\.)+[a-zA-Z0-9-]{2,}' | tail -n 1)

  echo -e "\n${C_YELLOW}CHÚ Ý: Domain ${C_BOLD_WHITE}$NAME${C_YELLOW} ĐÃ ĐƯỢC CHUYỂN HƯỚNG TRƯỚC ĐÓ!${C_RESET}"
  echo -e "Đang chuyển hướng tới: ${C_CYAN}${current_target:-Không xác định}${C_RESET}\n"

  if ! wptt_xac_nhan "Bạn có muốn XÓA thiết lập cũ và tạo chuyển hướng MỚI sang $NAME2 không?" "" "" "Đồng ý Ghi đè" "Hủy bỏ"; then
    echo -e "${C_YELLOW}Đã hủy thao tác.${C_RESET}"
    sleep 2
    [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-domain-main 1
    return 2>/dev/null || exit
  fi
fi

# ==============================================================================
# HÀM THAY THẾ WEBSITE CHÍNH (NẾU CẦN)
# ==============================================================================
function thay_name_domain_chinh() {
  local NAME_OLD=$1
  local NAME_NEW=$2

  sed -i "/Website_chinh/d" /etc/wptt/.wptt.conf
  echo "Website_chinh=$NAME_NEW" >>/etc/wptt/.wptt.conf
  sed -i "/keyFile/d" /usr/local/lsws/conf/httpd_config.conf
  sed -i "/certFile/d" /usr/local/lsws/conf/httpd_config.conf
  sed -i "/CACertFile/d" /usr/local/lsws/conf/httpd_config.conf

  if [[ -f "/etc/letsencrypt/live/$NAME_NEW/cert.pem" ]]; then
    sed -i "/https/a keyFile              \/etc\/letsencrypt\/live\/$NAME_NEW\/privkey.pem" /usr/local/lsws/conf/httpd_config.conf
    sed -i "/https/a certFile             \/etc\/letsencrypt\/live\/$NAME_NEW\/cert.pem" /usr/local/lsws/conf/httpd_config.conf
    sed -i "/https/a CACertFile           \/etc\/letsencrypt\/live\/$NAME_NEW\/chain.pem" /usr/local/lsws/conf/httpd_config.conf
  else
    sed -i "/https/a keyFile              \/etc\/wptt-ssl-tu-ky\/$NAME_NEW\/$NAME_NEW.key" /usr/local/lsws/conf/httpd_config.conf
    sed -i "/https/a certFile             \/etc\/wptt-ssl-tu-ky\/$NAME_NEW\/cert.crt" /usr/local/lsws/conf/httpd_config.conf
  fi

  if [[ -n "$id_dang_nhap_phpmyadmin" ]]; then
    cp -rf "/usr/local/lsws/$NAME_OLD/html/phpmyadmin" "/usr/local/lsws/$NAME_NEW/html/"
    rm -rf "/usr/local/lsws/$NAME_OLD/html/phpmyadmin"
    mkdir -p "/usr/local/lsws/$NAME_NEW/passwd"
    cp -f "/usr/local/lsws/$NAME_OLD/passwd/.phpmyadmin" "/usr/local/lsws/$NAME_NEW/passwd"

    if $(cat /etc/*release | grep -q "Ubuntu"); then tuong_thich_nhom_litespeed="nogroup"; else tuong_thich_nhom_litespeed="nobody"; fi
    chown -R nobody:$tuong_thich_nhom_litespeed "/usr/local/lsws/$NAME_NEW/passwd"

    sed -i -e '/^realm '${NAME_OLD}'phpphpmyadmin/,/^}$/d' "/usr/local/lsws/conf/vhosts/$NAME_OLD/$NAME_OLD.conf"
    sed -i -e '/^context \/phpmyadmin\//,/^}$/d' "/usr/local/lsws/conf/vhosts/$NAME_OLD/$NAME_OLD.conf"

    echo 'realm '${NAME_NEW}phpphpmyadmin' {
        userDB  {
        location              /usr/local/lsws/'$NAME_NEW'/passwd/.phpmyadmin
    }
}
context /phpmyadmin/ {
location                phpmyadmin/
allowBrowse             1
realm                   '${NAME_NEW}phpphpmyadmin'

accessControl  {
allow                 ALL
}

rewrite  {

}
addDefaultCharset     off

phpIniOverride  {

}
}' >>"/usr/local/lsws/conf/vhosts/$NAME_NEW/$NAME_NEW.conf"
  fi
}

# Xử lý Logic Đổi Website Chính bằng UX Bo Cong
if [[ "$Website_chinh" == "$NAME" ]]; then
  if [[ -d "/usr/local/lsws/$NAME2/html" ]]; then
    thay_name_domain_chinh "$NAME" "$NAME2"
  else
    if (($(ls -At /etc/wptt/vhost 2>/dev/null | wc -l) >= 2)) && [[ "${1:-}" == "98" ]]; then
      echo -e "\n${C_YELLOW}CẢNH BÁO: Tên miền bạn đang chuyển hướng ($NAME) hiện đang là WEBSITE CHÍNH (Đại diện) của hệ thống!${C_RESET}"
      echo -e "Bạn cần phải chọn một tên miền KHÁC đang tồn tại để thay thế làm Website Chính."

      box_inner_width=${box_inner_width:-71}
      selects=()
      for entry in $(ls -A /etc/wptt/vhost | grep -v '^\.\.conf$' | sort -uV); do
        NAME_CHINH_OPTION=$(echo "$entry" | sed 's/^.//' | sed 's/.conf//')
        if [[ "$NAME_CHINH_OPTION" == ?*.?* && "$NAME_CHINH_OPTION" != "$Website_chinh" ]]; then
          selects+=("$NAME_CHINH_OPTION")
        fi
      done

      if [[ ${#selects[@]} -eq 0 ]]; then
        echo -e "\n${C_RED}❌ Hệ thống không còn website nào khác để gán làm Website chính!${C_RESET}"
        echo -e "Vui lòng thêm một website mới trước khi chuyển hướng website chính hiện tại."
        exec /etc/wptt/wptt-domain-main 1
      fi

      echo -e "\n${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
      center_text "${C_YELLOW}CHỌN DOMAIN LÀM WEBSITE CHÍNH MỚI${C_RESET}"
      echo -e "${C_CYAN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
      local i=1
      for domain in "${selects[@]}"; do
        local item_text=$(printf "  ${C_CYAN}%3d)${C_RESET} ${C_BOLD_WHITE}%s${C_RESET}" "$i" "$domain")
        local clean_text=$(printf "  %3d) %s" "$i" "$domain")
        local item_len=$(echo -n "$clean_text" | awk '{print length($0)}')
        local pad=$((box_inner_width - item_len))
        [[ $pad -lt 0 ]] && pad=0
        echo -e "${C_CYAN}│${C_RESET}${item_text}$(printf '%*s' "$pad" "")${C_CYAN}│${C_RESET}"
        ((i++))
      done
      echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯${C_RESET}"

      while true; do
        echo -en "${C_CYAN}👉 Nhập lựa chọn (1-${#selects[@]}) [0=Hủy bỏ]: ${C_RESET}"
        read -r REPLY
        if [[ "$REPLY" == "0" ]]; then
          exec /etc/wptt/wptt-domain-main 1
          exit 0
        fi
        if [[ "$REPLY" =~ ^[0-9]+$ ]] && [ "$REPLY" -ge 1 ] && [ "$REPLY" -le ${#selects[@]} ]; then
          action_index=$((REPLY - 1))
          NAME_CHINH_OPTION="${selects[$action_index]}"
          break
        else
          echo -e "${C_RED}❌ Lựa chọn không hợp lệ! Vui lòng chọn lại.${C_RESET}"
        fi
      done
      thay_name_domain_chinh "$NAME" "$NAME_CHINH_OPTION"
    fi
  fi
fi

echo "Chuyển hướng website $NAME về website $NAME2 : $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log

# ==============================================================================
# NHÁNH 1: WEBSITE ĐÃ TỒN TẠI (CHỈ CẦN TIÊM HTACCESS)
# ==============================================================================
echo ""
_runing "Đang thiết lập chuyển hướng $NAME sang $NAME2..."

if [[ -d "/usr/local/lsws/$NAME/html" ]]; then
  if [[ -f "/etc/wptt/vhost/.$NAME.conf" ]]; then
    . "/etc/wptt/vhost/.$NAME.conf"
    if [[ -n "$vhost_chuyen_htaccess" ]]; then
      . /etc/wptt/wptt-vhost-chuyen-ve-htaccess "$NAME" >/dev/null 2>&1
    fi
  fi

  echo '
#begin-chuyen-huong-domain-wptangtoc
RewriteEngine On
RewriteCond %{HTTP_HOST} ^'$NAME' [NC,OR]
RewriteCond %{HTTP_HOST} ^www.'$NAME' [NC]
RewriteCond %{REQUEST_URI} !.*well-known.*$ [NC]
RewriteRule (.*)$ https://'$NAME2www''$NAME2'/$1 [L, R=301,NC]
#end-chuyen-huong-domain-wptangtoc
' >"/usr/local/lsws/$NAME/html/.htaccess"

  mkdir -p /etc/wptt/chuyen-huong
  echo "" >"/etc/wptt/chuyen-huong/.$NAME.conf"

  [[ -d "/usr/local/lsws/$NAME/luucache" ]] && rm -rf "/usr/local/lsws/$NAME/luucache"

  if [[ -f "/etc/wptt/vhost/.$NAME.conf" ]]; then
    mkdir -p /etc/wptt/vhost_bk
    mv "/etc/wptt/vhost/.$NAME.conf" /etc/wptt/vhost_bk/
  fi

  _rundone "Cập nhật luật chuyển hướng thành công"
  /usr/local/lsws/bin/lswsctrl restart >/dev/null 2>&1

  # Bỏ qua Nhánh 2 bằng cách nhảy xuống cuối cùng
  GOTO_FINISH="yes"
fi

# ==============================================================================
# NHÁNH 2: TẠO VHOST MỚI ĐỂ HỨNG CHUYỂN HƯỚNG
# ==============================================================================
if [[ -z "$GOTO_FINISH" ]]; then
  # Giới hạn User Linux 32 chars
  check_ky_tu=$(echo ${#USER})
  if ((check_ky_tu > 32)); then USER=$(echo "$USER" | cut -c 1-30); fi

  useradd -p -m -d "/usr/local/lsws/$NAME" "$USER" >/dev/null 2>&1
  if ! id "$USER" &>/dev/null; then
    random=$(openssl rand -base64 32 | tr -dc 'a-zA-Z0-9' | head -c 2)
    USER=${NAME//[-._]/$random}
    USER=$(echo "$USER" | tr '[:upper:]' '[:lower:]')
    check_ky_tu2=$(echo ${#USER})
    if ((check_ky_tu2 > 32)); then USER=$(echo "$USER" | cut -c 1-30); fi
    useradd -p -m -d "/usr/local/lsws/$NAME" "$USER" >/dev/null 2>&1
  fi

  if ! id "$USER" &>/dev/null; then
    _runloi "Tạo tài khoản Linux thất bại"
    echo -e "${C_RED}❌ Lỗi: Hệ điều hành không thể tạo user mới!${C_RESET}"
    exec /etc/wptt/wptt-domain-main 1
  fi

  usermod "$USER" -s /sbin/nologin

  work_cpucore='1024'
  cpucore=$(grep -c ^processor /proc/cpuinfo)
  max_client=$((work_cpucore * cpucore * 2))
  tong_ram_byte=$(awk '/MemTotal/ {print $2}' /proc/meminfo)
  rong_ram_mb=$(echo "scale=0;${tong_ram_byte}/1024" | bc)
  [[ -z "$rong_ram_mb" ]] && rong_ram_mb="2048"

  echo "virtualhost $NAME {
    vhRoot                  /usr/local/lsws/$NAME/
    configFile              /usr/local/lsws/conf/vhosts/$NAME/$NAME.conf
    allowSymbolLink         1
    enableScript            1
    restrained              1
    maxKeepAliveReq         1000
    setUIDMode              2
    user                    $USER
    group                   $USER
  }" >>/usr/local/lsws/conf/httpd_config.conf
  sed -i "/listener http/a map 		$NAME $NAME" /usr/local/lsws/conf/httpd_config.conf
  mkdir -p "/usr/local/lsws/conf/vhosts/$NAME/"
  touch "/usr/local/lsws/conf/vhosts/$NAME/$NAME.conf"

  NAMEPHP=${NAME//[-._]/}

  echo "docRoot                   /usr/local/lsws/$NAME/html
  vhDomain                  $NAME
  enableGzip                1
  cgroups                   0
  index  {
    useServer               0
    indexFiles              index.html index.php
    autoIndex               0
  }
  scripthandler  {
    add                     lsapi:$NAMEPHP php
  }
  accessControl  {
    allow                   *
  }
  lsrecaptcha  {
    enabled                 1
    type                    0
  }
  namespace                 2
  extprocessor $NAMEPHP {
    type                    lsapi
    address                 uds://tmp/lshttpd/$NAMEPHP.sock
    maxConns                30
    env                     PHP_LSAPI_CHILDREN=30
    env                     LSAPI_AVOID_FORK=200M
    initTimeout             60
    retryTimeout            0
    pcKeepAliveTimeout      5
    respBuffer              0
    autoStart               1
    path                    /usr/local/lsws/lsphp74/bin/lsphp
    backlog                 100
    instances               1
    extUser                 $USER
    extGroup                $USER
    runOnStartUp            2
    priority                0
    memSoftLimit            ${rong_ram_mb}M
    memHardLimit            ${rong_ram_mb}M
    procSoftLimit           $max_client
    procHardLimit           $max_client
  }
  context / {
    location                /usr/local/lsws/$NAME/html
    allowBrowse             1
    extraHeaders            <<<END_extraHeaders
X-XSS-Protection 1;mode=block
X-Frame-Options SAMEORIGIN
Referrer-Policy strict-origin-when-cross-origin
X-Content-Type-Options nosniff
X-Powered-By WPTangTocOLS
permissions-policy accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=()
    END_extraHeaders
    rewrite  {
    }
    addDefaultCharset       off
    phpIniOverride  {
    }
  }
  rewrite  {
    enable                  1
    autoLoadHtaccess        1
  /usr/local/lsws/$NAME/html/.htaccess
  }
  vhssl  {
    keyFile                 /etc/wptt-ssl-tu-ky/$NAME/$NAME.key
    certFile                /etc/wptt-ssl-tu-ky/$NAME/cert.crt
    certChain               0
    sslProtocol             24
    renegProtection         1
    sslSessionCache         1
    sslSessionTickets       1
    enableSpdy              15
    enableQuic              1
  }
  module cache {
  checkPrivateCache   1
  checkPublicCache    1
  maxCacheObjSize     10000000
  maxStaleAge         200
  qsCache             1
  reqCookieCache      1
  respCookieCache     1
  ignoreReqCacheCtrl  1
  ignoreRespCacheCtrl 0
  storagePath /usr/local/lsws/$NAME/luucache
  enableCache         0
  expireInSeconds     3600
  enablePrivateCache  0
  privateExpireInSeconds 3600
    ls_enabled              1
  }
  context /.well-known/acme-challenge {
    location                /usr/local/lsws/Example/html/.well-known/acme-challenge
    allowBrowse             1
    rewrite  {
        enable                  0
    }
    addDefaultCharset       off
    phpIniOverride  {
    }
  }
  " >"/usr/local/lsws/conf/vhosts/$NAME/$NAME.conf"

  hostname_custom=$(cat "/usr/local/lsws/conf/vhosts/$Website_chinh/$Website_chinh.conf" 2>/dev/null | grep 'X-Powered-By' | cut -f2 -d ' ' | sort -u)
  if [[ -z "$hostname_custom" || "$hostname_custom" != 'WPTangTocOLS' ]]; then
    sed -i '/X-Powered-By/d' "/usr/local/lsws/conf/vhosts/$NAME/$NAME.conf"
  fi
  if [[ "$hostname_custom" != 'WPTangTocOLS' && -n "$hostname_custom" ]]; then
    sed -i "/extraHeaders /a X-Powered-By $hostname_custom" "/usr/local/lsws/conf/vhosts/$NAME/$NAME.conf"
  fi
  unset hostname_custom

  # Khởi tạo SSL Tự ký (Hứng Request)
  mkdir -p "/etc/wptt-ssl-tu-ky/$NAME"
  cd "/etc/wptt-ssl-tu-ky/$NAME" || exit
  openssl req -new -newkey rsa:2048 -nodes -keyout "$NAME.key" -out "$NAME.csr" -subj "/C=VN/ST=Hanoi/L=Hanoi/O=wptangtoc ols/OU=IT Department/CN=$NAME/emailAddress=admin@example.com" >/dev/null 2>&1
  openssl x509 -req -in "$NAME.csr" -signkey "$NAME.key" -out cert.crt -days 3650 >/dev/null 2>&1

  if $(cat /etc/*release | grep -q "Ubuntu"); then tuong_thich_nhom_litespeed="nogroup"; else tuong_thich_nhom_litespeed="nobody"; fi

  chown -R lsadm:$tuong_thich_nhom_litespeed "/usr/local/lsws/conf/vhosts/$NAME"

  php_version=$(php -v | grep cli | grep -oP 'PHP \K[0-9]+\.[0-9]+')
  php_ver_chon=${php_version//[-._]/}
  sed -E -i "s/lsphp[0-9]+/lsphp$php_ver_chon/g" "/usr/local/lsws/conf/vhosts/$NAME/$NAME.conf"

  chown -R lsadm:nobody "/usr/local/lsws/conf/vhosts/$NAME"
  chmod -R 750 "/usr/local/lsws/conf/vhosts/$NAME"
  mkdir -p "/usr/local/lsws/$NAME/html"
  mkdir -p "/usr/local/lsws/$NAME/luucache"
  chmod 755 "/usr/local/lsws/$NAME"
  chmod 755 "/usr/local/lsws/$NAME/html"

  useradd -p -m -d "/usr/local/lsws/$NAME" "$USER" >/dev/null 2>&1
  chown -R "$USER:$USER" "/usr/local/lsws/$NAME/html"

  # Tiêm Htaccess
  echo '
#begin-chuyen-huong-domain-wptangtoc
RewriteEngine On
RewriteCond %{HTTP_HOST} ^'$NAME' [NC,OR]
RewriteCond %{HTTP_HOST} ^www.'$NAME' [NC]
RewriteCond %{REQUEST_URI} !.*well-known.*$ [NC]
RewriteRule (.*)$ https://'$NAME2www''$NAME2'/$1 [L, R=301,NC]
#end-chuyen-huong-domain-wptangtoc
' >"/usr/local/lsws/$NAME/html/.htaccess"

  mkdir -p /etc/wptt/chuyen-huong
  touch "/etc/wptt/chuyen-huong/.$NAME.conf"

  _rundone "Khởi tạo Virtual Host phụ thành công"
  /usr/local/lsws/bin/lswsctrl restart >/dev/null 2>&1
fi

# ==============================================================================
# KIỂM TRA DNS VÀ IN BÁO CÁO BO CONG
# ==============================================================================
echo -e "\n${C_GREEN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_BOLD_WHITE}HOÀN TẤT CHUYỂN HƯỚNG TÊN MIỀN (301 REDIRECT)${C_RESET}"
echo -e "${C_GREEN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
left_text "Tên miền gốc  : ${C_YELLOW}$NAME${C_RESET}" 2
left_text "Chuyển hướng  : ${C_GREEN}$NAME2www$NAME2${C_RESET}" 2
echo -e "${C_GREEN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

# Kiểm tra DNS
checkdns=$(host "$NAME" 2>/dev/null | grep -Eo -m 1 '[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}')
if [[ -z "$checkdns" ]]; then
  checkdns=$(nslookup "$NAME" 2>/dev/null | grep Address | cut -f5 | grep -Eo -m 1 '[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}')
fi

ip=$(curl -skf --connect-timeout 5 --max-time 10 https://ipv4.icanhazip.com || curl -skf --connect-timeout 5 --max-time 10 https://checkip.amazonaws.com | grep -E -o '([0-9]{1,3}\.){3}[0-9]{1,3}')

if [[ "$checkdns" != "$ip" ]]; then
  echo -e "${C_YELLOW}CHÚ Ý QUAN TRỌNG VỀ DNS:${C_RESET}"
  if [[ -z "$checkdns" ]]; then
    echo -e "Tên miền ${C_BOLD_WHITE}$NAME${C_RESET} hiện chưa được trỏ IP."
    echo -e "Bạn vui lòng trỏ bản ghi A về IP: ${C_GREEN}$ip${C_RESET} để luật chuyển hướng hoạt động."
  else
    echo -e "Tên miền ${C_BOLD_WHITE}$NAME${C_RESET} đang trỏ đến IP: $checkdns"
    echo -e "Hãy đổi lại bản ghi A về IP máy chủ hiện tại: ${C_GREEN}$ip${C_RESET}"
  fi
  echo ""
fi

# Các kịch bản ping/check downtime của hệ thống
if [[ $download_api ]]; then
  if [[ -f /etc/wptt/add-one/check.sh ]]; then
    if [[ $email_check_downtime && $telegram_id ]]; then
      . /etc/wptt/add-one/check.sh $telegram_id $telegram_api $email >/dev/null 2>&1
    fi
    if [[ -z $email_check_downtime && $telegram_id ]]; then
      . /etc/wptt/add-one/check.sh $telegram_id $telegram_api >/dev/null 2>&1
    fi
    if [[ $email_check_downtime && -z $telegram_id ]]; then
      . /etc/wptt/add-one/check.sh $email_check_downtime >/dev/null 2>&1
    fi
  fi
fi

[[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-domain-main 1
