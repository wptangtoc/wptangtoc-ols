#!/bin/bash
# @author: Gia Tuấn
# @website: https://wptangtoc.com
# @since: 2026

function huong_dan() {
  Alias domain [hay còn gọi là Parked Domain, Tên miền bí danh] là một tên miền bổ sung được sử dụng để trỏ về một tên miền chính [domain chính]. Khi người dùng truy cập vào Parked domain, họ sẽ tự động được chuyển hướng đến tên miền chính. Nói một cách đơn giản: Tên miền chính: Giống như địa chỉ nhà chính của bạn.
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null

clear
echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}QUẢN LÝ DOMAIN ➜ THIẾT LẬP PARKED / ALIAS DOMAIN${C_RESET}"
echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯${C_RESET}"

. /etc/wptt/tenmien
lua_chon_NAME "Gốc muốn alias vào"
domain="$NAME"
path_conf="/etc/wptt/vhost/.$domain.conf"

if [[ ! -f "$path_conf" || "$NAME" == "0" ]]; then
  echo -e "\n${C_RED}❌ Lỗi: Website không tồn tại trên hệ thống hoặc sếp chưa chọn.${C_RESET}"
  sleep 2
  [[ $1 == "98" ]] && exec /etc/wptt/wptt-domain-main 1
  exit
fi

# ==============================================================================
# 3. NHẬP DOMAIN ALIAS MỚI
# ==============================================================================
echo -e "\n${C_CYAN}➜ Nhập tên miền mới sếp muốn thêm Alias (Ví dụ: alias.com):${C_RESET}"
read -p "   Lựa chọn [0 để thoát]: " NAME2

if [[ "$NAME2" == "0" || -z "$NAME2" ]]; then
  [[ $1 == "98" ]] && exec /etc/wptt/wptt-domain-main 1
  exit
fi

# Kiểm tra định dạng domain
if [[ "$NAME2" != *.* ]]; then
  echo -e "${C_RED}❌ Lỗi: Tên miền '$NAME2' không đúng định dạng.${C_RESET}"
  sleep 2
  exec "$0" "$1"
fi

# Kiểm tra xem domain alias đã tồn tại chưa
if [[ -f "/etc/wptt/vhost/.$NAME2.conf" ]]; then
  echo -e "${C_RED}❌ Lỗi: Tên miền '$NAME2' đã tồn tại như một website chính thức trên VPS.${C_RESET}"
  echo -e "${C_YELLOW}Vui lòng xóa website '$NAME2' trước khi gán nó làm Alias.${C_RESET}"
  sleep 3
  [[ $1 == "98" ]] && exec /etc/wptt/wptt-domain-main 1
  exit
fi

# ==============================================================================
# 4. XỬ LÝ SSL (SỬ DỤNG UI XÁC NHẬN)
# ==============================================================================
xacnhan_da_tro_dns='0'
if [[ -f "/etc/letsencrypt/live/$domain/cert.pem" ]]; then
  if wptt_xac_nhan "Sếp có muốn tự động cài đặt SSL cho Alias Domain này không?" "Website gốc đã có SSL." "Sếp cần trỏ IP trước khi thực hiện." "Có, cài đặt luôn" "Không, để sau"; then
    
    # Kiểm tra IP
    checkdns=$(host "$NAME2" | grep -Eo -m 1 '[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}')
    [[ -z "$checkdns" ]] && checkdns=$(nslookup "$NAME2" 2>/dev/null | grep Address | tail -n1 | awk '{print $2}')
    
    ip_vps=$(curl -s --connect-timeout 5 ipv4.icanhazip.com)
    
    if [[ "$checkdns" != "$ip_vps" ]]; then
      echo -e "\n${C_RED}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
      center_text "${C_BOLD_WHITE}DNS CHƯA TRỎ VỀ VPS${C_RESET}"
      center_text "Domain: ${C_YELLOW}$NAME2${C_RESET} | IP Hiện tại: ${C_RED}${checkdns:-Không có}${C_RESET}"
      center_text "Vui lòng trỏ về IP VPS: ${C_GREEN}$ip_vps${C_RESET}"
      echo -e "${C_RED}╰──────────────────────────────────────────────────────────────────────────────╯${C_RESET}"
      echo -e "\n${C_YELLOW}Cài đặt SSL sẽ bị bỏ qua. Sếp có thể cài lại sau khi trỏ DNS.${C_RESET}"
      sleep 5
    else
      xacnhan_da_tro_dns='1'
    fi
  fi
fi

# ==============================================================================
# 5. THỰC THI CẤU HÌNH OPENLITESPEED
# ==============================================================================
_runing "Đang cấu hình Alias Domain $NAME2 trỏ về $domain..."

# 1. Cấu hình Listener toàn cục
sed -i "s/$domain $domain/&, $NAME2/g" /usr/local/lsws/conf/httpd_config.conf

# 2. Cấu hình Virtual Host
vhost_conf="/usr/local/lsws/conf/vhosts/$domain/$domain.conf"
if grep -q "vhAliases" "$vhost_conf"; then
  sed -i "/^ *vhAliases/ s/$/, $NAME2/" "$vhost_conf"
else
  sed -i "/vhDomain/a vhAliases                     $NAME2" "$vhost_conf"
fi

# 3. Restart OLS
/usr/local/lsws/bin/lswsctrl restart >/dev/null 2>&1

# 4. Cài đặt SSL nếu DNS đã trỏ
if [[ "$xacnhan_da_tro_dns" == "1" ]]; then
  domain_alias_list="$domain,"
  domain_alias_list+=$(grep "vhAliases" "$vhost_conf" | awk '{$1=""; print $0}' | sed 's/ //g')
  
  _runing "Đang tiến hành cấp chứng chỉ SSL mở rộng: $domain_alias_list"
  docroot=$(grep 'docRoot' "$vhost_conf" | awk '{print $2}')
  
  certbot certonly --non-interactive --agree-tos --register-unsafely-without-email --webroot -w "${docroot}" --force-renewal --expand -d "$domain_alias_list" >/dev/null 2>&1
  _rundone "Hoàn tất cài đặt SSL."
fi

/usr/local/lsws/bin/lswsctrl restart >/dev/null 2>&1

# ==============================================================================
# 6. THÔNG BÁO KẾT QUẢ
# ==============================================================================
echo -e "\n${C_GREEN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_BOLD_WHITE}THIẾT LẬP HOÀN TẤT!${C_RESET}"
center_text "Domain Alias: ${C_YELLOW}$NAME2${C_RESET} ➜ Trỏ về: ${C_GREEN}$domain${C_RESET}"
echo -e "${C_GREEN}╰──────────────────────────────────────────────────────────────────────────────╯${C_RESET}"

# Kiểm tra lại DNS một lần nữa để nhắc nhở người dùng
final_check=$(host "$NAME2" | grep -Eo -m 1 '[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}')
vps_ip=$(curl -s --connect-timeout 5 ipv4.icanhazip.com)

if [[ "$final_check" != "$vps_ip" ]]; then
  echo -e "${C_YELLOW}Lưu ý: Domain $NAME2 chưa được trỏ IP.${C_RESET}"
  echo -e "   Vui lòng trỏ DNS bản ghi ${C_CYAN}A${C_RESET} về: ${C_BOLD_WHITE}$vps_ip${C_RESET} để website hoạt động."
fi

[[ $1 == "98" ]] && exec /etc/wptt/wptt-domain-main 1
exit
