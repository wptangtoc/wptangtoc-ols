#!/bin/bash
# @author: Gia Tuấn
# @website: https://wptangtoc.com
# @since: 2026

function huong_dan() {
  Xoá thiết lập domain alias đã thiết lập trước đó
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null

clear
echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}QUẢN LÝ DOMAIN ➜ Xóa Tên Miền Phụ Bám (Parked/Alias Domain)${C_RESET}"
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

if [[ "${1:-}" == '98' ]]; then
  WPTT_IN_MENU="yes"
  WPTT_MENU_BACK="/etc/wptt/wptt-domain-main 1"
fi

. /etc/wptt/tenmien 2>/dev/null
lua_chon_NAME "Xóa Alias"

[[ "$NAME" == "0" || -z "$NAME" ]] && {
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-domain-main 1
  exit 0
}

pathcheck="/etc/wptt/vhost/.$NAME.conf"
if [[ ! -f "$pathcheck" ]]; then
  echo -e "\n${C_RED}❌ Lỗi: Tên miền $NAME không tồn tại trên hệ thống!${C_RESET}"
  sleep 3
  exec /etc/wptt/wptt-domain-main 1
  exit 1
fi

check_alias=$(grep -c "vhAliases" "/usr/local/lsws/conf/vhosts/$NAME/$NAME.conf" 2>/dev/null)

if [[ "$check_alias" == '0' ]]; then
  echo -e "\n${C_RED}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_BOLD_WHITE}KHÔNG TÌM THẤY ALIAS DOMAIN${C_RESET}"
  echo -e "${C_RED}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
  left_text "Website ${C_YELLOW}$NAME${C_RESET} hiện tại chưa được thiết lập" 2
  left_text "bất kỳ tên miền Alias (Parked Domain) nào!" 2
  echo -e "${C_RED}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"
  sleep 3
  exec /etc/wptt/wptt-domain-main 1
  exit 1
fi

# Trích xuất danh sách Alias vào mảng
domain_alias_all=$(grep "vhAliases" "/usr/local/lsws/conf/vhosts/$NAME/$NAME.conf" | awk '{$1=""; print $0}' | sed 's/ //g' | tr ',' '\n')
selects=()
while IFS= read -r line; do
  [[ -n "$line" ]] && selects+=("$line")
done <<<"$domain_alias_all"
total=${#selects[@]}

# ==============================================================================
# BƯỚC 3: IN DANH SÁCH VÀ CHỌN ALIAS ĐỂ XÓA
# ==============================================================================
echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_BOLD_WHITE}DANH SÁCH ALIAS CỦA: ${C_YELLOW}$NAME${C_RESET}"
echo -e "${C_CYAN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
i=1
for val in "${selects[@]}"; do
  left_text "  ${C_CYAN}$i)${C_RESET} ${C_BOLD_WHITE}$val${C_RESET}" 2
  ((i++))
done
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯${C_RESET}"

while true; do
  echo -en "${C_CYAN}Nhập số thứ tự Alias bạn muốn xóa (1-$total) [0=Thoát]: ${C_RESET}"
  read -r REPLY

  [[ "$REPLY" == "0" || -z "$REPLY" ]] && {
    echo -e "${C_YELLOW}Đã hủy thao tác.${C_RESET}"
    [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-domain-main 1
    exit 0
  }

  if [[ "$REPLY" =~ ^[0-9]+$ ]] && [ "$REPLY" -ge 1 ] && [ "$REPLY" -le "$total" ]; then
    domain_xoa="${selects[$((REPLY - 1))]}"
    break
  else
    echo -e "${C_RED}Lựa chọn không hợp lệ! Vui lòng nhập số từ 1 đến $total.${C_RESET}"
  fi
done

if ! wptt_xac_nhan "Bạn có chắc chắn muốn XÓA Alias Domain này không?" \
  "Tên miền bị xóa: ${C_RED}$domain_xoa${C_RESET}" \
  "Tên miền gốc   : ${C_GREEN}$NAME${C_RESET}" \
  "Đồng ý Xóa" "Hủy thao tác"; then
  echo -e "${C_YELLOW}Đã hủy thao tác.${C_RESET}\n"
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-domain-main 1
  exit 0
fi

_runing "Gỡ bỏ Alias $domain_xoa khỏi Vhost $NAME"

# TỐI ƯU CÚ PHÁP: Xử lý xóa mảng an toàn tuyệt đối
if [[ $total -eq 1 ]]; then
  # Nếu chỉ có 1 Alias, xóa hẳn dòng vhAliases
  sed -i "/$NAME $NAME/d" /usr/local/lsws/conf/httpd_config.conf
  sed -i "/listener http/a map          $NAME $NAME" /usr/local/lsws/conf/httpd_config.conf
  sed -i "/vhAliases/d" /usr/local/lsws/conf/vhosts/$NAME/$NAME.conf
else
  # Lọc bỏ domain cần xóa ra khỏi mảng
  new_aliases=()
  for a in "${selects[@]}"; do
    [[ "$a" != "$domain_xoa" ]] && new_aliases+=("$a")
  done

  # Nối các phần tử còn lại bằng dấu phẩy
  domain_alias_con_lai=$(
    IFS=,
    echo "${new_aliases[*]}"
  )

  # Ghi lại cấu hình
  sed -i "/$NAME $NAME/d" /usr/local/lsws/conf/httpd_config.conf
  sed -i "/listener http/a map          $NAME $NAME,$domain_alias_con_lai" /usr/local/lsws/conf/httpd_config.conf
  sed -i "/vhAliases/d" /usr/local/lsws/conf/vhosts/$NAME/$NAME.conf
  sed -i "/vhDomain/a vhAliases                 $domain_alias_con_lai" /usr/local/lsws/conf/vhosts/$NAME/$NAME.conf
fi

/usr/local/lsws/bin/lswsctrl restart >/dev/null 2>&1
_rundone "Gỡ bỏ Alias $domain_xoa khỏi Vhost $NAME"

echo "Xoá alias domain $domain_xoa khoi $NAME: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log

echo -e "${C_GREEN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_BOLD_WHITE}HOÀN TẤT XÓA ALIAS DOMAIN${C_RESET}"
echo -e "${C_GREEN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
left_text "Website gốc        : ${C_YELLOW}$NAME${C_RESET}" 2
left_text "Alias đã gỡ bỏ     : ${C_RED}$domain_xoa${C_RESET}" 2
echo -e "${C_GREEN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

[[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-domain-main 1
