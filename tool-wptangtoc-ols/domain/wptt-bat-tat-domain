#!/bin/bash

function huong_dan() {
  Đây là tính năng giúp tạm khoá website
  Tính năng bật và tắt này là tính năng tạm khoá website, không xoá mã nguồn bất kỳ thứ gì.
  chỉ đơn giản nó sẽ tạm ngừng hoạt động website hoặc bật lại nếu đã thiết lập tạm ngừng trước đó
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null # Nạp thư viện UI Xác nhận

clear
echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}${quan_ly_domain} ➜ ${mo_khoa_domain:-Tạm khóa / Kích hoạt lại Website}${C_RESET}"
echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

# ==============================================================================
# HÀM MENU LỌC TRẠNG THÁI BẬT/TẮT CỦA CÁC VHOST
# ==============================================================================
function lua_chon_NAME() {
  unset NAME selects
  selects=()
  local box_inner_width=${box_inner_width:-71}

  if [ "$(ls -A /etc/wptt/vhost 2>/dev/null | grep -v '^\.\.conf$' | sort -uV)" ]; then
    for entry in $(ls -A /etc/wptt/vhost | grep -v '^\.\.conf$' | sort -uV); do
      local dom=$(echo "$entry" | sed 's/^.//' | sed 's/.conf//')

      # Kiểm tra trạng thái dựa trên sự tồn tại của file .bkwptt
      if [[ -f "/usr/local/lsws/conf/vhosts/$dom/$dom.conf.bkwptt" ]]; then
        selects+=("$dom|[Đang TẠM KHÓA]")
      else
        selects+=("$dom|[Đang BẬT]")
      fi
    done
  fi

  if [[ ${#selects[@]} -eq 0 ]]; then
    echo -e "${C_YELLOW}Hệ thống chưa có website nào được khởi tạo!${C_RESET}"
    sleep 3
    exec /etc/wptt/wptt-domain-main 1
  fi

  # Render Khung Bo Cong
  echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
  local title_text="Trạng thái hiện tại & Chọn website bạn muốn thao tác:"
  local len=$(echo -n "$title_text" | awk '{print length($0)}')
  local pad_r=$((box_inner_width - len - 2))
  [[ $pad_r -lt 0 ]] && pad_r=0
  echo -e "${C_CYAN}│${C_RESET}  ${C_YELLOW}${title_text}${C_RESET}$(printf '%*s' "$pad_r" "")${C_CYAN}│${C_RESET}"

  local line_len=$((len + 3))
  local pad_line_r=$((box_inner_width - line_len))
  [[ $pad_line_r -lt 0 ]] && pad_line_r=0
  local short_line=$(printf "%${line_len}s" "" | sed 's/ /─/g')
  echo -e "${C_CYAN}├${short_line}$(printf '%*s' "$pad_line_r" "")│${C_RESET}"

  local i=1
  for item in "${selects[@]}"; do
    local dom=$(echo "$item" | cut -d'|' -f1)
    local stt=$(echo "$item" | cut -d'|' -f2)

    local color_stt="${C_GREEN}"
    if [[ "$stt" == "[Đang TẠM KHÓA]" ]]; then color_stt="${C_RED}"; fi

    local item_text=$(printf "  ${C_CYAN}%3d)${C_RESET} ${C_BOLD_WHITE}%-30s${C_RESET} %s" "$i" "$dom" "${color_stt}${stt}${C_RESET}")
    local clean_text=$(printf "  %3d) %-30s %s" "$i" "$dom" "$stt")
    local item_len=$(echo -n "$clean_text" | awk '{print length($0)}')
    local pad=$((box_inner_width - item_len))
    [[ $pad -lt 0 ]] && pad=0
    echo -e "${C_CYAN}│${C_RESET}${item_text}$(printf '%*s' "$pad" "")${C_CYAN}│${C_RESET}"
    ((i++))
  done
  echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯${C_RESET}"

  local fzf_installed=false
  if command -v fzf &>/dev/null; then
    fzf_installed=true
    PROMPT_TEXT="Nhập lựa chọn (1-${#selects[@]}) [00=Tìm nhanh] [0=${exit_thoat:-Thoát}]: "
  else
    PROMPT_TEXT="Nhập lựa chọn (1-${#selects[@]}) [0=${exit_thoat:-Thoát}]: "
  fi

  while true; do
    echo -en "${C_CYAN}${PROMPT_TEXT}${C_RESET}"
    if ! read -r REPLY; then exit 1; fi
    REPLY=$(echo "$REPLY" | tr -d ' ' | tr '[:upper:]' '[:lower:]')

    case "$REPLY" in
    0)
      echo -e "\n${C_GREEN}Đang thoát...${C_RESET}"
      NAME="0"
      return 0
      ;;
    00)
      if $fzf_installed; then
        local selected_item=$(printf '%s\n' "${selects[@]}" | nl -w 3 -s ': ' | fzf --prompt="Tìm website >> " --height=40% --border=rounded --color=border:red --cycle --reverse)
        local dom=$(echo "$selected_item" | sed 's/^[[:space:]]*[0-9]\+\:[[:space:]]*//' | cut -d'|' -f1)
        if [[ -n "$dom" ]]; then
          NAME="$dom"
          return 0
        else echo -e "${C_YELLOW}Đã hủy chọn. Vui lòng chọn lại.${C_RESET}"; fi
      else
        echo -e "${C_RED}Lỗi: FZF chưa cài đặt.${C_RESET}"
      fi
      ;;
    *)
      if [[ "$REPLY" =~ ^[0-9]+$ ]] && [ "$REPLY" -ge 1 ] && [ "$REPLY" -le ${#selects[@]} ]; then
        local action_index=$((REPLY - 1))
        NAME=$(echo "${selects[$action_index]}" | cut -d'|' -f1)
        return 0
      else
        echo -e "\n${C_RED}❌ Lựa chọn không hợp lệ! Vui lòng chọn lại.${C_RESET}"
      fi
      ;;
    esac
  done
}

lua_chon_NAME

[[ "$NAME" == "0" || -z "$NAME" ]] && {
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-domain-main 1
  return 2>/dev/null || exit
}

pathcheck="/etc/wptt/vhost/.$NAME.conf"
if [[ ! -f "$pathcheck" ]]; then
  echo -e "\n${C_RED}❌ ${ten_mien_nay_khong_ton_tai_tren_he_thong:-Tên miền không tồn tại trên hệ thống này!}${C_RESET}"
  sleep 3
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-domain-main 1
  return 2>/dev/null || exit
fi

# ==============================================================================
# XỬ LÝ LOGIC ĐẢO TRẠNG THÁI (TOGGLE) KÈM XÁC NHẬN
# ==============================================================================
echo ""
is_success=false
action_msg=""

# TRƯỜNG HỢP 1: ĐANG BỊ KHÓA -> HỎI BẬT LẠI
if [[ -f "/usr/local/lsws/conf/vhosts/$NAME/$NAME.conf.bkwptt" ]]; then
  if wptt_xac_nhan "Website này đang TẠM KHÓA. Bạn có muốn BẬT LẠI không?" "${C_BOLD_WHITE}Website:${C_RESET} $NAME" "" "Đồng ý Mở khóa" "Hủy bỏ"; then
    echo ""
    _runing "Đang kích hoạt lại website $NAME..."

    mv "/usr/local/lsws/conf/vhosts/$NAME/$NAME.conf.bkwptt" "/usr/local/lsws/conf/vhosts/$NAME/$NAME.conf"

    if $(cat /etc/*release | grep -q "Ubuntu"); then tuong_thich_nhom_litespeed="nogroup"; else tuong_thich_nhom_litespeed="nobody"; fi
    chown -R lsadm:$tuong_thich_nhom_litespeed "/usr/local/lsws/conf/vhosts/$NAME"
    chmod -R 750 "/usr/local/lsws/conf/vhosts/$NAME"

    action_msg="Đã MỞ KHÓA thành công. Website hoạt động bình thường."
    is_success=true
    _rundone "Đang kích hoạt lại website $NAME..."
  fi

# TRƯỜNG HỢP 2: ĐANG BẬT -> HỎI TẠM KHÓA
else
  if wptt_xac_nhan "Bạn có muốn TẠM KHÓA website này không? (Mã nguồn,DB vẫn giữ nguyên)" "${C_BOLD_WHITE}Website:${C_RESET} $NAME" "" "Đồng ý Tạm khóa" "Hủy bỏ"; then
    echo ""
    _runing "Đang tiến hành tạm khóa website $NAME..."

    mv "/usr/local/lsws/conf/vhosts/$NAME/$NAME.conf" "/usr/local/lsws/conf/vhosts/$NAME/$NAME.conf.bkwptt"
    [[ -d "/usr/local/lsws/$NAME/luucache" ]] && rm -rf "/usr/local/lsws/$NAME/luucache" # Xóa lscache

    action_msg="Đã TẠM KHÓA. Truy cập vào website sẽ bị báo lỗi không tìm thấy máy chủ."
    is_success=true
    _rundone "Đang tiến hành tạm khóa website $NAME..."
  fi
fi

# ==============================================================================
# KHỞI ĐỘNG LẠI DỊCH VỤ VÀ BÁO CÁO (NẾU THÀNH CÔNG)
# ==============================================================================
if $is_success; then
  /usr/local/lsws/bin/lswsctrl restart >/dev/null 2>&1

  # _rundone "Cập nhật dịch vụ OpenLiteSpeed hoàn tất"

  echo -e "\n${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_GREEN}HOÀN TẤT THAY ĐỔI TRẠNG THÁI WEBSITE${C_RESET}"
  echo -e "${C_CYAN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
  left_text "Website thao tác : ${C_YELLOW}$NAME${C_RESET}"
  left_text "Trạng thái mới   : ${C_GREEN}$action_msg${C_RESET}"
  echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

  # Kịch bản check downtime hệ thống
  . /etc/wptt/.wptt.conf 2>/dev/null
  if [[ $download_api ]]; then
    if [[ -f /etc/wptt/add-one/check.sh ]]; then
      if [[ $email_check_downtime && $telegram_id ]]; then
        . /etc/wptt/add-one/check.sh $telegram_id $telegram_api $email >/dev/null 2>&1
      fi
      if [[ -z $email_check_downtime && $telegram_id ]]; then
        . /etc/wptt/add-one/check.sh $telegram_id $telegram_api >/dev/null 2>&1
      fi
      if [[ $email_check_downtime && -z $telegram_id ]]; then
        . /etc/wptt/add-one/check.sh $email_check_downtime >/dev/null 2>&1
      fi
    fi
  fi
else
  echo -e "${C_YELLOW}Đã hủy thao tác.${C_RESET}"
fi

[[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-domain-main 1
