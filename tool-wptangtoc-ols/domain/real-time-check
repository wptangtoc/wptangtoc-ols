#!/bin/bash

function huong_dan() {
  Đây là tính năng xem real time hoạt động của litespeed webserver
}

clear

check_menu_wptangtoc_active=$1

if [[ $check_menu_wptangtoc_active = "99" ]]; then
  echo "========================================================================="
  echo "|Quan ly Logs => Real-Time Statistics Monitoring                        |"
  echo "========================================================================="
else
  echo "========================================================================="
  echo "|Quan ly Domain => Real-Time Statistics Monitoring                      |"
  echo "========================================================================="
fi

echo ""

has_domain=0

# Vòng lặp thuần Bash trên RAM
for filepath in /etc/wptt/vhost/.*.conf; do
  [[ ! -f "$filepath" || "$filepath" == *"/..conf" ]] && continue

  domain="${filepath##*/}"
  domain="${domain%.conf}"
  domain="${domain#.}"

  path="/usr/local/lsws/$domain/html"

  if [[ -d "$path" ]]; then
    # Lấy dòng thông số thô
    giatuan_raw=$(grep -h "^REQ_RATE \[$domain\]" /tmp/lshttpd/.rtreport* 2>/dev/null | head -n 1)

    if [[ -n "$giatuan_raw" ]]; then
      # Lột xác bằng sed: Dịch sang tiếng Việt, ngắt dòng và tô màu
      giatuan_vi=$(echo "$giatuan_raw" | sed \
        -e "s/REQ_RATE \[$domain\]: //" \
        -e 's/REQ_PROCESSING/\\e[33mĐang xử lý (Active)\\e[0m/g' \
        -e 's/REQ_PER_SEC/\\e[32mYêu cầu\/giây (RPS)\\e[0m/g' \
        -e 's/TOT_REQS/\\e[36mTổng số yêu cầu\\e[0m/g' \
        -e 's/PUB_CACHE_HITS_PER_SEC/\\e[32mCache chung\/giây\\e[0m/g' \
        -e 's/TOTAL_PUB_CACHE_HITS/\\e[36mTổng Cache chung\\e[0m/g' \
        -e 's/PRIVATE_CACHE_HITS_PER_SEC/\\e[32mCache riêng\/giây\\e[0m/g' \
        -e 's/TOTAL_PRIVATE_CACHE_HITS/\\e[36mTổng Cache riêng\\e[0m/g' \
        -e 's/STATIC_HITS_PER_SEC/\\e[32mFile tĩnh\/giây\\e[0m/g' \
        -e 's/TOTAL_STATIC_HITS/\\e[36mTổng File tĩnh\\e[0m/g' \
        -e 's/, /\n  - /g') # Biến dấu phẩy thành dấu xuống dòng và gạch đầu dòng

      echo "========================================================================="
      echo -e "\\e[1;37mThông tin Real-time website:\\e[0m \\e[1;32m$domain\\e[0m"
      echo "-------------------------------------------------------------------------"
      echo -e "  - $giatuan_vi"
      echo "========================================================================="
    fi
  fi
done

[[ $has_domain -eq 1 ]] && echo ""

# Điều hướng quay lại menu bằng 1 cấu trúc kiểm tra duy nhất
if [[ $check_menu_wptangtoc_active = "98" ]]; then
  exec /etc/wptt/wptt-domain-main 1
elif [[ $check_menu_wptangtoc_active = "99" ]]; then
  exec /etc/wptt/wptt-logs-main 1
fi
