#!/bin/bash

function huong_dan() {
  Tính năng Xóa chuyển hướng domain là quá trình gỡ bỏ hoặc vô hiệu hóa một cài đặt đã được thiết lập trước đó để tự động điều hướng người dùng và công cụ tìm kiếm từ một tên miền này sang một tên miền khác.

  Nói một cách đơn giản, đây là hành động dừng việc tự động chuyển tiếp từ tên miền A sang tên miền B. Sau khi xóa chuyển hướng, khi người dùng truy cập vào tên miền A, họ sẽ không còn bị tự động đưa đến tên miền B nữa.

  Mục Đích Chính
  * Khôi phục nội dung gốc: Khi bạn muốn tên miền đang bị chuyển hướng [ví dụ: tên miền A] bắt đầu hiển thị nội dung riêng của nó, thay vì trỏ sang nơi khác.
  * Thay đổi đích đến của chuyển hướng: Nếu bạn muốn tên miền A chuyển hướng đến một tên miền C hoàn toàn mới, bạn có thể cần xóa chuyển hướng cũ [sang B] trước khi thiết lập chuyển hướng mới [sang C].
  * Hủy bỏ việc gộp tên miền: Nếu trước đó bạn gộp nhiều tên miền về một, nay muốn tách chúng ra hoạt động độc lập.
  * Gỡ lỗi: Nếu chuyển hướng đang gây ra lỗi [ví dụ: vòng lặp chuyển hướng, sai đích] thì việc xóa bỏ nó là cần thiết để khắc phục.
  * Không còn nhu cầu: Khi việc chuyển hướng không còn cần thiết nữa [ví dụ: tên miền đích không còn tồn tại, chiến dịch marketing đã kết thúc].
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null # Nạp thư viện UI Xác nhận

clear
echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}${quan_ly_domain} ➜ ${xoa_chuyen_huong_domain}${C_RESET}"
echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

if [[ ! -d /etc/wptt/chuyen-huong ]]; then
  echo -e "${C_YELLOW}Bạn chưa từng thiết lập chuyển hướng domain nào trên hệ thống!${C_RESET}"
  sleep 3
  exec /etc/wptt/wptt-domain-main 1
  exit
fi

function lua_chon_NAME() {
  unset NAME selects
  selects=()
  local box_inner_width=${box_inner_width:-71}

  if [ "$(ls -At /etc/wptt/chuyen-huong 2>/dev/null)" ]; then
    for entry in $(ls -A /etc/wptt/chuyen-huong); do
      local dom=$(echo "$entry" | sed 's/^.//' | sed 's/.conf//')
      if [[ "$dom" != "${dom/./}" ]]; then
        # Bóc tách tên miền đích từ file .htaccess
        local target=$(sed '/^#begin-chuyen-huong-domain-wptangtoc/,/^#end-chuyen-huong-domain-wptangtoc$/!d' "/usr/local/lsws/$dom/html/.htaccess" 2>/dev/null | grep '301' | grep -o -E '([a-zA-Z0-9-]+\.)+[a-zA-Z0-9-]{2,}' | tail -n 1)
        [[ -z "$target" ]] && target="Không xác định"
        selects+=("$dom|$target")
      fi
    done

    if [[ ${#selects[@]} -eq 0 ]]; then
      echo -e "${C_YELLOW}Hệ thống chưa có domain nào được kích hoạt sử dụng chuyển hướng!${C_RESET}"
      sleep 3
      exec /etc/wptt/wptt-domain-main 1
    fi

    # Render Menu Bo Cong
    echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
    local title_text="Lựa chọn website đang chuyển hướng bạn muốn gỡ bỏ:"
    local len=$(echo -n "$title_text" | awk '{print length($0)}')
    local pad_r=$((box_inner_width - len - 2))
    [[ $pad_r -lt 0 ]] && pad_r=0
    echo -e "${C_CYAN}│${C_RESET}  ${C_YELLOW}${title_text}${C_RESET}$(printf '%*s' "$pad_r" "")${C_CYAN}│${C_RESET}"

    local line_len=$((len + 3))
    local pad_line_r=$((box_inner_width - line_len))
    [[ $pad_line_r -lt 0 ]] && pad_line_r=0
    local short_line=$(printf "%${line_len}s" "" | sed 's/ /─/g')
    echo -e "${C_CYAN}├${short_line}$(printf '%*s' "$pad_line_r" "")│${C_RESET}"

    local i=1
    for item in "${selects[@]}"; do
      local source_dom=$(echo "$item" | cut -d'|' -f1)
      local target_dom=$(echo "$item" | cut -d'|' -f2)

      local item_text=$(printf "  ${C_CYAN}%3d)${C_RESET} ${C_BOLD_WHITE}%-25s${C_RESET} ➜  ${C_GREEN}%s${C_RESET}" "$i" "$source_dom" "$target_dom")
      local clean_text=$(printf "  %3d) %-25s ➜  %s" "$i" "$source_dom" "$target_dom")
      local item_len=$(echo -n "$clean_text" | awk '{print length($0)}')
      local pad=$((box_inner_width - item_len))
      [[ $pad -lt 0 ]] && pad=0
      echo -e "${C_CYAN}│${C_RESET}${item_text}$(printf '%*s' "$pad" "")${C_CYAN}│${C_RESET}"
      ((i++))
    done
    echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯${C_RESET}"

    local fzf_installed=false
    if command -v fzf &>/dev/null; then
      fzf_installed=true
      PROMPT_TEXT="Nhập lựa chọn (1-${#selects[@]}) [00=Tìm nhanh] [0=Thoát]: "
    else
      PROMPT_TEXT="Nhập lựa chọn (1-${#selects[@]}) [0=Thoát]: "
    fi

    while true; do
      echo -en "${C_CYAN}${PROMPT_TEXT}${C_RESET}"
      if ! read -r REPLY; then exit 1; fi
      REPLY=$(echo "$REPLY" | tr -d ' ' | tr '[:upper:]' '[:lower:]')

      case "$REPLY" in
      0)
        echo -e "\n${C_GREEN}Đang thoát...${C_RESET}"
        NAME="0"
        return 0
        ;;
      00)
        if $fzf_installed; then
          local selected_item=$(printf '%s\n' "${selects[@]}" | nl -w 3 -s ': ' | fzf --prompt="Tìm website >> " --height=40% --border=rounded --color=border:red --cycle --reverse)
          local dom=$(echo "$selected_item" | sed 's/^[[:space:]]*[0-9]\+\:[[:space:]]*//' | cut -d'|' -f1)
          if [[ -n "$dom" ]]; then
            NAME="$dom"
            return 0
          else echo -e "${C_YELLOW}Đã hủy chọn. Vui lòng chọn lại.${C_RESET}"; fi
        else
          echo -e "${C_RED}Lỗi: FZF chưa cài đặt.${C_RESET}"
        fi
        ;;
      *)
        if [[ "$REPLY" =~ ^[0-9]+$ ]] && [ "$REPLY" -ge 1 ] && [ "$REPLY" -le ${#selects[@]} ]; then
          local action_index=$((REPLY - 1))
          NAME=$(echo "${selects[$action_index]}" | cut -d'|' -f1)
          return 0
        else
          echo -e "\n${C_RED}❌ Lựa chọn không hợp lệ! Vui lòng chọn lại.${C_RESET}"
        fi
        ;;
      esac
    done
  else
    echo -e "${C_YELLOW}⚠️ Không có domain nào tồn tại trên hệ thống!${C_RESET}"
    sleep 3
    exec /etc/wptt/wptt-domain-main 1
  fi
}

lua_chon_NAME

[[ "$NAME" == "0" || -z "$NAME" ]] && {
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-domain-main 1
  return 2>/dev/null || exit
}

path="/etc/wptt/chuyen-huong/.$NAME.conf"
if [[ ! -f "$path" ]]; then
  echo -e "\n${C_RED}❌ Domain chuyển hướng không tồn tại trên VPS!${C_RESET}"
  sleep 3
  exec /etc/wptt/wptt-domain-main 1
fi

# ==============================================================================
# HỎI XÓA MÃ NGUỒN (NẾU CÓ TỒN TẠI)
# ==============================================================================
xoa_ma_nguon="y" # Mặc định là xóa sạch (Trường hợp tạo Vhost mới để hứng redirect)

# Chỉ hỏi nếu thực sự tìm thấy file mã nguồn (.php)
if [[ -n $(find "/usr/local/lsws/$NAME/html" -maxdepth 2 -type f -name "*.php" 2>/dev/null | head -n 1) ]]; then
  echo ""
  echo -e "${C_YELLOW}Hệ thống phát hiện Website này đang chứa mã nguồn (.php).${C_RESET}"
  if wptt_xac_nhan "Bạn có muốn XÓA SẠCH toàn bộ Mã nguồn & Database không?" "${C_BOLD_WHITE}Website:${C_RESET} $NAME" "" "Có (Xóa sạch)" "Không (Chỉ gỡ luật chuyển hướng)"; then
    xoa_ma_nguon="y"
  else
    xoa_ma_nguon="n"
  fi
fi

echo "Xóa chuyển hướng website $NAME : $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log
echo ""

# ==============================================================================
# THỰC THI GỠ BỎ
# ==============================================================================
if [[ "$xoa_ma_nguon" == 'y' ]]; then
  _runing "Đang xóa bỏ Vhost và User hệ thống..."

  if [[ -f "/etc/wptt/vhost_bk/.$NAME.conf" ]]; then
    . "/etc/wptt/vhost_bk/.$NAME.conf"
  elif [[ -f "/etc/wptt/vhost/.$NAME.conf" ]]; then
    . "/etc/wptt/vhost/.$NAME.conf"
  fi

  rm -rf "/usr/local/lsws/conf/vhosts/$NAME"
  if [[ -n "$User_name_vhost" ]]; then
    usermod -R wptangtoc-ols "$User_name_vhost" >/dev/null 2>&1
    userdel -f "$User_name_vhost" >/dev/null 2>&1
  fi

  # Tháo ống nối (Umount) bảo vệ tiến trình
  JAIL_PATH="/usr/local/lsws/$NAME"
  if [[ -d "$JAIL_PATH/etc/wptt" ]]; then
    umount -fl "$JAIL_PATH/etc/wptt" 2>/dev/null || true
    umount -fl "$JAIL_PATH/etc/wptt-user" 2>/dev/null || true
    umount -fl "$JAIL_PATH/usr/bin/wptangtoc-user" 2>/dev/null || true
    umount -fl "$JAIL_PATH/.cron_spool" 2>/dev/null || true
    REAL_SOCK=$(mariadb -N -e "select @@socket;" 2>/dev/null || echo "/var/lib/mysql/mysql.sock")
    umount -fl "$JAIL_PATH$REAL_SOCK" 2>/dev/null || true
  fi

  # Xé toạc Namespace OpenLiteSpeed
  OLS_NS_PATH="/var/lsns/*/$NAME"
  if ls $OLS_NS_PATH 1>/dev/null 2>&1; then
    fuser -k -9 $OLS_NS_PATH/* $OLS_NS_PATH/*/mnt 2>/dev/null || true
    umount -fl $OLS_NS_PATH/*/mnt 2>/dev/null || true
    umount -fl $OLS_NS_PATH/* 2>/dev/null || true
    rm -rf /var/lsns/*/$NAME 2>/dev/null || true
  fi

  # Check An Toàn Root
  if ! wptt_kha_dung_de_xoa_xac_thuc "$NAME"; then
    _runloi "Gỡ bỏ hệ thống"
    echo -e "${C_RED}❌ Lỗi: Check rỗng. Hủy bỏ lệnh xóa bảo vệ VPS!${C_RESET}"
    [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-domain-main 1
    return 2>/dev/null || exit 1
  fi

  rm -rf "/home/$NAME"
  rm -rf "/wptangtoc-ols/$NAME"
  rm -rf "/usr/local/lsws/$NAME"

  sed -i "/${NAME} ${NAME}/d" /usr/local/lsws/conf/httpd_config.conf
  sed -i -e '/^virtualhost '$NAME'/,/^}$/d' /usr/local/lsws/conf/httpd_config.conf
  _rundone "Gỡ bỏ Vhost và User thành công"

  # Xóa Database
  if [[ -n "$DB_User_web" ]] && [[ -n "$DB_Name_web" ]]; then
    _runing "Đang dọn dẹp cơ sở dữ liệu (Database)..."
    TEMP_CNF_ROOT=$(mktemp)
    chmod 600 "$TEMP_CNF_ROOT"
    cat >"$TEMP_CNF_ROOT" <<EOF
[client]
user=${database_admin_username}
password=${database_admin_password}
host=localhost
max_allowed_packet=1G
default-character-set=utf8mb4

[mysqldump]
quick
quote-names
max_allowed_packet=1G
EOF

    mariadb --defaults-extra-file="$TEMP_CNF_ROOT" -e "KILL USER ${DB_User_web}" >/dev/null 2>&1 || true
    mariadb --defaults-extra-file="$TEMP_CNF_ROOT" -e "DROP DATABASE IF EXISTS \`${DB_Name_web}\`" >/dev/null 2>&1
    mariadb --defaults-extra-file="$TEMP_CNF_ROOT" -e "DROP USER IF EXISTS '${DB_User_web}'@'localhost'" >/dev/null 2>&1
    rm -f "$TEMP_CNF_ROOT"
    _rundone "Xóa Database thành công"
  fi
  msg_action="Xóa hoàn toàn Mã nguồn, DB và gỡ Chuyển hướng."

else
  _runing "Đang gỡ bỏ luật chuyển hướng trong file .htaccess..."
  sed -i -e '/^#begin-chuyen-huong-domain-wptangtoc/,/^#end-chuyen-huong-domain-wptangtoc$/d' "/usr/local/lsws/$NAME/html/.htaccess"

  if [[ -f "/etc/wptt/vhost_bk/.$NAME.conf" ]]; then
    mv "/etc/wptt/vhost_bk/.$NAME.conf" "/etc/wptt/vhost/"
  fi

  echo '# BEGIN WordPress
<IfModule mod_rewrite.c>
RewriteEngine On
RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]
RewriteBase /
RewriteRule ^index\.php$ - [L]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . /index.php [L]
</IfModule>
# END WordPress' >"/usr/local/lsws/$NAME/html/.htaccess"

  _rundone "Phục hồi cấu hình .htaccess nguyên bản"
  msg_action="Giữ lại dữ liệu. Chỉ gỡ bỏ luật Chuyển hướng."
fi

# ==============================================================================
# KẾT THÚC DỌN DẸP & BÁO CÁO
# ==============================================================================
rm -f "/etc/wptt/chuyen-huong/.$NAME.conf"

# _runing "Đang khởi động lại OpenLiteSpeed..."
/usr/local/lsws/bin/lswsctrl restart >/dev/null 2>&1
# _rundone "Đang khởi động lại OpenLiteSpeed..."

# Kịch bản check downtime hệ thống
. /etc/wptt/.wptt.conf 2>/dev/null
if [[ $download_api ]]; then
  if [[ -f /etc/wptt/add-one/check.sh ]]; then
    if [[ $email_check_downtime && $telegram_id ]]; then
      . /etc/wptt/add-one/check.sh $telegram_id $telegram_api $email >/dev/null 2>&1
    fi
    if [[ -z $email_check_downtime && $telegram_id ]]; then
      . /etc/wptt/add-one/check.sh $telegram_id $telegram_api >/dev/null 2>&1
    fi
    if [[ $email_check_downtime && -z $telegram_id ]]; then
      . /etc/wptt/add-one/check.sh $email_check_downtime >/dev/null 2>&1
    fi
  fi
fi

echo -e "\n${C_GREEN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_BOLD_WHITE}HOÀN TẤT GỠ BỎ CHUYỂN HƯỚNG${C_RESET}"
echo -e "${C_GREEN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
left_text "Tên miền xử lý : ${C_YELLOW}$NAME${C_RESET}" 2
left_text "Hành động      : ${C_GREEN}$msg_action${C_RESET}" 2
echo -e "${C_GREEN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

[[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-domain-main 1
