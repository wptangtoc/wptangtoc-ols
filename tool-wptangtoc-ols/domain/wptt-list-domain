#!/bin/bash

function huong_dan() {
  Đây là tính năng xem danh sách toàn bộ domain có trong hệ thống của bạn
  Tính năng này sẽ hiện thị danh sách các domain trong hệ thống
}

clear

. /etc/wptt/.wptt.conf
if [[ -z "$ngon_ngu" ]]; then
  ngon_ngu='vi'
fi
. /etc/wptt/lang/$ngon_ngu.sh

echo ""
echo ""
echo ""
echo "========================================================================="
echo "|$quan_ly_domain => $danh_sach_domain                                   |"
echo "========================================================================="
echo ""
echo ""

function box_out() {
  local s=("$@") b w=0
  for l in "${s[@]}"; do
    ((w < ${#l})) && {
      b="$l"
      w="${#l}"
    }
  done
  tput setaf 3
  echo " -${b//?/-}-
| ${b//?/ } |"
  for l in "${s[@]}"; do
    printf '| %s%*s%s |\n' "$(tput setaf 4)" "-$w" "$l" "$(tput setaf 3)"
  done
  echo "| ${b//?/ } |
 -${b//?/-}-"
  tput sgr 0
}

# 1. Quét file siêu tốc trên RAM và đưa vào mảng
valid_domains=()
shopt -s nullglob
for filepath in /etc/wptt/vhost/.*.conf; do
  [[ ! -f "$filepath" || "$filepath" == *"/..conf" ]] && continue

  domain="${filepath##*/}"
  domain="${domain%.conf}"
  domain="${domain#.}"

  if [[ "$domain" == ?*.?* ]]; then
    if [[ -d "/usr/local/lsws/$domain/html" ]]; then
      valid_domains+=("$domain")
    fi
  fi
done
shopt -u nullglob

# 2. Đếm số lượng dựa trên độ dài mảng
so_luong_website="${#valid_domains[@]}"

echo "========================================================================="
box_out "$may_chu: $so_luong_website website"
echo "========================================================================="

# 3. Hiển thị danh sách nếu có website
if [[ $so_luong_website -gt 0 ]]; then
  echo
  echo "$danh_sach_domain $tren_he_thong: "

  # Sắp xếp mảng chuẩn Version (Tuỳ chọn, giúp list hiện đẹp hơn)
  mapfile -t valid_domains < <(printf "%s\n" "${valid_domains[@]}" | sort -uV)

  a=0
  for domain in "${valid_domains[@]}"; do
    ((a++)) # Toán tử tăng nội tại của Bash (Thay cho expr)
    box_out "${a}: ${domain}"
  done
  echo
fi

echo "Xem list danh sách domain trên webserver: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log

check_menu_wptangtoc_active=$1
if [[ $check_menu_wptangtoc_active = "98" ]]; then
  exec /etc/wptt/wptt-domain-main 1
fi
