#!/bin/bash

function huong_dan() {
  Đây là tính năng xem danh sách toàn bộ domain có trong hệ thống của bạn
  Tính năng này sẽ hiện thị danh sách các domain trong hệ thống
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null

clear
echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}${quan_ly_domain} ➜ ${danh_sach_domain}${C_RESET}"
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

valid_domains=()
for filepath in /etc/wptt/vhost/.*.conf; do
  [[ ! -f "$filepath" || "$filepath" == *"/..conf" ]] && continue

  domain="${filepath##*/}"
  domain="${domain%.conf}"
  domain="${domain#.}"

  if [[ "$domain" == ?*.?* ]]; then
    if [[ -d "/usr/local/lsws/$domain/html" ]]; then
      valid_domains+=("$domain")
    fi
  fi
done

# Đếm và Sắp xếp
so_luong_website="${#valid_domains[@]}"
if [[ $so_luong_website -gt 0 ]]; then
  mapfile -t valid_domains < <(printf "%s\n" "${valid_domains[@]}" | sort -uV)
fi

echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_BOLD_WHITE}TỔNG QUAN: ĐANG CÓ ${C_YELLOW}${so_luong_website}${C_BOLD_WHITE} WEBSITE HOẠT ĐỘNG${C_RESET}"
echo -e "${C_CYAN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"

if [[ $so_luong_website -gt 0 ]]; then
  i=1
  for domain in "${valid_domains[@]}"; do
    # 1. Hệ thống phân tích Tags (Nhãn dán trạng thái)
    tags=""

    # Check Website Chính
    if [[ "$domain" == "$Website_chinh" ]]; then
      tags+="${C_YELLOW}[★ Website Chính]${C_RESET} "
    fi

    # Check Tạm khóa
    if [[ -f "/usr/local/lsws/conf/vhosts/$domain/$domain.conf.bkwptt" ]]; then
      tags+="${C_RED}[Tạm khóa]${C_RESET} "
    fi

    # Check SSL (Let's Encrypt hoặc Trả phí)
    if [[ -f "/etc/letsencrypt/live/$domain/cert.pem" || -d "/usr/local/lsws/$domain/ssl" ]]; then
      tags+="${C_GREEN}[SSL]${C_RESET} "
    fi

    # 2. Render Dòng
    domain_padded=$(printf "%-25s" "$domain")
    left_text "  ${C_CYAN}${i})${C_RESET} ${C_BOLD_WHITE}${domain_padded}${C_RESET} $tags" 2
    ((i++))
  done
else
  center_text "${C_YELLOW}Hệ thống hiện chưa có website nào.${C_RESET}"
fi

echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

echo "Xem list danh sách domain trên webserver: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log

check_menu_wptangtoc_active=${1:-}
if [[ $check_menu_wptangtoc_active == "98" ]]; then
  echo -en "\n${C_CYAN}Nhấn phím [Enter] để quay lại Menu...${C_RESET}"

  #cho thêm trap người dùng tư nhiên chõ này lại đi ân ctrl + c cắt bắt theo
trap '
  stty sane  # KHÔI PHỤC HIỂN THỊ CHỮ: Sửa lỗi gõ phím bị tàng hình
  tput cnorm # Hiện lại con trỏ chuột nhấp nháy
  clear
  exec /etc/wptt/wptt-domain-main 1
' SIGINT SIGTERM SIGQUIT
  read -r dummy
trap - SIGINT SIGTERM SIGQUIT
  exec /etc/wptt/wptt-domain-main 1
fi
