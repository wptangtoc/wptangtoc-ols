#!/bin/bash

function huong_dan() {
  Đây là tính năng kiểm tra hoạt động website.
  Tính năng Kiểm tra hoạt động website là tập hợp các phương pháp và công cụ được sử dụng để kiểm tra, xác minh xem một trang web có đang trực tuyến, người dùng có thể truy cập được hay không, và các chức năng cơ bản của nó có đang vận hành đúng cách hay không.

  Nói một cách đơn giản, đây là cách để bạn biết website của tôi có đang chạy tốt không? hoặc khách hàng có vào được website của tôi lúc này không?

  Mục Đích Chính
  * Đảm bảo thời gian hoạt động [Uptime]: Phát hiện nhanh chóng khi website bị sập [down] hoặc không thể truy cập, giúp giảm thiểu gián đoạn.
  * Xác minh chức năng cơ bản: Kiểm tra xem các trang có tải được không, có lỗi máy chủ [server error] hay không, các liên kết có hoạt động không.
  * Phát hiện sớm sự cố: Giúp nhận biết vấn đề [ví dụ: lỗi server, hết hạn SSL, database không kết nối] trước cả khi người dùng phàn nàn.
  * Duy trì trải nghiệm người dùng: Một website luôn sẵn sàng và hoạt động tốt là yếu tố then chốt cho trải nghiệm người dùng tích cực.
  * Bảo vệ uy tín và SEO: Thời gian website ngừng hoạt động kéo dài có thể ảnh hưởng xấu đến uy tín và thứ hạng tìm kiếm.

  Việc thường xuyên kiểm tra hoạt động website giúp đảm bảo tính ổn định, sẵn sàng và mang lại trải nghiệm tốt nhất cho người dùng.
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null

clear
echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}${quan_ly_domain:-QUẢN LÝ DOMAIN} ➜ ${kiem_tra_hoat_dong:-Kiểm tra Hoạt động Website (Uptime Check)}${C_RESET}"
echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

echo "Kiểm tra hoạt động: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log

# ==============================================================================
# QUÉT DANH SÁCH VHOST TỒN TẠI
# ==============================================================================
vhost_list=()
if [ "$(ls -A /etc/wptt/vhost 2>/dev/null | grep -v '^\.\.conf$' | sort -uV)" ]; then
  for filepath in /etc/wptt/vhost/.*.conf; do
    [[ ! -f "$filepath" || "$filepath" == *"/..conf" ]] && continue
    domain="${filepath##*/}"
    domain="${domain%.conf}"
    domain="${domain#.}"

    if [[ "$domain" == ?*.?* ]]; then
      vhost_list+=("$domain")
    fi
  done
fi

if [[ ${#vhost_list[@]} -eq 0 ]]; then
  echo -e "${C_YELLOW}⚠️ Không có website nào trên hệ thống để kiểm tra!${C_RESET}"
  sleep 3
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-domain-main 1
  exit 0
fi

_runing "kiểm tra HTTP/HTTPS của ${#vhost_list[@]} website (Sẽ mất vài giây)..."

results=()
USER_AGENT="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36"

for domain in "${vhost_list[@]}"; do
  path="/usr/local/lsws/$domain/html"

  if [[ -d "$path" ]]; then
    # Check Tạm khóa
    if [[ -f "/usr/local/lsws/conf/vhosts/$domain/$domain.conf.bkwptt" ]]; then
      results+=("$domain|disabled")
    else
      # Check Uptime (Thêm --max-time 5s để chống treo script nếu server/DNS tịt)
      # Mở rộng regex check code: 200 (OK), 301/302/307/308 (Redirects)
      checkssl=$(curl -Iks --max-time 5 "https://${domain}" -A "$USER_AGENT" | head -n 1 | grep -c "200\|301\|302\|307\|308")
      checkssl2=$(curl -Iks --max-time 5 "http://${domain}" -A "$USER_AGENT" | head -n 1 | grep -c "200\|301\|302\|307\|308")
      checkssl3=$(curl -Iks --max-time 5 "https://www.${domain}" -A "$USER_AGENT" | head -n 1 | grep -c "200\|301\|302\|307\|308")
      checkssl4=$(curl -Iks --max-time 5 "http://www.${domain}" -A "$USER_AGENT" | head -n 1 | grep -c "200\|301\|302\|307\|308")

      if [[ "$checkssl" == "0" && "$checkssl2" == "0" && "$checkssl3" == "0" && "$checkssl4" == "0" ]]; then
        results+=("$domain|offline")
      else
        results+=("$domain|online")
      fi
    fi
  fi
done

_rundone "Kiểm tra hoạt động hoàn tất"

# ==============================================================================
# BẢNG BÁO CÁO BO CONG TỔNG HỢP
# ==============================================================================
echo -e "\n${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}BẢNG TRẠNG THÁI HOẠT ĐỘNG WEBSITE (UPTIME)${C_RESET}"
echo -e "${C_CYAN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"

for item in "${results[@]}"; do
  dom=$(echo "$item" | cut -d'|' -f1)
  status=$(echo "$item" | cut -d'|' -f2)

  dom_padded=$(printf "%-35s" "$dom")

  if [[ "$status" == "online" ]]; then
    left_text "▪ ${C_BOLD_WHITE}${dom_padded}${C_RESET} : ${C_GREEN}${hoat_dong_tot:-Hoạt động tốt (Online)}${C_RESET}" 2
  elif [[ "$status" == "offline" ]]; then
    left_text "▪ ${C_BOLD_WHITE}${dom_padded}${C_RESET} : ${C_RED}${ngung_hoat_dong:-Không phản hồi (Offline)}${C_RESET}" 2
  elif [[ "$status" == "disabled" ]]; then
    left_text "▪ ${C_BOLD_WHITE}${dom_padded}${C_RESET} : ${C_YELLOW}${dang_duoc_tat:-Đang Tạm khóa (Disabled)}${C_RESET}" 2
  fi
done

echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

# echo -en "${C_GREEN}Nhấn phím [Enter] để quay lại Menu...${C_RESET}"
# read -r dummy

[[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-domain-main 1
