#!/bin/bash
# @author: Gia Tuấn
# @website: https://wptangtoc.com
# @email: giatuan@wptangtoc.com

function huong_dan() {
  Tính năng cập nhật WPTangToc OLS là một chức năng quan trọng giúp người dùng dễ dàng nâng cấp script WPTangToc OLS lên phiên bản mới nhất.

  Giới thiệu ngắn gọn:
  Mục đích: Đảm bảo người dùng luôn được sử dụng phiên bản WPTangToc OLS mới nhất với các bản vá lỗi, cải tiến hiệu suất, tính năng mới và cập nhật bảo mật cũng như các thành phần liên quan.

  wptangtoc ols tích hợp sẵn tính năng cập nhật trong menu tự động kiểm tra phiên bản mới nhất từ nguồn phát hành chính thức.
  Người dùng chỉ cần chạy lệnh cập nhật đơn giản, wptangtoc ols sẽ tự động xử lý các bước cần thiết.

  Lợi ích:
  * An toàn và ổn định: Nhận các bản vá lỗi và cập nhật bảo mật mới nhất.
  * Hiệu suất tối ưu: Hưởng lợi từ các cải tiến về tốc độ và tài nguyên.
  * Tính năng mới: Trải nghiệm các công cụ và tùy chọn quản lý máy chủ mới được bổ sung.
  * Tiện lợi: Quá trình cập nhật được tự động hóa, tiết kiệm thời gian và công sức.

  Việc thường xuyên kiểm tra và thực hiện cập nhật WPTangToc OLS giúp máy chủ web của bạn hoạt động hiệu quả, an toàn và luôn được hỗ trợ tốt nhất.
}

PATH='/root/.local/bin:/root/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin'

unset khong_dau_vi_ngon_ngu wptangtocols_version ngon_ngu
. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null # Nạp thư viện UI Xác nhận

clear
echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}HỆ THỐNG ➜ $update_wptangtoc_ols${C_RESET}"
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯${C_RESET}\n"

# ==============================================================================
# 1. KIỂM TRA PHIÊN BẢN (GIAO DIỆN CHỜ)
# ==============================================================================
box_inner_width=${box_inner_width:-71}

echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"

# Dòng 1: Phiên bản hiện tại
line1_text="Phiên bản WPTangToc OLS hiện tại: $version_wptangtoc_ols"
pad1=$((box_inner_width - ${#line1_text} - 2))
[[ $pad1 -lt 0 ]] && pad1=0
echo -e "${C_CYAN}│${C_RESET}  ${C_BOLD_WHITE}Phiên bản WPTangToc OLS hiện tại:${C_RESET} ${C_YELLOW}$version_wptangtoc_ols${C_RESET}$(printf '%*s' "$pad1" "")${C_CYAN}│${C_RESET}"

# Dòng 2: Đang kết nối
line2_text="Đang kết nối máy chủ để kiểm tra phiên bản mới nhất..."
pad2=$((box_inner_width - ${#line2_text} - 2))
[[ $pad2 -lt 0 ]] && pad2=0
echo -e "${C_CYAN}│${C_RESET}  ${C_CYAN}Đang kết nối máy chủ để kiểm tra phiên bản mới nhất...${C_RESET}$(printf '%*s' "$pad2" "")${C_CYAN}│${C_RESET}"

echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯${C_RESET}"

# Lấy phiên bản mới nhất từ server
wptangtocols_version=$(curl -sL --connect-timeout 5 --max-time 10 https://wptangtoc.com/share/version-wptangtoc-ols.txt?domain-update="$Website_chinh")

if [[ -z "$wptangtocols_version" ]]; then
  echo -e "\n${C_RED}❌ Lỗi mạng: Không thể kết nối đến máy chủ WPTangToc. Vui lòng thử lại sau!${C_RESET}"
  sleep 3
  [[ ${1:-} == "98" ]] && exec /etc/wptt/wptt-update-main 1
  [[ ${1:-} == "97" ]] && exec /usr/bin/wptangtoc 1
  exec /etc/wptt/wptt-status2
  exit
fi

# ==============================================================================
# 2. XỬ LÝ LÔGIC PHIÊN BẢN
# ==============================================================================
if [[ "$wptangtocols_version" == "$version_wptangtoc_ols" ]]; then
  echo -e "\n${C_GREEN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_BOLD_WHITE}BẠN ĐANG SỬ DỤNG PHIÊN BẢN MỚI NHẤT${C_RESET}"
  echo -e "${C_GREEN}╰───────────────────────────────────────────────────────────────────────╯${C_RESET}"
  sleep 2
  [[ ${1:-} == "98" ]] && exec /etc/wptt/wptt-update-main 1
  [[ ${1:-} == "97" ]] && exec /usr/bin/wptangtoc 1
  exec /etc/wptt/wptt-status2
else
  # ============================================================================
  # DÙNG THƯ VIỆN GIAO DIỆN ĐỂ HỎI NGƯỜI DÙNG CÓ MUỐN CẬP NHẬT HAY KHÔNG
  # ============================================================================
  if wptt_xac_nhan "Đã có bản cập nhật mới! Bạn có muốn nâng cấp ngay không?" "${C_BOLD_WHITE}Bản hiện tại:${C_RESET} ${C_YELLOW}$version_wptangtoc_ols${C_RESET}" "${C_BOLD_WHITE}Bản mới nhất:${C_RESET} ${C_GREEN}$wptangtocols_version${C_RESET}" "Tiến hành nâng cấp" "Để sau"; then
    echo ""
    _runing "WPTangToc OLS cập nhật Hệ thống lên bản $wptangtocols_version"

    # _runing "$dang_tien_hanh $cap_nhat lên $wptangtocols_version"

    OLD_PWD=$(pwd)
    TMP_DIR=$(mktemp -d)
    cd "$TMP_DIR" || exit

    # Lấy Checksum
    unset checksum_wptangtoc_file id_checksum id_checksum_user
    checksum_wptangtoc_file=$(curl -sL --connect-timeout 10 --max-time 15 https://wptangtoc.com/share/checksum.txt)
    [[ -z "$checksum_wptangtoc_file" ]] && checksum_wptangtoc_file=$(curl -skL --connect-timeout 10 --max-time 15 http://wptangtoc.com/share/checksum.txt)

    mapfile -t checksum_array <<<"$checksum_wptangtoc_file"
    id_checksum="${checksum_array[0]}"
    id_checksum_user="${checksum_array[1]}"

    # Tải file Core
    wget -q --timeout=15 --tries=3 https://wptangtoc.com/share/wptangtoc-ols.zip
    [[ "$id_checksum" != $(md5sum wptangtoc-ols.zip 2>/dev/null | awk '{print $1}') ]] && rm -f wptangtoc-ols.zip
    if [[ ! -f wptangtoc-ols.zip ]]; then
      sleep 2
      wget -q --timeout=15 --tries=3 http://wptangtoc.com/share/wptangtoc-ols.zip --no-check-certificate
      [[ "$id_checksum" != $(md5sum wptangtoc-ols.zip 2>/dev/null | awk '{print $1}') ]] && rm -f wptangtoc-ols.zip
    fi

    # Tải file User
    wget -q --timeout=15 --tries=3 https://wptangtoc.com/share/wptangtoc-ols-user.zip
    [[ "$id_checksum_user" != $(md5sum wptangtoc-ols-user.zip 2>/dev/null | awk '{print $1}') ]] && rm -f wptangtoc-ols-user.zip
    if [[ ! -f wptangtoc-ols-user.zip ]]; then
      wget -q --timeout=15 --tries=3 http://wptangtoc.com/share/wptangtoc-ols-user.zip --no-check-certificate
      [[ "$id_checksum_user" != $(md5sum wptangtoc-ols-user.zip 2>/dev/null | awk '{print $1}') ]] && rm -f wptangtoc-ols-user.zip
    fi

    # Báo lỗi nếu thiếu file
    if [[ ! -f wptangtoc-ols.zip || ! -f wptangtoc-ols-user.zip ]]; then
      [[ -n "$wptangtocols_version" ]] && echo "$wptangtocols_version" >/tmp/wptangtoc-ols-version
      echo -e "\n${C_RED}❌ Tải file thất bại hoặc Checksum không khớp. Đã hủy cập nhật để bảo đảm an toàn!${C_RESET}"
      rm -rf "$TMP_DIR"
      sleep 3
      [[ ${1:-} == "98" ]] && exec /etc/wptt/wptt-update-main 1
      [[ ${1:-} == "97" ]] && exec /usr/bin/wptangtoc 1
      exec /etc/wptt/wptt-status2
      exit
    fi

    # ==========================================================================
    # BACKUP ĐỂ ROLLBACK (PHÒNG HỜ)
    # ==========================================================================
    kiem_tra_ton_tai_nhom=$(cat /etc/group | grep '^wptangtoc-ols:')
    mkdir -p /etc/wptt/wptt-backup-system
    timedate=$(date +%Hgio_%d_%m_%Y)
    BACKUP_FILE="/etc/wptt/wptt-backup-system/wptt_backup_${timedate}_version:$version_wptangtoc_ols.zip"

    (cd /etc/wptt && zip -r -q "$BACKUP_FILE" . -x "wptt-backup-system/*" -x ".wptt.conf" -x ".ram_hien_tai" -x "vhost/*")
    [[ -f "$BACKUP_FILE" ]] && zip -g -j -q "$BACKUP_FILE" /usr/bin/wptangtoc /usr/bin/wptt
    ls -dt /etc/wptt/wptt-backup-system/*.zip 2>/dev/null | tail -n +11 | xargs -r rm -f

    # ==========================================================================
    # TIẾN HÀNH GIẢI NÉN VÀ CHÉP FILE (CORE)
    # ==========================================================================
    unzip -oq wptangtoc-ols.zip
    if ! \cp -rf tool-wptangtoc-ols/* /etc/wptt/ 2>/dev/null; then
      echo -e "\n${C_RED}❌ Lỗi chép file! Đang tự động khôi phục lại phiên bản cũ...${C_RESET}"
      unzip -oq "$BACKUP_FILE" -d /etc/wptt/
      \cp -f /etc/wptt/wptangtoc /usr/bin
      rm -f /etc/wptt/wptangtoc
      \cp -f /etc/wptt/wptt /usr/bin
      rm -f /etc/wptt/wptt
      cd "$OLD_PWD" || cd /root
      rm -rf "$TMP_DIR"
      sleep 3
      [[ ${1:-} == "98" ]] && exec /etc/wptt/wptt-update-main 1
      [[ ${1:-} == "97" ]] && exec /usr/bin/wptangtoc 1
      exec /etc/wptt/wptt-status2
      exit
    fi

    # FIX: Tách lệnh xóa file zip và thư mục giải nén
    rm -f wptangtoc-ols.zip
    rm -rf tool-wptangtoc-ols

    [[ -d /etc/wptt-child ]] && \cp -rf /etc/wptt-child/* /etc/wptt

    chmod -R 700 /etc/wptt
    if [[ -n "$kiem_tra_ton_tai_nhom" ]]; then
      chown root:wptangtoc-ols /etc/wptt /etc/wptt/vhost
      chmod 750 /etc/wptt /etc/wptt/vhost
    else
      chown root:root /etc/wptt /etc/wptt/vhost
    fi

    \cp -f /etc/wptt/wptangtoc /usr/bin
    rm -f /etc/wptt/wptangtoc
    \cp -f /etc/wptt/wptt /usr/bin
    rm -f /etc/wptt/wptt

    # Chown file Vhost cho User
    if [[ -n "$kiem_tra_ton_tai_nhom" ]]; then
      for entry in $(ls -A /etc/wptt/vhost | grep -v '^\.\.conf$' | sort -uV); do
        domain=$(echo $entry | sed 's/^.//' | sed 's/.conf//')
        path="/usr/local/lsws/$domain/html"
        if [[ -d "$path" && -f /etc/wptt/vhost/.$domain.conf ]]; then
          . /etc/wptt/vhost/.$domain.conf
          if [[ -n $(cat /etc/group | grep '^wptangtoc-ols:' | grep "$User_name_vhost") ]]; then
            chown $User_name_vhost:$User_name_vhost /etc/wptt/vhost/.$domain.conf
          fi
        fi
      done
    fi

    # ==========================================================================
    # TIẾN HÀNH GIẢI NÉN VÀ CHÉP FILE (USER)
    # ==========================================================================
    unzip -qo wptangtoc-ols-user.zip
    \cp -rf tool-wptangtoc-ols-user/* /etc/wptt-user

    # FIX: Tách lệnh xóa file zip và thư mục giải nén
    rm -f wptangtoc-ols-user.zip
    rm -rf tool-wptangtoc-ols-user

    if [[ -n "$kiem_tra_ton_tai_nhom" ]]; then
      chown -R root:wptangtoc-ols /etc/wptt-user
      chmod -R 750 /etc/wptt-user
      \cp -f /etc/wptt-user/wptangtoc-user /usr/bin
      chown root:wptangtoc-ols /usr/bin/wptangtoc-user
      chmod 750 /usr/bin/wptangtoc-user
    else
      chown -R root:root /etc/wptt-user
      chmod -R 700 /etc/wptt-user
      \cp -f /etc/wptt-user/wptangtoc-user /usr/bin
      chown root:root /usr/bin/wptangtoc-user
      chmod 700 /usr/bin/wptangtoc-user
    fi

    # Key Activate (Premium)
    if [[ -n "$key_activate" ]]; then
      wget -q --timeout=15 --tries=3 "https://key.wptangtoc.com/?${key_activate}" -U "Activate key WPTangToc OLS" -O premium.zip
      [[ ! -s premium.zip ]] && wget -q --timeout=15 --tries=3 "https://key.wptangtoc.com/?${key_activate}" --no-check-certificate -U "Activate key WPTangToc OLS" -O premium.zip
      if [[ -s premium.zip ]]; then
        unzip -oq premium.zip -d /etc/wptt/add-one
        rm -f premium.zip
        chmod -R 700 /etc/wptt/add-one
      fi
    fi

    # Khử dấu ngôn ngữ
    if [[ "$khong_dau_vi_ngon_ngu" == '1' ]]; then
      find /etc/wptt -type f ! -path '/etc/wptt/lang/wptt-set-lang-vi' ! -path '/etc/wptt/wptt-update2' ! -path '/etc/wptt/wptt-update' ! -name '.*' -exec sed -i 'y/áàảãạăắằẳẵặâấầẩẫậđéèẻẽẹêếềểễệíìỉĩịóòỏõọôốồổỗộơớờởỡợúùủũụưứừửữựýỳỷỹỵÁÀẢÃẠĂẮẰẲẴẶÂẤẦẨẪẬĐÉÈẺẼẸÊẾỀỂỄỆÍÌỈĨỊÓÒỎÕỌÔỐỒỔỖỘƠỚỜỞỠỢÚÙỦŨỤƯỨỪỬỮỰÝỲỶỸỴ/aaaaaaaaaaaaaaaaadeeeeeeeeeeeiiiiiooooooooooooooooouuuuuuuuuuuyyyyyAAAAAAAAAAAAAAAAADEEEEEEEEEEEIIIIIOOOOOOOOOOOOOOOOOUUUUUUUUUUUYYYYY/' {} +
      [[ -n "$kiem_tra_ton_tai_nhom" ]] && sudo find /etc/wptt-user -type f -exec sed -i 'y/áàảãạăắằẳẵặâấầẩẫậđéèẻẽẹêếềểễệíìỉĩịóòỏõọôốồổỗộơớờởỡợúùủũụưứừửữựýỳỷỹỵÁÀẢÃẠĂẮẰẲẴẶÂẤẦẨẪẬĐÉÈẺẼẸÊẾỀỂỄỆÍÌỈĨỊÓÒỎÕỌÔỐỒỔỖỘƠỚỜỞỠỢÚÙỦŨỤƯỨỪỬỮỰÝỲỶỸỴ/aaaaaaaaaaaaaaaaadeeeeeeeeeeeiiiiiooooooooooooooooouuuuuuuuuuuyyyyyAAAAAAAAAAAAAAAAADEEEEEEEEEEEIIIIIOOOOOOOOOOOOOOOOOUUUUUUUUUUUYYYYY/' {} +
    fi

    # Cấu hình phụ trợ (Script Update server)
    curl -sO https://wptangtoc.com/share/update --connect-timeout 10 --max-time 15
    if grep -q 'UPDATE_DONE="YES"' update 2>/dev/null; then
      bash update >/dev/null 2>&1
    fi
    rm -f update

    # Lưu Version
    sed -i "/version_wptangtoc_ols/d" /etc/wptt/.wptt.conf
    echo "version_wptangtoc_ols=$wptangtocols_version" >>/etc/wptt/.wptt.conf
    echo "$wptangtocols_version" >/tmp/wptangtoc-ols-version
    echo "$version_wptangtoc_ols" >/tmp/wptangtoc-ols-version-main

    # Dọn dẹp
    cd "$OLD_PWD" || cd /root
    rm -rf "$TMP_DIR"

    # Thông báo hoàn tất
    _rundone "WPTangToc OLS cập nhật Hệ thống lên bản $wptangtocols_version"

    echo "Cập nhật WPTangToc OLS: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log
    sleep 3

    if [[ -n "${1:-}" ]]; then
      [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-update-main
      [[ "${1:-}" == "97" ]] && exec /usr/bin/wptangtoc 1
    fi
  else
    # Nếu người dùng bấm "2) Không đồng ý / Để sau"
    echo -e "${C_YELLOW}Đã hủy thao tác cập nhật.${C_RESET}"
    sleep 1
  fi

  #nếu người dùng ở trong menu mà ấn vào nhưng sau đó không update sẽ return về đây
  if [[ -n "${1:-}" ]]; then
    [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-update-main
    [[ "${1:-}" == "97" ]] && exec /usr/bin/wptangtoc 1
  fi
  exec /etc/wptt/wptt-status2
fi
