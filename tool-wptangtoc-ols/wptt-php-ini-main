# ==============================================================================
# 3. LOGIC XỬ LÝ (ÁNH XẠ CHUẨN 100% VỚI INDEX MỚI)
# ==============================================================================
run_action() {
  local index=$1
  local script_path=""
  local script_args="98"

  case $index in
  0) script_path="/etc/wptt/php/wptt-sua-phpini" ;;
  1) script_path="/etc/wptt/php/wptt-php-ini-uploads" ;;
  2) script_path="/etc/wptt/php/wptt-php-memory-limit-ram-php" ;;
  3) script_path="/etc/wptt/php/wptt-php-max-execution-time" ;;
  4) script_path="/etc/wptt/php/wptt-php-max-input-time" ;;
  5) script_path="/etc/wptt/php/wptt-php-max-input-vars" ;;
  
  6) script_path="/etc/wptt/php/wptt-domain-php" ;;
  7) script_path="/etc/wptt/php/wptt-php-version-all-server" ;;
  8) script_path="/etc/wptt/php/wptt-php-version-domain" ;;
  9) script_path="/etc/wptt/php/php-extension-them" ;;
  10) script_path="/etc/wptt/php/php-extension-xoa" ;;
  11) script_path="/etc/wptt/php/wptt-khoi-phuc-sua-phpini" ;;
  esac

  if [[ -x "$script_path" || -f "$script_path" ]]; then
    exec bash "$script_path" "$script_args"
  else
    echo -e "\n\033[1;31m[!] Lỗi: Không tìm thấy tệp '$script_path'.\033[0m"
    sleep 2
    exec /etc/wptt/wptt-php-ini-main 1
  fi
}

