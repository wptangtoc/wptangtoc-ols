#!/bin/bash
# @author: Gia Tuấn
# @website: https://wptangtoc.com
# @since: 2026

function huong_dan() {
  Tính năng Xóa database [hay Xóa cơ sở dữ liệu] là hành động loại bỏ hoàn toàn một cơ sở dữ liệu cụ thể, bao gồm tất cả các bảng [tables], dữ liệu chứa trong đó, các chỉ mục [indexes] và cấu trúc liên quan khỏi máy chủ cơ sở dữ liệu [MariaDB]

  Nói một cách đơn giản, đây là việc bạn vứt bỏ toàn bộ một kho chứa dữ liệu cùng với tất cả những gì bên trong nó.

  Mục Đích Chính
  * Loại bỏ database không còn sử dụng: Khi một website hoặc dự án không còn hoạt động, việc xóa database của nó giúp giải phóng dung lượng lưu trữ và tài nguyên máy chủ.
  * Dọn dẹp database thử nghiệm/cũ: Xóa các database đã được tạo cho mục đích kiểm thử hoặc các phiên bản cũ không còn cần thiết.
  * Làm lại từ đầu: Đôi khi cần xóa database cũ để tạo lại một database mới hoàn toàn cho một ứng dụng.
  * Xóa dữ liệu vĩnh viễn: Khi cần loại bỏ hoàn toàn dữ liệu nhạy cảm không còn được phép lưu trữ.

  Lưu ý quan trọng: LUÔN LUÔN SAO LƯU [BACKUP] TRƯỚC KHI XÓA: Hãy chắc chắn bạn có một bản sao lưu đầy đủ và còn tốt của database trước khi quyết định xóa.
}

. /etc/wptt/.wptt.conf
[[ $ngon_ngu == '' ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh
. /etc/wptt/echo-color
echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_BOLD_WHITE}$quan_ly_database ➜ Xoá Database${C_RESET}"
echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯${C_RESET}\n"

. /etc/wptt/.wptt.conf
. /etc/wptt/core-functions

if [[ "${1:-}" == '98' ]]; then
  WPTT_IN_MENU="yes"
  WPTT_MENU_BACK="/etc/wptt/wptt-db-main 1"
fi

wptt_check_mariadb || wptt_die "MariaDB đang bị sập! Hệ thống từ chối cho phép xoá database."

. /etc/wptt/echo-color

# --- KHỞI TẠO FILE BẢO MẬT & BẪY TRAP (CHỐNG LỘ PASSWORD) ---
TEMP_CNF_ROOT=$(mktemp)
chmod 600 "$TEMP_CNF_ROOT"
cat >"$TEMP_CNF_ROOT" <<EOF
[client]
user=${database_admin_username}
password=${database_admin_password}
host=localhost
max_allowed_packet=1G
default-character-set=utf8mb4

[mysqldump]
quick
quote-names
max_allowed_packet=1G
EOF
# Luật Thép: Phải có trap để hệ thống tự xóa file temp khi kết thúc/thoát script
trap "rm -f $TEMP_CNF_ROOT" EXIT

# --- QUÉT DANH SÁCH DATABASE ---
selects=()
for entry in $(mariadb --defaults-extra-file="$TEMP_CNF_ROOT" -e "show databases where \`database\` not in('information_schema', 'test', 'sys', 'mysql', 'performance_schema')" | grep '_dbname'); do
  selects+=("$entry")
done

if [[ ${#selects[@]} -eq 0 ]]; then
  echoDo "Không tìm thấy Database nào (thuộc hệ sinh thái WPTangToc) trên hệ thống!"
  sleep 2
  exec /etc/wptt/wptt-db-main 1
fi

echo "Danh sách Database: "
PS3="$(tput setab 0)-//- Nhập lựa chọn database bạn cần xóa [0=Thoát]: $(tput sgr0)"
select opt in "${selects[@]}"; do
  databaseclear=$opt
  break
done

# --- CHỐT CHẶN THOÁT HIỂM ---
[[ "$databaseclear" == "0" || -z "$databaseclear" ]] && exec /etc/wptt/wptt-db-main 1

read -p "CẢNH BÁO: Xác nhận xóa vĩnh viễn database [$databaseclear]? (y/n): " confirm

if [[ "$confirm" == "y" ]]; then
  UI_STRING="Xóa database $databaseclear và dọn dẹp User"
  _runing "$UI_STRING"

  echo "Xoá database ${databaseclear}: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log

  # 1. Xóa Database
  mariadb --defaults-extra-file="$TEMP_CNF_ROOT" -e "DROP DATABASE IF EXISTS \`${databaseclear}\`;"

  # 2. Xóa User đi kèm (Tách hậu tố _dbname thành _username)
  base_name="${databaseclear%_dbname}"
  username_to_delete="${base_name}_username"
  mariadb --defaults-extra-file="$TEMP_CNF_ROOT" -e "DROP USER IF EXISTS '${username_to_delete}'@'localhost';"

  mariadb --defaults-extra-file="$TEMP_CNF_ROOT" -e "FLUSH PRIVILEGES;"

  _rundone "$UI_STRING"
else
  exec /etc/wptt/wptt-db-main 1
fi

[[ ${1:-} == "98" ]] && exec /etc/wptt/wptt-db-main 1
