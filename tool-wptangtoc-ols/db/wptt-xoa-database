#!/bin/bash
# @author: Gia Tuấn
# @website: https://wptangtoc.com
# @since: 2026

function huong_dan() {
  Tính năng Xóa database [hay Xóa cơ sở dữ liệu] là hành động loại bỏ hoàn toàn một cơ sở dữ liệu cụ thể, bao gồm tất cả các bảng [tables], dữ liệu chứa trong đó, các chỉ mục [indexes] và cấu trúc liên quan khỏi máy chủ cơ sở dữ liệu [MariaDB]

  Nói một cách đơn giản, đây là việc bạn vứt bỏ toàn bộ một kho chứa dữ liệu cùng với tất cả những gì bên trong nó.

  Mục Đích Chính
  * Loại bỏ database không còn sử dụng: Khi một website hoặc dự án không còn hoạt động, việc xóa database của nó giúp giải phóng dung lượng lưu trữ và tài nguyên máy chủ.
  * Dọn dẹp database thử nghiệm/cũ: Xóa các database đã được tạo cho mục đích kiểm thử hoặc các phiên bản cũ không còn cần thiết.
  * Làm lại từ đầu: Đôi khi cần xóa database cũ để tạo lại một database mới hoàn toàn cho một ứng dụng.
  * Xóa dữ liệu vĩnh viễn: Khi cần loại bỏ hoàn toàn dữ liệu nhạy cảm không còn được phép lưu trữ.

  Lưu ý quan trọng: LUÔN LUÔN SAO LƯU [BACKUP] TRƯỚC KHI XÓA: Hãy chắc chắn bạn có một bản sao lưu đầy đủ và còn tốt của database trước khi quyết định xóa.
}

export LC_ALL=C.UTF-8 2>/dev/null || export LC_ALL=en_US.UTF-8 2>/dev/null

. /etc/wptt/.wptt.conf 2>/dev/null
[[ $ngon_ngu == '' ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null     
. /etc/wptt/core-functions 2>/dev/null 

if [[ "${1:-}" == '98' ]]; then
  WPTT_IN_MENU="yes"
  WPTT_MENU_BACK="/etc/wptt/wptt-db-main 1"
fi

wptt_check_mariadb || wptt_die "MariaDB đang bị sập! Hệ thống từ chối cho phép xoá database."

TEMP_CNF_ROOT=$(mktemp)
chmod 600 "$TEMP_CNF_ROOT"
cat >"$TEMP_CNF_ROOT" <<EOF
[client]
user=${database_admin_username}
password=${database_admin_password}
host=localhost
max_allowed_packet=1G
default-character-set=utf8mb4
EOF
trap "rm -f $TEMP_CNF_ROOT" EXIT

# ==============================================================================
# HÀM TRỢ GIÚP VẼ MENU UX 
# ==============================================================================
print_full_row() {
  local index="$1" text="$2"
  local formatted_index=$(printf "%2s" "$index")
  local raw_text="  [${formatted_index}] ${text}"
  local clean_text=$(echo -en "$raw_text" | sed "s/\x1B\[[0-9;]*[a-zA-Z]//g" | tr -d '\r\n')
  local text_len=$(LC_ALL=C.UTF-8 printf "%s" "$clean_text" | wc -m | tr -d ' ' 2>/dev/null)
  [[ -z "$text_len" || "$text_len" == "0" ]] && text_len=${#clean_text}
  local pad=$((78 - text_len - 1))
  [[ $pad -lt 0 ]] && pad=0
  echo -e "${C_CYAN}│${C_RESET}  ${C_YELLOW}[${formatted_index}]${C_RESET} ${text}$(printf '%*s' "$pad" "") ${C_CYAN}│${C_RESET}"
}

print_sub_row() {
  local text="$1"
  local raw_text="       $text"
  local clean_text=$(echo -en "$raw_text" | sed "s/\x1B\[[0-9;]*[a-zA-Z]//g" | tr -d '\r\n')
  local text_len=$(LC_ALL=C.UTF-8 printf "%s" "$clean_text" | wc -m | tr -d ' ' 2>/dev/null)
  [[ -z "$text_len" || "$text_len" == "0" ]] && text_len=${#clean_text}
  local pad=$((78 - text_len - 1))
  [[ $pad -lt 0 ]] && pad=0
  echo -e "${C_CYAN}│${C_RESET}${raw_text}$(printf '%*s' "$pad" "") ${C_CYAN}│${C_RESET}"
}

# ==============================================================================
# QUÉT VÀ PHÂN TÍCH BIÊN CHẾ TỪ VHOST
# ==============================================================================
echo -e "${C_YELLOW}Đang quét và phân tích sở hữu Database, vui lòng chờ...${C_RESET}"

# Đọc cấu hình WPTangToc Vhost để tìm các DB đang được biên chế
declare -A db_map
for vhost_file in /etc/wptt/vhost/.*.conf; do
  if [[ -f "$vhost_file" ]]; then
    domain="${vhost_file##*/.}"
    domain="${domain%.conf}"
    
    # Tìm DB chính được biên chế trong vhost
    db_name=$(grep -oP "^DB_Name_web=\K.*" "$vhost_file" | tr -d '\r\n')
    [[ -n "$db_name" ]] && db_map["$db_name"]="$domain"
  fi
done

db_list=()
for entry in $(mariadb --defaults-extra-file="$TEMP_CNF_ROOT" -e "show databases where \`database\` not in('information_schema', 'test', 'sys', 'mysql', 'performance_schema')" | grep '_dbname'); do
  db_list+=("$entry")
done

if [[ ${#db_list[@]} -eq 0 ]]; then
  echo -e "\n${C_RED}❌ Không tìm thấy Database nào trên hệ thống!${C_RESET}"
  sleep 2
  exec /etc/wptt/wptt-db-main 1
fi

# ==============================================================================
# RENDER GIAO DIỆN TƯƠNG TÁC
# ==============================================================================
total_db=${#db_list[@]}
box_inner_width=78

while true; do
  clear
  echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_YELLOW}QUẢN LÝ DATABASE ➜ XOÁ DATABASE${C_RESET}"
  echo -e "${C_CYAN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
  
  for i in "${!db_list[@]}"; do
    db_name="${db_list[$i]}"
    matched_domain="${db_map[$db_name]}"

    print_full_row "$((i + 1))" "${C_CYAN}${db_name}${C_RESET}"
    if [[ -n "$matched_domain" ]]; then
      print_sub_row "↳ Trạng thái    : ${C_GREEN}THUỘC BIÊN CHẾ ($matched_domain)${C_RESET}"
    else
      print_sub_row "↳ Trạng thái    : ${C_RED}MỒ CÔI (Có thể xóa an toàn)${C_RESET}"
    fi
  done
  
  echo -e "${C_CYAN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
  
  footer_text="Nhập số (1-${total_db}) | [0] Quay lại Menu Quản lý DB"
  len_footer=$(LC_ALL=C.UTF-8 printf "%s" "$footer_text" | wc -m | tr -d ' ' 2>/dev/null)
  [[ -z "$len_footer" || "$len_footer" == "0" ]] && len_footer=${#footer_text}
  pad_footer=$(((78 - len_footer) / 2))
  echo -e "${C_CYAN}│${C_RESET}$(printf '%*s' "$pad_footer" "")Nhập số (1-${total_db}) | ${C_RED}[0] Quay lại Menu Quản lý DB${C_RESET}$(printf '%*s' "$((78 - len_footer - pad_footer))" "")${C_CYAN}│${C_RESET}"
  
  echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯${C_RESET}"

  echo -en "${C_YELLOW}>> Lựa chọn database cần xóa: ${C_RESET}"
  read -r choice

  if [[ "$choice" == "0" || "$choice" == "q" ]]; then
    exec /etc/wptt/wptt-db-main 1
    break
  elif [[ "$choice" =~ ^[0-9]+$ ]] && [ "$choice" -ge 1 ] && [ "$choice" -le "$total_db" ]; then
    
    selected_db="${db_list[$((choice - 1))]}"
    selected_domain="${db_map[$selected_db]}"
    
    # Cảnh báo động tùy theo trạng thái Biên chế
    warn_title="Sếp có chắc chắn muốn XÓA VĨNH VIỄN database: $selected_db?"
    warn_sub="Trạng thái: MỒ CÔI (Chưa phát hiện thuộc biên chế website nào)"
    
    if [[ -n "$selected_domain" ]]; then
      warn_sub="${C_RED}CẢNH BÁO NGUY HIỂM: Database đang thuộc BIÊN CHẾ của website $selected_domain${C_RESET}"
      warn_title="Sếp đang cố gắng xóa một Database đang HOẠT ĐỘNG!"
    fi

    # ==========================================================================
    # XÁC NHẬN BẢO MẬT & THỰC THI XÓA
    # ==========================================================================
    echo ""
    if wptt_xac_nhan "$warn_title" "$warn_sub" "Hành động này không thể hoàn tác nếu chưa Backup!" "Có, XÓA NGAY LẬP TỨC" "Không, Hủy bỏ an toàn"; then
      
      _runing "Đang xóa database $selected_db..."
      echo "Xoá database ${selected_db}: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log

      # 1. Chỉ xóa Database (Tuyệt đối không xóa User)
      mariadb --defaults-extra-file="$TEMP_CNF_ROOT" -e "DROP DATABASE IF EXISTS \`${selected_db}\`;"
      mariadb --defaults-extra-file="$TEMP_CNF_ROOT" -e "FLUSH PRIVILEGES;"
      _rundone "Đã xóa Database khỏi MariaDB."

      # 2. Xử lý gạch tên khỏi sổ hộ khẩu (Biên chế)
      if [[ -n "$selected_domain" ]]; then
        _runing "Đang gỡ bỏ biên chế khỏi website $selected_domain..."
        vhost_conf="/etc/wptt/vhost/.$selected_domain.conf"
        if [[ -f "$vhost_conf" ]]; then
          sed -i '/^DB_Name_web=/d' "$vhost_conf"
          # Có thể xóa luôn User và Pass ở Vhost nếu cần, nhưng sếp chỉ yêu cầu xóa DB_Name_web
        fi
        _rundone "Đã gạch tên database khỏi cấu hình Website."
        echo -e "\n${C_RED}[!] Lưu ý: Website $selected_domain hiện tại đang bị mất kết nối Database!${C_RESET}"
      fi

      echo -e "\n${C_GREEN}➜ Nhấn [Enter] để quay lại Menu...${C_RESET}"
      read -r dummy
      exec /etc/wptt/wptt-db-main 1
    else
      echo -e "\n${C_GREEN}Đã hủy lệnh xóa. Dữ liệu của sếp vẫn an toàn!${C_RESET}"
      sleep 2
    fi
  else
    echo -e "\n${C_RED}[!] Lựa chọn không hợp lệ. Vui lòng nhập từ 1 đến ${total_db}.${C_RESET}"
    sleep 1.5
  fi
done
