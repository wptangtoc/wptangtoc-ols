#!/bin/bash
function huong_dan() {
  Đây là tính năng chuyển đổi công nghệ lưu trữ database sang [MyISAM, InnoDB, Aria]

  Tính năng Chuyển đổi công nghệ lưu trữ database sang [MyISAM, InnoDB, Aria] là khả năng thay đổi cơ chế [storage engine] mà hệ quản trị cơ sở dữ liệu MariaDB sử dụng để lưu trữ, truy xuất và quản lý dữ liệu trong các bảng [table] của bạn. Mỗi công nghệ lưu trữ có những đặc điểm, ưu và nhược điểm riêng về hiệu năng, tính năng và độ tin cậy.

  Nói một cách đơn giản, đây là việc bạn chọn một kiểu nhà kho khác cho dữ liệu của mình, tùy thuộc vào nhu cầu sử dụng cụ thể. Ba cái tên bạn đề cập là các storage engine phổ biến:

  * InnoDB: Thường là mặc định và được khuyến nghị cho hầu hết các ứng dụng hiện đại. Hỗ trợ giao dịch [transactions ACID], khóa ở cấp độ hàng [row-level locking giúp xử lý đồng thời tốt], ràng buộc khóa ngoại [foreign keys], và khả năng phục hồi sau sự cố [crash recovery] tốt. Rất quan trọng cho tính toàn vẹn dữ liệu.
  * MyISAM: Công nghệ cũ hơn, nổi tiếng với tốc độ đọc nhanh trong một số trường hợp nhất định [ít ghi, ít truy cập đồng thời]. Sử dụng khóa ở cấp độ bảng [table-level locking], không hỗ trợ transactions và khóa ngoại. Dễ bị hỏng dữ liệu hơn InnoDB khi có sự cố.
  * Aria: Do MariaDB phát triển, được thiết kế như một sự thay thế cải tiến và an toàn hơn MyISAM. Nó cung cấp khả năng phục hồi sau sự cố tốt hơn MyISAM và một số tính năng khác, nhưng vẫn có những đặc điểm riêng.

  Mục Đích Chính Của Việc Chuyển Đổi
  * Tận dụng tính năng cụ thể:
  * Chuyển sang InnoDB để có giao dịch, khóa ngoại, an toàn dữ liệu cao hơn.
  * Chuyển từ MyISAM sang InnoDB/Aria để cải thiện độ tin cậy.
  * Tối ưu hiệu năng: Chọn engine phù hợp với loại tác vụ của website [đọc nhiều hay ghi nhiều, mức độ truy cập đồng thời].
  * Hiện đại hóa: Chuyển từ các engine cũ [như MyISAM] sang các engine mạnh mẽ và nhiều tính năng hơn.
  * Yêu cầu của ứng dụng: Một số ứng dụng web hoặc framework có thể yêu cầu hoặc hoạt động tốt nhất với một storage engine cụ thể.

}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null # Nạp thư viện UX Bo Cong

clear
echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}QUẢN LÝ DATABASE ➜ Chuyển đổi Storage Engine (InnoDB/MyISAM/Aria)${C_RESET}"
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

if [[ "${1:-}" == '98' ]]; then
  WPTT_IN_MENU="yes"
  WPTT_MENU_BACK="/etc/wptt/wptt-db-main 1"
fi

wptt_check_mariadb || wptt_die "MariaDB đang bị sập! Hệ thống từ chối không cho phép can thiệp cấu trúc Database."

# Lấy và kiểm tra đối số Engine ($2)
loai_luu_tru=${2:-}
if [[ -n "$loai_luu_tru" ]]; then
  if ! echo "InnoDB MyISAM Aria" | grep -wq "$loai_luu_tru"; then
    unset loai_luu_tru
  fi
fi

# Lấy và kiểm tra đối số Tên miền ($1)
NAME=${1:-}
[[ "$NAME" == "98" ]] && NAME=""

if [[ -z "$NAME" ]]; then
  . /etc/wptt/tenmien-them-lua-chon-tat-ca-website-by-wordpress 2>/dev/null
  lua_chon_NAME "chuyển đổi định dạng lưu trữ database"
fi

# ==============================================================================
# HÀM MENU CHỌN STORAGE ENGINE (UX BO CONG)
# ==============================================================================
function lua_chon_engine() {
  if [[ -n "$loai_luu_tru" ]]; then
    dinh_dang_luu_tru_database_storege_engine="$loai_luu_tru"
    return
  fi

  echo -e "\n${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_YELLOW}CHỌN CÔNG NGHỆ LƯU TRỮ (STORAGE ENGINE) MỤC TIÊU${C_RESET}"
  echo -e "${C_CYAN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
  left_text "  ${C_CYAN}1)${C_RESET} ${C_BOLD_WHITE}InnoDB${C_RESET} (Khuyên dùng: Hỗ trợ Transaction, Khóa ngoại, An toàn)" 2
  left_text "  ${C_CYAN}2)${C_RESET} ${C_BOLD_WHITE}MyISAM${C_RESET} (Tốc độ đọc nhanh, Cấu trúc cũ, Không Transaction)" 2
  left_text "  ${C_CYAN}3)${C_RESET} ${C_BOLD_WHITE}Aria${C_RESET}   (Cải tiến của MyISAM, Phục hồi sau sự cố tốt hơn)" 2
  echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯${C_RESET}"

  while true; do
    echo -en "${C_CYAN}Nhập lựa chọn của bạn (1-3) [0=Thoát]: ${C_RESET}"
    read -r REPLY
    case "$REPLY" in
    0)
      echo -e "\n${C_GREEN}Đang thoát...${C_RESET}"
      [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-db-main 1
      exit 0
      ;;
    1)
      dinh_dang_luu_tru_database_storege_engine="InnoDB"
      break
      ;;
    2)
      dinh_dang_luu_tru_database_storege_engine="MyISAM"
      break
      ;;
    3)
      dinh_dang_luu_tru_database_storege_engine="Aria"
      break
      ;;
    *) echo -e "${C_RED}Lựa chọn không hợp lệ!${C_RESET}" ;;
    esac
  done
}

# ==============================================================================
# NHÁNH 1: XỬ LÝ HÀNG LOẠT "TẤT CẢ WEBSITE"
# ==============================================================================
if [[ "$NAME" == 'Tất cả website' ]]; then
  lua_chon_engine

  echo -e "\n${C_GREEN}Đang chuẩn bị chuyển đổi toàn bộ hệ thống sang $dinh_dang_luu_tru_database_storege_engine...${C_RESET}"

  if [ "$(ls -A /etc/wptt/vhost 2>/dev/null | grep -v '^\.\.conf$' | sort -uV)" ]; then
    for entry in $(ls -A /etc/wptt/vhost | grep -v '^\.\.conf$' | sort -uV); do
      domain=$(echo "$entry" | sed 's/^.//' | sed 's/.conf//')
      path="/usr/local/lsws/$domain/html/wp-config.php"

      if [[ "$domain" == ?*.?* && -f "$path" ]]; then
        _runing "Website $domain: Đang chuyển đổi sang $dinh_dang_luu_tru_database_storege_engine..."
        (/etc/wptt/db/chuyen-doi-dinh-dang-luu-tru-storage-engine-innodb-myisam-aria "$domain" "$dinh_dang_luu_tru_database_storege_engine" >/dev/null 2>&1)
        _rundone "Website $domain: Đã hoàn tất chuyển đổi"
      fi
    done
  fi

  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-db-main 1
  exit 0
fi

# ==============================================================================
# NHÁNH 2: XỬ LÝ 1 WEBSITE CỤ THỂ
# ==============================================================================
[[ "$NAME" == "0" || -z "$NAME" ]] && exec /etc/wptt/wptt-db-main 1

pathcheck="/etc/wptt/vhost/.$NAME.conf"
if [[ ! -f "$pathcheck" ]]; then
  echo -e "\n${C_RED}❌ Tên miền không tồn tại trên hệ thống này!${C_RESET}"
  sleep 3
  exec /etc/wptt/wptt-db-main 1
  exit 1
fi

pathcheckwp="/usr/local/lsws/$NAME/html/wp-load.php"
if [[ ! -f "$pathcheckwp" ]]; then
  echo -e "\n${C_RED}❌ Lỗi: Hệ thống xác nhận bạn không sử dụng mã nguồn WordPress!${C_RESET}"
  echo -e "${C_YELLOW}⚠️ Tính năng này vận hành dựa trên lõi WP-CLI nên chỉ hỗ trợ WordPress.${C_RESET}"
  sleep 3
  exec /etc/wptt/wptt-db-main 1
  exit 1
fi

# Gọi Menu chọn Engine nếu chưa truyền đối số
lua_chon_engine

echo -e "\n${C_GREEN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_BOLD_WHITE}TIẾN HÀNH CHUYỂN ĐỔI STORAGE ENGINE${C_RESET}"
echo -e "${C_GREEN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
left_text "Website mục tiêu : ${C_YELLOW}$NAME${C_RESET}" 2
left_text "Engine định dạng : ${C_YELLOW}$dinh_dang_luu_tru_database_storege_engine${C_RESET}" 2
echo -e "${C_GREEN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

. /etc/wptt/php/php-cli-domain-config "$NAME" 2>/dev/null
echo "Chuyển đạng dạng lưu trữ sang $dinh_dang_luu_tru_database_storege_engine cho website $NAME : $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log

cd "/usr/local/lsws/$NAME/html"

_runing "Đang quét Database để tìm các Table chưa ở định dạng $dinh_dang_luu_tru_database_storege_engine..."
# WP-CLI Query lấy danh sách Table lệch Engine
WPTABLES=($(/usr/local/lsws/lsphp${phien_ban_php_domain_thuc_thi}/bin/php /usr/local/bin/wp db query "SHOW TABLE STATUS WHERE Engine != '$dinh_dang_luu_tru_database_storege_engine'" --allow-root --silent --skip-column-names 2>/dev/null | awk '{ print $1}'))

if [[ ${#WPTABLES[@]} -gt 0 ]]; then
  _rundone "Quét hoàn tất! Tìm thấy ${#WPTABLES[@]} Table cần được chuyển đổi."
  echo ""

  for WPTABLE in "${WPTABLES[@]}"; do
    _runing "Đang Convert Table: [${WPTABLE}] ➜ $dinh_dang_luu_tru_database_storege_engine"
    /usr/local/lsws/lsphp${phien_ban_php_domain_thuc_thi}/bin/php /usr/local/bin/wp db query "ALTER TABLE \`${WPTABLE}\` ENGINE=$dinh_dang_luu_tru_database_storege_engine" --allow-root --path="/usr/local/lsws/$NAME/html" >/dev/null 2>&1
    _rundone "Đã Convert Table: [${WPTABLE}] ➜ $dinh_dang_luu_tru_database_storege_engine"
  done

  echo ""
  _rundone "Hoàn tất chuyển đổi Database sang $dinh_dang_luu_tru_database_storege_engine cho website $NAME!"
else
  _rundone "Tuyệt vời! Tất cả các Table đều đã ở định dạng $dinh_dang_luu_tru_database_storege_engine, không cần chuyển đổi thêm!"
fi

# Điều hướng thoát nếu gọi từ Menu Database (98)
if [[ "${1:-}" == "98" ]]; then
  exec /etc/wptt/wptt-db-main 1
fi
