#!/bin/bash

function huong_dan() {
  Tính năng Thiết lập tự động tối ưu hóa database là việc cài đặt một lịch trình để hệ thống tự động thực hiện các tác vụ bảo trì trên cơ sở dữ liệu [database] của bạn nhằm duy trì và cải thiện hiệu suất hoạt động cũng như thu hồi không gian lưu trữ không cần thiết.

  Nói một cách đơn giản, đây là cách bạn lên lịch dọn dẹp và sắp xếp lại kho dữ liệu [database] của mình một cách tự động, ví dụ như hàng tuần hoặc hàng tháng, để nó luôn hoạt động nhanh nhẹn và hiệu quả.

  Mục Đích Chính
  * Cải thiện hiệu suất truy vấn: Theo thời gian, việc thêm, sửa, xóa dữ liệu có thể làm các bảng bị phân mảnh và chỉ mục [index] hoạt động kém hiệu quả. Tối ưu hóa giúp sắp xếp lại dữ liệu và chỉ mục, làm cho các truy vấn chạy nhanh hơn.
  * Thu hồi dung lượng lưu trữ lãng phí: Khi xóa dữ liệu, không gian trống thường không được giải phóng ngay. Tối ưu hóa có thể giúp gom lại không gian này, giảm kích thước tổng thể của database.
  * Cập nhật thống kê bảng: Giúp bộ tối ưu truy vấn của database có thông tin mới nhất về dữ liệu, từ đó đưa ra kế hoạch thực thi truy vấn hiệu quả hơn.
  * Bảo trì phòng ngừa: Giúp ngăn chặn các vấn đề về hiệu suất hoặc lỗi phát sinh nghiêm trọng hơn trong tương lai.
  * Giảm thiểu công việc thủ công: Bạn không cần phải nhớ và tự chạy các lệnh tối ưu hóa bằng tay.

  Tính năng này giúp cơ sở dữ liệu của bạn hoạt động ổn định và hiệu quả hơn về lâu dài với ít sự can thiệp thủ công hơn.
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null # Nạp thư viện UX Bo Cong

clear
echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}QUẢN LÝ DATABASE ➜ Thiết lập Tự động Tối ưu hóa Database${C_RESET}"
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯${C_RESET}"

if [[ "${1:-}" == '98' ]]; then
  WPTT_IN_MENU="yes"
  WPTT_MENU_BACK="/etc/wptt/wptt-db-main 1"
fi

wptt_check_mariadb || wptt_die "MariaDB đang bị sập! Hệ thống từ chối cho phép thiết lập tối ưu database tự động."

CRON_FILE="/etc/cron.d/database-toi-uu-hoa-all.cron"

# Hàm chuyển đổi số thứ sang Text hiển thị (Đồng bộ với wptt-times-tuan)
get_day_name() {
  case "$1" in
  0 | 7) echo "Chủ nhật hàng tuần" ;;
  1) echo "Thứ hai hàng tuần" ;;
  2) echo "Thứ ba hàng tuần" ;;
  3) echo "Thứ tư hàng tuần" ;;
  4) echo "Thứ năm hàng tuần" ;;
  5) echo "Thứ sáu hàng tuần" ;;
  6) echo "Thứ bảy hàng tuần" ;;
  *) echo "Hàng ngày" ;;
  esac
}

# ==============================================================================
# KIỂM TRA TRẠNG THÁI HIỆN TẠI VÀ IN BẢNG THÔNG BÁO
# ==============================================================================
echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
if [[ -f "$CRON_FILE" ]]; then

  # Đọc file Cron chuẩn xác bất chấp số lượng dấu cách
  read -r c_phut c_gio c_ngay c_thang c_thu c_user c_cmd <"$CRON_FILE"

  # Phân tích ngày tháng
  if [[ "$c_ngay" != "*" && "$c_thu" == "*" ]]; then
    thu_text="Ngày $c_ngay hàng tháng"
  elif [[ "$c_thu" == "*" ]]; then
    thu_text="Hàng ngày"
  else
    thu_text=$(get_day_name "$c_thu")
  fi

  # Format thời gian đẹp (VD: 15:01 thay vì 15:1)
  time_format=$(printf "%02d:%02d" "${c_gio:-0}" "${c_phut:-0}")

  left_text "Trạng thái    : ${C_GREEN}ĐÃ KÍCH HOẠT${C_RESET}" 2
  left_text "Lịch trình    : ${C_YELLOW}Lúc $time_format, $thu_text${C_RESET}" 2
  echo -e "${C_CYAN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
  left_text "Hệ thống sẽ tự động dọn dẹp dung lượng thừa và cập nhật" 2
  left_text "chỉ mục (Index) Database theo đúng lịch trình trên." 2
else
  left_text "Trạng thái    : ${C_RED}CHƯA KÍCH HOẠT${C_RESET}" 2
  echo -e "${C_CYAN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
  left_text "Nên bật tính năng này để Database tự động chống phân mảnh," 2
  left_text "giúp các truy vấn luôn đạt tốc độ xử lý nhanh nhất." 2
fi
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

# ==============================================================================
# NHÁNH 1: ĐÃ KÍCH HOẠT -> HỎI ĐỂ TẮT (DISABLE)
# ==============================================================================
if [[ -f "$CRON_FILE" ]]; then
  if wptt_xac_nhan "Tính năng Tự động Tối ưu hóa đang bật. Bạn có muốn TẮT không?" "" "" "Đồng ý Tắt" "Giữ nguyên (Hủy)"; then
    echo ""
    _runing "Đang gỡ bỏ cấu hình tự động tối ưu hóa..."
    rm -f "$CRON_FILE"
    rm -f /etc/cron.d/database-toi-uu-hoa-all_cron 2>/dev/null

    if grep -qi "ubuntu" /etc/os-release 2>/dev/null; then
      systemctl restart cron.service
    else
      systemctl restart crond.service
    fi
    _rundone "Đã TẮT tính năng Tự động tối ưu hóa Database!"
    sleep 2
  else
    echo -e "${C_YELLOW}Đã hủy thao tác.${C_RESET}\n"
  fi

  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-db-main 1
  exit 0
fi

# NHÁNH 2: CHƯA KÍCH HOẠT -> TIẾN HÀNH THIẾT LẬP (ENABLE)
echo -e "${C_YELLOW}Thiết lập Lịch trình Tự động tối ưu hóa Database:${C_RESET}"
echo -en "${C_CYAN}Nhập Giờ bạn muốn chạy (Từ 0 đến 23) [Mặc định: 1h sáng]: ${C_RESET}"
read gio

if ! [[ "$gio" =~ ^[0-9]+$ ]] || ((gio < 0 || gio > 23)); then
  echo -e "${C_YELLOW}⚠️ Nhập không hợp lệ. Hệ thống tự chọn 1h sáng (Khung giờ vắng khách nhất).${C_RESET}"
  gio="1"
fi

# GỌI THƯ VIỆN WPTT-TIMES-TUAN ĐỂ IN GIAO DIỆN CHỌN NGÀY
. /etc/wptt/wptt-times-tuan
tuan

# Xử lý Logic thời gian sau khi lấy biến từ thư viện
phut=$(shuf -i2-58 -n1 2>/dev/null)
[[ -z "$phut" ]] && phut='0'

# Khởi tạo lệnh mặc định cho hàng tuần/hàng ngày
cron_thuc_thi="$phut $gio * * $thu"
thu_text=$(get_day_name "$thu")

# Bắt sự kiện nếu chọn Số 9 (Hàng tháng) từ thư viện
if [[ "$thu" == "9" ]]; then
  cron_thuc_thi="$phut $gio $ngay_cua_thang * *"
  thu_text="Ngày $ngay_cua_thang hàng tháng"
fi

echo ""
_runing "Đang lưu lịch trình Cronjob vào hệ thống..."
cat >"$CRON_FILE" <<EOF
$cron_thuc_thi root /etc/wptt/wordpress/all-database >/dev/null 2>&1
EOF

if grep -qi "ubuntu" /etc/os-release 2>/dev/null; then
  ln -sf "$CRON_FILE" /etc/cron.d/database-toi-uu-hoa-all_cron
  systemctl restart cron.service
else
  systemctl restart crond.service
fi
_rundone "Cấu hình lịch trình hoàn tất"

echo "Thiết lập tự động tối ưu hoá database : $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log

time_format=$(printf "%02d:%02d" "${gio:-0}" "${phut:-0}")

echo -e "\n${C_GREEN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_BOLD_WHITE}HOÀN TẤT THIẾT LẬP TỰ ĐỘNG TỐI ƯU${C_RESET}"
echo -e "${C_GREEN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
left_text "Lịch trình  : ${C_YELLOW}Lúc $time_format, $thu_text${C_RESET}" 2
left_text "Hành động   : Chống phân mảnh và Rebuild Index toàn bộ Database" 2
echo -e "${C_GREEN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

[[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-db-main 1
