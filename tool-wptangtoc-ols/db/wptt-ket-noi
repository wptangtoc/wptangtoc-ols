# sed -i "/DB_HOST/s/\"/'/g" "$wp_config_php_path"
# sed -i "/DB_USER/s/\"/'/g" "$wp_config_php_path"
# sed -i "/DB_PASSWORD/s/\"/'/g" "$wp_config_php_path"

