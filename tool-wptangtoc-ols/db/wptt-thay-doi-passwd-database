#!/bin/bash
# @author: Gia Tuấn
# @website: https://wptangtoc.com
# @since: 2026

function huong_dan() {
  Tính năng Thay đổi password database là quá trình cập nhật mật khẩu cho một tài khoản người dùng [username] cụ thể đã được tạo để truy cập và tương tác với cơ sở dữ liệu [database] trên máy chủ MariaDB.

  Nói một cách đơn giản, đây là cách bạn đổi chìa khóa và ổ khoá cho một người gác cổng [user] của kho chứa dữ liệu [database] của bạn.

  Mục Đích Chính
  * Tăng cường bảo mật [quan trọng nhất]:
  * Thay đổi mật khẩu định kỳ là một thói quen tốt.
  * Cần đổi ngay nếu nghi ngờ mật khẩu cũ đã bị lộ.
  * Khi nhân viên/người quản lý cũ nghỉ việc: Đổi mật khẩu của user mà họ sử dụng.
  * Sau khi thiết lập ban đầu: Đặt một mật khẩu mạnh hơn cho user sau khi tạo.
  * Tuân thủ chính sách mật khẩu: Đảm bảo mật khẩu đủ mạnh và phức tạp theo quy định.

}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null # Nạp thư viện UI Xác nhận

if [[ "${1:-}" == '98' ]]; then
  WPTT_IN_MENU="yes"
  WPTT_MENU_BACK="/etc/wptt/wptt-db-main 1"
fi

clear
echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}${quan_ly_database} ➜ Thay đổi Mật khẩu Database${C_RESET}"
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

wptt_check_mariadb || wptt_die "MariaDB đang bị sập! Hệ thống từ chối thay đổi password database để đảm bảo an toàn."

# ==============================================================================
# CHỌN WEBSITE VÀ KIỂM TRA TRẠNG THÁI
# ==============================================================================
. /etc/wptt/tenmien
lua_chon_NAME "Đổi Mật khẩu Database"

[[ "$NAME" == "0" || -z "$NAME" ]] && {
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-db-main 1
  return 2>/dev/null || exit
}

pathcheck="/etc/wptt/vhost/.$NAME.conf"
if [[ ! -f "$pathcheck" ]]; then
  echo -e "\n${C_RED}❌ Tên miền không tồn tại trên hệ thống này!${C_RESET}"
  sleep 3
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-db-main 1
  return 2>/dev/null || exit
fi

. "$pathcheck" 2>/dev/null

if [[ "$DB_User_web" == "$database_admin_username" ]]; then
  echo -e "\n${C_RED}❌ Lỗi: Không thể đổi mật khẩu cho tài khoản ROOT thông qua chức năng này!${C_RESET}"
  sleep 4
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-db-main 1
  return 2>/dev/null || exit
fi

# ==============================================================================
# XÁC NHẬN VÀ THỰC THI (UX BO CONG)
# ==============================================================================
echo ""
if wptt_xac_nhan "Xác nhận ĐỔI MẬT KHẨU Database?" "${C_BOLD_WHITE}Website:${C_RESET} ${C_YELLOW}$NAME${C_RESET} | ${C_BOLD_WHITE}User DB:${C_RESET} ${C_CYAN}$DB_User_web${C_RESET}" "Hệ thống sẽ tạo ngẫu nhiên một mật khẩu siêu bảo mật mới" "Đồng ý Đổi" "Hủy thao tác"; then
  echo ""

  _runing "Đang khởi tạo mật khẩu và cập nhật MariaDB..."
  echo "Thay đổi password Database website $NAME : $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log

  # Tạo mật khẩu ngẫu nhiên
  password=$(openssl rand -base64 32 | tr -dc 'a-zA-Z0-9' | head -c 36)

  TEMP_CNF_ROOT=$(mktemp)
  chmod 600 "$TEMP_CNF_ROOT"
  cat >"$TEMP_CNF_ROOT" <<EOF
[client]
user=${database_admin_username}
password=${database_admin_password}
host=localhost
max_allowed_packet=1G
default-character-set=utf8mb4
EOF

  # Bẫy an toàn: Tự động xóa file temp khi script thoát
  trap "rm -f $TEMP_CNF_ROOT" EXIT

  mariadb --defaults-extra-file="$TEMP_CNF_ROOT" -e "SET PASSWORD FOR '$DB_User_web'@'localhost' = PASSWORD('${password}')" >/dev/null 2>&1

  check_remote=$(mariadb --defaults-extra-file="$TEMP_CNF_ROOT" -e "SHOW GRANTS FOR '$DB_User_web'@'%';" 2>/dev/null)
  if [[ -n "$check_remote" ]]; then
    mariadb --defaults-extra-file="$TEMP_CNF_ROOT" -e "SET PASSWORD FOR '$DB_User_web'@'%' = PASSWORD('${password}')" >/dev/null 2>&1
  fi

  mariadb --defaults-extra-file="$TEMP_CNF_ROOT" -e "FLUSH PRIVILEGES" >/dev/null 2>&1
  rm -f "$TEMP_CNF_ROOT"

  # Ghi đè vào file cấu hình WPTangToc
  sed -i "/DB_Password_web=/d" "$pathcheck"
  echo "DB_Password_web=$password" >>"$pathcheck"

  systemctl restart mariadb.service >/dev/null 2>&1
  /usr/local/lsws/bin/lswsctrl restart >/dev/null 2>&1

  _rundone "Đang khởi tạo mật khẩu và cập nhật MariaDB..."

  # ==============================================================================
  # CẬP NHẬT TỰ ĐỘNG VÀO WP-CONFIG.PHP
  # ==============================================================================
  wp_config_status="Không tìm thấy WordPress để tự động cập nhật"
  checkplugin="/usr/local/lsws/$NAME/html/wp-config.php"
  if [[ -f "$checkplugin" || -f /usr/local/lsws/$NAME/html/configuration.php ]]; then
    _runing "Đồng bộ tài khoản database mới với mã nguồn"
    (/etc/wptt/db/wptt-ket-noi $NAME >/dev/null 2>&1)
    _rundone "Đồng bộ tài khoản database mới với mã nguồn"
  fi

  # ==============================================================================
  # BẢNG BÁO CÁO THÀNH CÔNG (UX BO CONG)
  # ==============================================================================
  echo -e "\n${C_GREEN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_BOLD_WHITE}HOÀN TẤT THAY ĐỔI MẬT KHẨU DATABASE${C_RESET}"
  echo -e "${C_GREEN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
  left_text "Website thao tác : ${C_YELLOW}$NAME${C_RESET}" 2
  left_text "Database Name    : ${C_CYAN}$DB_Name_web${C_RESET}" 2
  left_text "Database User    : ${C_CYAN}$DB_User_web${C_RESET}" 2
  left_text "Mật khẩu MỚI     : ${C_YELLOW}$password${C_RESET}" 2
  echo -e "${C_GREEN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
  left_text "WordPress Status : ${C_GREEN}$wp_config_status${C_RESET}" 2
  echo -e "${C_GREEN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

else
  echo -e "${C_YELLOW}Đã hủy thao tác Đổi mật khẩu.${C_RESET}"
fi

[[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-db-main 1
