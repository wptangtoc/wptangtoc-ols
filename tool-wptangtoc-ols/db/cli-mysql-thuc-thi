#!/bin/bash

function huong_dan() {
  MySQL CLI [còn gọi là MySQL Monitor] là một công cụ giao diện dòng lệnh cho phép bạn tương tác trực tiếp với máy chủ MySQL. Bạn có thể thực hiện mọi tác vụ từ tạo cơ sở dữ liệu, quản lý bảng, đến truy vấn dữ liệu phức tạp.
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null

if [[ "${1:-}" == '98' ]]; then
  WPTT_IN_MENU="yes"
  WPTT_MENU_BACK="/etc/wptt/wptt-db-main 1"
fi

clear
echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}${quan_ly_database} ➜ Thực thi MySQL CLI (Command Line)${C_RESET}"
echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

wptt_check_mariadb || wptt_die "MariaDB đang bị sập! Hệ thống từ chối mở kết nối MySQL CLI."

function lua_chon_NAME() {
  unset NAME selects
  selects=("root|[Tài khoản quản trị Tối cao]")
  local box_inner_width=${box_inner_width:-71}

  if [ "$(ls -A /etc/wptt/vhost 2>/dev/null | grep -v '^\.\.conf$' | sort -uV)" ]; then
    for entry in $(ls -A /etc/wptt/vhost | grep -v '^\.\.conf$' | sort -uV); do
      local dom=$(echo "$entry" | sed 's/^.//' | sed 's/.conf//')
      if [[ "$dom" == ?*.?* && -f "/etc/wptt/vhost/.$dom.conf" ]]; then
        selects+=("$dom")
      fi
    done
  fi

  echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
  local title_text="${nhap_lua_chon_website_cua_ban:-Lựa chọn tài khoản} bạn muốn kết nối MySQL CLI:"
  local len=$(echo -n "$title_text" | awk '{print length($0)}')
  local pad_r=$((box_inner_width - len - 2))
  [[ $pad_r -lt 0 ]] && pad_r=0
  echo -e "${C_CYAN}│${C_RESET}  ${C_YELLOW}${title_text}${C_RESET}$(printf '%*s' "$pad_r" "")${C_CYAN}│${C_RESET}"

  local line_len=$((len + 3))
  local pad_line_r=$((box_inner_width - line_len))
  [[ $pad_line_r -lt 0 ]] && pad_line_r=0
  local short_line=$(printf "%${line_len}s" "" | sed 's/ /─/g')
  echo -e "${C_CYAN}├${short_line}$(printf '%*s' "$pad_line_r" "")│${C_RESET}"

  local i=1
  for item in "${selects[@]}"; do
    local dom=$(echo "$item" | cut -d'|' -f1)
    local desc=$(echo "$item" | cut -d'|' -f2)

    if [[ "$dom" == "root" ]]; then
      local item_text=$(printf "  ${C_CYAN}%3d)${C_RESET} ${C_RED}%-25s${C_RESET} ${C_YELLOW}%s${C_RESET}" "$i" "root" "$desc")
      local clean_text=$(printf "  %3d) %-25s %s" "$i" "root" "$desc")
    else
      local item_text=$(printf "  ${C_CYAN}%3d)${C_RESET} ${C_BOLD_WHITE}%s${C_RESET}" "$i" "$dom")
      local clean_text=$(printf "  %3d) %s" "$i" "$dom")
    fi

    local item_len=$(echo -n "$clean_text" | awk '{print length($0)}')
    local pad=$((box_inner_width - item_len))
    [[ $pad -lt 0 ]] && pad=0
    echo -e "${C_CYAN}│${C_RESET}${item_text}$(printf '%*s' "$pad" "")${C_CYAN}│${C_RESET}"
    ((i++))
  done
  echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯${C_RESET}"

  local fzf_installed=false
  if command -v fzf &>/dev/null; then
    fzf_installed=true
    PROMPT_TEXT="Nhập lựa chọn (1-${#selects[@]}) [00=${chon_nhanh:-Tìm nhanh}] [0=${exit_thoat:-Thoát}]: "
  else
    PROMPT_TEXT="Nhập lựa chọn (1-${#selects[@]}) [0=${exit_thoat:-Thoát}]: "
  fi

  while true; do
    echo -en "${C_CYAN}${PROMPT_TEXT}${C_RESET}"
    if ! read -r REPLY; then exit 1; fi
    REPLY=$(echo "$REPLY" | tr -d ' ' | tr '[:upper:]' '[:lower:]')

    case "$REPLY" in
    0)
      echo -e "\n${C_GREEN}Đang thoát...${C_RESET}"
      NAME="0"
      return 0
      ;;
    00)
      if $fzf_installed; then
        local selected_item=$(printf '%s\n' "${selects[@]}" | nl -w 3 -s ': ' | fzf --prompt="Tìm website >> " --height=40% --border=rounded --color=border:red --cycle --reverse)
        local dom=$(echo "$selected_item" | sed 's/^[[:space:]]*[0-9]\+\:[[:space:]]*//' | cut -d'|' -f1)
        if [[ -n "$dom" ]]; then
          NAME="$dom"
          return 0
        else echo -e "${C_YELLOW}Đã hủy chọn. Vui lòng chọn lại.${C_RESET}"; fi
      else
        echo -e "${C_RED}Lỗi: FZF chưa cài đặt.${C_RESET}"
      fi
      ;;
    *)
      if [[ "$REPLY" =~ ^[0-9]+$ ]] && [ "$REPLY" -ge 1 ] && [ "$REPLY" -le ${#selects[@]} ]; then
        local action_index=$((REPLY - 1))
        NAME=$(echo "${selects[$action_index]}" | cut -d'|' -f1)
        return 0
      else
        echo -e "\n${C_RED}❌ Lựa chọn không hợp lệ! Vui lòng chọn lại.${C_RESET}"
      fi
      ;;
    esac
  done
}

lua_chon_NAME

[[ "$NAME" == "0" || -z "$NAME" ]] && {
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-db-main 1
  return 2>/dev/null || exit
}

# ==============================================================================
# KHUNG HƯỚNG DẪN MYSQL CLI (CHEAT SHEET)
# ==============================================================================
echo -e "\n${C_GREEN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_BOLD_WHITE}BẢNG HƯỚNG DẪN CÁC LỆNH MYSQL CƠ BẢN${C_RESET}"
echo -e "${C_GREEN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
left_text " ${C_YELLOW}SHOW DATABASES;${C_RESET}    - Liệt kê tất cả cơ sở dữ liệu." 2
left_text " ${C_YELLOW}USE [tên_db];${C_RESET}      - Chọn một cơ sở dữ liệu để làm việc." 2
left_text " ${C_YELLOW}SHOW TABLES;${C_RESET}       - Liệt kê tất cả bảng trong DB đang chọn." 2
left_text " ${C_YELLOW}SHOW PROCESSLIST;${C_RESET}  - Xem các tiến trình DB đang thực thi." 2
left_text " ${C_YELLOW}exit;${C_RESET}              - Thoát khỏi giao diện MySQL CLI." 2
echo -e "${C_GREEN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

# ==============================================================================
# TẠO FILE TEMP BẢO MẬT & KẾT NỐI
# ==============================================================================
TEMP_CNF=$(mktemp)
chmod 600 "$TEMP_CNF"       # Chỉ Root mới có quyền đọc
trap "rm -f $TEMP_CNF" EXIT # Bẫy an toàn: Tự hủy file kể cả khi ấn Ctrl+C

if [[ "$NAME" == 'root' ]]; then
  cat >"$TEMP_CNF" <<EOF
[client]
user=${database_admin_username}
password=${database_admin_password}
host=localhost
max_allowed_packet=1G
default-character-set=utf8mb4
EOF

  echo -e "${C_CYAN}Đang mở kết nối bằng tài khoản ROOT Tối cao...${C_RESET}"
  mariadb --defaults-extra-file="$TEMP_CNF"

else
  unset DB_Password_web DB_User_web DB_Name_web
  if [[ -f "/etc/wptt/vhost/.$NAME.conf" ]]; then
    . "/etc/wptt/vhost/.$NAME.conf"

    if [[ -n "$DB_User_web" && -n "$DB_Password_web" ]]; then
      cat >"$TEMP_CNF" <<EOF
[client]
user=${DB_User_web}
password=${DB_Password_web}
host=localhost
max_allowed_packet=1G
default-character-set=utf8mb4
EOF

      echo -e "${C_CYAN}Đang mở kết nối cho website: ${C_BOLD_WHITE}$NAME${C_RESET}"
      echo -e "${C_GREEN}Gợi ý:${C_RESET} Gõ lệnh ${C_YELLOW}USE \`$DB_Name_web\`;${C_RESET} để bắt đầu truy vấn ngay."
      echo ""
      mariadb --defaults-extra-file="$TEMP_CNF"
    else
      echo -e "${C_RED}❌ Lỗi: Không xác định được thông tin Database của website $NAME!${C_RESET}"
      sleep 3
    fi
  fi
fi

# Xóa chủ động lần cuối (dù đã có trap)
rm -f "$TEMP_CNF"

echo -e "\n${C_GREEN}Đã thoát phiên MySQL CLI thành công!${C_RESET}"

[[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-db-main 1
