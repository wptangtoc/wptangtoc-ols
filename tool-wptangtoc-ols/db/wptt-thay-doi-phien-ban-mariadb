#!/bin/bash

function huong_dan() {
  là tính năng để thay đổi nhánh phiên bản MariaDB
  Ví dụ: bạn đang sử dụng MariaDB phiên bản 10.6 bạn muốn chuyển lên bản 10.11 thì hãy sử dụng tính năng này hoặc ngược lại bạn hoàn toàn có thể hạ cấp phiên bản MariaDB.
  Bạn có thể thay đổi lựa chọn phiên bản MariaDB bạn muốn sử dụng
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null # Nạp thư viện UI Xác nhận

clear
echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}QUẢN LÝ DATABASE ➜ Chuyển đổi / Nâng cấp Phiên bản MariaDB${C_RESET}"
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

if [[ "${1:-}" == '98' ]]; then
  WPTT_IN_MENU="yes"
  WPTT_MENU_BACK="/etc/wptt/wptt-db-main 1"
fi

# ==============================================================================
# RÀO CHẮN 1: KIỂM TRA SỨC KHỎE MARIADB HIỆN TẠI
# ==============================================================================
wptt_check_mariadb || wptt_die "MariaDB đang bị sập! Hệ thống từ chối cho phép thay đổi nhánh phiên bản MariaDB để bảo vệ an toàn."

active_hien_tai=$(systemctl is-active mariadb.service 2>/dev/null)
if [[ "$active_hien_tai" != "active" ]]; then
  echo -e "${C_RED}❌ Lỗi: MariaDB hiện tại không hoạt động, không thể thực hiện Backup!${C_RESET}"
  sleep 3
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-db-main 1
  exit 1
fi

phien_ban_hien_tai=$(mariadbd --version 2>/dev/null | cut -f4 -d " " | grep '^1' | cut -f1-2 -d '.' | cut -f1 -d '-')

echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
left_text "Phiên bản hiện tại : ${C_GREEN}MariaDB $phien_ban_hien_tai${C_RESET}" 2
left_text "Cảnh báo rủi ro    : Quá trình này sẽ XÓA TOÀN BỘ Database cũ và" 2
left_text "                     Cài đặt lại bản mới, sau đó Khôi phục dữ liệu." 2
echo -e "${C_CYAN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
left_text "${C_YELLOW}Hệ thống sẽ TỰ ĐỘNG SAO LƯU toàn bộ Website trước khi làm!${C_RESET}" 2
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

# ==============================================================================
# RÀO CHẮN 2: KIỂM TRA DUNG LƯỢNG Ổ CỨNG (CHUẨN XÁC = MB)
# ==============================================================================
DB_SIZE=$(du -sm /var/lib/mysql 2>/dev/null | awk '{print $1}')
FREE_SPACE=$(df -m /var/lib/mysql | awk 'NR==2 {print $4}')
REQUIRED_SPACE=$((DB_SIZE * 2 + 1024)) # Cần ít nhất gấp đôi DB size + 1GB dự phòng

if [ "$FREE_SPACE" -lt "$REQUIRED_SPACE" ]; then
  echo -e "${C_RED}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_BOLD_WHITE}LỖI NGHIÊM TRỌNG: KHÔNG ĐỦ DUNG LƯỢNG Ổ CỨNG${C_RESET}"
  echo -e "${C_RED}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
  left_text "Dung lượng Database: ${DB_SIZE} MB" 2
  left_text "Ổ cứng còn trống   : ${FREE_SPACE} MB" 2
  left_text "Yêu cầu an toàn    : Tối thiểu ${REQUIRED_SPACE} MB để chứa bản Backup." 2
  echo -e "${C_RED}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"
  echo -e "${C_YELLOW}Vui lòng dọn dẹp ổ cứng (wptt disk) trước khi thực hiện chức năng này!${C_RESET}"
  sleep 4
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-db-main 1
  exit 1
fi

# ==============================================================================
# FETCH DATA & MENU CHỌN PHIÊN BẢN MARIADB
# ==============================================================================
_runing "Đang kết nối máy chủ MariaDB để lấy danh sách phiên bản LTS..."
rest_api_mariadb_verison=$(curl -s --connect-timeout 5 "https://downloads.mariadb.org/rest-api/mariadb" | tr "}" "\n" | grep '"release_support_type": "Long Term Support"' | grep '"release_status": "Stable"' | grep -Eo '"release_name": "[^"]+"' | cut -d'"' -f4)
_rundone "Lấy danh sách phiên bản thành công"
echo ""

if [[ -z "$rest_api_mariadb_verison" ]]; then
  echo -e "${C_RED}❌ Lỗi kết nối mạng: Không lấy được danh sách phiên bản từ MariaDB.org${C_RESET}"
  sleep 3
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-db-main 1
  exit 1
fi

unset selects
selects=()
while IFS= read -r line; do
  [[ -n "$line" ]] && selects+=("$line")
done <<<"$rest_api_mariadb_verison"

echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}LỰA CHỌN PHIÊN BẢN MARIADB LTS (STABLE) MUỐN CÀI ĐẶT${C_RESET}"
echo -e "${C_CYAN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
i=1
for ver in "${selects[@]}"; do
  stt_text=""
  [[ "$ver" == "$phien_ban_hien_tai" ]] && stt_text="${C_GREEN}(Đang sử dụng)${C_RESET}"
  left_text "  ${C_CYAN}${i})${C_RESET} MariaDB ${C_BOLD_WHITE}${ver}${C_RESET} $stt_text" 2
  ((i++))
done
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯${C_RESET}"

while true; do
  echo -en "${C_CYAN}Nhập lựa chọn của bạn (1-${#selects[@]}) [0=Thoát]: ${C_RESET}"
  read -r REPLY
  [[ "$REPLY" == "0" ]] && {
    echo -e "\n${C_GREEN}Đang thoát...${C_RESET}"
    [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-db-main 1
    exit 0
  }

  if [[ "$REPLY" =~ ^[0-9]+$ ]] && [ "$REPLY" -ge 1 ] && [ "$REPLY" -le ${#selects[@]} ]; then
    mariadb_version="${selects[$((REPLY - 1))]}"
    break
  else
    echo -e "${C_RED}❌ Lựa chọn không hợp lệ!${C_RESET}"
  fi
done

if [[ "$mariadb_version" == "$phien_ban_hien_tai" ]]; then
  echo -e "\n${C_YELLOW}Bạn đang sử dụng đúng phiên bản $phien_ban_hien_tai rồi! Hủy thao tác.${C_RESET}"
  sleep 3
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-db-main 1
  exit 0
fi

# ==============================================================================
# XÁC NHẬN CHÓT (POINT OF NO RETURN)
# ==============================================================================
echo ""
if ! wptt_xac_nhan "CẢNH BÁO: Bạn sắp chuyển từ MariaDB $phien_ban_hien_tai sang $mariadb_version" "Quá trình này sẽ XÓA TOÀN BỘ CƠ SỞ DỮ LIỆU HIỆN TẠI. Dù hệ thống" "có auto-backup, hãy đảm bảo bạn cũng đã tự tay Backup ở nơi khác!" "Đồng ý Nâng/Hạ Cấp Nguy Hiểm" "Hủy thao tác"; then
  echo -e "${C_YELLOW}Đã hủy thao tác. An toàn là trên hết!${C_RESET}\n"
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-db-main 1
  exit 0
fi

# Tạm dừng Monit
ngung_monit_rebuild=""
if systemctl is-active --quiet monit; then
  systemctl stop monit
  ngung_monit_rebuild=1
fi

# ==============================================================================
# TIẾN TRÌNH SAO LƯU (BACKUP) TOÀN BỘ WEBSITE
# ==============================================================================
echo -e "\n${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}BƯỚC 1: SAO LƯU TOÀN BỘ CƠ SỞ DỮ LIỆU TRƯỚC KHI NÂNG CẤP${C_RESET}"
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

mkdir -p /usr/local/backup-website/move-db-version

backup_database_wptt() {
  local NAME=$1
  . /etc/wptt/vhost/."$NAME".conf 2>/dev/null

  [[ -z "$NAME" || -z "$DB_Name_web" ]] && return 1
  mkdir -p "/usr/local/backup-website/move-db-version/$NAME"

  _runing "Sao lưu Database Website: $NAME"

  local TEMP_CNF=$(mktemp)
  chmod 600 "$TEMP_CNF"
  cat >"$TEMP_CNF" <<EOF
[client]
user=${DB_User_web}
password=${DB_Password_web}
host=localhost
max_allowed_packet=1G
default-character-set=utf8mb4

[mysqldump]
quick
quote-names
max_allowed_packet=1G
single-transaction
EOF

  if [[ "$sql_gz" == '1' ]]; then
    mariadb-dump --defaults-extra-file="$TEMP_CNF" "$DB_Name_web" --ssl-verify-server-cert=false | gzip >"/usr/local/backup-website/move-db-version/$NAME/$NAME.sql.gz"
  elif [[ "$sql_gz" == '2' ]]; then
    mariadb-dump --defaults-extra-file="$TEMP_CNF" "$DB_Name_web" --ssl-verify-server-cert=false | zstd >"/usr/local/backup-website/move-db-version/$NAME/$NAME.sql.zst"
  else
    mariadb-dump --defaults-extra-file="$TEMP_CNF" "$DB_Name_web" --ssl-verify-server-cert=false >"/usr/local/backup-website/move-db-version/$NAME/$NAME.sql"
  fi
  rm -f "$TEMP_CNF"

  # Verify dung lượng file Backup (>10KB)
  local check_file_error=0
  if [[ "$sql_gz" == '1' ]]; then check_file_error=$(du -k "/usr/local/backup-website/move-db-version/$NAME/$NAME.sql.gz" 2>/dev/null | awk '{print $1}'); fi
  if [[ "$sql_gz" == '2' ]]; then check_file_error=$(du -k "/usr/local/backup-website/move-db-version/$NAME/$NAME.sql.zst" 2>/dev/null | awk '{print $1}'); fi
  if [[ "$sql_gz" != '1' && "$sql_gz" != '2' ]]; then check_file_error=$(du -k "/usr/local/backup-website/move-db-version/$NAME/$NAME.sql" 2>/dev/null | awk '{print $1}'); fi

  if ((check_file_error < 10)); then
    _runloi "Sao lưu Database Website: $NAME (File rỗng hoặc lỗi)"
    rm -rf "/usr/local/backup-website/move-db-version/$NAME"
    return 1
  else
    _rundone "Sao lưu Database Website: $NAME"
    return 0
  fi
}

if [ "$(ls -A /etc/wptt/vhost 2>/dev/null | grep -v '^\.\.conf$' | sort -uV)" ]; then
  for entry in $(ls -A /etc/wptt/vhost | grep -v '^\.\.conf$' | sort -uV); do
    domain=$(echo "$entry" | sed 's/^.//' | sed 's/.conf//')
    if [[ "$domain" == ?*.?* && -d "/usr/local/lsws/$domain/html" ]]; then
      backup_database_wptt "$domain"
    fi
  done
fi

# ==============================================================================
# GỠ BỎ MARIADB CŨ & CÀI ĐẶT BẢN MỚI
# ==============================================================================
echo -e "\n${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}BƯỚC 2: XÓA DỮ LIỆU CŨ VÀ CÀI ĐẶT MARIADB MỚI ($mariadb_version)${C_RESET}"
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

echo "Bắt đầu chuyển từ MariaDB $phien_ban_hien_tai sang $mariadb_version: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log

_runing "Đang Dừng và Gỡ bỏ MariaDB Server hiện tại..."
systemctl stop mariadb >/dev/null 2>&1
pkill mysql >/dev/null 2>&1
rm -rf /var/lib/mysql
rm -rf /etc/mysql
rm -f /etc/my.cnf.d/server.cnf

if grep -qi "ubuntu" /etc/os-release 2>/dev/null; then
  export DEBIAN_FRONTEND=noninteractive
  apt-get remove -y mariadb-server mariadb-client mariadb-common >/dev/null 2>&1
  apt-get autoremove -y >/dev/null 2>&1
else
  yum remove -y mariadb-server mariadb-client mariadb-common >/dev/null 2>&1
fi
_rundone "Đã xóa sạch tàn dư MariaDB $phien_ban_hien_tai"

_runing "Đang thiết lập Repository cho MariaDB $mariadb_version..."
# ==============================================================================
# THUẬT TOÁN DYNAMIC REPO THÔNG MINH CHO RHEL/ALMA/ROCKY (8, 9, 10, 11...)
# ==============================================================================
if ! grep -qi "ubuntu" /etc/os-release 2>/dev/null; then
  OS_ID=$(grep -w '^ID' /etc/os-release | cut -d= -f2 | tr -d '"')
  OS_VER=$(grep -w '^VERSION_ID' /etc/os-release | cut -d= -f2 | tr -d '"' | cut -d. -f1)
  ARCH="amd64"
  [[ "$(uname -m)" == "aarch64" ]] && ARCH="aarch64"

  # Logic Fix Lỗi: Alma/Rocky 10 không có nhánh riêng, ép dùng chung RHEL
  if [[ "$OS_VER" -ge 10 ]]; then
    REPO_OS="rhel"
  elif [[ "$OS_ID" == "almalinux" ]]; then
    REPO_OS="almalinux"
  elif [[ "$OS_ID" == "rocky" ]]; then
    REPO_OS="rockylinux"
  else
    REPO_OS="rhel"
  fi

  mariadb_repo_name="${REPO_OS}${OS_VER}-${ARCH}"

  cat <<EOF >/etc/yum.repos.d/MariaDB.repo
[mariadb]
name = MariaDB
baseurl = http://yum.mariadb.org/$mariadb_version/$mariadb_repo_name
gpgkey=https://yum.mariadb.org/RPM-GPG-KEY-MariaDB
gpgcheck=1
module_hotfixes=1
EOF
fi

# THIẾT LẬP REPO CHO UBUNTU
if grep -qi "ubuntu" /etc/os-release 2>/dev/null; then
  curl -LsS https://downloads.mariadb.com/MariaDB/mariadb_repo_setup | bash -s -- --mariadb-server-version="mariadb-$mariadb_version" >/dev/null 2>&1
fi
_rundone "Thiết lập Repository thành công (Nhánh: $mariadb_repo_name)"

_runing "Đang Tải và Cài đặt MariaDB $mariadb_version (Vui lòng chờ)..."
if grep -qi "ubuntu" /etc/os-release 2>/dev/null; then
  apt-get update >/dev/null 2>&1
  apt-get install -y mariadb-server mariadb-client >/dev/null 2>&1
else
  yum install -y MariaDB-server MariaDB-client >/dev/null 2>&1

  # Fallback nếu Mirror chính bị sập
  if [[ ! -d /var/lib/mysql ]]; then
    sed -i 's|http://yum.mariadb.org|https://mirror.rackspace.com|g' /etc/yum.repos.d/MariaDB.repo
    yum clean all >/dev/null 2>&1
    yum install -y MariaDB-server MariaDB-client >/dev/null 2>&1
  fi
fi
_rundone "Cài đặt MariaDB $mariadb_version thành công"

# ==============================================================================
# CẤU HÌNH TỐI ƯU (MY.CNF)
# ==============================================================================
_runing "Đang thiết lập thông số tối ưu my.cnf theo phần cứng..."
work_cpucore='1024'
cpucore=$(grep -c ^processor /proc/cpuinfo)
tong_ram_byte=$(awk '/MemTotal/ {print $2}' /proc/meminfo)
rong_ram_mb=$(echo "scale=0;${tong_ram_byte}/1024" | bc)
[[ -z "$rong_ram_mb" ]] && rong_ram_mb="2048"

tong_ram_mb_db=$(echo "scale=0;${rong_ram_mb}/4" | bc)
tong_ram_gb=$((rong_ram_mb / 1024))
[[ $tong_ram_gb -eq 0 ]] && tong_ram_gb=1

db_table_size=$((tong_ram_gb * 64))
buffer_db=$((rong_ram_mb / 6))
max_connections=$((64 * tong_ram_gb))

if ((cpucore > 2)); then
  query_cache_type=0
  query_cache_size=0
else
  query_cache_type=1
  query_cache_size='50M'
fi

duong_dan_cau_hinh_mariadb="/etc/my.cnf.d/server.cnf"
grep -qi "ubuntu" /etc/os-release 2>/dev/null && duong_dan_cau_hinh_mariadb="/etc/mysql/my.cnf"

cat <<EOF >>"$duong_dan_cau_hinh_mariadb"
key_buffer_size = ${buffer_db}M
table_cache = 2000
innodb_buffer_pool_size = ${tong_ram_mb_db}M
max_connections = $max_connections
query_cache_type = $query_cache_type
query_cache_limit = 2M
query_cache_min_res_unit = 2k
query_cache_size = $query_cache_size
tmp_table_size = ${db_table_size}M
max_heap_table_size = ${db_table_size}M
thread_cache_size = 81
max_allowed_packet = 64M
wait_timeout=60
interactive_timeout = 60
EOF
sed -i '/\[mysqld\]/a skip-log-bin' "$duong_dan_cau_hinh_mariadb"

# Xử lý an toàn loại bỏ Query Cache nếu MariaDB >= 10.8
lowest_version=$(printf '%s\n%s\n' "10.8" "$mariadb_version" | sort -V | head -n1)
if [[ "$lowest_version" == "10.8" ]]; then
  sed -i '/query_cache/d' "$duong_dan_cau_hinh_mariadb"
fi
_rundone "Cấu hình tối ưu my.cnf hoàn tất"

# Khởi động MariaDB
systemctl enable mariadb >/dev/null 2>&1
systemctl start mariadb >/dev/null 2>&1

_runing "Đang cấu hình Root Password và bảo mật sơ bộ..."
mariadb <<EOF
use mysql;
FLUSH PRIVILEGES;
CREATE USER 'wordpressadmin'@'localhost' IDENTIFIED BY '$database_admin_password';
GRANT ALL PRIVILEGES ON *.* TO 'wordpressadmin'@'localhost' WITH GRANT OPTION;
DROP USER IF EXISTS 'root'@'localhost';
FLUSH PRIVILEGES;
EOF
_rundone "Cấu hình User System thành công"

# ==============================================================================
# KHÔI PHỤC DỮ LIỆU (RESTORE)
# ==============================================================================
echo -e "\n${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}BƯỚC 3: KHÔI PHỤC DỮ LIỆU CHO CÁC WEBSITE${C_RESET}"
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

TEMP_CNF_ROOT=$(mktemp)
chmod 600 "$TEMP_CNF_ROOT"
cat >"$TEMP_CNF_ROOT" <<EOF
[client]
user=${database_admin_username}
password=${database_admin_password}
host=localhost
max_allowed_packet=1G
default-character-set=utf8mb4
EOF

for entry in $(ls -A /etc/wptt/vhost 2>/dev/null | grep -v '^\.\.conf$' | sort -uV); do
  domain=$(echo "$entry" | sed 's/^.//' | sed 's/.conf//')

  if [[ "$domain" == ?*.?* && -d "/usr/local/backup-website/move-db-version/$domain" ]]; then
    unset DB_User_web DB_Password_web DB_Name_web
    . "/etc/wptt/vhost/.$domain.conf" 2>/dev/null

    if [[ -n "$DB_Name_web" ]]; then
      _runing "Đang Rebuild Database: $domain"
      mariadb --defaults-extra-file="$TEMP_CNF_ROOT" --ssl-verify-server-cert=false -e "DROP DATABASE IF EXISTS ${DB_Name_web};"
      mariadb --defaults-extra-file="$TEMP_CNF_ROOT" --ssl-verify-server-cert=false -e "CREATE DATABASE IF NOT EXISTS ${DB_Name_web};"
      mariadb --defaults-extra-file="$TEMP_CNF_ROOT" --ssl-verify-server-cert=false -e "DROP USER IF EXISTS '${DB_User_web}'@'localhost';"
      mariadb --defaults-extra-file="$TEMP_CNF_ROOT" --ssl-verify-server-cert=false -e "CREATE USER IF NOT EXISTS '${DB_User_web}'@'localhost' IDENTIFIED BY '${DB_Password_web}';"
      mariadb --defaults-extra-file="$TEMP_CNF_ROOT" --ssl-verify-server-cert=false -e "GRANT ALL PRIVILEGES ON ${DB_Name_web}.* TO '${DB_User_web}'@'localhost';"
      mariadb --defaults-extra-file="$TEMP_CNF_ROOT" --ssl-verify-server-cert=false -e "FLUSH PRIVILEGES;"
      _rundone "Đã khởi tạo vỏ Database: $domain"

      _runing "Đang Khôi phục dữ liệu (Import SQL): $domain"
      if [[ -f "/usr/local/backup-website/move-db-version/$domain/$domain.sql.zst" ]]; then
        zstd -d <"/usr/local/backup-website/move-db-version/$domain/$domain.sql.zst" | mariadb --defaults-extra-file="$TEMP_CNF_ROOT" "$DB_Name_web" --ssl-verify-server-cert=false
      elif [[ -f "/usr/local/backup-website/move-db-version/$domain/$domain.sql.gz" ]]; then
        zcat "/usr/local/backup-website/move-db-version/$domain/$domain.sql.gz" | mariadb --defaults-extra-file="$TEMP_CNF_ROOT" "$DB_Name_web" --ssl-verify-server-cert=false
      elif [[ -f "/usr/local/backup-website/move-db-version/$domain/$domain.sql" ]]; then
        mariadb --defaults-extra-file="$TEMP_CNF_ROOT" "$DB_Name_web" --ssl-verify-server-cert=false <"/usr/local/backup-website/move-db-version/$domain/$domain.sql"
      fi
      _rundone "Import dữ liệu Database: $domain thành công"
    fi
  fi
done

# Dọn dẹp
rm -rf /usr/local/backup-website/move-db-version
rm -f "$TEMP_CNF_ROOT"

# ==============================================================================
# BƯỚC CUỐI: TÁI CẤU TRÚC (UPGRADE SCHEMA)
# ==============================================================================
_runing "Đang chạy MariaDB Upgrade (Tái cấu trúc Schema Core)..."
TEMP_CNF_ROOT=$(mktemp)
chmod 600 "$TEMP_CNF_ROOT"
cat >"$TEMP_CNF_ROOT" <<EOF
[client]
user=${database_admin_username}
password=${database_admin_password}
[mysqladmin]
user=${database_admin_username}
password=${database_admin_password}
[mariadb-upgrade]
user=${database_admin_username}
password=${database_admin_password}
[mysql_upgrade]
user=${database_admin_username}
password=${database_admin_password}
EOF

