function huong_dan() {
  Tính năng Thêm database [hay Thêm cơ sở dữ liệu] là quá trình tạo ra một kho chứa dữ liệu mới, rỗng và riêng biệt trên máy chủ cơ sở dữ liệu [MariaDB]. Kho chứa này sau đó sẽ được sử dụng để lưu trữ các bảng [tables], dữ liệu, và các cấu trúc liên quan cho một website hoặc một ứng dụng cụ thể.

  Nói một cách đơn giản, đây là việc bạn xây một ngôi nhà mới [database] trên mảnh đất [máy chủ database] để chuẩn bị chứa đồ đạc [dữ liệu] cho một mục đích riêng.

  Mục Đích Chính
  * Cài đặt website/ứng dụng mới: Hầu hết các website động [như WordPress, Joomla, các diễn đàn, trang thương mại điện tử] đều cần một database riêng để lưu trữ nội dung, cài đặt, thông tin người dùng, v.v.
  * Tách biệt dữ liệu: Giữ cho dữ liệu của các website hoặc ứng dụng khác nhau được tách biệt, đảm bảo an toàn và dễ quản lý.
  * Phục vụ môi trường phát triển/thử nghiệm: Tạo database mới cho các phiên bản đang phát triển hoặc kiểm thử của website.
  * Lưu trữ dữ liệu có cấu trúc: Cho bất kỳ dự án nào cần một nơi để tổ chức và lưu trữ thông tin một cách có hệ thống.

  Sau khi Thêm database, bạn sẽ có một cơ sở dữ liệu mới, trống, sẵn sàng để một ứng dụng kết nối vào, tạo bảng và bắt đầu lưu trữ dữ liệu
}

echo -e "\n========================================================================="
echo -e "|Quản lý Database => Thêm Database                                      |"
echo -e "=========================================================================\n"

. /etc/wptt/.wptt.conf
. /etc/wptt/tenmien

echo -e "\nLựa chọn tên website bạn muốn thêm database: \n"
lua_chon_NAME

. /etc/wptt/echo-color

# --- CHỐT CHẶN THOÁT HIỂM BẮT BUỘC ---
[[ "$NAME" == "0" || -z "$NAME" ]] && exec /etc/wptt/wptt-db-main 1

pathcheck="/etc/wptt/vhost/.$NAME.conf"
[[ ! -f "$pathcheck" ]] && {
  clear
  echoDo "Tên miền không tồn tại trên hệ thống này"
  sleep 2
  exec /etc/wptt/wptt-db-main 1
}

. "$pathcheck"

name_db=${NAME//[-._]/}

ramdom_db=$(openssl rand -base64 32 | tr -dc 'a-zA-Z0-9' | head -c 18)
database="${name_db}_${ramdom_db}_dbname"
username="${name_db}_${ramdom_db}_username"
password=$(openssl rand -base64 32 | tr -dc 'a-zA-Z0-9' | head -c 36)

echo "Xác nhận thêm database mới cho website $NAME?"
prompt="Nhập lựa chọn của bạn [1-2]: "
dongy="n"
options=("Đồng ý" "Không đồng ý")
PS3="$prompt"
select opt in "${options[@]}"; do
  case "$REPLY" in
  1)
    dongy="y"
    break
    ;;
  2)
    dongy="n"
    break
    ;;
  *)
    printf "\nBạn nhập sai hệ thống sẽ chọn là không đồng ý\n"
    break
    ;;
  esac
done

if [[ "$dongy" == "y" ]]; then
  UI_STRING="Thêm database mới cho website $NAME"
  _runing "$UI_STRING"

  TEMP_CNF_ROOT=$(mktemp)
  chmod 600 "$TEMP_CNF_ROOT" # Chỉ root mới đọc được
  cat >"$TEMP_CNF_ROOT" <<EOF
[client]
user=${database_admin_username}
password=${database_admin_password}
host=localhost
max_allowed_packet=1G
default-character-set=utf8mb4

[mysqldump]
quick
quote-names
max_allowed_packet=1G
EOF
  trap "rm -f $TEMP_CNF_ROOT" EXIT

  # Thực thi SQL
  mariadb --defaults-extra-file="$TEMP_CNF_ROOT" -e "DROP DATABASE IF EXISTS ${database}"
  mariadb --defaults-extra-file="$TEMP_CNF_ROOT" -e "CREATE DATABASE IF NOT EXISTS ${database}"
  mariadb --defaults-extra-file="$TEMP_CNF_ROOT" -e "DROP USER IF EXISTS '${username}'@'localhost'"
  mariadb --defaults-extra-file="$TEMP_CNF_ROOT" -e "CREATE USER IF NOT EXISTS '${username}'@'localhost' IDENTIFIED BY '${password}'"
  mariadb --defaults-extra-file="$TEMP_CNF_ROOT" -e "GRANT ALL PRIVILEGES ON ${database}.* TO '${username}'@'localhost';"
  mariadb --defaults-extra-file="$TEMP_CNF_ROOT" -e "FLUSH PRIVILEGES"

  rm -rf "$TEMP_CNF_ROOT"

  sed -i '/^DB_Name_web=/d' "/etc/wptt/vhost/.$NAME.conf"
  sed -i '/^DB_User_web=/d' "/etc/wptt/vhost/.$NAME.conf"
  sed -i '/^DB_Password_web=/d' "/etc/wptt/vhost/.$NAME.conf"

  echo "DB_Name_web=$database
DB_User_web=$username
DB_Password_web=$password" >>"/etc/wptt/vhost/.$NAME.conf"

  _rundone "$UI_STRING"

  echo -e "\n==================================================================="
  echoDone "                   Thêm database thành công                  "
  echo -e "==================================================================="
  echo "database_name           : $database"
  echo "database_user           : $username"
  echo "database_password       : $password"
  echo -e "==================================================================="
  echo "Phần mềm phát triển bởi : Gia Tuấn"
  echo -e "===================================================================\n"
else
  exec /etc/wptt/wptt-db-main 1
fi

[[ ${1:-} == "98" ]] && exec /etc/wptt/wptt-db-main 1
