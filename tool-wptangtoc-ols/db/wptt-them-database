function huong_dan() {
  Tính năng Thêm database [hay Thêm cơ sở dữ liệu] là quá trình tạo ra một kho chứa dữ liệu mới, rỗng và riêng biệt trên máy chủ cơ sở dữ liệu [MariaDB]. Kho chứa này sau đó sẽ được sử dụng để lưu trữ các bảng [tables], dữ liệu, và các cấu trúc liên quan cho một website hoặc một ứng dụng cụ thể.

  Mục Đích Chính
  * Cài đặt website/ứng dụng mới: Hầu hết các website động đều cần một database riêng.
  * Tách biệt dữ liệu: Giữ cho dữ liệu của các website được tách biệt.
  * Phục vụ môi trường phát triển/thử nghiệm: Tạo database mới cho các phiên bản đang phát triển.
}


export LC_ALL=C.UTF-8 2>/dev/null || export LC_ALL=en_US.UTF-8 2>/dev/null

. /etc/wptt/.wptt.conf 2>/dev/null
[[ $ngon_ngu == '' ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null

if [[ "${1:-}" == '98' ]]; then
  WPTT_IN_MENU="yes"
  WPTT_MENU_BACK="/etc/wptt/wptt-db-main 1"
fi

wptt_check_mariadb || wptt_die "MariaDB đang bị sập! Hệ thống từ chối cho phép thêm database."

clear
echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}QUẢN LÝ DATABASE ➜ THÊM DATABASE MỚI${C_RESET}"
echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

. /etc/wptt/tenmien
lua_chon_NAME "thêm database"

[[ "$NAME" == "0" || -z "$NAME" ]] && exec /etc/wptt/wptt-db-main 1

pathcheck="/etc/wptt/vhost/.$NAME.conf"
[[ ! -f "$pathcheck" ]] && {
  echo -e "\n${C_RED}❌ Tên miền không tồn tại trên hệ thống này!${C_RESET}"
  sleep 2
  exec /etc/wptt/wptt-db-main 1
}

# Nạp cấu hình hiện tại
. "$pathcheck"

name_db=${NAME//[-._]/}
ramdom_db=$(openssl rand -base64 32 | tr -dc 'a-zA-Z0-9' | head -c 18)
database="${name_db}_${ramdom_db}_dbname"
username="${name_db}_${ramdom_db}_username"
password=$(openssl rand -base64 32 | tr -dc 'a-zA-Z0-9' | head -c 36)

# ==============================================================================
# TRẠM KIỂM LÂM: PHÁT HIỆN DATABASE "MA" VÀ XỬ LÝ LOGIC "BIÊN CHẾ"
# ==============================================================================
msg_warning=""
msg_warning2=""
db_is_orphan=true # Cờ xác định DB mới tạo sẽ là mồ côi (true) hay được biên chế (false)

if [[ -n "$DB_Name_web" ]]; then
  # Có lưu trong Vhost, bắt đầu kiểm tra thực tế
  TEMP_CNF_CHK=$(mktemp)
  chmod 600 "$TEMP_CNF_CHK"
  cat >"$TEMP_CNF_CHK" <<EOF
[client]
user=${database_admin_username}
password=${database_admin_password}
host=localhost
EOF

  # Truy vấn MariaDB xem DB còn tồn tại không
  db_exists=$(mariadb --defaults-extra-file="$TEMP_CNF_CHK" -sse "SELECT EXISTS(SELECT 1 FROM information_schema.schemata WHERE schema_name = '$DB_Name_web');")
  rm -f "$TEMP_CNF_CHK"

  if [[ "$db_exists" == "1" ]]; then
    # DB thực sự tồn tại
    msg_warning="Website $NAME ĐÃ CÓ DB chính đang hoạt động ($DB_Name_web)."
    msg_warning2="Cơ sở dữ liệu mới sẽ ở dạng MỒ CÔI (Dự phòng)."
    db_is_orphan=true
  else
    # Lỗi: DB bị xóa lén nhưng Vhost vẫn còn lưu
    msg_warning="Phát hiện DB biên chế cũ ($DB_Name_web) ĐÃ BỊ XÓA khỏi hệ thống."
    msg_warning2="Cơ sở dữ liệu mới sẽ được cấp BIÊN CHẾ thay thế."
    db_is_orphan=false
    
    # Gạch tên DB chết khỏi vhost ngay và luôn
    sed -i '/^DB_Name_web=/d' "$pathcheck"
    sed -i '/^DB_User_web=/d' "$pathcheck"
    sed -i '/^DB_Password_web=/d' "$pathcheck"
  fi
else
  # Vhost hoàn toàn trống DB
  msg_warning="Website $NAME hiện chưa có Database."
  msg_warning2="Cơ sở dữ liệu mới sẽ được BIÊN CHẾ làm DB chính."
  db_is_orphan=false
fi

echo ""
if wptt_xac_nhan "Bạn chắc chắn muốn thêm Database mới cho website: $NAME?" "$msg_warning" "$msg_warning2" "Có, Tạo mới" "Hủy bỏ"; then
  
  UI_STRING="Đang khởi tạo Database mới cho $NAME..."
  _runing "$UI_STRING"

  TEMP_CNF_ROOT=$(mktemp)
  chmod 600 "$TEMP_CNF_ROOT"
  cat >"$TEMP_CNF_ROOT" <<EOF
[client]
user=${database_admin_username}
password=${database_admin_password}
host=localhost
max_allowed_packet=1G
default-character-set=utf8mb4
EOF
  trap "rm -f $TEMP_CNF_ROOT" EXIT

  # Thực thi SQL (Chỉ tạo mới, nếu User chưa có thì tạo)
  mariadb --defaults-extra-file="$TEMP_CNF_ROOT" -e "CREATE DATABASE IF NOT EXISTS \`${database}\`;"
  mariadb --defaults-extra-file="$TEMP_CNF_ROOT" -e "CREATE USER IF NOT EXISTS '${username}'@'localhost' IDENTIFIED BY '${password}';"
  mariadb --defaults-extra-file="$TEMP_CNF_ROOT" -e "GRANT ALL PRIVILEGES ON \`${database}\`.* TO '${username}'@'localhost';"
  mariadb --defaults-extra-file="$TEMP_CNF_ROOT" -e "FLUSH PRIVILEGES;"

  rm -f "$TEMP_CNF_ROOT"

  # Cấp phát biên chế nếu cờ mồ côi là false
  trang_thai_bien_che="${C_RED}MỒ CÔI (Dự phòng)${C_RESET}"
  if [[ "$db_is_orphan" == false ]]; then
    # Ghi cấu hình vào vhost
    sed -i '/^DB_Name_web=/d' "$pathcheck"
    sed -i '/^DB_User_web=/d' "$pathcheck"
    sed -i '/^DB_Password_web=/d' "$pathcheck"
    echo "DB_Name_web=$database
DB_User_web=$username
DB_Password_web=$password" >> "$pathcheck"
    trang_thai_bien_che="${C_GREEN}ĐÃ NHẬP BIÊN CHẾ${C_RESET}"
  fi

  _rundone "$UI_STRING"

  # ============================================================================
  # BẢNG TÓM TẮT THÀNH CÔNG (TẬN DỤNG THƯ VIỆN ECHO-COLOR)
  # ============================================================================
  echo -e "\n${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_GREEN}KHỞI TẠO DATABASE THÀNH CÔNG${C_RESET}"
  echo -e "${C_CYAN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
  
  left_text "${C_BOLD_WHITE}Tên Website   :${C_RESET} ${C_YELLOW}$NAME${C_RESET}"
  left_text "${C_BOLD_WHITE}Tên Database  :${C_RESET} ${C_BOLD_WHITE}$database${C_RESET}"
  left_text "${C_BOLD_WHITE}User Database :${C_RESET} ${C_BOLD_WHITE}$username${C_RESET}"
  left_text "${C_BOLD_WHITE}Mật khẩu      :${C_RESET} ${C_CYAN}$password${C_RESET}"
  left_text "${C_BOLD_WHITE}Trạng thái    :${C_RESET} $trang_thai_bien_che"

  echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯${C_RESET}\n"

  echo -en "${C_GREEN}➜ Nhấn [Enter] để tiếp tục...${C_RESET}"
  read -r dummy
  exec /etc/wptt/wptt-db-main 1
else
  exec /etc/wptt/wptt-db-main 1
fi
