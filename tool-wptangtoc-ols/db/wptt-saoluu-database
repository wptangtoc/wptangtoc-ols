function huong_dan() {
  Tính năng Sao lưu database [Database Backup] là quá trình tạo ra một bản sao của toàn bộ cơ sở dữ liệu của bạn – bao gồm cấu trúc [các bảng, cột], dữ liệu chứa trong đó, các chỉ mục [index] – rồi lưu trữ bản sao đó ở một nơi an toàn. Khôi phục là cặp đôi không thể thiếu cho sự an toàn của dữ liệu.

  Nói một cách đơn giản, đây là việc bạn chụp lại một bức ảnh toàn bộ kho chứa dữ liệu [database] của mình tại một thời điểm nhất định, để nếu có chuyện không may xảy ra với kho chính, bạn vẫn còn bức ảnh đó để dựng lại.

  Mục Đích Chính [Vô Cùng Quan Trọng]
  * Phòng chống mất mát dữ liệu: Đây là mục đích hàng đầu. Bảo vệ dữ liệu khỏi lỗi phần cứng, lỗi phần mềm, xóa nhầm bởi con người, tấn công mạng [malware, ransomware], hoặc thiên tai.
  * Khôi phục sau sự cố [Disaster Recovery]: Cho phép bạn đưa database trở lại trạng thái hoạt động ổn định sau khi gặp vấn đề.
  * Di chuyển dữ liệu [Data Migration]: Sử dụng bản sao lưu để chuyển database sang một máy chủ mới hoặc một môi trường khác.
  * Phục vụ thử nghiệm và phát triển: Tạo bản sao của database sản xuất để thử nghiệm tính năng mới hoặc gỡ lỗi mà không ảnh hưởng đến dữ liệu thật.
  * Lưu trữ và tuân thủ quy định: Một số ngành nghề yêu cầu phải sao lưu và lưu trữ dữ liệu định kỳ.

  Để sẵn sàng để sử dụng khi cần khôi phục.
}

. /etc/wptt/.wptt.conf
if [[ $ngon_ngu = '' ]]; then
  ngon_ngu='vi'
fi
. /etc/wptt/lang/$ngon_ngu.sh
. /etc/wptt/core-functions
. /etc/wptt/echo-color

if [[ "$1" == '98' ]]; then
  WPTT_IN_MENU="yes"
  WPTT_MENU_BACK="/etc/wptt/wptt-db-main 1"
fi

if [[ "$1" == '97' ]]; then
  WPTT_IN_MENU="yes"
  WPTT_MENU_BACK="/etc/wptt/wptt-backup-restore-main 1"
fi

check_menu_wptangtoc_active=$1
if [[ $check_menu_wptangtoc_active = "97" ]]; then
  echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_BOLD_WHITE}$backup_restore ➜ $sao_luu_database${C_RESET}"
  echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯${C_RESET}\n"
else
  echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_BOLD_WHITE}$quan_ly_database ➜ $sao_luu_database${C_RESET}"
  echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯${C_RESET}\n"
fi

wptt_check_mariadb || wptt_die "MariaDB đang bị sập! Hệ thống từ chối không cho phép sao lưu database."

echo "Sao lưu database: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log

. /etc/wptt/echo-color

NAME=$1
if [[ $NAME = "98" ]]; then
  NAME=""
fi

if [[ $NAME = "97" ]]; then
  NAME=""
fi

if [[ "$NAME" = "" ]]; then
  . /etc/wptt/tenmien-them-lua-chon-tat-ca-website
  lua_chon_NAME "$sao_luu_database"
fi

ggdriver=$2
ggdriver2=$3


if [[ $2 = '12345' ]] || [[ $2 = '1998' ]];then
ep_luong_cpu_disk_thu_tu_yeu_tien_thap_dang_chay_auto_backup="ionice -c 3 nice -n 19"
else #đây là không auto backup mà chạy trực tiếp trên terminal, không cần hạ thấp ưu tiên
ep_luong_cpu_disk_thu_tu_yeu_tien_thap_dang_chay_auto_backup=""
fi

# ==============================================================================
# HÀM PHỤ TRỢ: NHẬN DIỆN CLOUD HIỆN TẠI
# ==============================================================================
get_cloud_name() {
  local conf="/root/.config/rclone/rclone.conf"
  if grep -E -q '^[[:space:]]*type[[:space:]]*=[[:space:]]*onedrive' "$conf" 2>/dev/null; then
    echo "OneDrive"
  elif grep -E -q '^[[:space:]]*type[[:space:]]*=[[:space:]]*s3' "$conf" 2>/dev/null; then
    echo "S3 Storage"
  else
    echo "Google Drive"
  fi
}

get_cloud_dir() {
  local conf="/root/.config/rclone/rclone.conf"
  if grep -E -q '^[[:space:]]*type[[:space:]]*=[[:space:]]*s3' "$conf" 2>/dev/null; then
    echo "wptangtoc-ols-backup"
  elif rclone lsd wptangtoc: 2>/dev/null | grep -q 'wptangtoc-ols-backup'; then
    echo "wptangtoc-ols-backup"
  else
    echo "wptangtoc_ols_backup"
  fi
}

# ==============================================================================
# XỬ LÝ KHI CHỌN ALL WEBSITE
# ==============================================================================
if [[ $NAME = 'Tất cả website' ]]; then
  if [[ -z $3 ]]; then #doi số 3 không có giá trị auto mới hỏi
    unset ggdriver ggdriver2 checkdathietlap
    checkdathietlap=$(grep -q '\[wptangtoc\]' ~/.config/rclone/rclone.conf 2>/dev/null && echo 1)
    if [[ $checkdathietlap ]]; then
      drive_name=$(get_cloud_name)
      echo "$ban_co_muon file backup uploads $drive_name?"

      prompt="$nhap_lua_chon_cua_ban [1-2]: "
      ggdriver="n"
      options=("$dong_y" "$khong_dong_y")
      PS3="$prompt"
      select opt in "${options[@]}"; do
        case "$REPLY" in
        1) ggdriver="1998"; break ;;
        2) ggdriver="n"; break ;;
        *) printf "\n$ban_nhap_sai_he_thong_se_chon_khong_dong_y\n"; break ;;
        esac
      done
      
      if [[ "$ggdriver" = "1998" ]]; then
        kiem_tra_xem_cloud_drive_co_hoat_dong_khong=$(rclone about wptangtoc: 2>/dev/null | grep 'Free:')
        if [[ $kiem_tra_xem_cloud_drive_co_hoat_dong_khong ]]; then
          echo "$ban_co_muon $xoa file backup tại local khi đã được lưu trữ đám mây $drive_name không?"
          prompt="$nhap_lua_chon_cua_ban [1-2]: "
          ggdriver2="12345"
          options=("$dong_y" "$khong_dong_y")
          PS3="$prompt"
          select opt in "${options[@]}"; do
            case "$REPLY" in
            1) ggdriver2="1998"; break ;;
            2) ggdriver2="12345"; break ;;
            *) printf "\n$ban_nhap_sai_he_thong_se_chon_khong_dong_y\n"; break ;;
            esac
          done
        fi
      fi
    fi
  fi

  START_TIMESTAMP_FILE=$(mktemp) #khởi tạo file temp để xác định bắt đầu thực thi all

  if [[ $ggdriver = '1998' ]]; then
    dung_luong_drive_truoc_khi_sao_luu=$(rclone size wptangtoc: 2>/dev/null --exclude "Personal Vault/**" --exclude "Kho lưu trữ cá nhân/**" | grep 'size' | cut -f2 -d ':' | cut -f1 -d '(' | head -1)
  fi

  before_optimize_full_all=$(du -hs /usr/local/backup-website)
  if [ "$(ls -A /etc/wptt/vhost | grep -v '^\.\.conf$' | sort -uV)" ]; then
    echo $sao_luu_toan_bo_database
    for entry in $(ls -A /etc/wptt/vhost | grep -v '^\.\.conf$' | sort -uV); do
      domain=$(echo $entry | sed 's/^.//' | sed 's/.conf//')
      path_html="/usr/local/lsws/$domain/html"
      i=1
      if [ "$domain" != "${domain/./}" ] && [ "$domain" != '.' ]; then #điều kiện domain phải có dấu . và lỗi chỉ có only .
        if [[ -d "$path_html" ]]; then
          _runing "$sao_luu_database website $domain"
          . /etc/wptt/db/wptt-saoluu-database $domain $ggdriver $ggdriver2
          _rundone "$sao_luu_database website $domain"
        fi
      fi
    done
  fi

  check_menu_wptangtoc_active=$1
  if [[ $check_menu_wptangtoc_active = "98" || $check_menu_wptangtoc_active = "97" ]]; then
    END_TIMESTAMP_FILE=$(mktemp) #kết thúc file temp
    clear
    echo "==================================================================="
    echo "Hoàn tất backup $sao_luu_tat_ca_website"
    echo "==================================================================="
    for entry in $(ls -A /etc/wptt/vhost | grep -v '^\.\.conf$' | sort -uV); do
      domain=$(echo $entry | sed 's/^.//' | sed 's/.conf//')
      path="/usr/local/lsws/$domain/html"
      i=1

      if [[ -d "$path" ]]; then
        if [[ $ggdriver2 != '1998' ]]; then
          if [[ $(find "/usr/local/backup-website/$domain" -type f -newer "$START_TIMESTAMP_FILE" ! -newer "$END_TIMESTAMP_FILE" -ls) ]]; then
            echo "Hoàn tất backup database website: $domain"
          fi
        else
          echo "Hoàn tất backup database website: $domain"
        fi
      fi
    done
    
    if [[ $ggdriver2 != '1998' ]]; then
      echo "==================================================================="
      echo "Dung lượng thư mục trước khi sao lưu  : $before_optimize_full_all"
      echo "Dung lượng thư mục sau khi sao lưu    : $(du -hs /usr/local/backup-website)"
      echo "==================================================================="
    fi

    if [[ $ggdriver = '1998' ]]; then
      drive_name=$(get_cloud_name)
      echo "Dung lượng $drive_name của bạn trước khi sao lưu: $dung_luong_drive_truoc_khi_sao_luu"
      echo "Dung lượng $drive_name của bạn sau khi sao lưu: $(rclone size wptangtoc: 2>/dev/null --exclude "Personal Vault/**" --exclude "Kho lưu trữ cá nhân/**" | grep 'size' | cut -f2 -d ':' | cut -f1 -d '(' | head -1)"
    fi

    rm "$END_TIMESTAMP_FILE"
    check_menu_wptangtoc_active=$1
    if [[ $check_menu_wptangtoc_active = "98" ]]; then
      exec /etc/wptt/wptt-db-main 1
    fi
    if [[ $check_menu_wptangtoc_active = "97" ]]; then
      exec /etc/wptt/wptt-backup-restore-main 1
    fi
  fi
  rm -f "$START_TIMESTAMP_FILE"
  return 2>/dev/null
  exit
fi

unset DB_User_web DB_Password_web DB_Name_web
. /etc/wptt/vhost/."$NAME".conf

if [[ "$NAME" = "0" || "$NAME" = "" ]]; then
  check_menu_wptangtoc_active=$1
  if [[ $check_menu_wptangtoc_active = "98" ]]; then
    exec /etc/wptt/wptt-db-main 1
  fi
  if [[ $check_menu_wptangtoc_active = "97" ]]; then
    exec /etc/wptt/wptt-backup-restore-main 1
  fi
fi

pathcheck="/etc/wptt/vhost/.$NAME.conf"
if [[ ! -f "$pathcheck" ]]; then
  clear
  echoDo "$ten_mien_nay_khong_ton_tai_tren_he_thong"
  sleep 3
  exec /etc/wptt/wptt-db-main 1
  exit
fi

mkdir -p "/usr/local/backup-website/$NAME"

_runing "$sao_luu_database website $NAME"

# ==============================================================================
# BẮT ĐẦU CƠ CHẾ LOCKING
# ==============================================================================
if [[ -n "$NAME" && "$NAME" != "Tất cả website" && "$NAME" != "98" ]]; then
  LOCK_FILE="/tmp/wptt_lock_sao_luu_khoi_phuc_${NAME}.lock"
  exec 200>"$LOCK_FILE"

  if ! flock -n 200; then
    echo ""
    echo "========================================================================="
    _runloi "Lỗi Đụng Độ Tiến Trình"
    echoDo "Website $NAME đang được thao tác bởi một tiến trình khác (Backup/Restore)."
    echoDo "Vui lòng chờ tiến trình đó hoàn tất rồi thử lại để tránh hỏng dữ liệu!"
    echo "========================================================================="

    check_menu_wptangtoc_active=$1
    if [[ $check_menu_wptangtoc_active = "98" ]]; then
      exec /etc/wptt/wptt-db-main 1
    fi
    if [[ $check_menu_wptangtoc_active = "97" ]]; then
      exec /etc/wptt/wptt-backup-restore-main 1
    fi
    return 2>/dev/null || exit 1
  fi
fi
# ==============================================================================
# KẾT THÚC CƠ CHẾ LOCKING
# ==============================================================================

timedate=$(date +%Hgio\_%d\_%m\_%Y)

TEMP_CNF=$(mktemp)
chmod 600 "$TEMP_CNF"
cat >"$TEMP_CNF" <<EOF
[client]
user=${DB_User_web}
password=${DB_Password_web}
host=localhost
max_allowed_packet=1G
default-character-set=utf8mb4

[mysqldump]
quick
quote-names
max_allowed_packet=1G
single-transaction
EOF

trap "rm -f $TEMP_CNF" EXIT

# ==================================================================
# BƯỚC 1: TÍNH TOÁN DUNG LƯỢNG
# ==================================================================
RAW_SIZE=$(mariadb --defaults-extra-file="$TEMP_CNF" -N -e "SELECT SUM(data_length) FROM information_schema.TABLES WHERE table_schema='$DB_Name_web'")
if [[ -z "$RAW_SIZE" || "$RAW_SIZE" == "NULL" ]]; then RAW_SIZE=1024; fi
ADJUSTED_SIZE=$((RAW_SIZE * 95 / 100))

if command -v pv &>/dev/null; then
  PV_CMD="pv -s $ADJUSTED_SIZE -N 'Exporting' -p -t -e -w 80"
else
  PV_CMD="cat"
fi

_runing "$sao_luu_database website $NAME"
echo ""
# ==================================================================
# BƯỚC 2: THỰC THI DUMP DATABASE
# ==================================================================

if [[ $sql_gz = '1' ]]; then
  $ep_luong_cpu_disk_thu_tu_yeu_tien_thap_dang_chay_auto_backup mariadb-dump --defaults-extra-file="$TEMP_CNF" "$DB_Name_web" --ssl-verify-server-cert=false | bash -c "$PV_CMD" | $ep_luong_cpu_disk_thu_tu_yeu_tien_thap_dang_chay_auto_backup gzip >"/usr/local/backup-website/$NAME/$NAME$timedate.sql.gz"
elif [[ $sql_gz = '2' ]]; then
  $ep_luong_cpu_disk_thu_tu_yeu_tien_thap_dang_chay_auto_backup mariadb-dump --defaults-extra-file="$TEMP_CNF" "$DB_Name_web" --ssl-verify-server-cert=false | bash -c "$PV_CMD" | $ep_luong_cpu_disk_thu_tu_yeu_tien_thap_dang_chay_auto_backup zstd >"/usr/local/backup-website/$NAME/$NAME$timedate.sql.zst"
else
  $ep_luong_cpu_disk_thu_tu_yeu_tien_thap_dang_chay_auto_backup mariadb-dump --defaults-extra-file="$TEMP_CNF" "$DB_Name_web" --ssl-verify-server-cert=false | $ep_luong_cpu_disk_thu_tu_yeu_tien_thap_dang_chay_auto_backup bash -c "$PV_CMD" >"/usr/local/backup-website/$NAME/$NAME$timedate.sql"
fi

echo -ne "\033[1A\r\033[K"
echo -ne "\033[1A\r\033[K"

rm -rf $TEMP_CNF

if [[ ! -f /usr/local/backup-website/$NAME/$NAME$timedate.sql && ! -f /usr/local/backup-website/$NAME/$NAME$timedate.sql.gz && ! -f /usr/local/backup-website/$NAME/$NAME$timedate.sql.zst ]]; then
  _runloi "$sao_luu_database website $NAME"
fi

if [[ $sql_gz = '1' ]]; then
  check_file_error=$(du -c /usr/local/backup-website/$NAME/$NAME$timedate.sql.gz | awk '{print $1}' | sed '1d')
  if ((${check_file_error:-0} < 3)); then
    _runloi "$sao_luu_database website $NAME"
    $ep_luong_cpu_disk_thu_tu_yeu_tien_thap_dang_chay_auto_backup rm -f /usr/local/backup-website/$NAME/$NAME$timedate.sql.gz
    return 2>/dev/null
    exit
  fi
elif [[ $sql_gz = '2' ]]; then
  check_file_error=$(du -c /usr/local/backup-website/$NAME/$NAME$timedate.sql.zst | awk '{print $1}' | sed '1d')
  if ((${check_file_error:-0} < 3)); then
    _runloi "$sao_luu_database website $NAME"
    $ep_luong_cpu_disk_thu_tu_yeu_tien_thap_dang_chay_auto_backup rm -f /usr/local/backup-website/$NAME/$NAME$timedate.sql.gz
    return 2>/dev/null
    exit
  fi
else
  check_file_error=$(du -c /usr/local/backup-website/$NAME/$NAME$timedate.sql | awk '{print $1}' | sed '1d')
  if ((${check_file_error:-0} < 3)); then
    _runloi "$sao_luu_database website $NAME"
    $ep_luong_cpu_disk_thu_tu_yeu_tien_thap_dang_chay_auto_backup rm -f /usr/local/backup-website/$NAME/$NAME$timedate.sql
    return 2>/dev/null
    exit
  fi
fi

_rundone "$sao_luu_database website $NAME"

checkdathietlap=$(grep -q '\[wptangtoc\]' /root/.config/rclone/rclone.conf 2>/dev/null && echo 1)
if [[ $checkdathietlap ]]; then
  drive_name=$(get_cloud_name)
  CLOUD_DIR=$(get_cloud_dir)

  if [[ "$ggdriver" != "1998" ]]; then
    echo "$ban_co_muon file backup uploads $drive_name?"
    prompt="$nhap_lua_chon_cua_ban [1-2]: "
    uploads="n"
    options=("$dong_y" "$khong_dong_y")
    PS3="$prompt"
    select opt in "${options[@]}"; do
      case "$REPLY" in
      1) uploads="y"; break ;;
      2) uploads="n"; break ;;
      *) printf "\n$ban_nhap_sai_he_thong_se_chon_khong_dong_y\n"; break ;;
      esac
    done
  fi
  
  if [[ "$uploads" = "y" || "$ggdriver" = "1998" ]]; then
    _runing "File backup database uploads $drive_name"

    # -------------------------------------------------------------
    # BỘ ĐIỀU TỐC THÔNG MINH CHO RCLONE (DYNAMIC PERFORMANCE ENGINE)
    # -------------------------------------------------------------
    TOTAL_CORES=$(nproc 2>/dev/null || echo 1)
    TOTAL_RAM_MB=$(free -m | awk '/^Mem:/{print $2}')

    # 1. Cấu hình cơ bản dựa trên sức mạnh phần cứng (Phân loại yếu/khỏe)
    if (( TOTAL_CORES <= 2 )) || (( TOTAL_RAM_MB <= 2048 )); then
      OPT_TRANSFERS=2
      OPT_CHUNK="32M"
    else
      OPT_TRANSFERS=4
      OPT_CHUNK="64M"
    fi

    # 2. Điều tốc theo ngữ cảnh: Cronjob (Nền) vs Thủ công (User)
    if [[ "$ggdriver" == "1998" ]]; then
      if (( TOTAL_CORES == 1 )); then
        OPT_TRANSFERS=1
      fi
    fi

    # 3. Thêm cờ --log-level ERROR để bịt mõm các dòng NOTICE rác của Rclone
    RCLONE_OPTS="--transfers=$OPT_TRANSFERS --checkers=$OPT_TRANSFERS --drive-chunk-size=$OPT_CHUNK --s3-upload-concurrency=$OPT_TRANSFERS --log-level ERROR"

    # =============================================================
    # HÀM UPLOAD GIAO DIỆN CHUẨN UX (KẾT HỢP PV + RCAT + AUTO CLEAN)
    # =============================================================
    function wptt_upload_db_ux() {
      local src_file="$1"
      local dest_dir="$2"
      local fname=$(basename "$src_file")

      if [[ "$ggdriver" == "1998" ]]; then
        # Chạy ngầm Cronjob: Im lặng tuyệt đối
        $ep_luong_cpu_disk_thu_tu_yeu_tien_thap_dang_chay_auto_backup rclone copy "$src_file" "$dest_dir" $RCLONE_OPTS >/dev/null 2>&1
      else
        # Chạy tay: Vẽ tiến trình PV và Tự động dọn dẹp
        if command -v pv &>/dev/null; then
          local fsize=$(du -b "$src_file" | cut -f1)
          pv -s "$fsize" -N "Upload Database" -p -t -e -r -b -w 90 "$src_file" | rclone rcat "$dest_dir/$fname" $RCLONE_OPTS
          
          # Tuyệt kỹ Tàng Hình: Vừa chạy xong 100% -> Nhảy lên 1 dòng -> Xóa sạch thanh tiến trình
          echo -en "\033[1A\033[2K\r"
        else
          rclone copy "$src_file" "$dest_dir" $RCLONE_OPTS --progress --stats-one-line
          echo -en "\033[1A\033[2K\r"
        fi
      fi
    }

    echo "" # Tạo một dòng trống cho giao diện thoáng đãng

    if [[ $sql_gz = '1' ]]; then
      wptt_upload_db_ux "/usr/local/backup-website/$NAME/$NAME$timedate.sql.gz" "wptangtoc:$CLOUD_DIR/$NAME"
    elif [[ $sql_gz = '2' ]]; then
      wptt_upload_db_ux "/usr/local/backup-website/$NAME/$NAME$timedate.sql.zst" "wptangtoc:$CLOUD_DIR/$NAME"
    else
      wptt_upload_db_ux "/usr/local/backup-website/$NAME/$NAME$timedate.sql" "wptangtoc:$CLOUD_DIR/$NAME"
    fi

    _rundone "File backup database uploads $drive_name"
    
    if ! [[ "$ggdriver2" = "1998" || "$ggdriver2" = "12345" ]]; then
      echo "$ban_co_muon $xoa file backup tại local khi đã được lưu trữ đám mây $drive_name không?"
      prompt="$nhap_lua_chon_cua_ban [1-2]: "
      clearfile="n"
      options=("$dong_y" "$khong_dong_y")
      PS3="$prompt"
      select opt in "${options[@]}"; do
        case "$REPLY" in
        1) clearfile="y"; break ;;
        2) clearfile="n"; break ;;
        *) printf "\n$ban_nhap_sai_he_thong_se_chon_khong_dong_y\n"; break ;;
        esac
      done
    fi
    
    if [[ "$clearfile" = "y" || "$ggdriver2" = "1998" ]]; then
      _runing "$xoa file backup database tại local"
      if [[ $sql_gz = '1' ]]; then
        $ep_luong_cpu_disk_thu_tu_yeu_tien_thap_dang_chay_auto_backup rm -f /usr/local/backup-website/"$NAME"/$NAME$timedate.sql.gz
      elif [[ $sql_gz = '2' ]]; then
        $ep_luong_cpu_disk_thu_tu_yeu_tien_thap_dang_chay_auto_backup rm -f /usr/local/backup-website/"$NAME"/$NAME$timedate.sql.zst
      else
        $ep_luong_cpu_disk_thu_tu_yeu_tien_thap_dang_chay_auto_backup rm -f /usr/local/backup-website/"$NAME"/$NAME$timedate.sql
      fi
      _rundone "$xoa file backup database tại local"
    fi
  fi
fi

if [[ $clearfile != 'y' ]]; then
  echo ''
  echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
  if [[ $sql_gz = '1' ]]; then
    left_text "File database: $NAME$timedate.sql.gz"
    left_text "Lưu trữ trong thư mục: /usr/local/backup-website/$NAME"
  elif [[ $sql_gz = '2' ]]; then
    left_text "File database: $NAME$timedate.sql.zst"
    left_text "Lưu trữ trong thư mục: /usr/local/backup-website/$NAME"
  else
    left_text "File database: $NAME$timedate.sql"
    left_text "Lưu trữ trong thư mục: /usr/local/backup-website/$NAME"
  fi
  echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯${C_RESET}\n"
fi

# 1. Báo cho Kernel mở khóa đồng bộ và chờ xác nhận (Synchronous)
flock -u 200
# 2. Đóng File Descriptor
exec 200>&-
rm -f "/tmp/wptt_lock_sao_luu_khoi_phuc_${NAME}.lock" 2>/dev/null

check_menu_wptangtoc_active=$1
if [[ $check_menu_wptangtoc_active = "98" ]]; then
  exec /etc/wptt/wptt-db-main 1
fi

check_menu_wptangtoc_active=$1
if [[ $check_menu_wptangtoc_active = "97" ]]; then
  exec /etc/wptt/wptt-backup-restore-main 1
fi
