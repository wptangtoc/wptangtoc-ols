function huong_dan() {
  Tính năng Xem thông tin tài khoản username database cho phép bạn xem chi tiết về các tài khoản người dùng [username] đã được tạo để truy cập và tương tác với cơ sở dữ liệu [database] trên máy chủ MariaDB.

  Mục Đích Chính
  * website nào được biến chế database, username database nào.
  * Kiểm tra và đối chiếu: Hữu ích khi bạn quản lý nhiều website và cần kiểm tra xem database nào tương ứng với website nào.
  * Quản lý người dùng: Biết được danh sách các user đang tồn tại để dễ dàng quản lý.
  * Kiểm tra quyền hạn: Xem xét các quyền [ví dụ: SELECT, INSERT, UPDATE, DELETE, CREATE, ALL PRIVILEGES] đã được cấp cho từng username trên các database cụ thể.
  * Bảo mật: Rà soát và đảm bảo các username chỉ có những quyền cần thiết, xóa bỏ user không dùng hoặc thu hồi quyền không phù hợp.
  * Gỡ lỗi kết nối: Khi ứng dụng không kết nối được database, việc kiểm tra lại thông tin username và host kết nối của nó là rất quan trọng.
  * Xác định user cho ứng dụng: Biết được ứng dụng nào đang sử dụng username nào để kết nối vào database.

  Tính năng này rất cần thiết cho việc quản trị cơ sở dữ liệu, đảm bảo an toàn
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null

clear
echo ""
print_border_top "$C_CYAN"
center_text "${C_YELLOW}${quan_ly_database} ➜ ${thong_tin_tai_khoan_database}${C_RESET}" "$C_CYAN"
print_border_bot "$C_CYAN"
echo ""

if [[ "$1" == '98' ]]; then
  WPTT_IN_MENU="yes"
  WPTT_MENU_BACK="/etc/wptt/wptt-db-main 1"
fi

wptt_check_mariadb || wptt_die "MariaDB đang bị sập! Hệ thống từ chối xem tài khoản Mariadb."

# ==============================================================================
# HÀM MENU LỌC TÊN MIỀN & TÀI KHOẢN ROOT (ĐÃ UPGRADE CHUẨN 78 KÝ TỰ)
# ==============================================================================
function lua_chon_NAME() {
  unset NAME selects
  selects=("root|[Tài khoản quản trị cao nhất]")
  local box_inner_width=78

  if [ "$(ls -A /etc/wptt/vhost 2>/dev/null | grep -v '^\.\.conf$' | sort -uV)" ]; then
    for entry in $(ls -A /etc/wptt/vhost | grep -v '^\.\.conf$' | sort -uV); do
      local dom=$(echo "$entry" | sed 's/^.//' | sed 's/.conf//')
      if [[ "$dom" == ?*.?* && -f "/etc/wptt/vhost/.$dom.conf" ]]; then
        selects+=("$dom")
      fi
    done
  fi

  if [[ ${#selects[@]} -eq 1 ]]; then
    echo -e "${C_YELLOW}Hệ thống chưa có website nào. Chỉ có thể xem thông tin tài khoản Root.${C_RESET}\n"
  fi

  echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
  local title_text="${nhap_lua_chon_website_cua_ban:-Lựa chọn Website} bạn muốn tra cứu Database:"
  local len=$(echo -n "$title_text" | awk '{print length($0)}')
  local pad_r=$((box_inner_width - len - 2))
  [[ $pad_r -lt 0 ]] && pad_r=0
  echo -e "${C_CYAN}│${C_RESET}  ${C_YELLOW}${title_text}${C_RESET}$(printf '%*s' "$pad_r" "")${C_CYAN}│${C_RESET}"
  echo -e "${C_CYAN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"

  local i=1
  for item in "${selects[@]}"; do
    local dom=$(echo "$item" | cut -d'|' -f1)
    local desc=$(echo "$item" | cut -d'|' -f2)

    if [[ "$dom" == "root" ]]; then
      local item_text=$(printf "  ${C_CYAN}%3d)${C_RESET} ${C_RED}%-25s${C_RESET} ${C_YELLOW}%s${C_RESET}" "$i" "root" "$desc")
      local clean_text=$(printf "  %3d) %-25s %s" "$i" "root" "$desc")
    else
      local item_text=$(printf "  ${C_CYAN}%3d)${C_RESET} ${C_BOLD_WHITE}%s${C_RESET}" "$i" "$dom")
      local clean_text=$(printf "  %3d) %s" "$i" "$dom")
    fi

    local item_len=$(echo -n "$clean_text" | awk '{print length($0)}')
    local pad=$((box_inner_width - item_len))
    [[ $pad -lt 0 ]] && pad=0
    echo -e "${C_CYAN}│${C_RESET}${item_text}$(printf '%*s' "$pad" "")${C_CYAN}│${C_RESET}"
    ((i++))
  done
  echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯${C_RESET}"

  local fzf_installed=false
  if command -v fzf &>/dev/null; then
    fzf_installed=true
    PROMPT_TEXT="Nhập lựa chọn (1-${#selects[@]}) [00=${chon_nhanh:-Tìm nhanh}] [0=${exit_thoat:-Thoát}]: "
  else
    PROMPT_TEXT="Nhập lựa chọn (1-${#selects[@]}) [0=${exit_thoat:-Thoát}]: "
  fi

  while true; do
    echo -en "${C_CYAN}${PROMPT_TEXT}${C_RESET}"
    if ! read -r REPLY; then exit 1; fi
    REPLY=$(echo "$REPLY" | tr -d ' ' | tr '[:upper:]' '[:lower:]')

    case "$REPLY" in
    0)
      echo -e "\n${C_GREEN}Đang thoát...${C_RESET}"
      NAME="0"
      return 0
      ;;
    00)
      if $fzf_installed; then
        local selected_item=$(printf '%s\n' "${selects[@]}" | nl -w 3 -s ': ' | fzf --prompt="Tìm website >> " --height=40% --border=rounded --color=border:red --cycle --reverse)
        local dom=$(echo "$selected_item" | sed 's/^[[:space:]]*[0-9]\+\:[[:space:]]*//' | cut -d'|' -f1)
        if [[ -n "$dom" ]]; then
          NAME="$dom"
          return 0
        else echo -e "${C_YELLOW}Đã hủy chọn. Vui lòng chọn lại.${C_RESET}"; fi
      else
        echo -e "${C_RED}Lỗi: FZF chưa cài đặt.${C_RESET}"
      fi
      ;;
    *)
      if [[ "$REPLY" =~ ^[0-9]+$ ]] && [ "$REPLY" -ge 1 ] && [ "$REPLY" -le ${#selects[@]} ]; then
        local action_index=$((REPLY - 1))
        NAME=$(echo "${selects[$action_index]}" | cut -d'|' -f1)
        return 0
      else
        echo -e "\n${C_RED}❌ Lựa chọn không hợp lệ! Vui lòng chọn lại.${C_RESET}"
      fi
      ;;
    esac
  done
}

lua_chon_NAME

[[ "$NAME" == "0" || -z "$NAME" ]] && {
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-db-main 1
  return 2>/dev/null || exit
}

echo "Xem thông tin tài khoản database $NAME : $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log

# ==============================================================================
# HÀM KIỂM TRA THỰC TẾ DATABASE TRÊN MARIADB (TRẠM KIỂM LÂM)
# ==============================================================================
# Tạo file cấu hình tạm bảo mật để query vào DB mà không lộ pass trên terminal
TEMP_CNF_ROOT=$(mktemp)
chmod 600 "$TEMP_CNF_ROOT"
cat >"$TEMP_CNF_ROOT" <<EOF
[client]
user=${database_admin_username}
password=${database_admin_password}
host=localhost
EOF
trap "rm -f $TEMP_CNF_ROOT" EXIT

check_real_database_status() {
  local db_name="$1"
  local db_user="$2"
  local db_exists='0'
  local user_exists='0'

  if [[ -n "$db_name" ]]; then
    db_exists=$(mariadb --defaults-extra-file="$TEMP_CNF_ROOT" -sse "SELECT EXISTS(SELECT 1 FROM information_schema.schemata WHERE schema_name = '$db_name');" 2>/dev/null)
  fi
  if [[ -n "$db_user" ]]; then
    user_exists=$(mariadb --defaults-extra-file="$TEMP_CNF_ROOT" -sse "SELECT EXISTS(SELECT 1 FROM mysql.user WHERE user = '$db_user');" 2>/dev/null)
  fi

  echo "$db_exists|$user_exists"
}

# ==============================================================================
# IN BÁO CÁO THÔNG TIN DATABASE
# ==============================================================================
echo ""

if [[ "$NAME" == 'root' ]]; then
  print_border_top "$C_RED"
  center_text "${C_BOLD_WHITE}THÔNG TIN TÀI KHOẢN DATABASE ROOT (CAO NHẤT)${C_RESET}" "$C_RED"
  print_border_mid "$C_RED"
  left_text "Root Username : ${C_BOLD_WHITE}$database_admin_username${C_RESET}" 2 "$C_RED"
  left_text "Root Password : ${C_YELLOW}$database_admin_password${C_RESET}" 2 "$C_RED"
  print_border_mid "$C_RED"
  left_text "${C_YELLOW}LƯU Ý: Tuyệt đối không chia sẻ thông tin này cho bất kỳ ai!${C_RESET}" 2 "$C_RED"
  print_border_bot "$C_RED"
  echo ""
else
  unset DB_Password_web DB_User_web DB_Name_web subfolder_su_dung
  . "/etc/wptt/vhost/.$NAME.conf" 2>/dev/null

  if [[ -n "$DB_User_web" && -n "$DB_Password_web" ]]; then
    # KIỂM CHỨNG THỰC TẾ
    status=$(check_real_database_status "$DB_Name_web" "$DB_User_web")
    db_exists=$(echo "$status" | cut -d'|' -f1)
    user_exists=$(echo "$status" | cut -d'|' -f2)

    has_error=0
    st_db="${C_GREEN}[HOẠT ĐỘNG TỐT]${C_RESET}"
    st_user="${C_GREEN}[HOẠT ĐỘNG TỐT]${C_RESET}"
    box_color="$C_GREEN"
    box_title="${C_BOLD_WHITE}THÔNG TIN DATABASE WEBSITE${C_RESET}"

    if [[ "$db_exists" == "0" ]]; then
      st_db="${C_RED}[CẢNH BÁO: ĐÃ BỊ XÓA LÉN]${C_RESET}"
      has_error=1
    fi
    if [[ "$user_exists" == "0" ]]; then
      st_user="${C_RED}[CẢNH BÁO: ĐÃ BỊ XÓA LÉN]${C_RESET}"
      has_error=1
    fi

    if [[ $has_error -eq 1 ]]; then
      box_color="$C_RED"
      box_title="${C_BOLD_WHITE}LỖI ĐỒNG BỘ DATABASE WEBSITE${C_RESET}"
    fi

    print_border_top "$box_color"
    center_text "$box_title" "$box_color"
    print_border_mid "$box_color"
    left_text "Website       : ${C_YELLOW}$NAME${C_RESET}" 2 "$box_color"
    left_text "DatabaseName  : ${C_CYAN}$DB_Name_web${C_RESET} $st_db" 2 "$box_color"
    left_text "Username      : ${C_CYAN}$DB_User_web${C_RESET} $st_user" 2 "$box_color"
    left_text "Password      : ${C_YELLOW}$DB_Password_web${C_RESET}" 2 "$box_color"
    print_border_bot "$box_color"
    echo ""
  fi

  # Xử lý thông tin Subfolder (Nếu có)
  if [[ -n "$subfolder_su_dung" && -d "/etc/wptt/${NAME}-wptt" ]]; then
    for sub_file in /etc/wptt/${NAME}-wptt/*; do
      [[ ! -f "$sub_file" ]] && continue
      unset DB_Password_web DB_User_web DB_Name_web domain thumuc
      . "$sub_file" 2>/dev/null

      # KIỂM CHỨNG THỰC TẾ SUBFOLDER
      status_sub=$(check_real_database_status "$DB_Name_web" "$DB_User_web")
      db_exists_sub=$(echo "$status_sub" | cut -d'|' -f1)
      user_exists_sub=$(echo "$status_sub" | cut -d'|' -f2)

      has_error_sub=0
      st_db_sub="${C_GREEN}[HOẠT ĐỘNG TỐT]${C_RESET}"
      st_user_sub="${C_GREEN}[HOẠT ĐỘNG TỐT]${C_RESET}"
      box_color_sub="$C_CYAN"
      box_title_sub="${C_BOLD_WHITE}THÔNG TIN DATABASE SUB-FOLDER${C_RESET}"

      if [[ "$db_exists_sub" == "0" ]]; then
        st_db_sub="${C_RED}[CẢNH BÁO: ĐÃ BỊ XÓA LÉN]${C_RESET}"
        has_error_sub=1
      fi
      if [[ "$user_exists_sub" == "0" ]]; then
        st_user_sub="${C_RED}[CẢNH BÁO: ĐÃ BỊ XÓA LÉN]${C_RESET}"
        has_error_sub=1
      fi

      if [[ $has_error_sub -eq 1 ]]; then
        box_color_sub="$C_RED"
        box_title_sub="${C_BOLD_WHITE}LỖI ĐỒNG BỘ DATABASE SUB-FOLDER${C_RESET}"
      fi

      print_border_top "$box_color_sub"
      center_text "$box_title_sub" "$box_color_sub"
      print_border_mid "$box_color_sub"
      left_text "Website (Sub) : ${C_YELLOW}$domain/$thumuc${C_RESET}" 2 "$box_color_sub"
      left_text "DatabaseName  : ${C_CYAN}$DB_Name_web${C_RESET} $st_db_sub" 2 "$box_color_sub"
      left_text "Username      : ${C_CYAN}$DB_User_web${C_RESET} $st_user_sub" 2 "$box_color_sub"
      left_text "Password      : ${C_YELLOW}$DB_Password_web${C_RESET}" 2 "$box_color_sub"
      print_border_bot "$box_color_sub"
      echo ""
    done
  fi
fi

echo -en "${C_GREEN}➜ Nhấn phím [Enter] để quay lại Menu...${C_RESET}"
read -r dummy

[[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-db-main 1
exec /usr/bin/wptangtoc 1
