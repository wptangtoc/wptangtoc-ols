#!/bin/bash

# ==============================================================================
# BỔ SUNG: TỐI ƯU HÓA RAM CHO MARIADB BẰNG JEMALLOC (CHỐNG PHÂN MẢNH)
# ==============================================================================
echo "Tiến hành cài đặt jemalloc để tối ưu bộ nhớ cho MariaDB..."
dnf install jemalloc -y >/dev/null 2>&1
# Tự động tìm đường dẫn chính xác của file thư viện jemalloc (libjemalloc.so)
JEMALLOC_PATH=$(rpm -ql jemalloc | grep -E 'libjemalloc\.so\.[0-9]+$' | head -n 1)
if [[ -n "$JEMALLOC_PATH" ]]; then
  # 1. Tạo thư mục cấu hình ghi đè (drop-in) của systemd cho MariaDB
  mkdir -p /etc/systemd/system/mariadb.service.d/
  
  # 2. Tạo file cấu hình ép MariaDB nạp thư viện jemalloc trước tiên (LD_PRELOAD)
  if [[ ! -f /etc/systemd/system/mariadb.service.d/jemalloc.conf ]];then
  cat > /etc/systemd/system/mariadb.service.d/jemalloc.conf <<EOF
[Service]
Environment="LD_PRELOAD=$JEMALLOC_PATH"
EOF
  # 3. Thông báo cho systemd biết cấu hình vừa thay đổi
systemctl daemon-reload
systemctl restart mariadb
  echo "Đã kích hoạt jemalloc cho MariaDB thành công tại: $JEMALLOC_PATH"
fi
fi
# ==============================================================================
