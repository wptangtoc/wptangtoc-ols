#!/bin/bash
echo "Tiến hành cài đặt jemalloc để tối ưu bộ nhớ cho MariaDB..."

# 1. Nhận diện Hệ Điều Hành
if [ -f /etc/os-release ]; then
  . /etc/os-release
  OS=$ID
fi

JEMALLOC_PATH=""

# 2. Xử lý cài đặt và tìm đường dẫn theo từng OS
if [[ "$OS" == "ubuntu" ]]; then
  export DEBIAN_FRONTEND=noninteractive
  apt-get update >/dev/null 2>&1
  apt-get install -y libjemalloc2 >/dev/null 2>&1
  # Tìm đường dẫn trên Ubuntu
  JEMALLOC_PATH=$(dpkg -L libjemalloc2 | grep -E 'libjemalloc\.so\.[0-9]+$' | head -n 1)

elif [[ "$OS" == "almalinux" || "$OS" == "rocky" || "$OS" == "centos" || "$OS" == "rhel" ]]; then
  dnf install jemalloc -y >/dev/null 2>&1
  # Tìm đường dẫn trên AlmaLinux/RHEL
  JEMALLOC_PATH=$(rpm -ql jemalloc | grep -E 'libjemalloc\.so\.[0-9]+$' | head -n 1)
else
  echo "Hệ điều hành $OS không được hỗ trợ tối ưu jemalloc tự động."
fi

# 3. Tiến hành cấu hình systemd nếu tìm thấy file thư viện
if [[ -n "$JEMALLOC_PATH" ]]; then
  # Tạo thư mục cấu hình ghi đè (drop-in) của systemd cho MariaDB
  mkdir -p /etc/systemd/system/mariadb.service.d/

  # Tạo file cấu hình ép MariaDB nạp thư viện jemalloc (Đã bỏ dấu ngoặc kép)
  if [[ ! -f /etc/systemd/system/mariadb.service.d/jemalloc.conf ]]; then
    cat >/etc/systemd/system/mariadb.service.d/jemalloc.conf <<EOF
[Service]
Environment=LD_PRELOAD=$JEMALLOC_PATH
EOF
    # Thông báo cho systemd biết cấu hình vừa thay đổi
    systemctl daemon-reload
    # Khởi động lại bằng stop/start để đảm bảo tiến trình ngắt hoàn toàn
    systemctl stop mariadb
    systemctl start mariadb
    echo "Hoàn tất cài đặt jemalloc để tối ưu bộ nhớ cho MariaDB..."
  fi
fi

#lệnh check xem đã kích hoạt chưa: mariadb -e "SHOW VARIABLES LIKE 'version_malloc_library';"
