#!/bin/bash
# @author: Gia Tuấn
# @website: https://wptangtoc.com
# @email: giatuan@wptangtoc.com
# @since: 2025

function huong_dan() {
  Tính năng Remote database [hay Truy cập cơ sở dữ liệu từ xa] là khả năng cho phép các ứng dụng, công cụ hoặc người dùng kết nối và tương tác với một máy chủ cơ sở dữ liệu [MariaDB] từ một máy tính hoặc máy chủ khác, không phải là máy chủ đang trực tiếp chứa cơ sở dữ liệu đó, thông qua một kết nối mạng [LAN hoặc Internet]

  Nói một cách đơn giản, thay vì website và database phải ở chung một nhà [cùng một server], tính năng này cho phép website ở nhà A có thể nói chuyện và lấy dữ liệu từ database đang ở nhà B.

  Mục Đích Chính
  * Phân tách kiến trúc ứng dụng: Cho phép máy chủ web [chạy ứng dụng] và máy chủ cơ sở dữ liệu hoạt động riêng biệt, giúp tăng khả năng mở rộng. [Ghi chú sẽ giảm hiệu suất, và rủi ro bảo mật hơn nếu dùng kết nối qua Internet không phải mạng lan]
  * Quản lý và phát triển từ xa: Lập trình viên hoặc quản trị viên cơ sở dữ liệu có thể làm việc với database từ máy tính cá nhân của họ bằng các công cụ quản lý database chuyên dụng [như MySQL Workbench, DBeaver, HeidiSQL] mà không cần đăng nhập trực tiếp vào server chứa database.
  * Tích hợp dữ liệu: Cho phép các hệ thống hoặc công cụ báo cáo khác nhau truy cập dữ liệu từ một nguồn database tập trung.
  * Mô hình microservices: Các dịch vụ nhỏ lẻ có thể chạy trên các server khác nhau nhưng cùng kết nối về một hoặc nhiều database từ xa.

}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null # Nạp thư viện UX Bo Cong

clear
echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}${quan_ly_database} ➜ Bật/Tắt Truy cập từ xa (Remote Database)${C_RESET}"
echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

if [[ "${1:-}" == '98' ]]; then
  WPTT_IN_MENU="yes"
  WPTT_MENU_BACK="/etc/wptt/wptt-db-main 1"
fi

wptt_check_mariadb || wptt_die "MariaDB đang bị sập! Hệ thống từ chối cho phép thiết lập remote database."

. /etc/wptt/tenmien 2>/dev/null
lua_chon_NAME "Remote Database"

if [[ "$NAME" == "0" || -z "$NAME" ]]; then
  exec /etc/wptt/wptt-db-main 1
  exit 0
fi

pathcheck="/etc/wptt/vhost/.$NAME.conf"
if [[ ! -f "$pathcheck" ]]; then
  echo -e "\n${C_RED}❌ Tên miền không tồn tại trên hệ thống này!${C_RESET}"
  sleep 3
  exec /etc/wptt/wptt-db-main 1
  exit 1
fi

# NHẬN DIỆN ĐƯỜNG DẪN CẤU HÌNH MARIADB CHUẨN XÁC THEO OS
if grep -qi "ubuntu" /etc/os-release 2>/dev/null; then
  duong_dan_cau_hinh_mariadb="/etc/mysql/my.cnf"
else
  duong_dan_cau_hinh_mariadb="/etc/my.cnf.d/server.cnf"
fi

. /etc/wptt/vhost/.$NAME.conf

# File cấu hình tạm thời bảo mật tuyệt đối cho MariaDB
TEMP_CNF_ROOT=$(mktemp)
chmod 600 "$TEMP_CNF_ROOT"
cat >"$TEMP_CNF_ROOT" <<EOF
[client]
user=${database_admin_username}
password=${database_admin_password}
host=localhost
max_allowed_packet=1G
default-character-set=utf8mb4

[mysqldump]
quick
quote-names
max_allowed_packet=1G
EOF

# Cơ chế an toàn: Tự động xóa file khi script kết thúc
trap "rm -f $TEMP_CNF_ROOT" EXIT

echo ""
# Kiểm tra xem User này đã được cấp quyền '%' (Remote) chưa
check_remote=$(mariadb --defaults-extra-file="$TEMP_CNF_ROOT" -e "SHOW GRANTS FOR '$DB_User_web'@'%';" 2>/dev/null)

# ==============================================================================
# NHÁNH 1: REMOTE ĐANG BẬT -> HỎI ĐỂ TẮT (DISABLE)
# ==============================================================================
if [[ -n "$check_remote" ]]; then
  if wptt_xac_nhan "Website $NAME ĐANG KÍCH HOẠT Remote Database. Bạn có muốn TẮT không?" "" "" "Đồng ý Tắt" "Hủy thao tác"; then
    echo ""
    _runing "Đang xóa quyền Remote (Truy cập từ xa) của User: $DB_User_web"
    mariadb --defaults-extra-file="$TEMP_CNF_ROOT" -e "DROP USER IF EXISTS '${DB_User_web}'@'%'"
    mariadb --defaults-extra-file="$TEMP_CNF_ROOT" -e "FLUSH PRIVILEGES"
    _rundone "Đã xóa quyền Remote của User: $DB_User_web"

    # Kiểm tra xem hệ thống còn Website nào đang dùng Remote không
    _runing "Đang quét hệ thống xem còn Website nào sử dụng Remote Database không..."
    rm -f /tmp/remote_wptangtoc_ols

    for entry in $(ls -A /etc/wptt/vhost 2>/dev/null | grep -v '^\.\.conf$' | sort -uV); do
      domain=$(echo "$entry" | sed 's/^.//' | sed 's/.conf//')
      path="/usr/local/lsws/$domain/html"
      if [[ -d "$path" && "$domain" != "$NAME" ]]; then
        unset DB_User_web_check
        . "/etc/wptt/vhost/.$domain.conf" 2>/dev/null
        if [[ -n "${DB_User_web_check:-$DB_User_web}" ]]; then
          mariadb --defaults-extra-file="$TEMP_CNF_ROOT" -e "SHOW GRANTS FOR '${DB_User_web_check:-$DB_User_web}'@'%';" 2>/dev/null 1>>/tmp/remote_wptangtoc_ols
        fi
      fi
    done

    check_con_dung_website_khac=""
    [[ -f /tmp/remote_wptangtoc_ols ]] && check_con_dung_website_khac=$(cat /tmp/remote_wptangtoc_ols)

    # NẾU KHÔNG CÒN AI DÙNG -> ĐÓNG PORT & BẬT LẠI SKIP-NETWORKING
    if [[ -z "$check_con_dung_website_khac" ]]; then
      _rundone "Không còn Website nào dùng Remote. Tiến hành niêm phong hệ thống mạng!"

      port_mariadb_remote=$(grep -i '^port[[:space:]]*=' "$duong_dan_cau_hinh_mariadb" | grep -o '[0-9]\+$')

      _runing "Đang đóng kết nối TCP và Bật lại tính năng Skip-Networking..."
      sed -i '/^bind-address/d' "$duong_dan_cau_hinh_mariadb"
      sed -i '/^port[[:space:]]*=/d' "$duong_dan_cau_hinh_mariadb"
      sed -i '/skip-networking/d' "$duong_dan_cau_hinh_mariadb"
      sed -i '/\[mysqld\]/a skip-networking' "$duong_dan_cau_hinh_mariadb"
      _rundone "Đã cấu hình MariaDB chỉ dùng Unix Socket (Siêu bảo mật)"

      # Đóng tường lửa Firewalld
      if [[ $(systemctl status firewalld.service 2>/dev/null | grep 'Active' | awk '{print $2}') == 'active' ]]; then
        _runing "Đang đóng cổng $port_mariadb_remote trên Firewalld..."
        firewall-cmd --permanent --zone=public --remove-port=${port_mariadb_remote}/tcp >/dev/null 2>&1
        firewall-cmd --reload >/dev/null 2>&1
        _rundone "Đã đóng cổng Firewalld"
      fi

      # Đóng tường lửa CSF
      if [[ -f /etc/csf/csf.conf ]]; then
        _runing "Đang đóng cổng $port_mariadb_remote trên tường lửa CSF..."
        sed -i -r '/^TCP_IN /s/"'$port_mariadb_remote'"/""/; s/([",])'$port_mariadb_remote',|,'$port_mariadb_remote'([,"])/\1\2/' /etc/csf/csf.conf
        csf -x >/dev/null 2>&1
        csf -e >/dev/null 2>&1
        _rundone "Đã đóng cổng CSF"
      fi

      # Đóng tường lửa Nftables
      if [[ $(systemctl status nftables.service 2>/dev/null | grep 'Active' | awk '{print $2}') == 'active' ]]; then
        path_nftables_config="/etc/sysconfig/nftables.conf"
        cat /etc/*release 2>/dev/null | grep -qi "Ubuntu" && path_nftables_config="/etc/nftables.conf"
        if [[ -f "$path_nftables_config" ]]; then
          _runing "Đang đóng cổng $port_mariadb_remote trên Nftables..."
          sed -i '/#port remote mariadb/d' "$path_nftables_config"
          systemctl restart nftables
          _rundone "Đã đóng cổng Nftables"
        fi
      fi

      _runing "khởi động lại dịch vụ MariaDB và Fail2ban..."
      systemctl restart mariadb.service >/dev/null 2>&1
      [[ -n "$port_mariadb_remote" ]] && sed -i "s/$port_mariadb_remote/3306/g" /etc/fail2ban/jail.local
      systemctl restart fail2ban.service >/dev/null 2>&1
      _rundone "khởi động lại dịch vụ MariaDB và Fail2ban..."

    else
      _rundone "Hệ thống vẫn còn Website khác dùng Remote. Giữ nguyên cổng kết nối mạng."
    fi

    rm -f /tmp/remote_wptangtoc_ols
    sleep 2
    [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-db-main 1
    exit 0
  else
    echo -e "${C_YELLOW}Đã hủy thao tác Tắt Remote.${C_RESET}\n"
    [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-db-main 1
    exit 0
  fi
fi

# ==============================================================================
# NHÁNH 2: REMOTE ĐANG TẮT -> HỎI ĐỂ BẬT (ENABLE)
# ==============================================================================
if wptt_xac_nhan "Bạn có muốn KÍCH HOẠT Remote Database cho website $NAME không?" "" "" "Đồng ý Bật" "Hủy thao tác"; then

  # Kiểm tra xem MariaDB đã mở cổng mạng chưa (có chữ port= chưa)
  if ! grep -qi '^port[[:space:]]*=' "$duong_dan_cau_hinh_mariadb"; then
    echo ""
    while true; do
      echo -en "${C_CYAN}Nhập Port bạn muốn sử dụng cho Remote (VD: 3306, 33066) [0=Thoát]: ${C_RESET}"
      read -r port

      [[ "$port" == "0" || -z "$port" ]] && {
        echo -e "\n${C_GREEN}Đang thoát...${C_RESET}"
        [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-db-main 1
        exit 0
      }

      if ! [[ "$port" =~ ^[0-9]+$ ]] || ((port < 1 || port > 65535)); then
        echo -e "${C_RED}❌ Lỗi: Port phải là số nguyên từ 1 đến 65535! Vui lòng nhập lại.${C_RESET}"
        continue
      fi

      # Kiểm tra trùng Port SSH
      port_checkssh=$(grep "^Port " /etc/ssh/sshd_config | grep -o '[0-9]\+' || echo 22)
      if [[ "$port" == "$port_checkssh" || "$port" == "80" || "$port" == "443" ]]; then
        echo -e "${C_RED}❌ Lỗi: Cổng $port đã được sử dụng bởi hệ thống (SSH/Web). Hãy chọn cổng khác!${C_RESET}"
        continue
      fi

      # Kiểm tra trùng Port WebGUI OLS
      if [[ ! -f /usr/local/lsws/conf/disablewebconsole ]]; then
        port_webgui_openlitespeed=$(grep "address" /usr/local/lsws/admin/conf/admin_config.conf | cut -f2 -d":")
        if [[ "$port" == "$port_webgui_openlitespeed" ]]; then
          echo -e "${C_RED}❌ Lỗi: Cổng $port đã được sử dụng bởi LiteSpeed WebAdmin. Hãy chọn cổng khác!${C_RESET}"
          continue
        fi
      fi

      break # Nhập đúng thì thoát vòng lặp
    done

    # =========================================================
    # THIẾT LẬP MỞ MẠNG VÀ CẤU HÌNH TƯỜNG LỬA
    # =========================================================
    echo ""
    _runing "Đang loại bỏ Skip-Networking và gắn cổng Port $port cho MariaDB..."
    sed -i '/^bind-address/d' "$duong_dan_cau_hinh_mariadb"
    sed -i '/^port[[:space:]]*=/d' "$duong_dan_cau_hinh_mariadb"
    sed -i '/skip-networking/d' "$duong_dan_cau_hinh_mariadb" # FIX KHÁNH VY: Dùng đúng biến cấu hình theo OS

    # Tiêm cấu hình mạng xuống ngay dưới [mysqld]
    sed -i "/\[mysqld\]/a port=$port\nbind-address=0.0.0.0" "$duong_dan_cau_hinh_mariadb"
    _rundone "Cấu hình mạng MariaDB hoàn tất"

    # Mở Firewalld
    if [[ $(systemctl status firewalld.service 2>/dev/null | grep 'Active' | awk '{print $2}') == 'active' ]]; then
      _runing "Mở cổng $port trên Firewalld..."
      firewall-cmd --permanent --zone=public --add-port=$port/tcp >/dev/null 2>&1
      firewall-cmd --reload >/dev/null 2>&1
      _rundone "Mở cổng $port trên Firewalld..."
    fi

    # Mở CSF
    if [[ -f /etc/csf/csf.conf ]]; then
      _runing "mở cổng $port trên tường lửa CSF..."
      if ! grep -q "^TCP_IN =.*$port," /etc/csf/csf.conf; then
        sed -i "s/^TCP_IN = \"/TCP_IN = \"$port,/g" /etc/csf/csf.conf
        csf -x >/dev/null 2>&1
        csf -e >/dev/null 2>&1
      fi
      _rundone "mở cổng $port trên tường lửa CSF..."
    fi

    # Mở Nftables
    if [[ $(systemctl status nftables.service 2>/dev/null | grep 'Active' | awk '{print $2}') == 'active' ]]; then
      path_nftables_config="/etc/sysconfig/nftables.conf"
      cat /etc/*release 2>/dev/null | grep -qi "Ubuntu" && path_nftables_config="/etc/nftables.conf"
      if [[ -f "$path_nftables_config" ]]; then
        _runing "Đang mở cổng $port trên Nftables..."
        sed -i '/#port remote mariadb/d' "$path_nftables_config"
        sed -i "/chain input /a\ \ tcp dport $port accept #port remote mariadb" "$path_nftables_config"
        systemctl restart nftables >/dev/null 2>&1
        _rundone "Đã cấu hình Nftables"
      fi
    fi

    _runing "khởi động lại dịch vụ MariaDB và Fail2ban..."
    sed -i "s/3306/$port/g" /etc/fail2ban/jail.local
    systemctl restart mariadb.service >/dev/null 2>&1
    systemctl restart fail2ban.service >/dev/null 2>&1
    _rundone "khởi động lại dịch vụ MariaDB và Fail2ban..."
  else
    # Nếu mạng đã mở rồi thì chỉ lấy Port ra để in thông báo
    port=$(grep -i '^port[[:space:]]*=' "$duong_dan_cau_hinh_mariadb" | grep -o '[0-9]\+$')
  fi

  # =========================================================
  # CẤP QUYỀN DATABASE VÀ IN THÔNG TIN
  # =========================================================
  _runing "Cấp quyền Remote cho User: $DB_User_web ..."
  echo "Kích hoạt remote database website $NAME : $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log

  mariadb --defaults-extra-file="$TEMP_CNF_ROOT" -e "CREATE USER IF NOT EXISTS '$DB_User_web'@'%' IDENTIFIED BY '$DB_Password_web'"
  mariadb --defaults-extra-file="$TEMP_CNF_ROOT" -e "GRANT ALL PRIVILEGES ON $DB_Name_web.* TO '$DB_User_web'@'%';"
  mariadb --defaults-extra-file="$TEMP_CNF_ROOT" -e "FLUSH PRIVILEGES"
  _rundone "Cấp quyền Remote cho User: $DB_User_web ..."

  # Lấy IP Public
  ip=$(curl -skf --connect-timeout 5 "https://ipv4.icanhazip.com" || curl -skf --connect-timeout 5 "https://checkip.amazonaws.com")
  [[ -z "$ip" ]] && ip=$(curl -sk --connect-timeout 5 "https://ipv6.icanhazip.com") # Fallback IPv6

  echo -e "\n${C_GREEN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_BOLD_WHITE}HOÀN TẤT BẬT REMOTE DATABASE${C_RESET}"
  echo -e "${C_GREEN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
  left_text "Sử dụng các thông tin dưới đây để kết nối bằng phần mềm" 2
  left_text "quản lý Database (Navicat, DBeaver, MySQL Workbench...):" 2
  echo -e "${C_GREEN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
  left_text " 1. Máy chủ (Host/IP) : ${C_YELLOW}$ip${C_RESET}" 2
  left_text " 2. Cổng mạng (Port)  : ${C_YELLOW}$port${C_RESET}" 2
  left_text " 3. Tên Database      : ${C_YELLOW}$DB_Name_web${C_RESET}" 2
  left_text " 4. Tên Đăng nhập     : ${C_YELLOW}$DB_User_web${C_RESET}" 2
  left_text " 5. Mật khẩu (Pass)   : ${C_YELLOW}$DB_Password_web${C_RESET}" 2
  echo -e "${C_GREEN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

else
  echo -e "${C_YELLOW}Đã hủy thao tác Bật Remote.${C_RESET}\n"
fi

[[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-db-main 1
