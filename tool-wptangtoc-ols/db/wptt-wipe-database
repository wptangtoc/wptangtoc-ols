#!/bin/bash
# @author: Gia Tuấn
# @website: https://wptangtoc.com
# @since: 2026

function huong_dan() {
  Tính năng Format trắng database [hay Làm trắng/Xóa sạch cơ sở dữ liệu] là hành động xóa bỏ hoàn toàn tất cả các đối tượng [như bảng, view, stored procedure] và toàn bộ dữ liệu bên trong một cơ sở dữ liệu [database] hiện có, đưa nó về trạng thái trống rỗng như lúc mới được tạo.

  Nói một cách đơn giản, đây là việc bạn dọn sạch sành sanh một kho chứa dữ liệu, vứt bỏ hết đồ đạc [dữ liệu] và các kệ chứa [bảng], chỉ giữ lại cái vỏ kho [database, username vẫn còn tồn tại].

  Mục Đích Chính
  * Làm lại từ đầu hoàn toàn: Khi bạn muốn xóa sạch một database [ví dụ: database thử nghiệm, staging] để bắt đầu với một cấu trúc mới hoặc cài đặt lại ứng dụng từ đầu.
  * Chuẩn bị cài đặt lại ứng dụng: Một số ứng dụng yêu cầu một database trống khi cài đặt hoặc cài đặt lại.
  * Loại bỏ cấu trúc bị lỗi nặng: Trong trường hợp hiếm gặp khi cấu trúc database bị hỏng nặng mà không thể sửa chữa, việc làm trắng có thể là một giải pháp [dù khôi phục từ backup thường được ưu tiên hơn].
  * Xóa dữ liệu triệt để: Để đảm bảo mọi dữ liệu trong một database cụ thể bị xóa hoàn toàn trước khi tái sử dụng database đó cho mục đích khác.

  LUÔN LUÔN SAO LƯU [BACKUP] TRƯỚC KHI THỰC HIỆN: Đây là điều bắt buộc. Hãy đảm bảo bạn có một bản sao lưu tin cậy trước khi tiến hành.
  Hãy thực hiện thao tác này với sự cẩn trọng tối đa và chỉ khi bạn hoàn toàn chắc chắn về việc mình đang làm.
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null # Nạp thư viện UI Xác nhận

clear
echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}${quan_ly_database} ➜ Format trắng Database (Wipe)${C_RESET}"
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

if [[ "${1:-}" == '98' ]]; then
  WPTT_IN_MENU="yes"
  WPTT_MENU_BACK="/etc/wptt/wptt-db-main 1"
fi

wptt_check_mariadb || wptt_die "MariaDB đang bị sập! Hệ thống từ chối không cho phép format database website để đảm bảo an toàn."

NAME=$1
[[ "$NAME" == '98' ]] && NAME=''

# ==============================================================================
# GỌI THƯ VIỆN CHỌN DOMAIN LÕI
# ==============================================================================
if [[ -z "$NAME" ]]; then
  . /etc/wptt/tenmien
  lua_chon_NAME "Lựa chọn Website để Format trắng Database (Wipe)"
fi

[[ "$NAME" == "0" || -z "$NAME" ]] && {
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-db-main 1
  return 2>/dev/null || exit
}

pathcheck="/etc/wptt/vhost/.$NAME.conf"
if [[ ! -f "$pathcheck" ]]; then
  echo -e "\n${C_RED}❌ Tên miền không tồn tại trên hệ thống này!${C_RESET}"
  sleep 3
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-db-main 1
  return 2>/dev/null || exit
fi

# Load cấu hình Vhost để lấy $DB_Name_web và $DB_User_web
. "$pathcheck" 2>/dev/null

dongy="n"

# Chỉ hỏi xác nhận khi chạy thủ công qua Menu
if [[ "${1:-}" == "98" || -z "${1:-}" ]]; then
  echo ""
  if wptt_xac_nhan "Bạn có CHẮC CHẮN muốn Format trắng không?" "${C_BOLD_WHITE}Website:${C_RESET} ${C_YELLOW}$NAME${C_RESET} ${C_BOLD_WHITE}Database:${C_RESET} ${C_RED}$DB_Name_web${C_RESET}" "CẢNH BÁO NGUY HIỂM: Hành động này sẽ XÓA SẠCH SÀNH SANH toàn bộ dữ liệu (Bảng, Nội dung) của Database này" "Đồng ý XÓA TOÀN BỘ" "Hủy thao tác"; then
    dongy="y"
  fi
else
  # Kích hoạt chế độ Non-interactive (Auto Wipe) nếu truyền thẳng biến $NAME bằng CLI
  dongy="y"
fi

if [[ "$dongy" == "y" ]]; then
  echo ""
  _runing "Format trắng Database của website $NAME"
  echo "Wipe format xoá dữ liệu database website $NAME : $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log

  TEMP_CNF_ROOT=$(mktemp)
  chmod 600 "$TEMP_CNF_ROOT"
  cat >"$TEMP_CNF_ROOT" <<EOF
[client]
user=${database_admin_username}
password=${database_admin_password}
host=localhost
max_allowed_packet=1G
default-character-set=utf8mb4

[mysqldump]
quick
quote-names
max_allowed_packet=1G
EOF

  # Bẫy an toàn: Luôn xóa file Temp kể cả khi script bị crash giữa chừng
  trap "rm -f $TEMP_CNF_ROOT" EXIT

  # 1. Xóa Database (Lúc này quyền của User cũng bị MariaDB xóa theo)
  mariadb --defaults-extra-file="$TEMP_CNF_ROOT" -e "DROP DATABASE IF EXISTS \`$DB_Name_web\`;"

  # 2. Tạo lại Database trắng
  mariadb --defaults-extra-file="$TEMP_CNF_ROOT" -e "CREATE DATABASE IF NOT EXISTS \`$DB_Name_web\`;"

  # 3. Phục hồi quyền (Grant) cho User để website không bị lỗi Access Denied
  mariadb --defaults-extra-file="$TEMP_CNF_ROOT" -e "GRANT ALL PRIVILEGES ON \`$DB_Name_web\`.* TO '$DB_User_web'@'localhost';"
  mariadb --defaults-extra-file="$TEMP_CNF_ROOT" -e "FLUSH PRIVILEGES;"

  rm -rf "$TEMP_CNF_ROOT"
  _rundone "Format trắng Database của website $NAME"

  echo -e "\n${C_GREEN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_BOLD_WHITE}HOÀN TẤT FORMAT DATABASE${C_RESET}"
  echo -e "${C_GREEN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
  left_text "Website thao tác : ${C_YELLOW}$NAME${C_RESET}" 2
  left_text "Tên Database     : ${C_RED}$DB_Name_web${C_RESET}" 2
  left_text "Tên Database User: ${C_CYAN}$DB_User_web${C_RESET}" 2
  echo -e "${C_GREEN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
  left_text "Trạng thái       : Cơ sở dữ liệu đã được làm sạch hoàn toàn." 2
  left_text "                   Quyền truy cập của User vẫn được giữ nguyên." 2
  echo -e "${C_GREEN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

else
  echo -e "${C_YELLOW}Đã hủy thao tác Wipe Database.${C_RESET}"
fi

[[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-db-main 1
