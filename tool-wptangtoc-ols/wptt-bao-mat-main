# 3. HÀM THỰC THI (MAPPING INDEX 0-23 TƯƠNG THÍCH WPTT-SEARCH)
# ==============================================================================
run_action() {
  local index=$1
  local script_path=""
  local script_args="98" # Tham số để script con biết đường quay lại Menu

  case $index in
  0) script_path="/etc/wptt/bao-mat/csf-main" ;;
  1) script_path="/etc/wptt/bao-mat/wptt-modsecurity" ;;
  2) script_path="/etc/wptt/bao-mat/wptt-firewall-7g" ;;
  3) script_path="/etc/wptt/bao-mat/mod-ddos-litespeed" ;;
  4) script_path="/etc/wptt/bao-mat/wptt-chong-ddos-ip-thiet-lap" ;;
  5) script_path="/etc/wptt/bao-mat/wptt-canh-bao-ddos-thiet-lap" ;;
  6) script_path="/etc/wptt/bao-mat/bao-mat-ddos-404" ;;
  7) script_path="/etc/wptt/bao-mat/ddos-search" ;;
  8) script_path="/etc/wptt/bao-mat/wptt-ddos-403-bi-pham-block-http" ;;
  9) script_path="/etc/wptt/bao-mat/wptt-block-bad-bot" ;;
  10) script_path="/etc/wptt/bao-mat/wptt-firewall-bot-ai" ;;
  11) script_path="/etc/wptt/bao-mat/wptt-bay-ruoi-honneypot" ;;

  12) script_path="/etc/wptt/wordpress/bao-mat-2lop" ;;
  13) script_path="/etc/wptt/bao-mat/wptt-kiem-tra-tai-khoan-bao-mat-2lop" ;;
  14) script_path="/etc/wptt/bao-mat/wptt-admin-bao-mat" ;;
  15) script_path="/etc/wptt/bao-mat/wptt-lock-down" ;;
  16) script_path="/etc/wptt/bao-mat/bat-tat-open-basedir" ;;
  17) script_path="/etc/wptt/bao-mat/bat-tat-ham-function-php-nguy-hiem" ;;
  18) script_path="/etc/wptt/bao-mat/wptt-hotlinking" ;;
  19) script_path="/etc/wptt/bao-mat/add-domain-hotlinking" ;;

  20) script_path="/etc/wptt/bao-mat/wptt-scan-virus" ;;
  21) script_path="/etc/wptt/bao-mat/wptt-scan-virus-xoa-phan-mem" ;;
  22) script_path="/etc/wptt/bao-mat/wptt-telegram" ;;
  23) script_path="/etc/wptt/bao-mat/thong-bao-login-ssh" ;;
  *)
    echo "${lua_chon_khong_hop_le:-Lựa chọn không hợp lệ}: Index $index."
    return 1
    ;;
  esac

  if [[ -x "$script_path" || -f "$script_path" ]]; then
    exec bash "$script_path" "$script_args"
  else
    echo -e "\n\033[1;31m[!] Lỗi: Không tìm thấy hoặc không thể thực thi script '$script_path'.\033[0m"
    sleep 2
    exec /etc/wptt/wptt-bao-mat-main 1
  fi
}

