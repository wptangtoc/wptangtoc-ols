# ==============================================================================
function wptt_xac_nhan() {
  local msg_title="${1:-Bạn có chắc chắn muốn thực hiện thao tác này?}"
  local info_1="$2"
  local info_2="$3"
  local opt_1="${4:-Đồng ý}"
  local opt_2="${5:-Không đồng ý}"

  local box_inner_width=${box_inner_width:-71}

  echo -e "\n${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"

  # 1. In Tiêu đề
  local clean_title=$(echo -e "$msg_title" | sed "s/\x1B\[[0-9;]*[a-zA-Z]//g")
  local pad_title=$((box_inner_width - ${#clean_title} - 2))
  [[ $pad_title -lt 0 ]] && pad_title=0
  echo -e "${C_CYAN}│${C_RESET}  ${C_YELLOW}${msg_title}${C_RESET}$(printf '%*s' "$pad_title" "")${C_CYAN}│${C_RESET}"

  echo -e "${C_CYAN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"

  # 2. In Dòng thông tin 1 (Nếu có truyền vào)
  if [[ -n "$info_1" ]]; then
    local clean_info1=$(echo -e "$info_1" | sed "s/\x1B\[[0-9;]*[a-zA-Z]//g")
    local pad_1=$((box_inner_width - ${#clean_info1} - 2))
    [[ $pad_1 -lt 0 ]] && pad_1=0
    echo -e "${C_CYAN}│${C_RESET}  ${info_1}$(printf '%*s' "$pad_1" "")${C_CYAN}│${C_RESET}"
  fi

  # 3. In Dòng thông tin 2 (Nếu có truyền vào)
  if [[ -n "$info_2" ]]; then
    local clean_info2=$(echo -e "$info_2" | sed "s/\x1B\[[0-9;]*[a-zA-Z]//g")
    local pad_2=$((box_inner_width - ${#clean_info2} - 2))
    [[ $pad_2 -lt 0 ]] && pad_2=0
    echo -e "${C_CYAN}│${C_RESET}  ${info_2}$(printf '%*s' "$pad_2" "")${C_CYAN}│${C_RESET}"
  fi

  # Vẽ vách ngăn nếu có chứa thông tin 1 hoặc 2
  if [[ -n "$info_1" || -n "$info_2" ]]; then
    echo -e "${C_CYAN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
  fi

  # 4. In các nút lựa chọn
  local clean_opt1="1) $opt_1"
  local pad_opt1=$((box_inner_width - ${#clean_opt1} - 2))
  [[ $pad_opt1 -lt 0 ]] && pad_opt1=0
  echo -e "${C_CYAN}│${C_RESET}  ${C_CYAN}1)${C_RESET} ${opt_1}$(printf '%*s' "$pad_opt1" "")${C_CYAN}│${C_RESET}"

  local clean_opt2="2) $opt_2"
  local pad_opt2=$((box_inner_width - ${#clean_opt2} - 2))
  [[ $pad_opt2 -lt 0 ]] && pad_opt2=0
  echo -e "${C_CYAN}│${C_RESET}  ${C_CYAN}2)${C_RESET} ${opt_2}$(printf '%*s' "$pad_opt2" "")${C_CYAN}│${C_RESET}"

  echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯${C_RESET}"

  # 5. Vòng lặp nhận phím an toàn
  while true; do
    echo -en "${C_CYAN}Nhập lựa chọn của bạn [1-2]: ${C_RESET}"
    read -r confirm
    case "$confirm" in
    1)
      return 0 # Mã 0 = True (Bấm Đồng ý)
      ;;
    2)
      return 1 # Mã 1 = False (Bấm Không đồng ý)
      ;;
    *)
      echo -e "${C_RED}❌ Bạn nhập sai, vui lòng nhập 1 hoặc 2.${C_RESET}"
      ;;
    esac
  done
}

