# ==============================================================================
# 3. LOGIC XỬ LÝ (ÁNH XẠ CHUẨN VỚI INDEX MỚI)
# ==============================================================================
run_action() {
  local index=$1
  local script_path=""
  local script_args="98"

  case $index in
  0) script_path="/etc/wptt/disk/wptt-disk-website" ;;
  1) script_path="/etc/wptt/disk/wptt-larg-file-all-dung-luong-lon" ;;
  2) script_path="/etc/wptt/disk/wptt-larg-thu-muc-all-dung-luong-lon" ;;
  
  3) script_path="/etc/wptt/disk/wptt-larg-file-website-dung-luong-lon" ;;
  4) script_path="/etc/wptt/disk/wptt-larg-thu-muc-website-dung-luong-lon" ;;
  esac

  if [[ -x "$script_path" || -f "$script_path" ]]; then
    exec bash "$script_path" "$script_args"
  else
    echo -e "\n\033[1;31m[!] Lỗi: Không tìm thấy hoặc không thể thực thi script '$script_path'.\033[0m"
    sleep 2
    exec /etc/wptt/wptt-disk-main 1
  fi
}

# ==============================================================================
# 4. GIAO DIỆN TÙY CHỈNH (NHÚNG THANH TRẠNG THÁI DISK VÀO KHUNG)
# ==============================================================================
draw_custom_grid() {
  # Tính toán dung lượng đĩa Real-time
  local disk_used_gb="ERR"
  local disk_total_gb="ERR"
  local disk_percent_numeric="0"
  local disk_color="${C_RED}"
  
  local disk_stats_output=$(df -BG / 2>/dev/null | awk 'NR==2 {print $3, $2, $5}')
  if [[ -n "$disk_stats_output" ]]; then
    read -r used total percent <<< "$disk_stats_output"
    disk_used_gb=$(echo "$used" | tr -d 'G')
    disk_total_gb=$(echo "$total" | tr -d 'G')
    disk_percent_numeric=$(echo "$percent" | tr -d '%')
    
    if [[ "$disk_percent_numeric" =~ ^[0-9]+$ ]]; then
      if (( disk_percent_numeric > 90 )); then disk_color="${C_RED}"
      elif (( disk_percent_numeric > 70 )); then disk_color="${C_YELLOW}"
      else disk_color="${C_GREEN}"; fi
    else
      disk_percent_numeric="ERR"
    fi
  fi

  # In thanh trạng thái (Căn giữa tuyệt đối trong khung 78)
  local plain_text=" TỔNG QUAN Ổ ĐĨA: ${disk_used_gb}/${disk_total_gb}GB (${disk_percent_numeric}%) "
  local pad_left=$(( (78 - ${#plain_text}) / 2 ))
  local pad_right=$(( 78 - ${#plain_text} - pad_left ))
  
  printf "${MARGIN}${C_CYAN}│${C_RESET}%*s${C_YELLOW}TỔNG QUAN Ổ ĐĨA:${C_RESET} ${C_BOLD_WHITE}%s/%sGB${C_RESET} %b(%s%%)%b%*s${C_CYAN}│${C_RESET}\n" \
    "$pad_left" "" "$disk_used_gb" "$disk_total_gb" "$disk_color" "$disk_percent_numeric" "${C_RESET}" "$pad_right" ""

  print_spacer
  echo -e "${MARGIN}${C_CYAN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
  print_spacer

  # In 2 cột chức năng
  print_row "" "QUẢN LÝ CHUNG & MÁY CHỦ" "" "TÌM KIẾM THEO WEBSITE (DOMAIN)"
  print_row "1" "${options[0]}" ""  ""
  print_row "2" "${options[1]}" "4" "${options[3]}"
  print_row "3" "${options[2]}" "5" "${options[4]}"
}

