# Hàm thực thi hành động
run_action() {
  local index=$1
  local script_path=""
  local script_args=""

  case $index in
  0)
    script_path="/etc/wptt/chuyen-web/wptt-chuyen-website"
    script_args=""
    ;;
  1)
    script_path="/etc/wptt/chuyen-web/wptt-chuyen-website-all"
    script_args=""
    ;;
  2)
    script_path="/etc/wptt/chuyen-web/rsync-move"
    script_args=""
    ;;
  3)
    script_path="/etc/wptt/chuyen-web/rsync-move-only"
    script_args="98"
    ;;
  4)
    script_path="/etc/wptt/chuyen-web/get-rsync-move"
    script_args="98"
    ;;
  *)
    echo -e "\n${C_RED}[!] ${lua_chon_khong_hop_le:-Lựa chọn không hợp lệ}: Index $index.${C_RESET}"
    return 1
    ;;
  esac

  # Kiểm tra và chạy script con
  if [[ -x "$script_path" || -f "$script_path" ]]; then
    if [[ -n "$script_args" ]]; then
      exec bash "$script_path" "$script_args"
    else
      exec bash "$script_path"
    fi
  else
    echo -e "\n${C_RED}[!] Lỗi: Không tìm thấy kịch bản '$script_path'.${C_RESET}"
    sleep 2
    exec /etc/wptt/chuyen-web-main 1
  fi
}

# ==============================================================================
# TÙY BIẾN GIAO DIỆN HIỂN THỊ FULL 1 CỘT (CÓ NÚT MÀU VÀNG VÀ CHỐNG LỆCH UTF-8)
# ==============================================================================
print_full_row() {
  local index="$1"
  local text="$2"
  
  # Format cho index (vd: " 1", " 2") để thẳng hàng
  local formatted_index=$(printf "%2s" "$index")
  
  # Chuỗi thô dùng để đếm ký tự (không chứa mã màu)
  local raw_text="  [${formatted_index}] ${text}"
  local clean_text=$(echo -en "$raw_text" | sed "s/\x1B\[[0-9;]*[a-zA-Z]//g" | tr -d '\r\n')
  
  # Đếm bằng UTF-8 để tiếng Việt không bóp méo khung
  local text_len=$(LC_ALL=C.UTF-8 printf "%s" "$clean_text" | wc -m | tr -d ' ' 2>/dev/null)
  [[ -z "$text_len" || "$text_len" == "0" ]] && text_len=${#clean_text}
  
  # Tính toán khoảng trống còn lại để đập vào lề phải (78 lọt lòng - 1 space lề)
  local pad=$((78 - text_len - 1))
  [[ $pad -lt 0 ]] && pad=0
  
  # In ra với mã màu VÀNG ($C_YELLOW) bọc đúng cặp ngoặc và số
  echo -e "${C_CYAN}│${C_RESET}  ${C_YELLOW}[${formatted_index}]${C_RESET} ${text}$(printf '%*s' "$pad" "") ${C_CYAN}│${C_RESET}"
}

draw_custom_grid() {
  print_full_row "1" "${options[0]}"
  print_full_row "2" "${options[1]}"
  print_full_row "3" "${options[2]}"
  print_full_row "4" "${options[3]}"
  print_full_row "5" "${options[4]}"
}

