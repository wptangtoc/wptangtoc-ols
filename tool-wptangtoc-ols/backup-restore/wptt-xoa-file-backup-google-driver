#!/bin/bash
# @author: Gia Tuấn
# @website: https://wptangtoc.com
# @description: Quản lý & Xóa file backup Cloud
# @since: 2026

function huong_dan() {
  Tính năng xóa file backup thủ công trên lưu trữ đám mây [OneDrive, Google Drive, S3] đơn giản là việc bạn tự tay lựa chọn và xóa các tệp tin hoặc thư mục sao lưu [backup] không còn cần thiết nữa.

  Khi nào cần dùng:
  * Khi bạn cần giải phóng dung lượng lưu trữ ngay lập tức. Tiết kiệm chi phí lưu trữ đám mây.
  * Dọn dẹp đột xuất ngoài lịch trình tự động.

  Lưu ý quan trọng: Việc xóa thủ công cần cẩn trọng để tránh vô tình xóa nhầm những bản sao lưu quan trọng.
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null

export box_inner_width=78

clear
echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}SAO LƯU & KHÔI PHỤC ➜ Quản lý và Xóa file Backup trên Cloud${C_RESET}"
echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

# ==============================================================================
# HÀM ĐỊNH DẠNG DUNG LƯỢNG (BYTES SANG KB/MB/GB)
# ==============================================================================
function bytesToHuman() {
  local size=$1
  if [[ -z "$size" || ! "$size" =~ ^[0-9]+$ ]]; then echo "0B"; return; fi
  if [ $size -ge 1073741824 ]; then awk "BEGIN {printf \"%.1fG\", $size/1073741824}";
  elif [ $size -ge 1048576 ]; then awk "BEGIN {printf \"%.1fM\", $size/1048576}";
  elif [ $size -ge 1024 ]; then awk "BEGIN {printf \"%.1fK\", $size/1024}";
  else echo "${size}B"; fi
}

# ==============================================================================
# KIỂM TRA RCLONE VÀ NHẬN DIỆN CLOUD
# ==============================================================================
RCLONE_CONF="/root/.config/rclone/rclone.conf"

if ! grep -q 'wptangtoc' "$RCLONE_CONF" 2>/dev/null; then
  echo -e "${C_RED}❌ Lỗi: Bạn chưa kích hoạt và kết nối Rclone trên hệ thống này!${C_RESET}"
  sleep 3
  exec /etc/wptt/wptt-backup-restore-main 1
  exit 1
fi

CLOUD_DIR="wptangtoc_ols_backup"
cloud_name="Google Drive"

if grep -E -q '^[[:space:]]*type[[:space:]]*=[[:space:]]*onedrive' "$RCLONE_CONF" 2>/dev/null; then
  cloud_name="OneDrive"
elif grep -E -q '^[[:space:]]*type[[:space:]]*=[[:space:]]*s3' "$RCLONE_CONF" 2>/dev/null; then
  cloud_name="S3 Storage"
  CLOUD_DIR="wptangtoc-ols-backup"
elif rclone lsd wptangtoc: 2>/dev/null | grep -q 'wptangtoc-ols-backup'; then
  CLOUD_DIR="wptangtoc-ols-backup"
fi

# ==============================================================================
# HÀM MENU CHỌN DOMAIN (CHỈ HIỂN THỊ DOMAIN HỢP LỆ)
# ==============================================================================
function lua_chon_NAME() {
  unset NAME selects
  selects=()

  for filepath in /etc/wptt/vhost/.*.conf; do
    [[ ! -f "$filepath" || "$filepath" == *"/..conf" ]] && continue
    local domain="${filepath##*/}"
    domain="${domain%.conf}"
    domain="${domain#.}"
    if [[ "$domain" == ?*.?* ]]; then
      selects+=("$domain")
    fi
  done

  if [[ ${#selects[@]} -eq 0 ]]; then
    echo -e "${C_YELLOW}⚠️ Không tìm thấy website nào trên hệ thống!${C_RESET}"
    sleep 3
    exec /etc/wptt/wptt-backup-restore-main 1
  fi

  mapfile -t selects < <(printf "%s\n" "${selects[@]}" | sort -uV)

  echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
  local title_text="Lựa chọn website bạn muốn dọn dẹp Backup trên Cloud:"
  local len=$(echo -n "$title_text" | awk '{print length($0)}')
  local pad_r=$((box_inner_width - len - 2))
  [[ $pad_r -lt 0 ]] && pad_r=0
  echo -e "${C_CYAN}│${C_RESET}  ${C_YELLOW}${title_text}${C_RESET}$(printf '%*s' "$pad_r" "")${C_CYAN}│${C_RESET}"

  local line_len=$((len + 3))
  local pad_line_r=$((box_inner_width - line_len))
  [[ $pad_line_r -lt 0 ]] && pad_line_r=0
  local short_line=$(printf "%${line_len}s" "" | sed 's/ /─/g')
  echo -e "${C_CYAN}├${short_line}$(printf '%*s' "$pad_line_r" "")│${C_RESET}"

  local i=1
  for domain in "${selects[@]}"; do
    local item_text=$(printf "  ${C_CYAN}%3d)${C_RESET} ${C_BOLD_WHITE}%s${C_RESET}" "$i" "$domain")
    local clean_text=$(printf "  %3d) %s" "$i" "$domain")
    local item_len=$(echo -n "$clean_text" | awk '{print length($0)}')
    local pad=$((box_inner_width - item_len))
    [[ $pad -lt 0 ]] && pad=0
    echo -e "${C_CYAN}│${C_RESET}${item_text}$(printf '%*s' "$pad" "")${C_CYAN}│${C_RESET}"
    ((i++))
  done
  echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯${C_RESET}"

  local fzf_installed=false
  if command -v fzf &>/dev/null; then
    fzf_installed=true
    PROMPT_TEXT="Nhập lựa chọn (1-${#selects[@]}) [00=Tìm nhanh] [0=Thoát]: "
  else
    PROMPT_TEXT="Nhập lựa chọn (1-${#selects[@]}) [0=Thoát]: "
  fi

  while true; do
    echo -en "${C_CYAN}${PROMPT_TEXT}${C_RESET}"
    if ! read -r REPLY; then exit 1; fi
    REPLY=$(echo "$REPLY" | tr -d ' ' | tr '[:upper:]' '[:lower:]')

    case "$REPLY" in
    0)
      echo -e "\n${C_GREEN}Đang thoát...${C_RESET}"
      NAME="0"
      return 0
      ;;
    00)
      if $fzf_installed; then
        local selected_name=$(printf '%s\n' "${selects[@]}" | nl -w 3 -s ': ' | fzf --prompt="Tìm website >> " --height=40% --border=rounded --color=border:red --cycle --reverse)
        selected_name=$(echo "$selected_name" | sed 's/^[[:space:]]*[0-9]\+\:[[:space:]]*//')
        if [[ -n "$selected_name" ]]; then
          NAME="$selected_name"
          return 0
        else echo -e "${C_YELLOW}Đã hủy chọn. Vui lòng chọn lại.${C_RESET}"; fi
      else
        echo -e "${C_RED}Lỗi: FZF chưa cài đặt.${C_RESET}"
      fi
      ;;
    *)
      if [[ "$REPLY" =~ ^[0-9]+$ ]] && [ "$REPLY" -ge 1 ] && [ "$REPLY" -le ${#selects[@]} ]; then
        local action_index=$((REPLY - 1))
        NAME="${selects[$action_index]}"
        return 0
      else
        echo -e "\n${C_RED}❌ Lựa chọn không hợp lệ! Vui lòng chọn lại.${C_RESET}"
      fi
      ;;
    esac
  done
}

lua_chon_NAME

[[ "$NAME" == "0" || -z "$NAME" ]] && {
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-backup-restore-main 1
  return 2>/dev/null || exit
}

pathcheck="/etc/wptt/vhost/.$NAME.conf"
if [[ ! -f "$pathcheck" ]]; then
  echo -e "\n${C_RED}❌ Tên miền không tồn tại trên hệ thống này!${C_RESET}"
  sleep 3
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-backup-restore-main 1
  return 2>/dev/null || exit
fi

# ==============================================================================
# VÒNG LẶP CHÍNH: HIỂN THỊ DASHBOARD VÀ XÓA FILE
# ==============================================================================
while true; do
  echo ""
  _runing "Đang truy xuất và phân tích dữ liệu từ $cloud_name..."

  # Dùng format "tps" (Time-Path-Size) để ép Rclone trả về thời gian thực tế, sau đó dùng 'sort' 
  # Mặc định sort sẽ xếp thời gian từ Cũ nhất (Xưa) -> Mới nhất (Hiện tại)
  rclone_output=$(rclone lsf "wptangtoc:$CLOUD_DIR/$NAME" --format "tps" --separator "|" 2>/dev/null | grep -E "\.zip|\.sql|\.tar|\.zst" | sort)

  if [[ -z "$rclone_output" ]]; then
    _runloi "Thư mục trống"
    echo -e "${C_YELLOW}⚠️ Không có file backup nào của website $NAME đang lưu trên $cloud_name!${C_RESET}"
    sleep 3
    exec /etc/wptt/wptt-backup-restore-main 1
    exit
  fi

  total_bytes=0
  db_files=0
  zip_files=0
  selects=()

  # Đọc từng dòng: Thời gian | Tên file | Byte
  while IFS="|" read -r ftime fname fbytes; do
    [[ -z "$fname" ]] && continue
    total_bytes=$((total_bytes + fbytes))
    fsize=$(bytesToHuman "$fbytes")
    selects+=("$fname|$fsize")
    
    if [[ "$fname" == *.sql* ]]; then ((db_files++)); fi
    if [[ "$fname" == *.zip* || "$fname" == *.tar* || "$fname" == *.zst* ]]; then ((zip_files++)); fi
  done <<< "$rclone_output"

  total_size_human=$(bytesToHuman "$total_bytes")

  _rundone "Truy xuất dữ liệu thành công từ $cloud_name"

  # ==============================================================================
  # RENDER DASHBOARD TỔNG QUAN
  # ==============================================================================
  clear
  echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_YELLOW}QUẢN LÝ DUNG LƯỢNG CLOUD ➜ ${C_BOLD_WHITE}$NAME${C_RESET}"
  echo -e "${C_CYAN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"

  colored_stat="  ${C_BOLD_WHITE}Tổng dung lượng:${C_RESET} ${C_GREEN}${total_size_human}${C_RESET}  |  ${C_BOLD_WHITE}Mã nguồn:${C_RESET} ${C_YELLOW}${zip_files} file${C_RESET}  |  ${C_BOLD_WHITE}Database:${C_RESET} ${C_YELLOW}${db_files} file${C_RESET}"
  raw_stat="  Tổng dung lượng: ${total_size_human}  |  Mã nguồn: ${zip_files} file  |  Database: ${db_files} file"
  pad_stat=$((box_inner_width - ${#raw_stat}))
  [[ $pad_stat -lt 0 ]] && pad_stat=0
  echo -e "${C_CYAN}│${C_RESET}${colored_stat}$(printf '%*s' "$pad_stat" "")${C_CYAN}│${C_RESET}"
  echo -e "${C_CYAN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"

  title_text="Chọn file cần xóa (Cũ nhất xếp trên cùng):"
  len=${#title_text}
  pad_r=$((box_inner_width - len - 2))
  [[ $pad_r -lt 0 ]] && pad_r=0
  echo -e "${C_CYAN}│${C_RESET}  ${C_YELLOW}${title_text}${C_RESET}$(printf '%*s' "$pad_r" "")${C_CYAN}│${C_RESET}"
  echo -e "${C_CYAN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"

  # IN DANH SÁCH FILE VỚI KÍCH THƯỚC ĐÍNH KÈM
  i=1
  for item in "${selects[@]}"; do
    f_name="${item%|*}"
    f_size="${item#*|}"

    clean_row=$(printf "  %3d) [%-7s] %s" "$i" "$f_size" "$f_name")
    item_row=$(printf "  ${C_CYAN}%3d)${C_RESET} [${C_GREEN}%-7s${C_RESET}] ${C_BOLD_WHITE}%s${C_RESET}" "$i" "$f_size" "$f_name")
    pad=$((box_inner_width - ${#clean_row}))
    [[ $pad -lt 0 ]] && pad=0

    echo -e "${C_CYAN}│${C_RESET}${item_row}$(printf '%*s' "$pad" "")${C_CYAN}│${C_RESET}"
    ((i++))
  done

  # TUỲ CHỌN XÓA TẤT CẢ (999)
  echo -e "${C_CYAN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
  clean_row_999="  999) [XÓA HẾT] Dọn dẹp sạch sẽ toàn bộ thư mục Backup này trên Cloud"
  item_row_999="  ${C_RED}999)${C_RESET} [${C_RED}XÓA HẾT${C_RESET}] Dọn dẹp sạch sẽ toàn bộ thư mục Backup này trên Cloud"
  pad_999=$((box_inner_width - ${#clean_row_999}))
  [[ $pad_999 -lt 0 ]] && pad_999=0
  echo -e "${C_CYAN}│${C_RESET}${item_row_999}$(printf '%*s' "$pad_999" "")${C_CYAN}│${C_RESET}"
  echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯${C_RESET}"

  # LỰA CHỌN FILE
  echo -en "${C_CYAN}Nhập số thứ tự file cần xóa (1-${#selects[@]}) [999=Xóa Tất Cả] [0=Thoát]: ${C_RESET}"
  read -r REPLY

  [[ "$REPLY" == "0" || -z "$REPLY" ]] && break

  # XỬ LÝ: XÓA TẤT CẢ (Lệnh 999)
  if [[ "$REPLY" == "999" ]]; then
    echo ""
    if wptt_xac_nhan "Xác nhận xóa TẤT CẢ bản sao lưu của $NAME trên Cloud!" "Hành động này không thể hoàn tác. Toàn bộ ($total_size_human) sẽ bị xóa sạch khỏi $cloud_name." "" "Đồng ý XÓA SẠCH" "Hủy thao tác"; then
      _runing "Đang xóa toàn bộ dữ liệu Backup trên Cloud..."
      
      rclone -v delete "wptangtoc:$CLOUD_DIR/$NAME" >/dev/null 2>&1
      echo "Xóa TẤT CẢ file backup website $NAME trên Cloud: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log
      
      _rundone "Đã dọn dẹp sạch sẽ toàn bộ thư mục Cloud ($total_size_human)!"
      sleep 2
      break
    else
      echo -e "${C_YELLOW}Đã hủy thao tác xóa tất cả.${C_RESET}"
      sleep 1
    fi

  # XỬ LÝ: XÓA TỪNG FILE (Lệnh 1 đến N)
  elif [[ "$REPLY" =~ ^[0-9]+$ ]] && [ "$REPLY" -ge 1 ] && [ "$REPLY" -le ${#selects[@]} ]; then
    idx=$((REPLY - 1))
    val="${selects[$idx]}"
    target_file="${val%|*}"
    target_size="${val#*|}"

    echo ""
    if wptt_xac_nhan "Bạn có chắc chắn muốn XÓA VĨNH VIỄN file backup này trên Cloud?" "File: $target_file" "Giải phóng: $target_size" "Đồng ý XÓA" "Hủy bỏ"; then
      _runing "Đang tiến hành xóa file khỏi $cloud_name..."
      
      rclone -v delete "wptangtoc:$CLOUD_DIR/$NAME/$target_file" >/dev/null 2>&1
      echo "Xóa file backup trên $cloud_name $target_file của website $NAME: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log
      
      _rundone "Đã xóa thành công file: $target_file ($target_size)"
      sleep 1.5
    else
      echo -e "${C_YELLOW}Đã hủy thao tác xóa file.${C_RESET}"
      sleep 1
    fi
  else
    echo -e "${C_RED}❌ Lựa chọn không hợp lệ! Vui lòng chọn lại.${C_RESET}"
    sleep 1
  fi
done

[[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-backup-restore-main 1
