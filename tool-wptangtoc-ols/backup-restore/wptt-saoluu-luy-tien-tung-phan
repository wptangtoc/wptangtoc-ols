#!/bin/bash
# @author: Gia Tuấn
# @website: https://wptangtoc.com
# @description: Sao lưu lũy tiến từng phần (Tiết kiệm 80% ổ cứng) - Tối ưu UX/Hiệu năng
# @since: 2026

function huong_dan() {
  Tính năng sao lưu website [website backup] là quá trình tạo ra các bản sao của toàn bộ dữ liệu website của bạn và lưu trữ chúng ở một nơi an toàn.

  Sao lưu luỹ tiến từng phần là kỹ thuật backup mục đích chính của nó là giảm chi phí lưu trữ giảm dung lượng ổ cứng.

  Nguyên lý hoạt động bình thường: giả sử mã nguồn của bạn 1GB khi nén thành 1 file zip để backup bạn sẽ tạo ra được 1 file zip nặng 1GB
  Nếu bạn backup liên tục trong 30 ngày thì suy ra bạn phải tốn 30GB dung lượng ổ cứng
  
  Còn với kỹ thuật backup luỹ tiến từng phần: nó sẽ backup full 1 bản riêng phần ảnh [ví dụ nặng 900MB] là 1 file zip riêng loại trừ thư mục uploads hiện hữu.
  Và sau đó nó sẽ sao lưu phần 2: sao lưu mã nguồn và loại bỏ toàn bộ file backup ảnh ở phần full ảnh trên chỉ lưu thêm thư mục ảnh hiện hữu: wp-content/uploads/2025/05 thì chỉ tốn 100MB
  
  Thay vì phải tốn 30GB backup thì nhờ kỹ thuật này bạn chỉ tốn 3.9GB tiết kiệm được: 30-3.9 = 26.1GB giảm được 87% dung lượng.
  Kỹ thuật này rất hữu ích với mã nguồn có dung lượng lớn.
}

. /etc/wptt/.wptt.conf
if [[ $ngon_ngu = '' ]]; then
  ngon_ngu='vi'
fi
. /etc/wptt/lang/$ngon_ngu.sh
. /etc/wptt/echo-color

echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_BOLD_WHITE}$backup_restore ➜ $sao_luu_website (Lũy Tiến)${C_RESET}"
echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯${C_RESET}\n"

NAME=$1
ggdriver=$2
ggdriver2=$3

if [[ $NAME = "98" ]]; then
  NAME=""
fi

. /etc/wptt/core-functions
if [[ "$1" == '98' ]]; then
  WPTT_IN_MENU="yes"
  WPTT_MENU_BACK="/etc/wptt/wptt-backup-restore-main 1"
fi

wptt_check_mariadb || wptt_die "MariaDB đang bị sập! Hệ thống từ chối không cho phép sao lưu website."

if [[ "$NAME" = "" ]]; then
  . /etc/wptt/tenmien-them-lua-chon-tat-ca-website-by-wordpress
  lua_chon_NAME "$sao_luu_website luỹ tiến"

  if [[ "$NAME" = "0" || "$NAME" = "" ]]; then
    exec /etc/wptt/wptt-backup-restore-main 1
  fi
fi

if [[ $2 = '12345' ]] || [[ $2 = '1998' ]];then
  ep_luong_cpu_disk_thu_tu_yeu_tien_thap_dang_chay_auto_backup="ionice -c 3 nice -n 19"
else
  ep_luong_cpu_disk_thu_tu_yeu_tien_thap_dang_chay_auto_backup=""
fi

date_nam=$(date +"%Y")
if [[ $NAME = 'Tất cả website' ]]; then
  if [[ -z $3 ]]; then #doi số 3 không có giá trị auto mới hỏi
    unset ggdriver ggdriver2 checkdathietlap
    checkdathietlap=$(grep -q '\[wptangtoc\]' ~/.config/rclone/rclone.conf 2>/dev/null && echo 1)
    if [[ $checkdathietlap ]]; then
      # Nhận diện thông minh loại Cloud
      if grep -E -q '^[[:space:]]*type[[:space:]]*=[[:space:]]*onedrive' ~/.config/rclone/rclone.conf 2>/dev/null; then
        drive_name="OneDrive"
      elif grep -E -q '^[[:space:]]*type[[:space:]]*=[[:space:]]*s3' ~/.config/rclone/rclone.conf 2>/dev/null; then
        drive_name="S3 Storage"
      else
        drive_name="Google Drive"
      fi

      echo "$ban_co_muon file backup uploads $drive_name?"

      prompt="$nhap_lua_chon_cua_ban [1-2]: "
      ggdriver="n"
      options=("$dong_y" "$khong_dong_y")
      PS3="$prompt"
      select opt in "${options[@]}"; do
        case "$REPLY" in
        1)
          ggdriver="1998"
          break
          ;;
        2)
          ggdriver="n"
          break
          ;;
        $((${#options[@]} + 1)))
          printf "\n$ban_nhap_sai_he_thong_se_chon_khong_dong_y\n"
          break
          ;;
        *)
          printf "$ban_nhap_sai_he_thong_se_chon_khong_dong_y\n"
          break
          ;;
        esac
      done
      if [[ "$ggdriver" = "1998" ]]; then
        kiem_tra_xem_cloud_drive_co_hoat_dong_khong=$(rclone about wptangtoc: 2>/dev/null | grep 'Free:')
        if [[ $kiem_tra_xem_cloud_drive_co_hoat_dong_khong ]]; then
          echo "$ban_co_muon $xoa file backup tại local khi đã được lưu trữ đám mây $drive_name không?"
          prompt="$nhap_lua_chon_cua_ban [1-2]: "
          ggdriver2="12345"
          options=("$dong_y" "$khong_dong_y")
          PS3="$prompt"
          select opt in "${options[@]}"; do
            case "$REPLY" in
            1)
              ggdriver2="1998"
              break
              ;;
            2)
              ggdriver2="12345"
              break
              ;;
            $((${#options[@]} + 1)))
              printf "\n$ban_nhap_sai_he_thong_se_chon_khong_dong_y\n"
              break
              ;;
            *)
              printf "$ban_nhap_sai_he_thong_se_chon_khong_dong_y\n"
              break
              ;;
            esac
          done
        fi
      fi
    fi
  fi

  START_TIMESTAMP_FILE=$(mktemp) #khởi tạo file temp để xác định bắt đầu thực thi all

  before_optimize_full_all=$(du -hs /usr/local/backup-website)
  if [ "$(ls -A /etc/wptt/vhost | grep -v '^\.\.conf$' | sort -uV)" ]; then
    for entry in $(ls -A /etc/wptt/vhost | grep -v '^\.\.conf$' | sort -uV); do
      domain=$(echo $entry | sed 's/^.//' | sed 's/.conf//')
      path_html="/usr/local/lsws/$domain/html/wp-load.php"
      path_uploads_dir_nam="/usr/local/lsws/$domain/html/wp-content/uploads/$date_nam"
      i=1
      if [[ -f "$path_html" && -d $path_uploads_dir_nam ]]; then
        . /etc/wptt/backup-restore/wptt-saoluu-luy-tien-tung-phan $domain $ggdriver $ggdriver2
      fi
    done
  fi

  check_menu_wptangtoc_active=$1
  if [[ $check_menu_wptangtoc_active = "98" ]]; then
    END_TIMESTAMP_FILE=$(mktemp) #kết thúc file temp
    clear
    echo "==================================================================="
    echo "Hoàn tất backup $sao_luu_tat_ca_website (Lũy Tiến)"
    echo "==================================================================="
    for entry in $(ls -A /etc/wptt/vhost | grep -v '^\.\.conf$' | sort -uV); do
      domain=$(echo $entry | sed 's/^.//' | sed 's/.conf//')
      path="/usr/local/lsws/$domain/html"
      i=1

      if [[ -d "$path" ]]; then
        if [[ $ggdriver2 != '1998' ]]; then
          if [[ $(find "/usr/local/backup-website/$domain" -type f -newer "$START_TIMESTAMP_FILE" ! -newer "$END_TIMESTAMP_FILE" -ls) ]]; then
            echo "Hoàn tất backup website: $domain"
          fi
        else
          echo "Hoàn tất backup website: $domain"
        fi
      fi
    done
    if [[ $ggdriver2 != '1998' ]]; then
      echo "==================================================================="
      echo "Dung lượng thư mục trước khi sao lưu  : $before_optimize_full_all"
      echo "Dung lượng thư mục sau khi sao lưu    : $(du -hs /usr/local/backup-website)"
      echo "==================================================================="
    fi
    rm "$END_TIMESTAMP_FILE"
    exec /etc/wptt/wptt-backup-restore-main 1
  fi
  rm -f "$START_TIMESTAMP_FILE"
fi

pathcheckwp="/usr/local/lsws/$NAME/html/wp-load.php"
if [[ ! -f "$pathcheckwp" ]]; then
  clear
  echoDo "Hệ thống xác nhận bạn không sử dụng WordPress"
  echoDo "Tính năng này chỉ có thể hoạt động trên mã nguồn WordPress"
  sleep 3
  exec /etc/wptt/wptt-backup-restore-main 1
  exit
fi

. /etc/wptt/php/php-cli-domain-config $NAME

if [[ $(/usr/local/lsws/lsphp${phien_ban_php_domain_thuc_thi}/bin/php /usr/local/bin/wp option get uploads_use_yearmonth_folders --allow-root --path=/usr/local/lsws/$NAME/html 2>/dev/null) = '' ]]; then
  echoDo "Hệ thống xác nhận bạn sử dụng WordPress nhưng không để chế độ uploads_use_yearmonth_folders"
  echo "Để dùng tính năng này, hãy vào WP-Admin => Settings => Media => Bật Organize my uploads into month- and year-based folders"
  sleep 3
  exec /etc/wptt/wptt-backup-restore-main 1
  exit
fi

pathcheck="/usr/local/backup-website/$NAME"
before_optimize=$(du -hs $pathcheck | sed 's/\t//g' | cut -f1 -d '/')
times=$(date +%Hgio\_%d\_%m\_%Y)
. /etc/wptt/.wptt.conf
. /etc/wptt/vhost/."$NAME".conf
cd /usr/local/lsws/"$NAME"/html || exit 1

echo "Sao lưu website $NAME luỹ tiến: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log

_runing "$sao_luu_database website $NAME"

TEMP_CNF=$(mktemp)
chmod 600 "$TEMP_CNF" # Chỉ root mới đọc được
cat >"$TEMP_CNF" <<EOF
[client]
user=${DB_User_web}
password=${DB_Password_web}
host=localhost
max_allowed_packet=1G
default-character-set=utf8mb4

[mysqldump]
quick
quote-names
max_allowed_packet=1G
single-transaction
EOF

RAW_SIZE=$(mariadb --defaults-extra-file="$TEMP_CNF" -N -e "SELECT SUM(data_length) FROM information_schema.TABLES WHERE table_schema='$DB_Name_web'")
if [[ -z "$RAW_SIZE" || "$RAW_SIZE" == "NULL" ]]; then RAW_SIZE=1024; fi
ADJUSTED_SIZE=$((RAW_SIZE * 95 / 100))

if command -v pv &>/dev/null; then
  PV_CMD="pv -s $ADJUSTED_SIZE -N 'Exporting' -p -t -e -w 80"
else
  PV_CMD="cat"
fi

echo ""
if [[ $sql_gz = '1' ]]; then
  $ep_luong_cpu_disk_thu_tu_yeu_tien_thap_dang_chay_auto_backup mariadb-dump --defaults-extra-file="$TEMP_CNF" "$DB_Name_web" --ssl-verify-server-cert=false | bash -c "$PV_CMD" | $ep_luong_cpu_disk_thu_tu_yeu_tien_thap_dang_chay_auto_backup gzip >"/usr/local/backup-website/$NAME/$NAME$times.sql.gz"
elif [[ $sql_gz = '2' ]]; then
  $ep_luong_cpu_disk_thu_tu_yeu_tien_thap_dang_chay_auto_backup mariadb-dump --defaults-extra-file="$TEMP_CNF" "$DB_Name_web" --ssl-verify-server-cert=false | bash -c "$PV_CMD" | $ep_luong_cpu_disk_thu_tu_yeu_tien_thap_dang_chay_auto_backup zstd >"/usr/local/backup-website/$NAME/$NAME$times.sql.zst"
else
  $ep_luong_cpu_disk_thu_tu_yeu_tien_thap_dang_chay_auto_backup mariadb-dump --defaults-extra-file="$TEMP_CNF" "$DB_Name_web" --ssl-verify-server-cert=false | $ep_luong_cpu_disk_thu_tu_yeu_tien_thap_dang_chay_auto_backup bash -c "$PV_CMD" >"/usr/local/backup-website/$NAME/$NAME$times.sql"
fi

echo -ne "\033[1A\r\033[K"
echo -ne "\033[1A\r\033[K"
rm -rf $TEMP_CNF

unset check_file_error_database
if [[ $sql_gz = '1' ]]; then
  check_file_error_database=$(du -c /usr/local/backup-website/$NAME/$NAME$times.sql.gz | awk '{print $1}' | sed '1d')
  if ((${check_file_error_database:-0} < 3)); then
    tuanxacnhandb="0"
    _runloi "$sao_luu_database website $NAME"
    rm -f /usr/local/backup-website/$NAME/$NAME$times.sql.gz
  fi
elif [[ $sql_gz = '2' ]]; then
  check_file_error_database=$(du -c /usr/local/backup-website/$NAME/$NAME$times.sql.zst | awk '{print $1}' | sed '1d')
  if ((${check_file_error_database:-0} < 3)); then
    tuanxacnhandb="0"
    _runloi "$sao_luu_database website $NAME"
    rm -f /usr/local/backup-website/$NAME/$NAME$times.sql.zst
  fi
else
  check_file_error_database=$(du -c /usr/local/backup-website/$NAME/$NAME$times.sql | awk '{print $1}' | sed '1d')
  if ((${check_file_error_database:-0} < 3)); then
    tuanxacnhandb="0"
    _runloi "$sao_luu_database website $NAME"
    rm -f /usr/local/backup-website/$NAME/$NAME$times.sql
  fi
fi

if [[ -f /usr/local/backup-website/$NAME/$NAME$times.sql || -f /usr/local/backup-website/$NAME/$NAME$times.sql.gz || -f /usr/local/backup-website/$NAME/$NAME$times.sql.zst ]]; then
  _rundone "$sao_luu_database website $NAME"
  tuanxacnhandb="1"
else
  _runloi "$sao_luu_database website $NAME"
fi

_runing "$sao_luu_ma_nguon website $NAME"
echo ''
cd /usr/local/lsws/"$NAME"/html && $ep_luong_cpu_disk_thu_tu_yeu_tien_thap_dang_chay_auto_backup zip -r /usr/local/backup-website/$NAME/$NAME$times-wptt-luy-tien-tung-phan-core.zip * -x "wp-content/uploads/*" -x "wp-content/ai1wm-backups/*" -x "wp-content/cache/*" -x "wp-content/updraft/*" -x "wp-content/ai1wm-backups/*" -x "error_log" -x "wp-content/debug.log" -x "wp-content/uploads/backupbuddy_backups/*" -x "wp-content/backups-dup-pro/*" -x "wp-content/backups-dup-lite/*" #luy tuyen core

unset tuanxacnhan tao_file_dir_uploads_full
if [[ -f /usr/local/backup-website/$NAME/$NAME$times-wptt-luy-tien-tung-phan-core.zip ]]; then
  _rundone "$sao_luu_ma_nguon website $NAME"
  tuanxacnhan="1"
else
  _runloi "$sao_luu_ma_nguon website $NAME"
fi

date_thang_nam=$(date +"%m_%Y")
date_thang=$(date +"%m")
date_nam=$(date +"%Y")
if [[ ! -f /usr/local/backup-website/$NAME/$NAME-${date_thang_nam}-wptt-luy-tien-wp-uploads-dir.zip ]]; then #một tháng chỉ 1 lần thôi uploads full dir
  tao_file_dir_uploads_full=1
  cd /usr/local/lsws/"$NAME"/html && $ep_luong_cpu_disk_thu_tu_yeu_tien_thap_dang_chay_auto_backup zip -r /usr/local/backup-website/$NAME/$NAME-${date_thang_nam}-wptt-luy-tien-wp-uploads-dir.zip wp-content/uploads/*
fi

if [[ -d /usr/local/lsws/$NAME/html/wp-content/uploads/$date_nam/$date_thang && $(ls -At /usr/local/lsws/$NAME/html/wp-content/uploads/$date_nam/$date_thang) ]]; then
  cd /usr/local/lsws/"$NAME"/html && $ep_luong_cpu_disk_thu_tu_yeu_tien_thap_dang_chay_auto_backup zip -r /usr/local/backup-website/$NAME/$NAME-${times}-wptt-luy-tien-uploads-thang-hien-huu.zip wp-content/uploads/$date_nam/$date_thang/*
fi

# Merge file zip: mã nguồn và thư mục uploads luỹ tiến
if [[ -d /usr/local/lsws/$NAME/html/wp-content/uploads/$date_nam/$date_thang && $(ls -At /usr/local/lsws/$NAME/html/wp-content/uploads/$date_nam/$date_thang) ]]; then
  temp_dir_backup=$(mktemp -d)
  unzip -oq /usr/local/backup-website/$NAME/$NAME$times-wptt-luy-tien-tung-phan-core.zip -d $temp_dir_backup
  unzip -oq /usr/local/backup-website/$NAME/$NAME-${times}-wptt-luy-tien-uploads-thang-hien-huu.zip -d $temp_dir_backup
  cd $temp_dir_backup && $ep_luong_cpu_disk_thu_tu_yeu_tien_thap_dang_chay_auto_backup zip -r /usr/local/backup-website/$NAME/$NAME$times-wptt-luy-tien-tung-phan-core.zip *
  cd
  rm -rf $temp_dir_backup
  rm -f /usr/local/backup-website/$NAME/$NAME-${times}-wptt-luy-tien-uploads-thang-hien-huu.zip
fi

checkdathietlap=$(grep -q '\[wptangtoc\]' ~/.config/rclone/rclone.conf 2>/dev/null && echo 1)
if [[ $checkdathietlap ]]; then
  if [[ "$ggdriver" != "1998" ]]; then
    if grep -E -q '^[[:space:]]*type[[:space:]]*=[[:space:]]*onedrive' ~/.config/rclone/rclone.conf 2>/dev/null; then
      drive_name='OneDrive'
    elif grep -E -q '^[[:space:]]*type[[:space:]]*=[[:space:]]*s3' ~/.config/rclone/rclone.conf 2>/dev/null; then
      drive_name='S3 Storage'
    else
      drive_name='Google Drive'
    fi
    echo "$ban_co_muon file backup uploads ${drive_name}?"

    prompt="$nhap_lua_chon_cua_ban [1-2]: "
    uploads="n"
    options=("$dong_y" "$khong_dong_y")
    PS3="$prompt"
    select opt in "${options[@]}"; do
      case "$REPLY" in
      1) uploads="y"; break ;;
      2) uploads="n"; break ;;
      *) printf "\n$ban_nhap_sai_he_thong_se_chon_khong_dong_y\n"; break ;;
      esac
    done
  fi
  
  if [[ "$uploads" = "y" || "$ggdriver" = "1998" ]]; then

    _runing "File backup uploads $drive_name"

    # Xử lý Bucket Name S3
    CLOUD_DIR="wptangtoc_ols_backup"
    if grep -E -q '^[[:space:]]*type[[:space:]]*=[[:space:]]*s3' /root/.config/rclone/rclone.conf 2>/dev/null; then
      CLOUD_DIR="wptangtoc-ols-backup"
    elif rclone lsd wptangtoc: 2>/dev/null | grep -q 'wptangtoc-ols-backup'; then
      CLOUD_DIR="wptangtoc-ols-backup"
    fi

    # -------------------------------------------------------------
    # BỘ ĐIỀU TỐC THÔNG MINH CHO RCLONE (DYNAMIC PERFORMANCE ENGINE)
    # -------------------------------------------------------------
    TOTAL_CORES=$(nproc 2>/dev/null || echo 1)
    TOTAL_RAM_MB=$(free -m | awk '/^Mem:/{print $2}')

    if (( TOTAL_CORES <= 2 )) || (( TOTAL_RAM_MB <= 2048 )); then
      OPT_TRANSFERS=2
      OPT_CHUNK="32M"
    else
      OPT_TRANSFERS=4
      OPT_CHUNK="64M"
    fi

    if [[ "$ggdriver" == "1998" ]]; then
      OPT_BWLIMIT="--bwlimit 07:00,10M 23:00,off"
      if (( TOTAL_CORES == 1 )); then OPT_TRANSFERS=1; fi
    else
      OPT_BWLIMIT=""
    fi

    RCLONE_OPTS="--transfers=$OPT_TRANSFERS --checkers=$OPT_TRANSFERS --drive-chunk-size=$OPT_CHUNK --s3-upload-concurrency=$OPT_TRANSFERS $OPT_BWLIMIT --log-level ERROR"

    # =============================================================
    # HÀM UPLOAD GIAO DIỆN CHUẨN UX (KẾT HỢP PV + RCAT + AUTO CLEAN)
    # =============================================================
    function wptt_upload_luy_tien_ux() {
      local src_file="$1"
      local dest_dir="$2"
      local file_type="$3"
      local fname=$(basename "$src_file")

      if [[ "$ggdriver" == "1998" ]]; then
        $ep_luong_cpu_disk_thu_tu_yeu_tien_thap_dang_chay_auto_backup rclone copy "$src_file" "$dest_dir" $RCLONE_OPTS --quiet
      else
        if command -v pv &>/dev/null; then
          local fsize=$(du -b "$src_file" | cut -f1)
          pv -s "$fsize" -N "Upload $file_type" -p -t -e -r -b -w 90 "$src_file" | rclone rcat "$dest_dir/$fname" $RCLONE_OPTS
          echo -en "\033[1A\033[2K\r"
        else
          rclone copy "$src_file" "$dest_dir" $RCLONE_OPTS --progress --stats-one-line
          echo -en "\033[1A\033[2K\r"
        fi
      fi
    }

    echo "" # Tạo một dòng trống cho giao diện thoáng đãng

    # 1. Đẩy Mã nguồn cốt lõi (Core)
    wptt_upload_luy_tien_ux "/usr/local/backup-website/$NAME/$NAME$times-wptt-luy-tien-tung-phan-core.zip" "wptangtoc:$CLOUD_DIR/$NAME" "Lõi Mã Nguồn"

    # 2. Đẩy Thư mục Ảnh (Nếu có tạo file full mới tháng này)
    if [[ $tao_file_dir_uploads_full = '1' ]]; then
      wptt_upload_luy_tien_ux "/usr/local/backup-website/$NAME/$NAME-${date_thang_nam}-wptt-luy-tien-wp-uploads-dir.zip" "wptangtoc:$CLOUD_DIR/$NAME" "Thư Mục Ảnh"
    fi

    # 3. Đẩy Database
    if [[ $sql_gz = '1' ]]; then
      wptt_upload_luy_tien_ux "/usr/local/backup-website/"$NAME"/$NAME$times.sql.gz" "wptangtoc:$CLOUD_DIR/$NAME" "Database"
    elif [[ $sql_gz = '2' ]]; then
      wptt_upload_luy_tien_ux "/usr/local/backup-website/"$NAME"/$NAME$times.sql.zst" "wptangtoc:$CLOUD_DIR/$NAME" "Database"
    else
      wptt_upload_luy_tien_ux "/usr/local/backup-website/"$NAME"/$NAME$times.sql" "wptangtoc:$CLOUD_DIR/$NAME" "Database"
    fi

    kiem_tra_xem_file_da_uploads=$(rclone lsf wptangtoc:$CLOUD_DIR/$NAME 2>/dev/null | grep "$NAME$times")
    if [[ $kiem_tra_xem_file_da_uploads ]]; then
      _rundone "File backup uploads $drive_name"
    else
      _runloi "File backup uploads $drive_name"
    fi

    if ! [[ "$ggdriver2" = "1998" || "$ggdriver2" = "12345" ]]; then
      if [[ $kiem_tra_xem_file_da_uploads ]]; then
        echo "$ban_co_muon $xoa file backup tại local khi đã được lưu trữ đám mây $drive_name không?"
        prompt="$nhap_lua_chon_cua_ban [1-2]: "
        clearfile="n"
        options=("$dong_y" "$khong_dong_y")
        PS3="$prompt"
        select opt in "${options[@]}"; do
          case "$REPLY" in
          1) clearfile="y"; break ;;
          2) clearfile="n"; break ;;
          *) printf "\n$ban_nhap_sai_he_thong_se_chon_khong_dong_y\n"; break ;;
          esac
        done
      fi
    fi

    if [[ "$clearfile" = "y" || "$ggdriver2" = "1998" ]]; then
      _runing "$xoa file backup tại local"
      $ep_luong_cpu_disk_thu_tu_yeu_tien_thap_dang_chay_auto_backup rm -f /usr/local/backup-website/$NAME/$NAME$times-wptt-luy-tien-tung-phan-core.zip
      if [[ $tao_file_dir_uploads_full = '1' ]]; then
        $ep_luong_cpu_disk_thu_tu_yeu_tien_thap_dang_chay_auto_backup rm -f /usr/local/backup-website/$NAME/$NAME-${date_thang_nam}-wptt-luy-tien-wp-uploads-dir.zip
      fi

      if [[ $sql_gz = '1' ]]; then
        $ep_luong_cpu_disk_thu_tu_yeu_tien_thap_dang_chay_auto_backup rm -f /usr/local/backup-website/"$NAME"/$NAME$times.sql.gz
      elif [[ $sql_gz = '2' ]]; then
        $ep_luong_cpu_disk_thu_tu_yeu_tien_thap_dang_chay_auto_backup rm -f /usr/local/backup-website/"$NAME"/$NAME$times.sql.zst
      else
        $ep_luong_cpu_disk_thu_tu_yeu_tien_thap_dang_chay_auto_backup rm -f /usr/local/backup-website/"$NAME"/$NAME$times.sql
      fi
      _rundone "$xoa file backup tại local"
    fi

  fi
fi

clear
if [[ "$tuanxacnhandb" = "1" && "$tuanxacnhan" = "1" ]]; then
  echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "$sao_luu_website $NAME thành công"
  echo -e "${C_CYAN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
  if ! [[ "$clearfile" = "y" || "$ggdriver2" = "1998" ]]; then 
    left_text "Thư mục backup  : /usr/local/backup-website/$NAME"
    left_text "Thư mục website : /usr/local/lsws/$NAME/html"
    left_text "Disk : $(df -BG | awk '$NF=="/"{printf "%d/%dGB (%s)\n", $3,$2,$5}')                        "
    echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯${C_RESET}"

    echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
    left_text "Dung lượng thư mục backup trước khi backup          : $before_optimize"
    left_text "Dung lượng thư mục backup sau khi backup            : $(du -hs $pathcheck | sed 's/\t//g' | cut -f1 -d '/')"
    echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯${C_RESET}\n"
  else
    echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯${C_RESET}\n"
  fi
else
  RED='\033[0;33m'
  NC='\033[0m'
  echo -e "${RED}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
  left_text "$sao_luu_website $NAME $khong_thanh_cong"
  echo -e "${RED}╰──────────────────────────────────────────────────────────────────────────────╯${C_RESET}\n"
fi

disk=$(df -BG | awk '$NF=="/"{printf "%d/%d\n", $3,$2,$5}')
disk_dang_dung=$(echo $disk | cut -f1 -d '/')
disk_tong=$(echo $disk | cut -f2 -d '/' | cut -f1 -d ' ')
disk_kha_dung=$(expr $disk_tong - $disk_dang_dung)

het_disk="2"
if [[ $disk_kha_dung =~ ^-?[0-9]+$ ]]; then
  if (("$disk_kha_dung" < "$het_disk")); then
    RED='\033[0;33m'
    NC='\033[0m'
    echo -e "${RED}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
    left_text "$canh_bao_fulldisk"
    left_text "Disk: $(df -BG | awk '$NF=="/"{printf "%d/%dGB (%s)\n", $3,$2,$5}')"
    left_text "$de_kiem_tra_dung_luong_o_cung_dang_su_dung: wptt disk"
    echo -e "${RED}╰──────────────────────────────────────────────────────────────────────────────╯${C_RESET}\n"
  fi
fi

if [[ "$uploads" = "y" ]]; then
  echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
  left_text "Dung lượng $drive_name của bạn trước khi sao lưu: $truoc_khi_backup"
  left_text "Dung lượng $drive_name của bạn sau khi sao lưu: $(rclone size wptangtoc: 2>/dev/null --exclude "Personal Vault/**" --exclude "Kho lưu trữ cá nhân/**"| grep 'size' | cut -f2 -d ':' | cut -f1 -d '(' | head -1)"
  echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯${C_RESET}\n"
fi

check_menu_wptangtoc_active=$1
