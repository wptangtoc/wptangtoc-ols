#!/bin/bash
# @author: Gia Tuấn
# @website: https://wptangtoc.com
# @email: giatuan@wptangtoc.com
# @since: 2026

function huong_dan() {
  WPTangToc OLS nay cho phép bạn lựa chọn giữa 3 định dạng nén mã nguồn khi sao lưu, giúp tối ưu hóa giữa hiệu suất, tính toàn vẹn và sự tiện lợi.

  1. ZIP [.zip]: Lựa chọn Tương Thích Tối Đa
  File .zip có thể mở được trên mọi máy tính [Windows, macOS] mà không cần cài đặt thêm phần mềm.
  Khuyên dùng: Khi mục đích chính là tải file backup về máy tính cá nhân [đặc biệt là Windows] hoặc chia sẻ cho người dùng không chuyên.

  2. ZSTD [.tar.zst]: Lựa chọn Hiệu Suất Tối Đa
  Nén và giải nén cực nhanh, tốn ít CPU và thường tạo ra file backup có dung lượng nhỏ nhất.
  Khuyên dùng: Cho các tác vụ tự động trên máy chủ khi tốc độ là ưu tiên tuyệt đối, giúp giảm tải cho server và tiết kiệm thời gian.

  3. TAR.GZ [.tar.gz]: Lựa chọn Tiêu Chuẩn Vàng
  Cân bằng giữa tỉ lệ nén tốt và tính tương thích cao trên mọi môi trường máy chủ [Linux, macOS].
  Khuyên dùng: Làm định dạng mặc định cho hầu hết nhu cầu sao lưu. Đảm bảo tính toàn vẹn và dễ dàng phục hồi website nhất.

  Mặc định thiết lập là: .zip
}

. /etc/wptt/.wptt.conf 2>/dev/null
if [[ -z "$ngon_ngu" ]]; then ngon_ngu='vi'; fi
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null

clear
echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}Quản lý Backup ➜ Thiết lập định dạng nén Mã Nguồn${C_RESET}"
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯${C_RESET}\n"

# ==============================================================================
# ĐỌC TRẠNG THÁI HIỆN TẠI
# ==============================================================================
current_format=".zip"
if [[ "$dinh_dang_nen_ma_nguon" == "1" ]]; then
  current_format=".tar.zst"
elif [[ "$dinh_dang_nen_ma_nguon" == "2" ]]; then
  current_format=".tar.gz"
fi

# ==============================================================================
# RENDER BOX CHỌN ĐỊNH DẠNG (UX TAB GẠCH CHÂN)
# ==============================================================================
box_inner_width=${box_inner_width:-71}
echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"

# Tiêu đề
title_text="Chọn định dạng nén mã nguồn (Hiện tại: $current_format):"
clean_title=$(echo -e "$title_text" | sed "s/\x1B\[[0-9;]*[a-zA-Z]//g")
len=${#clean_title}
pad_r=$((box_inner_width - len - 2))
[[ $pad_r -lt 0 ]] && pad_r=0

echo -e "${C_CYAN}│${C_RESET}  ${C_YELLOW}${title_text}${C_RESET}$(printf '%*s' "$pad_r" "")${C_CYAN}│${C_RESET}"

# Vạch gạch chân (sed chống lỗi UTF-8)
line_len=$((len + 3))
pad_line_r=$((box_inner_width - line_len))
[[ $pad_line_r -lt 0 ]] && pad_line_r=0
short_line=$(printf "%${line_len}s" "" | sed 's/ /─/g')
echo -e "${C_CYAN}├${short_line}$(printf '%*s' "$pad_line_r" "")│${C_RESET}"

# Danh sách các lựa chọn có mô tả chi tiết
options=(
  ".zip      (Tương thích tối đa với Windows/macOS - Mặc định)"
  ".tar.zst  (Siêu tốc độ, nén cực nhỏ, tiết kiệm CPU - Khuyên dùng)"
  ".tar.gz   (Tiêu chuẩn vàng, nén tốt, an toàn trên Linux)"
)

for i in "${!options[@]}"; do
  num=$((i + 1))
  text="${options[$i]}"

  # Highlight lựa chọn đang Active
  if [[ ($num == 1 && -z "$dinh_dang_nen_ma_nguon") || ($num == 2 && "$dinh_dang_nen_ma_nguon" == "1") || ($num == 3 && "$dinh_dang_nen_ma_nguon" == "2") ]]; then
    item_text=$(printf "  ${C_CYAN}%d)${C_RESET} ${C_GREEN}%s [ĐANG CHỌN]${C_RESET}" "$num" "$text")
    clean_text=$(printf "  %d) %s [ĐANG CHỌN]" "$num" "$text")
  else
    item_text=$(printf "  ${C_CYAN}%d)${C_RESET} ${C_BOLD_WHITE}%s${C_RESET}" "$num" "$text")
    clean_text=$(printf "  %d) %s" "$num" "$text")
  fi

  len_text=${#clean_text}
  pad=$((box_inner_width - len_text))
  [[ $pad -lt 0 ]] && pad=0

  echo -e "${C_CYAN}│${C_RESET}${item_text}$(printf '%*s' "$pad" "")${C_CYAN}│${C_RESET}"
done
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯${C_RESET}"

# ==============================================================================
# NHẬN PHÍM AN TOÀN
# ==============================================================================
prompt_msg="${nhap_lua_chon_cua_ban:-Nhập lựa chọn của bạn} (1-3) [0=${exit_thoat:-Thoát}]: "
while true; do
  echo -en "${C_CYAN}${prompt_msg}${C_RESET}"
  if ! read -r REPLY; then exit 1; fi
  REPLY=$(echo "$REPLY" | tr -d ' ' | tr '[:upper:]' '[:lower:]')

  case "$REPLY" in
  0) exec /etc/wptt/wptt-backup-restore-main 1 ;;
  1)
    dinh_dang_nen_ma_nguon="no"
    break
    ;;
  2)
    dinh_dang_nen_ma_nguon="1"
    break
    ;;
  3)
    dinh_dang_nen_ma_nguon="2"
    break
    ;;
  *) echo -e "\n${C_RED}❌ Lựa chọn không hợp lệ! Vui lòng nhập từ 1 đến 3.${C_RESET}\n" ;;
  esac
done

# ==============================================================================
# THỰC THI LƯU CẤU HÌNH VÀ CÀI ĐẶT
# ==============================================================================
echo ""

if [[ $dinh_dang_nen_ma_nguon == '1' ]]; then
  print_dinh_dang_db='.tar.zst'
  if ! command -v zstd &>/dev/null || ! command -v tar &>/dev/null; then
    _runing "Đang cài đặt thư viện nén ZSTD và TAR"
    ! command -v zstd &>/dev/null && (dnf install zstd -y >/dev/null 2>&1 || apt-get install zstd -y >/dev/null 2>&1)
    ! command -v tar &>/dev/null && (dnf install tar -y >/dev/null 2>&1 || apt-get install tar -y >/dev/null 2>&1)
    _rundone "Cài đặt thư viện nén ZSTD và TAR"
  fi

elif [[ $dinh_dang_nen_ma_nguon == '2' ]]; then
  print_dinh_dang_db='.tar.gz'
  if ! command -v pigz &>/dev/null || ! command -v tar &>/dev/null || ! command -v gzip &>/dev/null; then
    _runing "Đang cài đặt thư viện nén đa luồng PIGZ, TAR và GZIP"
    ! command -v pigz &>/dev/null && (dnf install pigz -y >/dev/null 2>&1 || apt-get install pigz -y >/dev/null 2>&1)
    ! command -v tar &>/dev/null && (dnf install tar -y >/dev/null 2>&1 || apt-get install tar -y >/dev/null 2>&1)
    ! command -v gzip &>/dev/null && (dnf install gzip -y >/dev/null 2>&1 || apt-get install gzip -y >/dev/null 2>&1)
    _rundone "Cài đặt thư viện nén đa luồng PIGZ, TAR và GZIP"
  fi

else
  print_dinh_dang_db='.zip'
  if ! command -v zip &>/dev/null; then
    _runing "Đang cài đặt thư viện nén ZIP"
    dnf install zip -y >/dev/null 2>&1 || apt-get install zip -y >/dev/null 2>&1
    _rundone "Cài đặt thư viện nén ZIP"
  fi
fi

_runing "Thiết lập định dạng sao lưu mã nguồn sang $print_dinh_dang_db"

# Lưu vào file cấu hình
sed -i '/dinh_dang_nen_ma_nguon/d' /etc/wptt/.wptt.conf
if [[ $dinh_dang_nen_ma_nguon != 'no' ]]; then
  echo "dinh_dang_nen_ma_nguon=$dinh_dang_nen_ma_nguon" >>/etc/wptt/.wptt.conf
fi

echo "Config chuyển định dạng sao lưu mã nguồn $print_dinh_dang_db: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log

_rundone "Thiết lập định dạng sao lưu mã nguồn sang $print_dinh_dang_db"

if [[ ${1:-} == "98" ]]; then
  exec /etc/wptt/wptt-backup-restore-main 1
fi
