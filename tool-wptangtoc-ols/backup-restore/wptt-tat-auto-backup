function huong_dan() {
  Tính năng tắt tự động sao lưu website là một tùy chọn cho phép bạn dừng hoàn toàn hoặc tạm ngưng việc hệ thống tự động tạo ra các bản sao lưu [backup] cho website của bạn theo lịch trình đã định sẵn.

  Nói đơn giản, nếu website của bạn đang được cài đặt để tự động backup mỗi ngày, việc tắt tính năng này sẽ khiến quá trình đó ngừng lại. Website sẽ không còn được tự động sao lưu nữa cho đến khi bạn kích hoạt lại tính năng này.
}

echo ""
echo ""
echo ""
echo "========================================================================="
echo "|Sao lưu & khôi phục => Tắt thiết lập tự động sao lưu website           |"
echo "========================================================================="
. /etc/wptt/echo-color
echo ""
echo ""
if [ "$(ls -A /etc/wptt/vhost | grep -v '^\.\.conf$' | sort -uV)" ]; then
  echo "========================================================================="
  echo "Danh sách domain đã kích hoạt tự động backup website:"
  echo "========================================================================="

  for entry in $(ls -A /etc/wptt/vhost | grep -v '^\.\.conf$' | sort -uV); do
    domain=$(echo $entry | sed 's/^.//' | sed 's/.conf//')
    path="/etc/cron.d/backup$domain.cron"

    if [[ -f "$path" ]]; then
      checkauto="Đã kích hoạt tự động lúc "
      # Dùng awk để lấy chính xác các cột dù file cron xài phím cách hay Tab
      cron_line=$(cat "$path" | grep -v "^#")
      checkauto1=$(echo "$cron_line" | awk '{print $2}') # Giờ
      check_dom=$(echo "$cron_line" | awk '{print $3}')  # Ngày trong tháng
      checkauto2=$(echo "$cron_line" | awk '{print $5}') # Ngày trong tuần

      kiemtra_doi_so=$(grep -c "1998" /etc/wptt-auto/$domain-auto-backup 2>/dev/null)
      tinhnang=""

      if [[ "$kiemtra_doi_so" = "1" ]]; then
        if grep -q 'onedrive' ~/.config/rclone/rclone.conf 2>/dev/null; then
          tinhnang="| backup xong uploads lên OneDrive"
        else
          tinhnang="| backup xong uploads lên Google Drive"
        fi
      elif [[ "$kiemtra_doi_so" = "2" ]]; then
        if grep -q 'onedrive' ~/.config/rclone/rclone.conf 2>/dev/null; then
          tinhnang="| backup xong uploads lên OneDrive và xóa luôn file backup tại local"
        else
          tinhnang="| backup xong uploads lên Google Drive và xóa luôn file backup tại local"
        fi
      fi

      # Logic nhận diện Hàng Tháng -> Hàng Tuần -> Hàng Ngày
      if [[ "$check_dom" != "*" && -n "$check_dom" ]]; then
        thu123=" giờ ngày $check_dom hàng tháng"
      elif [[ "$checkauto2" != "*" && -n "$checkauto2" ]]; then
        case "$checkauto2" in
        0 | 7) thu123=" giờ chủ nhật hàng tuần" ;;
        1) thu123=" giờ thứ hai hàng tuần" ;;
        2) thu123=" giờ thứ ba hàng tuần" ;;
        3) thu123=" giờ thứ tư hàng tuần" ;;
        4) thu123=" giờ thứ năm hàng tuần" ;;
        5) thu123=" giờ thứ sáu hàng tuần" ;;
        6) thu123=" giờ thứ bảy hàng tuần" ;;
        esac
      else
        thu123=" giờ hàng ngày"
      fi

    else
      checkauto="Chưa được kích hoạt"
      checkauto1=""
      thu123=" tự động sao lưu backup website"
      tinhnang=""
    fi
    echo "Website $domain $checkauto$checkauto1$thu123 $tinhnang"
  done

  # Xử lý cho Toàn bộ website (All website)
  if [[ ! -f /etc/cron.d/backup-all-website-wptt-ols.cron ]]; then
    echo "Toàn bộ website chưa thiết lập tự động backup"
  else
    checkauto="Đã kích hoạt tự động lúc "
    cron_line_all=$(cat /etc/cron.d/backup-all-website-wptt-ols.cron | grep -v "^#")
    checkauto1=$(echo "$cron_line_all" | awk '{print $2}')
    check_dom_all=$(echo "$cron_line_all" | awk '{print $3}')
    checkauto2=$(echo "$cron_line_all" | awk '{print $5}')

    kiemtra_doi_so=$(grep -c "1998" /etc/wptt-auto/all-website-wptt-ols-auto-backup 2>/dev/null)
    tinhnang=""

    if [[ "$kiemtra_doi_so" = "1" ]]; then
      tinhnang="| backup xong uploads lên Google Drive"
    elif [[ "$kiemtra_doi_so" = "2" ]]; then
      tinhnang="| backup xong uploads lên Google Drive và xóa luôn file backup tại local"
    fi

    # Logic nhận diện Hàng Tháng -> Hàng Tuần -> Hàng Ngày cho All Website
    if [[ "$check_dom_all" != "*" && -n "$check_dom_all" ]]; then
      thu123=" giờ ngày $check_dom_all hàng tháng"
    elif [[ "$checkauto2" != "*" && -n "$checkauto2" ]]; then
      case "$checkauto2" in
      0 | 7) thu123=" giờ chủ nhật hàng tuần" ;;
      1) thu123=" giờ thứ hai hàng tuần" ;;
      2) thu123=" giờ thứ ba hàng tuần" ;;
      3) thu123=" giờ thứ tư hàng tuần" ;;
      4) thu123=" giờ thứ năm hàng tuần" ;;
      5) thu123=" giờ thứ sáu hàng tuần" ;;
      6) thu123=" giờ thứ bảy hàng tuần" ;;
      esac
    else
      thu123=" giờ hàng ngày"
    fi

    echo "Toàn bộ website $checkauto$checkauto1$thu123 $tinhnang"
  fi

  echo "========================================================================="
  echo
fi

function lua_chon_NAME() {
  NAME=""
  if [ "$(ls -At /etc/wptt/vhost)" ]; then
    selects=()
    for entry in $(ls -A /etc/wptt/vhost | sort -uV); do
      NAME=$(echo $entry | sed 's/^.//' | sed 's/.conf//')
      if [[ -f /etc/cron.d/backup$NAME.cron ]]; then
        selects+=("$NAME")
      fi
    done

    if [[ -f /etc/cron.d/backup-all-website-wptt-ols.cron ]]; then #xác định đã có thiết lập toàn bộ website all
      selects+=("Tất cả website")
    fi

    if [[ $selects = '' ]]; then
      echo "Tất cả domain trên hệ thống chưa có domain nào được kích hoạt sao lưu backup website tự động"
      exec /etc/wptt/wptt-backup-restore-main 1
    fi

    PS3="
-//- Nhập lựa chọn website của bạn [0=Thoát]: "
    select select in "${selects[@]}"; do
      NAME=$select
      index=$REPLY
      break
    done
  else
    clear
    echo "Khong co domain duoc thiet lap tu dong backup truoc do tai tren he thong cua ban."
    exit
  fi
}

echo ""
echo ""
echo "Lựa chọn website bạn muốn tắt tự động sao lưu website: "
echo ""
lua_chon_NAME

if [[ "$NAME" = "0" || "$NAME" = "" ]]; then
  exec /etc/wptt/wptt-backup-restore-main 1
fi

if [[ $NAME != 'Tất cả website' ]]; then
  pathcheck="/etc/wptt/vhost/.$NAME.conf"
  if [[ ! -f "$pathcheck" ]]; then
    clear
    echoDo "Tên miền không tồn tại trên hệ thống này"
    sleep 3
    check_menu_wptangtoc_active=$1
    if [[ $check_menu_wptangtoc_active = "98" ]]; then
      exec /etc/wptt/wptt-backup-restore-main 1
    fi
    return 2>/dev/null
    exit
  fi
fi

if [[ $NAME = 'Tất cả website' ]]; then
  if [ -f /etc/cron.d/backup-all-website-wptt-ols.cron ]; then
    _runing "Tắt tự động sao lưu tất cả website"
    rm -f /etc/cron.d/backup-all-website-wptt-ols.cron
    rm -f /etc/wptt-auto/all-website-wptt-ols-auto-backup

    if $(cat /etc/*release | grep -q "Ubuntu"); then
      rm -f /etc/cron.d/backup-all-website-wptt-ols_cron #ubuntu nếu có
      systemctl restart cron.service
    else
      systemctl restart crond.service
    fi

    echo "Tắt tự động sao lưu website tất cả website: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log
    _rundone "Tắt tự động sao lưu tất cả website"
  else
    echo "Bạn chưa kích hoạt tự động sao lưu tự động"
  fi

else #chuyển else lệnh tất cả website
  if [ -f /etc/cron.d/backup"$NAME".cron ]; then
    _runing "Tắt tự động sao lưu website $NAME"
    rm -f /etc/cron.d/backup"$NAME".cron
    rm -f /etc/wptt-auto/$NAME-auto-backup
    if $(cat /etc/*release | grep -q "Ubuntu"); then
      NAME_CRON_ubuntu=${NAME//[.]/_}
      rm -f /etc/cron.d/backup${NAME_CRON_ubuntu}_cron
      systemctl restart cron.service
    else
      systemctl restart crond.service
    fi

    echo "Tắt tự động sao lưu website $NAME: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log

    _rundone "Tắt tự động sao lưu website $NAME"
  else
    echo "Bạn chưa kích hoạt tự động sao lưu tự động"
  fi

fi

check_menu_wptangtoc_active=$1
if [[ $check_menu_wptangtoc_active = "98" ]]; then
  exec /etc/wptt/wptt-backup-restore-main 1
fi
