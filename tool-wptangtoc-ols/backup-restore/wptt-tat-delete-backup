#!/bin/bash

function huong_dan() {
  Tính năng tắt tự động xóa file backup hết hạn là một tùy chọn cho phép bạn tạm dừng hoặc vô hiệu hóa hoàn toàn cơ chế tự động loại bỏ các bản sao lưu cũ dựa trên quy tắc thời gian đã đặt trước.

  Nói đơn giản, nếu bạn đã cài đặt để hệ thống tự xóa backup sau 30 ngày, thì việc tắt tính năng này có nghĩa là tất cả các bản backup, kể cả những bản cũ hơn 30 ngày, sẽ không bị tự động xóa nữa và sẽ được giữ lại cho đến khi bạn xóa thủ công hoặc bật lại tính năng tự động xóa.

  Mục đích sử dụng:

  * Lưu trữ dài hạn đột xuất: Khi bạn cần giữ lại tất cả các bản backup trong một khoảng thời gian nhất định [ví dụ, để điều tra sự cố hoặc trước một thay đổi lớn trên website].
  * Thay đổi chính sách lưu trữ: Khi bạn muốn thay đổi quy tắc lưu giữ và cần thời gian để cấu hình lại.
  * Kiểm tra hoặc gỡ lỗi: Để kiểm tra xem liệu việc tự động xóa có gây ra vấn đề gì không.

  Lưu ý: Khi tắt tính năng này, dung lượng lưu trữ sẽ tăng lên theo thời gian do các bản backup cũ không được dọn dẹp.
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null # Nạp thư viện xác nhận

clear
echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}SAO LƯU & KHÔI PHỤC ➜ Tắt Tự động xóa File Backup cũ${C_RESET}"
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

# ==============================================================================
# BẢNG THỐNG KÊ CÁC DOMAIN ĐANG KÍCH HOẠT AUTO DELETE
# ==============================================================================
box_inner_width=${box_inner_width:-71}
active_list=()

if [ "$(ls -A /etc/wptt/vhost 2>/dev/null | grep -v '^\.\.conf$' | sort -uV)" ]; then
  for entry in $(ls -A /etc/wptt/vhost | grep -v '^\.\.conf$' | sort -uV); do
    domain=$(echo "$entry" | sed 's/^.//' | sed 's/.conf//')
    path="/etc/cron.d/delete$domain.cron"

    if [[ -f "$path" ]]; then
      checktuan0=$(cat "/etc/wptt-auto/$domain-delete-backup" 2>/dev/null | sed 's/.*-mmin +\([0-9]*\).*/\1/' | awk '{print $NF}' | grep -o '[0-9]\+')
      checktuan=$((checktuan0 / 60 / 24))

      domain_padded=$(printf "%-25s" "$domain")
      active_list+=("${C_BOLD_WHITE}${domain_padded}${C_RESET} : Đang xóa file cũ hơn ${C_YELLOW}${checktuan} ngày${C_RESET}")
    fi
  done
fi

# Check ALL WEBSITE
if [[ -f /etc/cron.d/delete-backup-all-website-wptt-ols-local.cron ]]; then
  checktuan0=$(cat /etc/wptt-auto/all-delete-backup-het-han-local 2>/dev/null | sed 's/.*-mmin +\([0-9]*\).*/\1/' | awk '{print $NF}' | grep -o '[0-9]\+')
  checktuan=$((checktuan0 / 60 / 24))

  domain_padded=$(printf "%-25s" "[Toàn bộ Website]")
  active_list+=("${C_YELLOW}${domain_padded}${C_RESET} : Đang xóa file cũ hơn ${C_YELLOW}${checktuan} ngày${C_RESET}")
fi

if [[ ${#active_list[@]} -gt 0 ]]; then
  echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_YELLOW}DANH SÁCH ĐANG BẬT TỰ ĐỘNG XÓA BACKUP CŨ${C_RESET}"
  echo -e "${C_CYAN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
  for item in "${active_list[@]}"; do
    left_text "$item" 2
  done
  echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"
fi

# ==============================================================================
# HÀM MENU LỌC THÔNG MINH (CHỈ HIỂN THỊ DOMAIN ĐÃ KÍCH HOẠT)
# ==============================================================================
function lua_chon_NAME() {
  unset NAME selects
  selects=()

  for filepath in /etc/wptt/vhost/.*.conf; do
    [[ ! -f "$filepath" || "$filepath" == *"/..conf" ]] && continue
    local domain="${filepath##*/}"
    domain="${domain%.conf}"
    domain="${domain#.}"

    if [[ -f "/etc/cron.d/delete$domain.cron" ]]; then
      selects+=("$domain")
    fi
  done

  if [[ -f /etc/cron.d/delete-backup-all-website-wptt-ols-local.cron ]]; then
    selects+=("Tất cả website")
  fi

  if [[ ${#selects[@]} -eq 0 ]]; then
    echo -e "${C_YELLOW}⚠️ Hệ thống chưa có website nào được kích hoạt Tự động xóa file Backup cũ!${C_RESET}"
    sleep 3
    exec /etc/wptt/wptt-backup-restore-main 1
  fi

  mapfile -t selects < <(printf "%s\n" "${selects[@]}" | sort -uV)

  echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
  local title_text="Lựa chọn website muốn TẮT tự động xóa backup cũ:"
  local len=$(echo -n "$title_text" | awk '{print length($0)}')
  local pad_r=$((box_inner_width - len - 2))
  [[ $pad_r -lt 0 ]] && pad_r=0
  echo -e "${C_CYAN}│${C_RESET}  ${C_YELLOW}${title_text}${C_RESET}$(printf '%*s' "$pad_r" "")${C_CYAN}│${C_RESET}"

  local line_len=$((len + 3))
  local pad_line_r=$((box_inner_width - line_len))
  [[ $pad_line_r -lt 0 ]] && pad_line_r=0
  local short_line=$(printf "%${line_len}s" "" | sed 's/ /─/g')
  echo -e "${C_CYAN}├${short_line}$(printf '%*s' "$pad_line_r" "")│${C_RESET}"

  local i=1
  for domain in "${selects[@]}"; do
    if [[ "$domain" == "Tất cả website" ]]; then
      local item_text=$(printf "  ${C_CYAN}%3d)${C_RESET} ${C_YELLOW}%s${C_RESET}" "$i" "$domain")
    else
      local item_text=$(printf "  ${C_CYAN}%3d)${C_RESET} ${C_BOLD_WHITE}%s${C_RESET}" "$i" "$domain")
    fi
    local clean_text=$(printf "  %3d) %s" "$i" "$domain")
    local item_len=$(echo -n "$clean_text" | awk '{print length($0)}')
    local pad=$((box_inner_width - item_len))
    [[ $pad -lt 0 ]] && pad=0
    echo -e "${C_CYAN}│${C_RESET}${item_text}$(printf '%*s' "$pad" "")${C_CYAN}│${C_RESET}"
    ((i++))
  done
  echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯${C_RESET}"

  local fzf_installed=false
  if command -v fzf &>/dev/null; then
    fzf_installed=true
    PROMPT_TEXT="Nhập lựa chọn (1-${#selects[@]}) [00=Tìm nhanh] [0=Thoát]: "
  else
    PROMPT_TEXT="Nhập lựa chọn (1-${#selects[@]}) [0=Thoát]: "
  fi

  while true; do
    echo -en "${C_CYAN}${PROMPT_TEXT}${C_RESET}"
    if ! read -r REPLY; then exit 1; fi
    REPLY=$(echo "$REPLY" | tr -d ' ' | tr '[:upper:]' '[:lower:]')

    case "$REPLY" in
    0)
      echo -e "\n${C_GREEN}Đang thoát...${C_RESET}"
      NAME="0"
      return 0
      ;;
    00)
      if $fzf_installed; then
        local selected_name=$(printf '%s\n' "${selects[@]}" | nl -w 3 -s ': ' | fzf --prompt="Tìm website tắt dọn dẹp >> " --height=40% --border=rounded --color=border:red --cycle --reverse)
        selected_name=$(echo "$selected_name" | sed 's/^[[:space:]]*[0-9]\+\:[[:space:]]*//')
        if [[ -n "$selected_name" ]]; then
          NAME="$selected_name"
          return 0
        else echo -e "${C_YELLOW}Đã hủy chọn. Vui lòng chọn lại.${C_RESET}"; fi
      else
        echo -e "${C_RED}Lỗi: FZF chưa cài đặt.${C_RESET}"
      fi
      ;;
    *)
      if [[ "$REPLY" =~ ^[0-9]+$ ]] && [ "$REPLY" -ge 1 ] && [ "$REPLY" -le ${#selects[@]} ]; then
        local action_index=$((REPLY - 1))
        NAME="${selects[$action_index]}"
        return 0
      else
        echo -e "\n${C_RED}❌ Lựa chọn không hợp lệ! Vui lòng chọn lại.${C_RESET}"
      fi
      ;;
    esac
  done
}

lua_chon_NAME

[[ "$NAME" == "0" || -z "$NAME" ]] && {
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-backup-restore-main 1
  return 2>/dev/null || exit
}

if [[ "$NAME" != 'Tất cả website' ]]; then
  pathcheck="/etc/wptt/vhost/.$NAME.conf"
  if [[ ! -f "$pathcheck" ]]; then
    echo -e "\n${C_RED}❌ Tên miền không tồn tại trên hệ thống này!${C_RESET}"
    sleep 3
    [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-backup-restore-main 1
    return 2>/dev/null || exit
  fi
fi

# ==============================================================================
# XÁC NHẬN VÀ THỰC THI TẮT DỌN DẸP
# ==============================================================================
echo ""
if wptt_xac_nhan "Bạn có chắc chắn muốn TẮT tính năng Tự động Xóa File Backup cũ?" "${C_BOLD_WHITE}Website:${C_RESET} ${C_YELLOW}$NAME${C_RESET}" "" "Đồng ý Tắt" "Hủy bỏ"; then
  echo ""

  if [[ "$NAME" == 'Tất cả website' ]]; then
    if [[ -f /etc/cron.d/delete-backup-all-website-wptt-ols-local.cron ]]; then
      _runing "Đang gỡ bỏ cấu hình dọn dẹp cho Tất cả website..."
      rm -f /etc/wptt-auto/all-delete-backup-het-han-local
      rm -f /etc/cron.d/delete-backup-all-website-wptt-ols-local.cron

      if $(cat /etc/*release | grep -q "Ubuntu"); then
        rm -f /etc/cron.d/delete-backup-all-website-wptt-ols-local_cron 2>/dev/null
        systemctl restart cron.service
      else
        systemctl restart crond.service
      fi

      echo "Tắt tự động xóa backup hết hạn tất cả website: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log
      _rundone "Hủy xóa file backup hết hạn toàn bộ website"
      is_success=true
    else
      echo -e "${C_YELLOW}⚠️ Tính năng này chưa được kích hoạt trước đó!${C_RESET}"
      is_success=false
    fi

  else
    if [[ -f "/etc/cron.d/delete$NAME.cron" ]]; then
      _runing "Đang gỡ bỏ cấu hình dọn dẹp cho website $NAME..."
      rm -f "/etc/cron.d/delete$NAME.cron"
      rm -f "/etc/wptt-auto/$NAME-delete-backup"

      if $(cat /etc/*release | grep -q "Ubuntu"); then
        NAME_CRON_ubuntu=${NAME//[.]/_}
        rm -f "/etc/cron.d/delete${NAME_CRON_ubuntu}_cron" 2>/dev/null
        systemctl restart cron.service
      else
        systemctl restart crond.service
      fi

      echo "Tắt tự động xóa backup hết hạn website $NAME: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log
      _rundone "Hủy xóa file backup hết hạn website $NAME"
      is_success=true
    else
      echo -e "${C_YELLOW}⚠️ Bạn chưa kích hoạt tự động xóa cho website này!${C_RESET}"
      is_success=false
    fi
  fi

  # ==============================================================================
  # BẢNG THÔNG BÁO THÀNH CÔNG (UX BO CONG - ĐỒNG BỘ VIỀN CYAN)
  # ==============================================================================
  if [[ "$is_success" == "true" ]]; then
    echo -e "\n${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
    center_text "${C_GREEN}ĐÃ TẮT TỰ ĐỘNG XÓA BACKUP THÀNH CÔNG${C_RESET}"
    echo -e "${C_CYAN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
    left_text "Website        : ${C_YELLOW}$NAME${C_RESET}"
    left_text "Trạng thái     : ${C_GREEN}Các file Backup cũ sẽ không bị xóa tự động nữa.${C_RESET}"
    echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"
  fi

else
  echo -e "${C_YELLOW}Đã hủy thao tác Tắt Auto Delete.${C_RESET}"
fi

[[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-backup-restore-main 1
