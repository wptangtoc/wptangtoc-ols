#!/bin/bash
# @author: Gia Tuấn
# @website: https://wptangtoc.com
# @email: giatuan@wptangtoc.com
# @since: 2026

function huong_dan() {
  Thiết lập Google Drive đám mây là một giải pháp sao lưu website hiệu quả, an toàn và có khả năng tùy biến cao.
  Đây là một giải pháp mạnh mẽ và linh hoạt, cho phép bạn lưu trữ các bản sao lưu website của mình ở một vị trí riêng biệt.
}

export LANG=en_US.UTF-8
export LC_ALL=en_US.UTF-8
stty iutf8

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null

clear
echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}SAO LƯU & KHÔI PHỤC ➜ Thiết lập Rclone (Google Drive)${C_RESET}"
echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

# ==============================================================================
# KIỂM TRA TRẠNG THÁI CÀI ĐẶT TRƯỚC ĐÓ
# ==============================================================================
if [[ ! -d /root/.config/rclone ]]; then
  mkdir -p /root/.config/rclone
  chmod 751 /root/.config
fi

duong_dan_rclone="/root/.config/rclone/rclone.conf"
if [[ -f "$duong_dan_rclone" && -s "$duong_dan_rclone" ]]; then
  
  raw_type=$(grep -A 1 '\[wptangtoc\]' "$duong_dan_rclone" 2>/dev/null | grep 'type' | awk -F '=' '{print $2}' | tr -d ' ')
  
  case "$raw_type" in
    drive)    cloud_name="Google Drive" ;;
    onedrive) cloud_name="Microsoft OneDrive" ;;
    s3)       cloud_name="S3 Storage (AWS/R2/MinIO...)" ;;
    *)        cloud_name="Cloud Khác ($raw_type)" ;;
  esac

  echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_YELLOW}PHÁT HIỆN KẾT NỐI CLOUD TỒN TẠI${C_RESET}"
  echo -e "${C_CYAN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
  left_text "Hệ thống phát hiện VPS đã được cấu hình lưu trữ Đám mây từ trước."
  left_text "Trạng thái hiện tại: Đang kết nối nền tảng [ ${C_GREEN}${cloud_name}${C_RESET} ]"
  echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"
  
  msg_title="BẠN CÓ MUỐN GỠ KẾT NỐI CŨ VÀ CÀI ĐẶT LẠI KHÔNG?"
  msg_sub1="Đang dùng : ${C_GREEN}$cloud_name${C_RESET}"
  msg_sub2="Ghi chú  : Dữ liệu cũ trên $cloud_name sẽ không bị xóa."
  
  if ! wptt_xac_nhan "$msg_title" "$msg_sub1" "$msg_sub2" "Đồng ý Xóa và Cài Mới" "Giữ nguyên (Thoát)"; then
    exec /etc/wptt/wptt-backup-restore-main 1
    exit
  fi
  
  rm -f "$duong_dan_rclone"
  clear
fi

# ==============================================================================
# CÀI ĐẶT BINARY RCLONE (TỰ ĐỘNG KÉO PHIÊN BẢN MỚI NHẤT)
# ==============================================================================
_runing "Đang cài đặt và đồng bộ hóa công cụ Rclone..."
rm -rf ~/.config/rclone
mkdir -p /root/.config/rclone
rm -rf /usr/sbin/rclone /usr/bin/rclone
cd /tmp || exit

phienban=$(curl -s https://downloads.rclone.org/version.txt | awk '{print $2}' | tr -d 'v')
[[ -z "$phienban" ]] && phienban="1.74.2" # Fallback version nếu curl lỗi

if [[ $(uname -m | grep 'aarch64') ]]; then
  cpu_dong_="linux-arm64"
else
  cpu_dong_="linux-amd64"
fi

wget -q "https://downloads.rclone.org/v${phienban}/rclone-v${phienban}-${cpu_dong_}.zip"
if [[ ! -f "rclone-v${phienban}-${cpu_dong_}.zip" ]]; then
  wget -q "https://github.com/rclone/rclone/releases/download/v${phienban}/rclone-v${phienban}-${cpu_dong_}.zip" --no-check-certificate
fi

unzip -oq "rclone-v${phienban}-${cpu_dong_}.zip"
cp -r "rclone-v${phienban}-${cpu_dong_}/rclone" /usr/sbin/
chmod 755 /usr/sbin/rclone
rm -rf "/tmp/rclone-v${phienban}-${cpu_dong_}" "rclone-v${phienban}-${cpu_dong_}.zip"
_rundone "Cài đặt nền tảng Rclone thành công (Phiên bản: $phienban)"

# ==============================================================================
# HƯỚNG DẪN LẤY TOKEN
# ==============================================================================
box_inner_width=${box_inner_width:-78}
echo -e "\n${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_BOLD_WHITE}HƯỚNG DẪN XÁC THỰC GOOGLE DRIVE${C_RESET}"
echo -e "${C_CYAN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
left_text "${C_RED}CHÚ Ý: KHÔNG CHẠY LỆNH DƯỚI ĐÂY TRÊN VPS NÀY!${C_RESET}" 2
left_text "Hãy mở CMD (Windows) hoặc Terminal (Macbook) trên ${C_YELLOW}MÁY TÍNH CÁ NHÂN${C_RESET}" 2
left_text "của bạn, copy và dán lệnh sau vào để trình duyệt tự mở lên:" 2
echo -e "${C_CYAN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
center_text "${C_YELLOW}rclone authorize \"drive\" \"eyJzY29wZSI6ImRyaXZlIn0\"${C_RESET}"
echo -e "${C_CYAN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
left_text "Hoặc truy cập URL này để xem hướng dẫn chi tiết:" 2
center_text "${C_GREEN}https://wptangtoc.com/xac-thuc-drive/${C_RESET}"
echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

# ==============================================================================
# BẮT TOKEN BẰNG CƠ CHẾ SLURP (TỰ ĐỘNG HÚT MULTI-LINE CHỈ VỚI 1 ENTER)
# ==============================================================================
echo -en "${C_CYAN}Dán TOÀN BỘ mã Token của bạn vào đây [0=Thoát]: ${C_RESET}"
read -r checkid

if [[ "$checkid" == "0" || -z "$checkid" ]]; then
  echo -e "\n${C_YELLOW}Đã hủy thao tác thiết lập.${C_RESET}"
  sleep 1
  exec /etc/wptt/wptt-backup-restore-main 1
  exit
fi

# Hút nốt các dòng còn lại trong bộ đệm (Nếu khách dán khối nhiều dòng)
while read -r -t 0.1 extra_line; do
  checkid="$checkid$extra_line"
done

_runing "Đang kết nối và thiết lập Google Drive (API)..."

# ==============================================================================
# LỌC VÀ TIÊM (INJECT) TOKEN VÀO FILE CONFIG CHUẨN XÁC
# ==============================================================================
clean_token=$(echo "$checkid" | sed 's/.*Paste the following into your remote machine --->//Ig' | sed 's/<---End paste.*//Ig' | tr -d '\n\r ')

if [[ "$clean_token" == eyJ* ]]; then
  # 1. Giải mã Base64
  decoded_token=$(echo "$clean_token" | base64 -d 2>/dev/null)
  
  # 2. Xóa bỏ lớp vỏ {"token":" và cái đuôi "}
  clean_token=$(echo "$decoded_token" | sed 's/^{"token":"//' | sed 's/"}$//')
  
  # 3. Xóa bỏ các ký tự escape (\") để trả về JSON chuẩn
  clean_token=$(echo "$clean_token" | sed 's/\\"/"/g')
fi

# Ghi đè cấu hình thẳng vào tệp tin rclone.conf
cat <<EOF > "$duong_dan_rclone"
[wptangtoc]
type = drive
scope = drive
token = $clean_token
EOF

# KIỂM TRA VÀ KHỞI TẠO THƯ MỤC BACKUP
if grep -q 'wptangtoc' "$duong_dan_rclone" 2>/dev/null; then
  check_tao_thu_muc=$(rclone lsd wptangtoc: 2>/dev/null | grep 'wptangtoc_ols_backup')
  if [[ -z "$check_tao_thu_muc" ]]; then
    rclone mkdir wptangtoc:wptangtoc_ols_backup >/dev/null 2>&1
  fi
fi

if rclone lsd wptangtoc: 2>/dev/null | grep -q 'wptangtoc_ols_backup'; then
  _rundone "Thiết lập kết nối Google Drive thành công"

  echo -e "\n${C_GREEN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_BOLD_WHITE}HOÀN TẤT KẾT NỐI CLOUD${C_RESET}"
  echo -e "${C_GREEN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
  left_text "Nền tảng    : ${C_YELLOW}Google Drive${C_RESET}"
  left_text "Trạng thái  : ${C_GREEN}Kết nối API Token hợp lệ.${C_RESET}"
  left_text "Thư mục lưu : Khởi tạo thành công [wptangtoc_ols_backup/]"
  echo -e "${C_GREEN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

  if ls /etc/cron.d/backup*.cron 1>/dev/null 2>&1; then
    echo -e "${C_YELLOW}Ghi chú:${C_RESET} Bạn đang có các tiến trình Auto Backup đã được bật."
    echo -e "Hệ thống sẽ tự động sử dụng Google Drive làm kho lưu trữ chính trong chu kỳ tới."
  fi
else
  _runloi "Thiết lập Google Drive thất bại"
  echo -e "${C_RED}Lỗi: Mã Token không hợp lệ hoặc bị thiếu cấu trúc JSON. Vui lòng copy chính xác khối Token.${C_RESET}"
  rm -f "$duong_dan_rclone"
fi

[[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-backup-restore-main 1
