#!/bin/bash
# @author: Gia Tuấn
# @website: https://wptangtoc.com
# @email: giatuan@wptangtoc.com
# @description: Khôi phục Website Lũy tiến
# @since: 2026

function huong_dan() {
  Tính năng khôi phục website luỹ tiến từng phần

  Khôi phục website là quá trình sửa chữa, phục hồi hoặc đưa trở lại trạng thái hoạt động bình thường cho các chức năng cụ thể của một trang web đã bị lỗi, bị mất hoặc không hoạt động đúng cách. Điều này đảm bảo rằng người dùng có thể tiếp tục tương tác và sử dụng đầy đủ các tiện ích mà website đó cung cấp.

  Khôi phục từ bản sao lưu [Backup] sao lưu luỹ tiến trong wptangtoc ols: Nếu bạn thường xuyên sao lưu website, bạn có thể khôi phục toàn bộ website hoặc các thành phần cụ thể về một thời điểm trước khi lỗi xảy ra.
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null


if [[ "$1" == '98' ]]; then
  WPTT_IN_MENU="yes"
  WPTT_MENU_BACK="/etc/wptt/wptt-backup-restore-main 1"
fi

wptt_check_mariadb || wptt_die "MariaDB đang bị sập! Hệ thống từ chối không cho phép khôi phục website."


box_inner_width=78

NAME=$1
[[ "$NAME" == "98" ]] && NAME=""

# ==============================================================================
# 1. GIAO DIỆN CHỌN WEBSITE
# ==============================================================================
if [[ -z "$NAME" ]]; then
  clear
  echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_YELLOW}SAO LƯU & KHÔI PHỤC ➜ $khoi_phuc_website (Lũy tiến)${C_RESET}"
  echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"
  . /etc/wptt/tenmien 2>/dev/null
  lua_chon_NAME "Khôi phục Lũy tiến"
fi

[[ "$NAME" == "0" || -z "$NAME" ]] && exec /etc/wptt/wptt-backup-restore-main 1

pathcheck="/etc/wptt/vhost/.$NAME.conf"
if [[ ! -f "$pathcheck" ]]; then
  echo -e "\n${C_RED}❌ Tên miền không tồn tại trên hệ thống!${C_RESET}"
  sleep 3
  exec /etc/wptt/wptt-backup-restore-main 1
  exit
fi

. /etc/wptt/vhost/."$NAME".conf

if [[ -z "$(ls -A /usr/local/backup-website/$NAME/ 2>/dev/null)" && -z "$(ls -A /usr/local/lsws/$NAME/backup-website 2>/dev/null)" ]]; then
  echo -e "\n${C_YELLOW}⚠️ Không có file backup nào tồn tại cho website $NAME.${C_RESET}"
  echo -e "Vui lòng upload file backup vào: /usr/local/backup-website/$NAME/"
  if grep -q '\[wptangtoc\]' ~/.config/rclone/rclone.conf 2>/dev/null; then
    echo -e "Mẹo: Bạn có thể dùng tính năng [Download File backup từ Cloud]."
  fi
  sleep 4
  exec /etc/wptt/wptt-backup-restore-main 1
  exit
fi

# ==============================================================================
# BẮT ĐẦU CƠ CHẾ LOCKING (CHỐNG ĐỤNG ĐỘ TIẾN TRÌNH BACKUP/RESTORE)
# ==============================================================================
LOCK_FILE="/tmp/wptt_lock_sao_luu_khoi_phuc_${NAME}.lock"
exec 200>"$LOCK_FILE"
if ! flock -n 200; then
  echo -e "\n${C_RED}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_YELLOW}CẢNH BÁO: ĐỤNG ĐỘ TIẾN TRÌNH${C_RESET}"
  echo -e "${C_RED}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
  left_text "Website $NAME đang được thao tác bởi một tiến trình Backup/Restore khác."
  left_text "Vui lòng chờ tiến trình đó hoàn tất rồi thử lại để tránh hỏng dữ liệu!"
  echo -e "${C_RED}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"
  sleep 4
  exec /etc/wptt/wptt-backup-restore-main 1
  exit 1
fi

# ==============================================================================
# 2. CHỌN MỐC THỜI GIAN MÃ NGUỒN (CORE + UPLOADS)
# ==============================================================================
selects_code=()
# Quét thư mục Root
for entry in $(ls -At /usr/local/backup-website/$NAME/ 2>/dev/null | grep '\-wptt\-luy\-tien\-tung\-phan\-core.zip$' | sed 's/-wptt-luy-tien-tung-phan-core.zip//g'); do
  suffix_date=$(echo "$entry" | sed "s/^$NAME//g" | cut -f1 -d '.' | awk -F'_' '{print $(NF-1)"_"$(NF)}')
  if [[ -f "/usr/local/backup-website/$NAME/$NAME-${suffix_date}-wptt-luy-tien-wp-uploads-dir.zip" ]]; then
    selects_code+=("$entry")
  fi
done

# Quét thư mục User
for entry in $(ls -At /usr/local/lsws/$NAME/backup-website 2>/dev/null | grep '\-wptt\-luy\-tien\-tung\-phan\-core.zip$' | sed 's/-wptt-luy-tien-tung-phan-core.zip//g'); do
  suffix_date=$(echo "$entry" | sed "s/^$NAME//g" | cut -f1 -d '.' | awk -F'_' '{print $(NF-1)"_"$(NF)}')
  if [[ -f "/usr/local/lsws/$NAME/backup-website/$NAME-${suffix_date}-wptt-luy-tien-wp-uploads-dir.zip" ]]; then
    selects_code+=("$entry")
  fi
done

# Xóa trùng lặp nếu cả 2 bên đều có
mapfile -t selects_code < <(printf "%s\n" "${selects_code[@]}" | sort -uV | tac)

if [[ ${#selects_code[@]} -eq 0 ]]; then
  echo -e "\n${C_YELLOW}⚠️ Không tìm thấy bản Backup Lũy tiến hợp lệ (Core + Uploads) nào.${C_RESET}"
  sleep 3
  exec /etc/wptt/wptt-backup-restore-main 1
  exit
fi

clear
echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}CHỌN MỐC THỜI GIAN KHÔI PHỤC (MÃ NGUỒN LŨY TIẾN)${C_RESET}"
echo -e "${C_CYAN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"

i=1
for val in "${selects_code[@]}"; do
  full_name="${val}-wptt-luy-tien-tung-phan-core.zip"
  # Lấy dung lượng (Ưu tiên root, sau đó user)
  if [[ -f "/usr/local/backup-website/$NAME/$full_name" ]]; then
    fsize=$(du -sh "/usr/local/backup-website/$NAME/$full_name" 2>/dev/null | cut -f1)
  else
    fsize=$(du -sh "/usr/local/lsws/$NAME/backup-website/$full_name" 2>/dev/null | cut -f1)
  fi
  
  item_row=$(printf "  ${C_CYAN}%3d)${C_RESET} [${C_GREEN}%-7s${C_RESET}] ${C_BOLD_WHITE}%s${C_RESET}" "$i" "${fsize:-???}" "$val")
  clean_row=$(printf "  %3d) [%-7s] %s" "$i" "${fsize:-???}" "$val")
  pad=$((box_inner_width - ${#clean_row}))
  [[ $pad -lt 0 ]] && pad=0
  echo -e "${C_CYAN}│${C_RESET}${item_row}$(printf '%*s' "$pad" "")${C_CYAN}│${C_RESET}"
  ((i++))
done
echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯${C_RESET}"

echo -en "${C_CYAN}Nhập số thứ tự để chọn Mã nguồn khôi phục (1-${#selects_code[@]}) [0=Thoát]: ${C_RESET}"
read -r REPLY

[[ "$REPLY" == "0" || -z "$REPLY" ]] && exec /etc/wptt/wptt-backup-restore-main 1

if [[ "$REPLY" =~ ^[0-9]+$ ]] && [ "$REPLY" -ge 1 ] && [ "$REPLY" -le ${#selects_code[@]} ]; then
  idx=$((REPLY - 1))
  file_code_raw="${selects_code[$idx]}"
  file_code="${file_code_raw}-wptt-luy-tien-tung-phan-core.zip"
else
  echo -e "${C_RED}❌ Lựa chọn không hợp lệ!${C_RESET}"
  sleep 2
  exec /etc/wptt/wptt-backup-restore-main 1
  exit
fi

# Xử lý đụng độ Root/User Mã nguồn
if [[ -f "/usr/local/backup-website/$NAME/$file_code" && -f "/usr/local/lsws/$NAME/backup-website/$file_code" ]]; then
  echo ""
  if wptt_xac_nhan "Phát hiện file Mã nguồn tồn tại ở cả 2 phân vùng (Root & User)!" "Bạn muốn sử dụng file ở phân vùng nào?" "" "Dùng file của Root" "Dùng file của User"; then
    duong_dan_thu_muc_ma_nguon="/usr/local/backup-website/$NAME/$file_code"
  else
    duong_dan_thu_muc_ma_nguon="/usr/local/lsws/$NAME/backup-website/$file_code"
  fi
elif [[ -f "/usr/local/backup-website/$NAME/$file_code" ]]; then
  duong_dan_thu_muc_ma_nguon="/usr/local/backup-website/$NAME/$file_code"
else
  duong_dan_thu_muc_ma_nguon="/usr/local/lsws/$NAME/backup-website/$file_code"
fi

# ==============================================================================
# 3. CHỌN MỐC THỜI GIAN DATABASE
# ==============================================================================
selects_db=()
for entry in $(ls -At /usr/local/backup-website/$NAME 2>/dev/null | grep '.sql$\|.sql.gz$\|.sql.zst$'); do
  selects_db+=("$entry")
done
for entry in $(ls -At /usr/local/lsws/$NAME/backup-website 2>/dev/null | grep '.sql$\|.sql.gz$\|.sql.zst$'); do
  selects_db+=("$entry")
done

mapfile -t selects_db < <(printf "%s\n" "${selects_db[@]}" | sort -uV | tac)

if [[ ${#selects_db[@]} -eq 0 ]]; then
  echo -e "\n${C_YELLOW}⚠️ Không tìm thấy file Database (.sql, .sql.gz, .zst) hợp lệ.${C_RESET}"
  sleep 3
  exec /etc/wptt/wptt-backup-restore-main 1
  exit
fi

echo -e "\n${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}CHỌN MỐC THỜI GIAN KHÔI PHỤC (DATABASE)${C_RESET}"
echo -e "${C_CYAN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"

i=1
for val in "${selects_db[@]}"; do
  if [[ -f "/usr/local/backup-website/$NAME/$val" ]]; then
    fsize=$(du -sh "/usr/local/backup-website/$NAME/$val" 2>/dev/null | cut -f1)
  else
    fsize=$(du -sh "/usr/local/lsws/$NAME/backup-website/$val" 2>/dev/null | cut -f1)
  fi

  item_row=$(printf "  ${C_CYAN}%3d)${C_RESET} [${C_GREEN}%-7s${C_RESET}] ${C_BOLD_WHITE}%s${C_RESET}" "$i" "${fsize:-???}" "$val")
  clean_row=$(printf "  %3d) [%-7s] %s" "$i" "${fsize:-???}" "$val")
  pad=$((box_inner_width - ${#clean_row}))
  [[ $pad -lt 0 ]] && pad=0
  echo -e "${C_CYAN}│${C_RESET}${item_row}$(printf '%*s' "$pad" "")${C_CYAN}│${C_RESET}"
  ((i++))
done
echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯${C_RESET}"

echo -en "${C_CYAN}Nhập số thứ tự để chọn Database khôi phục (1-${#selects_db[@]}) [0=Thoát]: ${C_RESET}"
read -r REPLY

[[ "$REPLY" == "0" || -z "$REPLY" ]] && exec /etc/wptt/wptt-backup-restore-main 1

if [[ "$REPLY" =~ ^[0-9]+$ ]] && [ "$REPLY" -ge 1 ] && [ "$REPLY" -le ${#selects_db[@]} ]; then
  idx=$((REPLY - 1))
  filesql="${selects_db[$idx]}"
else
  echo -e "${C_RED}❌ Lựa chọn không hợp lệ!${C_RESET}"
  sleep 2
  exec /etc/wptt/wptt-backup-restore-main 1
  exit
fi

# Xử lý đụng độ Root/User DB
if [[ -f "/usr/local/backup-website/$NAME/$filesql" && -f "/usr/local/lsws/$NAME/backup-website/$filesql" ]]; then
  echo ""
  if wptt_xac_nhan "Phát hiện file Database tồn tại ở cả 2 phân vùng (Root & User)!" "Bạn muốn sử dụng file ở phân vùng nào?" "" "Dùng file của Root" "Dùng file của User"; then
    duong_dan_thu_path_sql="/usr/local/backup-website/$NAME/$filesql"
  else
    duong_dan_thu_path_sql="/usr/local/lsws/$NAME/backup-website/$filesql"
  fi
elif [[ -f "/usr/local/backup-website/$NAME/$filesql" ]]; then
  duong_dan_thu_path_sql="/usr/local/backup-website/$NAME/$filesql"
else
  duong_dan_thu_path_sql="/usr/local/lsws/$NAME/backup-website/$filesql"
fi

check_file_error=$(du -c "$duong_dan_thu_path_sql" | awk '{print $1}' | sed '1d')
if (($check_file_error < 10)); then
  echo -e "\n${C_RED}❌ Lỗi: File Database $filesql bị hỏng hoặc quá nhẹ (Không hợp lệ).${C_RESET}"
  sleep 3
  exec /etc/wptt/wptt-backup-restore-main 1
  exit
fi

# ==============================================================================
# 4. TIẾN HÀNH KHÔI PHỤC (EXECUTION)
# ==============================================================================
clear
echo "Khôi phục lũy tiến website $NAME: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log

_runing "Đang Dọn dẹp & Tái tạo Database hiện tại..."
TEMP_CNF_ROOT=$(mktemp)
chmod 600 "$TEMP_CNF_ROOT"
cat >"$TEMP_CNF_ROOT" <<EOF
[client]
user=${database_admin_username}
password=${database_admin_password}
host=localhost
max_allowed_packet=1G
default-character-set=utf8mb4
EOF

mariadb --defaults-extra-file="$TEMP_CNF_ROOT" -e "DROP DATABASE IF EXISTS ${DB_Name_web}"
mariadb --defaults-extra-file="$TEMP_CNF_ROOT" -e "CREATE DATABASE IF NOT EXISTS ${DB_Name_web}"
rm -f "$TEMP_CNF_ROOT"
_rundone "Dọn dẹp & Tái tạo Database hoàn tất"

_runing "Đang Import (Bơm dữ liệu) vào Database..."
TEMP_CNF=$(mktemp)
chmod 600 "$TEMP_CNF"
cat >"$TEMP_CNF" <<EOF
[client]
user=${DB_User_web}
password=${DB_Password_web}
host=localhost
max_allowed_packet=1G
default-character-set=utf8mb4
EOF

if [[ "$filesql" == *.sql.zst ]]; then
  [[ -z $(which zstd 2>/dev/null) ]] && dnf install zstd -y -q >/dev/null 2>&1
  zstd -d <"$duong_dan_thu_path_sql" | mariadb --defaults-extra-file="$TEMP_CNF" "$DB_Name_web"
elif [[ "$filesql" == *.sql.gz ]]; then
  zcat "$duong_dan_thu_path_sql" | mariadb --defaults-extra-file="$TEMP_CNF" "$DB_Name_web"
else
  mariadb --defaults-extra-file="$TEMP_CNF" "$DB_Name_web" <"$duong_dan_thu_path_sql"
fi
rm -f "$TEMP_CNF"
_rundone "Import Database thành công"

_runing "Đang Xóa trắng mã nguồn cũ..."
[[ -n "$lock_down" ]] && . /etc/wptt/bao-mat/wptt-chattr-file-lock "$NAME" off
rm -rf /usr/local/lsws/"$NAME"/html/*
_rundone "Xóa mã nguồn cũ hoàn tất"

_runing "Đang Giải nén Mã nguồn (Core + Uploads Lũy tiến)..."
check_time_restore_thang_nam=$(echo "$duong_dan_thu_muc_ma_nguon" | cut -f6 -d '/' | grep "^$NAME" | sed "s/^$NAME//g" | sed 's/-wptt-luy-tien-tung-phan-core//g' | cut -f1 -d '.' | awk -F'_' '{print $(NF-1)"_"$(NF)}')

if [[ "$file_code" == *.zip ]]; then
  if unzip -l "$duong_dan_thu_muc_ma_nguon" 2>/dev/null | awk '{ print $4 }' | grep -q '^wp-load.php$'; then
    # Giải nén Core
    unzip -oq "$duong_dan_thu_muc_ma_nguon" -d /usr/local/lsws/"$NAME"/html/
    # Giải nén Uploads theo tháng
    unzip -oq "/usr/local/backup-website/$NAME/$NAME-${check_time_restore_thang_nam}-wptt-luy-tien-wp-uploads-dir.zip" -d /usr/local/lsws/"$NAME"/html/ 2>/dev/null
    
    check_time_restore_nam_thang_uploads=$(echo "$duong_dan_thu_muc_ma_nguon" | cut -f6 -d '/' | grep "^$NAME" | sed "s/^$NAME//g" | sed 's/-wptt-luy-tien-tung-phan-core//g' | cut -f1 -d '.' | awk -F'_' '{print $(NF)"/"$(NF-1)}')
    unzip -oq "$duong_dan_thu_muc_ma_nguon" "wp-content/uploads/$check_time_restore_nam_thang_uploads/*" -d /usr/local/lsws/"$NAME"/html/ 2>/dev/null
  fi
fi
_rundone "Giải nén Lũy tiến thành công"

_runing "Đang Thiết lập Phân quyền (Chown/Chmod)..."
chown -R "$User_name_vhost":"$User_name_vhost" /usr/local/lsws/"$NAME"/html

if [[ -n "$lock_down" ]]; then
  find /usr/local/lsws/"$NAME"/html -type f -print0 | xargs -0 chmod 404
  find /usr/local/lsws/"$NAME"/html -type d -print0 | xargs -0 chmod 515
  find /usr/local/lsws/"$NAME"/html/wp-content/uploads -type d -print0 | xargs -0 chmod 755
  . /etc/wptt/bao-mat/wptt-chattr-file-lock "$NAME" on
else
  find /usr/local/lsws/"$NAME"/html -type f -print0 | xargs -0 chmod 644
  find /usr/local/lsws/"$NAME"/html -type d -print0 | xargs -0 chmod 755
fi
_rundone "Thiết lập phân quyền an toàn hoàn tất"

wp_config_php_path="/usr/local/lsws/$NAME/html/wp-config.php"
if [[ -f "$wp_config_php_path" ]]; then
  _runing "Đang cấu hình lại kết nối wp-config.php..."
  [[ -n "$lock_down" ]] && chattr -i "$wp_config_php_path"

  wp config set DB_HOST 'localhost' --type=constant --allow-root --path="/usr/local/lsws/$NAME/html" --quiet
  wp config set DB_NAME "$DB_Name_web" --type=constant --allow-root --path="/usr/local/lsws/$NAME/html" --quiet
  wp config set DB_USER "$DB_User_web" --type=constant --allow-root --path="/usr/local/lsws/$NAME/html" --quiet
  wp config set DB_PASSWORD "$DB_Password_web" --type=constant --allow-root --path="/usr/local/lsws/$NAME/html" --quiet

  wp rewrite flush --allow-root --path="/usr/local/lsws/$NAME/html" >/dev/null 2>&1
  [[ -n "$lock_down" ]] && chattr +i "$wp_config_php_path"
  _rundone "Cấu hình Database cho WordPress thành công"
else
  echo -e "${C_YELLOW}Không tìm thấy file wp-config.php (Có thể đây không phải WordPress).${C_RESET}"
fi

if [[ -f "/usr/local/lsws/$NAME/html/wp-load.php" ]]; then
  . /etc/wptt/cache/wptt-xoacache "$NAME" >/dev/null 2>&1
fi

if [[ -d "/usr/local/lsws/$NAME/luucache" ]]; then
  _runing "Đang dọn dẹp LSCache (Server-side)..."
  rm -rf /usr/local/lsws/"$NAME"/luucache
  _rundone "Dọn dẹp LSCache hoàn tất"
fi

/usr/local/lsws/bin/lswsctrl reload >/dev/null 2>&1

# ==============================================================================
# 5. MỞ KHÓA VÀ RENDER KẾT QUẢ THÀNH CÔNG
# ==============================================================================
flock -u 200
exec 200>&-
rm -f "/tmp/wptt_lock_sao_luu_khoi_phuc_${NAME}.lock" 2>/dev/null

thong_bao_sql=$(echo "$duong_dan_thu_path_sql" | cut -f6 -d '/' | grep "^$NAME" | sed "s/^$NAME//g" | cut -f1 -d '.')
thong_bao_ma_nguon=$(echo "$duong_dan_thu_muc_ma_nguon" | cut -f6 -d '/' | grep "^$NAME" | sed "s/^$NAME//g" | cut -f1 -d '.' | sed 's/-wptt-luy-tien-tung-phan-core//g')

time_str="Không xác định"
if [[ -n "$thong_bao_sql" && -n "$thong_bao_ma_nguon" && "$thong_bao_ma_nguon" == "$thong_bao_sql" ]]; then
  chuyen_doi_thong_bao_gio=$(echo "$thong_bao_ma_nguon" | cut -c 1-2)
  chuyen_doi_thong_bao_ngay=$(echo "$thong_bao_ma_nguon" | cut -f2 -d '_' | cut -c 1-2)
  chuyen_doi_thong_bao_thang=$(echo "$thong_bao_ma_nguon" | cut -f3 -d '_' | cut -c 1-2)
  chuyen_doi_thong_bao_nam=$(echo "$thong_bao_ma_nguon" | cut -f4 -d '_' | cut -c 1-4)
  if [[ -n "$chuyen_doi_thong_bao_gio" && -n "$chuyen_doi_thong_bao_nam" ]]; then
    time_str="${chuyen_doi_thong_bao_gio}:00 - Ngày ${chuyen_doi_thong_bao_ngay}/${chuyen_doi_thong_bao_thang}/${chuyen_doi_thong_bao_nam}"
  fi
fi

echo -e "\n${C_GREEN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_BOLD_WHITE}HOÀN TẤT KHÔI PHỤC WEBSITE LŨY TIẾN${C_RESET}"
echo -e "${C_GREEN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
left_text "Website      : ${C_YELLOW}$NAME${C_RESET}"
left_text "Mốc dữ liệu  : ${C_GREEN}$time_str${C_RESET}"
left_text "Tình trạng   : Đã liên kết Mã nguồn Core, Uploads và Database thành công."
echo -e "${C_GREEN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

[[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-backup-restore-main 1
