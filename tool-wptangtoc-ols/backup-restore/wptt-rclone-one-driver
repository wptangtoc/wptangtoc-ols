#!/bin/bash
# @author: Gia Tuấn
# @website: https://wptangtoc.com
# @email: giatuan@wptangtoc.com
# @since: 2025

function huong_dan() {
  Thiết lập OneDrive đám mây là một giải pháp sao lưu website hiệu quả, an toàn và có khả năng tùy biến cao, muốn kiểm soát sâu hơn vào quy trình sao lưu của mình.

  OneDrive: Là dịch vụ lưu trữ và đồng bộ hóa tệp tin trên đám mây của Microsoft, cung cấp một không gian lưu trữ trực tuyến tiện lợi và dễ truy cập.

  Đây là một giải pháp mạnh mẽ và linh hoạt, cho phép bạn lưu trữ các bản sao lưu website của mình ở một vị trí riêng biệt, tách biệt khỏi máy chủ website, giúp tăng cường bảo vệ dữ liệu.
}

export LANG=en_US.UTF-8
export LC_ALL=en_US.UTF-8
stty iutf8 # Tương thích với bộ gõ tiếng Việt Telex

# ==============================================================================
# NẠP CẤU HÌNH, NGÔN NGỮ VÀ MÀU SẮC
# ==============================================================================
. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null

clear
echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}SAO LƯU & KHÔI PHỤC ➜ Thiết lập Rclone (Microsoft OneDrive)${C_RESET}"
echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

# ==============================================================================
# KIỂM TRA TRẠNG THÁI CÀI ĐẶT TRƯỚC ĐÓ
# ==============================================================================
if [[ ! -d /root/.config ]]; then
  mkdir -p /root/.config
  chmod 751 /root/.config
fi

duong_dan_rclone="/root/.config/rclone/rclone.conf"
if [[ -f "$duong_dan_rclone" ]]; then
  echo -e "${C_YELLOW}Hệ thống phát hiện VPS đã được cấu hình Rclone từ trước!${C_RESET}"
  if grep -q 'onedrive' "$duong_dan_rclone" 2>/dev/null; then
    echo "Trạng thái hiện tại: Đang kết nối với OneDrive."
  else
    echo "Trạng thái hiện tại: Đang kết nối với Google Drive."
  fi
  sleep 3
  exec /etc/wptt/wptt-backup-restore-main 1
  exit
fi

# ==============================================================================
# CÀI ĐẶT BINARY RCLONE (NẾU CHƯA CÓ)
# ==============================================================================
_runing "Đang kiểm tra và cài đặt công cụ Rclone..."
rm -rf /usr/sbin/rclone
rm -rf /usr/bin/rclone
cd /tmp || exit

rm -f install.sh
curl -sO https://rclone.org/install.sh && bash install.sh >/dev/null 2>&1
rm -f install.sh

phienban=1.69.0
if [[ $(uname -m | grep 'aarch64') ]]; then
  cpu_dong_="linux-arm64"
else
  cpu_dong_="linux-amd64"
fi

wget -q "https://downloads.rclone.org/v${phienban}/rclone-v${phienban}-${cpu_dong_}.zip"
if [[ ! -f "/tmp/rclone-v${phienban}-${cpu_dong_}.zip" ]]; then
  wget -q "https://github.com/rclone/rclone/releases/download/v${phienban}/rclone-v${phienban}-${cpu_dong_}.zip" --no-check-certificate
fi

unzip -oq "rclone-v${phienban}-${cpu_dong_}.zip"
cd "rclone-v${phienban}-${cpu_dong_}" || exit
cp -r rclone /usr/sbin/
chmod 755 /usr/sbin/rclone

cd /tmp || exit
rm -rf "/tmp/rclone-v${phienban}-${cpu_dong_}"
rm -f "/tmp/rclone-v${phienban}-${cpu_dong_}.zip"
_rundone "Cài đặt nền tảng Rclone thành công"

# ==============================================================================
# HƯỚNG DẪN LẤY TOKEN (GIAO DIỆN UX BO CONG)
# ==============================================================================
box_inner_width=${box_inner_width:-71}
echo -e "\n${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_BOLD_WHITE}HƯỚNG DẪN XÁC THỰC MICROSOFT ONEDRIVE${C_RESET}"
echo -e "${C_CYAN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
left_text "Để lấy Token bảo mật, bạn hãy copy và dán lệnh sau vào" 2
left_text "Command Line (CMD/PowerShell) trên MÁY TÍNH CÁ NHÂN của bạn:" 2
echo -e "${C_CYAN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
center_text "${C_YELLOW}rclone authorize \"onedrive\"${C_RESET}"
echo -e "${C_CYAN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
left_text "Hoặc truy cập URL này để xem hướng dẫn chi tiết:" 2
center_text "${C_GREEN}https://wptangtoc.com/xac-thuc-drive/${C_RESET}"
echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

# Yêu cầu nhập mã Token
echo -en "${C_CYAN}Dán mã Token OneDrive của bạn vào đây [0=Thoát]: ${C_RESET}"
read -r checkid

if [[ "$checkid" == "0" || -z "$checkid" ]]; then
  echo -e "\n${C_YELLOW}Đã hủy thao tác thiết lập.${C_RESET}"
  sleep 1
  exec /etc/wptt/wptt-backup-restore-main 1
  exit
fi

# ==============================================================================
# CẤU HÌNH TỰ ĐỘNG BẰNG EXPECT SCRIPT
# ==============================================================================
_runing "Đang kết nối và thiết lập Microsoft OneDrive..."
checktool="/usr/bin/expect"
if [[ ! -f $checktool ]]; then
  yum install expect -y -q >/dev/null 2>&1 || dnf install expect -y -q >/dev/null 2>&1 || apt-get install expect -y -q >/dev/null 2>&1
fi

# Chuyển đổi ký tự đặc biệt cho Expect an toàn
checkid=$(echo "$checkid" | sed 's/"/\\042/g')

rm -rf ~/.config/rclone

thietlap=$(expect -c "
set timeout 120
spawn rclone config
expect \"n\"
send \"n\r\"
expect \"name\"
send \"wptangtoc\r\"
expect \"Storage\"
send \"onedrive\r\"
expect \"client_id\"
send \"\r\"
expect \"client_secret\"
send \"\r\"
expect \"region\"
send \"1\r\"
expect \"tenant\"
send \"\r\"
expect \"n\"
send \"n\r\"
expect \"n\"
send \"n\r\"
expect \"config_token\"
send \"$checkid\r\"
expect \"config_type\"
send \"1\r\"
expect \"config_driveid\"
send \"1\r\"
expect \"n\"
send \"y\r\"
expect \"y\"
send \"y\r\"
expect \"n\"
send \"q\r\"
expect eof
") >/dev/null 2>&1

# ==============================================================================
# KIỂM TRA VÀ KHỞI TẠO THƯ MỤC BACKUP
# ==============================================================================
if grep -q 'wptangtoc' /root/.config/rclone/rclone.conf 2>/dev/null; then
  check_tao_thu_muc=$(rclone lsd wptangtoc: 2>/dev/null | grep 'wptangtoc_ols_backup')
  if [[ -z "$check_tao_thu_muc" ]]; then
    rclone mkdir wptangtoc:wptangtoc_ols_backup >/dev/null 2>&1
  fi
fi

# ==============================================================================
# BÁO CÁO KẾT QUẢ
# ==============================================================================
if rclone lsd wptangtoc: 2>/dev/null | grep -q 'wptangtoc_ols_backup'; then
  _rundone "Thiết lập kết nối Microsoft OneDrive thành công"

  echo -e "\n${C_GREEN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_BOLD_WHITE}HOÀN TẤT KẾT NỐI CLOUD${C_RESET}"
  echo -e "${C_GREEN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
  left_text "Nền tảng    : ${C_YELLOW}Microsoft OneDrive${C_RESET}"
  left_text "Trạng thái  : ${C_GREEN}Kết nối API Token hợp lệ.${C_RESET}"
  left_text "Thư mục lưu : Khởi tạo thành công [wptangtoc_ols_backup/]"
  echo -e "${C_GREEN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

  if ls /etc/cron.d/backup*.cron 1>/dev/null 2>&1; then
    echo -e "${C_YELLOW}Ghi chú:${C_RESET} Bạn đang có các tiến trình Auto Backup đã được bật."
    echo -e "Hãy cấu hình lại tính năng [Tự động sao lưu] để hệ thống kích hoạt Upload lên OneDrive nhé."
  fi
else
  _runloi "Thiết lập Microsoft OneDrive thất bại"
  echo -e "${C_RED}❌ Lỗi: Mã Token không hợp lệ hoặc máy chủ không thể kết nối tới Microsoft API.${C_RESET}"
fi

[[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-backup-restore-main 1
