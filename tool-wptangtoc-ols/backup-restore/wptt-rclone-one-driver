#!/bin/bash
# @author: Gia Tuấn
# @website: https://wptangtoc.com
# @email: giatuan@wptangtoc.com
# @since: 2026

function huong_dan() {
  Thiết lập OneDrive đám mây là một giải pháp sao lưu website hiệu quả, an toàn và có khả năng tùy biến cao.
  OneDrive: Là dịch vụ lưu trữ và đồng bộ hóa tệp tin trên đám mây của Microsoft.
  Đây là một giải pháp mạnh mẽ, cho phép bạn lưu trữ các bản sao lưu tách biệt khỏi máy chủ website.
}

export LANG=en_US.UTF-8
export LC_ALL=en_US.UTF-8
stty iutf8 # Tương thích với bộ gõ tiếng Việt Telex

# ==============================================================================
# NẠP CẤU HÌNH, NGÔN NGỮ VÀ MÀU SẮC
# ==============================================================================
. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null

clear
echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}SAO LƯU & KHÔI PHỤC ➜ Thiết lập Rclone (Microsoft OneDrive)${C_RESET}"
echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

# ==============================================================================
# KIỂM TRA TRẠNG THÁI CÀI ĐẶT TRƯỚC ĐÓ
# ==============================================================================
if [[ ! -d /root/.config/rclone ]]; then
  mkdir -p /root/.config/rclone
  chmod 751 /root/.config
fi

duong_dan_rclone="/root/.config/rclone/rclone.conf"
if [[ -f "$duong_dan_rclone" && -s "$duong_dan_rclone" ]]; then
  
  raw_type=$(grep -A 1 '\[wptangtoc\]' "$duong_dan_rclone" 2>/dev/null | grep 'type' | awk -F '=' '{print $2}' | tr -d ' ')
  
  case "$raw_type" in
    drive)    cloud_name="Google Drive" ;;
    onedrive) cloud_name="Microsoft OneDrive" ;;
    s3)       cloud_name="S3 Storage (AWS/R2/MinIO...)" ;;
    *)        cloud_name="Cloud Khác ($raw_type)" ;;
  esac

  echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_YELLOW}PHÁT HIỆN KẾT NỐI CLOUD TỒN TẠI${C_RESET}"
  echo -e "${C_CYAN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
  left_text "Hệ thống phát hiện VPS đã được cấu hình lưu trữ Đám mây từ trước."
  left_text "Trạng thái hiện tại: Đang kết nối nền tảng [ ${C_GREEN}${cloud_name}${C_RESET} ]"
  echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"
  
  msg_title="BẠN CÓ MUỐN GỠ KẾT NỐI CŨ VÀ CÀI ĐẶT LẠI KHÔNG?"
  msg_sub1="Đang dùng : ${C_GREEN}$cloud_name${C_RESET}"
  msg_sub2="Ghi chú  : Dữ liệu cũ trên $cloud_name sẽ không bị xóa."
  
  if ! wptt_xac_nhan "$msg_title" "$msg_sub1" "$msg_sub2" "Đồng ý Xóa và Cài Mới" "Giữ nguyên (Thoát)"; then
    exec /etc/wptt/wptt-backup-restore-main 1
    exit
  fi
  
  rm -f "$duong_dan_rclone"
  clear
fi

# ==============================================================================
# CÀI ĐẶT BINARY RCLONE & CÔNG CỤ JQ (JSON PARSER)
# ==============================================================================
_runing "Đang cài đặt Rclone..."
rm -rf ~/.config/rclone
mkdir -p /root/.config/rclone
rm -rf /usr/sbin/rclone /usr/bin/rclone
cd /tmp || exit


#rclone yêu cầu phải có thư viện unzip bắt buộc thì mới chạy đuợc
if ! command -v unzip &>/dev/null; then #đề phòng máy chủ xoá mất unzip khi cài đặt sẽ phải chạy lại
    if [ -f /etc/redhat-release ]; then
      dnf install unzip -y -q >/dev/null 2>&1 || yum install unzip -y -q >/dev/null 2>&1
    elif [ -f /etc/debian_version ]; then apt-get update -q >/dev/null 2>&1 && apt-get install unzip -y -q >/dev/null 2>&1; fi
fi


if ! command -v jq &> /dev/null; then #cài đặt jq nếu như hệ thống chưa có
  yum install jq -y -q >/dev/null 2>&1 || dnf install jq -y -q >/dev/null 2>&1 || apt-get install jq -y -q >/dev/null 2>&1
fi

phienban=$(curl -s https://downloads.rclone.org/version.txt | awk '{print $2}' | tr -d 'v')
[[ -z "$phienban" ]] && phienban="1.74.2"

if [[ $(uname -m | grep 'aarch64') ]]; then
  cpu_dong_="linux-arm64"
else
  cpu_dong_="linux-amd64"
fi

wget -q "https://downloads.rclone.org/v${phienban}/rclone-v${phienban}-${cpu_dong_}.zip"
if [[ ! -f "rclone-v${phienban}-${cpu_dong_}.zip" ]]; then
  wget -q "https://github.com/rclone/rclone/releases/download/v${phienban}/rclone-v${phienban}-${cpu_dong_}.zip" --no-check-certificate
fi

unzip -oq "rclone-v${phienban}-${cpu_dong_}.zip"
cp -r "rclone-v${phienban}-${cpu_dong_}/rclone" /usr/sbin/
chmod 755 /usr/sbin/rclone
rm -rf "/tmp/rclone-v${phienban}-${cpu_dong_}" "rclone-v${phienban}-${cpu_dong_}.zip"
_rundone "Cài đặt nền tảng Rclone thành công (Phiên bản: $phienban)"

# ==============================================================================
# HƯỚNG DẪN LẤY TOKEN
# ==============================================================================
box_inner_width=${box_inner_width:-78}
echo -e "\n${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_BOLD_WHITE}HƯỚNG DẪN XÁC THỰC MICROSOFT ONEDRIVE${C_RESET}"
echo -e "${C_CYAN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
left_text "${C_RED}CHÚ Ý: KHÔNG CHẠY LỆNH DƯỚI ĐÂY TRÊN VPS NÀY!${C_RESET}" 2
left_text "1. Mở CMD/Terminal trên ${C_YELLOW}MÁY TÍNH CÁ NHÂN${C_RESET} và chạy lệnh sau:" 2
echo -e "${C_CYAN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
center_text "${C_YELLOW}rclone authorize \"onedrive\"${C_RESET}"
echo -e "${C_CYAN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
left_text "2. Trình duyệt mở ra, đăng nhập tài khoản Microsoft." 2
left_text "3. Copy toàn bộ đoạn mã (JSON) được xuất ra." 2
echo -e "${C_CYAN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
left_text "Hoặc truy cập URL này để xem hướng dẫn chi tiết:" 2
center_text "${C_GREEN}https://wptangtoc.com/xac-thuc-drive/${C_RESET}"
echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"
echo -en "${C_CYAN}Dán TOÀN BỘ mã Token OneDrive của bạn vào đây [0=Thoát]: ${C_RESET}"
read -r checkid

if [[ "$checkid" == "0" || -z "$checkid" ]]; then
  echo -e "\n${C_YELLOW}Đã hủy thao tác thiết lập.${C_RESET}"
  sleep 1
  exec /etc/wptt/wptt-backup-restore-main 1
  exit
fi

# Hút nốt bộ đệm nếu khách copy thừa xuống dòng
while read -r -t 0.1 extra_line; do
  checkid="$checkid$extra_line"
done

_runing "Đang giải mã và thiết lập cấu hình OneDrive..."

# ==============================================================================
# LỌC, GIẢI MÃ VÀ BÓC TÁCH JSON BẰNG JQ (HỖ TRỢ CẢ BASE64 & RAW JSON)
# ==============================================================================
clean_token=$(echo "$checkid" | sed 's/.*Paste the following into your remote machine --->//Ig' | sed 's/<---End paste.*//Ig' | tr -d '\n\r ')

if [[ "$clean_token" == eyJ* ]]; then
  # 1. Giải mã Base64
  decoded_json=$(echo "$clean_token" | base64 -d 2>/dev/null)
  
  # 2. Dùng JQ để bóc tách an toàn
  token_str=$(echo "$decoded_json" | jq -r '.token // empty' 2>/dev/null)
  [[ -z "$token_str" ]] && token_str="$decoded_json"
elif [[ "$clean_token" == \{*\} ]]; then
  # Là cục JSON nguyên bản
  token_str="$clean_token"
else
  _runloi "Lỗi cấu trúc Token"
  echo -e "${C_RED}❌ Mã Token không đúng định dạng JSON hoặc Base64 của Rclone.${C_RESET}"
  sleep 3
  exec /etc/wptt/wptt-backup-restore-main 1
  exit
fi

# Đảm bảo cục token_str là JSON hợp lệ
if ! echo "$token_str" | jq . >/dev/null 2>&1; then
  _runloi "Lỗi cấu trúc Token"
  echo -e "${C_RED}❌ Dữ liệu JSON bị hỏng hoặc copy thiếu ký tự.${C_RESET}"
  sleep 3
  exec /etc/wptt/wptt-backup-restore-main 1
  exit
fi

# ==============================================================================
# TRUY XUẤT DRIVE_ID VÀ DRIVE_TYPE TỪ MICROSOFT GRAPH API
# ==============================================================================
_rundone "Nhận diện Token thành công"
_runing "Đang kết nối Microsoft API để trích xuất Drive ID..."

access_token=$(echo "$token_str" | jq -r '.access_token // empty')
drive_id=""
drive_type=""

if [[ -n "$access_token" ]]; then
  # Gọi thẳng vào Microsoft Graph API bằng chính access_token của khách
  drive_info=$(curl -s -X GET "https://graph.microsoft.com/v1.0/me/drive" -H "Authorization: Bearer $access_token")
  
  drive_id=$(echo "$drive_info" | jq -r '.id // empty')
  drive_type=$(echo "$drive_info" | jq -r '.driveType // empty')
fi

# ==============================================================================
# TIÊM CẤU HÌNH VÀO RCLONE.CONF
# ==============================================================================
cat <<EOF > "$duong_dan_rclone"
[wptangtoc]
type = onedrive
token = $token_str
EOF

# Chỉ ghi vào file nếu API lấy được dữ liệu thành công (không bị null)
if [[ -n "$drive_id" && "$drive_id" != "null" ]]; then
  echo "drive_id = $drive_id" >> "$duong_dan_rclone"
fi
if [[ -n "$drive_type" && "$drive_type" != "null" ]]; then
  echo "drive_type = $drive_type" >> "$duong_dan_rclone"
fi

# ==============================================================================
# KIỂM TRA VÀ KHỞI TẠO THƯ MỤC BACKUP
# ==============================================================================
if grep -q 'wptangtoc' "$duong_dan_rclone" 2>/dev/null; then
  check_tao_thu_muc=$(rclone lsd wptangtoc: 2>/dev/null | grep 'wptangtoc_ols_backup')
  if [[ -z "$check_tao_thu_muc" ]]; then
    rclone mkdir wptangtoc:wptangtoc_ols_backup >/dev/null 2>&1
  fi
fi

# ==============================================================================
# BÁO CÁO KẾT QUẢ
# ==============================================================================
if rclone lsd wptangtoc: 2>/dev/null | grep -q 'wptangtoc_ols_backup'; then
  _rundone "Thiết lập kết nối Microsoft OneDrive thành công"

  display_type="Không xác định"
  [[ "$drive_type" == "personal" ]] && display_type="Personal"
  [[ "$drive_type" == "business" ]] && display_type="Business"
  [[ "$drive_type" == "documentLibrary" ]] && display_type="SharePoint"

  echo -e "\n${C_GREEN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_BOLD_WHITE}HOÀN TẤT KẾT NỐI CLOUD${C_RESET}"
  echo -e "${C_GREEN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
  left_text "Nền tảng    : ${C_YELLOW}Microsoft OneDrive ($display_type)${C_RESET}"
  left_text "Drive ID    : ${C_CYAN}${drive_id:-Tự động nhận diện}${C_RESET}"
  left_text "Trạng thái  : ${C_GREEN}Kết nối API Token hợp lệ.${C_RESET}"
  left_text "Thư mục lưu : Khởi tạo thành công [wptangtoc_ols_backup/]"
  echo -e "${C_GREEN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

  if ls /etc/cron.d/backup*.cron 1>/dev/null 2>&1; then
    echo -e "${C_YELLOW}Ghi chú:${C_RESET} Bạn đang có tiến trình Auto Backup."
    echo -e "Hệ thống sẽ dùng OneDrive làm kho lưu trữ chính trong chu kỳ tới."
  fi
else
  _runloi "Thiết lập OneDrive thất bại"
  echo -e "${C_RED}❌ Lỗi: Máy chủ không thể kết nối tới Microsoft API. Token có thể đã hết hạn hoặc thiếu quyền.${C_RESET}"
  rm -f "$duong_dan_rclone"
fi

[[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-backup-restore-main 1
