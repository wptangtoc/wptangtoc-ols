#!/bin/bash

function huong_dan() {
  Tính năng tải [download] file sao lưu từ lưu trữ đám mây để phục vụ khôi phục là quá trình bạn lấy lại các tệp tin mã nguồn và cơ sở dữ liệu website đã được lưu trữ trên dịch vụ đám mây [như Google Drive, OneDrive v.v.] về máy chủ của mình.

  Nói đơn giản, đây là bước quan trọng để mang bản sao lưu từ nơi cất giữ an toàn trên mạng về lại nơi bạn cần [ví dụ: máy chủ web] để có thể tiến hành quá trình phục hồi website sau khi gặp sự cố.

  Mục đích chính:

  * Chuẩn bị cho việc khôi phục website: Các tệp sao lưu cần phải có mặt trên máy chủ hoặc môi trường phù hợp để bạn có thể sử dụng chúng [giải nén, import cơ sở dữ liệu,...] nhằm đưa website trở lại trạng thái hoạt động trước đó.
  * Truy cập dữ liệu offline: Cho phép bạn xem xét, kiểm tra nội dung của bản sao lưu mà không cần kết nối internet [sau khi đã tải về].

  Đây là một bước không thể thiếu trong quy trình khôi phục website từ các bản sao lưu được lưu trữ từ xa.
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null # Nạp thư viện UI Xác nhận

clear
echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}SAO LƯU & KHÔI PHỤC ➜ Tải file backup từ Lưu trữ Cloud${C_RESET}"
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"
echo "Tải file backup từ lưu trữ đám mây: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log

# ==============================================================================
# KIỂM TRA RCLONE VÀ NHẬN DIỆN CLOUD
# ==============================================================================
if ! grep -q 'wptangtoc' /root/.config/rclone/rclone.conf 2>/dev/null; then
  echo -e "${C_RED}❌ Lỗi: Bạn chưa kích hoạt Rclone trên hệ thống này!${C_RESET}"
  sleep 3
  exec /etc/wptt/wptt-backup-restore-main 1
  exit 1
fi

cloud_service="Google Drive"
grep -q 'onedrive' ~/.config/rclone/rclone.conf 2>/dev/null && cloud_service="OneDrive"

# ==============================================================================
# GỌI THƯ VIỆN CHỌN DOMAIN LÕI
# ==============================================================================
. /etc/wptt/tenmien
lua_chon_NAME "Download file backup từ CLOUD"

[[ "$NAME" == "0" || -z "$NAME" ]] && {
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-backup-restore-main 1
  return 2>/dev/null || exit
}

pathcheck="/etc/wptt/vhost/.$NAME.conf"
if [[ ! -f "$pathcheck" ]]; then
  echo -e "\n${C_RED}❌ Tên miền không tồn tại trên hệ thống này!${C_RESET}"
  sleep 3
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-backup-restore-main 1
  return 2>/dev/null || exit
fi

# ==============================================================================
# BƯỚC 1: TRUY XUẤT VÀ TẢI FILE LẦN 1
# ==============================================================================
echo ""
_runing "Đang tải danh sách file từ $cloud_service..."

# Lấy danh sách thô từ Rclone và giữ lại để dùng cho vòng lặp sau
rclone_output=$(rclone lsf "wptangtoc:wptangtoc_ols_backup/$NAME" 2>/dev/null)
mapfile -t selects < <(echo "$rclone_output" | grep -E "\.zip$|\.sql$|\.sql\.gz$|\.tar\.gz$|\.tar\.zst$")

if [[ ${#selects[@]} -eq 0 ]]; then
  _runloi "Truy xuất danh sách thất bại"
  echo -e "${C_YELLOW}Không có file backup hợp lệ nào đang lưu trữ trên Cloud!${C_RESET}"
  sleep 3
  exec /etc/wptt/wptt-backup-restore-main 1
fi
_rundone "Tải danh sách từ $cloud_service thành công"

box_inner_width=${box_inner_width:-71}
echo -e "\n${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}DANH SÁCH FILE BACKUP ĐANG LƯU TRÊN CLOUD${C_RESET}"
echo -e "${C_CYAN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
i=1
for file in "${selects[@]}"; do
  item_text=$(printf "  ${C_CYAN}%3d)${C_RESET} ${C_BOLD_WHITE}%s${C_RESET}" "$i" "$file")
  clean_text=$(printf "  %3d) %s" "$i" "$file")
  item_len=$(echo -n "$clean_text" | awk '{print length($0)}')
  pad=$((box_inner_width - item_len))
  [[ $pad -lt 0 ]] && pad=0
  echo -e "${C_CYAN}│${C_RESET}${item_text}$(printf '%*s' "$pad" "")${C_CYAN}│${C_RESET}"
  ((i++))
done
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯${C_RESET}"

file1=""
while true; do
  echo -en "${C_CYAN}Nhập số thứ tự File cần tải (1-${#selects[@]}) [0=Thoát]: ${C_RESET}"
  read -r REPLY
  if [[ "$REPLY" == "0" ]]; then
    [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-backup-restore-main 1
    exit 0
  elif [[ "$REPLY" =~ ^[0-9]+$ ]] && [ "$REPLY" -ge 1 ] && [ "$REPLY" -le ${#selects[@]} ]; then
    action_index=$((REPLY - 1))
    file1="${selects[$action_index]}"
    break
  else
    echo -e "${C_RED}❌ Lựa chọn không hợp lệ! Vui lòng chọn lại.${C_RESET}"
  fi
done

# XÁC NHẬN TẢI FILE 1
echo ""
dongy_taifile1="n"
if wptt_xac_nhan "Xác nhận để tải File này về máy chủ?" "${C_BOLD_WHITE}Tên file:${C_RESET} ${C_YELLOW}$file1${C_RESET}" "" "Đồng ý Tải" "Hủy bỏ"; then
  dongy_taifile1="y"
  echo ""
  _runing "Đang tải $file1 từ $cloud_service..."
  mkdir -p "/usr/local/backup-website/$NAME"
  rm -f "/usr/local/backup-website/$NAME/$file1"
  rclone copy "wptangtoc:wptangtoc_ols_backup/$NAME/$file1" "/usr/local/backup-website/$NAME" 2>/dev/null
  _rundone "Đã tải thành công $file1"
fi

# ==============================================================================
# BƯỚC 2: LOGIC GỢI Ý TẢI THÊM FILE ĐỒNG BỘ
# ==============================================================================
echo ""
dongy_taifile2="n"
file2=""

# Lọc bỏ file1 (vừa tải) ra khỏi mảng selects để tránh tải trùng lặp
filtered_selects=()
for f in "${selects[@]}"; do
  [[ "$f" != "$file1" ]] && filtered_selects+=("$f")
done
selects=("${filtered_selects[@]}") # Ghi đè lại mảng selects bằng mảng đã lọc

# Chỉ hiển thị gợi ý nếu mảng selects (sau khi lọc) vẫn còn file để tải
if [[ ${#selects[@]} -gt 0 ]]; then
  if echo "$file1" | grep -q "\.zip$\|\.tar\.gz$\|\.tar\.zst$"; then
    echo -e "${C_YELLOW}Gợi ý:${C_RESET} Bạn đã tải file Mã nguồn. Nên tải thêm Database (.sql) để khôi phục đồng bộ."
    ggdrthem="File Database (.sql)"
  elif echo "$file1" | grep -q "\.sql$\|\.sql\.gz$\|\.sql\.zst$"; then
    echo -e "${C_YELLOW}Gợi ý:${C_RESET} Bạn đã tải file Database. Nên tải thêm Mã nguồn (.zip/.tar) để khôi phục đồng bộ."
    ggdrthem="File Mã nguồn (.zip/.tar)"
  fi

  if [[ -n "$ggdrthem" ]]; then
    if wptt_xac_nhan "Bạn có muốn TIẾP TỤC tải thêm $ggdrthem không?" "" "" "Có (Tải thêm)" "Không cần"; then
      echo ""
      echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
      center_text "${C_YELLOW}CHỌN FILE BỔ SUNG TỪ DANH SÁCH CLOUD${C_RESET}"
      echo -e "${C_CYAN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
      i=1
      for file in "${selects[@]}"; do
        item_text=$(printf "  ${C_CYAN}%3d)${C_RESET} ${C_BOLD_WHITE}%s${C_RESET}" "$i" "$file")
        clean_text=$(printf "  %3d) %s" "$i" "$file")
        item_len=$(echo -n "$clean_text" | awk '{print length($0)}')
        pad=$((box_inner_width - item_len))
        [[ $pad -lt 0 ]] && pad=0
        echo -e "${C_CYAN}│${C_RESET}${item_text}$(printf '%*s' "$pad" "")${C_CYAN}│${C_RESET}"
        ((i++))
      done
      echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯${C_RESET}"

      while true; do
        echo -en "${C_CYAN}Nhập số thứ tự File cần tải (1-${#selects[@]}) [0=Bỏ qua]: ${C_RESET}"
        read -r REPLY
        if [[ "$REPLY" == "0" ]]; then
          break
        elif [[ "$REPLY" =~ ^[0-9]+$ ]] && [ "$REPLY" -ge 1 ] && [ "$REPLY" -le ${#selects[@]} ]; then
          action_index=$((REPLY - 1))
          file2="${selects[$action_index]}"
          break
        else
          echo -e "${C_RED}❌ Lựa chọn không hợp lệ! Vui lòng chọn lại.${C_RESET}"
        fi
      done

      if [[ -n "$file2" ]]; then
        dongy_taifile2="y"
        echo ""
        _runing "Đang tải file bổ sung $file2 từ $cloud_service..."
        rm -f "/usr/local/backup-website/$NAME/$file2"
        rclone copy "wptangtoc:wptangtoc_ols_backup/$NAME/$file2" "/usr/local/backup-website/$NAME" 2>/dev/null
        _rundone "Đã tải thành công $file2"
      fi
    fi
  fi
fi

# ==============================================================================
# BẢNG BÁO CÁO TỔNG HỢP (UX BO CONG)
# ==============================================================================
echo -e "\n${C_GREEN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_BOLD_WHITE}TIẾN TRÌNH DOWNLOAD HOÀN TẤT${C_RESET}"
echo -e "${C_GREEN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"

has_error=false

if [[ "$dongy_taifile1" == "y" ]]; then
  if [[ -f "/usr/local/backup-website/$NAME/$file1" ]]; then
    left_text "▪ Đã lưu thành công : ${C_GREEN}$file1${C_RESET}" 2
  else
    left_text "▪ Lỗi tải xuống     : ${C_RED}$file1${C_RESET}" 2
    has_error=true
  fi
fi

if [[ "$dongy_taifile2" == "y" && -n "$file2" ]]; then
  if [[ -f "/usr/local/backup-website/$NAME/$file2" ]]; then
    left_text "▪ Đã lưu thành công : ${C_GREEN}$file2${C_RESET}" 2
  else
    left_text "▪ Lỗi tải xuống     : ${C_RED}$file2${C_RESET}" 2
    has_error=true
  fi
fi

if ! $has_error; then
  echo -e "${C_GREEN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
  left_text "Khu vực lưu trữ: /usr/local/backup-website/$NAME/"
  echo -e "${C_GREEN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"
  echo -e "${C_CYAN}Ghi chú:${C_RESET} File đã sẵn sàng. Bạn có thể sử dụng Menu Khôi phục ngay bây giờ."
else
  echo -e "${C_GREEN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
  left_text "${C_YELLOW}Trạng thái: Có file bị lỗi hoặc không đầy đủ trong quá trình tải!${C_RESET}"
  echo -e "${C_GREEN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"
fi

[[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-backup-restore-main 1
