function huong_dan() {
  Tính năng tự động sao lưu database là một cơ chế được thiết lập để hệ thống tự động tạo ra các bản sao [backup] của cơ sở dữ liệu [database] website của bạn theo một lịch trình định sẵn mà không cần sự can thiệp thủ công.

  Nói đơn giản, thay vì bạn phải nhớ và tự mình chạy lệnh để sao lưu database mỗi ngày hoặc mỗi tuần tận chí là mỗi tháng, hệ thống sẽ tự động làm điều đó. Ví dụ, nó có thể tự động xuất toàn bộ dữ liệu từ MySQL, của bạn ra một tệp tin vào lúc 2 giờ sáng mỗi ngày.

  Tại sao nó cực kỳ quan trọng:

  * Bảo vệ dữ liệu cốt lõi: Database chứa các thông tin quan trọng như nội dung website, thông tin người dùng, đơn hàng, v.v. Mất database có thể đồng nghĩa với mất trắng website.
  * Khôi phục nhanh khi có sự cố: Nếu website gặp lỗi, bị tấn công, hoặc dữ liệu bị hỏng, bản sao lưu database tự động gần nhất giúp bạn khôi phục lại trạng thái ổn định một cách nhanh chóng.
  * Giảm thiểu rủi ro do con người: Tránh trường hợp quên sao lưu hoặc sao lưu không đúng cách.

  Tính năng thiết lập tự động sao lưu database website [định dạng .sql hoặc .sql.gz - nếu đã thiết lập]
}

. /etc/wptt/.wptt.conf
if [[ $ngon_ngu = '' ]]; then
  ngon_ngu='vi'
fi
. /etc/wptt/lang/$ngon_ngu.sh

echo ""
echo ""
echo ""
echo "========================================================================="
echo "|$backup_restore => $tu_dong_sao_luu_database               |"
echo "========================================================================="
echo ""
echo ""
if [ "$(ls -A /etc/wptt/vhost | grep -v '^\.\.conf$' | sort -uV)" ]; then
  echo "========================================================================="
  echo "Danh sách domain đã kích hoạt tự động backup database:"
  echo "========================================================================="

  for entry in $(ls -A /etc/wptt/vhost | grep -v '^\.\.conf$' | sort -uV); do
    domain=$(echo $entry | sed 's/^.//' | sed 's/.conf//')
    path="/etc/cron.d/backup-database$domain.cron"

    if [[ -f "$path" ]]; then
      checkauto="Đã kích hoạt tự động lúc "
      # Dùng awk để lấy chính xác các cột
      cron_line=$(cat "$path" | grep -v "^#")
      checkauto1=$(echo "$cron_line" | awk '{print $2}') # Giờ
      check_dom=$(echo "$cron_line" | awk '{print $3}')  # Ngày trong tháng
      checkauto2=$(echo "$cron_line" | awk '{print $5}') # Ngày trong tuần

      kiemtra_doi_so=$(grep -c "1998" /etc/wptt-auto/$domain-auto-backup-database 2>/dev/null)
      tinhnang=""

      if [[ "$kiemtra_doi_so" = "1" ]]; then
        if grep -q 'onedrive' ~/.config/rclone/rclone.conf 2>/dev/null; then
          tinhnang="| backup xong uploads lên OneDrive"
        else
          tinhnang="| backup xong uploads lên Google Drive"
        fi
      elif [[ "$kiemtra_doi_so" = "2" ]]; then
        if grep -q 'onedrive' ~/.config/rclone/rclone.conf 2>/dev/null; then
          tinhnang="| backup xong uploads lên OneDrive và xóa luôn file backup tại local"
        else
          tinhnang="| backup xong uploads lên Google Drive và xóa luôn file backup tại local"
        fi
      fi

      # Logic nhận diện Hàng Tháng -> Hàng Tuần -> Hàng Ngày
      if [[ "$check_dom" != "*" && -n "$check_dom" ]]; then
        thu123=" giờ ngày $check_dom hàng tháng"
      elif [[ "$checkauto2" != "*" && -n "$checkauto2" ]]; then
        case "$checkauto2" in
        0 | 7) thu123=" giờ chủ nhật hàng tuần" ;;
        1) thu123=" giờ thứ hai hàng tuần" ;;
        2) thu123=" giờ thứ ba hàng tuần" ;;
        3) thu123=" giờ thứ tư hàng tuần" ;;
        4) thu123=" giờ thứ năm hàng tuần" ;;
        5) thu123=" giờ thứ sáu hàng tuần" ;;
        6) thu123=" giờ thứ bảy hàng tuần" ;;
        esac
      else
        thu123=" giờ hàng ngày"
      fi

    else
      checkauto="Chưa được kích hoạt"
      checkauto1=""
      thu123=" tự động sao lưu backup database"
      tinhnang=""
    fi
    echo "Website $domain $checkauto$checkauto1$thu123 $tinhnang"
  done

  # Xử lý cho Toàn bộ website (All website)
  if [[ ! -f /etc/cron.d/backup-all-database-wptt-ols.cron ]]; then
    echo "Tính năng sao lưu toàn bộ database website chưa được thiết lập"
  else
    checkauto="Đã kích hoạt tự động lúc "
    cron_line_all=$(cat /etc/cron.d/backup-all-database-wptt-ols.cron | grep -v "^#")
    checkauto1=$(echo "$cron_line_all" | awk '{print $2}')
    check_dom_all=$(echo "$cron_line_all" | awk '{print $3}')
    checkauto2=$(echo "$cron_line_all" | awk '{print $5}')

    kiemtra_doi_so=$(grep -c "1998" /etc/wptt-auto/all-database-wptt-ols-auto-backup 2>/dev/null)
    tinhnang=""

    if [[ "$kiemtra_doi_so" = "1" ]]; then
      tinhnang="| backup xong uploads lên Drive"
    elif [[ "$kiemtra_doi_so" = "2" ]]; then
      tinhnang="| backup xong uploads lên Drive và xóa luôn file backup tại local"
    fi

    # Logic nhận diện Hàng Tháng -> Hàng Tuần -> Hàng Ngày cho All Website
    if [[ "$check_dom_all" != "*" && -n "$check_dom_all" ]]; then
      thu123=" giờ ngày $check_dom_all hàng tháng"
    elif [[ "$checkauto2" != "*" && -n "$checkauto2" ]]; then
      case "$checkauto2" in
      0 | 7) thu123=" giờ chủ nhật hàng tuần" ;;
      1) thu123=" giờ thứ hai hàng tuần" ;;
      2) thu123=" giờ thứ ba hàng tuần" ;;
      3) thu123=" giờ thứ tư hàng tuần" ;;
      4) thu123=" giờ thứ năm hàng tuần" ;;
      5) thu123=" giờ thứ sáu hàng tuần" ;;
      6) thu123=" giờ thứ bảy hàng tuần" ;;
      esac
    else
      thu123=" giờ hàng ngày"
    fi

    echo "Toàn bộ website $checkauto$checkauto1$thu123 $tinhnang"
  fi

  echo "========================================================================="
  echo
fi

. /etc/wptt/.wptt.conf

function lua_chon_NAME() {
  NAME=""
  if [ "$(ls -At /etc/wptt/vhost)" ]; then
    selects=()
    for entry in $(ls -A /etc/wptt/vhost | grep -v '^\.\.conf$' | sort -uV); do
      NAME=$(echo $entry | sed 's/^.//' | sed 's/.conf//')
      if [[ ! -f /etc/cron.d/backup-database$NAME.cron ]]; then
        selects+=("$NAME")
      fi
    done

    if [[ ! -f /etc/cron.d/backup-all-database-wptt-ols.cron ]]; then
      selects+=("Tất cả website")
    fi
    if [[ $selects = '' ]]; then
      echo "Tất cả domain trên hệ thống đã được kích hoạt sao lưu backup database tự động hết rồi"
      exec /etc/wptt/wptt-backup-restore-main 1
    fi

    PS3="
-//- Nhập lựa chọn website của bạn [0=Thoát]: "
    select select in "${selects[@]}"; do
      NAME=$select
      index=$REPLY
      break
    done
  else
    clear
    echo "Không xác định được domain nào."
    exit
  fi
}

echo ""
echo ""
echo "Lựa chọn website bạn muốn thiết lập tự động backup sao lưu database: "
echo ""
lua_chon_NAME

. /etc/wptt/echo-color
if [[ "$NAME" = "0" || "$NAME" = "" ]]; then
  exec /etc/wptt/wptt-backup-restore-main 1
fi

if [[ $NAME != 'Tất cả website' ]]; then
  pathcheck="/etc/wptt/vhost/.$NAME.conf"
  if [[ ! -f "$pathcheck" ]]; then
    clear
    echoDo "Tên miền không tồn tại trên hệ thống này"
    sleep 3
    check_menu_wptangtoc_active=$1
    if [[ $check_menu_wptangtoc_active = "98" ]]; then
      exec /etc/wptt/wptt-backup-restore-main 1
    fi
    return 2>/dev/null
    exit
  fi
fi

if [ -f /etc/cron.d/backup-database"$NAME".cron ]; then
  echoDo "website $NAME đã được kích hoạt tự động sao lưu backup trước đó rồi!"
  sleep 3
  exec /etc/wptt/wptt-backup-restore-main 1
  exit
fi

if [[ -f /etc/wptt/vhost/."$NAME".conf ]]; then
  . /etc/wptt/vhost/."$NAME".conf
fi

echo -n "Bạn muốn tự động backup website lúc mấy giờ? [0-23]: "
read gio

if [[ ! $gio =~ ^-?[0-9]+$ ]]; then
  echo "Bạn nhập sai dữ liệu thời gian từ 0 đến 23, hệ thống sẽ tự động chọn giá trị là 1h sáng"
  gio="1"
fi

if (("$gio" > "23")); then
  echo "Bạn nhập sai dữ liệu thời gian từ 0 đến 23, hệ thống sẽ tự động chọn giá trị là 1h sáng"
  gio="1"
fi

if [[ "$gio" = "" ]]; then
  gio="1"
  echo "Bạn không nhập dữ liệu hệ thống sẽ tự động chọn là 1h sáng"
fi

echo "Bạn muốn tự động backup website vào thứ mấy? "
echo ""
. /etc/wptt/wptt-times-tuan
tuan

if [ "$thu" = "0" ] || [ "$thu" = "7" ]; then
  thu12="chủ nhật hàng tuần"
fi
if [ "$thu" = "1" ]; then
  thu12="thứ hai hàng tuần"
fi
if [ "$thu" = "2" ]; then
  thu12="thứ ba hàng tuần"
fi
if [ "$thu" = "3" ]; then
  thu12="thứ tư hàng tuần"
fi
if [ "$thu" = "4" ]; then
  thu12="thứ năm hàng tuần"
fi
if [ "$thu" = "5" ]; then
  thu12="thứ sáu hàng tuần"
fi
if [ "$thu" = "6" ]; then
  thu12="thứ bảy hàng tuần"
fi

if [ "$thu" = "*" ]; then
  thu12="hàng ngày"
fi

if [ "$thu" = "9" ]; then
  thu12="ngày $ngay_cua_thang hàng tháng"
fi

#ngẫu nhiên phút: để có thể tránh cron 0 để tránh cao điểm nhất, nhiều khi anh em dùng 1 tài khoản onedrive hoặc onedrive cho nhiều vps
phut=$(shuf -i2-58 -n1)
if [[ $phut = '' ]]; then
  phut='0'
fi
echo "Bạn có chắc chắn muốn tự động sao lưu database $NAME lúc $phut phút $gio giờ $thu12 ?"

prompt="Nhập lựa chọn của bạn [1-2]: "
response="n"
options=("Đồng ý" "Không đồng ý")
PS3="$prompt"
select opt in "${options[@]}"; do
  case "$REPLY" in
  1)
    response="y"
    break
    ;;

  2)
    response="n"
    break
    ;;

  $((${#options[@]} + 1)))
    printf "\nBạn nhập sai hệ thống sẽ chọn là không đồng ý\n"
    break
    ;;
  *)
    printf "Bạn nhập sai hệ thống sẽ chọn là không đồng ý\n"
    break
    ;;
  esac
done

if [[ "$response" = "y" ]]; then
  mkdir -p /etc/wptt-auto
  mkdir -p /usr/local/backup-website/"$NAME"

  checkdathietlap=$(grep -rnw '/root/.config/rclone/rclone.conf' -e "wptangtoc" >>/dev/null 2>&1 && echo 1)
  if [[ $checkdathietlap ]]; then
    echo "Bạn có muốn uploads file backup tự động lên lưu trữ đám mây Google Driver không?"
    prompt="Nhập lựa chọn của bạn [1-2]: "
    uploads="n"
    options=("Đồng ý" "Không đồng ý")
    PS3="$prompt"
    select opt in "${options[@]}"; do
      case "$REPLY" in
      1)
        uploads="y"
        break
        ;;

      2)
        uploads="n"
        break
        ;;

      $((${#options[@]} + 1)))
        printf "\nBạn nhập sai hệ thống sẽ chọn là không đồng ý\n"
        break
        ;;
      *)
        printf "Bạn nhập sai hệ thống sẽ chọn là không đồng ý\n"
        break
        ;;
      esac
    done

    if [[ "$uploads" = "y" ]]; then
      tuan1="1998"
      echo "Khi đã uploads lên Google Driver bạn có muốn tự động xóa file backup tại local không?"
      prompt="Nhập lựa chọn của bạn [1-2]: "
      delete="n"
      options=("Đồng ý" "Không đồng ý")
      PS3="$prompt"
      select opt in "${options[@]}"; do
        case "$REPLY" in
        1)
          delete="y"
          break
          ;;

        2)
          delete="n"
          break
          ;;

        $((${#options[@]} + 1)))
          printf "\nBạn nhập sai hệ thống sẽ chọn là không đồng ý\n"
          break
          ;;
        *)
          printf "Bạn nhập sai hệ thống sẽ chọn là không đồng ý\n"
          break
          ;;
        esac
      done

      if [[ "$delete" = "y" ]]; then
        tuan2="1998"
      else
        tuan2="12345"
      fi

    fi

  fi

  mkdir -p /etc/wptt-auto
  if [[ $NAME = 'Tất cả website' ]]; then #setup tất cả website
    cat >"/etc/wptt-auto/all-database-wptt-ols-auto-backup" <<END
#!/bin/bash
ionice -c 3 nice -n 19 /bin/bash /etc/wptt/db/wptt-saoluu-database "$NAME" $tuan1 $tuan2
END
    chmod 740 /etc/wptt-auto/all-database-wptt-ols-auto-backup
  else
    cat >"/etc/wptt-auto/$NAME-auto-backup-database" <<END
#!/bin/bash
ionice -c 3 nice -n 19 /bin/bash /etc/wptt/db/wptt-saoluu-database $NAME $tuan1 $tuan2
END
    chmod 740 /etc/wptt-auto/$NAME-auto-backup-database
  fi

  cron_thuc_thi="$phut $gio * * $thu"
  if [[ $thu = '9' ]]; then # thêm option hàng tháng
    thu='*'
    cron_thuc_thi="$phut $gio $ngay_cua_thang * $thu"
  fi

  if [[ $NAME = 'Tất cả website' ]]; then #setup tất cả website
    cat >"/etc/cron.d/backup-all-database-wptt-ols.cron" <<END
$cron_thuc_thi root /etc/wptt-auto/all-database-wptt-ols-auto-backup >/dev/null 2>&1
END
  else
    cat >"/etc/cron.d/backup-database$NAME.cron" <<END
$cron_thuc_thi root /etc/wptt-auto/$NAME-auto-backup-database >/dev/null 2>&1
END
  fi

  if $(cat /etc/*release | grep -q "Ubuntu"); then
    if [[ $NAME = 'Tất cả website' ]]; then #setup tất cả website
      ln -sf /etc/cron.d/backup-all-database-wptt-ols.cron /etc/cron.d/backup-all-database-wptt-ols_cron
    else
      NAME_CRON_ubuntu=${NAME//[.]/_}
      ln -sf /etc/cron.d/backup-database${NAME}.cron /etc/cron.d/backup-database${NAME_CRON_ubuntu}_cron
    fi
    systemctl restart cron.service
  else
    systemctl restart crond.service
  fi

  if [[ $NAME = 'Tất cả website' ]]; then #setup tất cả website
    echo "-------------------------------------------------------------------------"
    echo "Tất cả website sẽ được tự động sao lưu database vào $gio giờ $thu12 .      "
    echo "-------------------------------------------------------------------------"
    unset NAME
  else
    echo "-------------------------------------------------------------------------"
    echo "website $NAME sẽ được tự động sao lưu database vào $gio giờ $thu12 .      "
    echo "-------------------------------------------------------------------------"
  fi

  echo "$duong_dan_thu_muc backup database :/usr/local/backup-website/$NAME   "
  if [[ "$uploads" = "y" ]]; then
    echo "-------------------------------------------------------------------------"
    echo "File backup trên Google Driver sẽ tự động lưu trữ tại thư mục: wptangtoc_ols_backup/$NAME"
  fi
  echo "-------------------------------------------------------------------------"
  echo "Nếu cần khôi phục lại website thì bạn hãy truy cập vào menu của WPTangToc OLS rồi sử dụng tính năng khôi phục website"
  echo "-------------------------------------------------------------------------"
fi

check_menu_wptangtoc_active=$1
if [[ $check_menu_wptangtoc_active = "98" ]]; then
  exec /etc/wptt/wptt-backup-restore-main 1
fi
