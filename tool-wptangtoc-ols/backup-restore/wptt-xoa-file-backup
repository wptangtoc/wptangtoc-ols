function huong_dan() {
  Tính năng xóa file backup thủ công đơn giản là việc bạn tự tay lựa chọn và xóa các tệp tin hoặc thư mục sao lưu [backup] không còn cần thiết nữa.

  Khi nào cần dùng:

  * Khi bạn cần giải phóng dung lượng lưu trữ ngay lập tức.
  * Khi bạn biết chắc chắn một bản sao lưu cụ thể không còn giá trị hoặc bị lỗi.
  * Để dọn dẹp đột xuất ngoài lịch trình tự động.

  Lưu ý quan trọng: Việc xóa thủ công cần cẩn trọng để tránh vô tình xóa nhầm những bản sao lưu quan trọng mà bạn có thể cần đến sau này.
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null

clear
echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}Sao lưu & khôi phục ➜ Quản lý Xóa file Backup${C_RESET}"
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯${C_RESET}\n"

# ==============================================================================
# 1. GỌI MENU CHỌN DOMAIN
# ==============================================================================
. /etc/wptt/tenmien
lua_chon_NAME "Xóa file Backup"

[[ "$NAME" == "0" || -z "$NAME" ]] && exec /etc/wptt/wptt-backup-restore-main 1

pathcheck="/etc/wptt/vhost/.$NAME.conf"
[[ ! -f "$pathcheck" ]] && echo -e "\n${C_RED}❌ Tên miền không tồn tại trên hệ thống này${C_RESET}" && sleep 2 && exec /etc/wptt/wptt-backup-restore-main 1

backup_dir="/usr/local/backup-website/$NAME"
if [[ ! -d "$backup_dir" ]] || [[ -z "$(ls -A "$backup_dir" 2>/dev/null)" ]]; then
  echo -e "\n${C_YELLOW}⚠️ Thư mục trống. Không có file backup nào của $NAME tồn tại trên hệ thống.${C_RESET}"
  sleep 3
  exec /etc/wptt/wptt-backup-restore-main 1
fi

# ==============================================================================
# 2. VÒNG LẶP QUẢN LÝ TỆP TIN (DASHBOARD)
# ==============================================================================
while true; do
  clear
  echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_YELLOW}QUẢN LÝ DUNG LƯỢNG BACKUP ➜ ${C_BOLD_WHITE}$NAME${C_RESET}"
  echo -e "${C_CYAN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"

  box_inner_width=${box_inner_width:-71}

  # Thống kê nhanh
  total_files=$(ls -1q "$backup_dir" 2>/dev/null | wc -l)
  total_size=$(du -sh "$backup_dir" 2>/dev/null | awk '{print $1}')
  db_files=$(ls -1q "$backup_dir"/*.sql* 2>/dev/null | wc -l)
  zip_files=$(ls -1q "$backup_dir"/*.zip* "$backup_dir"/*.tar* 2>/dev/null | wc -l)

  # ============================================================================
  # FIX UX: Tự động đo độ dài chuỗi thống kê để căn lề phải thẳng tắp
  # ============================================================================
  raw_stat="  Tổng dung lượng: ${total_size}  |  Mã nguồn: ${zip_files} file  |  Database: ${db_files} file"
  len_stat=${#raw_stat}
  pad_stat=$((box_inner_width - len_stat))
  [[ $pad_stat -lt 0 ]] && pad_stat=0

  colored_stat="  ${C_BOLD_WHITE}Tổng dung lượng:${C_RESET} ${C_GREEN}${total_size}${C_RESET}  |  ${C_BOLD_WHITE}Mã nguồn:${C_RESET} ${C_YELLOW}${zip_files} file${C_RESET}  |  ${C_BOLD_WHITE}Database:${C_RESET} ${C_YELLOW}${db_files} file${C_RESET}"

  echo -e "${C_CYAN}│${C_RESET}${colored_stat}$(printf '%*s' "$pad_stat" "")${C_CYAN}│${C_RESET}"

  title_text="Chọn file cần xóa (Mới nhất xếp trên cùng):"
  clean_title=$(echo -e "$title_text" | sed "s/\x1B\[[0-9;]*[a-zA-Z]//g")
  len=${#clean_title}
  pad_r=$((box_inner_width - len - 2))
  [[ $pad_r -lt 0 ]] && pad_r=0

  echo -e "${C_CYAN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
  echo -e "${C_CYAN}│${C_RESET}  ${C_YELLOW}${title_text}${C_RESET}$(printf '%*s' "$pad_r" "")${C_CYAN}│${C_RESET}"

  line_len=$((len + 3))
  pad_line_r=$((box_inner_width - line_len))
  [[ $pad_line_r -lt 0 ]] && pad_line_r=0
  short_line=$(printf "%${line_len}s" "" | sed 's/ /─/g')
  echo -e "${C_CYAN}├${short_line}$(printf '%*s' "$pad_line_r" "")│${C_RESET}"

  selects=()
  mapfile -t file_list < <(ls -1t "$backup_dir" 2>/dev/null)

  i=1
  for f in "${file_list[@]}"; do
    fsize=$(du -sh "$backup_dir/$f" 2>/dev/null | cut -f1)
    selects+=("$f|$fsize")

    clean_row=$(printf "  %3d) [%-7s] %s" "$i" "$fsize" "$f")
    item_row=$(printf "  ${C_CYAN}%3d)${C_RESET} [${C_GREEN}%-7s${C_RESET}] ${C_BOLD_WHITE}%s${C_RESET}" "$i" "$fsize" "$f")
    pad=$((box_inner_width - ${#clean_row}))
    [[ $pad -lt 0 ]] && pad=0

    echo -e "${C_CYAN}│${C_RESET}${item_row}$(printf '%*s' "$pad" "")${C_CYAN}│${C_RESET}"
    ((i++))
  done
  echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯${C_RESET}"

  if [[ ${#selects[@]} -eq 0 ]]; then
    echo -e "\n${C_GREEN}Đã dọn dẹp sạch sẽ toàn bộ thư mục Backup!${C_RESET}"
    sleep 2
    break
  fi

  echo -en "${C_CYAN}Nhập số thứ tự file cần xóa (1-${#selects[@]}) [0=Thoát]: ${C_RESET}"
  read -r REPLY

  [[ "$REPLY" == "0" ]] && break

  if [[ "$REPLY" =~ ^[0-9]+$ ]] && [ "$REPLY" -ge 1 ] && [ "$REPLY" -le ${#selects[@]} ]; then
    idx=$((REPLY - 1))
    val="${selects[$idx]}"
    target_file="${val%|*}"
    target_size="${val#*|}"
    target_path="$backup_dir/$target_file"

    # ==============================================================================
    # KHỐI UX XÁC NHẬN "ĐỒNG Ý/KHÔNG ĐỒNG Ý" BO CONG ĐỒNG BỘ
    # ==============================================================================
    echo -e "\n${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"

    msg_title="Bạn có muốn xóa file backup này không?"
    pad_title=$((box_inner_width - ${#msg_title} - 2))
    echo -e "${C_CYAN}│${C_RESET}  ${C_YELLOW}${msg_title}${C_RESET}$(printf '%*s' "$pad_title" "")${C_CYAN}│${C_RESET}"

    echo -e "${C_CYAN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"

    # Hiển thị Tên File và Dung lượng gọn gàng
    clean_file="File: $target_file"
    pad_file=$((box_inner_width - ${#clean_file} - 2))
    echo -e "${C_CYAN}│${C_RESET}  ${C_BOLD_WHITE}File:${C_RESET} $target_file$(printf '%*s' "$pad_file" "")${C_CYAN}│${C_RESET}"

    clean_size="Giải phóng: $target_size"
    pad_size=$((box_inner_width - ${#clean_size} - 2))
    echo -e "${C_CYAN}│${C_RESET}  ${C_BOLD_WHITE}Giải phóng:${C_RESET} ${C_GREEN}$target_size${C_RESET}$(printf '%*s' "$pad_size" "")${C_CYAN}│${C_RESET}"

    echo -e "${C_CYAN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"

    opt1="1) Đồng ý (Xóa vĩnh viễn)"
    pad1=$((box_inner_width - ${#opt1} - 2))
    echo -e "${C_CYAN}│${C_RESET}  ${C_CYAN}1)${C_RESET} Đồng ý (Xóa vĩnh viễn)$(printf '%*s' "$pad1" "")${C_CYAN}│${C_RESET}"

    opt2="2) Không đồng ý (Hủy thao tác)"
    pad2=$((box_inner_width - ${#opt2} - 2))
    echo -e "${C_CYAN}│${C_RESET}  ${C_CYAN}2)${C_RESET} Không đồng ý (Hủy thao tác)$(printf '%*s' "$pad2" "")${C_CYAN}│${C_RESET}"

    echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯${C_RESET}"

    # Vòng lặp nhận phím an toàn
    while true; do
      echo -en "${C_CYAN}Nhập lựa chọn của bạn [1-2]: ${C_RESET}"
      read -r confirm
      case "$confirm" in
      1)
        dongy="y"
        break
        ;;
      2)
        dongy="n"
        break
        ;;
      *)
        echo -e "${C_RED}❌ Bạn nhập sai, vui lòng nhập 1 hoặc 2.${C_RESET}"
        ;;
      esac
    done

    if [[ "$dongy" == "y" ]]; then
      rm -f "$target_path"
      echo "Xoá file backup website $NAME ($target_path): $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log
      _rundone "Đã xóa thành công: $target_file"
      sleep 1.5
    else
      echo -e "${C_YELLOW}Đã hủy thao tác xóa.${C_RESET}"
      sleep 1
    fi
  else
    echo -e "${C_RED}❌ Lựa chọn không hợp lệ!${C_RESET}"
    sleep 1
  fi
done

# ==============================================================================
# CẢNH BÁO DUNG LƯỢNG Ổ CỨNG
# ==============================================================================
free_mb=$(df -m / | awk 'NR==2 {print $4}')

if [[ -n "$free_mb" ]] && ((free_mb < 2048)); then
  echo -e "\n${C_RED}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_YELLOW}CẢNH BÁO NGUY HIỂM: FULL DISK (Ổ CỨNG SẮP ĐẦY)${C_RESET}"
  echo -e "${C_RED}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
  echo -e "${C_RED}│${C_RESET} Máy chủ chỉ còn dưới ${C_RED}2GB${C_RESET} dung lượng trống!                               ${C_RED}│${C_RESET}"
  echo -e "${C_RED}│${C_RESET} Disk hiện tại: ${C_YELLOW}$(df -h / | awk 'NR==2 {printf "%s / %s (Sử dụng %s)", $3, $2, $5}')${C_RESET}                   ${C_RED}│${C_RESET}"
  echo -e "${C_RED}│${C_RESET} Khuyến nghị: Gõ lệnh ${C_BOLD_WHITE}wptt disk${C_RESET} để quét các thư mục chiếm bộ nhớ.   ${C_RED}│${C_RESET}"
  echo -e "${C_RED}╰───────────────────────────────────────────────────────────────────────╯${C_RESET}"
fi

exec /etc/wptt/wptt-backup-restore-main 1
