#!/bin/bash
# @author: Gia Tuấn
# @website: https://wptangtoc.com
# @description: Auto Delete Cronjob Cloud (Drive, OneDrive, S3)
# @since: 2026

NAME=$1
ngay=$2
RCLONE_CONF="/root/.config/rclone/rclone.conf"

# Kiểm tra trạng thái kích hoạt Cloud
if ! grep -q 'wptangtoc' "$RCLONE_CONF" 2>/dev/null; then
  echo "Bạn chưa kích hoạt Rclone Cloud"
  exit 1
fi

# ==============================================================================
# NHẬN DIỆN CLOUD VÀ THƯ MỤC LƯU TRỮ
# ==============================================================================
CLOUD_DIR="wptangtoc_ols_backup"
DELETE_FLAGS=()

# Bắt buộc quét đúng tham số "type =" để tránh nhận diện nhầm
if grep -E -q '^[[:space:]]*type[[:space:]]*=[[:space:]]*onedrive' "$RCLONE_CONF" 2>/dev/null; then
  if grep -q 'personal' "$RCLONE_CONF" 2>/dev/null; then
    DELETE_FLAGS=() # Personal OneDrive không hỗ trợ hard-delete cờ phụ
  else
    DELETE_FLAGS=("--onedrive-hard-delete") # OneDrive Business hoặc SharePoint
  fi
elif grep -E -q '^[[:space:]]*type[[:space:]]*=[[:space:]]*s3' "$RCLONE_CONF" 2>/dev/null; then
  CLOUD_DIR="wptangtoc-ols-backup" # S3 bắt buộc dùng dấu gạch ngang
  DELETE_FLAGS=() # S3 tự động hard-delete, không cần cờ phụ
else
  # Mặc định là Google Drive
  DELETE_FLAGS=("--drive-use-trash=false") # Xóa vĩnh viễn không vào thùng rác Drive
fi

# Fallback: Tránh trường hợp dùng Drive/OneDrive nhưng đã lỡ tạo Bucket gạch ngang trước đó
if rclone lsd wptangtoc: 2>/dev/null | grep -q 'wptangtoc-ols-backup'; then
  CLOUD_DIR="wptangtoc-ols-backup"
fi

# ==============================================================================
# HÀM XÓA FILE (TÁI SỬ DỤNG CHO 1 HOẶC NHIỀU WEBSITE)
# ==============================================================================
xoa_backup_cu() {
  local domain="$1"
  # Quét danh sách file quá hạn (Fix Regex chuẩn hóa tất cả các đuôi mở rộng)
  danh_sach_file_het_han=($(rclone ls "wptangtoc:$CLOUD_DIR/$domain" --min-age "${ngay}d" 2>/dev/null | awk '{print $2}' | grep -E '\.(zip|sql|sql\.gz|tar\.gz|tar\.zst|sql\.zst)$'))
  
  for file in "${danh_sach_file_het_han[@]}"; do
    if [[ -n "$file" ]]; then
      # Truyền linh hoạt các cờ xóa (flags) tùy thuộc vào từng nền tảng Cloud
      if [[ ${#DELETE_FLAGS[@]} -gt 0 ]]; then
        rclone -v "${DELETE_FLAGS[@]}" delete "wptangtoc:$CLOUD_DIR/$domain/$file"
      else
        rclone -v delete "wptangtoc:$CLOUD_DIR/$domain/$file"
      fi
    fi
  done
}

# ==============================================================================
# THỰC THI CHÍNH
# ==============================================================================
if [[ "$NAME" == 'Tất cả website' ]]; then
  # Quét toàn bộ vhost nếu chọn All
  for entry in $(ls -A /etc/wptt/vhost | grep -v '^\.\.conf$' | sort -uV); do
    domain=$(echo "$entry" | sed 's/^.//' | sed 's/.conf//')
    if [ "$domain" != "${domain/./}" ] && [ "$domain" != '.' ]; then
      xoa_backup_cu "$domain"
    fi
  done
else
  # Chỉ thực thi 1 website cụ thể
  xoa_backup_cu "$NAME"
fi
