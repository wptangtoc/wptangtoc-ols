#!/bin/bash
# @author: Gia Tuấn
# @website: https://wptangtoc.com
# @description: Thiết lập Rclone S3
# @since: 2026

function huong_dan() {
  Thiết lập Lưu trữ Đám mây [Cloud Storage] chuẩn S3 Compatible là giải pháp siêu tốc, chuyên nghiệp và tối ưu chi phí nhất.
  - Hỗ trợ các nền tảng: Cloudflare R2, Amazon S3, DigitalOcean Spaces, MinIO và các hãng S3 Custom...
}

export LANG=en_US.UTF-8
export LC_ALL=en_US.UTF-8
stty iutf8 # Tương thích với bộ gõ tiếng Việt Telex

# ==============================================================================
# NẠP CẤU HÌNH, NGÔN NGỮ VÀ MÀU SẮC
# ==============================================================================
. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null

clear
print_border_top
center_text "${C_YELLOW}SAO LƯU ĐÁM MÂY ➜ Cấu Hình S3 Compatible (R2, AWS)${C_RESET}"
print_border_bot
echo ""

# ==============================================================================
# KIỂM TRA TRẠNG THÁI CÀI ĐẶT TRƯỚC ĐÓ
# ==============================================================================
mkdir -p /root/.config/rclone
chmod 751 /root/.config

duong_dan_rclone="/root/.config/rclone/rclone.conf"
if [[ -f "$duong_dan_rclone" && -s "$duong_dan_rclone" ]]; then
  
  raw_type=$(grep -A 1 '\[wptangtoc\]' "$duong_dan_rclone" 2>/dev/null | grep 'type' | awk -F '=' '{print $2}' | tr -d ' ')
  
  case "$raw_type" in
    drive)    cloud_name="Google Drive" ;;
    onedrive) cloud_name="Microsoft OneDrive" ;;
    s3|alias) cloud_name="S3 Storage (AWS/R2/MinIO...)" ;;
    *)        cloud_name="Cloud Khác ($raw_type)" ;;
  esac

  echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_YELLOW}PHÁT HIỆN KẾT NỐI CLOUD TỒN TẠI${C_RESET}"
  echo -e "${C_CYAN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
  left_text "Hệ thống phát hiện VPS đã được cấu hình lưu trữ Đám mây từ trước."
  left_text "Trạng thái hiện tại: Đang kết nối nền tảng [ ${C_GREEN}${cloud_name}${C_RESET} ]"
  echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"
  
  msg_title="BẠN CÓ MUỐN GỠ KẾT NỐI CŨ VÀ CÀI ĐẶT LẠI KHÔNG?"
  msg_sub1="Đang dùng : ${C_GREEN}$cloud_name${C_RESET}"
  msg_sub2="Ghi chú : Dữ liệu cũ trên $cloud_name sẽ không bị xóa."
  
  if ! wptt_xac_nhan "$msg_title" "$msg_sub1" "$msg_sub2" "Đồng ý Xóa và Cài Mới" "Giữ nguyên (Thoát)"; then
    exec /etc/wptt/wptt-backup-restore-main 1
    exit
  fi
  
  rm -f "$duong_dan_rclone"
  clear
fi

# ==============================================================================
# CÀI ĐẶT BINARY RCLONE
# ==============================================================================
_runing "Đang cài đặt và đồng bộ hóa Rclone Engine..."
rm -rf /usr/sbin/rclone /usr/bin/rclone
cd /tmp || exit

phienban="1.74.2"

if [[ $(uname -m | grep 'aarch64') ]]; then
  cpu_dong_="linux-arm64"
else
  cpu_dong_="linux-amd64"
fi


#rclone yêu cầu phải có thư viện unzip bắt buộc thì mới chạy đuợc
if ! command -v unzip &>/dev/null; then #đề phòng máy chủ xoá mất unzip khi cài đặt sẽ phải chạy lại
    if [ -f /etc/redhat-release ]; then
      dnf install unzip -y -q >/dev/null 2>&1 || yum install unzip -y -q >/dev/null 2>&1
    elif [ -f /etc/debian_version ]; then apt-get update -q >/dev/null 2>&1 && apt-get install unzip -y -q >/dev/null 2>&1; fi
fi


wget -q "https://downloads.rclone.org/v${phienban}/rclone-v${phienban}-${cpu_dong_}.zip"
if [[ ! -f "rclone-v${phienban}-${cpu_dong_}.zip" ]]; then
  wget -q "https://github.com/rclone/rclone/releases/download/v${phienban}/rclone-v${phienban}-${cpu_dong_}.zip" --no-check-certificate
fi

unzip -oq "rclone-v${phienban}-${cpu_dong_}.zip"
cp -r "rclone-v${phienban}-${cpu_dong_}/rclone" /usr/sbin/
chmod 755 /usr/sbin/rclone
rm -rf "/tmp/rclone-v${phienban}-${cpu_dong_}" "rclone-v${phienban}-${cpu_dong_}.zip"

_rundone "Cài đặt nền tảng Rclone thành công"

echo -e "\n${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_BOLD_WHITE}KHAI BÁO API S3 COMPATIBLE${C_RESET}"
echo -e "${C_CYAN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
left_text "Hãy cung cấp các thông tin Endpoint từ nhà cung cấp dịch vụ của bạn." 2
left_text "Lưu ý: Endpoint bắt buộc phải có tiền tố https://" 2
echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

echo -en "${C_GREEN} 1. Nhập Access Key ID: ${C_RESET}"; read -r s3_ak
echo -en "${C_GREEN} 2. Nhập Secret Access Key: ${C_RESET}"; read -r s3_sk
echo -en "${C_GREEN} 3. Nhập Endpoint URL: ${C_RESET}"; read -r s3_ep

if [[ -z "$s3_ak" || -z "$s3_sk" || -z "$s3_ep" ]]; then
  echo -e "\n${C_RED}Thông tin không được để trống! Đã hủy thiết lập.${C_RESET}"
  sleep 1; exec /etc/wptt/wptt-backup-restore-main 1; exit
fi

# ==============================================================================
# THUẬT TOÁN TỰ THÍCH NGHI BUCKET (ADAPTIVE BUCKET CREATION)
# ==============================================================================
_runing "Đang khởi tạo và thăm dò cấu hình S3 Storage..."

# 1. Khởi tạo trực tiếp bằng cấu hình chính chuẩn WPTangToc
rclone config create wptangtoc s3 provider "Other" env_auth "false" access_key_id "$s3_ak" secret_access_key "$s3_sk" endpoint "$s3_ep" acl "private" >/dev/null 2>&1

# 2. Thử tạo Bucket chủ động
rclone mkdir wptangtoc:wptangtoc-ols-backup >/dev/null 2>&1

if rclone lsd wptangtoc: 2>/dev/null | grep -q 'wptangtoc-ols-backup'; then
  # Kịch bản 1: Hãng cho phép -> Không cần làm thêm gì, xong luôn!
  NEN_TANG="S3 Storage (Standard Mode)"
  THU_MUC_HIEN_THI="Bucket [ wptangtoc-ols-backup/ ]"
else
  # Kịch bản 2: Hãng khóa quyền -> Dò Bucket có sẵn rồi tráo đổi bằng Alias
  bucket_mac_dinh=$(rclone lsd wptangtoc: 2>/dev/null | head -n 1 | awk '{print $NF}' | tr -d '\r')

  if [[ -n "$bucket_mac_dinh" ]]; then
    # Đổi tên cái mình vừa tạo thành cấu hình Gốc (s3_goc)
    sed -i 's/^\[wptangtoc\]$/\[wptangtoc_s3_goc\]/g' "$duong_dan_rclone"
    
    # Bơm cờ "Bịt mắt" vào để lách lỗi 403
    echo "no_check_bucket = true" >> "$duong_dan_rclone"

    # Nối mặt nạ Alias vào cuối file
    cat <<EOF >> "$duong_dan_rclone"

[wptangtoc]
type = alias
remote = wptangtoc_s3_goc:${bucket_mac_dinh}
EOF
    NEN_TANG="S3 Storage (Alias Mode)"
    THU_MUC_HIEN_THI="Thư mục [ wptangtoc-ols-backup/ ] (Bucket: $bucket_mac_dinh)"

	# Khởi tạo thư mục ảo trên mặt phẳng S3
	#mồi tạo thư mục
	echo "Init" > /tmp/s3-init-wptt.txt
    rclone copy /tmp/s3-init-wptt.txt wptangtoc:wptangtoc-ols-backup/ >/dev/null 2>&1
    rm -f /tmp/s3-init-wptt.txt

  else
    _runloi "Thiết lập API tới nền tảng S3 thất bại!"
    echo -e "${C_RED}Lỗi: Hãng không cấp Bucket mặc định và từ chối quyền tạo Bucket mới.${C_RESET}"
    rclone config delete wptangtoc >/dev/null 2>&1
    sleep 3; exec /etc/wptt/wptt-backup-restore-main 1; exit
  fi
fi

if rclone lsd wptangtoc: 2>/dev/null | grep -q 'wptangtoc-ols-backup'; then
  _rundone "Thiết lập kết nối thành công tới hệ thống S3"

  echo -e "\n${C_GREEN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_BOLD_WHITE}HOÀN TẤT KẾT NỐI CLOUD${C_RESET}"
  echo -e "${C_GREEN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
  left_text "Nền tảng    : ${C_YELLOW}$NEN_TANG${C_RESET}"
  left_text "Endpoint    : $s3_ep"
  left_text "Trạng thái  : ${C_GREEN}Kết nối API S3 hợp lệ.${C_RESET}"
  left_text "Thư mục lưu : $THU_MUC_HIEN_THI"
  echo -e "${C_GREEN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

  if ls /etc/cron.d/backup*.cron 1>/dev/null 2>&1; then
    echo -e "${C_YELLOW}Ghi chú:${C_RESET} Bạn đang có các tiến trình Auto Backup đã được bật."
    echo -e "Hệ thống sẽ tự động sử dụng S3 làm kho lưu trữ chính trong chu kỳ tới."
  fi
else
  _runloi "Thiết lập API tới nền tảng S3 thất bại!"
  echo -e "${C_RED}Lỗi: Sai Access/Secret Key hoặc Endpoint không phản hồi.${C_RESET}"
  rm -f "$duong_dan_rclone"
fi

[[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-backup-restore-main 1
