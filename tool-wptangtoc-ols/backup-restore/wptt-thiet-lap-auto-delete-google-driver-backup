#!/bin/bash
# @author: Gia Tuấn
# @website: https://wptangtoc.com
# @since: 2025

function huong_dan() {
  Tính năng tự động xóa file backup hết hạn trên đám mây drive [OneDrive, Google Drive ] là một chức năng cho phép hệ thống tự động loại bỏ các bản sao lưu website cũ hoặc không còn cần thiết sau một khoảng thời gian nhất định hoặc khi chúng đã đạt đến [tuổi thọ] được định sẵn.

  Nói đơn giản, bạn thiết lập quy tắc [ví dụ: chỉ giữ lại các bản sao lưu trong 30 ngày gần nhất]. Khi một bản sao lưu vượt quá giới hạn này, hệ thống sẽ tự động xóa nó đi ở trên đám mây drive [Google Drive, OneDrive].

  Lợi ích chính:

  * Tiết kiệm dung lượng lưu trữ: Ngăn chặn việc các bản sao lưu cũ tích tụ và chiếm hết không gian đĩa Các dịch vụ đám mây thường tính phí dựa trên dung lượng sử dụng. Tự động xóa giúp bạn không bị tốn tiền cho việc lưu trữ những bản backup không còn cần thiết.
  * Quản lý bản sao lưu hiệu quả: Giữ cho kho lưu trữ backup gọn gàng, dễ tìm kiếm khi cần.
  * Tối ưu chi phí: Giảm chi phí lưu trữ, đặc biệt khi sử dụng các dịch vụ lưu trữ đám mây tính theo dung lượng.
  = >Đây là một tính năng rất hữu ích và thường có trong các phần mềm sao lưu chuyên nghiệp,
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null # Nạp thư viện xác nhận

clear
echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}SAO LƯU & KHÔI PHỤC ➜ Thiết lập Tự động xóa Backup trên Cloud${C_RESET}"
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

if ! grep -q 'wptangtoc' /root/.config/rclone/rclone.conf 2>/dev/null; then
  echo -e "${C_RED}❌ Lỗi: Bạn chưa kích hoạt và kết nối Rclone (Google Drive/OneDrive) trên VPS này!${C_RESET}"
  sleep 3
  exec /etc/wptt/wptt-backup-restore-main 1
  exit 1
fi

cloud_name="Google Drive"
grep -q 'onedrive' ~/.config/rclone/rclone.conf 2>/dev/null && cloud_name="OneDrive"

# ==============================================================================
# BẢNG THỐNG KÊ CÁC DOMAIN ĐÃ KÍCH HOẠT AUTO DELETE CLOUD
# ==============================================================================
box_inner_width=${box_inner_width:-71}
active_list=()

if [ "$(ls -A /etc/wptt/vhost 2>/dev/null | grep -v '^\.\.conf$' | sort -uV)" ]; then
  for entry in $(ls -A /etc/wptt/vhost | grep -v '^\.\.conf$' | sort -uV); do
    domain=$(echo "$entry" | sed 's/^.//' | sed 's/.conf//')
    path="/etc/cron.d/delete-google-driver-$domain.cron"

    if [[ -f "$path" ]]; then
      checktuan0=$(cat "/etc/wptt-auto/$domain-delete-backup-google-driver" 2>/dev/null | awk '{print $NF}' | grep -o '[0-9]\+')
      domain_padded=$(printf "%-25s" "$domain")
      active_list+=("${C_BOLD_WHITE}${domain_padded}${C_RESET} : Đang xóa file cũ hơn ${C_YELLOW}${checktuan0} ngày${C_RESET}")
    fi
  done
fi

# Check ALL WEBSITE
if [[ -f /etc/cron.d/delete-google-driver-all-website-wptt-ols.cron ]]; then
  checktuan0=$(cat /etc/wptt-auto/delete-backup-google-driver-all-website 2>/dev/null | awk '{print $NF}' | grep -o '[0-9]\+')
  domain_padded=$(printf "%-25s" "[Toàn bộ Website]")
  active_list+=("${C_YELLOW}${domain_padded}${C_RESET} : Đang xóa file cũ hơn ${C_YELLOW}${checktuan0} ngày${C_RESET}")
fi

if [[ ${#active_list[@]} -gt 0 ]]; then
  echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_YELLOW}DANH SÁCH ĐÃ THIẾT LẬP TỰ ĐỘNG XÓA BACKUP CLOUD${C_RESET}"
  echo -e "${C_CYAN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
  for item in "${active_list[@]}"; do
    left_text "$item" 2
  done
  echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"
fi

# ==============================================================================
# HÀM MENU LỌC THÔNG MINH (CHỈ HIỂN THỊ DOMAIN CHƯA KÍCH HOẠT)
# ==============================================================================
function lua_chon_NAME() {
  unset NAME selects
  selects=()

  for filepath in /etc/wptt/vhost/.*.conf; do
    [[ ! -f "$filepath" || "$filepath" == *"/..conf" ]] && continue
    local domain="${filepath##*/}"
    domain="${domain%.conf}"
    domain="${domain#.}"

    if [[ "$domain" == ?*.?* ]]; then
      if [[ ! -f "/etc/cron.d/delete-google-driver-$domain.cron" ]]; then
        selects+=("$domain")
      fi
    fi
  done

  if [[ ! -f /etc/cron.d/delete-google-driver-all-website-wptt-ols.cron ]]; then
    selects+=("Tất cả website")
  fi

  if [[ ${#selects[@]} -eq 0 ]]; then
    echo -e "${C_YELLOW}⚠️ Tất cả domain trên hệ thống đều đã được cấu hình tự động xóa backup trên $cloud_name!${C_RESET}"
    sleep 3
    exec /etc/wptt/wptt-backup-restore-main 1
  fi

  mapfile -t selects < <(printf "%s\n" "${selects[@]}" | sort -uV)

  echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
  local title_text="Lựa chọn website muốn thiết lập tự động xóa backup trên Cloud:"
  local len=$(echo -n "$title_text" | awk '{print length($0)}')
  local pad_r=$((box_inner_width - len - 2))
  [[ $pad_r -lt 0 ]] && pad_r=0
  echo -e "${C_CYAN}│${C_RESET}  ${C_YELLOW}${title_text}${C_RESET}$(printf '%*s' "$pad_r" "")${C_CYAN}│${C_RESET}"

  local line_len=$((len + 3))
  local pad_line_r=$((box_inner_width - line_len))
  [[ $pad_line_r -lt 0 ]] && pad_line_r=0
  local short_line=$(printf "%${line_len}s" "" | sed 's/ /─/g')
  echo -e "${C_CYAN}├${short_line}$(printf '%*s' "$pad_line_r" "")│${C_RESET}"

  local i=1
  for domain in "${selects[@]}"; do
    if [[ "$domain" == "Tất cả website" ]]; then
      local item_text=$(printf "  ${C_CYAN}%3d)${C_RESET} ${C_YELLOW}%s${C_RESET}" "$i" "$domain")
    else
      local item_text=$(printf "  ${C_CYAN}%3d)${C_RESET} ${C_BOLD_WHITE}%s${C_RESET}" "$i" "$domain")
    fi
    local clean_text=$(printf "  %3d) %s" "$i" "$domain")
    local item_len=$(echo -n "$clean_text" | awk '{print length($0)}')
    local pad=$((box_inner_width - item_len))
    [[ $pad -lt 0 ]] && pad=0
    echo -e "${C_CYAN}│${C_RESET}${item_text}$(printf '%*s' "$pad" "")${C_CYAN}│${C_RESET}"
    ((i++))
  done
  echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯${C_RESET}"

  local fzf_installed=false
  if command -v fzf &>/dev/null; then
    fzf_installed=true
    PROMPT_TEXT="Nhập lựa chọn (1-${#selects[@]}) [00=Tìm nhanh] [0=Thoát]: "
  else
    PROMPT_TEXT="Nhập lựa chọn (1-${#selects[@]}) [0=Thoát]: "
  fi

  while true; do
    echo -en "${C_CYAN}${PROMPT_TEXT}${C_RESET}"
    if ! read -r REPLY; then exit 1; fi
    REPLY=$(echo "$REPLY" | tr -d ' ' | tr '[:upper:]' '[:lower:]')

    case "$REPLY" in
    0)
      echo -e "\n${C_GREEN}Đang thoát...${C_RESET}"
      NAME="0"
      return 0
      ;;
    00)
      if $fzf_installed; then
        local selected_name=$(printf '%s\n' "${selects[@]}" | nl -w 3 -s ': ' | fzf --prompt="Tìm website >> " --height=40% --border=rounded --color=border:red --cycle --reverse)
        selected_name=$(echo "$selected_name" | sed 's/^[[:space:]]*[0-9]\+\:[[:space:]]*//')
        if [[ -n "$selected_name" ]]; then
          NAME="$selected_name"
          return 0
        else echo -e "${C_YELLOW}Đã hủy chọn. Vui lòng chọn lại.${C_RESET}"; fi
      else
        echo -e "${C_RED}Lỗi: FZF chưa cài đặt.${C_RESET}"
      fi
      ;;
    *)
      if [[ "$REPLY" =~ ^[0-9]+$ ]] && [ "$REPLY" -ge 1 ] && [ "$REPLY" -le ${#selects[@]} ]; then
        local action_index=$((REPLY - 1))
        NAME="${selects[$action_index]}"
        return 0
      else
        echo -e "\n${C_RED}❌ Lựa chọn không hợp lệ! Vui lòng chọn lại.${C_RESET}"
      fi
      ;;
    esac
  done
}

lua_chon_NAME

[[ "$NAME" == "0" || -z "$NAME" ]] && {
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-backup-restore-main 1
  return 2>/dev/null || exit
}

if [[ "$NAME" != 'Tất cả website' ]]; then
  pathcheck="/etc/wptt/vhost/.$NAME.conf"
  if [[ ! -f "$pathcheck" ]]; then
    echo -e "\n${C_RED}❌ Tên miền không tồn tại trên hệ thống này!${C_RESET}"
    sleep 3
    [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-backup-restore-main 1
    return 2>/dev/null || exit
  fi
fi

# ==============================================================================
# NHẬP VÀ XÁC NHẬN SỐ NGÀY LƯU TRỮ
# ==============================================================================
echo ""
while true; do
  echo -en "${C_CYAN}👉 Nhập số ngày lưu trữ file backup trên $cloud_name (Ví dụ: 10, 30, 60): ${C_RESET}"
  read -r ngay
  if [[ ! "$ngay" =~ ^[1-9][0-9]*$ ]]; then
    echo -e "${C_RED}❌ Lỗi: Số ngày không hợp lệ! Vui lòng nhập số nguyên dương lớn hơn 0.${C_RESET}"
  else
    break
  fi
done

echo ""
msg_xacnhan="Bạn muốn tự động xóa các file backup trên $cloud_name cũ hơn ${C_YELLOW}$ngay ngày${C_RESET}?"
if wptt_xac_nhan "$msg_xacnhan" "${C_BOLD_WHITE}Website:${C_RESET} ${C_YELLOW}$NAME${C_RESET}" "" "Đồng ý Thiết lập" "Hủy bỏ"; then

  mkdir -p /etc/wptt-auto

  # ==============================================================================
  # GHI FILE CẤU HÌNH VÀ CRON
  # ==============================================================================
  _runing "Đang khởi tạo chu kỳ Cronjob tự động dọn dẹp Cloud..."

  if [[ "$NAME" == 'Tất cả website' ]]; then
    cat >"/etc/wptt-auto/delete-backup-google-driver-all-website" <<END
#!/bin/bash
nice -n 19 /bin/bash /etc/wptt/backup-restore/wptt-auto-delete-google-driver-backup "$NAME" $ngay
END
    chmod 740 /etc/wptt-auto/delete-backup-google-driver-all-website

    cat >"/etc/cron.d/delete-google-driver-all-website-wptt-ols.cron" <<END
0 3 * * * root /etc/wptt-auto/delete-backup-google-driver-all-website >/dev/null 2>&1
END
  else
    cat >"/etc/wptt-auto/$NAME-delete-backup-google-driver" <<END
#!/bin/bash
nice -n 19 /bin/bash /etc/wptt/backup-restore/wptt-auto-delete-google-driver-backup $NAME $ngay
END
    chmod 740 "/etc/wptt-auto/$NAME-delete-backup-google-driver"

    cat >"/etc/cron.d/delete-google-driver-$NAME.cron" <<END
0 3 * * * root /etc/wptt-auto/$NAME-delete-backup-google-driver >/dev/null 2>&1
END
  fi

  # Khởi động lại Cron daemon
  if $(cat /etc/*release | grep -q "Ubuntu"); then
    if [[ "$NAME" == 'Tất cả website' ]]; then
      ln -sf /etc/cron.d/delete-google-driver-all-website-wptt-ols.cron /etc/cron.d/delete-google-driver-all-website-wptt-ols_cron 2>/dev/null
    else
      NAME_CRON_ubuntu=${NAME//[.]/_}
      ln -sf "/etc/cron.d/delete-google-driver-$NAME.cron" "/etc/cron.d/delete-google-driver-${NAME_CRON_ubuntu}_cron" 2>/dev/null
    fi
    systemctl restart cron.service
  else
    systemctl restart crond.service
  fi

  echo "Thiết lập tự động xóa backup Cloud hết hạn $NAME: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log
  _rundone "Cấu hình Cronjob Cloud thành công"

  echo -e "\n${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_GREEN}THIẾT LẬP AUTO DELETE CLOUD THÀNH CÔNG${C_RESET}"
  echo -e "${C_CYAN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"

  left_text "Website        : ${C_YELLOW}$NAME${C_RESET}"
  left_text "Thời gian lưu  : ${C_YELLOW}$ngay ngày${C_RESET}"

  if [[ "$NAME" == 'Tất cả website' ]]; then
    left_text "Thư mục Cloud  : $cloud_name -> wptangtoc_ols_backup/*"
  else
    left_text "Thư mục Cloud  : $cloud_name -> wptangtoc_ols_backup/$NAME/*"
  fi

  echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"
  echo -e "${C_CYAN}Ghi chú:${C_RESET} Cứ vào lúc ${C_GREEN}3 giờ sáng hàng ngày${C_RESET}, hệ thống sẽ tự động dọn dẹp."
  echo -e "Các file backup cũ hơn ${C_YELLOW}$ngay ngày${C_RESET} trên $cloud_name sẽ bị xóa đi."

else
  echo -e "${C_YELLOW}Đã hủy thao tác thiết lập Auto Delete Cloud.${C_RESET}"
fi

[[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-backup-restore-main 1
