function huong_dan() {
  Tính năng tự động xóa file backup hết hạn trên đám mây drive [OneDrive, Google Drive ] là một chức năng cho phép hệ thống tự động loại bỏ các bản sao lưu website cũ hoặc không còn cần thiết sau một khoảng thời gian nhất định hoặc khi chúng đã đạt đến [tuổi thọ] được định sẵn.

  Nói đơn giản, bạn thiết lập quy tắc [ví dụ: chỉ giữ lại các bản sao lưu trong 30 ngày gần nhất]. Khi một bản sao lưu vượt quá giới hạn này, hệ thống sẽ tự động xóa nó đi ở trên đám mây drive [Google Drive, OneDrive].

  Lợi ích chính:

  * Tiết kiệm dung lượng lưu trữ: Ngăn chặn việc các bản sao lưu cũ tích tụ và chiếm hết không gian đĩa Các dịch vụ đám mây thường tính phí dựa trên dung lượng sử dụng. Tự động xóa giúp bạn không bị tốn tiền cho việc lưu trữ những bản backup không còn cần thiết.
  * Quản lý bản sao lưu hiệu quả: Giữ cho kho lưu trữ backup gọn gàng, dễ tìm kiếm khi cần.
  * Tối ưu chi phí: Giảm chi phí lưu trữ, đặc biệt khi sử dụng các dịch vụ lưu trữ đám mây tính theo dung lượng.
  = >Đây là một tính năng rất hữu ích và thường có trong các phần mềm sao lưu chuyên nghiệp,
}

echo ""
echo ""
echo ""
echo "========================================================================="
echo "|Sao lưu & khôi phục => Thiết lập tự động xóa file sao luu website Google Driver      |"
echo "========================================================================="
checkactivate=$(grep -rnw '/root/.config/rclone/rclone.conf' -e "wptangtoc" >>/dev/null 2>&1 && echo 2)
if [[ "$checkactivate" = "2" ]]; then
  google=4
else
  echo "Bạn chưa kích hoạt rclone Google Drive"
  sleep 3
  exec /etc/wptt/wptt-backup-restore-main 1
  exit
fi
. /etc/wptt/.wptt.conf
echo ""
echo ""
if [ "$(ls -A /etc/wptt/vhost | grep -v '^\.\.conf$' | sort -uV)" ]; then
  echo "=================================================================================="
  echo "Danh sách Domain đã kích hoạt tự động xóa file backup hết hạn trên Drive:"
  echo "=================================================================================="
  for entry in $(ls -A /etc/wptt/vhost | grep -v '^\.\.conf$' | sort -uV); do
    domain=$(echo $entry | sed 's/^.//' | sed 's/.conf//')
    path="/etc/cron.d/delete-google-driver-$domain.cron"
    i=1
    if [[ -f "$path" ]]; then
      checkauto="Đã kích hoạt giá trị thiết lập là "
      checktuan0=$(cat /etc/wptt-auto/$domain-delete-backup-google-driver | awk '{print $NF}' | grep -o '[0-9]\+$')
      themphut=" ngày"
    else
      checkauto="Chưa kích hoạt"
      checktuan0=""
      themphut=""
    fi
    echo "Website $domain $checkauto$checktuan0$themphut tự động xóa file backup hết hạn trên Drive"
  done

  if [[ ! -f /etc/wptt-auto/delete-backup-google-driver-all-website ]]; then
    echo "Toàn bộ website chưa thiết lập tự động xoá backup hết hạn trên drive"
  else
    checkauto="Đã kích hoạt giá trị thiết lập là "
    checktuan0=$(cat /etc/wptt-auto/delete-backup-google-driver-all-website | awk '{print $NF}' | grep -o '[0-9]\+$')
    themphut=" ngày"
    echo "Toàn bộ website $checkauto$checktuan0$themphut tự động xóa file backup hết hạn trên Drive"
  fi
  echo "========================================================================="
fi

function lua_chon_NAME() {
  NAME=""
  if [ "$(ls -At /etc/wptt/vhost)" ]; then
    selects=()
    for entry in $(ls -A /etc/wptt/vhost | grep -v '^\.\.conf$' | sort -uV); do
      NAME=$(echo $entry | sed 's/^.//' | sed 's/.conf//')
      if [[ ! -f /etc/cron.d/delete-google-driver-$NAME.cron ]]; then
        selects+=("$NAME")
      fi
    done

    if [[ ! -f /etc/cron.d/delete-google-driver-all-website-wptt-ols.cron ]]; then
      selects+=("Tất cả website")
    fi

    if [[ $selects = '' ]]; then
      echo "Tất cả domain trên hệ thống đã được kích hoạt xóa file backup tự động trên Google Drive hết rồi"
      exec /etc/wptt/wptt-backup-restore-main 1
    fi

    PS3="
-//- Nhập lựa chọn website của bạn [0=Thoát]: "
    select select in "${selects[@]}"; do
      NAME=$select
      index=$REPLY
      break
    done
  else
    clear
    echo "Không xác định được domain nào"
    exit
  fi
}

echo ""
echo ""
echo "Lựa chọn website bạn muốn thiết lập tự động xóa file file backup hết hạn trên Google Drive: "
echo ""
lua_chon_NAME

if [[ "$NAME" = "0" || "$NAME" = "" ]]; then
  exec /etc/wptt/wptt-backup-restore-main 1
fi

if [[ $NAME != 'Tất cả website' ]]; then
  pathcheck="/etc/wptt/vhost/.$NAME.conf"
  if [[ ! -f "$pathcheck" ]]; then
    clear
    echoDo "Tên miền không tồn tại trên hệ thống này"
    sleep 3
    check_menu_wptangtoc_active=$1
    if [[ $check_menu_wptangtoc_active = "98" ]]; then
      exec /etc/wptt/wptt-backup-restore-main 1
    fi
    return 2>/dev/null
    exit
  fi
fi

if [ -f /etc/cron.d/delete-google-driver-"$NAME".cron ]; then
  echo "$NAME đã được kích hoạt tự động backup hết hạn trước đó rồi!"
  sleep 3
  exec /etc/wptt/wptt-backup-restore-main 1
  exit
fi

. /etc/wptt/echo-color
read -p "Nhập số ngày của bạn muốn đặt hạn sử dụng cho file backup trên Google Driver
Ví dụ: 10 hay 60 sử dụng số nguyên dương: " ngay

if [[ ! $ngay =~ ^-?[0-9]+$ ]]; then
  clear
  echoDo "Nhập số ngày không đúng định dạng"
  sleep 4
  exec /etc/wptt/wptt-backup-restore-main 1
  exit
fi

_runing "Thiết lập xóa file backup trên Google Drive hết hạn"

if [[ $NAME = 'Tất cả website' ]]; then
  cat >"/etc/wptt-auto/delete-backup-google-driver-all-website" <<END
#!/bin/bash
nice -n 19 /bin/bash /etc/wptt/backup-restore/wptt-auto-delete-google-driver-backup "$NAME" $ngay
END
  chmod 740 /etc/wptt-auto/delete-backup-google-driver-all-website
else
  cat >"/etc/wptt-auto/$NAME-delete-backup-google-driver" <<END
#!/bin/bash
nice -n 19 /bin/bash /etc/wptt/backup-restore/wptt-auto-delete-google-driver-backup $NAME $ngay
END
  chmod 740 /etc/wptt-auto/$NAME-delete-backup-google-driver
fi

if [[ $NAME = 'Tất cả website' ]]; then
  cat >"/etc/cron.d/delete-google-driver-all-website-wptt-ols.cron" <<END
0 3 * * * root /etc/wptt-auto/delete-backup-google-driver-all-website >/dev/null 2>&1
END
else
  cat >"/etc/cron.d/delete-google-driver-$NAME.cron" <<END
0 3 * * * root /etc/wptt-auto/$NAME-delete-backup-google-driver >/dev/null 2>&1
END
fi

if [[ $NAME = 'Tất cả website' ]]; then
  if $(cat /etc/*release | grep -q "Ubuntu"); then
    ln -sf /etc/cron.d/delete-google-driver-all-website-wptt-ols.cron /etc/cron.d/delete-google-driver-all-website-wptt-ols_cron
    systemctl restart cron.service
  else
    systemctl restart crond.service
  fi

  unset NAME #unset để print giá trị dưới là rỗng
else
  if $(cat /etc/*release | grep -q "Ubuntu"); then
    NAME_CRON_ubuntu=${NAME//[.]/_}
    ln -sf /etc/cron.d/delete-google-driver-$NAME.cron /etc/cron.d/delete-google-driver-${NAME_CRON_ubuntu}_cron
    systemctl restart cron.service
  else
    systemctl restart crond.service
  fi
fi

_rundone "Thiết lập xóa file backup trên Google Drive hết hạn"
echo "========================================================================="
echo "Hoàn tất kích hoạt tự động xóa file backup hết hạn Google Drive"
echo "========================================================================="
echo "Vào lúc 3 giờ sáng hàng ngày"
echo "Hệ thống sẽ tự động xóa các file backup trong thư mục backup google drive: wptangtoc_ols_backup/$NAME file nào đã được tạo trước ngày $ngay ngày sẽ tự động xóa đi"
echo "========================================================================="

check_menu_wptangtoc_active=$1
if [[ $check_menu_wptangtoc_active = "98" ]]; then
  exec /etc/wptt/wptt-backup-restore-main 1
fi
