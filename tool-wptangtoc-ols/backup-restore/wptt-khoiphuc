#!/bin/bash
# @author: Gia Tuấn
# @website: https://wptangtoc.com
# @email: giatuan@wptangtoc.com
# @since: 2026

function huong_dan() {
  Tính năng khôi phục website

  Nói một cách đơn giản, nếu website của bạn gặp sự cố [mất dữ liệu, bị lỗi, bị tấn công], tính năng này giống như việc bạn sử dụng một cỗ máy thời gian để quay ngược website về một thời điểm mà nó còn hoạt động tốt, dựa trên bản sao lưu bạn đã có.

  Khôi phục website là quá trình sửa chữa, phục hồi hoặc đưa trở lại trạng thái hoạt động bình thường cho các chức năng cụ thể của một trang web đã bị lỗi, bị mất hoặc không hoạt động đúng cách. Điều này đảm bảo rằng người dùng có thể tiếp tục tương tác và sử dụng đầy đủ các tiện ích mà website đó cung cấp.

  Khôi phục từ bản sao lưu [Backup]: Nếu bạn thường xuyên sao lưu website, bạn có thể khôi phục toàn bộ website hoặc các thành phần cụ thể về một thời điểm trước khi lỗi xảy ra.
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null

if [[ "$1" == '98' ]]; then
  WPTT_IN_MENU="yes"
  WPTT_MENU_BACK="/etc/wptt/wptt-backup-restore-main 1"
fi

wptt_check_mariadb || wptt_die "MariaDB đang bị sập! Hệ thống từ chối không cho phép khôi phục website."

NAME=$1
[[ "$NAME" == "98" ]] && NAME=""

if [[ -z "$NAME" ]]; then
  . /etc/wptt/tenmien
  echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_BOLD_WHITE}$backup_restore ➜ $khoi_phuc_website${C_RESET}"
  echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"
  lua_chon_NAME "$khoi_phuc_website"
fi

[[ "$NAME" == "0" || -z "$NAME" ]] && exec /etc/wptt/wptt-backup-restore-main 1

pathcheck="/etc/wptt/vhost/.$NAME.conf"
if [[ ! -f "$pathcheck" ]]; then
  echo -e "\n${C_RED}❌ $ten_mien_nay_khong_ton_tai_tren_he_thong${C_RESET}"
  sleep 3
  exec /etc/wptt/wptt-backup-restore-main 1
fi

. /etc/wptt/vhost/."$NAME".conf

# ==============================================================================
# 1. CHỌN BẢN SAO LƯU MÃ NGUỒN (SOURCE CODE)
# ==============================================================================
if [[ ! "$(ls -A /usr/local/backup-website/$NAME/ 2>/dev/null)" && ! "$(ls -A /usr/local/lsws/$NAME/backup-website 2>/dev/null)" ]]; then
  echo -e "\n${C_YELLOW}⚠️ $khong_co_file_backup_nao_ton_tai${C_RESET}"
  echo "Vui lòng upload file backup của bạn vào: /usr/local/backup-website/$NAME/"
  [[ -f ~/.config/rclone/rclone.conf ]] && echo "Mẹo: Bạn có thể dùng tính năng Download từ lưu trữ đám mây."
  sleep 3
  exec /etc/wptt/wptt-backup-restore-main 1
fi

c=1
for entry in $(ls -At /usr/local/backup-website/$NAME 2>/dev/null | grep ".zip$\|.tar.gz$\|.tar.zst$" | grep -v '\-wptt\-luy\-tuyen'); do c=$((c + 1)); done

cc=1
if [[ $(ls -At /usr/local/lsws/$NAME/backup-website 2>/dev/null | grep '.zip$\|.tar.gz$\|.tar.zst$' | grep -v '\-wptt\-luy\-tuyen') ]]; then
  for entry in $(ls -At /usr/local/lsws/$NAME/backup-website 2>/dev/null | grep '.zip$\|.tar.gz$\|.tar.zst$' | grep -v '\-wptt\-luy\-tuyen'); do cc=$((cc + 1)); done
fi

echo -e "\n${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}THỐNG KÊ BẢN SAO LƯU MÃ NGUỒN (SOURCE CODE)${C_RESET}"
echo -e "${C_CYAN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
left_text "Số lượng file (Quyền Root): $((c - 1))"
left_text "Số lượng file (Quyền User): $((cc - 1))"
echo -e "${C_CYAN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
left_text "${C_GREEN}Tổng cộng có: $((cc + c - 2)) file sao lưu mã nguồn${C_RESET}"
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯${C_RESET}"

selects=()
for entry in $(ls -At /usr/local/backup-website/$NAME/ 2>/dev/null | grep ".zip$\|.tar.gz$\|.tar.zst$" | grep -v '\-wptt\-luy\-tuyen'); do selects+=("$entry"); done
if [[ $(ls -At /usr/local/lsws/$NAME/backup-website 2>/dev/null | grep '.zip$\|.tar.gz$\|.tar.zst$' | grep -v '\-wptt\-luy\-tuyen') ]]; then
  for entry in $(ls -At /usr/local/lsws/$NAME/backup-website 2>/dev/null | grep '.zip$\|.tar.gz$\|.tar.zst$' | grep -v '\-wptt\-luy\-tuyen'); do selects+=("$entry"); done
fi

if [[ ${#selects[@]} -eq 0 ]]; then
  echo -e "${C_RED}❌ Không có file backup mã nguồn nào hợp lệ (.zip, .tar.gz, .tar.zst)!${C_RESET}"
  sleep 3
  exec /etc/wptt/wptt-backup-restore-main 1
fi

PS3="$(echo -e "${C_CYAN}Chọn bản sao lưu mã nguồn cần khôi phục [0=Thoát]: ${C_RESET}")"
select select in "${selects[@]}"; do
  file=$select
  break
done

[[ "$file" == "0" || -z "$file" ]] && exec /etc/wptt/wptt-backup-restore-main 1

duong_dan_thu_muc_ma_nguon="/usr/local/backup-website/$NAME/$file"
[[ ! -f $duong_dan_thu_muc_ma_nguon ]] && duong_dan_thu_muc_ma_nguon="/usr/local/lsws/$NAME/backup-website/$file"

# Xử lý đụng độ tên file mã nguồn
if [[ -f "/usr/local/backup-website/$NAME/$file" && -f "/usr/local/lsws/$NAME/backup-website/$file" ]]; then
  echo -e "\n${C_YELLOW}Phát hiện trùng lặp tên file backup Mã nguồn giữa thư mục Root và User!${C_RESET}"
  echo -e "${C_CYAN}1)${C_RESET} Dùng bản của ${C_RED}Root${C_RESET} (/usr/local/backup-website/...)"
  echo -e "${C_CYAN}2)${C_RESET} Dùng bản của ${C_GREEN}User${C_RESET} (/usr/local/lsws/.../backup-website/...)"
  while true; do
    echo -en "${C_CYAN}Chọn nguồn ưu tiên [1-2]: ${C_RESET}"
    read -r opt
    case "$opt" in
    1)
      file_root_hay_user_zip="y"
      duong_dan_thu_muc_ma_nguon="/usr/local/backup-website/$NAME/$file"
      break
      ;;
    2)
      file_root_hay_user_zip="n"
      duong_dan_thu_muc_ma_nguon="/usr/local/lsws/$NAME/backup-website/$file"
      break
      ;;
    *) echo -e "${C_RED}❌ Nhập sai, vui lòng chọn 1 hoặc 2.${C_RESET}" ;;
    esac
  done
fi

# ==============================================================================
# 2. CHỌN BẢN SAO LƯU CƠ SỞ DỮ LIỆU (DATABASE)
# ==============================================================================
if [[ ! $(ls -A /usr/local/backup-website/$NAME 2>/dev/null | grep '.sql$\|.sql.gz$\|.sql.zst$') && ! $(ls -A /usr/local/lsws/$NAME/backup-website 2>/dev/null | grep '.sql$\|.sql.gz$\|.sql.zst$') ]]; then
  echo -e "\n${C_RED}❌ Không có file backup Database (.sql) nào tồn tại.${C_RESET}"
  sleep 3
  exec /etc/wptt/wptt-backup-restore-main 1
fi

b=1
for entry in $(ls -At /usr/local/backup-website/$NAME 2>/dev/null | grep '.sql$\|.sql.gz$\|.sql.zst$'); do b=$((b + 1)); done

bb=1
if [[ $(ls -At /usr/local/lsws/$NAME/backup-website 2>/dev/null | grep '.sql$\|.sql.gz$\|.sql.zst$') ]]; then
  for entry in $(ls -At /usr/local/lsws/$NAME/backup-website 2>/dev/null | grep '.sql$\|.sql.gz$\|.sql.zst$'); do bb=$((bb + 1)); done
fi

echo -e "\n${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}THỐNG KÊ BẢN SAO LƯU DATABASE (CƠ SỞ DỮ LIỆU)${C_RESET}"
echo -e "${C_CYAN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
left_text "Số lượng file (Quyền Root): $((b - 1))"
left_text "Số lượng file (Quyền User): $((bb - 1))"
echo -e "${C_CYAN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
left_text "${C_GREEN}Tổng cộng có: $((bb + b - 2)) file sao lưu Database${C_RESET}"
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯${C_RESET}"

selects=()
for entry in $(ls -At /usr/local/backup-website/$NAME 2>/dev/null | grep '.sql$\|.sql.gz$\|.sql.zst$'); do selects+=("$entry"); done
if [[ $(ls -At /usr/local/lsws/$NAME/backup-website 2>/dev/null | grep '.sql$\|.sql.gz$\|.sql.zst$') ]]; then
  for entry in $(ls -At /usr/local/lsws/$NAME/backup-website 2>/dev/null | grep '.sql$\|.sql.gz$\|.sql.zst$'); do selects+=("$entry"); done
fi

PS3="$(echo -e "${C_CYAN}Chọn bản sao lưu Database cần khôi phục [0=Thoát]: ${C_RESET}")"
select select in "${selects[@]}"; do
  filesql=$select
  break
done

[[ "$filesql" == "0" || -z "$filesql" ]] && exec /etc/wptt/wptt-backup-restore-main 1

duong_dan_thu_path_sql="/usr/local/backup-website/$NAME/$filesql"
[[ ! -f $duong_dan_thu_path_sql ]] && duong_dan_thu_path_sql="/usr/local/lsws/$NAME/backup-website/$filesql"

# Xử lý đụng độ tên file Database
if [[ -f "/usr/local/backup-website/$NAME/$filesql" && -f "/usr/local/lsws/$NAME/backup-website/$filesql" ]]; then
  echo -e "\n${C_YELLOW}⚠️ Phát hiện trùng lặp tên file backup Database giữa thư mục Root và User!${C_RESET}"
  echo -e "${C_CYAN}1)${C_RESET} Dùng bản của ${C_RED}Root${C_RESET} (/usr/local/backup-website/...)"
  echo -e "${C_CYAN}2)${C_RESET} Dùng bản của ${C_GREEN}User${C_RESET} (/usr/local/lsws/.../backup-website/...)"
  while true; do
    echo -en "${C_CYAN}Chọn nguồn ưu tiên [1-2]: ${C_RESET}"
    read -r opt
    case "$opt" in
    1)
      file_root_hay_user="y"
      duong_dan_thu_path_sql="/usr/local/backup-website/$NAME/$filesql"
      break
      ;;
    2)
      file_root_hay_user="n"
      duong_dan_thu_path_sql="/usr/local/lsws/$NAME/backup-website/$filesql"
      break
      ;;
    *) echo -e "${C_RED}❌ Nhập sai, vui lòng chọn 1 hoặc 2.${C_RESET}" ;;
    esac
  done
fi

check_file_error=$(du -c "$duong_dan_thu_path_sql" | awk '{print $1}' | sed '1d')
if ((${check_file_error:-0} < 10)); then
  echo -e "\n${C_RED}❌ Lỗi: File $filesql quá nhỏ (Dưới 10KB), có thể bị lỗi corrupt!${C_RESET}"
  echo "Vui lòng lựa chọn file Database backup khác."
  sleep 3
  exec /etc/wptt/wptt-backup-restore-main 1
fi

clear
echo "Khôi phục website $NAME: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log

# ==============================================================================
# BẮT ĐẦU CƠ CHẾ LOCKING (CHỐNG ĐỤNG ĐỘ TIẾN TRÌNH BACKUP/RESTORE)
# ==============================================================================
if [[ -n "$NAME" && "$NAME" != "Tất cả website" && "$NAME" != "98" ]]; then
  LOCK_FILE="/tmp/wptt_lock_sao_luu_khoi_phuc_${NAME}.lock"
  exec 200>"$LOCK_FILE"

  if ! flock -n 200; then
    echo -e "\n${C_RED}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
    center_text "${C_YELLOW}❌ LỖI ĐỤNG ĐỘ TIẾN TRÌNH (LOCKING)${C_RESET}"
    echo -e "${C_RED}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
    left_text "Website $NAME đang được thao tác bởi một tiến trình Backup/Restore khác!"
    left_text "Vui lòng chờ tiến trình đó hoàn tất rồi thử lại để tránh hỏng dữ liệu."
    echo -e "${C_RED}╰───────────────────────────────────────────────────────────────────────╯${C_RESET}\n"

    check_menu_wptangtoc_active=$1
    if [[ "$check_menu_wptangtoc_active" == "98" || -z "$check_menu_wptangtoc_active" ]]; then
      sleep 3
      exec /etc/wptt/wptt-backup-restore-main 1
    fi
    return 2>/dev/null || exit 1
  fi
fi

# ==============================================================================
# KHÔI PHỤC DATABASE
# ==============================================================================
echo ""
_runing "$xoa_toan_bo_du_lieu_database website $NAME"

TEMP_CNF_ROOT=$(mktemp)
chmod 600 "$TEMP_CNF_ROOT"
cat >"$TEMP_CNF_ROOT" <<EOF
[client]
user=${database_admin_username}
password=${database_admin_password}
host=localhost
max_allowed_packet=1G
default-character-set=utf8mb4
EOF

mariadb --defaults-extra-file="$TEMP_CNF_ROOT" --ssl-verify-server-cert=false -e "DROP DATABASE IF EXISTS \`${DB_Name_web}\`;"
mariadb --defaults-extra-file="$TEMP_CNF_ROOT" --ssl-verify-server-cert=false -e "CREATE DATABASE IF NOT EXISTS \`${DB_Name_web}\`;"
rm -rf "$TEMP_CNF_ROOT"
_rundone "$xoa_toan_bo_du_lieu_database website $NAME"

TEMP_CNF=$(mktemp)
chmod 600 "$TEMP_CNF"
cat >"$TEMP_CNF" <<EOF
[client]
user=${DB_User_web}
password=${DB_Password_web}
host=localhost
max_allowed_packet=1G
default-character-set=utf8mb4
EOF

_runing "$khoi_phuc_database website $NAME"

if ! command -v pv &>/dev/null; then
  if [ -f /etc/redhat-release ]; then
    dnf install pv -y -q >/dev/null 2>&1 || yum install pv -y -q >/dev/null 2>&1
  elif [ -f /etc/debian_version ]; then
    apt-get update -q >/dev/null 2>&1 && apt-get install pv -y -q >/dev/null 2>&1
  fi
fi

INIT_SQL="SET FOREIGN_KEY_CHECKS=0; SET UNIQUE_CHECKS=0; SET AUTOCOMMIT=0;"
END_SQL="COMMIT; SET FOREIGN_KEY_CHECKS=1; SET UNIQUE_CHECKS=1; SET AUTOCOMMIT=1;"

if command -v pv &>/dev/null; then
  if [[ "$duong_dan_thu_path_sql" == *".sql.zst" ]]; then
    if ! command -v zstd &>/dev/null; then dnf install zstd -y -q >/dev/null 2>&1; fi
    (
      echo "$INIT_SQL"
      pv -N "Importing" "$duong_dan_thu_path_sql" | zstd -d
      echo "$END_SQL"
    ) | mariadb --defaults-extra-file="$TEMP_CNF" "$DB_Name_web" --ssl-verify-server-cert=false
  elif [[ "$duong_dan_thu_path_sql" == *".sql.gz" ]]; then
    (
      echo "$INIT_SQL"
      pv -N "Importing" "$duong_dan_thu_path_sql" | zcat
      echo "$END_SQL"
    ) | mariadb --defaults-extra-file="$TEMP_CNF" "$DB_Name_web" --ssl-verify-server-cert=false
  else
    (
      echo "$INIT_SQL"
      pv -N "Importing" "$duong_dan_thu_path_sql"
      echo "$END_SQL"
    ) | mariadb --defaults-extra-file="$TEMP_CNF" "$DB_Name_web" --ssl-verify-server-cert=false
  fi
else
  if [[ "$duong_dan_thu_path_sql" == *".sql.zst" ]]; then
    (
      echo "$INIT_SQL"
      zstd -d <"$duong_dan_thu_path_sql"
      echo "$END_SQL"
    ) | mariadb --defaults-extra-file="$TEMP_CNF" "$DB_Name_web" --ssl-verify-server-cert=false
  elif [[ "$duong_dan_thu_path_sql" == *".sql.gz" ]]; then
    (
      echo "$INIT_SQL"
      zcat "$duong_dan_thu_path_sql"
      echo "$END_SQL"
    ) | mariadb --defaults-extra-file="$TEMP_CNF" "$DB_Name_web" --ssl-verify-server-cert=false
  else
    (
      echo "$INIT_SQL"
      cat "$duong_dan_thu_path_sql"
      echo "$END_SQL"
    ) | mariadb --defaults-extra-file="$TEMP_CNF" "$DB_Name_web" --ssl-verify-server-cert=false
  fi
fi

if [[ $? -eq 0 ]]; then
  echo ""
  _rundone "$khoi_phuc_database website $NAME"
else
  echo ""
  _runloi "$khoi_phuc_database website $NAME (Có lỗi xảy ra)"
fi
rm -f "$TEMP_CNF"

# ==============================================================================
# KHÔI PHỤC MÃ NGUỒN
# ==============================================================================
_runing "$xoa $ma_nguon website $NAME"

if [[ -n "$lock_down" ]]; then
  . /etc/wptt/bao-mat/wptt-chattr-file-lock $NAME off
fi

if [[ -z "$NAME" || "$NAME" == "." ]]; then
  echo -e "\n${C_RED}Lỗi: Domain rỗng. Hủy bỏ lệnh xóa an toàn!${C_RESET}"
  flock -u 200
  exec 200>&-
  rm -f "/tmp/wptt_lock_sao_luu_khoi_phuc_${NAME}.lock" 2>/dev/null
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-backup-restore-main 1
  return 2>/dev/null || exit
fi

rm -rf /usr/local/lsws/"$NAME"/html/*
_rundone "$xoa $ma_nguon website $NAME"

_runing "$giai_nen $ma_nguon website $NAME"

if [[ "$file" == *".zip" ]]; then
  if ! command -v unzip &>/dev/null; then
    if [ -f /etc/redhat-release ]; then
      dnf install unzip -y -q >/dev/null 2>&1 || yum install unzip -y -q >/dev/null 2>&1
    elif [ -f /etc/debian_version ]; then apt-get update -q >/dev/null 2>&1 && apt-get install unzip -y -q >/dev/null 2>&1; fi
  fi

  if [[ $(unzip -l "$duong_dan_thu_muc_ma_nguon" | awk '{ print $4 }' | grep '^wp-load.php$') ]]; then
    unzip -o "$duong_dan_thu_muc_ma_nguon" -d /usr/local/lsws/"$NAME"/html/
  else
    check_path_file_wp_load_bi_boc_boi_thu_muc=$(unzip -l "$duong_dan_thu_muc_ma_nguon" | awk '{ print $4 }' | grep '/wp-load.php$')
    if [[ -n "$check_path_file_wp_load_bi_boc_boi_thu_muc" ]]; then
      check_path_file_wp_load_bi_boc_boi_thu_muc_change=$(echo "$check_path_file_wp_load_bi_boc_boi_thu_muc" | sed 's/wp-load.php/*/g')
      TEMP_DIR_ma_nguon=$(mktemp -d)
      unzip -o "$duong_dan_thu_muc_ma_nguon" -d "$TEMP_DIR_ma_nguon"
      mv "$TEMP_DIR_ma_nguon"/$check_path_file_wp_load_bi_boc_boi_thu_muc_change /usr/local/lsws/"$NAME"/html/
      rm -rf "$TEMP_DIR_ma_nguon"
    else
      unzip -o "$duong_dan_thu_muc_ma_nguon" -d /usr/local/lsws/"$NAME"/html/
    fi
  fi
fi

if [[ "$file" == *".tar.zst" ]]; then
  [[ -z $(which zstd) ]] && dnf install zstd -y -q >/dev/null 2>&1
  [[ -z $(which tar) ]] && dnf install tar -y -q >/dev/null 2>&1

  if [[ $(tar --use-compress-program="zstd" -tvf "$duong_dan_thu_muc_ma_nguon" | awk '{ print $6 }' | grep '^./wp-load.php$') ]]; then
    tar --use-compress-program="zstd" -xf "$duong_dan_thu_muc_ma_nguon" -C /usr/local/lsws/"$NAME"/html --overwrite
  else
    check_path_file_wp_load_bi_boc_boi_thu_muc=$(tar --use-compress-program="zstd" -tvf "$duong_dan_thu_muc_ma_nguon" | awk '{ print $6 }' | sed 's#\./##g' | grep '/wp-load.php$')
    if [[ -n "$check_path_file_wp_load_bi_boc_boi_thu_muc" ]]; then
      check_path_file_wp_load_bi_boc_boi_thu_muc_change=$(echo "$check_path_file_wp_load_bi_boc_boi_thu_muc" | sed 's/wp-load.php/*/g')
      TEMP_DIR_ma_nguon=$(mktemp -d)
      tar --use-compress-program="zstd" -xf "$duong_dan_thu_muc_ma_nguon" -C "$TEMP_DIR_ma_nguon" --overwrite
      mv "$TEMP_DIR_ma_nguon"/$check_path_file_wp_load_bi_boc_boi_thu_muc_change /usr/local/lsws/"$NAME"/html
      rm -rf "$TEMP_DIR_ma_nguon"
    else
      tar --use-compress-program="zstd" -xf "$duong_dan_thu_muc_ma_nguon" -C /usr/local/lsws/"$NAME"/html --overwrite
    fi
  fi
fi

if [[ "$file" == *".tar.gz" ]]; then
  [[ -z $(which pigz) ]] && dnf install pigz -y -q >/dev/null 2>&1
  [[ -z $(which tar) ]] && dnf install tar -y -q >/dev/null 2>&1

  if [[ $(tar -tvzf "$duong_dan_thu_muc_ma_nguon" | awk '{ print $6 }' | grep '^wp-load.php$') ]]; then
    tar --use-compress-program="pigz" -xf "$duong_dan_thu_muc_ma_nguon" -C /usr/local/lsws/"$NAME"/html --overwrite
  else
    check_path_file_wp_load_bi_boc_boi_thu_muc=$(tar -tvzf "$duong_dan_thu_muc_ma_nguon" | awk '{ print $6 }' | grep '/wp-load.php$')
    if [[ -n "$check_path_file_wp_load_bi_boc_boi_thu_muc" ]]; then
      check_path_file_wp_load_bi_boc_boi_thu_muc_change=$(echo "$check_path_file_wp_load_bi_boc_boi_thu_muc" | sed 's/wp-load.php/*/g')
      TEMP_DIR_ma_nguon=$(mktemp -d)
      tar --use-compress-program="pigz" -xf "$duong_dan_thu_muc_ma_nguon" -C "$TEMP_DIR_ma_nguon" --overwrite
      mv "$TEMP_DIR_ma_nguon"/$check_path_file_wp_load_bi_boc_boi_thu_muc_change /usr/local/lsws/"$NAME"/html
      rm -rf "$TEMP_DIR_ma_nguon"
    else
      tar --use-compress-program="pigz" -xf "$duong_dan_thu_muc_ma_nguon" -C /usr/local/lsws/"$NAME"/html --overwrite
    fi
  fi
fi

_rundone "$giai_nen $ma_nguon website $NAME"

_runing "$phan_quyen website $NAME"
chown -R "$User_name_vhost":"$User_name_vhost" /usr/local/lsws/"$NAME"/html

if [[ -n "$lock_down" ]]; then
  find /usr/local/lsws/"$NAME"/html -type f -print0 | xargs -0 chmod 404
  find /usr/local/lsws/"$NAME"/html -type d -print0 | xargs -0 chmod 515
  find /usr/local/lsws/"$NAME"/html/wp-content/uploads -type d -print0 | xargs -0 chmod 755
  . /etc/wptt/bao-mat/wptt-chattr-file-lock $NAME on
else
  find /usr/local/lsws/"$NAME"/html -type f -print0 | xargs -0 chmod 644
  find /usr/local/lsws/"$NAME"/html -type d -print0 | xargs -0 chmod 755
fi
_rundone "$phan_quyen website $NAME"

# Update wp-config.php
wp_config_php_path="/usr/local/lsws/$NAME/html/wp-config.php"
if [[ -f $wp_config_php_path ]]; then
  _runing "Kết nối dữ liệu website $NAME"
  [[ -n "$lock_down" ]] && chattr -i "$wp_config_php_path"

  wp config set DB_HOST 'localhost' --type=constant --allow-root --path="/usr/local/lsws/$NAME/html" --quiet
  wp config set DB_NAME "$DB_Name_web" --type=constant --allow-root --path="/usr/local/lsws/$NAME/html" --quiet
  wp config set DB_USER "$DB_User_web" --type=constant --allow-root --path="/usr/local/lsws/$NAME/html" --quiet
  wp config set DB_PASSWORD "$DB_Password_web" --type=constant --allow-root --path="/usr/local/lsws/$NAME/html" --quiet
  wp rewrite flush --allow-root --path=/usr/local/lsws/"$NAME"/html >/dev/null 2>&1

  [[ -n "$lock_down" ]] && chattr +i "$wp_config_php_path"
  _rundone "Kết nối dữ liệu website $NAME"
fi

if [[ -f "/usr/local/lsws/$NAME/html/wp-load.php" ]]; then
  . /etc/wptt/cache/wptt-xoacache "$NAME" >/dev/null 2>&1
fi

if [[ -d "/usr/local/lsws/$NAME/luucache" ]]; then
  _runing "$don_dep cache lscache"
  rm -rf /usr/local/lsws/"$NAME"/luucache
  _rundone "$don_dep cache lscache"
fi

# ==============================================================================
# DỌN DẸP CONFIG CŨ TRONG VHOST
# ==============================================================================
vhost_conf="/usr/local/lsws/conf/vhosts/$NAME/$NAME.conf"
if [[ "$Website_chinh" == "$NAME" && -f "$vhost_conf" && -n $id_dang_nhap_phpmyadmin ]] && grep -qiE "realm.*phpmyadmin|context /phpmyadmin" "$vhost_conf"; then
  if [[ ! -d /usr/local/lsws/$NAME/html/phpmyadmin ]]; then
    [[ -f /usr/local/lsws/$NAME/passwd/.phpmyadmin ]] && rm -f "/usr/local/lsws/$NAME/passwd/.phpmyadmin"
    sed -i "/id_dang_nhap_phpmyadmin/d" /etc/wptt/.wptt.conf
    sed -i "/password_dang_nhap_phpmyadmin/d" /etc/wptt/.wptt.conf
    sed -i -e "/^realm ${Website_chinh}phpmyadmin/,/^}/d" "$vhost_conf" 2>/dev/null
    sed -i -e "/^context \/phpmyadmin\//,/^}/d" "$vhost_conf" 2>/dev/null
    sed -i -e '/^realm '${Website_chinh}phpphpmyadmin'/,/^}$/d' "$vhost_conf" 2>/dev/null
  fi
fi

if ! grep -qiE "realm.*phpmyadmin|context /phpmyadmin" "$vhost_conf" && [[ -d /usr/local/lsws/$NAME/html/phpmyadmin ]]; then
  rm -rf /usr/local/lsws/$NAME/html/phpmyadmin
fi

if [[ -f "$vhost_conf" && -n $id_dang_nhap_quan_ly_file_cap_2 ]] && grep -qiE "realm.*files|context /quan-ly-files" "$vhost_conf"; then
  if [[ ! -d /usr/local/lsws/$NAME/html/quan-ly-files ]]; then
    sed -i -e '/^realm '${NAME}files'/,/^}$/d' /usr/local/lsws/conf/vhosts/$NAME/$NAME.conf
    sed -i -e '/^context \/quan-ly-files\//,/^}$/d' /usr/local/lsws/conf/vhosts/$NAME/$NAME.conf
    sed -i '/password_dang_nhap_quan_ly_file_cap_2/d' /etc/wptt/vhost/.$NAME.conf
    sed -i '/id_dang_nhap_quan_ly_file_cap_2/d' /etc/wptt/vhost/.$NAME.conf
    sed -i '/id_quan_ly_files/d' /etc/wptt/vhost/.$NAME.conf
    sed -i '/password_quan_ly_file/d' /etc/wptt/vhost/.$NAME.conf
    [[ -f /usr/local/lsws/$NAME/passwd/.files ]] && rm -f /usr/local/lsws/$NAME/passwd/.files
    [[ -f /usr/local/lsws/$NAME/passwd/.password-giatuan.json ]] && rm -f /usr/local/lsws/"$NAME"/passwd/.password-giatuan.json
    [[ -f /usr/local/lsws/$NAME/passwd/.user-giatuan.json ]] && rm -f /usr/local/lsws/"$NAME"/passwd/.user-giatuan.json
  fi
fi

if ! grep -qiE "realm.*files|context /quan-ly-files" "$vhost_conf" && [[ -d /usr/local/lsws/$NAME/html/quan-ly-files ]]; then
  rm -rf /usr/local/lsws/$NAME/html/quan-ly-files
fi

/usr/local/lsws/bin/lswsctrl restart >/dev/null 2>&1

clear
# ==============================================================================
# BẢNG TÓM TẮT THÀNH CÔNG (CĂN TRÁI VỚI HÀM LOCAL IN_DONG ĐỂ GIỮ MÀU XANH LÁ)
# ==============================================================================
unset thong_bao_ma_nguon thong_bao_sql
thong_bao_sql=$(echo "$duong_dan_thu_path_sql" | sed 's/_[0-9]\+phut_//' | cut -f6 -d '/' | grep "^$NAME" | sed "s/^$NAME//g" | cut -f1 -d '.')
thong_bao_ma_nguon=$(echo "$duong_dan_thu_muc_ma_nguon" | sed 's/_[0-9]\+phut_//' | cut -f6 -d '/' | grep "^$NAME" | sed "s/^$NAME//g" | cut -f1 -d '.')

box_inner_width=${box_inner_width:-71}
echo -e "\n${C_GREEN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_BOLD_WHITE}$khoi_phuc_website $NAME thành công${C_RESET}"
echo -e "${C_GREEN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"

function in_dong_green() {
  local raw_text="$1"
  local colored_text="$2"
  local len=$(echo -n "$raw_text" | awk '{print length($0)}')
  local pad=$((box_inner_width - len - 2))
  [[ $pad -lt 0 ]] && pad=0
  echo -e "${C_GREEN}│${C_RESET}  ${colored_text}$(printf '%*s' "$pad" "")${C_GREEN}│${C_RESET}"
}

if [[ -n "$thong_bao_sql" && -n "$thong_bao_ma_nguon" && "$thong_bao_ma_nguon" == "$thong_bao_sql" ]]; then
  chuyen_doi_thong_bao_gio=$(echo "$thong_bao_ma_nguon" | cut -c 1-2)
  chuyen_doi_thong_bao_ngay=$(echo "$thong_bao_ma_nguon" | cut -f2 -d '_' | cut -c 1-2)
  chuyen_doi_thong_bao_thang=$(echo "$thong_bao_ma_nguon" | cut -f3 -d '_' | cut -c 1-2)
  chuyen_doi_thong_bao_nam=$(echo "$thong_bao_ma_nguon" | cut -f4 -d '_' | cut -c 1-4)
  if [[ -n "$chuyen_doi_thong_bao_gio" && -n "$chuyen_doi_thong_bao_ngay" && -n "$chuyen_doi_thong_bao_thang" && -n "$chuyen_doi_thong_bao_nam" ]]; then
    time_str="Lúc $chuyen_doi_thong_bao_gio giờ - Ngày $chuyen_doi_thong_bao_ngay/$chuyen_doi_thong_bao_thang/$chuyen_doi_thong_bao_nam"
    in_dong_green "Khôi phục về : $time_str" "${C_BOLD_WHITE}Khôi phục về :${C_RESET} ${C_CYAN}$time_str${C_RESET}"
  fi
else
  in_dong_green "Trạng thái   : Cơ sở dữ liệu và Mã nguồn đã được phục hồi." "${C_BOLD_WHITE}Trạng thái   :${C_RESET} Cơ sở dữ liệu và Mã nguồn đã được phục hồi."
fi

echo -e "${C_GREEN}╰───────────────────────────────────────────────────────────────────────╯${C_RESET}\n"

# Giải phóng khóa (Unlock)
flock -u 200
exec 200>&-
rm -f "/tmp/wptt_lock_sao_luu_khoi_phuc_${NAME}.lock" 2>/dev/null

[[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-backup-restore-main 1
