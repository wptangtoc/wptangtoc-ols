#!/bin/bash
# @author: Gia Tuấn
# @website: https://wptangtoc.com
# @email: giatuan@wptangtoc.com
# @since: 2025

function huong_dan() {
  Tính năng tự động sao lưu website là một yếu tố thiết yếu để đảm bảo an toàn dữ liệu và khả năng phục hồi cho bất kỳ trang web nào. Việc đầu tư vào một giải pháp sao lưu tự động đáng tin cậy là một quyết định khôn ngoan để bảo vệ tài sản website của bạn.

  Đúng vậy, tính năng tự động sao lưu website [automatic website backup] là một quy trình được thiết lập để tự động tạo ra các bản sao của dữ liệu và tệp tin website của bạn theo một lịch trình định sẵn mà không cần sự can thiệp thủ công của con người.

  Những bản sao này đóng vai trò như một [phao cứu sinh], cho phép bạn khôi phục lại website về trạng thái hoạt động ổn định trước đó nếu có sự cố xảy ra.

  Tính năng này sao lưu mã nguồn [Định dạng .zip] và database website [định dạng .sql hoặc .sql.gz - nếu đã thiết lập]

  Hỗ trợ sao lưu tại local máy chủ và đám mây drive
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null

clear
echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}SAO LƯU & KHÔI PHỤC ➜ Thiết lập Tự động sao lưu (Auto Backup)${C_RESET}"
echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

# ==============================================================================
# BẢNG THỐNG KÊ CÁC DOMAIN ĐÃ KÍCH HOẠT AUTO BACKUP
# ==============================================================================
active_list=()

if [ "$(ls -A /etc/wptt/vhost 2>/dev/null | grep -v '^\.\.conf$' | sort -uV)" ]; then
  for entry in $(ls -A /etc/wptt/vhost | grep -v '^\.\.conf$' | sort -uV); do
    domain=$(echo "$entry" | sed 's/^.//' | sed 's/.conf//')
    path="/etc/cron.d/backup$domain.cron"

    if [[ -f "$path" ]]; then
      cron_line=$(cat "$path" | grep -v "^#")
      checkauto1=$(echo "$cron_line" | awk '{print $2}')
      check_dom=$(echo "$cron_line" | awk '{print $3}')
      checkauto2=$(echo "$cron_line" | awk '{print $5}')

      kiemtra_doi_so=$(grep -c "1998" /etc/wptt-auto/$domain-auto-backup 2>/dev/null)
      tinhnang=""

      if [[ "$kiemtra_doi_so" == "1" ]]; then
        if grep -q 'onedrive' ~/.config/rclone/rclone.conf 2>/dev/null; then tinhnang=" (OneDrive)"; else tinhnang=" (GDrive)"; fi
      elif [[ "$kiemtra_doi_so" == "2" ]]; then
        if grep -q 'onedrive' ~/.config/rclone/rclone.conf 2>/dev/null; then tinhnang=" (OneDrive + Xóa Local)"; else tinhnang=" (GDrive + Xóa Local)"; fi
      fi

      if [[ "$check_dom" != "*" && -n "$check_dom" ]]; then
        thu123="Lúc $checkauto1 giờ - Ngày $check_dom hàng tháng"
      elif [[ "$checkauto2" != "*" && -n "$checkauto2" ]]; then
        case "$checkauto2" in
        0 | 7) thu123="Lúc $checkauto1 giờ - CN hàng tuần" ;;
        1) thu123="Lúc $checkauto1 giờ - T2 hàng tuần" ;;
        2) thu123="Lúc $checkauto1 giờ - T3 hàng tuần" ;;
        3) thu123="Lúc $checkauto1 giờ - T4 hàng tuần" ;;
        4) thu123="Lúc $checkauto1 giờ - T5 hàng tuần" ;;
        5) thu123="Lúc $checkauto1 giờ - T6 hàng tuần" ;;
        6) thu123="Lúc $checkauto1 giờ - T7 hàng tuần" ;;
        esac
      else
        thu123="Lúc $checkauto1 giờ - Hàng ngày"
      fi

      domain_padded=$(printf "%-25s" "$domain")
      active_list+=("${C_BOLD_WHITE}${domain_padded}${C_RESET} : ${C_YELLOW}${thu123}${tinhnang}${C_RESET}")
    fi
  done
fi

# Check ALL WEBSITE
if [[ -f /etc/cron.d/backup-all-website-wptt-ols.cron ]]; then
  cron_line_all=$(cat /etc/cron.d/backup-all-website-wptt-ols.cron | grep -v "^#")
  checkauto1=$(echo "$cron_line_all" | awk '{print $2}')
  check_dom_all=$(echo "$cron_line_all" | awk '{print $3}')
  checkauto2=$(echo "$cron_line_all" | awk '{print $5}')

  kiemtra_doi_so=$(grep -c "1998" /etc/wptt-auto/all-website-wptt-ols-auto-backup 2>/dev/null)
  tinhnang=""
  if [[ "$kiemtra_doi_so" == "1" ]]; then tinhnang=" (Cloud)"; elif [[ "$kiemtra_doi_so" == "2" ]]; then tinhnang=" (Cloud + Xóa Local)"; fi

  if [[ "$check_dom_all" != "*" && -n "$check_dom_all" ]]; then
    thu123="Lúc $checkauto1 giờ - Ngày $check_dom_all hàng tháng"
  elif [[ "$checkauto2" != "*" && -n "$checkauto2" ]]; then
    case "$checkauto2" in
    0 | 7) thu123="Lúc $checkauto1 giờ - CN" ;; 1) thu123="Lúc $checkauto1 giờ - T2" ;; 2) thu123="Lúc $checkauto1 giờ - T3" ;;
    3) thu123="Lúc $checkauto1 giờ - T4" ;; 4) thu123="Lúc $checkauto1 giờ - T5" ;; 5) thu123="Lúc $checkauto1 giờ - T6" ;;
    6) thu123="Lúc $checkauto1 giờ - T7" ;;
    esac
  else
    thu123="Lúc $checkauto1 giờ - Hàng ngày"
  fi

  domain_padded=$(printf "%-25s" "[Toàn bộ Website]")
  active_list+=("${C_YELLOW}${domain_padded}${C_RESET} : ${C_YELLOW}${thu123}${tinhnang}${C_RESET}")
fi

if [[ ${#active_list[@]} -gt 0 ]]; then
  echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_YELLOW}DANH SÁCH WEBSITE ĐÃ KÍCH HOẠT AUTO BACKUP${C_RESET}"
  echo -e "${C_CYAN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
  for item in "${active_list[@]}"; do
    left_text "$item" 2
  done
  echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"
fi

# ==============================================================================
# HÀM MENU LỌC THÔNG MINH (CHỈ HIỂN THỊ DOMAIN CHƯA KÍCH HOẠT)
# ==============================================================================
function lua_chon_NAME() {
  unset NAME selects
  selects=()

  for filepath in /etc/wptt/vhost/.*.conf; do
    [[ ! -f "$filepath" || "$filepath" == *"/..conf" ]] && continue
    local domain="${filepath##*/}"
    domain="${domain%.conf}"
    domain="${domain#.}"

    if [[ "$domain" == ?*.?* ]]; then
      if [[ ! -f "/etc/cron.d/backup$domain.cron" ]]; then
        selects+=("$domain")
      fi
    fi
  done

  if [[ ! -f /etc/cron.d/backup-all-website-wptt-ols.cron ]]; then
    selects+=("Tất cả website")
  fi

  if [[ ${#selects[@]} -eq 0 ]]; then
    echo -e "${C_YELLOW}⚠️ Tất cả domain trên hệ thống đều đã được kích hoạt Auto Backup!${C_RESET}"
    sleep 3
    exec /etc/wptt/wptt-backup-restore-main 1
  fi

  mapfile -t selects < <(printf "%s\n" "${selects[@]}" | sort -uV)

  echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
  local title_text="Lựa chọn website muốn thiết lập Auto Backup:"
  local len=$(echo -n "$title_text" | awk '{print length($0)}')
  local pad_r=$((box_inner_width - len - 2))
  [[ $pad_r -lt 0 ]] && pad_r=0
  echo -e "${C_CYAN}│${C_RESET}  ${C_YELLOW}${title_text}${C_RESET}$(printf '%*s' "$pad_r" "")${C_CYAN}│${C_RESET}"

  local line_len=$((len + 3))
  local pad_line_r=$((box_inner_width - line_len))
  [[ $pad_line_r -lt 0 ]] && pad_line_r=0
  local short_line=$(printf "%${line_len}s" "" | sed 's/ /─/g')
  echo -e "${C_CYAN}├${short_line}$(printf '%*s' "$pad_line_r" "")│${C_RESET}"

  local i=1
  for domain in "${selects[@]}"; do
    if [[ "$domain" == "Tất cả website" ]]; then
      local item_text=$(printf "  ${C_CYAN}%3d)${C_RESET} ${C_YELLOW}%s${C_RESET}" "$i" "$domain")
    else
      local item_text=$(printf "  ${C_CYAN}%3d)${C_RESET} ${C_BOLD_WHITE}%s${C_RESET}" "$i" "$domain")
    fi
    local clean_text=$(printf "  %3d) %s" "$i" "$domain")
    local item_len=$(echo -n "$clean_text" | awk '{print length($0)}')
    local pad=$((box_inner_width - item_len))
    [[ $pad -lt 0 ]] && pad=0
    echo -e "${C_CYAN}│${C_RESET}${item_text}$(printf '%*s' "$pad" "")${C_CYAN}│${C_RESET}"
    ((i++))
  done
  echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯${C_RESET}"

  local fzf_installed=false
  if command -v fzf &>/dev/null; then
    fzf_installed=true
    PROMPT_TEXT="Nhập lựa chọn (1-${#selects[@]}) [00=Tìm nhanh] [0=Thoát]: "
  else
    PROMPT_TEXT="Nhập lựa chọn (1-${#selects[@]}) [0=Thoát]: "
  fi

  while true; do
    echo -en "${C_CYAN}${PROMPT_TEXT}${C_RESET}"
    if ! read -r REPLY; then exit 1; fi
    REPLY=$(echo "$REPLY" | tr -d ' ' | tr '[:upper:]' '[:lower:]')

    case "$REPLY" in
    0)
      echo -e "\n${C_GREEN}Đang thoát...${C_RESET}"
      NAME="0"
      return 0
      ;;
    00)
      if $fzf_installed; then
        local selected_name=$(printf '%s\n' "${selects[@]}" | nl -w 3 -s ': ' | fzf --prompt="Tìm website >> " --height=40% --border=rounded --color=border:red --cycle --reverse)
        selected_name=$(echo "$selected_name" | sed 's/^[[:space:]]*[0-9]\+\:[[:space:]]*//')
        if [[ -n "$selected_name" ]]; then
          NAME="$selected_name"
          return 0
        else echo -e "${C_YELLOW}Đã hủy chọn. Vui lòng chọn lại.${C_RESET}"; fi
      else
        echo -e "${C_RED}Lỗi: FZF chưa cài đặt.${C_RESET}"
      fi
      ;;
    *)
      if [[ "$REPLY" =~ ^[0-9]+$ ]] && [ "$REPLY" -ge 1 ] && [ "$REPLY" -le ${#selects[@]} ]; then
        local action_index=$((REPLY - 1))
        NAME="${selects[$action_index]}"
        return 0
      else
        echo -e "\n${C_RED}❌ Lựa chọn không hợp lệ! Vui lòng chọn lại.${C_RESET}"
      fi
      ;;
    esac
  done
}

lua_chon_NAME

[[ "$NAME" == "0" || -z "$NAME" ]] && {
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-backup-restore-main 1
  return 2>/dev/null || exit
}

if [[ "$NAME" != 'Tất cả website' ]]; then
  pathcheck="/etc/wptt/vhost/.$NAME.conf"
  if [[ ! -f "$pathcheck" ]]; then
    echo -e "\n${C_RED}❌ Tên miền không tồn tại trên hệ thống này!${C_RESET}"
    sleep 3
    [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-backup-restore-main 1
    return 2>/dev/null || exit
  fi
fi

# ==============================================================================
# NHẬP THỜI GIAN SAO LƯU (GIỜ & THỨ)
# ==============================================================================
echo ""
while true; do
  echo -en "${C_CYAN}👉 Nhập Giờ muốn chạy Backup (0-23) [Enter=1h sáng]: ${C_RESET}"
  read gio
  [[ -z "$gio" ]] && gio="1"
  if [[ ! "$gio" =~ ^[0-9]+$ ]] || ((gio < 0 || gio > 23)); then
    echo -e "${C_RED}❌ Lỗi: Giờ không hợp lệ! Vui lòng nhập từ 0 đến 23.${C_RESET}"
  else
    break
  fi
done

. /etc/wptt/wptt-times-tuan
tuan

case "$thu" in
0 | 7) thu12="Chủ nhật hàng tuần" ;;
1) thu12="Thứ hai hàng tuần" ;;
2) thu12="Thứ ba hàng tuần" ;;
3) thu12="Thứ tư hàng tuần" ;;
4) thu12="Thứ năm hàng tuần" ;;
5) thu12="Thứ sáu hàng tuần" ;;
6) thu12="Thứ bảy hàng tuần" ;;
*) thu12="Hàng ngày" ;;
esac
[[ "$thu" == "9" ]] && thu12="Ngày $ngay_cua_thang hàng tháng"

phut=$(shuf -i2-58 -n1)
[[ -z "$phut" ]] && phut='0'

# ==============================================================================
# XỬ LÝ BACKUP LUỸ TIẾN NẾU THƯ MỤC UPLOADS QUÁ NẶNG (>1GB)
# ==============================================================================
response_loai_backup="1"
if [[ -f "/usr/local/lsws/$NAME/html/wp-load.php" ]]; then
  SIZE_KB=$(du -sk /usr/local/lsws/$NAME/html/wp-content/uploads 2>/dev/null | awk '{print $1}')
  LIMIT_KB=$((1024 * 1024))
  if [[ ${SIZE_KB:-0} -gt $LIMIT_KB ]]; then
    . /etc/wptt/php/php-cli-domain-config $NAME
    if [[ $(/usr/local/lsws/lsphp${phien_ban_php_domain_thuc_thi}/bin/php /usr/local/bin/wp option get uploads_use_yearmonth_folders --allow-root --path=/usr/local/lsws/$NAME/html 2>/dev/null) == '1' ]]; then
      echo -e "\n${C_YELLOW}⚠️ Phát hiện thư mục Uploads của website lớn hơn 1GB!${C_RESET}"
      echo -e "Hệ thống khuyến nghị dùng Backup Luỹ tiến (Chỉ sao lưu các file mới) để tiết kiệm ổ cứng."
      if wptt_xac_nhan "Bạn muốn sử dụng loại Sao lưu nào?" "${C_BOLD_WHITE}Website:${C_RESET} ${C_GREEN}$NAME${C_RESET}" "" "Sao lưu Luỹ tiến (Tiết kiệm dung lượng)" "Sao lưu Full (Đầy đủ)"; then
        response_loai_backup="2"
      else
        response_loai_backup="1"
      fi
    fi
  fi
fi

# ==============================================================================
# XÁC NHẬN VÀ XỬ LÝ RCLONE CLOUD
# ==============================================================================
echo ""
msg_xacnhan="Bạn có chắc chắn muốn Tự động Sao lưu website lúc ${C_YELLOW}$phut phút, $gio giờ${C_RESET} - ${C_GREEN}$thu12${C_RESET}?"
if wptt_xac_nhan "$msg_xacnhan" "${C_BOLD_WHITE}Website:${C_RESET} ${C_YELLOW}$NAME${C_RESET}" "" "Đồng ý Thiết lập" "Hủy bỏ"; then

  mkdir -p /etc/wptt-auto
  uploads="n"
  delete="n"
  tuan1="12345"
  tuan2="12345"

  if grep -rnw '/root/.config/rclone/rclone.conf' -e "wptangtoc" >/dev/null 2>&1; then
    cloud_name="Google Drive"
    grep -q 'onedrive' ~/.config/rclone/rclone.conf 2>/dev/null && cloud_name="OneDrive"

    echo ""
    if wptt_xac_nhan "Bạn có muốn Tự động Upload file lên đám mây $cloud_name không?" "" "" "Có (Tự động Upload)" "Không cần"; then
      uploads="y"
      tuan1="1998"

      echo ""
      if wptt_xac_nhan "Khi đã Upload thành công, bạn có muốn XÓA file backup tại máy chủ (Local) để trống ổ cứng không?" "" "" "Có (Xóa Local)" "Giữ lại Local"; then
        delete="y"
        tuan2="1998"
      fi
    fi
  fi

  # ==============================================================================
  # GHI FILE CẤU HÌNH VÀ CRON
  # ==============================================================================
  _runing "Đang khởi tạo chu kỳ Cronjob..."

  if [[ "$NAME" == 'Tất cả website' ]]; then
    script_path="/etc/wptt-auto/all-website-wptt-ols-auto-backup"
    cron_path="/etc/cron.d/backup-all-website-wptt-ols.cron"
    [[ "$response_loai_backup" == '2' ]] && cmd_type="wptt-saoluu-luy-tien-tung-phan" || cmd_type="wptt-saoluu"
  else
    script_path="/etc/wptt-auto/$NAME-auto-backup"
    cron_path="/etc/cron.d/backup$NAME.cron"
    [[ "$response_loai_backup" == '2' ]] && cmd_type="wptt-saoluu-luy-tien-tung-phan" || cmd_type="wptt-saoluu"
  fi

  cat >"$script_path" <<END
#!/bin/bash
ionice -c 3 nice -n 19 /bin/bash /etc/wptt/backup-restore/$cmd_type "$NAME" $tuan1 $tuan2
END
  chmod 740 "$script_path"

  cron_thuc_thi="$phut $gio * * $thu"
  if [[ "$thu" == '9' ]]; then
    cron_thuc_thi="$phut $gio $ngay_cua_thang * *"
  fi

  cat >"$cron_path" <<END
$cron_thuc_thi root $script_path >/dev/null 2>&1
END

  if $(cat /etc/*release | grep -q "Ubuntu"); then
    NAME_CRON_ubuntu=${NAME//[.]/_}
    ln -sf "$cron_path" /etc/cron.d/backup${NAME_CRON_ubuntu}_cron 2>/dev/null
    [[ "$NAME" == 'Tất cả website' ]] && ln -sf "$cron_path" /etc/cron.d/backup-all-website-wptt-ols_cron
    systemctl restart cron.service
  else
    systemctl restart crond.service
  fi

  echo "Thiết lập tự động sao lưu $NAME: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log
  _rundone "Cấu hình Cronjob thành công"

  # ==============================================================================
  # BẢNG TÓM TẮT THÀNH CÔNG (UX BO CONG - ĐỒNG BỘ VIỀN CYAN)
  # ==============================================================================
  echo -e "\n${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_GREEN}ĐÃ THIẾT LẬP AUTO BACKUP THÀNH CÔNG${C_RESET}"
  echo -e "${C_CYAN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"

  left_text "Website        : ${C_YELLOW}$NAME${C_RESET}"
  left_text "Chu kỳ chạy    : ${C_GREEN}$gio giờ $phut phút - $thu12${C_RESET}"

  if [[ "$NAME" == 'Tất cả website' ]]; then
    left_text "Lưu tại Máy chủ: /usr/local/backup-website/..."
  else
    left_text "Lưu tại Máy chủ: /usr/local/backup-website/$NAME/"
  fi

  if [[ "$uploads" == "y" ]]; then
    if [[ "$NAME" == 'Tất cả website' ]]; then
      left_text "Lưu tại Cloud  : $cloud_name -> wptangtoc_ols_backup/"
    else
      left_text "Lưu tại Cloud  : $cloud_name -> wptangtoc_ols_backup/$NAME/"
    fi
  fi

  echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"
  echo -e "Nếu cần khôi phục, hãy sử dụng tính năng [Khôi phục website] trong menu WPTangToc."

else
  echo -e "${C_YELLOW}Đã hủy thao tác thiết lập Auto Backup.${C_RESET}"
fi

[[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-backup-restore-main 1
