function huong_dan() {
  Tính năng tắt tự động sao lưu database là một tùy chọn cho phép bạn dừng hoặc tạm ngưng việc hệ thống tự động tạo ra các bản sao lưu [backup] riêng cho cơ sở dữ liệu [database] của website theo lịch trình đã định sẵn.

  Nói một cách đơn giản, nếu bạn có một tác vụ tự động chạy mysqldump mỗi đêm để sao lưu cơ sở dữ liệu, việc tắt tính năng này sẽ làm cho tác vụ đó không còn thực hiện nữa. Cơ sở dữ liệu sẽ không được tự động sao lưu riêng lẻ cho đến khi bạn kích hoạt lại.
}

echo ""
echo ""
echo ""
echo "========================================================================="
echo "|Sao lưu & khôi phục => Tắt thiết lập tự động sao lưu database          |"
echo "========================================================================="
. /etc/wptt/echo-color
echo ""
echo ""
if [ "$(ls -A /etc/wptt/vhost | grep -v '^\.\.conf$' | sort -uV)" ]; then
  echo "========================================================================="
  echo "Danh sách domain đã kích hoạt tự động backup database:"
  echo "========================================================================="

  for entry in $(ls -A /etc/wptt/vhost | grep -v '^\.\.conf$' | sort -uV); do
    domain=$(echo $entry | sed 's/^.//' | sed 's/.conf//')
    path="/etc/cron.d/backup-database$domain.cron"

    if [[ -f "$path" ]]; then
      checkauto="Đã kích hoạt tự động lúc "
      # Dùng awk để lấy chính xác các cột
      cron_line=$(cat "$path" | grep -v "^#")
      checkauto1=$(echo "$cron_line" | awk '{print $2}') # Giờ
      check_dom=$(echo "$cron_line" | awk '{print $3}')  # Ngày trong tháng
      checkauto2=$(echo "$cron_line" | awk '{print $5}') # Ngày trong tuần

      kiemtra_doi_so=$(grep -c "1998" /etc/wptt-auto/$domain-auto-backup-database 2>/dev/null)
      tinhnang=""

      if [[ "$kiemtra_doi_so" = "1" ]]; then
        if grep -q 'onedrive' ~/.config/rclone/rclone.conf 2>/dev/null; then
          tinhnang="| backup xong uploads lên OneDrive"
        else
          tinhnang="| backup xong uploads lên Google Drive"
        fi
      elif [[ "$kiemtra_doi_so" = "2" ]]; then
        if grep -q 'onedrive' ~/.config/rclone/rclone.conf 2>/dev/null; then
          tinhnang="| backup xong uploads lên OneDrive và xóa luôn file backup tại local"
        else
          tinhnang="| backup xong uploads lên Google Drive và xóa luôn file backup tại local"
        fi
      fi

      # Logic nhận diện Hàng Tháng -> Hàng Tuần -> Hàng Ngày
      if [[ "$check_dom" != "*" && -n "$check_dom" ]]; then
        thu123=" giờ ngày $check_dom hàng tháng"
      elif [[ "$checkauto2" != "*" && -n "$checkauto2" ]]; then
        case "$checkauto2" in
        0 | 7) thu123=" giờ chủ nhật hàng tuần" ;;
        1) thu123=" giờ thứ hai hàng tuần" ;;
        2) thu123=" giờ thứ ba hàng tuần" ;;
        3) thu123=" giờ thứ tư hàng tuần" ;;
        4) thu123=" giờ thứ năm hàng tuần" ;;
        5) thu123=" giờ thứ sáu hàng tuần" ;;
        6) thu123=" giờ thứ bảy hàng tuần" ;;
        esac
      else
        thu123=" giờ hàng ngày"
      fi

    else
      checkauto="Chưa được kích hoạt"
      checkauto1=""
      thu123=" tự động sao lưu backup website"
      tinhnang=""
    fi
    echo "Website $domain $checkauto$checkauto1$thu123 $tinhnang"
  done

  # Xử lý cho Toàn bộ website (All website)
  if [[ ! -f /etc/cron.d/backup-all-database-wptt-ols.cron ]]; then
    echo "Tính năng sao lưu toàn bộ website chưa được thiết lập"
  else
    checkauto="Đã kích hoạt tự động lúc "
    cron_line_all=$(cat /etc/cron.d/backup-all-database-wptt-ols.cron | grep -v "^#")
    checkauto1=$(echo "$cron_line_all" | awk '{print $2}')
    check_dom_all=$(echo "$cron_line_all" | awk '{print $3}')
    checkauto2=$(echo "$cron_line_all" | awk '{print $5}')

    kiemtra_doi_so=$(grep -c "1998" /etc/wptt-auto/all-database-wptt-ols-auto-backup 2>/dev/null)
    tinhnang=""

    if [[ "$kiemtra_doi_so" = "1" ]]; then
      tinhnang="| backup xong uploads lên Google Drive"
    elif [[ "$kiemtra_doi_so" = "2" ]]; then
      tinhnang="| backup xong uploads lên Google Drive và xóa luôn file backup tại local"
    fi

    # Logic nhận diện Hàng Tháng -> Hàng Tuần -> Hàng Ngày cho All Website
    if [[ "$check_dom_all" != "*" && -n "$check_dom_all" ]]; then
      thu123=" giờ ngày $check_dom_all hàng tháng"
    elif [[ "$checkauto2" != "*" && -n "$checkauto2" ]]; then
      case "$checkauto2" in
      0 | 7) thu123=" giờ chủ nhật hàng tuần" ;;
      1) thu123=" giờ thứ hai hàng tuần" ;;
      2) thu123=" giờ thứ ba hàng tuần" ;;
      3) thu123=" giờ thứ tư hàng tuần" ;;
      4) thu123=" giờ thứ năm hàng tuần" ;;
      5) thu123=" giờ thứ sáu hàng tuần" ;;
      6) thu123=" giờ thứ bảy hàng tuần" ;;
      esac
    else
      thu123=" giờ hàng ngày"
    fi

    echo "Toàn bộ website $checkauto$checkauto1$thu123 $tinhnang"
  fi

  echo "========================================================================="
  echo
fi

function lua_chon_NAME() {
  NAME=""
  if [ "$(ls -At /etc/wptt/vhost)" ]; then
    selects=()
    for entry in $(ls -A /etc/wptt/vhost | sort -uV); do
      NAME=$(echo $entry | sed 's/^.//' | sed 's/.conf//')
      if [[ -f /etc/cron.d/backup-database$NAME.cron ]]; then
        selects+=("$NAME")
      fi
    done

    if [[ -f /etc/cron.d/backup-all-database-wptt-ols.cron ]]; then
      selects+=("Tất cả website")
    fi

    if [[ $selects = '' ]]; then
      echo "Tất cả domain trên hệ thống chưa có domain nào được kích hoạt sao lưu database website tự động"
      exec /etc/wptt/wptt-backup-restore-main 1
    fi

    PS3="
-//- Nhập lựa chọn website của bạn [0=Thoát]: "
    select select in "${selects[@]}"; do
      NAME=$select
      index=$REPLY
      break
    done
  else
    clear
    echo "Không có domain nào"
    exit
  fi
}

echo ""
echo ""
echo "Lựa chọn website bạn muốn tắt tự động sao lưu website: "
echo ""
lua_chon_NAME

if [[ "$NAME" = "0" || "$NAME" = "" ]]; then
  exec /etc/wptt/wptt-backup-restore-main 1
fi

if [[ $NAME != 'Tất cả website' ]]; then
  pathcheck="/etc/wptt/vhost/.$NAME.conf"
  if [[ ! -f "$pathcheck" ]]; then
    clear
    echoDo "Tên miền không tồn tại trên hệ thống này"
    sleep 3
    check_menu_wptangtoc_active=$1
    if [[ $check_menu_wptangtoc_active = "98" ]]; then
      exec /etc/wptt/wptt-backup-restore-main 1
    fi
    return 2>/dev/null
    exit
  fi
fi

if [[ $NAME = 'Tất cả website' ]]; then
  _runing "Tắt tự động sao lưu database toàn bộ website"
  rm -f /etc/wptt-auto/all-database-wptt-ols-auto-backup
  rm -f /etc/cron.d/backup-all-database-wptt-ols.cron
  if $(cat /etc/*release | grep -q "Ubuntu"); then
    rm -f /etc/cron.d/backup-all-database-wptt-ols_cron
    systemctl restart cron.service
  else
    systemctl restart crond.service
  fi
  _rundone "Tắt tự động sao lưu database toàn bộ website"
  check_menu_wptangtoc_active=$1
  if [[ $check_menu_wptangtoc_active = "98" ]]; then
    exec /etc/wptt/wptt-backup-restore-main 1
  fi
  return 2>/dev/null
  exit
fi

if [ -f /etc/cron.d/backup-database"$NAME".cron ]; then
  _runing "Tắt tự động sao lưu database $NAME"
  rm -f /etc/cron.d/backup-database"$NAME".cron
  rm -f /etc/wptt-auto/$NAME-auto-backup-database
  if $(cat /etc/*release | grep -q "Ubuntu"); then
    rm -f /etc/cron.d/backup-database${NAME}_cron
    systemctl restart cron.service
  else
    systemctl restart crond.service
  fi
  _rundone "Tắt tự động sao lưu database $NAME"
else
  echo "Bạn chưa kích hoạt tự động sao lưu tự động"
  exec /etc/wptt/wptt-backup-restore-main 1
fi

check_menu_wptangtoc_active=$1
if [[ $check_menu_wptangtoc_active = "98" ]]; then
  exec /etc/wptt/wptt-backup-restore-main 1
fi
