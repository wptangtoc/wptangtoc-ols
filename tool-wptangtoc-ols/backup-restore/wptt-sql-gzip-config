function huong_dan() {
  Thiết lập chuyển đổi định dạng file backup database
  Đây là tính năng liên quan đến việc nén và giải nén file sao lưu cơ sở dữ liệu [database] của website:

  Chuyển đổi từ .sql hoặc .sql.gz hoặc .sql.zst [Nén file]:

  .sql: Là file văn bản thuần túy chứa các lệnh SQL để tạo lại cấu trúc và dữ liệu của database. File này có thể rất lớn.
  .sql.gz: Là file .sql đã được nén lại bằng thuật toán gzip. Việc này giúp giảm đáng kể dung lượng file, tiết kiệm không gian lưu trữ và làm cho việc tải lên/tải xuống nhanh hơn.
  .sql.zst: Là file .sql đã được nén lại bằng thuật toán zstd. Việc này giúp giảm đáng kể dung lượng file, tiết kiệm không gian lưu trữ và làm cho việc tải lên/tải xuống nhanh hơn.
  Cách thực hiện: Sử dụng các công cụ nén như gzip trên dòng lệnh [Linux/macOS] hoặc các phần mềm nén file như 7-Zip, WinRAR trên Windows.

  Đây là quá trình lựa chọn công nghệ nén file database sao lưu: .sql.gz và .sql gốc và .sql.zst

  Tóm lại: Việc chuyển đổi giữa .sql và .sql.gz và .sql.zst là một bước phổ biến trong quy trình sao lưu và phục hồi database website để lưu trữ và di chuyển hiệu quả.

  Mặc định thiết lập là: .sql
}

# ==============================================================================
# NẠP CẤU HÌNH, NGÔN NGỮ VÀ MÀU SẮC
# ==============================================================================
. /etc/wptt/.wptt.conf 2>/dev/null
if [[ -z "$ngon_ngu" ]]; then ngon_ngu='vi'; fi
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null

clear
echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}Quản lý Backup ➜ Thiết lập định dạng nén Database${C_RESET}"
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯${C_RESET}\n"

# ==============================================================================
# ĐỌC TRẠNG THÁI HIỆN TẠI
# ==============================================================================
current_format=".sql"
if [[ "$sql_gz" == "1" ]]; then
  current_format=".sql.gz"
elif [[ "$sql_gz" == "2" ]]; then
  current_format=".sql.zst"
fi

# ==============================================================================
# RENDER BOX CHỌN ĐỊNH DẠNG (UX TAB GẠCH CHÂN)
# ==============================================================================
box_inner_width=${box_inner_width:-71}
echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"

# Tiêu đề
title_text="Chọn định dạng nén DB (Hiện tại: $current_format):"
clean_title=$(echo -e "$title_text" | sed "s/\x1B\[[0-9;]*[a-zA-Z]//g")
len=${#clean_title}
pad_r=$((box_inner_width - len - 2))
[[ $pad_r -lt 0 ]] && pad_r=0

echo -e "${C_CYAN}│${C_RESET}  ${C_YELLOW}${title_text}${C_RESET}$(printf '%*s' "$pad_r" "")${C_CYAN}│${C_RESET}"

# Vạch gạch chân
line_len=$((len + 3))
pad_line_r=$((box_inner_width - line_len))
[[ $pad_line_r -lt 0 ]] && pad_line_r=0
short_line=$(printf "%${line_len}s" "" | sed 's/ /─/g')
echo -e "${C_CYAN}├${short_line}$(printf '%*s' "$pad_line_r" "")│${C_RESET}"

# Danh sách các lựa chọn có mô tả chi tiết
options=(
  ".sql     (Văn bản thuần, siêu nhanh, nhưng tốn dung lượng ổ cứng)"
  ".sql.gz  (Nén GZIP, chuẩn mực phổ biến, tiết kiệm 70% dung lượng)"
  ".sql.zst (Nén ZSTD, cực nhanh, tối ưu xuất sắc - Khuyên dùng)"
)

for i in "${!options[@]}"; do
  num=$((i + 1))
  text="${options[$i]}"

  # Highlight lựa chọn đang Active
  if [[ ($num == 1 && -z "$sql_gz") || ($num == 2 && "$sql_gz" == "1") || ($num == 3 && "$sql_gz" == "2") ]]; then
    item_text=$(printf "  ${C_CYAN}%d)${C_RESET} ${C_GREEN}%s [ĐANG CHỌN]${C_RESET}" "$num" "$text")
    clean_text=$(printf "  %d) %s [ĐANG CHỌN]" "$num" "$text")
  else
    item_text=$(printf "  ${C_CYAN}%d)${C_RESET} ${C_BOLD_WHITE}%s${C_RESET}" "$num" "$text")
    clean_text=$(printf "  %d) %s" "$num" "$text")
  fi

  len_text=${#clean_text}
  pad=$((box_inner_width - len_text))
  [[ $pad -lt 0 ]] && pad=0

  echo -e "${C_CYAN}│${C_RESET}${item_text}$(printf '%*s' "$pad" "")${C_CYAN}│${C_RESET}"
done
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯${C_RESET}"

# ==============================================================================
# NHẬN PHÍM AN TOÀN
# ==============================================================================
prompt_msg="${nhap_lua_chon_cua_ban:-Nhập lựa chọn của bạn} (1-3) [0=${exit_thoat:-Thoát}]: "
while true; do
  echo -en "${C_CYAN}${prompt_msg}${C_RESET}"
  if ! read -r REPLY; then exit 1; fi
  REPLY=$(echo "$REPLY" | tr -d ' ' | tr '[:upper:]' '[:lower:]')

  case "$REPLY" in
  0) exec /etc/wptt/wptt-db-main 1 ;;
  1)
    dinh_dang_database_backup="no"
    break
    ;;
  2)
    dinh_dang_database_backup="1"
    break
    ;;
  3)
    dinh_dang_database_backup="2"
    break
    ;;
  *) echo -e "\n${C_RED}❌ Lựa chọn không hợp lệ! Vui lòng nhập từ 1 đến 3.${C_RESET}\n" ;;
  esac
done

# ==============================================================================
# THỰC THI LƯU CẤU HÌNH VÀ CÀI ĐẶT
# ==============================================================================
echo ""

if [[ $dinh_dang_database_backup == '1' ]]; then
  if ! command -v gzip &>/dev/null; then
    _runing "Đang cài đặt công cụ nén GZIP"
    dnf install gzip -y >/dev/null 2>&1 || apt-get install gzip -y >/dev/null 2>&1
    _rundone "Cài đặt công cụ nén GZIP"
  fi
  print_dinh_dang_db='.sql.gz'

elif [[ $dinh_dang_database_backup == '2' ]]; then
  print_dinh_dang_db='.sql.zst'
  if ! command -v zstd &>/dev/null; then
    _runing "Đang cài đặt công cụ nén ZSTD siêu tốc"
    dnf install zstd -y >/dev/null 2>&1 || apt-get install zstd -y >/dev/null 2>&1
    _rundone "Cài đặt công cụ nén ZSTD siêu tốc"
  fi
else
  print_dinh_dang_db='.sql'
fi

_runing "Thiết lập định dạng sao lưu Database mặc định sang $print_dinh_dang_db"

# Lưu vào cấu hình
sed -i '/sql_gz/d' /etc/wptt/.wptt.conf
if [[ $dinh_dang_database_backup != 'no' ]]; then
  echo "sql_gz=$dinh_dang_database_backup" >>/etc/wptt/.wptt.conf
fi

echo "Config chuyển định dạng sao lưu database $print_dinh_dang_db: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log

_rundone "Thiết lập định dạng sao lưu Database mặc định sang $print_dinh_dang_db"

if [[ ${1:-} == "98" ]]; then
  exec /etc/wptt/wptt-backup-restore-main 1
fi
