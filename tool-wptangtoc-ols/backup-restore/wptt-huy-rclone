#!/bin/bash

function huong_dan() {
  Tính năng Hủy thiết lập Rclone backup lưu trữ đám mây là quá trình xóa bỏ hoặc vô hiệu hóa cấu hình kết nối mà bạn đã tạo trước đó trong Rclone để liên kết với một dịch vụ lưu trữ đám mây [như Google Drive, OneDrive, v.v.] cho mục đích sao lưu website.

  Nói một cách đơn giản, đây là hành động gỡ bỏ chìa khóa và địa chỉ mà Rclone dùng để truy cập và gửi file backup của bạn lên một tài khoản lưu trữ đám mây cụ thể.

  Mục đích chính của việc này:
  * Ngừng sử dụng một dịch vụ đám mây: Khi bạn muốn chuyển sang nhà cung cấp khác hoặc không muốn dùng dịch vụ đó để sao lưu nữa.
  Thay đổi cấu hình: Xóa cấu hình cũ để thiết lập lại từ đầu, có thể do lỗi hoặc muốn thay đổi cài đặt.
  * Bảo mật: Nếu nghi ngờ thông tin xác thực [token] của Rclone với dịch vụ đám mây bị lộ, việc hủy và tạo lại là cần thiết.
  * Dọn dẹp: Loại bỏ các cấu hình không còn sử dụng.

  Sau khi hủy thiết lập, Rclone sẽ không còn khả năng tương tác với dịch vụ đám mây đó thông qua cấu hình đã bị xóa, và các hoạt động sao lưu tự động mà uploads lên đám mây nó sẽ dừng lại. cho đến khi bạn thiết lập một dịch vụ lưu trữ đám mây mới thay thế.
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null # Nạp thư viện xác nhận

clear
echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}SAO LƯU & KHÔI PHỤC ➜ Hủy thiết lập Rclone Backup Cloud${C_RESET}"
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

# ==============================================================================
# KIỂM TRA TRẠNG THÁI HIỆN TẠI VÀ NHẬN DIỆN CLOUD
# ==============================================================================
rclone_conf="/root/.config/rclone/rclone.conf"

if [[ ! -d ~/.config/rclone || ! -f "$rclone_conf" ]]; then
  echo -e "${C_YELLOW}Bạn chưa thiết lập Rclone lưu trữ đám mây trên hệ thống này!${C_RESET}"
  sleep 3
  exec /etc/wptt/wptt-backup-restore-main 1
  exit
fi

if ! grep -q 'wptangtoc' "$rclone_conf" 2>/dev/null; then
  echo -e "${C_YELLOW}Không tìm thấy cấu hình kết nối Cloud hợp lệ của WPTangToc!${C_RESET}"
  sleep 3
  exec /etc/wptt/wptt-backup-restore-main 1
  exit
fi

cloud_name="Google Drive"
grep -q 'onedrive' "$rclone_conf" 2>/dev/null && cloud_name="OneDrive"

echo -e "Trạng thái hiện tại: Đang liên kết với ${C_GREEN}$cloud_name${C_RESET}.\n"

# ==============================================================================
# XÁC NHẬN VÀ THỰC THI GỠ BỎ
# ==============================================================================
if wptt_xac_nhan "Bạn có chắc chắn muốn HỦY LIÊN KẾT và XÓA cấu hình Rclone không?" "${C_BOLD_WHITE}Dịch vụ:${C_RESET} ${C_YELLOW}$cloud_name${C_RESET}" "" "Đồng ý XÓA (Gỡ liên kết)" "Hủy bỏ"; then
  echo ""
  _runing "Đang tiến hành gỡ bỏ $cloud_name và nhân Rclone..."

  # Dọn dẹp sạch sẽ cấu hình và binary
  rm -rf ~/.config/rclone
  rm -rf /usr/sbin/rclone
  rm -rf /usr/bin/rclone

  echo "Delete Rclone Backup đám mây ($cloud_name): $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log

  _rundone "Đã gỡ bỏ hoàn toàn $cloud_name"

  # ==============================================================================
  # BẢNG THÔNG BÁO THÀNH CÔNG (UX BO CONG - ĐỒNG BỘ VIỀN CYAN)
  # ==============================================================================
  echo -e "\n${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_GREEN}ĐÃ HỦY LIÊN KẾT CLOUD THÀNH CÔNG${C_RESET}"
  echo -e "${C_CYAN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
  left_text "Dịch vụ đã gỡ : ${C_YELLOW}$cloud_name${C_RESET}"
  left_text "Trạng thái    : ${C_GREEN}Đã xóa hoàn toàn cấu hình Rclone khỏi máy chủ.${C_RESET}"
  echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

else
  echo -e "${C_YELLOW}Đã hủy thao tác, giữ nguyên cấu hình $cloud_name.${C_RESET}"
fi

[[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-backup-restore-main 1
