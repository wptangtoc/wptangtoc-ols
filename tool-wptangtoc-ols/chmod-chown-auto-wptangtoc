#!/bin/bash
function check_auto_chmod_chown() {
  local NAME=${1:-}

  [[ -z $NAME ]] && return #return trả ngược về nếu $NAME không có giá trị

  unset User_name_vhost lock_down
  . /etc/wptt/vhost/.$NAME.conf
  if [[ -n $User_name_vhost ]] && [[ -z $lock_down ]]; then #yêu cầu điều kiện có username và không dùng lockdown
    # Thêm -ignore_readdir_race để chống lỗi vặt, nếu 1 website liên tục sinh ra và xóa đi các file tạm thời thực thi rất nhanh. Nếu lệnh find vừa hoàn thành Bước 1 (ghi nhận có file A), nhưng chưa kịp làm Bước 2 thì tiến trình PHP đã xóa mất file A đi rồi. sẽ báo log file này không tồn tại.
    if [[ $(/usr/bin/find /usr/local/lsws/$NAME/html -maxdepth 1 -ignore_readdir_race ! -name "phpmyadmin" \( ! -user "$User_name_vhost" -o ! -group "$User_name_vhost" \) -print -quit) ]]; then #quét xem có phân quyền đúng thuộc sở hữu hay không và bypass phpmyadmin nó quyền nobody
      ionice -c 3 nice -n 19 /etc/wptt/wptt-phanquyen $NAME >/dev/null 2>&1
    fi
  fi
}

for filepath in /etc/wptt/vhost/.*.conf; do
  [[ ! -f "$filepath" || "$filepath" == *"/..conf" ]] && continue

  NAME="${filepath##*/}"
  NAME="${NAME%.conf}"
  NAME="${NAME#.}"

  if [[ "$NAME" == ?*.?* ]]; then
    if [[ -d /usr/local/lsws/$NAME/html ]]; then
      check_auto_chmod_chown "$NAME"
    fi
  fi
done
