#!/bin/bash
function huong_dan() {
  Tính năng Kiểm tra RAM là tiện ích hệ thống để xem thông tin, theo dõi mức độ sử dụng hiện tại, và quan trọng nhất là kiểm tra lỗi hoặc sự cố của bộ nhớ truy cập ngẫu nhiên [RAM] trong máy tính hoặc máy chủ của bạn.

  Nói một cách đơn giản, đây là cách bạn khám sức khỏe cho RAM để biết nó có bao nhiêu dung lượng, đang dùng bao nhiêu, còn trống bao nhiêu, và có đang ốm [bị lỗi] hay không.

  Mục Đích Chính
  * Phát hiện lỗi RAM: RAM lỗi là nguyên nhân phổ biến gây ra các sự cố như máy tính bị treo.
  * Theo dõi hiệu suất: Xem lượng RAM đang sử dụng để biết hệ thống có bị thiếu RAM không.
  * Xác minh thông số RAM: Kiểm tra tổng dung lượng RAM đã cài đặt, công nghệ [DDR3,DDR4, DDR5].
  * Kiểm tra ZRAM: Theo dõi hiệu suất nén bộ nhớ để tối ưu hóa VPS.
}

# Khai báo màu sắc chuẩn UI WPTangToc
C_RED='\033[1;31m'
C_GREEN='\033[1;32m'
C_YELLOW='\033[1;33m'
C_CYAN='\033[1;36m'
C_RESET='\033[0m'

clear
echo -e "${C_YELLOW}Đang phân tích bộ nhớ hệ thống...${C_RESET}"
sleep 0.5 # Tạo độ mượt UI nhẹ nhàng
clear

# 1. Quét thông số RAM vật lý
read tram uram ram_khong_dung shared ram_duoc_tan_dung_cache ram_kha_dung <<<$(free -m | awk '/^Mem:/ {print $2, $3, $4, $5, $6, $7}')

# Tính toán % RAM và thiết lập cảnh báo màu sắc (UX)
ram_percent=$((uram * 100 / tram))
ram_color=$C_GREEN
[[ $ram_percent -gt 75 ]] && ram_color=$C_YELLOW
[[ $ram_percent -gt 90 ]] && ram_color=$C_RED

# Quét phần cứng RAM
check_ddr_ram=$(dmidecode -t memory 2>/dev/null | awk '/Type: DDR/ {print $2}' | head -n 1)
check_ram_bus=$(dmidecode -t memory 2>/dev/null | awk '/Speed:/ && $2 != "Unknown" {print $2" "$3}' | head -n 1)

if [[ -n "$check_ddr_ram" && -n "$check_ram_bus" ]]; then
  ram_type_bus="$check_ddr_ram / $check_ram_bus"
elif [[ -n "$check_ddr_ram" ]]; then
  ram_type_bus="$check_ddr_ram"
else
  ram_type_bus="N/A (Virtual RAM / KVM)"
fi

echo -e "${C_CYAN}╭────────────────────────────────────────────────────────╮${C_RESET}"
echo -e "${C_CYAN}│${C_RESET}           ${C_YELLOW}KIỂM TRA SỨC KHỎE RAM - WPTANGTOC OLS${C_RESET}        ${C_CYAN}│${C_RESET}"
echo -e "${C_CYAN}├────────────────────────────────────────────────────────┤${C_RESET}"
echo -e "${C_CYAN}│${C_RESET} ${C_GREEN}THÔNG TIN BỘ NHỚ VẬT LÝ (HARDWARE RAM)${C_RESET}"
echo -e "${C_CYAN}│${C_RESET} Công nghệ / Bus  : $ram_type_bus"
echo -e "${C_CYAN}│${C_RESET} Tổng dung lượng  : $tram MB"
echo -e "${C_CYAN}│${C_RESET} Đang sử dụng     : ${ram_color}${uram} MB (${ram_percent}%)${C_RESET}"
echo -e "${C_CYAN}│${C_RESET} Vùng khả dụng    : $ram_kha_dung MB (Available)"
echo -e "${C_CYAN}│${C_RESET} Vùng trống hoàn  : $ram_khong_dung MB (Free)"
echo -e "${C_CYAN}│${C_RESET} Đang làm Cache   : $ram_duoc_tan_dung_cache MB"

echo -e "${C_CYAN}├────────────────────────────────────────────────────────┤${C_RESET}"
echo -e "${C_CYAN}│${C_RESET} ${C_GREEN}BỘ NHỚ NÉN ẢO (ZRAM SWAP)${C_RESET}"

# 2. Quét thông số ZRAM
if command -v zramctl &>/dev/null && grep -q "^/dev/zram" /proc/swaps 2>/dev/null; then
  z_disk=$(zramctl --bytes -n -o DISKSIZE 2>/dev/null | awk '{sum+=$1} END {print int(sum/1024/1024)}')
  z_data=$(zramctl --bytes -n -o DATA 2>/dev/null | awk '{sum+=$1} END {print int(sum/1024/1024)}')
  z_compr=$(zramctl --bytes -n -o COMPR 2>/dev/null | awk '{sum+=$1} END {print int(sum/1024/1024)}')

  echo -e "${C_CYAN}│${C_RESET} Dung lượng tối đa: $z_disk MB"
  echo -e "${C_CYAN}│${C_RESET} Dữ liệu đang nén : $z_data MB (Lượng data thực tế)"
  echo -e "${C_CYAN}│${C_RESET} RAM thật bị chiếm: ${C_YELLOW}${z_compr} MB${C_RESET} (Lượng RAM tiêu tốn)"

  if [[ "$z_compr" -gt 0 ]]; then
    ty_le=$(awk "BEGIN {printf \"%.1f\", $z_data/$z_compr}")
    echo -e "${C_CYAN}│${C_RESET} Hiệu suất nén    : ${C_YELLOW}${ty_le}x (Giảm ${ty_le} lần dung lượng)${C_RESET}"
  else
    echo -e "${C_CYAN}│${C_RESET} Hiệu suất nén    : Chưa có dữ liệu để nén"
  fi
else
  echo -e "${C_CYAN}│${C_RESET} Trạng thái ZRAM  : ${C_RED}Không hoạt động / Chưa cấu hình${C_RESET}"
fi

echo -e "${C_CYAN}╰────────────────────────────────────────────────────────╯${C_RESET}"
echo ""

check_menu_wptangtoc_active=$1
if [[ $check_menu_wptangtoc_active == "98" ]]; then
  exec /etc/wptt/wptt-tai-nguyen-main 1
fi
