#!/bin/bash
function huong_dan() {
  Tính năng truy cập vào ứng dụng: top

  top trong Linux là một công cụ dòng lệnh cung cấp một cái nhìn động, cập nhật theo thời gian thực về các tiến trình [processes] đang chạy và tình hình sử dụng tài nguyên hệ thống của bạn.

  Nói một cách đơn giản, top giống như bảng điều khiển trung tâm hiển thị trực tiếp những gì đang diễn ra bên trong máy chủ hoặc máy tính Linux của bạn, đặc biệt là những tiến trình nào đang ngốn CPU và RAM nhiều nhất.

  Mục Đích Chính
  * Theo dõi hệ thống thời gian thực: Xem ngay lập tức các tiến trình đang hoạt động và tài nguyên đang được sử dụng như thế nào.
  * Xác định tiến trình nặng gánh: Nhanh chóng tìm ra các ứng dụng hoặc dịch vụ đang chiếm dụng quá nhiều CPU hoặc bộ nhớ, có thể là nguyên nhân gây chậm hệ thống.
  * Gỡ lỗi hiệu suất: Giúp chẩn đoán các vấn đề về hiệu suất, tình trạng treo hoặc phản hồi chậm của hệ thống.
  * Quản lý tiến trình cơ bản: Cho phép bạn thực hiện một số hành động như kill [dừng] một tiến trình hoặc renice [thay đổi độ ưu tiên] một cách tương tác.
  * Hiểu về tải hệ thống: Cung cấp thông tin về mức độ bận rộn của CPU và bộ nhớ.

  Hướng dẫn cách xem lệnh top: https://wptangtoc.com/kiem-tra-tai-nguyen-linux-top/
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null # Nạp thư viện UX Bo Cong

clear
echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}QUẢN LÝ TÀI NGUYÊN ➜ Trình Giám Sát Hệ Thống Thời Gian Thực (TOP)${C_RESET}"
echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

if [[ "${1:-}" == '98' ]]; then
  WPTT_IN_MENU="yes"
  WPTT_MENU_BACK="/etc/wptt/wptt-tai-nguyen-main 1"
fi

echo -e "${C_GREEN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_BOLD_WHITE}MẸO SỬ DỤNG NHANH TRONG MÀN HÌNH TOP${C_RESET}"
echo -e "${C_GREEN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
left_text "   ${C_YELLOW}Phím [ q ]${C_RESET} : Để THOÁT (Quit) và quay lại Menu WPTangToc." 2
left_text "   ${C_YELLOW}Phím [ 1 ]${C_RESET} : Xem chi tiết tải của từng luồng CPU (Cores)." 2
left_text "   ${C_YELLOW}Phím [ M ]${C_RESET} : Sắp xếp tiến trình ngốn RAM nhiều nhất lên đầu." 2
left_text "   ${C_YELLOW}Phím [ P ]${C_RESET} : Sắp xếp tiến trình ngốn CPU nhiều nhất lên đầu." 2
left_text "   ${C_YELLOW}Phím [ c ]${C_RESET} : Hiển thị đường dẫn lệnh chi tiết (Command path)." 2
echo -e "${C_GREEN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

#nếu người dùng ấn ctrl + c sẽ bay về menu con quản lý tài nguyên
trap '
  stty sane  # KHÔI PHỤC HIỂN THỊ CHỮ: Sửa lỗi gõ phím bị tàng hình
  tput cnorm # Hiện lại con trỏ chuột nhấp nháy
  clear
  exec /etc/wptt/wptt-tai-nguyen-main 1
' SIGINT SIGTERM SIGQUIT
#nếu người dùng ấn ctrl + c sẽ không bay ra shell
echo -e "Nhấn phím ${C_GREEN}[Enter]${C_RESET} để bắt đầu kiểm tra: TOP"

read -r # Dừng lại để người dùng xem kết quả

top

clear
echo -e "${C_GREEN}Đã thoát trình giám sát TOP.${C_RESET}\n"
# ==============================================================================
# GIẢI TRAP (RESET) NGAY SAU KHI THOÁT TOP BẰNG PHÍM 'q'
# ==============================================================================
trap - SIGINT SIGTERM SIGQUIT
if [[ "${1:-}" == "98" ]]; then
  exec /etc/wptt/wptt-tai-nguyen-main 1
fi
