#!/bin/bash
function huong_dan() {
  Tính năng Kiểm tra CPU là việc sử dụng các công cụ phần mềm hoặc tiện ích hệ thống để thu thập thông tin, theo dõi hoạt động và đánh giá sức khỏe của Bộ xử lý Trung tâm [CPU] trong máy tính hoặc máy chủ của bạn.

  Mục Đích Chính
  * Theo dõi hiệu suất: Xem CPU đang được sử dụng bao nhiêu %, tiến trình nào đang chiếm nhiều.
  * Chẩn đoán sự cố: Kiểm tra Load Average để biết hệ thống có đang quá tải hay nghẽn cổ chai không.
  * Kiểm tra phần cứng: Xác nhận model CPU, tốc độ, số nhân, số luồng.
  * Tập lệnh tối ưu: Đánh giá sức mạnh của CPU thông qua các công nghệ hỗ trợ như AES [Tăng tốc SSL/HTTPS] và AVX [Tăng tốc Database/PHP].
}

C_RED='\033[1;31m'
C_GREEN='\033[1;32m'
C_YELLOW='\033[1;33m'
C_CYAN='\033[1;36m'
C_RESET='\033[0m'

clear
echo -e "${C_YELLOW}Đang quét và phân tích Vi xử lý trung tâm (CPU)...${C_RESET}"
sleep 0.5
clear

# ==============================================================================
# 1. THU THẬP DỮ LIỆU PHẦN CỨNG & TẬP LỆNH
# ==============================================================================
vendor=$(lscpu 2>/dev/null | grep 'Vendor ID:' | awk -F: '{print $2}' | xargs)
[[ -z "$vendor" ]] && vendor=$(awk -F: '/vendor_id/ {print $2}' /proc/cpuinfo | head -1 | xargs)

cname=$(awk -F: '/model name/ {name=$2} END {print name}' /proc/cpuinfo | sed 's/^[ \t]*//;s/[ \t]*$//')
arch=$(uname -m)
cores=$(nproc 2>/dev/null || grep -c ^processor /proc/cpuinfo)
threads_per_core=$(lscpu 2>/dev/null | grep 'Thread(s) per core:' | awk '{print $4}')
[[ -z "$threads_per_core" ]] && threads_per_core="1"

freq=$(awk -F: '/cpu MHz/ {freq=$2} END {print freq}' /proc/cpuinfo | sed 's/^[ \t]*//;s/[ \t]*$//')
diem_bogo=$(lscpu 2>/dev/null | grep 'BogoMIPS:' | awk '{print $2}')

# Thu thập bộ nhớ đệm (Cache)
cache_l1=$(lscpu 2>/dev/null | grep 'L1d cache:' | awk -F: '{print $2}' | xargs)
cache_l2=$(lscpu 2>/dev/null | grep 'L2 cache:' | awk -F: '{print $2}' | xargs)
cache_l3=$(lscpu 2>/dev/null | grep 'L3 cache:' | awk -F: '{print $2}' | xargs)
[[ -z "$cache_l3" ]] && cache_l3=$(awk -F: '/cache size/ {print $2}' /proc/cpuinfo | head -1 | xargs)

# Quét tập lệnh mã hóa & tối ưu
grep -m1 -q aes /proc/cpuinfo && aes_status="${C_GREEN}Có (Tăng tốc HTTPS/SSL)${C_RESET}" || aes_status="${C_RED}Không (CPU Đời cũ)${C_RESET}"

if grep -m1 -q avx512 /proc/cpuinfo; then
  avx_status="${C_GREEN}Có (AVX-512 Siêu tốc)${C_RESET}"
elif grep -m1 -q avx2 /proc/cpuinfo; then
  avx_status="${C_GREEN}Có (AVX2 chuẩn hóa)${C_RESET}"
elif grep -m1 -q avx /proc/cpuinfo; then
  avx_status="${C_GREEN}Có (AVX cơ bản)${C_RESET}"
else
  avx_status="${C_RED}Không (Xử lý Data chậm)${C_RESET}"
fi

grep -m1 -E -q '(vmx|svm)' /proc/cpuinfo && virt_status="Có hỗ trợ" || virt_status="Không / Đang chạy ảo hóa"

# ==============================================================================
# 2. THU THẬP TRẠNG THÁI THỰC TẾ (REAL-TIME)
# ==============================================================================
load=$(uptime | awk -F'load average:' '{print $2}' | xargs)

# Tính toán mức sử dụng CPU chính xác tại thời điểm quét bằng top
cpu_idle=$(top -bn1 | grep "Cpu(s)" | sed "s/.*, *\([0-9.]*\)%* id.*/\1/")
cpu_usage=$(echo "scale=1; 100 - $cpu_idle" | bc 2>/dev/null)

# Định màu cảnh báo tải CPU
cpu_color=$C_GREEN
if [[ $(echo "$cpu_usage > 75" | bc 2>/dev/null) -eq 1 ]]; then cpu_color=$C_YELLOW; fi
if [[ $(echo "$cpu_usage > 90" | bc 2>/dev/null) -eq 1 ]]; then cpu_color=$C_RED; fi

echo -e "${C_CYAN}╭────────────────────────────────────────────────────────╮${C_RESET}"
echo -e "${C_CYAN}│${C_RESET}           ${C_YELLOW}KIỂM TRA SỨC KHỎE CPU - WPTANGTOC OLS${C_RESET}        ${C_CYAN}│${C_RESET}"
echo -e "${C_CYAN}├────────────────────────────────────────────────────────┤${C_RESET}"
echo -e "${C_CYAN}│${C_RESET} ${C_GREEN}THÔNG SỐ PHẦN CỨNG${C_RESET}"
echo -e "${C_CYAN}│${C_RESET} Hãng sản xuất    : $vendor ($arch)"
echo -e "${C_CYAN}│${C_RESET} Tên CPU (Model)  : $cname"
echo -e "${C_CYAN}│${C_RESET} Cấu trúc nhân    : $cores Cores ($threads_per_core Threads/Core)"
echo -e "${C_CYAN}│${C_RESET} Xung nhịp (Freq) : ${freq:-N/A} MHz"
echo -e "${C_CYAN}│${C_RESET} BogoMIPS Score   : ${diem_bogo:-N/A}"
echo -e "${C_CYAN}├────────────────────────────────────────────────────────┤${C_RESET}"
echo -e "${C_CYAN}│${C_RESET} ${C_GREEN}BỘ NHỚ ĐỆM & TẬP LỆNH NÂNG CAO${C_RESET}"
echo -e "${C_CYAN}│${C_RESET} L1/L2/L3 Cache   : ${cache_l1:-N/A} / ${cache_l2:-N/A} / ${cache_l3:-N/A}"
echo -e "${C_CYAN}│${C_RESET} Mã hóa AES (SSL) : $aes_status"
echo -e "${C_CYAN}│${C_RESET} Tính toán AVX    : $avx_status"
echo -e "${C_CYAN}│${C_RESET} Cờ Ảo hóa (VT-x) : $virt_status"
echo -e "${C_CYAN}├────────────────────────────────────────────────────────┤${C_RESET}"
echo -e "${C_CYAN}│${C_RESET} ${C_GREEN}TRẠNG THÁI HOẠT ĐỘNG THỰC TẾ${C_RESET}"
echo -e "${C_CYAN}│${C_RESET} Load Average     : $load"
echo -e "${C_CYAN}│${C_RESET} Mức tải hiện tại : ${cpu_color}${cpu_usage}%${C_RESET}"
echo -e "${C_CYAN}╰────────────────────────────────────────────────────────╯${C_RESET}"
echo ""

check_menu_wptangtoc_active=$1
if [[ $check_menu_wptangtoc_active == "98" ]]; then
  exec /etc/wptt/wptt-tai-nguyen-main 1
fi
