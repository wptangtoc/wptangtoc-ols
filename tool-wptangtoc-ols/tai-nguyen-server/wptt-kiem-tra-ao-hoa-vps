#!/bin/bash

function huong_dan() {
  Kiểm tra công nghệ ảo hóa VPS là quá trình xác định xem Máy chủ ảo riêng [VPS] của bạn đang được tạo ra và quản lý bằng công nghệ ảo hóa cụ thể nào [ví dụ: KVM, OpenVZ, Xen, VMware, Hyper-V].

  Mục Đích Chính:
  * Hiểu rõ khả năng của VPS:
  - Ảo hóa đầy đủ [KVM, Xen, VMware]: Tùy chỉnh kernel, độ cô lập cao.
  - Ảo hóa cấp độ OS [OpenVZ, LXC]: Chia sẻ kernel, nhẹ hơn nhưng ít cô lập.
  * Khắc phục sự cố: Chẩn đoán các vấn đề về tương thích hoặc hiệu suất.
  * Lựa chọn cấu hình: Hiểu về ảo hóa giúp tối ưu hóa hệ thống tốt hơn.
}

# Khai báo màu sắc chuẩn UI WPTangToc
C_RED='\033[1;31m'
C_GREEN='\033[1;32m'
C_YELLOW='\033[1;33m'
C_CYAN='\033[1;36m'
C_RESET='\033[0m'

clear
echo -e "${C_YELLOW}Đang phân tích nền tảng máy chủ...${C_RESET}"
sleep 0.5
clear

# ==============================================================================
# 1. THU THẬP THÔNG TIN ẢO HÓA (Đa lớp bảo vệ)
# ==============================================================================
virt=""

# Lớp 1: Dùng virt-what (Ép về 1 dòng nếu có nhiều kết quả)
if command -v virt-what &>/dev/null; then
  virt_raw=$(virt-what 2>/dev/null)
  if [[ -n "$virt_raw" ]]; then
    virt=$(echo "$virt_raw" | tr '\n' ' ' | sed 's/ $//')
  fi
fi

# Lớp 2: Dùng systemd-detect-virt làm Backup dự phòng nếu virt-what không có
if [[ -z "$virt" ]] && command -v systemd-detect-virt &>/dev/null; then
  virt=$(systemd-detect-virt 2>/dev/null)
  [[ "$virt" == "none" ]] && virt=""
fi

# ==============================================================================
# 2. PHÂN TÍCH & ĐÁNH GIÁ KẾT QUẢ
# ==============================================================================
if [[ -n "$virt" ]]; then
  # Viết hoa tên công nghệ ảo hóa
  virt_status="${C_YELLOW}${virt^^}${C_RESET} (Máy chủ Ảo - VPS)"

  # Đánh giá chất lượng ảo hóa để tư vấn cho người dùng
  if [[ "${virt,,}" =~ "kvm" || "${virt,,}" =~ "vmware" || "${virt,,}" =~ "xen" || "${virt,,}" =~ "qemu" ]]; then
    virt_desc="${C_GREEN}Ảo hóa toàn phần (Full Virtualization). Hiệu năng tốt, cô lập tài nguyên tuyệt đối.${C_RESET}"
  elif [[ "${virt,,}" =~ "openvz" || "${virt,,}" =~ "lxc" ]]; then
    virt_desc="${C_RED}Ảo hóa Container (Shared Kernel). Dễ bị Oversell, không thể can thiệp sâu vào Kernel.${C_RESET}"
  else
    virt_desc="Công nghệ ảo hóa tiêu chuẩn."
  fi
else
  # Nếu cả 2 tool đều không quét ra ảo hóa -> Khả năng cực cao là máy chủ vật lý
  virt_status="${C_GREEN}DEDICATED SERVER${C_RESET} (Máy chủ vật lý Bare-Metal)"
  virt_desc="${C_GREEN}Phần cứng độc lập, 100% sức mạnh thực tế, không bị chia sẻ tài nguyên.${C_RESET}"
fi

# ==============================================================================
# 3. RENDER GIAO DIỆN (UI DASHBOARD)
# ==============================================================================
echo -e "${C_CYAN}╭────────────────────────────────────────────────────────╮${C_RESET}"
echo -e "${C_CYAN}│${C_RESET}        ${C_YELLOW}KIỂM TRA CÔNG NGHỆ ẢO HÓA - WPTANGTOC OLS${C_RESET}       ${C_CYAN}│${C_RESET}"
echo -e "${C_CYAN}├────────────────────────────────────────────────────────┤${C_RESET}"
echo -e "${C_CYAN}│${C_RESET} ${C_GREEN}KẾT QUẢ PHÂN TÍCH${C_RESET}"
echo -e "${C_CYAN}│${C_RESET} Nền tảng hiện tại: $virt_status"
echo -e "${C_CYAN}│${C_RESET} Đánh giá         : $virt_desc"
echo -e "${C_CYAN}╰────────────────────────────────────────────────────────╯${C_RESET}"
echo ""
read -p "Bấm phím bất kỳ để quay lại menu..." enter

check_menu_wptangtoc_active=$1
if [[ $check_menu_wptangtoc_active == "98" ]]; then
  exec /etc/wptt/wptt-tai-nguyen-main 1
fi
