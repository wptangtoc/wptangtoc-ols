# @since: 2026

function huong_dan() {
  Tính năng này cung cấp khả năng tùy chỉnh và quản lý header HTTP [X-Powered-By] cho tất cả các tên miền trên máy chủ. Việc này rất quan trọng vì nó giúp bảo mật thông tin chi tiết về phần cứng, hệ điều hành và phần mềm đang chạy trên server của bạn. Bằng cách ẩn hoặc thay đổi giá trị [X-Powered-By], bạn có thể giảm thiểu nguy cơ bị tấn công từ các nguồn bên ngoài dựa trên thông tin này.
}

# Nạp file cấu hình nếu tồn tại, chuyển hướng lỗi sang /dev/null
. /etc/wptt/.wptt.conf 2>/dev/null

# Kiểm tra biến $ngon_ngu, gán mặc định là 'vi' nếu không có giá trị
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'

# Nạp file ngôn ngữ dựa trên biến $ngon_ngu
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null

# Nạp thư viện echo-color để màu hóa console output
. /etc/wptt/echo-color 2>/dev/null

# Nạp các hàm tiện ích cho UX
. /etc/wptt/core-functions 2>/dev/null # Nạp thư viện UX Bo Cong

clear
echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}Tùy biến Cấu hình Header (X-Powered-By)${C_RESET}"
echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

# Khởi tạo biến $MENU_FLAG và $CUSTOM_HEADER từ các tham số dòng lệnh
MENU_FLAG="${1:-}" # Flag $1 dùng để điều hướng menu hoặc gán giá trị '0' (Tắt)
CUSTOM_HEADER="${2:-}"

# Xử lý logic theo điều kiện gốc của WPTangToc
if [[ -n "$wptangtoc_ols_giatuan" || "$MENU_FLAG" == '0' ]]; then

  if [[ -n "$CUSTOM_HEADER" ]]; then
    # Kiểm tra quy tắc ký tự bằng Regex
    if ! [[ "$CUSTOM_HEADER" =~ ^[a-zA-Z0-9-]+$ ]]; then
      echo -e "${C_RED}❌ Lỗi: Hostname '$CUSTOM_HEADER' chứa ký tự không hợp lệ.${C_RESET}"
      echo -e "   Chỉ được phép sử dụng chữ cái (a-z, A-Z), số (0-9) và dấu gạch ngang (-).\n"
      [[ "$MENU_FLAG" == "98" ]] && exec /etc/wptt/wptt-add-one-main 1
      exit 0
    fi

    # Kiểm tra dấu gạch ngang ở đầu hoặc cuối
    if [[ "$CUSTOM_HEADER" == -* || "$CUSTOM_HEADER" == *- ]]; then
      echo -e "${C_RED}❌ Lỗi: Hostname không được bắt đầu hoặc kết thúc bằng dấu gạch ngang (-).${C_RESET}\n"
      [[ "$MENU_FLAG" == "98" ]] && exec /etc/wptt/wptt-add-one-main 1
      exit 0
    fi

    STATUS_TEXT="Thay đổi thành: ${C_YELLOW}$CUSTOM_HEADER${C_RESET}"
  else
    STATUS_TEXT="Đã ẩn (Xóa bỏ) X-Powered-By"
  fi

  echo ""
  _runing "Đang rà soát và cấu hình lại Header cho tất cả tên miền..."

  # ==============================================================================
  # BƯỚC 2: THỰC THI SỬA CẤU HÌNH VHOST
  # ==============================================================================
  DOMAIN_COUNT=0

  # Kiểm tra danh sách các file vhost, loại bỏ những dòng là '..conf'
  # Sử dụng sort -uV để đảm bảo không có file trùng lặp và sắp xếp theo phiên bản
  if [ "$(ls -A /etc/wptt/vhost 2>/dev/null | grep -v '^\.\.conf$' | sort -uV)" ]; then
    for entry in $(ls -A /etc/wptt/vhost 2>/dev/null | grep -v '^\.\.conf$' | sort -uV); do
      domain=$(echo "$entry" | sed 's/^\.//' | sed 's/\.conf$//')
      path="/usr/local/lsws/$domain/html"

      if [[ -d "$path" ]]; then
        conf_file="/usr/local/lsws/conf/vhosts/$domain/$domain.conf"
        if [[ -f "$conf_file" ]]; then
          # Xóa toàn bộ header X-Powered-By cũ
          sed -i '/X-Powered-By/d' "$conf_file"

          # Ghi Header mới (Nếu người dùng có khai báo CUSTOM_HEADER)
          if [[ -n "$CUSTOM_HEADER" ]]; then
            sed -i "/extraHeaders /a X-Powered-By $CUSTOM_HEADER" "$conf_file"
          fi
          ((DOMAIN_COUNT++))
        fi
      fi
    done
  fi

  _rundone "Ghi đè cấu hình thành công cho $DOMAIN_COUNT tên miền"

  _runing "Đang nạp lại cấu hình OpenLiteSpeed..."
  /usr/local/lsws/bin/lswsctrl restart >/dev/null 2>&1
  _rundone "OpenLiteSpeed khởi động thành công"

  echo -e "\n${C_GREEN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_BOLD_WHITE}HOÀN TẤT THIẾT LẬP HEADER X-POWERED-BY${C_RESET}"
  echo -e "${C_GREEN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
  left_text "  Số website xử lý : ${C_BOLD_WHITE}$DOMAIN_COUNT tên miền${C_RESET}" 2
  left_text "  Thiết lập        : $STATUS_TEXT" 2
  left_text "  Trạng thái       : ${C_GREEN}Đã áp dụng thành công trên toàn máy chủ.${C_RESET}" 2
  echo -e "${C_GREEN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

else
  # Fallback nếu không thỏa mãn biến điều kiện WPTangToc
  echo -e "${C_YELLOW}THÔNG BÁO: Không có lệnh thay đổi nào được thực thi.${C_RESET}\n"
fi

# ==============================================================================
# HOÀN TẤT VÀ THOÁT
# ==============================================================================
if [[ "$MENU_FLAG" == "98" ]]; then
  exec /etc/wptt/wptt-add-one-main 1
fi
