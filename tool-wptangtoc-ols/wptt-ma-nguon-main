#!/bin/bash

function huong_dan() {
  Tính năng quản lý mã nguồn
  * xoá mã nguồn
  * xem dung lượng mã nguồn
  * xem tổng quan mã nguồn
}

if [[ -z "$1" ]]; then
  . /etc/wptt/wptt-header-menu
  header_menu
else
  . /etc/wptt/echo-color 2>/dev/null
  echoDo "────────────────────────────────────────────────────────────────────────────────"
fi

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null

echo ""
echo "$quan_ly_ma_nguon:" > /dev/null # Để wptt-search tổng vẫn bắt được danh mục

# ==============================================================================
# 2. KHAI BÁO TIÊU ĐỀ MENU VÀ OPTIONS (ĐÃ SẮP XẾP LẠI UX)
# ==============================================================================
MENU_TITLE="TRUNG TÂM QUẢN LÝ MÃ NGUỒN (SOURCE CODE)"

options=(
  # --- CỘT TRÁI: THÔNG TIN & KIỂM TRA ---
  "$xem_tong_quan_ma_nguon"       #0 (Hiển thị: 1)
  "$kiem_tra_dung_luong_ma_nguon" #1 (Hiển thị: 2)

  # --- CỘT PHẢI: THAO TÁC DỮ LIỆU ---
  "$xoa_ma_nguon_website"         #2 (Hiển thị: 3)
)

# ==============================================================================
# 3. LOGIC XỬ LÝ (ÁNH XẠ CHUẨN VỚI INDEX MỚI)
# ==============================================================================
run_action() {
  local index=$1
  local script_path=""
  local script_args=""

  case $index in
  0) 
    script_path="/etc/wptt/ma-nguon/wptt-xem-ma-nguon"
    script_args="" 
    ;;
  1) 
    script_path="/etc/wptt/ma-nguon/wptt-kiem-tra-dung-luong"
    script_args="98"
    ;;
  2) 
    script_path="/etc/wptt/ma-nguon/wptt-xoa-ma-nguon"
    script_args="98"
    ;;
  esac

  if [[ -x "$script_path" || -f "$script_path" ]]; then
    if [[ -n "$script_args" ]]; then
      exec bash "$script_path" "$script_args"
    else
      exec bash "$script_path"
    fi
  else
    echo -e "\n\033[1;31m[!] Lỗi: Không tìm thấy tệp '$script_path'.\033[0m"
    sleep 2
    exec /etc/wptt/wptt-ma-nguon-main 1
  fi
}

# ==============================================================================
# 4. GIAO DIỆN TÙY CHỈNH (CĂN CHỈNH 2 CỘT LOGIC)
# ==============================================================================
draw_custom_grid() {
  print_full_row "" "THÔNG TIN & KIỂM TRA"
  print_full_row "1" "${options[0]}"
  print_full_row "2" "${options[1]}"
    print_spacer
  print_full_row "" "THAO TÁC QUẢN TRỊ"
  print_full_row "3" "${options[2]}"
}

# ==============================================================================
# 5. KÍCH HOẠT THƯ VIỆN UI ENGINE CHẠY
# ==============================================================================
. /etc/wptt/wptt-callback-menu-chon
