#!/bin/bash

function huong_dan() {
  Tính năng Chặn IP trong WPTangToc OLS là một công cụ bảo mật quan trọng, cho phép người quản trị máy chủ ngăn chặn truy cập từ các địa chỉ IP cụ thể đến website hoặc toàn bộ máy chủ. Đây là một biện pháp hiệu quả để đối phó với các hoạt động gây hại như tấn công DDoS, brute-force, spam, hoặc truy cập trái phép từ những nguồn đã biết.

  Mục đích chính của tính năng Chặn IP:
  * Tăng cường bảo mật: Ngăn chặn các địa chỉ IP độc hại tiếp cận máy chủ, giảm thiểu nguy cơ bị tấn công và xâm nhập.
  * Giảm tải cho máy chủ: Chặn các bot spam hoặc các IP liên tục gửi yêu cầu không mong muốn giúp tiết kiệm tài nguyên máy chủ [băng thông, CPU].
  * Bảo vệ website khỏi các hoạt động phá hoại: Ngăn chặn các IP đã được xác định là có hành vi xấu, ví dụ như cố gắng khai thác lỗ hổng hoặc gửi bình luận spam.

  Lợi ích:
  * Phản ứng nhanh với các mối đe dọa: Dễ dàng chặn ngay các IP đang gây rối.
  * Dễ sử dụng: Người dùng không cần phải thao tác trực tiếp với các tệp cấu hình phức tạp của webserver hay firewall.
  * Nâng cao khả năng phòng thủ: Là một lớp bảo vệ chủ động cho máy chủ và website.

  Tóm lại, tính năng Chặn IP trong WPTangToc OLS giúp người quản trị dễ dàng kiểm soát và ngăn chặn các truy cập không mong muốn hoặc độc hại đến máy chủ OpenLiteSpeed, góp phần bảo vệ an ninh và sự ổn định của hệ thống.
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null # Nạp thư viện UX Bo Cong

clear
echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}QUẢN LÝ IP ➜ Khóa Địa Chỉ IP (Block IP)${C_RESET}"
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

if [[ "${1:-}" == '98' ]]; then
  WPTT_IN_MENU="yes"
  WPTT_MENU_BACK="/etc/wptt/wptt-khoa-ip-main 1"
fi

while true; do
  echo -en "${C_CYAN}Nhập địa chỉ IPv4 hoặc IPv6 muốn Khóa [0=Thoát]: ${C_RESET}"
  read -r ip

  [[ "$ip" == "0" || -z "$ip" ]] && {
    echo -e "${C_YELLOW}Đã hủy thao tác.${C_RESET}\n"
    [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-khoa-ip-main 1
    exit 0
  }

  # Tự động loại bỏ toàn bộ khoảng trắng (space/tab) nếu người dùng lỡ tay nhập thừa
  ip="${ip//[[:space:]]/}"

  error_block_ipv4='1'
  error_block_ipv6='1'

  # A. Kiểm tra chuẩn IPv4 (Bao gồm thuật toán chống lách luật của WPTangToc)
  if [[ -n $(echo "$ip" | grep -E -o '(25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\.(25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\.(25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\.(25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)') ]]; then
    error_block_ipv4='0'
    IFS='.' read -r -a octets <<<"$ip"
    for octet in "${octets[@]}"; do
      # 10#$octet giúp Bash hiểu đây là hệ thập phân (tránh lỗi nếu user nhập 08, 09)
      if ((10#$octet > 255)); then
        error_block_ipv4='1'
        break
      fi
    done
  fi

  # B. Kiểm tra chuẩn IPv6
  if [[ -n $(echo "$ip" | grep -oE '\b([0-9a-fA-F]{1,4}:){7}[0-9a-fA-F]{1,4}\b|\b([0-9a-fA-F]{1,4}:){1,7}:\b|\b([0-9a-fA-F]{1,4}:){1,6}:[0-9a-fA-F]{1,4}\b|\b([0-9a-fA-F]{1,4}:){1,5}(:[0-9a-fA-F]{1,4}){1,2}\b|\b([0-9a-fA-F]{1,4}:){1,4}(:[0-9a-fA-F]{1,4}){1,3}\b|\b([0-9a-fA-F]{1,4}:){1,3}(:[0-9a-fA-F]{1,4}){1,4}\b|\b([0-9a-fA-F]{1,4}:){1,2}(:[0-9a-fA-F]{1,4}){1,5}\b|\b[0-9a-fA-F]{1,4}:((:[0-9a-fA-F]{1,4}){1,6})\b|\b:((:[0-9a-fA-F]{1,4}){1,7}|:)\b|\bfe80:(:[0-9a-fA-F]{0,4}){0,4}%[0-9a-zA-Z]{1,}\b|\b::(ffff(:0{1,4}){0,1}:){0,1}((25[0-5]|(2[0-4]|1{0,1}[0-9]){0,1}[0-9])\.){3,3}(25[0-5]|(2[0-4]|1{0,1}[0-9]){0,1}[0-9])\b|\b([0-9a-fA-F]{1,4}:){1,4}:((25[0-5]|(2[0-4]|1{0,1}[0-9]){0,1}[0-9])\.){3,3}(25[0-5]|(2[0-4]|1{0,1}[0-9]){0,1}[0-9])\b') ]]; then
    error_block_ipv6='0'
  fi

  # C. Chốt kết quả
  if [[ "$error_block_ipv4" == '1' && "$error_block_ipv6" == '1' ]]; then
    echo -e "${C_RED}❌ Lỗi: Địa chỉ IP không hợp lệ! Vui lòng kiểm tra lại định dạng.\e[0m"
  else
    break # Định dạng chuẩn, thoát vòng lặp
  fi
done

echo ""
_runing "Đang tiến hành cấm cửa IP: $ip"
FIREWALL_USED="Chưa xác định"

# ==============================================================================
# THỰC THI KHÓA IP TRÊN TƯỜNG LỬA (Tầng L3/L4 - Sức mạnh thực sự)
# ==============================================================================
if command -v csf >/dev/null 2>&1 && [[ -f /etc/csf/csf.conf ]]; then
  FIREWALL_USED="CSF Firewall"

  if grep -q -E "^$ip\b" /etc/csf/csf.deny 2>/dev/null; then
    _rundone "Bỏ qua (Địa chỉ IP đã bị khóa từ trước)"
    echo -e "\n${C_YELLOW}THÔNG BÁO: Địa chỉ IP $ip đã nằm sẵn trong danh sách chặn của CSF!\e[0m\n"
    [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-khoa-ip-main 1
    exit 0
  fi

  csf -d "$ip" "Khoa tu WPTangToc OLS" >/dev/null 2>&1

elif systemctl is-active --quiet nftables; then
  FIREWALL_USED="Nftables"
  . /etc/wptt/bao-mat/nftables/block-ip-nftables.sh "$ip" >/dev/null 2>&1

elif systemctl is-active --quiet firewalld; then
  FIREWALL_USED="Firewalld (Zone Drop)"

  # Tiền kiểm tra: IP đã nằm trên "Móc tử hình" (Zone Drop) chưa?
  if firewall-cmd --zone=drop --query-source="$ip" >/dev/null 2>&1; then
    _rundone "Bỏ qua (Địa chỉ IP đã bị khóa từ trước)"
    echo -e "\n${C_YELLOW}THÔNG BÁO: Địa chỉ IP $ip đã nằm sẵn trong danh sách chặn của Firewalld!\e[0m\n"
    [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-khoa-ip-main 1
    exit 0
  fi

  # Ném IP thẳng vào vùng Drop. (Firewalld sẽ tự động tối ưu ngầm tốc độ O(1))
  firewall-cmd --zone=drop --add-source="$ip" >/dev/null 2>&1
  firewall-cmd --permanent --zone=drop --add-source="$ip" >/dev/null 2>&1
fi

# ==============================================================================
# GHI LOG VÀ BÁO CÁO HOÀN TẤT
# ==============================================================================
echo "Khoá ip $ip: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log
_rundone "Khóa IP thành công"

echo -e "${C_GREEN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_BOLD_WHITE}HOÀN TẤT CHẶN ĐỊA CHỈ IP${C_RESET}"
echo -e "${C_GREEN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
left_text "Địa chỉ bị cấm  : ${C_RED}$ip${C_RESET}" 2
left_text "Tường lửa xử lý : ${C_YELLOW}$FIREWALL_USED${C_RESET}" 2
left_text "Trạng thái      : ${C_BOLD_WHITE}Đã cắt đứt toàn bộ kết nối đến máy chủ.${C_RESET}" 2
echo -e "${C_GREEN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

[[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-khoa-ip-main 1
