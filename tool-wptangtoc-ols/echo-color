#!/bin/bash

# ==============================================================================
# 1. NẠP CẤU HÌNH & NGÔN NGỮ
# ==============================================================================
if [[ -f /etc/wptt/.wptt.conf ]]; then
  . /etc/wptt/.wptt.conf
fi

if [[ -z "$ngon_ngu" ]]; then # Tối ưu: Dùng -z kiểm tra biến rỗng an toàn hơn
  ngon_ngu='vi'
fi
. /etc/wptt/lang/$ngon_ngu.sh

# Tối ưu: Giữ lại $PATH gốc của hệ thống bằng cách nối thêm ($PATH ở cuối)
PATH='/root/.local/bin:/root/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:'$PATH

# ==============================================================================
# 2. KHAI BÁO BẢNG MÀU CHUẨN (CHO ECHO)
# ==============================================================================
function echoVang { echo -e "\033[38;5;148m${1}\033[39m"; }
function echoDo { echo -e "\033[38;5;9m${1}\033[39m"; }
function echoBlue { echo -e "\033[38;5;21m${1}\033[39m"; }
function echoXanhlacay { echo -e "\033[38;5;28m${1}\033[39m"; }
function echoDone { echo -e "\033[38;5;41m${1}\033[39m"; }
function echoCam { echo -e "\033[38;5;203m${1}\033[39m"; }
function echoXam { echo -e "\033[1;3;94m${1}\033[0m"; }

# ==============================================================================
# 3. HIỆU ỨNG TRẠNG THÁI TIẾN TRÌNH (CĂN LỀ THẲNG TẮP)
# ==============================================================================
# Sử dụng %-50s để ép độ dài cột text cố định là 50 ký tự, giúp các dấu [ ] thẳng cột
function _runing {
  printf "%-50s [\033[38;5;148m%s...\033[39m]\r" "$1" "$dang_tien_hanh"
}

function _rundone {
  printf "%-50s [\033[38;5;28m%s\033[39m]\e[K\n" "$1" "$hoan_tat"
  sleep 0.4
}

function _runloi {
  printf "%-50s [\033[38;5;9m%s\033[39m]\e[K\n" "$1" "$dang_xay_ra_su_co"
}

# ==============================================================================
# 4. KHAI BÁO BIẾN MÀU UI & KÍCH THƯỚC KHUNG (Dùng cho Giao diện bo cong)
# ==============================================================================
C_RED='\033[1;31m'
C_GREEN='\033[1;32m'
C_YELLOW='\033[1;33m'
C_CYAN='\033[1;36m'
C_BOLD_WHITE='\033[1;37m'
C_RESET='\033[0m'
box_inner_width=71

# ==============================================================================
# 5. HÀM RENDER KHUNG (TỰ ĐỘNG CĂN GIỮA)
# ==============================================================================
center_text() {
  local text="$1"
  # Tẩy sạch ký tự mã màu ANSI để đếm chiều dài cho chuẩn
  local clean_text=$(echo -e "$text" | sed "s/\x1B\[[0-9;]*[a-zA-Z]//g")
  local text_len=${#clean_text}

  if ((text_len >= box_inner_width)); then
    printf "${C_CYAN}│${C_RESET} %b ${C_CYAN}│${C_RESET}\n" "$text"
    return
  fi

  local pad_left=$(((box_inner_width - text_len) / 2))
  local pad_right=$((box_inner_width - text_len - pad_left))
  printf "${C_CYAN}│${C_RESET}%*s%b%*s${C_CYAN}│${C_RESET}\n" "$pad_left" "" "$text" "$pad_right" ""
}

# ==============================================================================
# 6. HÀM RENDER KHUNG (TỰ ĐỘNG CĂN LỀ TRÁI)
# ==============================================================================
#left_text "${C_YELLOW}Đây là dòng chữ căn trái${C_RESET}"
#left_text "${C_WHITE}Dòng này lùi vào sâu hơn${C_RESET}" 5
left_text() {
  local text="$1"
  local indent=${2:-2} # Thụt lề trái mặc định là 2 dấu cách (có thể truyền tham số thứ 2 để đổi)

  # Tẩy sạch ký tự mã màu ANSI để đếm chiều dài
  local clean_text=$(echo -e "$text" | sed "s/\x1B\[[0-9;]*[a-zA-Z]//g")

  # Đếm độ dài chuẩn xác 100% cho tiếng Việt (tránh lỗi lệch viền phải)
  local text_len=$(echo -n "$clean_text" | awk '{print length($0)}')

  # Nếu chữ quá dài so với khung (chống lỗi tính toán âm)
  if ((text_len + indent >= box_inner_width)); then
    printf "${C_CYAN}│${C_RESET}%*s%b ${C_CYAN}│${C_RESET}\n" "$indent" "" "$text"
    return
  fi

  # Tính toán dồn toàn bộ khoảng trắng bù trừ sang lề phải
  local pad_right=$((box_inner_width - text_len - indent))

  # In ra màn hình: Viền trái -> Thụt lề -> Text -> Khoảng trắng bù -> Viền phải
  printf "${C_CYAN}│${C_RESET}%*s%b%*s${C_CYAN}│${C_RESET}\n" "$indent" "" "$text" "$pad_right" ""
}
