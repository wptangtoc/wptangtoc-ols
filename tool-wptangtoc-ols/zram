#!/bin/bash
# @author: Gia Tuấn
# @website: https://wptangtoc.com
# @since: 2025

function huong_dan() {
  1. Tính Năng Cài Đặt ZRAM [Install ZRAM Swap]
  Cài đặt ZRAM là quá trình thiết lập một phân vùng Swap [bộ nhớ ảo] hoạt động hoàn toàn trên RAM vật lý, sử dụng thuật toán nén dữ liệu thời gian thực.

  ZRAM là một công cụ chuẩn Enterprise giúp máy chủ:
  * Tránh sập nguồn [OOM] khi bị quá tải RAM cục bộ.
  * Tăng tốc độ đọc/ghi Swap lên gấp hàng nghìn lần so với Swap trên ổ cứng SSD/NVMe.
  * Bảo vệ tuổi thọ ổ cứng vật lý do không còn phải ghi/xóa các file rác liên tục.
  * Tự động điều chỉnh thông minh: Sử dụng 50% lượng RAM hiện có đối với máy chủ nhỏ, hoặc khóa trần ở mức tối đa 4GB đối với máy chủ lớn để bảo vệ CPU.
  * Tự động dọn dẹp và xóa hoàn toàn Swap đĩa cũ để giải phóng dung lượng SSD.

  Kết quả: Sau khi cài đặt, hệ thống sẽ có một ổ đĩa nén ZRAM [zram0] siêu tốc. Máy chủ sẽ lỳ lợm hơn khi chịu tải nặng.

  2. Tính Năng Hủy Cài Đặt ZRAM [Uninstall ZRAM Swap]
  Hủy cài đặt ZRAM là quá trình gỡ bỏ module nén bộ nhớ và trả lại không gian RAM vật lý cũng như trả lại cơ chế Swap đĩa truyền thống của Linux.

  Mục đích chính:
  * CPU của VPS quá yếu, không thể gánh được thuật toán nén.
  * Máy chủ chuyên dụng cho Database [không dùng chung Web Server].

  Kết quả: Dịch vụ ZRAM sẽ được dừng, xóa cấu hình và hệ thống sẽ tự động khởi tạo lại một Swap đĩa dung lượng 1GB [/var/swap.1] để đảm bảo an toàn cơ bản.
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null # Nạp thư viện UX Bo Cong

clear
echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}QUẢN LÝ TỐI ƯU RAM ➜ Bật/Tắt ZRAM (Swap nén siêu tốc)${C_RESET}"
echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

if [[ "${1:-}" == '98' ]]; then
  WPTT_IN_MENU="yes"
  WPTT_MENU_BACK="/etc/wptt/wptt-swap-main 1"
fi

# ==============================================================================
# NHẬN DIỆN HỆ ĐIỀU HÀNH & KIỂM TRA TRẠNG THÁI HIỆN TẠI
# ==============================================================================
if grep -qiE "ubuntu|debian" /etc/os-release 2>/dev/null; then
  OS_TYPE="UBUNTU"
  duong_dan_config_zram="/etc/default/zramswap"
else
  OS_TYPE="RHEL"
  duong_dan_config_zram="/etc/systemd/zram-generator.conf"
fi

if [[ -f "$duong_dan_config_zram" ]]; then
  ZRAM_STATUS="ON"
else
  ZRAM_STATUS="OFF"
fi

echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
if [[ "$ZRAM_STATUS" == "ON" ]]; then
  left_text "Trạng thái    : ${C_GREEN}ĐÃ KÍCH HOẠT${C_RESET}" 2
  echo -e "${C_CYAN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
  left_text "Máy chủ đang sử dụng ZRAM để nén dữ liệu Swap trên RAM thật." 2
  left_text "Giúp chống tràn bộ nhớ (OOM) và kéo dài tuổi thọ ổ cứng." 2
else
  left_text "Trạng thái    : ${C_RED}CHƯA KÍCH HOẠT${C_RESET}" 2
  echo -e "${C_CYAN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
  left_text "Hệ thống đang sử dụng Swap ghi/xóa liên tục lên ổ đĩa." 2
  left_text "Khuyến nghị BẬT ZRAM để tăng tốc hệ thống và bảo vệ SSD/NVMe." 2
fi
echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

# ==============================================================================
# XỬ LÝ ĐỐI SỐ DÒNG LỆNH (CLI)
# ==============================================================================
tham_so="${1:-}"
bo_qua_xac_nhan="n"

if [[ "$tham_so" == "on" ]]; then
  if [[ "$ZRAM_STATUS" == "ON" ]]; then
    echo -e "${C_YELLOW}ZRAM đã được kích hoạt từ trước!${C_RESET}"
    [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-swap-main 1
    exit 0
  fi
  bo_qua_xac_nhan="y"
elif [[ "$tham_so" == "off" ]]; then
  if [[ "$ZRAM_STATUS" == "OFF" ]]; then
    echo -e "${C_YELLOW}ZRAM chưa được cài đặt, không thể tắt!${C_RESET}"
    [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-swap-main 1
    exit 0
  fi
  bo_qua_xac_nhan="y"
fi

# ==============================================================================
# PHẦN 1: TIẾN HÀNH CÀI ĐẶT (ĐANG OFF -> YÊU CẦU ON)
# ==============================================================================
if [[ "$ZRAM_STATUS" == "OFF" ]]; then

  if [[ "$bo_qua_xac_nhan" != "y" ]]; then
    if ! wptt_xac_nhan "Bạn có muốn CÀI ĐẶT và BẬT ZRAM không?" "Hệ thống sẽ tự động gỡ bỏ Swap đĩa cũ và tạo vùng nén siêu tốc." "" "Đồng ý Bật ZRAM" "Hủy thao tác"; then
      echo -e "${C_YELLOW}Đã hủy thao tác.${C_RESET}\n"
      [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-swap-main 1
      exit 0
    fi
  fi

  echo "Kích hoạt ZRAM: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log

  # Tính toán dung lượng RAM
  tong_ram_byte=$(awk '/MemTotal/ {print $2}' /proc/meminfo)
  rong_ram_mb=$((tong_ram_byte / 1024))

  if (($rong_ram_mb <= 8192)); then
    ZRAM_SIZE_MB=$((rong_ram_mb / 2))
  else
    ZRAM_SIZE_MB=4096
  fi

  echo ""
  _runing "Đang cài đặt thư viện ZRAM cho $OS_TYPE..."

  # Cài đặt theo OS
  if [[ "$OS_TYPE" == "UBUNTU" ]]; then
    DEBIAN_FRONTEND=noninteractive apt-get update >/dev/null 2>&1
    DEBIAN_FRONTEND=noninteractive apt-get purge zram-generator -y >/dev/null 2>&1
    DEBIAN_FRONTEND=noninteractive apt-get install zram-tools -y >/dev/null 2>&1
    BEST_ALGO="zstd"
    cat <<EOF >"$duong_dan_config_zram"
ALGO=$BEST_ALGO
SIZE=$ZRAM_SIZE_MB
PRIORITY=100
EOF
  else
    yum install zram-generator -y >/dev/null 2>&1
    modprobe zram 2>/dev/null

    tao_dummy="0"
    if [[ ! -d /sys/block/zram0 ]]; then
      zramctl --find --size 10M >/dev/null 2>&1
      tao_dummy="1"
    fi

    if [[ -f /sys/block/zram0/comp_algorithm ]]; then
      SUPPORTED_ALGOS=$(cat /sys/block/zram0/comp_algorithm 2>/dev/null | tr -d '[]')
      if [[ " $SUPPORTED_ALGOS " == *" zstd "* ]]; then
        BEST_ALGO="zstd"
      elif [[ " $SUPPORTED_ALGOS " == *" lz4 "* ]]; then
        BEST_ALGO="lz4"
      else BEST_ALGO="lzo"; fi
    else
      BEST_ALGO="lzo"
    fi

    if [[ "$tao_dummy" == "1" ]]; then
      swapoff /dev/zram0 >/dev/null 2>&1
      zramctl --reset /dev/zram0 >/dev/null 2>&1
      if [[ -f /sys/class/zram-control/hot_remove ]]; then
        echo 0 >/sys/class/zram-control/hot_remove 2>/dev/null
      else
        rmmod zram >/dev/null 2>&1
      fi
    fi

    echo "[zram0]
zram-fraction = 1.0
max-zram-size = $ZRAM_SIZE_MB
zram-size = $ZRAM_SIZE_MB
compression-algorithm = $BEST_ALGO
swap-priority = 100
fs-type = swap" >"$duong_dan_config_zram"
  fi
  _rundone "Cài đặt thư viện thành công"

  # Cấu hình Kernel và dọn dẹp Swap đĩa
  _runing "Đang cấu hình Kernel và dọn dẹp Swap đĩa cũ..."
  echo "# wptangtoc-ols zram optimize
vm.page-cluster = 0
vm.swappiness = 100" >/etc/sysctl.d/99-wptt-zram.conf

  if [[ -f /usr/lib/tuned/virtual-guest/tuned.conf ]]; then
    sed -i '/vm.swappiness/d' /usr/lib/tuned/virtual-guest/tuned.conf
    echo 'vm.swappiness = 100' >>/usr/lib/tuned/virtual-guest/tuned.conf
  fi

  if [[ -f /etc/sysctl.d/101-sysctl.conf ]]; then
    sed -i '/vm.swappiness/d' /etc/sysctl.d/101-sysctl.conf
    echo 'vm.swappiness = 100' >>/etc/sysctl.d/101-sysctl.conf
  fi

  sysctl -p /etc/sysctl.d/101-sysctl.conf >/dev/null 2>&1
  sysctl -p /etc/sysctl.d/99-wptt-zram.conf >/dev/null 2>&1

  swapoff -a >/dev/null 2>&1
  rm -rf /var/swap.1 /swapfile /swap.img 2>/dev/null
  sed -i -e '/swap.1/d' -e '/swapfile/d' -e '/swap.img/d' /etc/fstab
  sed -i '/ swap / s/^\(.*\)$/#\1/g' /etc/fstab
  _rundone "Tối ưu hóa môi trường RAM hoàn tất"

  _runing "Đang khởi động dịch vụ ZRAM ($BEST_ALGO - ${ZRAM_SIZE_MB}MB)..."
  systemctl daemon-reload >/dev/null 2>&1
  if [[ "$OS_TYPE" == "UBUNTU" ]]; then
    systemctl restart zramswap >/dev/null 2>&1
    systemctl enable zramswap >/dev/null 2>&1
  else
    systemctl start dev-zram0.swap >/dev/null 2>&1
  fi
  _rundone "ZRAM đã hoạt động"

  echo -e "\n${C_GREEN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_BOLD_WHITE}HOÀN TẤT KÍCH HOẠT ZRAM${C_RESET}"
  echo -e "${C_GREEN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
  left_text "Dung lượng ZRAM : ${C_YELLOW}${ZRAM_SIZE_MB} MB${C_RESET}" 2
  left_text "Thuật toán nén  : ${C_YELLOW}${BEST_ALGO}${C_RESET}" 2
  left_text "Trạng thái      : ${C_BOLD_WHITE}Máy chủ đã trang bị bộ đệm siêu tốc.${C_RESET}" 2
  echo -e "${C_GREEN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

# ==============================================================================
# PHẦN 2: HỦY CÀI ĐẶT (ĐANG ON -> YÊU CẦU OFF)
# ==============================================================================
else

  if [[ "$bo_qua_xac_nhan" != "y" ]]; then
    if ! wptt_xac_nhan "Bạn có chắc chắn muốn TẮT và GỠ BỎ ZRAM không?" "Hệ thống sẽ tái tạo lại file Swap đĩa truyền thống (1024MB)." "" "Đồng ý Gỡ Bỏ" "Hủy thao tác"; then
      echo -e "${C_YELLOW}Đã hủy thao tác.${C_RESET}\n"
      [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-swap-main 1
      exit 0
    fi
  fi

  echo "Huỷ kích hoạt ZRAM: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log

  echo ""
  _runing "Đang dừng dịch vụ và xóa thư viện ZRAM..."
  if [[ "$OS_TYPE" == "UBUNTU" ]]; then
    systemctl stop zramswap >/dev/null 2>&1
    systemctl disable zramswap >/dev/null 2>&1
    DEBIAN_FRONTEND=noninteractive apt-get remove --purge zram-tools -y >/dev/null 2>&1
    DEBIAN_FRONTEND=noninteractive apt-get autoremove -y >/dev/null 2>&1
  else
    systemctl stop dev-zram0.swap >/dev/null 2>&1
    zramctl --reset /dev/zram0 >/dev/null 2>&1
    yum remove zram-generator -y >/dev/null 2>&1
  fi

  rm -f "$duong_dan_config_zram"
  rm -f /etc/sysctl.d/99-wptt-zram.conf

  if [[ -f /usr/lib/tuned/virtual-guest/tuned.conf ]]; then
    sed -i '/vm.swappiness/d' /usr/lib/tuned/virtual-guest/tuned.conf
    echo 'vm.swappiness = 10' >>/usr/lib/tuned/virtual-guest/tuned.conf
  fi

  if [[ -f /etc/sysctl.d/101-sysctl.conf ]]; then
    sed -i '/vm.swappiness/d' /etc/sysctl.d/101-sysctl.conf
    echo 'vm.swappiness = 10' >>/etc/sysctl.d/101-sysctl.conf
  fi

  sysctl -p /etc/sysctl.d/101-sysctl.conf >/dev/null 2>&1
  _rundone "Dọn dẹp cấu hình ZRAM thành công"

  _runing "Đang khởi tạo lại Swap đĩa dự phòng (1024MB)..."
  swapoff -a -v >/dev/null 2>&1
  rm -rf /var/swap.1 /swapfile /swap.img
  /bin/dd if=/dev/zero of=/var/swap.1 bs=1M count=1024 >/dev/null 2>&1
  chmod 600 /var/swap.1
  /sbin/mkswap /var/swap.1 >/dev/null 2>&1
  /sbin/swapon /var/swap.1 >/dev/null 2>&1

  sed -i -e '/swap.1/d' -e '/swapfile/d' -e '/swap.img/d' /etc/fstab
  sed -i '/ swap / s/^\(.*\)$/#\1/g' /etc/fstab
  echo '/var/swap.1 none swap defaults 0 0' >>/etc/fstab
  systemctl daemon-reload >/dev/null 2>&1
  _rundone "Tái tạo Swap truyền thống hoàn tất"

  echo -e "\n${C_GREEN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_BOLD_WHITE}HOÀN TẤT GỠ BỎ ZRAM${C_RESET}"
  echo -e "${C_GREEN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
  left_text "Swap hiện tại : ${C_YELLOW}Swap Đĩa Truyền Thống (1024MB)${C_RESET}" 2
  left_text "Trạng thái    : ${C_BOLD_WHITE}Đã khôi phục an toàn.${C_RESET}" 2
  echo -e "${C_GREEN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

fi

[[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-swap-main 1
