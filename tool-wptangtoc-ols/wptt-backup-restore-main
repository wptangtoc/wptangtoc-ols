# ==============================================================================
# 3. LOGIC XỬ LÝ (ÁNH XẠ CHUẨN 100% VỚI INDEX MỚI)
# ==============================================================================
run_action() {
  local index=$1
  local script_path=""
  local script_args="98"

  case $index in
  # Nhóm Local
  0) script_path="/etc/wptt/backup-restore/wptt-saoluu" ;;
  1) script_path="/etc/wptt/backup-restore/wptt-khoiphuc" ;;
  2) script_path="/etc/wptt/db/wptt-saoluu-database"; script_args="97" ;; # Đặc biệt: 97
  3) script_path="/etc/wptt/db/wptt-nhapdatabase"; script_args="97" ;; # Đặc biệt: 97
  4) script_path="/etc/wptt/backup-restore/wptt-auto-backup" ;;
  5) script_path="/etc/wptt/backup-restore/wptt-tat-auto-backup" ;;
  6) script_path="/etc/wptt/backup-restore/wptt-auto-backup-database" ;;
  7) script_path="/etc/wptt/backup-restore/wptt-tat-auto-backup-database" ;;
  8) script_path="/etc/wptt/backup-restore/wptt-auto-delete-backup" ;;
  9) script_path="/etc/wptt/backup-restore/wptt-tat-delete-backup" ;;
  10) script_path="/etc/wptt/backup-restore/wptt-xoa-file-backup" ;;

  # Nhóm Nâng cao & Đám mây
  11) script_path="/etc/wptt/backup-restore/wptt-saoluu-luy-tien-tung-phan" ;;
  12) script_path="/etc/wptt/backup-restore/wptt-khoiphuc-luy-tien-tung-phan" ;;
  13) script_path="/etc/wptt/backup-restore/wptt-sql-gzip-config" ;;
  14) script_path="/etc/wptt/backup-restore/dinh-dang-backup-ma-nguon-option" ;;
  15) script_path="/etc/wptt/backup-restore/wptt-rclone" ;;
  16) script_path="/etc/wptt/backup-restore/wptt-rclone-one-driver" ;;
  17) script_path="/etc/wptt/backup-restore/wptt-download-rclone" ;;
  18) script_path="/etc/wptt/backup-restore/wptt-huy-rclone" ;;
  19) script_path="/etc/wptt/backup-restore/wptt-thiet-lap-auto-delete-google-driver-backup" ;;
  20) script_path="/etc/wptt/backup-restore/wptt-tat-auto-delete-backup-google-driver" ;;
  21) script_path="/etc/wptt/backup-restore/wptt-xoa-file-backup-google-driver" ;;
  esac

  if [[ -x "$script_path" || -f "$script_path" ]]; then
    exec bash "$script_path" "$script_args"
  else
    echo -e "\n\033[1;31m[!] Lỗi: Không tìm thấy script '$script_path'.\033[0m"
    sleep 2
    exec /etc/wptt/wptt-backup-restore-main 1
  fi
}

