#!/bin/bash
# @author: Gia Tuấn
# @website: https://wptangtoc.com
# @since: 2024

function huong_dan() {
  mặc dù WebAdmin GUI của OpenLiteSpeed rất hữu ích, có những trường hợp bạn muốn hủy kích hoạt [vô hiệu hóa] nó, chủ yếu vì lý do bảo mật sau khi đã hoàn tất cấu hình ban đầu hoặc nếu bạn chỉ muốn quản lý máy chủ qua dòng lệnh.

  Dưới đây là giới thiệu ngắn gọn về tính năng hủy kích hoạt WebAdmin GUI của OpenLiteSpeed:

  Mục đích của việc hủy kích hoạt WebAdmin GUI:
  * Tăng cường bảo mật: Giảm bề mặt tấn công [attack surface] của máy chủ. Việc không có một giao diện quản trị web chạy công khai sẽ loại bỏ một vectơ tấn công tiềm năng.
  * Tuân thủ chính sách: Một số chính sách bảo mật yêu cầu hạn chế tối đa các giao diện quản trị qua web.
  * Quản lý tập trung: Nếu bạn quản lý nhiều máy chủ và sử dụng các công cụ quản lý cấu hình tự động [như Ansible, Puppet, Chef], việc phụ thuộc vào WebAdmin GUI có thể không cần thiết.

  Việc hủy kích hoạt WebAdmin GUI là một biện pháp bảo mật tốt sau khi bạn đã hoàn tất việc thiết lập ban đầu cho máy chủ OpenLiteSpeed của mình và ưa thích quản lý qua dòng lệnh hoặc các công cụ tự động hóa.
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null # Nạp thư viện UX Bo Cong

clear
echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}Quản lý WebGuiAdmin ➜ Hủy kích hoạt Giao diện Quản trị Web (Đóng GUI)${C_RESET}"
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

if [[ "${1:-}" == '98' ]]; then
  WPTT_IN_MENU="yes"
  WPTT_MENU_BACK="/etc/wptt/wptt-webadmin-main 1"
fi

# ==============================================================================
# KIỂM TRA TRẠNG THÁI HIỆN TẠI
# ==============================================================================
path="/usr/local/lsws/conf/disablewebconsole"
if [[ -f $path ]]; then
  echo -e "${C_GREEN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_BOLD_WHITE}WEBADMIN GUI ĐÃ ĐƯỢC TẮT${C_RESET}"
  echo -e "${C_GREEN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
  left_text "Hệ thống bảo mật đã được niêm phong từ trước!" 2
  left_text "Hiện tại máy chủ đang ở trạng thái an toàn tuyệt đối." 2
  echo -e "${C_GREEN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"
  sleep 3
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-webadmin-main 1
  exit 0
fi

echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_BOLD_WHITE}BẢO MẬT HỆ THỐNG${C_RESET}"
echo -e "${C_CYAN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
left_text "Khuyến nghị: Sau khi đã thiết lập xong các cấu hình cần thiết," 2
left_text "bạn NÊN TẮT WebAdmin GUI đi. Việc này giúp thu hẹp bề mặt" 2
left_text "tấn công mạng và tiết kiệm một phần tài nguyên cho máy chủ." 2
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

# ==============================================================================
# XÁC NHẬN VÀ TIẾN HÀNH ĐÓNG
# ==============================================================================
if ! wptt_xac_nhan "Bạn có chắc chắn muốn TẮT OpenLiteSpeed WebAdmin GUI không?" "" "" "Đồng ý Tắt" "Hủy thao tác"; then
  echo -e "${C_YELLOW}Đã hủy thao tác.${C_RESET}\n"
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-webadmin-main 1
  exit 0
fi

echo ""
_runing "Đang kích hoạt chế độ ẩn mình (Tạo file Disable WebConsole)..."
touch /usr/local/lsws/conf/disablewebconsole
_rundone "Cấm quyền truy cập WebGUI thành công"

# Lấy Port đang dùng để đóng tường lửa
port_webgui_openlitespeed=$(grep "address" /usr/local/lsws/admin/conf/admin_config.conf | grep -o '[0-9]\+')

if [[ -n "$port_webgui_openlitespeed" && "$port_webgui_openlitespeed" =~ ^[0-9]+$ ]]; then
  _runing "Đang đóng cổng mạng $port_webgui_openlitespeed trên hệ thống Tường lửa (Firewall)..."

  # Đóng Firewalld
  if [[ $(systemctl status firewalld.service 2>/dev/null | grep 'Active' | awk '{print $2}') == 'active' ]]; then
    firewall-cmd --permanent --zone=public --remove-port=${port_webgui_openlitespeed}/tcp >/dev/null 2>&1
    firewall-cmd --reload >/dev/null 2>&1
  fi

  # Đóng CSF
  if [[ -f /etc/csf/csf.conf ]]; then
    sed -i -r '/^TCP_IN /s/"'$port_webgui_openlitespeed'"/""/; s/([",])'$port_webgui_openlitespeed',|,'$port_webgui_openlitespeed'([,"])/\1\2/' /etc/csf/csf.conf
    csf -x >/dev/null 2>&1
    csf -e >/dev/null 2>&1
  fi

  # Đóng Nftables
  if [[ $(systemctl status nftables.service 2>/dev/null | grep 'Active' | awk '{print $2}') == 'active' ]]; then
    path_nftables_config="/etc/sysconfig/nftables.conf"
    cat /etc/*release 2>/dev/null | grep -qi "Ubuntu" && path_nftables_config="/etc/nftables.conf"
    if [[ -f "$path_nftables_config" ]]; then
      sed -i '/#port webguiadmin/d' "$path_nftables_config"
      systemctl restart nftables >/dev/null 2>&1
    fi
  fi
  _rundone "Đã niêm phong cổng kết nối $port_webgui_openlitespeed an toàn"
else
  _rundone "Cổng mạng hiện tại đã được khóa"
fi

_runing "Đang khởi động lại dịch vụ OpenLiteSpeed..."
/usr/local/lsws/bin/lswsctrl restart >/dev/null 2>&1
_rundone "Khởi động dịch vụ thành công"

echo "Tắt webguiadmin OLS : $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log

# ==============================================================================
# BẢNG BÁO CÁO THÀNH CÔNG
# ==============================================================================
echo -e "\n${C_GREEN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_BOLD_WHITE}HOÀN TẤT TẮT WEBADMIN GUI${C_RESET}"
echo -e "${C_GREEN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
left_text "Giao diện quản trị đã bị vô hiệu hóa, cổng mạng đã đóng." 2
left_text "Máy chủ của bạn hiện đang ở trạng thái an toàn bảo mật cao." 2
echo -e "${C_GREEN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

[[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-webadmin-main 1
