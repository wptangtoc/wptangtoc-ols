#!/bin/bash
# @author: Gia Tuấn
# @website: https://wptangtoc.com
# @since: 2026

function huong_dan() {
  thay đổi tài khoản [username] và mật khẩu [password] cho WebAdmin GUI của OpenLiteSpeed là một thao tác quản trị quan trọng để duy trì bảo mật cho máy chủ của bạn.

  Dưới đây là giới thiệu ngắn gọn về tính năng này:

  Tại sao cần thay đổi tài khoản và mật khẩu WebAdmin?
  * Bảo mật định kỳ: Thay đổi mật khẩu thường xuyên là một biện pháp bảo mật tốt để giảm thiểu rủi ro nếu thông tin đăng nhập cũ bị lộ.
  * Sau khi người dùng cũ rời đi: Nếu người quản trị trước đó không còn làm việc, bạn cần thay đổi thông tin đăng nhập để đảm bảo chỉ những người được ủy quyền mới có quyền truy cập.
  * Nghi ngờ bị xâm phạm: Nếu có bất kỳ nghi ngờ nào về việc tài khoản quản trị có thể đã bị xâm phạm, việc thay đổi ngay lập tức là cần thiết.
  * Thiết lập ban đầu không an toàn: Nếu bạn sử dụng mật khẩu yếu trong quá trình cài đặt ban đầu, bạn nên đổi sang một mật khẩu mạnh hơn.

  cập nhật thông tin đăng nhập cho giao diện quản trị WebAdmin của OpenLiteSpeed, giúp bạn bảo vệ máy chủ web của mình một cách hiệu quả.
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null # Nạp thư viện UX Bo Cong

clear
echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}Quản lý WebGuiAdmin ➜ Khởi tạo lại (Reset) Tài khoản WebAdmin GUI${C_RESET}"
echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

if [[ "${1:-}" == '98' ]]; then
  WPTT_IN_MENU="yes"
  WPTT_MENU_BACK="/etc/wptt/wptt-webadmin-main 1"
fi

# ==============================================================================
# KIỂM TRA TRẠNG THÁI HIỆN TẠI (NẾU ĐANG BỊ TẮT THÌ CẢNH BÁO)
# ==============================================================================
path="/usr/local/lsws/conf/disablewebconsole"
if [[ -f $path ]]; then
  echo -e "${C_RED}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_BOLD_WHITE}WEBADMIN GUI HIỆN ĐANG BỊ TẮT${C_RESET}"
  echo -e "${C_RED}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
  left_text "Giao diện quản trị Web hiện đang bị vô hiệu hóa để bảo mật." 2
  left_text "Nếu muốn đổi Mật khẩu, bạn cần [Mở WebAdmin] trước." 2
  echo -e "${C_RED}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"
  sleep 3
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-webadmin-main 1
  exit 0
fi

# ==============================================================================
# XÁC NHẬN VÀ THỰC THI THAY ĐỔI
# ==============================================================================
if wptt_xac_nhan "Bạn có muốn thay đổi (Reset) Tài khoản và Mật khẩu WebAdmin không?" "Hệ thống sẽ tạo ra một bộ thông tin đăng nhập ngẫu nhiên siêu bảo mật." "" "Đồng ý Thay đổi" "Hủy thao tác"; then

  echo ""
  _runing "Đang khởi tạo Tên đăng nhập và Mật khẩu mới (Random Generator)..."

  # Tạo User 24 ký tự và Pass 36 ký tự siêu bảo mật
  Webadmin_Pass=$(openssl rand -base64 48 | tr -dc 'a-zA-Z0-9' | head -c 36)
  id_ols_admin=$(openssl rand -base64 32 | tr -dc 'a-zA-Z0-9' | head -c 24)

  # Mã hóa và cập nhật vào hệ thống OpenLiteSpeed
  Encrypt_string=$(/usr/local/lsws/admin/fcgi-bin/admin_php -q /usr/local/lsws/admin/misc/htpasswd.php "${Webadmin_Pass}")
  echo "" >/usr/local/lsws/admin/conf/htpasswd
  echo "$id_ols_admin:$Encrypt_string" >/usr/local/lsws/admin/conf/htpasswd

  # Lưu lại cấu hình cho WPTangToc
  sed -i "/Password_OLS_webgui/d" /etc/wptt/.wptt.conf
  sed -i "/Ten_dang_nhap_ols_webgui/d" /etc/wptt/.wptt.conf
  echo "Password_OLS_webgui=$Webadmin_Pass" >>/etc/wptt/.wptt.conf
  echo "Ten_dang_nhap_ols_webgui=$id_ols_admin" >>/etc/wptt/.wptt.conf

  _rundone "Cập nhật tài khoản quản trị thành công"

  echo "Thay doi tai khoan webguiadmin OLS : $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log

  # ==============================================================================
  # LẤY THÔNG TIN URL VÀ IN BẢNG BÁO CÁO
  # ==============================================================================
  port_webgui_openlitespeed=$(grep "address" /usr/local/lsws/admin/conf/admin_config.conf 2>/dev/null | grep -o '[0-9]\+')
  port_webgui_openlitespeed=${port_webgui_openlitespeed:-19019}

  ipv4=$(curl -skf --connect-timeout 5 "https://ipv4.icanhazip.com" || curl -skf --connect-timeout 5 "https://checkip.amazonaws.com")
  ipv6=$(curl -sk --connect-timeout 5 "https://ipv6.icanhazip.com")

  if [[ -n "$ipv6" && -z "$ipv4" ]]; then
    link_truy_cap="http://[$ipv6]:$port_webgui_openlitespeed"
  else
    link_truy_cap="http://${ipv4}:$port_webgui_openlitespeed"
  fi

  echo -e "\n${C_GREEN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_BOLD_WHITE}HOÀN TẤT THAY ĐỔI TÀI KHOẢN WEBADMIN GUI${C_RESET}"
  echo -e "${C_GREEN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
  left_text "Lưu lại thông tin siêu bảo mật bên dưới để đăng nhập:" 2
  echo -e "${C_GREEN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
  left_text " 1. Đường dẫn Link  : ${C_YELLOW}$link_truy_cap${C_RESET}" 2
  left_text " 2. Tên đăng nhập   : ${C_YELLOW}$id_ols_admin${C_RESET}" 2
  left_text " 3. Mật khẩu (Pass) : ${C_YELLOW}$Webadmin_Pass${C_RESET}" 2
  echo -e "${C_GREEN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

else
  echo -e "${C_YELLOW}Đã hủy thao tác.${C_RESET}\n"
fi

echo -en "${C_GREEN}Nhấn phím [Enter] để quay lại Menu...${C_RESET}"
read -r dummy

[[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-webadmin-main 1
