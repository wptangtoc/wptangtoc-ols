#!/bin/bash
# @author: Gia Tuấn
# @website: https://wptangtoc.com
# @since: 2025

function huong_dan() {
  Tính năng WebAdmin GUI [Giao diện Quản trị Web] của OpenLiteSpeed là một công cụ mạnh mẽ và thân thiện, giúp bạn dễ dàng cấu hình và quản lý máy chủ web OpenLiteSpeed mà không cần phải thao tác trực tiếp với các tệp cấu hình qua dòng lệnh.

  Dưới đây là giới thiệu về tính năng kích hoạt và sử dụng WebAdmin GUI của OpenLiteSpeed:

  Mục đích của WebAdmin GUI:
  * Cấu hình trực quan: Cung cấp giao diện đồ họa để bạn có thể xem và chỉnh sửa hầu hết các thiết lập của máy chủ OpenLiteSpeed, từ cài đặt cơ bản đến các tính năng nâng cao.
  * Quản lý dễ dàng: Giúp việc quản lý virtual host [các trang web chạy trên cùng máy chủ], listeners [cổng lắng nghe], module, và các thành phần khác trở nên đơn giản hơn.
  * Theo dõi thời gian thực: Cung cấp các số liệu thống kê và trạng thái máy chủ theo thời gian thực, giúp bạn giám sát hiệu suất và phát hiện sự cố.
  * Giảm thiểu lỗi: Giao diện trực quan giúp hạn chế sai sót so với việc chỉnh sửa thủ công các tệp cấu hình văn bản phức tạp.

  WebAdmin GUI là một thành phần không thể thiếu khi làm việc với OpenLiteSpeed, giúp đơn giản hóa đáng kể công việc quản trị máy chủ web, đồng thời cung cấp nhiều công cụ mạnh mẽ để theo dõi và tối ưu hóa hiệu suất.

  Ghi chú: sử dụng webguiadmin đồng nghĩa với việc một port được mở ra đồng nghĩa với việc thêm một rủi ro bảo mật.
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null # Nạp thư viện UX Bo Cong

clear
echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}Quản lý WebGuiAdmin ➜ Kích hoạt Giao diện Quản trị Web (WebAdmin GUI)${C_RESET}"
echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

if [[ "${1:-}" == '98' ]]; then
  WPTT_IN_MENU="yes"
  WPTT_MENU_BACK="/etc/wptt/wptt-webadmin-main 1"
fi

# ==============================================================================
# KIỂM TRA TRẠNG THÁI HIỆN TẠI
# ==============================================================================
path="/usr/local/lsws/conf/disablewebconsole"
if [[ ! -f $path ]]; then
  echo -e "${C_GREEN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_BOLD_WHITE}WEBADMIN GUI ĐANG HOẠT ĐỘNG${C_RESET}"
  echo -e "${C_GREEN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
  left_text "Tính năng này đã được kích hoạt trước đó rồi!" 2
  left_text "Bạn có thể vào menu Xem thông tin OLS để lấy lại mật khẩu." 2
  echo -e "${C_GREEN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"
  sleep 3
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-webadmin-main 1
  exit 0
fi

echo -e "${C_YELLOW}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_BOLD_WHITE}CẢNH BÁO BẢO MẬT${C_RESET}"
echo -e "${C_YELLOW}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
left_text "WebAdmin GUI giúp cấu hình LiteSpeed trực quan trên trình duyệt." 2
left_text "Tuy nhiên, việc mở thêm cổng mạng (Port) sẽ làm tăng bề mặt" 2
left_text "tấn công. Khuyến nghị ĐỔI PORT KHÁC mặc định để an toàn hơn." 2
echo -e "${C_YELLOW}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

# ==============================================================================
# XÁC NHẬN VÀ CHỌN PORT
# ==============================================================================
if ! wptt_xac_nhan "Bạn có chắc chắn muốn KÍCH HOẠT OpenLiteSpeed WebAdmin GUI không?" "" "" "Đồng ý Kích hoạt" "Hủy thao tác"; then
  echo -e "${C_YELLOW}Đã hủy thao tác.${C_RESET}\n"
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-webadmin-main 1
  exit 0
fi

echo ""
echo -en "${C_CYAN}Nhập Port WebAdmin OLS mới (Khuyên dùng) hoặc [Enter] để dùng 19019: ${C_RESET}"
read -r port_ols

if [[ -z "$port_ols" || "$port_ols" == "0" ]]; then
  echo -e "${C_YELLOW}Đã chọn Port mặc định: 19019${C_RESET}"
  port_ols=19019
fi

if ! [[ "$port_ols" =~ ^[0-9]+$ ]] || ((port_ols < 1 || port_ols > 65535)); then
  echo -e "${C_RED}❌ Port không hợp lệ! Tự động chuyển về Port mặc định: 19019${C_RESET}"
  port_ols=19019
fi

# RÀO CHẮN: Kiểm tra trùng Port SSH
port_ssh=$(grep -E '^\s*Port\s+[0-9]+' /etc/ssh/sshd_config | awk '{print $2}' | head -n 1)
port_ssh=${port_ssh:-22}
if [[ "$port_ols" == "$port_ssh" ]]; then
  echo -e "\n${C_RED}❌ Lỗi: Cổng $port_ols đang được sử dụng bởi SSH! Vui lòng chọn cổng khác.${C_RESET}"
  sleep 3
  exec /etc/wptt/wptt-webadmin-main 1
  exit 1
fi

# RÀO CHẮN: Kiểm tra trùng Port Database
if cat /etc/*release 2>/dev/null | grep -qi "Ubuntu"; then
  duong_dan_cau_hinh_mariadb="/etc/mysql/my.cnf"
else
  duong_dan_cau_hinh_mariadb="/etc/my.cnf.d/server.cnf"
fi

port_mariadb_remote=$(grep -i '^port[[:space:]]*=' "$duong_dan_cau_hinh_mariadb" 2>/dev/null | grep -o '[0-9]\+')
if [[ -n "$port_mariadb_remote" && "$port_ols" == "$port_mariadb_remote" ]]; then
  echo -e "\n${C_RED}❌ Lỗi: Cổng $port_ols đang được sử dụng bởi MariaDB Remote! Vui lòng chọn cổng khác.${C_RESET}"
  sleep 3
  exec /etc/wptt/wptt-webadmin-main 1
  exit 1
fi

echo ""
# _runing "Đang xóa bỏ lệnh chặn (Disable WebConsole) trên hệ thống..."
rm -f /usr/local/lsws/conf/disablewebconsole
# _rundone "Gỡ bỏ lệnh chặn thành công"

# ==============================================================================
# CẤU HÌNH LISTENER (IPV4 & IPV6)
# ==============================================================================
_runing "Đang thiết lập cổng mạng (Listener) cho WebAdmin GUI ($port_ols)..."

ipv4=$(curl -sf --connect-timeout 5 "https://ipv4.icanhazip.com" || curl -sf --connect-timeout 5 "https://checkip.amazonaws.com")
ipv6=$(curl -s --connect-timeout 5 "https://ipv6.icanhazip.com")

sed -i -e '/^listener adminListener/,/^}$/d' /usr/local/lsws/admin/conf/admin_config.conf

if [[ -n "$ipv4" ]]; then
  echo "listener adminListener{
  address               *:$port_ols
  secure                1
  keyFile               \$SERVER_ROOT/admin/conf/webadmin.key
  certFile              \$SERVER_ROOT/admin/conf/webadmin.crt
  clientVerify          0
}" >>/usr/local/lsws/admin/conf/admin_config.conf
elif [[ -n "$ipv6" && -z "$ipv4" ]]; then
  echo "listener adminListener{
  address               [ANY]:$port_ols
  secure                1
  keyFile               \$SERVER_ROOT/admin/conf/webadmin.key
  certFile              \$SERVER_ROOT/admin/conf/webadmin.crt
  clientVerify          0
}" >>/usr/local/lsws/admin/conf/admin_config.conf
fi
_rundone "Cấu hình cổng kết nối Listener hoàn tất"

# ==============================================================================
# CẤU HÌNH TƯỜNG LỬA (FIREWALL)
# ==============================================================================
_runing "Đang mở cổng $port_ols trên hệ thống tường lửa (Firewall)..."

# Firewalld
if [[ $(systemctl status firewalld.service 2>/dev/null | grep 'Active' | awk '{print $2}') == 'active' ]]; then
  firewall-cmd --permanent --zone=public --add-port=$port_ols/tcp >/dev/null 2>&1
  firewall-cmd --reload >/dev/null 2>&1
fi

# CSF
if [[ -f /etc/csf/csf.conf ]]; then
  if ! grep -q "^TCP_IN =.*$port_ols," /etc/csf/csf.conf; then
    sed -i "s/^TCP_IN = \"/TCP_IN = \"$port_ols,/g" /etc/csf/csf.conf
    csf -x >/dev/null 2>&1
    csf -e >/dev/null 2>&1
  fi
fi

# Nftables
if [[ $(systemctl status nftables.service 2>/dev/null | grep 'Active' | awk '{print $2}') == 'active' ]]; then
  path_nftables_config="/etc/sysconfig/nftables.conf"
  cat /etc/*release 2>/dev/null | grep -qi "Ubuntu" && path_nftables_config="/etc/nftables.conf"
  if [[ -f "$path_nftables_config" ]]; then
    sed -i '/#port webguiadmin/d' "$path_nftables_config"
    sed -i "/chain input /a\ \ tcp dport $port_ols accept #port webguiadmin" "$path_nftables_config"
    systemctl restart nftables >/dev/null 2>&1
  fi
fi
_rundone "Xuyên tường lửa mở cổng thành công"

_runing "Đang khởi động lại dịch vụ OpenLiteSpeed..."
/usr/local/lsws/bin/lswsctrl restart >/dev/null 2>&1
_rundone "Khởi động dịch vụ thành công"

# ==============================================================================
# TẠO MẬT KHẨU NGẪU NHIÊN VÀ BÁO CÁO
# ==============================================================================
_runing "Đang tạo tài khoản quản trị (Username & Password) siêu bảo mật..."
Webadmin_Pass=$(openssl rand -base64 48 | tr -dc 'a-zA-Z0-9' | head -c 36)
id_ols_admin=$(openssl rand -base64 32 | tr -dc 'a-zA-Z0-9' | head -c 24)

Encrypt_string=$(/usr/local/lsws/admin/fcgi-bin/admin_php -q /usr/local/lsws/admin/misc/htpasswd.php "${Webadmin_Pass}")
echo "" >/usr/local/lsws/admin/conf/htpasswd
echo "$id_ols_admin:$Encrypt_string" >/usr/local/lsws/admin/conf/htpasswd

sed -i "/Password_OLS_webgui/d" /etc/wptt/.wptt.conf
sed -i "/Ten_dang_nhap_ols_webgui/d" /etc/wptt/.wptt.conf
sed -i "/port_webgui_openlitespeed=/d" /etc/wptt/.wptt.conf

echo "Password_OLS_webgui=$Webadmin_Pass" >>/etc/wptt/.wptt.conf
echo "Ten_dang_nhap_ols_webgui=$id_ols_admin" >>/etc/wptt/.wptt.conf
echo "port_webgui_openlitespeed=$port_ols" >>/etc/wptt/.wptt.conf
_rundone "Đã khởi tạo tài khoản quản trị xong"

echo "Mở webguiadmin OLS : $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log

echo -e "\n${C_GREEN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_BOLD_WHITE}HOÀN TẤT KÍCH HOẠT WEBADMIN GUI${C_RESET}"
echo -e "${C_GREEN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
left_text "Lưu lại thông tin siêu bảo mật bên dưới để truy cập vào" 2
left_text "trình duyệt cấu hình OpenLiteSpeed của bạn:" 2
echo -e "${C_GREEN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"

if [[ -n "$ipv6" && -z "$ipv4" ]]; then
  link_truy_cap="http://[$ipv6]:$port_ols"
else
  link_truy_cap="http://${ipv4}:$port_ols"
fi

left_text " 1. Đường dẫn Link  : ${C_YELLOW}$link_truy_cap${C_RESET}" 2
left_text " 2. Tên đăng nhập   : ${C_YELLOW}$id_ols_admin${C_RESET}" 2
left_text " 3. Mật khẩu (Pass) : ${C_YELLOW}$Webadmin_Pass${C_RESET}" 2
echo -e "${C_GREEN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

echo -en "${C_GREEN}Nhấn phím [Enter] để quay lại Menu...${C_RESET}"
read -r dummy

[[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-webadmin-main 1
