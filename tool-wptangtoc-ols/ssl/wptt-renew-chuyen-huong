#!/bin/bash
# @author: Gia Tuấn
# @website: https://wptangtoc.com
# @since: 2026

function huong_dan() {
  WPTangToc OLS có tính năng Renew thiết lập lại chuyển hướng HTTP to HTTPS, thì đây là một chức năng quan trọng giúp bạn kiểm tra, sửa chữa và áp dụng lại một cách dứt khoát quy tắc chuyển hướng toàn bộ truy cập từ giao thức http:// không an toàn sang https:// an toàn cho website của bạn.

  Nhấn mạnh rằng tính năng này không chỉ tạo mới mà còn có khả năng khôi phục hoặc sửa chữa một cấu hình chuyển hướng có thể đã bị lỗi hoặc thay đổi trước đó.

  Tính năng Renew [Làm mới] / Thiết lập lại Chuyển hướng HTTP to HTTPS
  🔒 Mục đích chính:
  * Sửa lỗi Chuyển hướng: Khắc phục các tình huống mà việc tự động chuyển từ HTTP sang HTTPS bị hỏng, không hoạt động hoặc hoạt động không chính xác do thay đổi cấu hình, cập nhật hoặc lỗi nào đó.
  * Đảm bảo Tính Đúng đắn: Xác minh và áp dụng lại quy tắc chuyển hướng theo phương pháp chuẩn [thường là 301 Permanent Redirect] mà công cụ WPTangToc OLS khuyên dùng.
  * Tiêu chuẩn hóa Cấu hình: Đảm bảo tất cả các website được quản lý đều áp dụng một cơ chế chuyển hướng HTTPS đồng nhất và hiệu quả.
  * Đơn giản hóa Quản lý: Cung cấp một nút bấm hoặc lệnh duy nhất để xử lý toàn bộ việc enforces HTTPS, thay vì phải can thiệp thủ công vào cấu hình OpenLiteSpeed.
  * Hỗ trợ Sau khi Cài/Gia hạn SSL: Là một bước cần thiết sau khi bạn cài đặt hoặc gia hạn thành công chứng chỉ SSL để đảm bảo website ngay lập tức sử dụng nó.

  Tóm lại: Tính năng Renew thiết lập lại chuyển hướng HTTP to HTTPS trong WPTangToc OLS là một công cụ mạnh mẽ và tiện lợi, giúp bạn đảm bảo rằng website của mình luôn hoạt động một cách an toàn và nhất quán trên giao thức HTTPS, đồng thời dễ dàng sửa chữa các lỗi cấu hình liên quan.
}

. /etc/wptt/echo-color
NAME=$1

[[ "$NAME" == "98" ]] && NAME=""

if [[ -z "$NAME" ]]; then
  echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_YELLOW}${quan_ly_ssl} ➜ Renew chuyển hướng HTTP TO HTTPS${C_RESET}"
  echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"
  . /etc/wptt/tenmien-them-lua-chon-tat-ca-website
  lua_chon_NAME "Renew chuyển hướng HTTP TO HTTPS"
fi

# --- KHỐI TẤT CẢ WEBSITE (SIÊU TỐC) ---
if [[ "$NAME" == 'Tất cả website' ]]; then
  for filepath in /etc/wptt/vhost/.*.conf; do
    [[ ! -f "$filepath" || "$filepath" == *"/..conf" ]] && continue

    domain="${filepath##*/}"
    domain="${domain%.conf}"
    domain="${domain#.}"

    if [[ "$domain" == ?*.?* ]]; then
      path="/usr/local/lsws/$domain/html"
      if [[ -d "$path" ]]; then
        # Kiểm tra chứng chỉ SSL hoặc Cloudflare
        if [[ ! -f "/etc/letsencrypt/live/$domain/cert.pem" && ! -f "/etc/letsencrypt/live/www.$domain/cert.pem" && ! -d "/usr/local/lsws/$domain/ssl" ]]; then
          continue
        fi

        UI_STRING="Renew chuyển hướng SSL $domain"
        _runing "$UI_STRING"
        (/etc/wptt/ssl/wptt-renew-chuyen-huong "$domain" >/dev/null 2>&1)
        _rundone "$UI_STRING"
      fi
    fi
  done

  [[ ${1:-} == "98" ]] && exec /etc/wptt/wptt-ssl-main 1
  exit
fi

[[ "$NAME" == "0" || -z "$NAME" ]] && exec /etc/wptt/wptt-ssl-main 1

path_conf="/etc/wptt/vhost/.$NAME.conf"
[[ ! -f "$path_conf" && ! -f "/etc/wptt/chuyen-huong/.$NAME.conf" ]] && {
  clear
  echoDo "$ten_mien_nay_khong_ton_tai_tren_he_thong"
  sleep 2
  [[ ${1:-} == "98" ]] && exec /etc/wptt/wptt-ssl-main 1
  exit 1
}

# Kiểm tra xem có SSL không (Bao gồm check siêu tốc Cloudflare)
if [[ ! -f "/etc/letsencrypt/live/$NAME/cert.pem" && ! -f "/etc/letsencrypt/live/www.$NAME/cert.pem" && ! -d "/usr/local/lsws/$NAME/ssl" ]]; then
  if ! curl -sI -m 5 "https://$NAME" 2>/dev/null | grep -qi 'cloudflare'; then
    echoDo "Website $NAME bạn chưa được cài đặt chứng chỉ SSL"
    [[ ${1:-} == "98" ]] && exec /etc/wptt/wptt-ssl-main 1
    exit 1
  fi
fi

UI_STRING="Setup Chuyển hướng website $NAME (HTTP TO HTTPS)"
_runing "$UI_STRING"

. /etc/wptt/php/php-cli-domain-config $NAME
. /etc/wptt/vhost/.$NAME.conf

if [[ -f "/usr/local/lsws/$NAME/html/wp-config.php" ]]; then
  WP_EXEC="sudo -u $User_name_vhost /usr/local/lsws/lsphp${phien_ban_php_domain_thuc_thi}/bin/php /usr/local/bin/wp"

  giatuanwww=$($WP_EXEC option get home --path="/usr/local/lsws/$NAME/html" 2>/dev/null | grep 'www.')
  if [[ -n "$giatuanwww" ]]; then
    $WP_EXEC option update home "https://www.$NAME" --path="/usr/local/lsws/$NAME/html" >/dev/null 2>&1
    $WP_EXEC option update siteurl "https://www.$NAME" --path="/usr/local/lsws/$NAME/html" >/dev/null 2>&1
  else
    $WP_EXEC option update home "https://$NAME" --path="/usr/local/lsws/$NAME/html" >/dev/null 2>&1
    $WP_EXEC option update siteurl "https://$NAME" --path="/usr/local/lsws/$NAME/html" >/dev/null 2>&1
  fi
fi

# --- 2. CHECK DNS ---
checkdns=$(host "$NAME" 2>/dev/null | grep -Eo -m 1 '[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}')
[[ -z "$checkdns" ]] && checkdns=$(nslookup "$NAME" 2>/dev/null | grep Address | cut -f5 | grep -Eo -m 1 '[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}')

checkdnscname=$(host "www.$NAME" 2>/dev/null | grep -Eo -m 1 '[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}')
[[ -z "$checkdnscname" ]] && checkdnscname=$(nslookup "www.$NAME" 2>/dev/null | grep Address | cut -f5 | grep -Eo -m 1 '[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}')

# --- 3. CẤU HÌNH HTACCESS ---
path2="/usr/local/lsws/$NAME/html/.htaccess"

# Xóa các rules chuyển hướng cũ của WPTangToc
sed -i -e '/^#begin-chuyen-huong-http-to-https-wptangtoc-ols/,/^#end-chuyen-huong-http-to-https-wptangtoc-ols$/d' "$path2" 2>/dev/null
sed -i -e '/^#begin-chuyen-huong-www-to-non-www-wptangtoc-ols/,/^#end-chuyen-huong-www-to-non-www-wptangtoc-ols$/d' "$path2" 2>/dev/null
sed -i -e '/^#begin-chuyen-huong-non-www-to-www-wptangtoc-ols/,/^#end-chuyen-huong-non-www-to-www-wptangtoc-ols$/d' "$path2" 2>/dev/null

# Thêm rule HTTP -> HTTPS
sed -i '1 i #begin-chuyen-huong-http-to-https-wptangtoc-ols\
RewriteCond %{HTTPS} !=on\
RewriteRule ^(.*)$ https:\/\/%{HTTP_HOST}%{REQUEST_URI} [L,R=301,NE]\
#end-chuyen-huong-http-to-https-wptangtoc-ols' "$path2"

# Thêm rule WWW -> non-WWW (Nếu DNS trỏ giống nhau)
if [[ "$checkdns" == "$checkdnscname" && -n "$checkdns" ]]; then
  sed -i '1 i #begin-chuyen-huong-www-to-non-www-wptangtoc-ols\
RewriteCond %{HTTP_HOST} ^www.'$NAME' [NC]\
RewriteRule ^(.*)$ https:\/\/'$NAME'/$1 [L,R=301,NC]\
#end-chuyen-huong-www-to-non-www-wptangtoc-ols' "$path2"
fi

# Chuyển đổi WWW nếu option của WordPress chứa WWW
if [[ ! -f "/etc/wptt/chuyen-huong/.$NAME.conf" ]]; then
  if [[ -f "/usr/local/lsws/$NAME/html/wp-config.php" ]]; then
    giatuanwww=$($WP_EXEC option get home --path="/usr/local/lsws/$NAME/html" 2>/dev/null | grep "$NAME" | grep 'www.')
    if [[ -n "$giatuanwww" && "$checkdns" == "$checkdnscname" ]]; then

      # Xóa rule WWW -> non-WWW vừa nãy (nếu có)
      sed -i -e '/^#begin-chuyen-huong-www-to-non-www-wptangtoc-ols/,/^#end-chuyen-huong-www-to-non-www-wptangtoc-ols$/d' "$path2"

      # Thêm rule non-WWW -> WWW
      sed -i '1 i #begin-chuyen-huong-non-www-to-www-wptangtoc-ols\
RewriteCond %{HTTP_HOST} ^'$NAME' [NC]\
RewriteRule ^(.*)$ https:\/\/www\.'$NAME'/$1 [L,R=301,NC]\
#end-chuyen-huong-non-www-to-www-wptangtoc-ols' "$path2"
    fi
  fi
fi

/usr/local/lsws/bin/lswsctrl reload >/dev/null 2>&1

echo "Cấu hình renew chuyển hướng website $NAME: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log

_rundone "$UI_STRING"

[[ ${1:-} == "98" ]] && exec /etc/wptt/wptt-ssl-main 1
