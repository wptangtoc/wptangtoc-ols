#!/bin/bash

function huong_dan() {
  Xoá thiết lập cài ssl letsencrypt miễn phí bằng DNS API Cloudflare
  đây là hành động cắt đứt kết nối và quyền hạn mà bạn đã cấp cho công cụ quản lý SSL để nó tương tác với tài khoản Cloudflare của bạn cho việc quản lý bản ghi DNS liên quan đến xác thực SSL.

  Mục Đích Chính
  * Thay đổi phương thức xác thực: Khi bạn muốn chuyển từ xác thực qua DNS với Cloudflare API sang phương thức khác [ví dụ: HTTP-01] hoặc sử dụng một nhà cung cấp DNS khác.
  * Ngừng sử dụng Cloudflare cho việc này: Nếu bạn không còn muốn Cloudflare quản lý DNS cho tên miền đó hoặc không muốn dùng API của họ cho mục đích này nữa.
  * Gỡ bỏ tên miền/máy chủ: Khi tên miền hoặc máy chủ sử dụng thiết lập này không còn hoạt động.
  * Lo ngại về bảo mật: Nếu API token/key của Cloudflare bị lộ hoặc nghi ngờ bị xâm phạm, bạn cần hủy thiết lập và thu hồi token.
  * Không còn cần chứng chỉ wildcard: Nếu bạn không còn nhu cầu sử dụng chứng chỉ wildcard [thường yêu cầu xác thực DNS].
  * Dọn dẹp cấu hình: Loại bỏ các thiết lập cũ, không còn sử dụng.

  Sau khi thực hiện tính năng này, hệ thống sẽ không còn tự động sử dụng Cloudflare API để xin cấp hay gia hạn SSL Lets Encrypt cho tên miền đó nữa.
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null # Nạp thư viện UX Bo Cong

clear
echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}QUẢN LÝ SSL ➜ Quản Lý DNS API ➜ Xóa Thiết Lập Cloudflare${C_RESET}"
echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

mkdir -p /etc/wptt/.cloudflare

NAME=$1
[[ "$NAME" == "98" ]] && NAME=""

if [[ -z "$NAME" ]]; then
  function lua_chon_NAME() {
    unset NAME selects
    selects=()
    local box_inner_width=${box_inner_width:-71}

    # Quét toàn bộ Vhost và Vhost chuyển hướng
    for dir in "/etc/wptt/vhost" "/etc/wptt/chuyen-huong"; do
      if [[ -d "$dir" ]]; then
        for filepath in "$dir"/.*.conf; do
          [[ ! -f "$filepath" || "$filepath" == *"/..conf" ]] && continue
          local domain="${filepath##*/}"
          domain="${domain%.conf}"
          domain="${domain#.}"
          
          # CHỈ LẤY những domain đang CÓ cấu hình Cloudflare API
          if [[ "$domain" == ?*.?* && -f "/etc/wptt/.cloudflare/wptt-$domain.ini" ]]; then
            selects+=("$domain")
          fi
        done
      fi
    done

    # FIX LOGIC BẢN CŨ: Thông báo chuẩn khi không có domain nào để xóa
    if [[ ${#selects[@]} -eq 0 ]]; then
      echo -e "${C_YELLOW}⚠️ Hệ thống ghi nhận: Không có tên miền nào đang sử dụng Cloudflare API DNS.${C_RESET}\n"
      sleep 3
      exec /etc/wptt/ssl/cloudflare-api-dns-main 1
    fi

    # Render Menu
    echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
    local title_text="Lựa chọn Website để XÓA liên kết API Cloudflare:"
    local len=$(echo -n "$title_text" | awk '{print length($0)}')
    local pad_r=$((box_inner_width - len - 2))
    [[ $pad_r -lt 0 ]] && pad_r=0
    echo -e "${C_CYAN}│${C_RESET}  ${C_YELLOW}${title_text}${C_RESET}$(printf '%*s' "$pad_r" "")${C_CYAN}│${C_RESET}"

    local line_len=$((len + 3))
    local pad_line_r=$((box_inner_width - line_len))
    [[ $pad_line_r -lt 0 ]] && pad_line_r=0
    local short_line=$(printf "%${line_len}s" "" | sed 's/ /─/g')
    echo -e "${C_CYAN}├${short_line}$(printf '%*s' "$pad_line_r" "")│${C_RESET}"

    local i=1
    for dom in "${selects[@]}"; do
      local item_text=$(printf "  ${C_CYAN}%3d)${C_RESET} ${C_BOLD_WHITE}%-30s${C_RESET} ${C_RED}[Đang Liên kết]${C_RESET}" "$i" "$dom")
      local clean_text=$(printf "  %3d) %-30s [Đang Liên kết]" "$i" "$dom")
      local item_len=$(echo -n "$clean_text" | awk '{print length($0)}')
      local pad=$((box_inner_width - item_len))
      [[ $pad -lt 0 ]] && pad=0
      echo -e "${C_CYAN}│${C_RESET}${item_text}$(printf '%*s' "$pad" "")${C_CYAN}│${C_RESET}"
      ((i++))
    done
    echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯${C_RESET}"

    local fzf_installed=false
    if command -v fzf &>/dev/null; then
      fzf_installed=true
      PROMPT_TEXT="Nhập lựa chọn (1-${#selects[@]}) [00=Tìm nhanh] [0=Thoát]: "
    else
      PROMPT_TEXT="Nhập lựa chọn (1-${#selects[@]}) [0=Thoát]: "
    fi

    while true; do
      echo -en "${C_CYAN}${PROMPT_TEXT}${C_RESET}"
      if ! read -r REPLY; then exit 1; fi
      REPLY=$(echo "$REPLY" | tr -d ' ' | tr '[:upper:]' '[:lower:]')

      case "$REPLY" in
      0)
        echo -e "\n${C_GREEN}Đang thoát...${C_RESET}"
        NAME="0"
        return 0
        ;;
      00)
        if $fzf_installed; then
          local selected_item=$(printf '%s\n' "${selects[@]}" | nl -w 3 -s ': ' | fzf --prompt="Tìm website xóa API CF >> " --height=40% --border=rounded --color=border:red --cycle --reverse)
          local dom=$(echo "$selected_item" | sed 's/^[[:space:]]*[0-9]\+\:[[:space:]]*//' | cut -d'|' -f1 | tr -d ' ')
          if [[ -n "$dom" ]]; then
            NAME="$dom"
            return 0
          else echo -e "${C_YELLOW}Đã hủy chọn. Vui lòng chọn lại.${C_RESET}"; fi
        else
          echo -e "${C_RED}Lỗi: FZF chưa cài đặt.${C_RESET}"
        fi
        ;;
      *)
        if [[ "$REPLY" =~ ^[0-9]+$ ]] && [ "$REPLY" -ge 1 ] && [ "$REPLY" -le ${#selects[@]} ]; then
          local action_index=$((REPLY - 1))
          NAME=$(echo "${selects[$action_index]}" | cut -d'|' -f1 | tr -d ' ')
          return 0
        else
          echo -e "\n${C_RED}❌ Lựa chọn không hợp lệ! Vui lòng chọn lại.${C_RESET}"
        fi
        ;;
      esac
    done
  }
  lua_chon_NAME
fi

[[ "$NAME" == "0" || -z "$NAME" ]] && {
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/ssl/cloudflare-api-dns-main 1
  return 2>/dev/null || exit
}

# ==============================================================================
# KIỂM TRA MÔI TRƯỜNG
# ==============================================================================
pathcheck="/etc/wptt/vhost/.$NAME.conf"
if [[ ! -f "$pathcheck" && ! -f "/etc/wptt/chuyen-huong/.$NAME.conf" ]]; then
  echo -e "\n${C_RED}❌ Lỗi: Tên miền $NAME không tồn tại trên hệ thống này!${C_RESET}"
  sleep 3
  exec /etc/wptt/ssl/cloudflare-api-dns-main 1
fi

if [[ ! -f "/etc/wptt/.cloudflare/wptt-$NAME.ini" ]]; then
  echo -e "\n${C_YELLOW}⚠️ Tên miền $NAME không có liên kết Cloudflare API nào để xóa!${C_RESET}"
  sleep 3
  exec /etc/wptt/ssl/cloudflare-api-dns-main 1
fi

# ==============================================================================
# CẢNH BÁO XÁC NHẬN AN TOÀN
# ==============================================================================
if ! wptt_xac_nhan "⚠️ XÁC NHẬN HỦY LIÊN KẾT CLOUDFLARE API?" \
                   "Tên miền: $NAME" \
                   "Sau khi xóa, chứng chỉ SSL sẽ không tự động gia hạn qua API nữa." \
                   "Đồng ý XÓA LIÊN KẾT" "Hủy thao tác"; then
  echo -e "${C_YELLOW}Đã hủy thao tác xóa.${C_RESET}\n"
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/ssl/cloudflare-api-dns-main 1
  exit 0
fi

# ==============================================================================
# THỰC THI XÓA VÀ DỌN DẸP
# ==============================================================================
echo ""
_runing "Đang gỡ bỏ cấu hình API Key và hủy liên kết Cloudflare..."
rm -f "/etc/wptt/.cloudflare/wptt-$NAME.ini"
_rundone "Xóa tệp cấu hình API thành công"

# Tự động gỡ phần mềm nếu không còn website nào dùng API
check_install=$(ls /etc/wptt/.cloudflare/wptt-*.ini 2>/dev/null)
if [[ -z "$check_install" ]]; then
  _runing "Phát hiện hệ thống trống API. Đang gỡ bỏ các thư viện Python thừa..."
  if grep -qi "ubuntu" /etc/*release 2>/dev/null || grep -qi "debian" /etc/*release 2>/dev/null; then
    export DEBIAN_FRONTEND=noninteractive
    apt-get remove -y -q python3-cloudflare python3-certbot-dns-cloudflare >/dev/null 2>&1
    apt-get autoremove -y -q >/dev/null 2>&1
  else
    dnf remove -y -q python3-cloudflare python3-certbot-dns-cloudflare >/dev/null 2>&1
  fi
  _rundone "Dọn dẹp thư viện Certbot-Cloudflare hoàn tất"
fi

# ==============================================================================
# BÁO CÁO KẾT QUẢ
# ==============================================================================
echo -e "\n${C_GREEN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_BOLD_WHITE}✅ HOÀN TẤT XÓA THIẾT LẬP CLOUDFLARE API${C_RESET}"
echo -e "${C_GREEN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
left_text "  Tên miền đã gỡ  : ${C_YELLOW}$NAME${C_RESET}" 2
left_text "  Trạng thái API  : ${C_RED}Đã bị ngắt kết nối (Disconnected)${C_RESET}" 2
left_text "  Gia hạn SSL     : Hệ thống sẽ chuyển về phương thức Webroot cơ bản." 2
echo -e "${C_GREEN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

check_menu_wptangtoc_active=${1:-}
if [[ "$check_menu_wptangtoc_active" == "98" ]]; then
  echo -en "${C_GREEN}👉 Nhấn phím [Enter] để quay lại Menu...${C_RESET}"
  read -r dummy
  exec /etc/wptt/ssl/cloudflare-api-dns-main 1
fi
