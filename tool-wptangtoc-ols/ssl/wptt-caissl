#!/bin/bash
# @author: Gia Tuấn
# @website: https://wptangtoc.com
# @since: 2026

function huong_dan() {
  Cài đặt SSL miễn phí: Dễ dàng cài đặt chứng chỉ SSL từ Lets Encrypt cho các tên miền của bạn mà không tốn chi phí.

  Tính năng Cài SSL Lets Encrypt là cài đặt chứng chỉ SSL/TLS miễn phí từ Lets Encrypt cho website của bạn, qua đó kích hoạt giao thức HTTPS [kết nối an toàn, mã hóa].

  Nói một cách đơn giản, đây là cách để website của bạn có biểu tượng ổ khóa 🔒 trên trình duyệt, đảm bảo dữ liệu truyền đi giữa người dùng và website được bảo mật, và thường được thực hiện một cách tự động hoặc rất đơn giản.

  Mục Đích Chính
  * Bảo mật dữ liệu: Mã hóa thông tin trao đổi [như mật khẩu, thông tin cá nhân, thẻ tín dụng] giữa trình duyệt của người dùng và website.
  * Xác thực website: Giúp khẳng định website là đáng tin cậy, không phải trang giả mạo [đối với loại chứng chỉ Domain Validation - DV mà Lets Encrypt cung cấp].
  * Cải thiện SEO: Các công cụ tìm kiếm như Google ưu tiên các website sử dụng HTTPS.
  * Tăng uy tín: Người dùng cảm thấy an tâm hơn khi truy cập website có HTTPS.

  Tính năng cài đặt SSL Lets Encrypt giúp việc bảo mật website trở nên dễ dàng, miễn phí và tự động, góp phần làm cho Internet an toàn hơn.

  * Tự động gia hạn: Chứng chỉ SSL Lets Encrypt có thời hạn nhất định [thường là 90 ngày]. WPTangToc OLS sẽ tự động thực hiện quá trình gia hạn này, đảm bảo website của bạn luôn được bảo vệ bằng HTTPS mà không cần can thiệp thủ công.
  * Hỗ trợ cho nhiều tên miền: Bạn có thể quản lý và cài đặt SSL cho nhiều tên miền và tên miền phụ trên cùng một máy chủ.
  * Tự động chuyển hướng HTTP sang HTTPS: Sau khi cài đặt SSL thành công, WPTangToc OLS thường sẽ hỗ trợ cấu hình tự động chuyển hướng truy cập từ HTTP sang HTTPS, giúp đảm bảo an toàn và cải thiện SEO.
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null

if [[ "$1" == '98' ]]; then
  WPTT_IN_MENU="yes"
  WPTT_MENU_BACK="/etc/wptt/wptt-ssl-main 1"
fi

clear
echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}${quan_ly_ssl} ➜ ${cai_dat_ssl_letencrypt}${C_RESET}"
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

wptt_check_lsws || wptt_die "OpenLiteSpeed đang bị lỗi. Hệ thống từ chối cài đặt SSL để đảm bảo an toàn."

NAME=$1
[[ "$NAME" == "98" ]] && NAME=""

# ==============================================================================
# HÀM MENU LỌC DOMAIN BO CONG
# ==============================================================================
if [[ -z "$NAME" ]]; then
  function lua_chon_NAME() {
    unset NAME selects
    selects=()
    local box_inner_width=${box_inner_width:-71}

    if [ "$(ls -At /etc/wptt/vhost 2>/dev/null)" ]; then
      for entry in $(ls -A /etc/wptt/vhost | grep -v '^\.\.conf$' | sort -uV); do
        local dom=$(echo "$entry" | sed 's/^.//' | sed 's/.conf//')
        if [[ "$dom" == ?*.?* && -f "/usr/local/lsws/conf/vhosts/$dom/$dom.conf" ]]; then
          selects+=("$dom")
        fi
      done
    fi

    if [[ -d /etc/wptt/chuyen-huong ]]; then
      for entry2 in $(ls -A /etc/wptt/chuyen-huong 2>/dev/null); do
        local dom2=$(echo "$entry2" | sed 's/^.//' | sed 's/.conf//')
        if [[ "$dom2" == ?*.?* && -f "/usr/local/lsws/conf/vhosts/$dom2/$dom2.conf" ]]; then
          selects+=("$dom2")
        fi
      done
    fi

    if [[ ${#selects[@]} -gt 0 ]]; then
      mapfile -t selects < <(printf "%s\n" "${selects[@]}" | sort -uV)
    else
      echo -e "${C_YELLOW}⚠️ ${khong_co_domain_nao_ton_tai_tren_he_thong:-Không có tên miền nào hợp lệ trên hệ thống!}${C_RESET}"
      sleep 3
      exec /etc/wptt/wptt-ssl-main 1
    fi

    echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
    local title_text="${lua_chon_website_ban_muon:-Lựa chọn Website} ${thiet_lap:-cài đặt} SSL Let's Encrypt:"
    local len=$(echo -n "$title_text" | awk '{print length($0)}')
    local pad_r=$((box_inner_width - len - 2))
    [[ $pad_r -lt 0 ]] && pad_r=0
    echo -e "${C_CYAN}│${C_RESET}  ${C_YELLOW}${title_text}${C_RESET}$(printf '%*s' "$pad_r" "")${C_CYAN}│${C_RESET}"

    local line_len=$((len + 3))
    local pad_line_r=$((box_inner_width - line_len))
    [[ $pad_line_r -lt 0 ]] && pad_line_r=0
    local short_line=$(printf "%${line_len}s" "" | sed 's/ /─/g')
    echo -e "${C_CYAN}├${short_line}$(printf '%*s' "$pad_line_r" "")│${C_RESET}"

    local i=1
    for dom in "${selects[@]}"; do
      local item_text=$(printf "  ${C_CYAN}%3d)${C_RESET} ${C_BOLD_WHITE}%s${C_RESET}" "$i" "$dom")
      local clean_text=$(printf "  %3d) %s" "$i" "$dom")
      local item_len=$(echo -n "$clean_text" | awk '{print length($0)}')
      local pad=$((box_inner_width - item_len))
      [[ $pad -lt 0 ]] && pad=0
      echo -e "${C_CYAN}│${C_RESET}${item_text}$(printf '%*s' "$pad" "")${C_CYAN}│${C_RESET}"
      ((i++))
    done
    echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯${C_RESET}"

    local fzf_installed=false
    if command -v fzf &>/dev/null; then
      fzf_installed=true
      PROMPT_TEXT="Nhập lựa chọn (1-${#selects[@]}) [00=Tìm nhanh] [0=Thoát]: "
    else
      PROMPT_TEXT="Nhập lựa chọn (1-${#selects[@]}) [0=Thoát]: "
    fi

    while true; do
      echo -en "${C_CYAN}${PROMPT_TEXT}${C_RESET}"
      if ! read -r REPLY; then exit 1; fi
      REPLY=$(echo "$REPLY" | tr -d ' ' | tr '[:upper:]' '[:lower:]')

      case "$REPLY" in
      0)
        echo -e "\n${C_GREEN}Đang thoát...${C_RESET}"
        NAME="0"
        return 0
        ;;
      00)
        if $fzf_installed; then
          local selected_item=$(printf '%s\n' "${selects[@]}" | nl -w 3 -s ': ' | fzf --prompt="Tìm tên miền cài SSL >> " --height=40% --border=rounded --color=border:cyan --cycle --reverse)
          selected_item=$(echo "$selected_item" | sed 's/^[[:space:]]*[0-9]\+\:[[:space:]]*//')
          if [[ -n "$selected_item" ]]; then
            NAME="$selected_item"
            return 0
          else echo -e "${C_YELLOW}Đã hủy chọn. Vui lòng chọn lại.${C_RESET}"; fi
        else
          echo -e "${C_RED}Lỗi: FZF chưa cài đặt.${C_RESET}"
        fi
        ;;
      *)
        if [[ "$REPLY" =~ ^[0-9]+$ ]] && [ "$REPLY" -ge 1 ] && [ "$REPLY" -le ${#selects[@]} ]; then
          local action_index=$((REPLY - 1))
          NAME="${selects[$action_index]}"
          return 0
        else
          echo -e "\n${C_RED}Lựa chọn không hợp lệ! Vui lòng chọn lại.${C_RESET}"
        fi
        ;;
      esac
    done
  }
  lua_chon_NAME
fi

[[ "$NAME" == "0" || -z "$NAME" ]] && {
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-ssl-main 1
  return 2>/dev/null || exit
}

unset lock_down
if [[ -f "/etc/wptt/vhost/.$NAME.conf" ]]; then
  . "/etc/wptt/vhost/.$NAME.conf"
  if [[ -n "$lock_down" ]]; then
    if [[ -d "/usr/local/lsws/$NAME/html/.well-known" ]]; then
      chattr -R -i "/usr/local/lsws/$NAME/html/.well-known" >/dev/null 2>&1
      rm -rf "/usr/local/lsws/$NAME/html/.well-known"
    fi
  fi
fi

if [[ ! -f "/etc/wptt/vhost/.$NAME.conf" && ! -f "/etc/wptt/chuyen-huong/.$NAME.conf" ]]; then
  echo -e "\n${C_RED}Tên miền $NAME không tồn tại trên hệ thống này!${C_RESET}"
  sleep 3
  exec /etc/wptt/wptt-ssl-main 1
fi

if [[ -f "/usr/local/lsws/conf/vhosts/$NAME/$NAME.conf.bkwptt" ]]; then
  echo -e "\n${C_RED}❌ Lỗi: Website $NAME đang bị TẠM KHÓA!${C_RESET}"
  echo -e "${C_YELLOW}Không thể cài đặt SSL khi website đang tắt. Vui lòng mở khóa trước.${C_RESET}"
  sleep 3
  exec /etc/wptt/wptt-ssl-main 1
fi

echo "Cài đặt SSL free letsencrypt website $NAME: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log

if [[ ! -d "/usr/local/lsws/$NAME/html" ]]; then
  echo -e "\n${C_RED}❌ Lỗi nghiêm trọng: Không tìm thấy thư mục mã nguồn!${C_RESET}"
  echo -e "Thư mục tiêu chuẩn (/usr/local/lsws/$NAME/html) không hợp lệ."
  echo -e "Hỗ trợ sửa lỗi: https://wptangtoc.com/lien-he/"
  exit 1
fi

# Chuyển hướng nếu đang dùng Cloudflare API DNS
if [[ -f "/etc/wptt/.cloudflare/wptt-$NAME.ini" ]]; then
  echo -e "${C_YELLOW}Phát hiện cấu hình Cloudflare API. Chuyển hướng sang module cài SSL DNS...${C_RESET}"
  . /etc/wptt/ssl/wptt-caissl-cloudlflare-api-dns "$NAME" 98
  return 2>/dev/null || exit
fi

# (Đã lược bỏ hàm curl HTTP check theo yêu cầu để tối ưu hệ thống)

# ==============================================================================
# KIỂM TRA DNS (IPV4 & IPV6) (ĐÃ FIX LỖI GREP CHUỖI RỖNG)
# ==============================================================================
echo ""
_runing "Đang kiểm tra phân giải DNS cho tên miền $NAME..."

error_ssl_ipv4="1"
error_ssl_ipv6="1"

# Lấy danh sách IP của Máy chủ hiện tại
server_ips=$(ip a | grep -Eo '[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}' | sed '/127.0.0.1/d' | sed '/192.168/d' | sort -u)
public_ip=$(curl -sf --connect-timeout 5 https://ipv4.icanhazip.com || curl -sf --connect-timeout 5 https://checkip.amazonaws.com | grep -Eo '[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}')
server_ips="$server_ips $public_ip"

# Lấy kết quả phân giải DNS của tên miền
checkdns=$(host "$NAME" 2>/dev/null | grep -Eo -m 1 '[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}')
checkdns2=$(nslookup "$NAME" 2>/dev/null | grep Address | cut -f5 | grep -Eo -m 1 '[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}')
checkdns3=$(curl -s --connect-timeout 5 "https://dns.google/resolve?name=${NAME}&type=A" | grep -E -o '([0-9]{1,3}\.){3}[0-9]{1,3}' | head -1)
checkdns4=$(curl -s --connect-timeout 5 -H 'accept: application/dns-json' "https://cloudflare-dns.com/dns-query?name=${NAME}&type=A" | grep -E -o '([0-9]{1,3}\.){3}[0-9]{1,3}' | head -1)

# KIỂM TRA ĐỐI CHIẾU IP AN TOÀN (Ngăn lỗi chuỗi rỗng)
for resolved_ip in "$checkdns" "$checkdns2" "$checkdns3" "$checkdns4"; do
  if [[ -n "$resolved_ip" ]] && echo "$server_ips" | grep -q "\b$resolved_ip\b"; then
    error_ssl_ipv4="0"
    break
  fi
done

# Kiểm tra IPv6 (Chỉ kiểm tra nếu Litespeed đang cấu hình lắng nghe IPv6)
if grep -q 'address.*\[ANY\]' /usr/local/lsws/conf/httpd_config.conf 2>/dev/null; then
  server_ipv6=$(curl -s --connect-timeout 5 https://ipv6.icanhazip.com 2>/dev/null)
  checkdns_v6=$(host "$NAME" 2>/dev/null | grep IPv6 | grep -Eio '([0-9a-fA-F]{1,4}:){7}[0-9a-fA-F]{1,4}|...' | head -1)

  if [[ -n "$checkdns_v6" && -n "$server_ipv6" ]] && echo "$server_ipv6" | grep -qiw "$checkdns_v6"; then
    error_ssl_ipv6="0"
  fi
fi

# XỬ LÝ NẾU TÊN MIỀN CHƯA TRỎ IP HOẶC ĐANG BẬT PROXY CLOUDFLARE
if [[ "$error_ssl_ipv4" == "1" && "$error_ssl_ipv6" == "1" ]]; then
  _runloi "Kiểm tra phân giải DNS thất bại"

  # Kiểm tra nhanh có phải đang cắm qua proxy Cloudflare hay không
  TRACE_OUTPUT=$(curl -Is --connect-timeout 5 --max-time 10 "https://$NAME/cdn-cgi/trace" 2>/dev/null)
  if echo "$TRACE_OUTPUT" | grep -qi 'cloudflare\|cf-ray'; then
    echo -e "\n${C_YELLOW}PHÁT HIỆN TÊN MIỀN ĐANG BẬT PROXY CLOUDFLARE (ĐÁM MÂY CAM) ☁️${C_RESET}"
    echo -e "Khi bạn đã bật Đám mây Cam trên Cloudflare, website đã được bảo vệ bằng chứng chỉ của CF."
    echo -e "Bạn ${C_RED}KHÔNG CẦN${C_RESET} và ${C_RED}KHÔNG THỂ${C_RESET} cài đặt chứng chỉ SSL Let's Encrypt qua Webroot lúc này."

    check_website_cdn_cloudflare_online=$(curl -Is --connect-timeout 5 --max-time 10 "https://$NAME" | head -1 | grep '200' || curl -Is --connect-timeout 5 --max-time 10 "https://www.$NAME" | head -1 | grep '200')
    if [[ -n "$check_website_cdn_cloudflare_online" ]]; then
      echo -e "${C_GREEN}Trạng thái: Website của bạn vẫn đang hoạt động HTTPS bình thường.${C_RESET}"
    else
      echo -e "${C_RED}Trạng thái: Website đang bị gián đoạn HTTPS.${C_RESET}"
      echo -e "Cách khắc phục: Truy cập Cloudflare Dashboard ➜ SSL/TLS ➜ Overview ➜ Đổi sang chế độ ${C_BOLD_WHITE}Full${C_RESET} hoặc ${C_BOLD_WHITE}Flexible${C_RESET}."
    fi
    sleep 5
    exec /etc/wptt/wptt-ssl-main 1
  fi

  # Báo lỗi tên miền không tồn tại hoặc trỏ sai IP (Trường hợp beta2 của sếp)
  echo -e "\n${C_RED}❌ LỖI: TÊN MIỀN CHƯA ĐƯỢC TRỎ IP VỀ MÁY CHỦ!${C_RESET}"
  echo -e "Tên miền ${C_YELLOW}$NAME${C_RESET} hiện đang trỏ tới: ${C_YELLOW}${checkdns:-Không xác định (Name or service not known)}${C_RESET}"
  echo -e "Vui lòng truy cập trang quản lý Tên miền, trỏ bản ghi A về IP máy chủ hiện tại: ${C_GREEN}$public_ip${C_RESET}"
  echo -e "Sau khi lưu DNS, hãy chờ vài phút và thử cài lại SSL."
  echo -en "\n${C_CYAN}Nhấn phím [Enter] để quay lại Menu...${C_RESET}"
  read -r dummy
  exec /etc/wptt/wptt-ssl-main 1
fi
_rundone "Kiểm tra DNS thành công (IP khớp với máy chủ)"

# ==============================================================================
# KIỂM TRA CHỨNG CHỈ TỒN TẠI VÀ THU HỒI
# ==============================================================================
rm -f "/tmp/ssl-$NAME.txt"

if [[ -f "/etc/letsencrypt/live/$NAME/cert.pem" ]]; then
  echo -e "\n${C_YELLOW}Hệ thống phát hiện chứng chỉ SSL cho $NAME đã tồn tại!${C_RESET}"
  if wptt_xac_nhan "Bạn có muốn GIA HẠN/MỞ RỘNG chứng chỉ SSL này không?" "" "" "Đồng ý Mở rộng" "Hủy bỏ"; then
    . /etc/wptt/ssl/wptt-mo-rong-ssl-free "$NAME"
  else
    exec /etc/wptt/wptt-ssl-main 1
  fi
fi

if [[ -f "/etc/letsencrypt/live/$NAME-0001/cert.pem" ]]; then
  echo -e "\n${C_YELLOW}Phát hiện chứng chỉ cấp phát trùng lặp ($NAME-0001).${C_RESET}"
  if wptt_xac_nhan "Bạn có muốn XÓA chứng chỉ cũ và làm sạch hệ thống không?" "" "" "Đồng ý Xóa" "Hủy bỏ"; then
    _runing "Đang thu hồi và xóa chứng chỉ cũ..."
    certbot revoke --cert-path "/etc/letsencrypt/live/$NAME-0001/cert.pem" >/dev/null 2>&1
    rm -rf "/etc/letsencrypt/live/$NAME-0001"
    _rundone "Đã dọn dẹp chứng chỉ trùng lặp"
  else
    exec /etc/wptt/wptt-ssl-main 1
  fi
fi

# ==============================================================================
# TIẾN HÀNH CERTBOT VÀ CẤU HÌNH LITESPEED
# ==============================================================================
_runing "Đang liên hệ với Let's Encrypt và cấp phát chứng chỉ..."

echo "$NAME" >>"/tmp/ssl-$NAME.txt"
if [[ -f "/usr/local/lsws/$NAME/html/wp-config.php" ]] && grep -q 'MULTISITE' "/usr/local/lsws/$NAME/html/wp-config.php"; then
  wp site list --field=url --path="/usr/local/lsws/$NAME/html" --allow-root 2>/dev/null | cut -f3 -d '/' | sort -u | uniq >>"/tmp/ssl-$NAME.txt"
fi

if [[ "$checkdns" == "$checkdnscname" || -n "$checkdnscname" ]]; then
  if ! host "www.$NAME" 2>/dev/null | grep -q 'SERVFAIL'; then
    echo "www.$NAME" >>"/tmp/ssl-$NAME.txt"
  fi
fi

list_ssl_domain_all=$(cat "/tmp/ssl-$NAME.txt" | sort -u | uniq | sed '/^$/d' | sed 's/^/-d /g' | tr -s '\n' ' ')
duong_dan_docroot_web=$(cat "/usr/local/lsws/conf/vhosts/$NAME/$NAME.conf" | grep 'docRoot' | awk '{print $2}' | head -1)

# LỆNH THỰC THI CERTBOT
certbot certonly --non-interactive --agree-tos --register-unsafely-without-email --expand --webroot -w "${duong_dan_docroot_web}" $list_ssl_domain_all >/dev/null 2>&1

# Sửa file Vhost (Bóc tách SSL cũ tự ký và đè SSL thật)
if [[ -f "/usr/local/lsws/conf/vhosts/$NAME/$NAME.conf" ]]; then
  sed -i -e '/^vhssl /,/^}$/d' "/usr/local/lsws/conf/vhosts/$NAME/$NAME.conf"
  echo "vhssl  {
  keyFile                 /etc/letsencrypt/live/$NAME/privkey.pem
  certFile                /etc/letsencrypt/live/$NAME/cert.pem
  certChain               0
  CACertFile              /etc/letsencrypt/live/$NAME/chain.pem
  sslProtocol             24
  renegProtection         1
  sslSessionCache         1
  sslSessionTickets       1
  enableSpdy              15
  enableQuic              1
}" >>"/usr/local/lsws/conf/vhosts/$NAME/$NAME.conf"
fi

# Fix Web chính
if [[ "$NAME" == "$Website_chinh" && -f "/usr/local/lsws/conf/httpd_config.conf" ]]; then
  sed -i "/keyFile/d" /usr/local/lsws/conf/httpd_config.conf
  sed -i "/certFile/d" /usr/local/lsws/conf/httpd_config.conf
  sed -i "/CACertFile/d" /usr/local/lsws/conf/httpd_config.conf

  sed -i "/https/a   keyFile                \/etc\/letsencrypt\/live\/${NAME}\/privkey.pem" /usr/local/lsws/conf/httpd_config.conf
  sed -i "/https/a   certFile               \/etc\/letsencrypt\/live\/${NAME}\/cert.pem" /usr/local/lsws/conf/httpd_config.conf
  sed -i "/https/a   CACertFile             \/etc\/letsencrypt\/live\/${NAME}\/chain.pem" /usr/local/lsws/conf/httpd_config.conf
fi

/usr/local/lsws/bin/lswsctrl restart >/dev/null 2>&1

if [[ -d "/etc/letsencrypt/live/www.$NAME" ]]; then
  ln -sf "/etc/letsencrypt/live/www.$NAME" "/etc/letsencrypt/live/$NAME"
fi

# ==============================================================================
# KIỂM TRA THÀNH CÔNG VÀ BÁO CÁO LỖI (TÍCH HỢP BẢNG RATE LIMIT)
# ==============================================================================
http_status=$(curl -o /dev/null -s -w "%{http_code}" "https://${NAME}" 2>/dev/null)

if [[ ! -f "/etc/letsencrypt/live/$NAME/cert.pem" || ("$http_status" -ne 200 && "$http_status" -ne 301 && "$http_status" -ne 404) ]]; then
  _runloi "Cấp phát chứng chỉ thất bại"
  echo -e "${C_RED}Lỗi: Quá trình cài đặt SSL Let's Encrypt không thành công!${C_RESET}"

  if [[ -f "/etc/letsencrypt/live/$NAME/cert.pem" ]]; then
    echo "Chứng chỉ đã được tải về nhưng cấu hình Web Server không nhận diện đúng HTTPS."
  else
    LOG_FILE="/var/log/letsencrypt/letsencrypt.log"
    IS_BANNED=0

    # Quét log để tìm mã lỗi Rate Limit
    LIMIT_MSG=$(tail -n 500 "$LOG_FILE" 2>/dev/null | grep -E -i "rateLimited|too many certificates" | tail -n 1)

    if [[ -n "$LIMIT_MSG" ]]; then
      IS_BANNED=1

      if echo "$LIMIT_MSG" | grep -qi "too many certificates already issued"; then
        BAN_REASON="Cài trùng lặp quá nhiều (Giới hạn 5 lần / tuần)."
        WAIT_TIME="Vui lòng chờ hệ thống mở khóa (Tối đa 7 ngày)."
      elif echo "$LIMIT_MSG" | grep -qi "too many failed authorizations"; then
        BAN_REASON="Xác thực lỗi quá nhiều lần (Giới hạn 5 lần / giờ)."
        WAIT_TIME="Hãy đợi đúng 1 tiếng đồng hồ nữa rồi thử lại."
      elif echo "$LIMIT_MSG" | grep -qi "Certificates per Registered Domain"; then
        BAN_REASON="Vượt giới hạn chứng chỉ tên miền (50 lần/tuần)."
        WAIT_TIME="Phải đợi Let's Encrypt reset lại quota trong tuần tới."
      else
        BAN_REASON="Vi phạm chính sách chống Spam API của Let's Encrypt."
        WAIT_TIME="Vui lòng thử lại sau vài giờ hoặc vài ngày."
      fi

      echo -e "\n${C_RED}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
      center_text "${C_BOLD_WHITE}TỪ CHỐI CẤP PHÁT: TÊN MIỀN BỊ KHÓA SSL TẠM THỜI${C_RESET}"
      echo -e "${C_RED}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
      left_text "  Tên miền bị chặn : ${C_YELLOW}$NAME${C_RESET}" 2
      left_text "  Nguyên nhân      : ${C_BOLD_WHITE}$BAN_REASON${C_RESET}" 2
      left_text "  Cách xử lý       : ${C_GREEN}$WAIT_TIME${C_RESET}" 2
      echo -e "${C_RED}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
      left_text " ${C_YELLOW}GIẢI THÍCH & LỜI KHUYÊN TỪ HỆ THỐNG:${C_RESET}" 2
      left_text " - Let's Encrypt giới hạn số lần tạo SSL để chống lạm dụng tài nguyên." 2
      left_text " - Hệ thống ghi nhận tên miền này đã chạm ngưỡng giới hạn (do thử" 2
      left_text "   cài lại quá nhiều lần hoặc xác thực thất bại liên tục)." 2
      left_text " - ${C_RED}KHÔNG thử cài lại ngay lúc này${C_RESET} để tránh bị khóa lâu hơn." 2
      echo -e "${C_RED}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

      [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-ssl-main 1
      return 1 2>/dev/null || exit 1
    fi

    # Lựa chọn xem file log nếu lỗi không phải do Rate Limit
    echo -e "\nBạn có thể kiểm tra chi tiết nguyên nhân lỗi tại file log: ${C_YELLOW}$LOG_FILE${C_RESET}"
    if wptt_xac_nhan "Bạn có muốn xem toàn bộ nội dung letsencrypt.log không?" "Mở trình đọc Log chuyên sâu để tự dò lỗi." "" "Đồng ý (xem log)" "Không đồng ý (Hủy thao tác)"; then
      echo -e "${C_GREEN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
      center_text "${C_BOLD_WHITE}HƯỚNG DẪN SỬ DỤNG TRÌNH ĐỌC LOG (LESS)${C_RESET}"
      echo -e "${C_GREEN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
      left_text "File đang xem : ${C_YELLOW}$LOG_FILE${C_RESET}" 2
      echo -e "${C_GREEN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
      left_text " ⬇️ ⬆️  Nhấn phím mũi tên [Lên/Xuống] để cuộn từng dòng." 2
      left_text " ␣    Nhấn phím [Space] để cuộn nhanh từng trang." 2
      left_text " 🔍   Nhấn phím [/] và nhập từ khóa để TÌM KIẾM (Bấm 'n' tìm tiếp)." 2
      left_text " ❌   ${C_RED}Nhấn phím [q] để THOÁT${C_RESET} và quay lại Menu." 2
      echo -e "${C_GREEN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

      echo -e "${C_CYAN}Đang chuẩn bị dữ liệu và mở trình đọc log...${C_RESET}"
      sleep 3
      clear
      less +G "$LOG_FILE"
    fi
  fi

  # Auto fix bug 0001
  if [[ -f "/etc/letsencrypt/live/$NAME-0001/cert.pem" && ! -f "/etc/letsencrypt/live/$NAME/cert.pem" ]]; then
    _runing "Đang nỗ lực sửa lỗi liên kết SSL (-0001)..."
    sed -i "s:/etc/letsencrypt/live/$NAME:/etc/letsencrypt/live/$NAME-0001:g" "/usr/local/lsws/conf/vhosts/$NAME/$NAME.conf"
    /usr/local/lsws/bin/lswsctrl restart >/dev/null 2>&1
    _rundone "Đã khôi phục liên kết chứng chỉ"
  fi
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-ssl-main 1
  return 1 2>/dev/null || exit 1
else
  _rundone "Cấp phát chứng chỉ Let's Encrypt thành công"
fi

# Cấu hình Redirect HTTPS
_runing "Cấu hình Redirect HTTP ➜ HTTPS"
(/etc/wptt/ssl/wptt-renew-chuyen-huong "$NAME" >/dev/null 2>&1)
_rundone "Cấu hình Redirect HTTP ➜ HTTPS"

# ==============================================================================
# BẢNG BÁO CÁO KẾT QUẢ THÀNH CÔNG
# ==============================================================================
echo -e "\n${C_GREEN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_BOLD_WHITE}CÀI ĐẶT SSL LET'S ENCRYPT THÀNH CÔNG${C_RESET}"
echo -e "${C_GREEN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
left_text "  Website được bảo vệ : ${C_YELLOW}https://$NAME${C_RESET}" 2
left_text "  Trạng thái ổ khóa   : ${C_GREEN}An toàn (Valid Certificate)${C_RESET}" 2
left_text "  Chuyển hướng (301)  : Đã BẬT (HTTP ➜ HTTPS)" 2
if [[ -n "$chuyenhuongwww" ]]; then
  left_text "  Kèm Subdomain       : Đã tích hợp www.$NAME" 2
fi
left_text "  Ngày hết hạn SSL    : WPTangToc OLS sẽ tự động gia hạn vĩnh viễn" 2
echo -e "${C_GREEN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

/usr/local/lsws/bin/lswsctrl restart >/dev/null 2>&1

# Fix CSF Firewall mở Port 443
if [[ -f /etc/csf/csf.conf ]]; then
  if ! grep '^TCP_IN' /etc/csf/csf.conf | grep -q "443"; then
    sed -i 's/^TCP_IN = "/TCP_IN = "443,/g' /etc/csf/csf.conf
    csf -x >/dev/null 2>&1
    csf -e >/dev/null 2>&1
  fi
fi

if [[ "${1:-}" == "98" ]]; then
  exec /etc/wptt/wptt-ssl-main 1
fi
