function huong_dan() {
  Tính năng Xóa SSL Lets Encrypt là quá trình gỡ bỏ một chứng chỉ SSL/TLS của Lets Encrypt đã được cài đặt cho một tên miền [website] cụ thể khỏi máy chủ web. Đồng thời, việc này thường bao gồm cả việc vô hiệu hóa cấu hình HTTPS liên quan đến chứng chỉ đó và có thể dừng tiến trình tự động gia hạn cho chứng chỉ này.

  Nói một cách đơn giản, đây là hành động gỡ bỏ ổ khóa 🔒 Lets Encrypt khỏi website của bạn, khiến website đó không còn sử dụng kết nối mã hóa HTTPS thông qua chứng chỉ Lets Encrypt đó nữa.

  Mục Đích Chính
  * Khi ngừng sử dụng website/tên miền: Nếu website không còn hoạt động, chứng chỉ SSL của nó cũng không còn cần thiết.
  * Chuyển sang loại chứng chỉ SSL khác: Khi bạn muốn sử dụng chứng chỉ từ một nhà cung cấp khác [ví dụ: chứng chỉ trả phí có xác thực tổ chức - OV, hoặc xác thực mở rộng - EV].
  * Gỡ lỗi sự cố SSL phức tạp: Trong một số trường hợp, việc xóa và cài đặt lại có thể là một bước để khắc phục sự cố.
  * Cấu hình lại máy chủ: Khi có những thay đổi lớn về cấu hình máy chủ hoặc chuyển đổi máy chủ.
  * Ngừng gia hạn tự động cho một tên miền cụ thể: Nếu bạn không muốn tên miền đó tiếp tục sử dụng HTTPS với Lets Encrypt.

  Sau khi xóa, website sẽ không còn phục vụ qua HTTPS bằng chứng chỉ Lets Encrypt đó nữa. Nếu không có chứng chỉ nào khác được cấu hình, truy cập HTTPS sẽ thất bại, và website có thể chỉ truy cập được qua HTTP [không mã hóa].
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null # Nạp thư viện UI Xác nhận

clear
echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}${quan_ly_ssl} ➜ ${xoa_chung_chi_ssl_letencrypt}${C_RESET}"
echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

function lua_chon_NAME() {
  unset NAME selects
  selects=()
  local box_inner_width=${box_inner_width:-71}

  # Quét Vhost Thường
  for filepath in /etc/wptt/vhost/.*.conf; do
    [[ ! -f "$filepath" || "$filepath" == *"/..conf" ]] && continue
    local domain="${filepath##*/}"
    domain="${domain%.conf}"
    domain="${domain#.}"
    if [[ "$domain" == ?*.?* ]]; then
      if [[ -f "/etc/letsencrypt/live/$domain/cert.pem" || -f "/etc/letsencrypt/live/www.${domain}/cert.pem" ]]; then
        selects+=("$domain")
      fi
    fi
  done

  # Quét Domain Chuyển hướng
  if [[ -d "/etc/wptt/chuyen-huong" ]]; then
    for filepath in /etc/wptt/chuyen-huong/.*.conf; do
      [[ ! -f "$filepath" || "$filepath" == *"/..conf" ]] && continue
      local domain="${filepath##*/}"
      domain="${domain%.conf}"
      domain="${domain#.}"
      if [[ "$domain" == ?*.?* ]]; then
        if [[ -f "/etc/letsencrypt/live/$domain/cert.pem" || -f "/etc/letsencrypt/live/www.${domain}/cert.pem" ]]; then
          selects+=("$domain")
        fi
      fi
    done
  fi

  # Lọc trùng lặp
  if [[ ${#selects[@]} -gt 0 ]]; then
    mapfile -t selects < <(printf "%s\n" "${selects[@]}" | sort -uV)
  else
    echo -e "${C_YELLOW}⚠️ Không có website nào trên hệ thống đang cài đặt SSL Let's Encrypt!${C_RESET}"
    sleep 3
    exec /etc/wptt/wptt-ssl-main 1
  fi

  # Render Menu Bo Cong
  echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
  local title_text="${lua_chon_website_ban_muon:-Lựa chọn Website} bạn muốn gỡ bỏ SSL:"
  local len=$(echo -n "$title_text" | awk '{print length($0)}')
  local pad_r=$((box_inner_width - len - 2))
  [[ $pad_r -lt 0 ]] && pad_r=0
  echo -e "${C_CYAN}│${C_RESET}  ${C_YELLOW}${title_text}${C_RESET}$(printf '%*s' "$pad_r" "")${C_CYAN}│${C_RESET}"

  local line_len=$((len + 3))
  local pad_line_r=$((box_inner_width - line_len))
  [[ $pad_line_r -lt 0 ]] && pad_line_r=0
  local short_line=$(printf "%${line_len}s" "" | sed 's/ /─/g')
  echo -e "${C_CYAN}├${short_line}$(printf '%*s' "$pad_line_r" "")│${C_RESET}"

  local i=1
  for dom in "${selects[@]}"; do
    local item_text=$(printf "  ${C_CYAN}%3d)${C_RESET} ${C_BOLD_WHITE}%-30s${C_RESET} ${C_GREEN}[Có SSL]${C_RESET}" "$i" "$dom")
    local clean_text=$(printf "  %3d) %-30s [Có SSL]" "$i" "$dom")
    local item_len=$(echo -n "$clean_text" | awk '{print length($0)}')
    local pad=$((box_inner_width - item_len))
    [[ $pad -lt 0 ]] && pad=0
    echo -e "${C_CYAN}│${C_RESET}${item_text}$(printf '%*s' "$pad" "")${C_CYAN}│${C_RESET}"
    ((i++))
  done
  echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯${C_RESET}"

  local fzf_installed=false
  if command -v fzf &>/dev/null; then
    fzf_installed=true
    PROMPT_TEXT="Nhập lựa chọn (1-${#selects[@]}) [00=Tìm nhanh] [0=Thoát]: "
  else
    PROMPT_TEXT="Nhập lựa chọn (1-${#selects[@]}) [0=Thoát]: "
  fi

  while true; do
    echo -en "${C_CYAN}👉 ${PROMPT_TEXT}${C_RESET}"
    if ! read -r REPLY; then exit 1; fi
    REPLY=$(echo "$REPLY" | tr -d ' ' | tr '[:upper:]' '[:lower:]')

    case "$REPLY" in
    0)
      echo -e "\n${C_GREEN}Đang thoát...${C_RESET}"
      NAME="0"
      return 0
      ;;
    00)
      if $fzf_installed; then
        local selected_item=$(printf '%s\n' "${selects[@]}" | nl -w 3 -s ': ' | fzf --prompt="Tìm website xóa SSL >> " --height=40% --border=rounded --color=border:red --cycle --reverse)
        local dom=$(echo "$selected_item" | sed 's/^[[:space:]]*[0-9]\+\:[[:space:]]*//' | cut -d'|' -f1)
        if [[ -n "$dom" ]]; then
          NAME="$dom"
          return 0
        else echo -e "${C_YELLOW}Đã hủy chọn. Vui lòng chọn lại.${C_RESET}"; fi
      else
        echo -e "${C_RED}Lỗi: FZF chưa cài đặt.${C_RESET}"
      fi
      ;;
    *)
      if [[ "$REPLY" =~ ^[0-9]+$ ]] && [ "$REPLY" -ge 1 ] && [ "$REPLY" -le ${#selects[@]} ]; then
        local action_index=$((REPLY - 1))
        NAME=$(echo "${selects[$action_index]}" | cut -d'|' -f1)
        return 0
      else
        echo -e "\n${C_RED}❌ Lựa chọn không hợp lệ! Vui lòng chọn lại.${C_RESET}"
      fi
      ;;
    esac
  done
}

lua_chon_NAME

# --- CHỐT CHẶN THOÁT HIỂM ---
[[ "$NAME" == "0" || -z "$NAME" ]] && exec /etc/wptt/wptt-ssl-main 1

CLEAN="$NAME"

# ==============================================================================
# KIỂM TRA MÔI TRƯỜNG VÀ XÁC NHẬN
# ==============================================================================
pathcheck="/etc/wptt/vhost/.$NAME.conf"
[[ ! -f "$pathcheck" && ! -f "/etc/wptt/chuyen-huong/.$NAME.conf" ]] && {
  echo -e "\n${C_RED}❌ Tên miền không tồn tại trên hệ thống này!${C_RESET}"
  sleep 2
  exec /etc/wptt/wptt-ssl-main 1
}

check_ssl="/etc/letsencrypt/live/$NAME/cert.pem"
if [[ ! -f "$check_ssl" && ! -f "/etc/letsencrypt/live/www.${NAME}/cert.pem" ]]; then
  echo -e "\n${C_RED}❌ Website $NAME hiện không có chứng chỉ SSL Let's Encrypt nào để xóa.${C_RESET}"
  sleep 3
  exec /etc/wptt/wptt-ssl-main 1
fi

echo ""
extra_msg=""
if [[ "$NAME" == "$Website_chinh" ]]; then
  extra_msg="${C_YELLOW}(Lưu ý: Đây là Website Chính, hệ thống sẽ cấp lại chứng chỉ Tự ký để OLS không bị lỗi)${C_RESET}"
fi

if wptt_xac_nhan "Bạn có chắc chắn muốn XÓA chứng chỉ SSL của website này?" "${C_BOLD_WHITE}Thu hồi chứng chỉ ssl letsencrypt Website:${C_RESET} ${C_YELLOW}$NAME${C_RESET}" "" "Đồng ý Xóa" "Hủy bỏ"; then
  echo ""
  _runing "Thu hồi chứng chỉ (Revoke) và xóa file ssl..."

  # Fix sập OLS nếu xoá SSL của Website Chính
  if [[ "$NAME" == "$Website_chinh" ]]; then
    mkdir -p "/etc/wptt-ssl-tu-ky/$NAME"
    cd "/etc/wptt-ssl-tu-ky/$NAME" || exit
    openssl req -new -newkey rsa:2048 -nodes -keyout "$NAME.key" -out "$NAME.csr" -subj "/C=VN/ST=Hanoi/L=Hanoi/O=WPTangToc OLS/OU=IT Department/CN=$NAME/emailAddress=admin@example.com" >/dev/null 2>&1
    openssl x509 -req -in "$NAME.csr" -signkey "$NAME.key" -out "cert.crt" -days 3650 >/dev/null 2>&1

    if [[ -f "/usr/local/lsws/conf/httpd_config.conf" ]]; then
      sed -i "/keyFile/d" /usr/local/lsws/conf/httpd_config.conf
      sed -i "/certFile/d" /usr/local/lsws/conf/httpd_config.conf
      sed -i "/CACertFile/d" /usr/local/lsws/conf/httpd_config.conf
      sed -i "/https/a    keyFile                \/etc\/wptt-ssl-tu-ky\/$NAME\/$NAME.key" /usr/local/lsws/conf/httpd_config.conf
      sed -i "/https/a    certFile               \/etc\/wptt-ssl-tu-ky\/$NAME\/cert.crt" /usr/local/lsws/conf/httpd_config.conf
    fi
  fi

  # Revoke & Delete non-www
  if [[ -f "$check_ssl" ]]; then
    certbot revoke --non-interactive --agree-tos --cert-path "$check_ssl" >/dev/null 2>&1
    if wptt_kha_dung_de_xoa_xac_thuc "$CLEAN"; then
      rm -rf "/etc/letsencrypt/live/${CLEAN}"
      rm -f "/etc/letsencrypt/renewal/${CLEAN}.conf"
      rm -rf "/etc/letsencrypt/archive/${CLEAN}"
    fi
  fi

  # Revoke & Delete www
  if [[ -f "/etc/letsencrypt/live/www.${CLEAN}/cert.pem" ]]; then
    certbot revoke --non-interactive --agree-tos --cert-path "/etc/letsencrypt/live/www.${CLEAN}/cert.pem" >/dev/null 2>&1
    if wptt_kha_dung_de_xoa_xac_thuc "${CLEAN}"; then
      rm -rf "/etc/letsencrypt/live/www.${CLEAN}"
      rm -f "/etc/letsencrypt/renewal/www.${CLEAN}.conf"
      rm -rf "/etc/letsencrypt/archive/www.${CLEAN}"
    fi
  fi
  _rundone "Thu hồi chứng chỉ (Revoke) và xóa file ssl..."

  # Xóa luật Htaccess
  _runing "Đang gỡ bỏ luật chuyển hướng HTTPS trong file .htaccess..."
  path2="/usr/local/lsws/$CLEAN/html/.htaccess"
  if [[ -f "$path2" ]]; then
    sed -i -e '/^#begin-chuyen-huong-http-to-https-wptangtoc-ols/,/^#end-chuyen-huong-http-to-https-wptangtoc-ols$/d' "$path2"
    sed -i -e '/^#begin-chuyen-huong-www-to-non-www-wptangtoc-ols/,/^#end-chuyen-huong-www-to-non-www-wptangtoc-ols$/d' "$path2"
    sed -i -e '/^#begin-chuyen-huong-non-www-to-www-wptangtoc-ols/,/^#end-chuyen-huong-non-www-to-www-wptangtoc-ols$/d' "$path2"
  fi
  _rundone "Đang gỡ bỏ luật chuyển hướng HTTPS trong file .htaccess..."

  /usr/local/lsws/bin/lswsctrl restart >/dev/null 2>&1
  echo "Xóa SSL free letsencrypt website $NAME: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log

  # ==============================================================================
  # BẢNG BÁO CÁO THÀNH CÔNG (UX BO CONG)
  # ==============================================================================
  echo -e "\n${C_GREEN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_BOLD_WHITE}HOÀN TẤT GỠ BỎ CHỨNG CHỈ SSL${C_RESET}"
  echo -e "${C_GREEN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
  left_text "Website        : ${C_YELLOW}$NAME${C_RESET}"
  left_text "Trạng thái mới : Đã thu hồi chứng chỉ và xóa cấu hình HTTPs."
  echo -e "${C_GREEN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

else
  echo -e "${C_YELLOW}Đã hủy thao tác xóa SSL.${C_RESET}"
fi

[[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-ssl-main 1
