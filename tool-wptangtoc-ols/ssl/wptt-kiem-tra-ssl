function huong_dan() {
  Tính năng Kiểm tra chứng chỉ SSL website là khả năng xem xét và xác minh các thông tin chi tiết của chứng chỉ SSL/TLS mà một trang web đang sử dụng để thiết lập kết nối HTTPS an toàn. Điều này giúp bạn đánh giá tính hợp lệ và độ tin cậy của kết nối đó.

  Nói một cách đơn giản, đây là cách bạn soi xem giấy phép bảo mật [chứng chỉ SSL] của một website có những thông tin gì, có còn hạn hay không, và do ai cấp.

  Mục Đích Chính
  * Xác minh danh tính website: Đảm bảo bạn đang kết nối đúng với website mình muốn, không phải trang giả mạo.
  * Kiểm tra thời hạn chứng chỉ: Xem ngày cấp và quan trọng nhất là ngày hết hạn để biết chứng chỉ có còn hiệu lực không.
  * Biết được đơn vị cấp [CA]: Xem tổ chức nào đã cấp chứng chỉ [ví dụ: Lets Encrypt, DigiCert, Sectigo].
  * Gỡ lỗi sự cố HTTPS: Khi website báo lỗi kết nối SSL [ví dụ: trình duyệt cảnh báo không an toàn], việc kiểm tra chứng chỉ giúp tìm ra nguyên nhân.
  * Đánh giá mức độ bảo mật: Xem các thông tin kỹ thuật của chứng chỉ như thuật toán chữ ký, độ dài khóa.
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null # Nạp thư viện UI

NAME=$1
if [[ "$1" == "98" ]]; then
  WPTT_IN_MENU="yes"
  WPTT_MENU_BACK="/etc/wptt/wptt-ssl-main 1"
  NAME=""
fi

clear

NAME=$1
[[ $NAME == "98" ]] && NAME=""

if [[ -z "$NAME" ]]; then
  echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_YELLOW}${quan_ly_ssl} ➜ Kiểm tra tình trạng Chứng chỉ SSL${C_RESET}"
  echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"
  . /etc/wptt/tenmien-them-lua-chon-tat-ca-website
  lua_chon_NAME "Kiểm tra tình trạng Chứng chỉ SSL"
fi

[[ "$NAME" == "0" || -z "$NAME" ]] && {
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-ssl-main 1
  return 2>/dev/null || exit
}

if [[ "$NAME" == 'Tất cả website' ]]; then
  echo ""
  _runing "Đang quét trạng thái SSL trên toàn bộ hệ thống..."

  echo -e "\n${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_YELLOW}BẢNG TRẠNG THÁI SSL TOÀN HỆ THỐNG${C_RESET}"
  echo -e "${C_CYAN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"

  if [ "$(ls -A /etc/wptt/vhost 2>/dev/null)" ]; then
    for entry in $(ls -A /etc/wptt/vhost | grep -v '^\.\.conf$' | sort -uV); do
      domain=$(echo "$entry" | sed 's/^.//' | sed 's/.conf//')
      path_html="/usr/local/lsws/$domain/html"

      if [[ "$domain" == ?*.?* && -d "$path_html" ]]; then
        unset ssl_xac_thuc_kha_dung
        # Chạy ngầm kịch bản check SSL để lấy biến kết quả
        . /etc/wptt/ssl/check-ssl-cert-con-kha-dung "$domain" >/dev/null 2>&1

        domain_padded=$(printf "%-30s" "$domain")
        if [[ "$ssl_xac_thuc_kha_dung" == 'true' ]]; then
          left_text "▪ ${C_BOLD_WHITE}${domain_padded}${C_RESET} : ${C_GREEN}Khả dụng${C_RESET}" 2
        else
          left_text "▪ ${C_BOLD_WHITE}${domain_padded}${C_RESET} : ${C_RED}Lỗi / Hết hạn${C_RESET}" 2
        fi
      fi
    done
  fi

  echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

  echo -en "${C_GREEN}Nhấn phím [Enter] để quay lại Menu...${C_RESET}"
  read -r dummy
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-ssl-main 1
  exit 0
fi

# ==============================================================================
# NHÁNH 2: QUÉT 1 WEBSITE CỤ THỂ
# ==============================================================================
pathcheck="/etc/wptt/vhost/.$NAME.conf"
if [[ ! -f "$pathcheck" ]]; then
  echo -e "\n${C_RED}❌ Tên miền không tồn tại trên hệ thống này!${C_RESET}"
  sleep 3
  exec /etc/wptt/wptt-ssl-main 1
fi

echo ""
_runing "Đang truy xuất thông tin chứng chỉ SSL cho $NAME..."
unset ssl_xac_thuc_kha_dung

# Cho phép kịch bản check in ra các thông số chi tiết (Nếu có)
. /etc/wptt/ssl/check-ssl-cert-con-kha-dung "$NAME"

_rundone "Kiểm tra hoàn tất"

echo -e "\n${C_GREEN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_BOLD_WHITE}KẾT QUẢ KIỂM TRA CHỨNG CHỈ SSL${C_RESET}"
echo -e "${C_GREEN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
left_text "Website kiểm tra : ${C_YELLOW}$NAME${C_RESET}" 2

if [[ "$ssl_xac_thuc_kha_dung" == 'true' ]]; then
  left_text "Trạng thái chung : ${C_GREEN}Chứng chỉ đang Khả dụng và Hợp lệ${C_RESET}" 2
else
  left_text "Trạng thái chung : ${C_RED}❌ Chứng chỉ Không Khả dụng, Hết hạn hoặc Lỗi${C_RESET}" 2
fi
echo -e "${C_GREEN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

echo -en "${C_GREEN}Nhấn phím [Enter] để quay lại Menu...${C_RESET}"
read -r dummy

[[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-ssl-main 1
