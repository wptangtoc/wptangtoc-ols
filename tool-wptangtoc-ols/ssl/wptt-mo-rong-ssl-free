#!/bin/bash
# @author: Gia Tuấn
# @website: https://wptangtoc.com
# @since: 2025

function huong_dan() {
  WPTangToc OLS có khả năng mở rộng SSL Lets Encrypt.

  Về cơ bản, tính năng này cho phép bạn:

  Cài đặt SSL letsencrypt mở rộng kết hợp chứng chỉ của bạn trước sẵn có.
  Giải thích: ví dụ bạn có domain là wptangtoc.com đã được cài chứng chỉ ssl letsencrypt trước đó giờ bạn muốn mở rộng thêm chứng chỉ sub.wptangtoc.com một chứng chỉ có thể hỗ trợ đồng thời cho 2 domain trở lên tận chí là nhiều hơn bạn muốn.

  Tóm lại: một chứng chỉ ssl chỉ dành cho một domain như thông lệ mà tính năng này giúp một chứng chỉ có thể dùng chung cho nhiều domain

  Mục đich tính năng mở rộng SSL Lets Encrypt trong WPTangToc OLS giúp người dùng dễ dàng triển khai và duy trì mã hóa HTTPS cho website của mình một cách tự động và miễn phí, góp phần tăng cường bảo mật và sự tin cậy cho trang web.

  Tính năng này rất hữu ích với anh em sử dụng multisite subdomain
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null

clear
echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}${quan_ly_ssl} ➜ Mở rộng Chứng chỉ SSL Let's Encrypt (Thêm Subdomain)${C_RESET}"
echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

NAME=$1
[[ "$NAME" == "98" ]] && NAME=""

# ==============================================================================
# HÀM MENU LỌC DOMAIN ĐANG SỬ DỤNG LET'S ENCRYPT (UX BO CONG)
# ==============================================================================
if [[ -z "$NAME" ]]; then
  function lua_chon_NAME() {
    unset NAME selects
    selects=()
    local box_inner_width=${box_inner_width:-71}

    for filepath in /etc/wptt/vhost/.*.conf; do
      [[ ! -f "$filepath" || "$filepath" == *"/..conf" ]] && continue
      local domain="${filepath##*/}"
      domain="${domain%.conf}"
      domain="${domain#.}"

      if [[ "$domain" == ?*.?* ]]; then
        # Chỉ lấy những domain ĐÃ CÓ chứng chỉ Let's Encrypt
        if [[ -f "/etc/letsencrypt/live/$domain/cert.pem" ]]; then
          selects+=("$domain")
        fi
      fi
    done

    if [[ ${#selects[@]} -eq 0 ]]; then
      echo -e "${C_YELLOW}⚠️ Không có website nào trên hệ thống đang cài SSL Let's Encrypt để mở rộng!${C_RESET}"
      sleep 3
      exec /etc/wptt/wptt-ssl-main 1
    fi

    # Render Menu
    echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
    local title_text="Lựa chọn Website bạn muốn MỞ RỘNG chứng chỉ SSL:"
    local len=$(echo -n "$title_text" | awk '{print length($0)}')
    local pad_r=$((box_inner_width - len - 2))
    [[ $pad_r -lt 0 ]] && pad_r=0
    echo -e "${C_CYAN}│${C_RESET}  ${C_YELLOW}${title_text}${C_RESET}$(printf '%*s' "$pad_r" "")${C_CYAN}│${C_RESET}"

    local line_len=$((len + 3))
    local pad_line_r=$((box_inner_width - line_len))
    [[ $pad_line_r -lt 0 ]] && pad_line_r=0
    local short_line=$(printf "%${line_len}s" "" | sed 's/ /─/g')
    echo -e "${C_CYAN}├${short_line}$(printf '%*s' "$pad_line_r" "")│${C_RESET}"

    local i=1
    for dom in "${selects[@]}"; do
      local item_text=$(printf "  ${C_CYAN}%3d)${C_RESET} ${C_BOLD_WHITE}%-30s${C_RESET} ${C_GREEN}[Có thể Mở rộng]${C_RESET}" "$i" "$dom")
      local clean_text=$(printf "  %3d) %-30s [Có thể Mở rộng]" "$i" "$dom")
      local item_len=$(echo -n "$clean_text" | awk '{print length($0)}')
      local pad=$((box_inner_width - item_len))
      [[ $pad -lt 0 ]] && pad=0
      echo -e "${C_CYAN}│${C_RESET}${item_text}$(printf '%*s' "$pad" "")${C_CYAN}│${C_RESET}"
      ((i++))
    done
    echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯${C_RESET}"

    local fzf_installed=false
    if command -v fzf &>/dev/null; then
      fzf_installed=true
      PROMPT_TEXT="Nhập lựa chọn (1-${#selects[@]}) [00=Tìm nhanh] [0=Thoát]: "
    else
      PROMPT_TEXT="Nhập lựa chọn (1-${#selects[@]}) [0=Thoát]: "
    fi

    while true; do
      echo -en "${C_CYAN}${PROMPT_TEXT}${C_RESET}"
      if ! read -r REPLY; then exit 1; fi
      REPLY=$(echo "$REPLY" | tr -d ' ' | tr '[:upper:]' '[:lower:]')

      case "$REPLY" in
      0)
        echo -e "\n${C_GREEN}Đang thoát...${C_RESET}"
        NAME="0"
        return 0
        ;;
      00)
        if $fzf_installed; then
          local selected_item=$(printf '%s\n' "${selects[@]}" | nl -w 3 -s ': ' | fzf --prompt="Tìm website mở rộng SSL >> " --height=40% --border=rounded --color=border:cyan --cycle --reverse)
          local dom=$(echo "$selected_item" | sed 's/^[[:space:]]*[0-9]\+\:[[:space:]]*//' | cut -d'|' -f1 | tr -d ' ')
          if [[ -n "$dom" ]]; then
            NAME="$dom"
            return 0
          else echo -e "${C_YELLOW}Đã hủy chọn. Vui lòng chọn lại.${C_RESET}"; fi
        else
          echo -e "${C_RED}Lỗi: FZF chưa cài đặt.${C_RESET}"
        fi
        ;;
      *)
        if [[ "$REPLY" =~ ^[0-9]+$ ]] && [ "$REPLY" -ge 1 ] && [ "$REPLY" -le ${#selects[@]} ]; then
          local action_index=$((REPLY - 1))
          NAME=$(echo "${selects[$action_index]}" | cut -d'|' -f1 | tr -d ' ')
          return 0
        else
          echo -e "\n${C_RED}❌ Lựa chọn không hợp lệ! Vui lòng chọn lại.${C_RESET}"
        fi
        ;;
      esac
    done
  }
  lua_chon_NAME
fi

[[ "$NAME" == "0" || -z "$NAME" ]] && {
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-ssl-main 1
  return 2>/dev/null || exit
}

# ==============================================================================
# KIỂM TRA MÔI TRƯỜNG & IP
# ==============================================================================
if [[ ! -d "/usr/local/lsws/$NAME/html" ]]; then
  echo -e "\n${C_RED}❌ Lỗi: Thư mục mã nguồn không tồn tại!${C_RESET}"
  sleep 3
  exec /etc/wptt/wptt-ssl-main 1
fi

if [[ ! -f "/etc/letsencrypt/live/$NAME/cert.pem" ]]; then
  echo -e "\n${C_RED}❌ Lỗi: Website $NAME chưa cài đặt chứng chỉ SSL Let's Encrypt.${C_RESET}"
  echo -e "Vui lòng sử dụng tính năng 'Cài đặt SSL Let's Encrypt' trước khi mở rộng."
  sleep 3
  exec /etc/wptt/wptt-ssl-main 1
fi

server_ips=$(ip a | grep -Eo '[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}' | sed '/127.0.0.1/d' | sed '/192.168/d' | sort -u)
public_ip=$(curl -sf --connect-timeout 5 https://ipv4.icanhazip.com || curl -sf --connect-timeout 5 https://checkip.amazonaws.com | grep -Eo '[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}')
server_ips="$server_ips $public_ip"

checkdns=$(host "$NAME" 2>/dev/null | grep -Eo -m 1 '[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}')
[[ -z "$checkdns" ]] && checkdns=$(nslookup "$NAME" 2>/dev/null | grep Address | cut -f5 | grep -Eo -m 1 '[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}')

checkdnscname=$(host "www.$NAME" 2>/dev/null | grep -Eo -m 1 '[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}')
[[ -z "$checkdnscname" ]] && checkdnscname=$(nslookup "www.$NAME" 2>/dev/null | grep Address | cut -f5 | grep -Eo -m 1 '[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}')

# Check IP Nguồn (Trừ phi dùng CF API)
if [[ ! -f "/etc/wptt/.cloudflare/wptt-$NAME.ini" ]]; then
  if [[ -n "$checkdns" ]] && ! echo "$server_ips" | grep -q "\b$checkdns\b"; then
    echo -e "\n${C_RED}❌ Lỗi: Tên miền gốc $NAME chưa trỏ về IP máy chủ hiện tại.${C_RESET}"
    echo -e "IP DNS hiện tại: ${C_YELLOW}${checkdns:-Không xác định}${C_RESET}"
    echo -e "Bạn phải trỏ chuẩn IP trước khi thực hiện mở rộng chứng chỉ."
    sleep 4
    exit 1
  fi
fi

# ==============================================================================
# LẤY DANH SÁCH SSL HIỆN TẠI VÀ THÊM MỚI
# ==============================================================================
rm -f "/tmp/ssl-$NAME.txt"

# Đọc các domain hiện có trong chứng chỉ (Gộp nhiều dòng thành 1 chuỗi bằng xargs)
ssl_actives=$(openssl x509 -in "/etc/letsencrypt/live/$NAME/cert.pem" -noout -ext subjectAltName 2>/dev/null | grep 'DNS:' | sed 's/DNS://g' | tr -d ' ' | tr ',' '\n')
for ssl_active in $ssl_actives; do
  echo "$ssl_active" >>"/tmp/ssl-$NAME.txt"
done

echo ""
echo -e "${C_GREEN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
left_text "${C_BOLD_WHITE}CHỨNG CHỈ HIỆN TẠI ĐANG BẢO VỆ CÁC TÊN MIỀN:${C_RESET}"
echo -e "${C_GREEN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
# Tự động gập dòng nếu danh sách quá dài
left_text "${C_YELLOW}$(cat "/tmp/ssl-$NAME.txt" | xargs | sed 's/ /, /g')${C_RESET}"
echo -e "${C_GREEN}╰──────────────────────────────────────────────────────────────────────────────╯${C_RESET}"
echo ""

# Vòng lặp Nhập liệu mượt mà
while true; do
  echo -en "${C_CYAN}Nhập tên Subdomain bạn muốn mở rộng (VD: cdn, shop, api) [Để trống = Xong]: ${C_RESET}"
  read -r subdomain

  if [[ -z "$subdomain" || "$subdomain" == "0" ]]; then
    break
  fi

  # Làm sạch input (tự động gắn đuôi tên miền gốc nếu người dùng chỉ nhập prefix)
  subdomain=$(echo "$subdomain" | sed "s/.$NAME//g" | sed "s/$/.$NAME/g" | sed 's#https://##g' | sed 's#http://##g')
  echo "$subdomain" >>"/tmp/ssl-$NAME.txt"
  echo -e "   ${C_GREEN}✔ Đã đưa ${C_YELLOW}$subdomain${C_GREEN} vào danh sách chờ.${C_RESET}"
done

# ==============================================================================
# TỰ ĐỘNG NẠP MULTISITE VÀ VHOST ALIASES
# ==============================================================================
_runing "Đang quét hệ thống để tìm kiếm tự động các Subdomain liên quan..."

if [[ -f "/usr/local/lsws/$NAME/html/wp-config.php" ]] && grep -q 'MULTISITE' "/usr/local/lsws/$NAME/html/wp-config.php"; then
  sub_domain_multisite=$(wp site list --field=url --path="/usr/local/lsws/$NAME/html" --allow-root 2>/dev/null | cut -f3 -d '/' | sort -u | uniq)
  [[ -n "$sub_domain_multisite" ]] && echo "$sub_domain_multisite" >>"/tmp/ssl-$NAME.txt"
fi

# Fix lỗi check vhAliases của bản cũ
domain_alias_all=$(grep "vhAliases" "/usr/local/lsws/conf/vhosts/$NAME/$NAME.conf" 2>/dev/null | cut -f2-99 -d ' ' | sed 's/ //g' | tr ',' '\n')
if [[ -n "$domain_alias_all" ]]; then
  for domain_alis in $domain_alias_all; do
    echo "$domain_alis" >>"/tmp/ssl-$NAME.txt"
  done
fi

if [[ "$checkdns" == "$checkdnscname" && -n "$checkdns" ]]; then
  echo "www.$NAME" >>"/tmp/ssl-$NAME.txt"
fi
echo "$NAME" >>"/tmp/ssl-$NAME.txt"
_rundone "Quét và gộp danh sách Subdomain hoàn tất"

# ==============================================================================
# KIỂM TRA DNS KHẮT KHE (TỰ ĐỘNG BỎ QUA SUBDOMAIN SAI IP)
# ==============================================================================
_runing "Đang kiểm tra phân giải DNS cho tất cả tên miền trong danh sách chờ..."
if [[ ! -f "/etc/wptt/.cloudflare/wptt-$NAME.ini" ]]; then
  if [[ -f "/tmp/ssl-$NAME.txt" ]]; then
    mapfile -t multisite_check_dns_tro_ip_chua < <(cat "/tmp/ssl-$NAME.txt" | sort -u | sed '/^$/d')
    for multisite in "${multisite_check_dns_tro_ip_chua[@]}"; do
      multisite_check_dns=$(host "$multisite" 2>/dev/null | grep -Eo -m 1 '[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}')
      if [[ -z "$multisite_check_dns" ]] || ! echo "$server_ips" | grep -q "\b$multisite_check_dns\b"; then
        echo -e "\n${C_YELLOW}⚠️ Bỏ qua: Tên miền $multisite chưa trỏ IP (hoặc trỏ sai).${C_RESET}"
        sed -i "/^$multisite$/d" "/tmp/ssl-$NAME.txt"
      fi
    done
  fi
fi
_rundone "Kiểm tra DNS hoàn tất"

# ==============================================================================
# THỰC THI CERTBOT EXPAND
# ==============================================================================
echo ""
_runing "Gửi yêu cầu cấp phát và MỞ RỘNG chứng chỉ tới Let's Encrypt..."
echo "Cài đặt mở rộng SSL free letsencrypt website $NAME: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log

list_ssl_domain_all=$(cat "/tmp/ssl-$NAME.txt" | sort -u | uniq | sed '/^$/d' | sed 's/^/-d /g' | tr -s '\n' ' ')
cloudflare=""
if [[ -f "/etc/wptt/.cloudflare/wptt-$NAME.ini" ]]; then
  cloudflare="--dns-cloudflare --dns-cloudflare-credentials /etc/wptt/.cloudflare/wptt-$NAME.ini"
fi

duong_dan_docroot_web=$(grep 'docRoot' "/usr/local/lsws/conf/vhosts/$NAME/$NAME.conf" 2>/dev/null | awk '{print $2}' | head -n 1)

# Lệnh thực thi mở rộng (Lưu ý: Không dùng --force-renewal để tránh lãng phí Rate Limit nếu không có thay đổi)
certbot_output=$(certbot certonly $cloudflare --non-interactive --agree-tos --register-unsafely-without-email --expand --webroot -w "${duong_dan_docroot_web}" $list_ssl_domain_all 2>&1)
certbot_exit_code=$?

/usr/local/lsws/bin/lswsctrl restart >/dev/null 2>&1
_rundone "Yêu cầu Let's Encrypt kết thúc"

# ==============================================================================
# KIỂM TRA LỖI RATE LIMIT & BÁO CÁO THÀNH CÔNG
# ==============================================================================
if [[ $certbot_exit_code -ne 0 ]]; then
  LOG_FILE="/var/log/letsencrypt/letsencrypt.log"
  LIMIT_MSG=$(tail -n 500 "$LOG_FILE" 2>/dev/null | grep -E -i "rateLimited|too many certificates" | tail -n 1)

  if [[ -n "$LIMIT_MSG" ]]; then
    if echo "$LIMIT_MSG" | grep -qi "too many certificates already issued"; then
      BAN_REASON="Cấp phát chứng chỉ lặp lại quá nhiều (5 lần/tuần)."
      WAIT_TIME="Vui lòng chờ hệ thống mở khóa (Tối đa 7 ngày)."
    elif echo "$LIMIT_MSG" | grep -qi "too many failed authorizations"; then
      BAN_REASON="Xác thực lỗi quá nhiều lần (Giới hạn 5 lần/giờ)."
      WAIT_TIME="Hãy đợi đúng 1 tiếng đồng hồ nữa rồi thử lại."
    else
      BAN_REASON="Vi phạm chính sách chống Spam API của Let's Encrypt."
      WAIT_TIME="Vui lòng thử lại sau vài giờ hoặc vài ngày."
    fi

    echo -e "\n${C_RED}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
    center_text "${C_BOLD_WHITE}⚠️ TỪ CHỐI CẤP PHÁT: BỊ KHÓA SSL TẠM THỜI${C_RESET}"
    echo -e "${C_RED}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
    left_text "  Tên miền bị chặn : ${C_YELLOW}$NAME${C_RESET}" 2
    left_text "  Nguyên nhân      : ${C_BOLD_WHITE}$BAN_REASON${C_RESET}" 2
    left_text "  Cách xử lý       : ${C_GREEN}$WAIT_TIME${C_RESET}" 2
    echo -e "${C_RED}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
    left_text " ${C_YELLOW}💡 GIẢI THÍCH & LỜI KHUYÊN TỪ HỆ THỐNG:${C_RESET}" 2
    left_text " - Hệ thống Let's Encrypt từ chối yêu cầu mở rộng chứng chỉ do bạn" 2
    left_text "   đã thao tác (Cài đặt/Mở rộng) thành công quá nhiều lần trong tuần." 2
    left_text " - Tin tốt là: ${C_GREEN}Chứng chỉ cũ của bạn VẪN ĐANG HOẠT ĐỘNG!${C_RESET}" 2
    left_text " - Chỉ là các Subdomain bạn vừa gõ thêm sẽ chưa có SSL vào lúc này." 2
    left_text " - ${C_RED}Tuyệt đối KHÔNG thử lại ngay lúc này${C_RESET} để tránh bị khóa lâu hơn." 2
    echo -e "${C_RED}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"
  else
    echo -e "\n${C_RED}❌ Lỗi: Quá trình Mở rộng SSL Let's Encrypt không thành công!${C_RESET}"
    echo "Bạn có thể kiểm tra chi tiết lỗi tại file log: $LOG_FILE"
  fi
else
  # BẢNG BÁO CÁO THÀNH CÔNG (UX BO CONG)
  echo -e "\n${C_GREEN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_BOLD_WHITE}🎉 HOÀN TẤT MỞ RỘNG CHỨNG CHỈ SSL${C_RESET}"
  echo -e "${C_GREEN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
  left_text "Chứng chỉ bảo mật Let's Encrypt đã được cấp phát / mở rộng" 2
  left_text "thành công cho các tên miền sau:" 2
  echo -e "${C_GREEN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"

  final_list=$(cat "/tmp/ssl-$NAME.txt" | sort -u | uniq | sed '/^$/d')
  for final_dom in $final_list; do
    left_text "▪ ${C_YELLOW}$final_dom${C_RESET}" 2
  done

  echo -e "${C_GREEN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"
fi

rm -f "/tmp/ssl-$NAME.txt"

check_menu_wptangtoc_active=$1
if [[ $check_menu_wptangtoc_active == "98" ]]; then
  echo -en "${C_GREEN}👉 Nhấn phím [Enter] để quay lại Menu...${C_RESET}"
  read -r dummy
  exec /etc/wptt/wptt-ssl-main 1
fi
