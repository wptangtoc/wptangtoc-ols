#!/bin/bash
# @author: Gia Tuấn
# @website: https://wptangtoc.com
# @since: 2026

function huong_dan() {
  Tính năng Cài đặt SSL trả phí là quá trình trang bị cho website của bạn một chứng chỉ SSL/TLS thương mại [mua từ các nhà cung cấp như DigiCert, Sectigo, GlobalSign,...] để kích hoạt giao thức HTTPS, đảm bảo kết nối mã hóa và xác thực danh tính website ở mức độ cao hơn.

  Nói một cách đơn giản, đây là việc bạn đầu tư mua một giấy phép bảo mật cao cấp hơn cho website, thường đi kèm với các quy trình xác minh nghiêm ngặt hơn và có thể cung cấp các dấu hiệu tin cậy rõ ràng hơn cho người dùng so với chứng chỉ miễn phí.

  Mục Đích Chính
  * Xác thực danh tính mạnh mẽ [đặc biệt với OV/EV]:
  * OV [Organization Validation]: Xác minh sự tồn tại và tính hợp pháp của tổ chức sở hữu website.
  * EV [Extended Validation]: Quy trình xác minh nghiêm ngặt nhất, trước đây thường hiển thị tên công ty trên thanh địa chỉ màu xanh lá [hiện nay ít phổ biến hơn nhưng vẫn tăng độ tin cậy].
  * Bảo mật dữ liệu: Mã hóa toàn bộ thông tin trao đổi giữa người dùng và website.
  * Tăng uy tín và niềm tin: Khách hàng có thể cảm thấy an tâm hơn khi giao dịch trên website có chứng chỉ trả phí, đặc biệt là OV/EV.
  * Bảo hiểm [Warranty]: Nhiều chứng chỉ trả phí đi kèm với các gói bảo hiểm, bồi thường nếu có sai sót từ phía nhà cung cấp chứng chỉ gây thiệt hại.
  * Hỗ trợ khách hàng: Thường nhận được sự hỗ trợ kỹ thuật tốt hơn từ nhà cung cấp.
  * Các tính năng đặc biệt: Một số loại có thể hỗ trợ nhiều tên miền [SAN] hoặc wildcard [cho tất cả tên miền phụ] một cách linh hoạt.

  Việc cài đặt SSL trả phí thường đòi hỏi nhiều bước hơn và có chi phí, nhưng mang lại các lợi ích về xác thực và uy tín cao hơn cho một số loại hình website, đặc biệt là các trang thương mại điện tử lớn hoặc tổ chức tài chính.
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null # Nạp thư viện UI Xác nhận

if [[ "$1" == "98" ]]; then
  WPTT_IN_MENU="yes"
  WPTT_MENU_BACK="/etc/wptt/wptt-ssl-main 1"
fi

clear
echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}${quan_ly_ssl} ➜ Khởi tạo & Cấu hình SSL Trả phí (Paid SSL)${C_RESET}"
echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

NAME=$1
no_key=$2
[[ "$NAME" == "98" ]] && NAME=""

# ==============================================================================
# HÀM MENU CHỌN DOMAIN (UX BO CONG)
# ==============================================================================
if [[ -z "$NAME" ]]; then
  . /etc/wptt/tenmien
  lua_chon_NAME "cấu hình SSL Trả phí"
fi

[[ "$NAME" == "0" || -z "$NAME" ]] && {
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-ssl-main 1
  return 2>/dev/null || exit
}

path="/etc/wptt/vhost/.$NAME.conf"
if [[ ! -f "$path" ]]; then
  echo -e "\n${C_RED}❌ Tên miền không tồn tại trên hệ thống này!${C_RESET}"
  sleep 3
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-ssl-main 1
  return 2>/dev/null || exit
fi

echo "Thiết lập cài đặt ssl trả phí website $NAME: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log
mkdir -p "/usr/local/lsws/$NAME/ssl"

# ==============================================================================
# TẠO PRIVATE KEY VÀ CSR
# ==============================================================================
dongy2="n"
if [[ -z "$no_key" ]]; then
  echo ""
  if wptt_xac_nhan "Bạn có muốn hệ thống tự tạo Private Key (.key) và mã CSR không?" "${C_BOLD_WHITE}Gợi ý:${C_RESET} Chọn [Có] nếu bạn chưa mua SSL và cần mã CSR để cung cấp cho nhà bán." "" "Có (Tự động tạo)" "Không cần"; then
    dongy2="y"
  fi
fi

if [[ "$dongy2" == "y" ]]; then
  echo ""
  _runing "Đang khởi tạo mã hóa RSA 2048-bit cho Private Key và CSR..."

  openssl genrsa -out "/usr/local/lsws/$NAME/ssl/$NAME.key" 2048 >/dev/null 2>&1
  country='VN'
  state='Hai Phong'
  locality='Hai Phong'
  organization="$NAME"
  organizationalunit="$NAME"
  commonname="$NAME"
  email="admin@${NAME}"

  openssl req -new -key "/usr/local/lsws/$NAME/ssl/$NAME.key" -out "/usr/local/lsws/$NAME/ssl/$NAME.csr" \
    -subj "/C=$country/ST=$state/L=$locality/O=$organization/OU=$organizationalunit/CN=$commonname/emailAddress=$email" >/dev/null 2>&1

  chmod 600 "/usr/local/lsws/$NAME/ssl/$NAME.key"
  _rundone "Khởi tạo thành công"

  echo -e "\n${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_BOLD_WHITE}MÃ CSR XÁC THỰC CỦA BẠN (CERTIFICATE SIGNING REQUEST)${C_RESET}"
  echo -e "${C_CYAN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
  left_text "Hãy COPY toàn bộ đoạn mã bên dưới và cung cấp cho nhà cung cấp SSL:" 2
  echo -e "${C_CYAN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"

  # In mã CSR (Căn lề chuẩn)
  while IFS= read -r line; do
    printf "${C_CYAN}│${C_RESET}  ${C_YELLOW}%-69s${C_RESET}${C_CYAN}│${C_RESET}\n" "$line"
  done <"/usr/local/lsws/$NAME/ssl/$NAME.csr"

  echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"
fi

# ==============================================================================
# CẤU HÌNH VHOST VÀ HTTPD_CONFIG
# ==============================================================================
_runing "Thiết lập cấu hình SSL trả phí Vhost..."

if [[ "$NAME" == "$Website_chinh" ]]; then
  sed -i "/keyFile/d" /usr/local/lsws/conf/httpd_config.conf
  sed -i "/certFile/d" /usr/local/lsws/conf/httpd_config.conf
  sed -i "/CACertFile/d" /usr/local/lsws/conf/httpd_config.conf

  sed -i "/https/a   keyFile                \/usr\/local\/lsws\/${NAME}\/ssl\/${NAME}.key" /usr/local/lsws/conf/httpd_config.conf
  sed -i "/https/a   certFile               \/usr\/local\/lsws\/${NAME}\/ssl\/cert.crt" /usr/local/lsws/conf/httpd_config.conf
  sed -i "/https/a   CACertFile             \/usr\/local\/lsws\/${NAME}\/ssl\/ca_bundle.crt" /usr/local/lsws/conf/httpd_config.conf
fi

sed -i -e '/^vhssl /,/^}$/d' "/usr/local/lsws/conf/vhosts/$NAME/$NAME.conf"
echo "vhssl  {
  keyFile                 /usr/local/lsws/$NAME/ssl/$NAME.key
  certFile                /usr/local/lsws/$NAME/ssl/cert.crt
  certChain               0
  CACertFile              /usr/local/lsws/$NAME/ssl/ca_bundle.crt
  sslProtocol             24
  renegProtection         1
  sslSessionCache         1
  sslSessionTickets       1
  enableSpdy              15
  enableQuic              1
}
" >>"/usr/local/lsws/conf/vhosts/$NAME/$NAME.conf"

# Xóa các lệnh redirect cũ
path2="/usr/local/lsws/$NAME/html/.htaccess"
sed -i -e '/^#begin-chuyen-huong-http-to-https-wptangtoc-ols/,/^#end-chuyen-huong-http-to-https-wptangtoc-ols$/d' "$path2" 2>/dev/null
sed -i -e '/^#begin-chuyen-huong-www-to-non-www-wptangtoc-ols/,/^#end-chuyen-huong-www-to-non-www-wptangtoc-ols$/d' "$path2" 2>/dev/null
sed -i -e '/^#begin-chuyen-huong-non-www-to-www-wptangtoc-ols/,/^#end-chuyen-huong-non-www-to-www-wptangtoc-ols$/d' "$path2" 2>/dev/null

checkdns=$(host "$NAME" 2>/dev/null | grep -Eo -m 1 '[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}')
checkdnscname=$(host "www.$NAME" 2>/dev/null | grep -Eo -m 1 '[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}')

if [[ "$checkdns" == "$checkdnscname" && -n "$checkdns" ]]; then
  sed -i '1 i #begin-chuyen-huong-http-to-https-wptangtoc-ols\
RewriteCond %{HTTPS} !=on\
RewriteRule ^(.*)$ https:\/\/%{HTTP_HOST}%{REQUEST_URI} [L,R=301,NE]\
#end-chuyen-huong-http-to-https-wptangtoc-ols' "$path2" 2>/dev/null

  sed -i '1 i #begin-chuyen-huong-www-to-non-www-wptangtoc-ols\
RewriteCond %{HTTP_HOST} ^www.'$NAME' [NC]\
RewriteRule ^(.*)$ https:\/\/'$NAME'/$1 [L,R=301,NC]\
#end-chuyen-huong-www-to-non-www-wptangtoc-ols' "$path2" 2>/dev/null
else
  sed -i '1 i #begin-chuyen-huong-http-to-https-wptangtoc-ols\
RewriteCond %{HTTPS} !=on\
RewriteRule ^(.*)$ https:\/\/%{HTTP_HOST}%{REQUEST_URI} [L,R=301,NE]\
#end-chuyen-huong-http-to-https-wptangtoc-ols' "$path2" 2>/dev/null
fi
_rundone "Thiết lập cấu hình SSL trả phí Vhost..."

# ==============================================================================
# HƯỚNG DẪN UPLOAD FILE (UX BO CONG)
# ==============================================================================
if [[ -z "$no_key" ]]; then
  echo -e "\n${C_GREEN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_BOLD_WHITE}CẤU HÌNH HỆ THỐNG HOÀN TẤT - BƯỚC TIẾP THEO${C_RESET}"
  echo -e "${C_GREEN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
  left_text "Hệ thống đã dọn đường sẵn. Bây giờ bạn cần UPLOAD CÁC FILE CHỨNG CHỈ" 2
  left_text "mà nhà cung cấp gửi cho bạn vào thư mục sau:" 2
  echo -e "${C_GREEN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
  center_text "${C_YELLOW}/usr/local/lsws/$NAME/ssl/${C_RESET}"
  echo -e "${C_GREEN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"

  if [[ "$dongy2" == "y" ]]; then
    left_text "Yêu cầu upload 2 file (Đặt đúng tên):" 2
    left_text "1. ${C_CYAN}cert.crt${C_RESET}       (File chứng chỉ SSL của tên miền)" 4
    left_text "2. ${C_CYAN}ca_bundle.crt${C_RESET}  (File chứng chỉ CA trung gian)" 4
  else
    left_text "Yêu cầu upload 3 file (Đặt đúng tên):" 2
    left_text "1. ${C_CYAN}$NAME.key${C_RESET}  (File Private Key)" 4
    left_text "2. ${C_CYAN}cert.crt${C_RESET}       (File chứng chỉ SSL của tên miền)" 4
    left_text "3. ${C_CYAN}ca_bundle.crt${C_RESET}  (File chứng chỉ CA trung gian)" 4
  fi

  echo -e "${C_GREEN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
  left_text "${C_YELLOW}SAU KHI UPLOAD XONG, HÃY CHẠY LỆNH NGOÀI TERMINAL SAU ĐỂ KÍCH HOẠT:${C_RESET}" 2
  center_text "${C_GREEN}wptt ssl-tra-phi-config $NAME${C_RESET}"
  echo -e "${C_GREEN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"
fi

[[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-ssl-main 1
