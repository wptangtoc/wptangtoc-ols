#!/bin/bash
# @author: Gia Tuấn
# @website: https://wptangtoc.com
# @since: 2026

function huong_dan() {
  Tính năng Xóa SSL trả phí là quá trình gỡ bỏ một chứng chỉ SSL/TLS thương mại [mà bạn đã mua từ các nhà cung cấp như DigiCert, Sectigo, Comodo, v.v.] khỏi máy chủ web cho một tên miền cụ thể. Việc này thường đi kèm với việc vô hiệu hóa cấu hình HTTPS liên quan đến chứng chỉ đó, có thể khiến website quay lại sử dụng HTTP hoặc chuyển sang một chứng chỉ SSL khác.

  Nói một cách đơn giản, đây là hành động gỡ bỏ giấy phép bảo mật có trả phí khỏi website của bạn, làm cho website không còn sử dụng kết nối mã hóa HTTPS thông qua chứng chỉ cụ thể đó nữa.

  Mục Đích Chính
  * Chứng chỉ hết hạn và không gia hạn: Khi chứng chỉ trả phí đã hết hạn sử dụng và bạn quyết định không mua mới [có thể do ngừng website, chuyển sang dùng Lets Encrypt miễn phí, v.v.].
  * Thay đổi nhà cung cấp hoặc loại chứng chỉ: Khi bạn muốn chuyển sang sử dụng chứng chỉ từ một nhà cung cấp khác, hoặc thay đổi loại chứng chỉ [ví dụ: từ DV sang EV].
  * Ngừng hoạt động website/tên miền: Nếu website không còn được sử dụng.
  * Sự cố với chứng chỉ: Nếu chứng chỉ bị cấp sai, khóa riêng tư bị lộ, hoặc có vấn đề bảo mật khác đòi hỏi phải thu hồi và gỡ bỏ.
  * Cấu hình lại máy chủ: Trong quá trình thay đổi lớn về máy chủ hoặc di chuyển hosting.
  * Tiết kiệm chi phí: Quyết định không tiếp tục trả phí cho chứng chỉ đó nữa.

  Sau khi xóa, website sẽ không còn sử dụng chứng chỉ SSL trả phí đó nữa. Nếu không có chứng chỉ nào khác thay thế, kết nối HTTPS sẽ thất bại.
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null # Nạp thư viện UI Xác nhận

if [[ "$1" == "98" ]]; then
  WPTT_IN_MENU="yes"
  WPTT_MENU_BACK="/etc/wptt/wptt-ssl-main 1"
fi

clear
echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}${quan_ly_ssl} ➜ Gỡ bỏ Chứng chỉ SSL Trả phí (Paid SSL)${C_RESET}"
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

NAME=$1
[[ "$NAME" == "98" ]] && NAME=""

if [[ -z "$NAME" ]]; then
  function lua_chon_NAME() {
    unset NAME selects
    selects=()
    local box_inner_width=${box_inner_width:-71}

    # Quét Vhost thường
    for filepath in /etc/wptt/vhost/.*.conf; do
      [[ ! -f "$filepath" || "$filepath" == *"/..conf" ]] && continue
      local domain="${filepath##*/}"
      domain="${domain%.conf}"
      domain="${domain#.}"
      if [[ "$domain" == ?*.?* && -d "/usr/local/lsws/$domain/ssl" ]]; then
        selects+=("$domain")
      fi
    done

    # Quét Domain chuyển hướng
    if [[ -d "/etc/wptt/chuyen-huong" ]]; then
      for filepath in /etc/wptt/chuyen-huong/.*.conf; do
        [[ ! -f "$filepath" || "$filepath" == *"/..conf" ]] && continue
        local domain="${filepath##*/}"
        domain="${domain%.conf}"
        domain="${domain#.}"
        if [[ "$domain" == ?*.?* && -d "/usr/local/lsws/$domain/ssl" ]]; then
          selects+=("$domain")
        fi
      done
    fi

    # Lọc trùng lặp
    if [[ ${#selects[@]} -gt 0 ]]; then
      mapfile -t selects < <(printf "%s\n" "${selects[@]}" | sort -uV)
    else
      echo -e "${C_YELLOW}⚠️ Hệ thống hiện không có Website nào đang sử dụng cấu hình SSL Trả phí!${C_RESET}"
      sleep 3
      exec /etc/wptt/wptt-ssl-main 1
    fi

    # Render Menu
    echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
    local title_text="Lựa chọn Website bạn muốn XÓA chứng chỉ SSL Trả phí:"
    local len=$(echo -n "$title_text" | awk '{print length($0)}')
    local pad_r=$((box_inner_width - len - 2))
    [[ $pad_r -lt 0 ]] && pad_r=0
    echo -e "${C_CYAN}│${C_RESET}  ${C_YELLOW}${title_text}${C_RESET}$(printf '%*s' "$pad_r" "")${C_CYAN}│${C_RESET}"

    local line_len=$((len + 3))
    local pad_line_r=$((box_inner_width - line_len))
    [[ $pad_line_r -lt 0 ]] && pad_line_r=0
    local short_line=$(printf "%${line_len}s" "" | sed 's/ /─/g')
    echo -e "${C_CYAN}├${short_line}$(printf '%*s' "$pad_line_r" "")│${C_RESET}"

    local i=1
    for dom in "${selects[@]}"; do
      local item_text=$(printf "  ${C_CYAN}%3d)${C_RESET} ${C_BOLD_WHITE}%-30s${C_RESET} ${C_GREEN}[Có SSL Paid]${C_RESET}" "$i" "$dom")
      local clean_text=$(printf "  %3d) %-30s [Có SSL Paid]" "$i" "$dom")
      local item_len=$(echo -n "$clean_text" | awk '{print length($0)}')
      local pad=$((box_inner_width - item_len))
      [[ $pad -lt 0 ]] && pad=0
      echo -e "${C_CYAN}│${C_RESET}${item_text}$(printf '%*s' "$pad" "")${C_CYAN}│${C_RESET}"
      ((i++))
    done
    echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯${C_RESET}"

    local fzf_installed=false
    if command -v fzf &>/dev/null; then
      fzf_installed=true
      PROMPT_TEXT="Nhập lựa chọn (1-${#selects[@]}) [00=Tìm nhanh] [0=Thoát]: "
    else
      PROMPT_TEXT="Nhập lựa chọn (1-${#selects[@]}) [0=Thoát]: "
    fi

    while true; do
      echo -en "${C_CYAN}${PROMPT_TEXT}${C_RESET}"
      if ! read -r REPLY; then exit 1; fi
      REPLY=$(echo "$REPLY" | tr -d ' ' | tr '[:upper:]' '[:lower:]')

      case "$REPLY" in
      0)
        echo -e "\n${C_GREEN}Đang thoát...${C_RESET}"
        NAME="0"
        return 0
        ;;
      00)
        if $fzf_installed; then
          local selected_item=$(printf '%s\n' "${selects[@]}" | nl -w 3 -s ': ' | fzf --prompt="Tìm website xóa SSL >> " --height=40% --border=rounded --color=border:red --cycle --reverse)
          local dom=$(echo "$selected_item" | sed 's/^[[:space:]]*[0-9]\+\:[[:space:]]*//' | cut -d'|' -f1)
          if [[ -n "$dom" ]]; then
            NAME="$dom"
            return 0
          else echo -e "${C_YELLOW}Đã hủy chọn. Vui lòng chọn lại.${C_RESET}"; fi
        else
          echo -e "${C_RED}Lỗi: FZF chưa cài đặt.${C_RESET}"
        fi
        ;;
      *)
        if [[ "$REPLY" =~ ^[0-9]+$ ]] && [ "$REPLY" -ge 1 ] && [ "$REPLY" -le ${#selects[@]} ]; then
          local action_index=$((REPLY - 1))
          NAME=$(echo "${selects[$action_index]}" | cut -d'|' -f1)
          return 0
        else
          echo -e "\n${C_RED}❌ Lựa chọn không hợp lệ! Vui lòng chọn lại.${C_RESET}"
        fi
        ;;
      esac
    done
  }
  lua_chon_NAME
fi

# --- CHỐT CHẶN THOÁT HIỂM BẮT BUỘC ---
[[ "$NAME" == "0" || -z "$NAME" ]] && {
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-ssl-main 1
  return 2>/dev/null || exit
}

pathcheck="/etc/wptt/vhost/.$NAME.conf"
[[ ! -f "$pathcheck" && ! -f "/etc/wptt/chuyen-huong/.$NAME.conf" ]] && {
  echo -e "\n${C_RED}❌ Tên miền không tồn tại trên hệ thống này!${C_RESET}"
  sleep 2
  exec /etc/wptt/wptt-ssl-main 1
}

if [[ ! -d "/usr/local/lsws/$NAME/ssl" ]]; then
  echo -e "\n${C_RED}❌ Website $NAME chưa thiết lập SSL Trả phí (Không tìm thấy thư mục cấu hình).${C_RESET}"
  sleep 2
  exec /etc/wptt/wptt-ssl-main 1
fi

# ==============================================================================
# XÁC NHẬN GỠ BỎ
# ==============================================================================
echo ""
extra_msg=""
if [[ -f "/etc/letsencrypt/live/$NAME/cert.pem" ]]; then
  extra_msg="${C_GREEN}* Hệ thống sẽ tự động Fallback cấu hình về chứng chỉ Let's Encrypt hiện có.${C_RESET}"
else
  extra_msg="${C_YELLOW}* Hệ thống sẽ tự động tạo chứng chỉ Tự Ký (Self-Signed) để OLS không bị lỗi.${C_RESET}"
fi

if wptt_xac_nhan "Bạn có chắc chắn muốn GỠ BỎ cấu hình SSL Trả phí của website này?" "${C_BOLD_WHITE}Website:${C_RESET} ${C_YELLOW}$NAME${C_RESET}\n$extra_msg" "" "Đồng ý Gỡ bỏ" "Hủy thao tác"; then
  echo ""

  _runing "Tiến hành gỡ bỏ cấu hình và thiết lập Fallback SSL..."

  # --- 1. SSL FALLBACK (XỬ LÝ CHUẨN TỰ KÝ VÀ LETS ENCRYPT) ---
  if [[ -f "/etc/letsencrypt/live/$NAME/cert.pem" ]]; then
    ssl_type="letsencrypt"
    ssl_key="/etc/letsencrypt/live/$NAME/privkey.pem"
    ssl_cert="/etc/letsencrypt/live/$NAME/cert.pem"
    ssl_ca="/etc/letsencrypt/live/$NAME/chain.pem"
    fallback_status="Phục hồi về Let's Encrypt"
  else
    ssl_type="self-signed"
    mkdir -p "/etc/wptt-ssl-tu-ky/$NAME"
    cd "/etc/wptt-ssl-tu-ky/$NAME" || exit
    openssl req -new -newkey rsa:2048 -nodes -keyout "$NAME.key" -out "$NAME.csr" -subj "/C=VN/ST=Hanoi/L=Hanoi/O=WPTangToc OLS/OU=IT Department/CN=$NAME/emailAddress=admin@example.com" >/dev/null 2>&1
    openssl x509 -req -in "$NAME.csr" -signkey "$NAME.key" -out "cert.crt" -days 3650 >/dev/null 2>&1

    ssl_key="/etc/wptt-ssl-tu-ky/$NAME/$NAME.key"
    ssl_cert="/etc/wptt-ssl-tu-ky/$NAME/cert.crt"
    fallback_status="Cấp mới chứng chỉ Tự ký (Self-Signed)"
  fi

  # --- 2. ÁP DỤNG CẤU HÌNH SSL MỚI CHO HTTPD (Nếu là Web Chính) ---
  if [[ "$NAME" == "$Website_chinh" ]]; then
    if [[ -f /usr/local/lsws/conf/httpd_config.conf ]]; then
      sed -i "/keyFile/d" /usr/local/lsws/conf/httpd_config.conf
      sed -i "/certFile/d" /usr/local/lsws/conf/httpd_config.conf
      sed -i "/CACertFile/d" /usr/local/lsws/conf/httpd_config.conf

      sed -i "/https/a \    keyFile                $ssl_key" /usr/local/lsws/conf/httpd_config.conf
      sed -i "/https/a \    certFile               $ssl_cert" /usr/local/lsws/conf/httpd_config.conf

      if [[ "$ssl_type" == "letsencrypt" ]]; then
        sed -i "/https/a \    CACertFile             $ssl_ca" /usr/local/lsws/conf/httpd_config.conf
      fi
    fi
  fi

  # --- 3. ÁP DỤNG CẤU HÌNH SSL MỚI CHO VHOST ---
  if [[ -f "/usr/local/lsws/conf/vhosts/$NAME/$NAME.conf" ]]; then
    sed -i -e '/^vhssl /,/^}$/d' "/usr/local/lsws/conf/vhosts/$NAME/$NAME.conf"

    if [[ "$ssl_type" == "letsencrypt" ]]; then
      echo "vhssl  {
  keyFile                 $ssl_key
  certFile                $ssl_cert
  certChain               0
  CACertFile              $ssl_ca
  sslProtocol             24
  renegProtection         1
  sslSessionCache         1
  sslSessionTickets       1
  enableSpdy              15
  enableQuic              1
}
" >>"/usr/local/lsws/conf/vhosts/$NAME/$NAME.conf"
    else
      echo "vhssl  {
  keyFile                 $ssl_key
  certFile                $ssl_cert
  certChain               0
  sslProtocol             24
  renegProtection         1
  sslSessionCache         1
  sslSessionTickets       1
  enableSpdy              15
  enableQuic              1
}
" >>"/usr/local/lsws/conf/vhosts/$NAME/$NAME.conf"
    fi
  fi

  # --- 4. XÓA THƯ MỤC SSL TRẢ PHÍ CŨ ---
  if [[ -d "/usr/local/lsws/$NAME/ssl" ]]; then
    rm -rf "/usr/local/lsws/$NAME/ssl"
  fi

  # --- 5. XÓA RULE CHUYỂN HƯỚNG TRONG HTACCESS ---
  path2="/usr/local/lsws/$NAME/html/.htaccess"
  if [[ -f "$path2" ]]; then
    sed -i -e '/^#begin-chuyen-huong-http-to-https-wptangtoc-ols/,/^#end-chuyen-huong-http-to-https-wptangtoc-ols$/d' "$path2" 2>/dev/null
    sed -i -e '/^#begin-chuyen-huong-www-to-non-www-wptangtoc-ols/,/^#end-chuyen-huong-www-to-non-www-wptangtoc-ols$/d' "$path2" 2>/dev/null
    sed -i -e '/^#begin-chuyen-huong-non-www-to-www-wptangtoc-ols/,/^#end-chuyen-huong-non-www-to-www-wptangtoc-ols$/d' "$path2" 2>/dev/null
  fi

  # Reload OLS không gây downtime
  /usr/local/lsws/bin/lswsctrl reload >/dev/null 2>&1

  echo "Xóa cài đặt ssl trả phí website $NAME: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log
  _rundone "Tiến hành gỡ bỏ cấu hình và thiết lập Fallback SSL..."

  # ==============================================================================
  # BẢNG BÁO CÁO THÀNH CÔNG (UX BO CONG)
  # ==============================================================================
  echo -e "\n${C_GREEN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_BOLD_WHITE}HOÀN TẤT GỠ BỎ SSL TRẢ PHÍ${C_RESET}"
  echo -e "${C_GREEN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
  left_text "Website thao tác : ${C_YELLOW}$NAME${C_RESET}"
  left_text "Trạng thái mới   : ${C_GREEN}$fallback_status${C_RESET}"
  echo -e "${C_GREEN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

else
  echo -e "${C_YELLOW}Đã hủy thao tác xóa cấu hình SSL Trả phí.${C_RESET}"
fi

[[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-ssl-main 1
