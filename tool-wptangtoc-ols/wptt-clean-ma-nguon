#!/bin/bash
# @author: Gia Tuấn
# @website: https://wptangtoc.com
# @email: giatuan@wptangtoc.com
# @since: 2026

NAME=$1
if [[ -z "$NAME" ]]; then
  echo -e "\n========================================================================="
  echo "| Reinstall WordPress Clean mã nguồn                                    |"
  echo "========================================================================="
  . /etc/wptt/tenmien
  echo -e "\nLựa chọn website Clean mã nguồn WordPress: \n"
  lua_chon_NAME
fi

[[ "$NAME" == "0" || -z "$NAME" ]] && exit 1

path_conf="/etc/wptt/vhost/.$NAME.conf"
[[ ! -f "$path_conf" ]] && {
  echoDo "Tên miền không tồn tại trên hệ thống này"
  sleep 2
  exit 1
}

echo "Reinstall WordPress Clean mã nguồn website $NAME : $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log

. /etc/wptt/echo-color
. /etc/wptt/core-functions
. /etc/wptt/vhost/.$NAME.conf

# 1. Tắt Lock Down an toàn
if [[ $lock_down ]]; then
  UI_STRING="$tat lock down website $NAME"
  _runing "$UI_STRING"
  . /etc/wptt/bao-mat/wptt-chattr-file-lock $NAME off
  sed -i '/lock_down/d' /etc/wptt/vhost/.$NAME.conf
  _rundone "$UI_STRING"
fi

if ! wptt_kha_dung_de_xoa_xac_thuc "$NAME"; then
  echoDo "Lỗi: Domain rỗng. Hủy bỏ lệnh xóa!"
  exit 1
fi

path="/usr/local/lsws/$NAME/html"

# 2. Xóa Core & File Rác
rm -rf "$path/wp-admin" "$path/wp-includes"
rm -f "$path/php.ini" "$path/user.ini"

# 3. Tẩy rửa thư mục gốc (Bỏ qua wp-config.php)
if [[ -d "$path/wp-content/plugins/devvn-quick-search" ]]; then
  find "$path" -maxdepth 1 -type f -name "*.php" ! -name "wp-config.php" ! -name "search.php" -delete
else
  find "$path" -maxdepth 1 -type f -name "*.php" ! -name "wp-config.php" -delete
fi

# 4. Cài đặt PHP Zip nếu thiếu
if ! php -m | grep -q 'zip'; then
  phien_ban_php_cli_hien_tai=$(php -v | grep cli | grep -oP 'PHP \K[0-9]+\.[0-9]+')
  . /etc/wptt/php/install-php-zip "$phien_ban_php_cli_hien_tai" >/dev/null 2>&1
fi

if ! php -m | grep -q 'zip'; then
  echoDo "Thiếu thư viện php extension zip để thực thi câu lệnh"
  exit 1
fi

# 5. Cấu hình WP_EXEC
. /etc/wptt/php/php-cli-domain-config $NAME
WP_EXEC="sudo -u $User_name_vhost /usr/local/lsws/lsphp${phien_ban_php_domain_thuc_thi}/bin/php /usr/local/bin/wp"

_runing "Đang tải lại mã nguồn Core, Plugin & Theme cho $NAME"

# Tải lại Core & Update DB
$WP_EXEC core download --skip-content --force --path="$path" >/dev/null 2>&1
$WP_EXEC core update-db --path="$path" >/dev/null 2>&1

# Tải lại Plugins
plugins_list=$($WP_EXEC plugin list --field=name --path="$path" 2>/dev/null)
[[ -n "$plugins_list" ]] && $WP_EXEC plugin install $plugins_list --force --path="$path" >/dev/null 2>&1

# Tải lại Themes
themes_list=$($WP_EXEC theme list --field=name --path="$path" 2>/dev/null)
[[ -n "$themes_list" ]] && $WP_EXEC theme install $themes_list --force --path="$path" >/dev/null 2>&1

_rundone "Đang tải lại mã nguồn Core, Plugin & Theme cho $NAME"

# 6. Dọn dẹp Cache, Cron rác & Drop-ins
_runing "Dọn dẹp rác, Cron và Drop-ins bảo mật"
rm -rf "$path/wp-content/cache"
rm -rf "/usr/local/lsws/$NAME/luucache"

$WP_EXEC cron event list --path="$path" 2>/dev/null | grep 'vtpost_login_daily' | awk '{ print $1 }' | xargs -I % $WP_EXEC cron event delete % --path="$path" >/dev/null 2>&1

# Dọn dẹp Drop-ins
rm -f "$path/wp-content/advanced-cache.php"
rm -f "$path/wp-content/object-cache.php"

# Bypass SQLite cho db.php
if [[ -f "$path/wp-content/db.php" ]]; then
  if ! grep -qi "sqlite" "$path/wp-content/db.php"; then
    rm -f "$path/wp-content/db.php"
  fi
fi

# Dọn dẹp mu-plugins (nếu có)
if [[ -d "$path/wp-content/mu-plugins" ]]; then
  find "$path/wp-content/mu-plugins" -type f -name "*.php" -delete
fi
_rundone "Dọn dẹp rác, Cron và Drop-ins bảo mật"

# 7. Xóa index.php của Theme cha
checkchild=$($WP_EXEC theme list --path="$path" 2>/dev/null | grep -c 'parent')
if [[ "$checkchild" != "1" ]]; then
  name_theme=$($WP_EXEC theme status --path="$path" 2>/dev/null | grep 'A' | head -1 | awk '{print $2}')
  rm -f "$path/wp-content/themes/$name_theme/index.php"
fi

# 8. Quét mã độc & Rải index.php chống Directory Listing
_runing "Quét mã độc và tối ưu bảo mật thư mục Uploads"

# Quét sạch toàn bộ script thực thi trong thư mục Uploads
find "$path/wp-content/uploads" -type f \( -name "*.php" -o -name "*.php[34578]" -o -name "*.phtml" -o -name "*.phps" -o -name "*.sh" -o -name "*.cgi" -o -name "*.pl" -o -name "*.shtml" \) -delete

# Xóa .htaccess rác
find "$path/wp-content" -type f -name ".htaccess" -delete

# Rải index.php rỗng vào các thư mục gốc
echo '<?php' >"$path/wp-content/uploads/index.php"
echo '<?php' >"$path/wp-content/index.php"
echo '<?php' >"$path/wp-content/themes/index.php"
echo '<?php' >"$path/wp-content/plugins/index.php"

# Rải index.php vào TẤT CẢ thư mục con của Uploads
find "$path/wp-content/uploads" -type d -print0 | while IFS= read -r -d '' dir; do
  [[ ! -f "$dir/index.php" ]] && echo '<?php' >"$dir/index.php"
done

_rundone "Quét mã độc và tối ưu bảo mật thư mục Uploads"

# 9. Kiểm tra nội soi wp-config.php
check_config_malware=$(grep -Ei "eval\(|base64_decode|gzinflate|str_rot13" "$path/wp-config.php" 2>/dev/null)
if [[ -n "$check_config_malware" ]]; then
  echo -e "\n\033[1;31m⚠️ CẢNH BÁO ĐỎ: Phát hiện chuỗi nghi ngờ bị mã hóa trong wp-config.php!\033[0m"
  echo "Vui lòng mở file /usr/local/lsws/$NAME/html/wp-config.php để kiểm tra và xóa thủ công các dòng mã độc."
  sleep 3
fi

# 10. Reset cấu hình phụ
(/etc/wptt/wordpress/thay-salt "$NAME" >/dev/null 2>&1)
(/etc/wptt/wptt-htaccess-reset "$NAME" >/dev/null 2>&1)

_runing "Xoá cache website $NAME"
(/etc/wptt/cache/wptt-xoacache "$NAME" >/dev/null 2>&1)
_rundone "Xoá cache website $NAME"

echoDone "Hoàn tất clean mã nguồn cho website $NAME"

# 11. Báo cáo Tài khoản Administrator (Rogue Admins)
echo -e "\n========================================================"
echo -e "\033[1;33mDANH SÁCH TÀI KHOẢN ADMINISTRATOR HIỆN TẠI:\033[0m"
$WP_EXEC user list --role=administrator --fields=ID,user_login,user_email,user_registered --path="$path" 2>/dev/null
echo "========================================================"
echo "Hãy kiểm tra danh sách trên, nếu có tài khoản lạ, vui lòng xóa ngay lập tức!"
echo ""
