#!/bin/bash

function huong_dan() {
  Tính năng Quản lý WebAdmin GUI trong WPTangToc OLS là một công cụ giúp bạn dễ dàng quản lý quyền truy cập và các thông tin liên quan đến giao diện quản trị web [WebAdmin Console] của OpenLiteSpeed. 🖥️🔐

  Giới thiệu ngắn gọn:
  Mục đích: Đơn giản hóa việc truy cập và bảo mật cho WebAdmin Console của OpenLiteSpeed [thường chạy trên port 19019], nơi bạn có thể cấu hình chi tiết máy chủ web.

  Cách hoạt động :
  * Hiển thị thông tin truy cập: Cung cấp nhanh chóng URL và port để truy cập WebAdmin GUI.
  * Đặt lại mật khẩu Admin: Cho phép bạn dễ dàng đặt lại mật khẩu cho tài khoản quản trị viên của OpenLiteSpeed WebAdmin nếu bạn quên.
  * Thiết lập ban đầu: Trong quá trình cài đặt OpenLiteSpeed, WPTangToc OLS thường sẽ tự động thiết lập tài khoản admin ban đầu cho WebAdmin Console.

  Lợi ích:
  * Truy cập thuận tiện: Nhanh chóng biết cách vào giao diện quản trị của OpenLiteSpeed.
  * Khôi phục dễ dàng: Không lo lắng nếu quên mật khẩu WebAdmin, có thể reset qua WPTangToc OLS.
  * Quản lý tập trung: Một số tác vụ cơ bản liên quan đến WebAdmin có thể được thực hiện hoặc hỗ trợ thông qua WPTangToc OLS.
  Tính năng này giúp bạn kiểm soát tốt hơn việc truy cập vào khu vực cấu hình quan trọng của OpenLiteSpeed, đồng thời hỗ trợ khi bạn cần lấy lại quyền truy cập.

}

if [[ -z "$1" ]]; then
  . /etc/wptt/wptt-header-menu
  header_menu
else
  clear
  . /etc/wptt/echo-color 2>/dev/null
  echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
  
  # Hàm vẽ tiêu đề phụ lọt lòng 78 (chống lệch UTF-8)
  center_tmp() {
    local text="$1"
    local clean_len=$(echo -en "$text" | sed "s/\x1B\[[0-9;]*[a-zA-Z]//g" | tr -d '\r\n')
    local len=$(LC_ALL=C.UTF-8 printf "%s" "$clean_len" | wc -m | tr -d ' ' 2>/dev/null)
    [[ -z "$len" || "$len" == "0" ]] && len=${#clean_len}
    
    local pad_left=$(((78 - len) / 2))
    local pad_right=$((78 - len - pad_left))
    printf "${C_CYAN}│${C_RESET}%*s%b%*s${C_CYAN}│${C_RESET}\n" "$pad_left" "" "$text" "$pad_right" ""
  }
  
  center_tmp "${C_YELLOW}TRUNG TÂM QUẢN LÝ WEBADMIN GUI (OPENLITESPEED)${C_RESET}"
  echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯${C_RESET}"
fi

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null

echo ""
echo "$quan_ly_webguiadmin:" > /dev/null # Dữ liệu ẩn cho bộ tìm kiếm để không bị mất tính năng search

# ==============================================================================
# TẠO MENU 2 CỘT (TRÁI: TRẠNG THÁI & MẠNG | PHẢI: BẢO MẬT & TÀI KHOẢN)
# ==============================================================================
MENU_TITLE="TRUNG TÂM QUẢN LÝ WEBADMIN GUI"

options=(
  # --- CỘT TRÁI (Index 0-2) ---
  "$kich_hoat_webguiadmin"                   # 0 (Hiện: 1)
  "$huy_kich_hoat_webguiadmin"               # 1 (Hiện: 2)
  "$doi_port_webguiadmin"                    # 2 (Hiện: 3)
  
  # --- CỘT PHẢI (Index 3-4) ---
  "$thay_doi_id_va_password"                 # 3 (Hiện: 4)
  "$xem_lai_thong_tin_tai_khoan_webguiadmin" # 4 (Hiện: 5)
)

# Hàm thực thi hành động
run_action() {
  local index=$1
  local script_path=""
  local script_args="98"

  case $index in
  0) script_path="/etc/wptt/webadmin/wptt-mo-webgui" ;;
  1) script_path="/etc/wptt/webadmin/wptt-dong-webgui" ;;
  2) script_path="/etc/wptt/webadmin/wptt-doi-port-webadmin" ;;
  3) script_path="/etc/wptt/webadmin/wptt-thay-doi-password-user" ;;
  4) script_path="/etc/wptt/webadmin/wptt-check-tk-webguiadmin" ;;
  *)
    echo -e "\n${C_RED}[!] ${lua_chon_khong_hop_le:-Lựa chọn không hợp lệ}: Index $index.${C_RESET}"
    return 1
    ;;
  esac

  if [[ -x "$script_path" || -f "$script_path" ]]; then
    exec bash "$script_path" "$script_args"
  else
    echo -e "\n${C_RED}[!] Lỗi: Không tìm thấy kịch bản '$script_path'.${C_RESET}"
    sleep 2
    exec /etc/wptt/wptt-webadmin-main 1
  fi
}

# ==============================================================================
# GHI ĐÈ BỐ CỤC 2 CỘT CHUẨN UX
# ==============================================================================
draw_custom_grid() {
  print_row "" "TRẠNG THÁI & MẠNG" "" "TÀI KHOẢN & BẢO MẬT"
  print_row "1" "${options[0]}" "4" "${options[3]}"
  print_row "2" "${options[1]}" "5" "${options[4]}"
  print_row "3" "${options[2]}" ""  ""
}

# Kích hoạt Engine Menu
. /etc/wptt/wptt-callback-menu-chon
