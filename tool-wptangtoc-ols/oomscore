#!/bin/bash
# @author: Gia Tuấn
# @website: https://wptangtoc.com

function wptt_optimize_oom_score() {
  # 1. Bảng phân cấp Quyền Lực Hệ Thống (Càng âm càng khó chết)
  # - sshd: -1000 (Bất tử tuyệt đối, giữ đường lùi cho Sysadmin)
  # - monit: -900 (Bác sĩ quân y, người gác đền tự động hồi sinh dịch vụ)
  # - mariadb: -500 (Trái tim dữ liệu, cấm chạm vào)
  # - lshttpd: -300 (Bộ não điều phối, bảo vệ ở mức cao)
  # - redis/valkey/keydb/memcached: -200 (Lá phổi Cache, bảo vệ tốt)

  declare -A PROTECTED_SERVICES=(
    ["sshd"]="-1000"
    ["monit"]="-900"
    ["mariadb"]="-500"
    ["lshttpd"]="-300"
    ["redis"]="-200"
    ["redis-server"]="-200"
    ["keydb"]="-200"
    ["valkey"]="-200"
    ["memcached"]="-200"
  )

  echo -e "\033[1;36mĐang thiết lập lớp giáp bảo vệ khi OOM (Out Of Memory) cho các dịch vụ lõi quan trọng...\033[0m"

  for service in "${!PROTECTED_SERVICES[@]}"; do
    local score="${PROTECTED_SERVICES[$service]}"
    local dropin_dir="/etc/systemd/system/${service}.service.d"
    local conf_file="${dropin_dir}/oom-protect.conf"

    # Tối ưu: Dùng systemctl cat để check tồn tại (siêu nhanh, không cần grep)
    if systemctl cat "$service" &>/dev/null; then

      # Tạo thư mục drop-in của systemd
      mkdir -p "$dropin_dir"

      # Ghi file cấu hình ép điểm OOM
      cat >"$conf_file" <<EOF
# Cấu hình được tạo bởi WPTangToc OLS
# Bảo vệ tiến trình khỏi OOM Killer khi cạn kiệt RAM
[Service]
OOMScoreAdjust=$score
EOF
      echo -e "- Đã kích hoạt khiên bảo vệ cho \033[1;33m[$service]\033[0m với điểm số: \033[1;32m$score\033[0m"
    fi
  done

  # 2. Tải lại daemon để systemd nhận diện luật mới
  systemctl daemon-reload

  echo -e "\n\033[1;32mHoàn tất! Hệ thống đã được trang bị khả năng Auto-Healing phân cấp khi đầy RAM.\033[0m"
  echo "Khuyến nghị: Thay đổi sẽ có hiệu lực hoàn toàn sau khi khởi động lại các dịch vụ hoặc Reboot máy chủ."
}

# Thực thi hàm
wptt_optimize_oom_score
