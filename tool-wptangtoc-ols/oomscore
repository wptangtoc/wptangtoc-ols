#!/bin/bash

function wptt_optimize_oom_score() {
    # 1. Bảng phân cấp Quyền Lực Hệ Thống (Càng âm càng khó chết)
    # - sshd: -1000 (Bất tử tuyệt đối, giữ đường lùi cho Sysadmin)
    # - mariadb: -900 (Trái tim dữ liệu, cấm chạm vào)
    # - lshttpd: -500 (Bộ não điều phối, bảo vệ ở mức cao) không được dùng lsws mà phải dùng lshttpd
    # - redis / redis-server / valkey: -400 (Lá phổi Cache, bảo vệ tốt nhưng hi sinh trước nếu bắt buộc)
    # - memcached: -400 (Tương tự Redis)
    
    declare -A PROTECTED_SERVICES=(
        ["sshd"]="-1000"
        ["mariadb"]="-900"
        ["lshttpd"]="-500"
        ["redis"]="-400"
        ["redis-server"]="-400"
        ["valkey"]="-400"
        ["memcached"]="-400"
    )

    echo "Đang thiết lập lớp giáp bảo vệ khi OOM (Out Of Memory) cho các dịch vụ lõi quan trọng..."

    for service in "${!PROTECTED_SERVICES[@]}"; do
        local score="${PROTECTED_SERVICES[$service]}"
        local dropin_dir="/etc/systemd/system/${service}.service.d"
        local conf_file="${dropin_dir}/oom-protect.conf"

        # Tự động nhận diện: Dịch vụ nào có cài trên máy chủ thì mới áp dụng
        if systemctl list-unit-files | grep -q "^${service}.service"; then
            
            # Tạo thư mục drop-in của systemd
            mkdir -p "$dropin_dir"

            # Ghi file cấu hình ép điểm OOM
            cat > "$conf_file" <<EOF
# Cấu hình được tạo bởi WPTangToc OLS
# Bảo vệ tiến trình khỏi OOM Killer khi cạn kiệt RAM
[Service]
OOMScoreAdjust=$score
EOF
            echo "- Đã kích hoạt khiên bảo vệ cho [$service] với điểm số: $score"
        fi
    done

    # 2. Tải lại daemon để systemd nhận diện luật mới
    systemctl daemon-reload

    # 3. Khởi động lại nhẹ nhàng các dịch vụ đang chạy để luật có hiệu lực
	# nên khởi động lại máy chủ

    echo "Hoàn tất! Hệ thống đã được trang bị khả năng Auto-Healing phân cấp khi đầy RAM."
}

# Thực thi hàm
wptt_optimize_oom_score
