#!/bin/bash

function huong_dan() {
  Tính năng ngăn chặn truy trực tiếp http://IP địa chỉ ip của bạn
  🎯 Mục đích chính Tăng cường Bảo mật và tiết kiệm tài nguyên máy chủ
  Việc này thường hữu ích khi:
  * Chống Bot dò quét tự động: Rất nhiều bot độc hại hoạt động bằng cách quét toàn bộ các dải địa chỉ IP trên Internet để tìm kiếm các máy chủ có lỗ hổng bảo mật. Khi bạn chặn truy cập qua IP, máy chủ của bạn sẽ không phản hồi với một trang web cụ thể. Điều này khiến máy chủ của bạn trở nên vô hình trước các cuộc tấn công tự động ở mức độ cơ bản, làm giảm đáng kể bề mặt tấn công.
  * Ngăn chặn tấn công Host Header Injection: Đây là một kỹ thuật tấn công mà kẻ xấu gửi yêu cầu đến IP của bạn nhưng lại giả mạo thông tin tên miền [Host header]. Bằng cách thiết lập một quy tắc mặc định để từ chối tất cả các truy cập không có tên miền hợp lệ, bạn có thể vô hiệu hóa kiểu tấn công này.
  * Bảo vệ các trang web đang phát triển: Khi bạn đang xây dựng một trang web mới trên máy chủ nhưng chưa trỏ tên miền chính thức, việc chặn truy cập IP sẽ ngăn người ngoài xem hoặc truy cập vào trang web còn dang dở của bạn.
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null # Nạp thư viện UX Bo Cong

clear
echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}ADD-ONS ➜ Ngăn chặn truy cập trực tiếp qua IP (Anti IP-Scan)${C_RESET}"
echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

if [[ "${2:-}" == 'premium' ]]; then
  if [[ -z "$key_activate" ]]; then
    echo -e "${C_RED}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
    center_text "${C_BOLD_WHITE}⚠️ TÍNH NĂNG PREMIUM ĐỘC QUYỀN${C_RESET}"
    echo -e "${C_RED}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
    left_text "  Tính năng này chỉ dành cho người dùng WPTangToc OLS Premium." 2
    left_text "  Vui lòng kích hoạt Bản quyền (Activate Key) để mở khóa tính năng." 2
    echo -e "${C_RED}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"
    
    check_menu_wptangtoc_active=${1:-}
    if [[ "$check_menu_wptangtoc_active" == "98" ]]; then
      echo -en "${C_YELLOW}👉 Nhấn phím [Enter] để đi tới trang Kích hoạt Bản quyền...${C_RESET}"
      read -r dummy
      exec /etc/wptt/wptt-add-one-main 1
    fi
    exit 0
  fi
fi

PATH='/root/.local/bin:/root/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin'

_runing "Đang định vị địa chỉ IP Public của máy chủ..."
ip=$(curl -sf --connect-timeout 5 --max-time 10 https://ipv4.icanhazip.com | grep -E -o '(25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\.(25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\.(25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\.(25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)' || curl -sf --connect-timeout 5 --max-time 10 https://checkip.amazonaws.com | grep -E -o '(25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\.(25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\.(25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\.(25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)')

if [[ -z "$ip" ]]; then
  _runloi "Không thể lấy được địa chỉ IP Public!"
  echo -e "${C_RED}Lỗi: Vui lòng kiểm tra lại kết nối mạng của máy chủ.${C_RESET}\n"
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-add-one-main 1
  exit 1
fi
_rundone "Nhận diện IP Máy chủ: $ip"

if [[ -n "$ip_domain" ]] || [[ -d "/usr/local/lsws/$ip/html" ]]; then
  echo -e "\n${C_YELLOW}⚠️ THÔNG BÁO: Tính năng chặn truy cập IP ($ip) đã được kích hoạt từ trước!${C_RESET}\n"
  
  if [[ "${1:-}" == "98" ]]; then
    echo -en "${C_YELLOW}👉 Nhấn phím [Enter] để quay lại Menu...${C_RESET}"
    read -r dummy
    exec /etc/wptt/wptt-add-one-main 1
  fi
  exit 0
fi

# ==============================================================================
# THỰC THI KHÓA IP VÀ PHÂN QUYỀN BẢO MẬT
# ==============================================================================
echo ""
_runing "Đang khởi tạo Host ảo và rào chắn bảo vệ cho IP ($ip)..."
. /etc/wptt/domain/wptt-themwebsite "$ip" >/dev/null 2>&1

echo '<IfModule mod_rewrite.c>
RewriteCond %{REQUEST_URI} ^(.*)$
RewriteRule .* - [E=blockbot:1,L]
</IfModule>
' >"/usr/local/lsws/$ip/html/.htaccess"

# Cài thuộc tính Immutable (Không thể xóa/sửa)
chattr +i "/usr/local/lsws/$ip/html/.htaccess"
_rundone "Tạo quy tắc tường lửa (Drop Request) thành công"

_runing "Đang dọn dẹp Access Log và thắt chặt phân quyền (Root)..."
if [[ -f /usr/local/lsws/logs/access.log ]]; then
  truncate -s 0 /usr/local/lsws/logs/access.log >/dev/null 2>&1
  rm -f /usr/local/lsws/logs/access.log.*
fi

if grep -qi "Ubuntu" /etc/*release 2>/dev/null; then
  tuong_thich_nhom_litespeed="nogroup"
else
  tuong_thich_nhom_litespeed="nobody"
fi

mkdir -p /usr/local/lsws/logs
chown root:$tuong_thich_nhom_litespeed /usr/local/lsws/logs
chown root:root /usr/local/lsws
rm -f "/etc/wptt/vhost/.$ip.conf"
_rundone "Bảo vệ an toàn cấp độ thư mục hoàn tất"

_runing "Đang khởi động lại OpenLiteSpeed để nạp cấu hình..."
/usr/local/lsws/bin/lswsctrl restart >/dev/null 2>&1
_rundone "OpenLiteSpeed khởi động thành công"

echo -e "${C_GREEN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_BOLD_WHITE}HOÀN TẤT KÍCH HOẠT ANTI IP-SCAN${C_RESET}"
echo -e "${C_GREEN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
left_text "  Mục tiêu bảo vệ : ${C_YELLOW}Địa chỉ IP $ip${C_RESET}" 2
left_text "  Trạng thái      : ${C_BOLD_WHITE}Đã chặn toàn bộ truy cập bằng IP trực tiếp.${C_RESET}" 2
left_text "  Hiệu quả        : ${C_GREEN}Tàng hình trước Bot dò quét, chống Host Header Injection.${C_RESET}" 2
echo -e "${C_GREEN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

if [[ "${1:-}" == "98" ]]; then
  exec /etc/wptt/wptt-add-one-main 1
fi
