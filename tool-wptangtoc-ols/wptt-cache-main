# ==============================================================================
# 3. LOGIC XỬ LÝ (ÁNH XẠ CHUẨN 100% VỚI INDEX MỚI)
# ==============================================================================
run_action() {
  local index=$1
  local script_path=""
  local script_args="98" # Mặc định đa số dùng 98

  case $index in
  # Cột trái
  0) script_path="/etc/wptt/cache/lscache"; script_args="99" ;; # Đặc biệt: 99
  1) script_path="/etc/wptt/cache/huy-lscache" ;;
  2) script_path="/etc/wptt/domain/real-time-check"; script_args="97" ;; # Đặc biệt: 97
  3) script_path="/etc/wptt/cache/wptt-redis-valkey-keydb" ;;
  4) script_path="/etc/wptt/cache/wptt-memcached" ;;
  5) script_path="/etc/wptt/cache/wptt-opcache" ;;
  
  # Cột phải
  6) script_path="/etc/wptt/cache/wptt-xoacache" ;;
  7) script_path="/etc/wptt/cache/wptt-xoa-cache-redis-valkey-keydb" ;;
  8) script_path="/etc/wptt/cache/clear-opcache" ;;
  9) script_path="/etc/wptt/cache/wptt-setup-gioi-han-dung-luong-page-cache-html" ;;
  10) script_path="/etc/wptt/cache/cloudflare-api-cdn-cache-thiet-lap" ;;
  esac

  if [[ -x "$script_path" || -f "$script_path" ]]; then
    exec bash "$script_path" "$script_args"
  else
    echo -e "\n\033[1;31m[!] Lỗi: Không tìm thấy hoặc không thể thực thi script '$script_path'.\033[0m"
    sleep 2
    exec /etc/wptt/wptt-cache-main 1
  fi
}

