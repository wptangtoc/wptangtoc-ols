#!/bin/bash

function huong_dan() {
  Việc kiểm tra dung lượng các file lớn nhất trong mã nguồn website là một tác vụ quản trị hệ thống thiết yếu, giúp bạn xác định những tệp tin nào đang chiếm nhiều không gian nhất trên ổ cứng của máy chủ.

  🎯 Mục đích chính:
  * Giải phóng Dung lượng Ổ cứng: Khi ổ cứng đầy, việc tìm và xử lý các file lớn không cần thiết [như log cũ, backup lỗi thời, file tạm dung lượng lớn] là cách nhanh nhất để lấy lại không gian.
  * Quản lý Tài nguyên Hiệu quả: Giúp bạn hiểu rõ hơn về việc sử dụng ổ đĩa, từ đó có kế hoạch lưu trữ và dọn dẹp hợp lý.
  * Phát hiện Bất thường: Đôi khi, các file lớn bất thường có thể là dấu hiệu của một lỗi ứng dụng [ví dụ: file log ghi không kiểm soát] hoặc hoạt động không mong muốn.
  * Hỗ trợ Tối ưu hóa: Biết được file nào lớn giúp đưa ra quyết định nên xóa, nén, hay di chuyển chúng sang nơi lưu trữ khác.

  ✨ Tại sao lại quan trọng?
  * Trên một máy chủ web, đặc biệt là máy chủ được quản lý qua các script như WPTangToc OLS, việc ổ cứng bị đầy có thể dẫn đến website ngừng hoạt động, không thể tạo backup, hoặc các dịch vụ khác bị lỗi. Khả năng nhanh chóng tìm ra các thủ phạm chiếm dụng dung lượng là rất cần thiết.

  Tóm lại, kiểm tra và xác định các file lớn nhất là một kỹ năng quản trị Linux cơ bản giúp duy trì sự ổn định và hiệu quả cho máy chủ của bạn.
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null # Nạp thư viện UX Bo Cong

clear
echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}QUẢN LÝ DISK ➜ Tìm 15 File Dung Lượng Lớn Nhất Trong Website${C_RESET}"
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

if [[ "${1:-}" == '98' ]]; then
  WPTT_IN_MENU="yes"
  WPTT_MENU_BACK="/etc/wptt/wptt-disk-main 1"
fi

. /etc/wptt/tenmien 2>/dev/null

lua_chon_NAME "Kiểm tra file lớn nhất"

[[ "$NAME" == "0" || -z "$NAME" ]] && exec /etc/wptt/wptt-disk-main 1

# Kiểm tra thư mục mã nguồn tồn tại
source_path="/usr/local/lsws/$NAME/html"
if [[ ! -d "$source_path" ]]; then
  echo -e "\n${C_RED}❌ Lỗi: Thư mục mã nguồn không tồn tại ($source_path)!${C_RESET}"
  sleep 3
  exec /etc/wptt/wptt-disk-main 1
  exit 1
fi

echo ""
_runing "Đang quét sâu toàn bộ thư mục mã nguồn website $NAME..."

echo "Kiểm tra dung lượng file lớn nhất của website $NAME : $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log

# ==============================================================================
# THỰC THI LỆNH TÌM KIẾM VÀ TRÍCH XUẤT VÀO MẢNG
# ==============================================================================
# Bổ sung 2>/dev/null để tránh rác log nếu đụng file không có quyền đọc
mapfile -t large_files < <(find "$source_path" -type f -exec du -Sh {} + 2>/dev/null | sort -rh | head -n 15)

_rundone "Quét hoàn tất! Đã tìm ra các file nặng nhất của Website."

# ==============================================================================
# IN BẢNG XẾP HẠNG (LEADERBOARD UI)
# ==============================================================================
echo -e "\n${C_GREEN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_BOLD_WHITE}TOP 15 FILE NẶNG NHẤT: ${C_YELLOW}$NAME${C_RESET}"
echo -e "${C_GREEN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"

if [[ ${#large_files[@]} -eq 0 ]]; then
  left_text "  Không tìm thấy file nào trong thư mục website." 2
else
  i=1
  for line in "${large_files[@]}"; do
    # Bóc tách Size và Filepath dựa trên chuẩn Output của lệnh du
    size=$(echo "$line" | cut -f1)
    filepath=$(echo "$line" | cut -f2-)

    # Lược bỏ đoạn đường dẫn gốc (prefix) để UX dễ nhìn hơn
    filepath="${filepath#$source_path/}"

    # Căn lề số liệu dung lượng
    size_padded=$(printf "%-6s" "$size")

    # Cắt ngắn đường dẫn nếu vẫn quá dài (trên 45 ký tự)
    if [[ ${#filepath} -gt 45 ]]; then
      filepath="...${filepath: -42}"
    fi

    # In ra dòng định dạng: 1. [ 1.2G ] wp-content/uploads/2026/video.mp4
    left_text "  ${C_CYAN}$(printf "%2d" $i).${C_RESET} [${C_RED}${size_padded}${C_RESET}] ${C_BOLD_WHITE}${filepath}${C_RESET}" 2
    ((i++))
  done
fi

echo -e "${C_GREEN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

[[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-disk-main 1
