#!/bin/bash

function huong_dan() {
  Việc kiểm tra dung lượng các thư mục lớn nhất trong Linux là một tác vụ quản trị hệ thống quan trọng, giúp bạn nhanh chóng xác định những thư mục nào đang chiếm dụng nhiều không gian đĩa nhất trên máy chủ.

  🎯 Mục đích chính:
  * Xác định Nguồn Gốc Chiếm Dung Lượng: Khi ổ cứng gần đầy, việc này giúp bạn tìm ra các điểm nóng – những thư mục gốc rễ chứa nhiều dữ liệu nhất [ví dụ: thư mục backups, thư mục logs, thư mục chứa nhiều website, hoặc thư mục home của người dùng nào đó].
  * Dọn dẹp Có Mục tiêu: Thay vì tìm từng file lẻ, việc xác định thư mục lớn cho phép bạn tập trung dọn dẹp hoặc tối ưu hóa không gian lưu trữ một cách hiệu quả hơn.
  * Hiểu Cấu trúc Sử dụng Đĩa: Cung cấp cái nhìn tổng quan về cách dung lượng ổ cứng được phân bổ giữa các thư mục khác nhau.
  * Bảo trì Hệ thống Định kỳ: Là một phần của việc kiểm tra sức khỏe máy chủ, giúp ngăn chặn tình trạng hết dung lượng đột ngột.

  ✨ Tại sao lại quan trọng?
  Trên máy chủ, đặc biệt là máy chủ web được quản lý bằng các script như WPTangToc OLS, việc các thư mục [như thư mục chứa uploads, backups, hoặc logs] phình to không kiểm soát có thể nhanh chóng làm cạn kiệt dung lượng ổ cứng, ảnh hưởng đến hoạt động của website và các dịch vụ khác. Khả năng xác định nhanh các thư mục này là rất cần thiết.

  Tóm lại, kiểm tra dung lượng thư mục lớn nhất là một kỹ năng quản trị Linux cơ bản giúp bạn duy trì sự ổn định và hiệu quả cho không gian lưu trữ của máy chủ.
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null # Nạp thư viện UX Bo Cong

clear
echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}QUẢN LÝ DISK ➜ Quét Hệ Thống Tìm 15 Thư Mục Nặng Nhất${C_RESET}"
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

if [[ "${1:-}" == '98' ]]; then
  WPTT_IN_MENU="yes"
  WPTT_MENU_BACK="/etc/wptt/wptt-disk-main 1"
fi

echo -e "${C_YELLOW}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
left_text "Quá trình quét sâu toàn bộ ổ cứng (Root /) đang được diễn ra." 2
left_text "Có thể mất từ ${C_RED}1 đến 5 phút${C_RESET} tùy thuộc vào số lượng thư mục." 2
left_text "Lưu ý: Chỉ tính dung lượng các tệp nằm trực tiếp trong thư mục," 2
left_text "không cộng dồn dung lượng của các thư mục con bên trong." 2
echo -e "${C_YELLOW}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

_runing "Đang Deep Scan (Quét sâu) toàn bộ hệ thống để tìm thư mục lớn..."

echo "Kiểm tra dung lượng thư mục lớn nhất : $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log

# Loại trừ các thư mục ảo, chạy lệnh du -Sh (tách biệt dung lượng)
mapfile -t large_dirs < <(find / -not -path "/proc/*" -not -path "/sys/*" -not -path "/run/*" -not -path "/dev/*" -type d -exec du -Sh {} + 2>/dev/null | sort -rh | uniq | head -n 15)

_rundone "Quét hoàn tất! Đã xác định được các 'điểm nóng' chiếm ổ cứng."

# ==============================================================================
# IN BẢNG XẾP HẠNG (LEADERBOARD UI)
# ==============================================================================
echo -e "\n${C_GREEN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_BOLD_WHITE}TOP 15 THƯ MỤC NẶNG NHẤT TRÊN MÁY CHỦ${C_RESET}"
echo -e "${C_GREEN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"

if [[ ${#large_dirs[@]} -eq 0 ]]; then
  left_text "  Không tìm thấy thư mục nào hoặc ổ cứng hiện đang trống." 2
else
  i=1
  for line in "${large_dirs[@]}"; do
    # Bóc tách Size và Filepath dựa trên chuẩn Output của lệnh du
    size=$(echo "$line" | cut -f1)
    filepath=$(echo "$line" | cut -f2-)

    # Căn lề số liệu dung lượng (Đẩy khoảng trắng để các ngoặc vuông bằng nhau)
    size_padded=$(printf "%-6s" "$size")

    # Cắt ngắn đường dẫn nếu dài quá 45 ký tự để không làm vỡ khung Box UI
    if [[ ${#filepath} -gt 45 ]]; then
      filepath="...${filepath: -42}"
    fi

    # In ra dòng định dạng: 1. [ 2.4G ] /usr/local/lsws/logs
    left_text "  ${C_CYAN}$(printf "%2d" $i).${C_RESET} [${C_RED}${size_padded}${C_RESET}] ${C_BOLD_WHITE}${filepath}${C_RESET}" 2
    ((i++))
  done
fi

echo -e "${C_GREEN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

[[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-disk-main 1
