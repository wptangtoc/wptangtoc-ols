#!/bin/bash
function huong_dan() {
  Tính năng Kiểm tra dung lượng mã nguồn website trong WPTangToc OLS là một công cụ cho phép bạn xác định tổng kích thước [dung lượng ổ cứng] mà các tệp và thư mục của một website cụ thể đang chiếm dụng trên máy chủ.

  🎯 Mục đích chính của tính năng này:
  * Quản lý Tài nguyên Ổ cứng: Giúp bạn theo dõi xem mỗi website đang sử dụng bao nhiêu dung lượng, đặc biệt quan trọng nếu bạn có giới hạn về ổ cứng hoặc quản lý nhiều website trên cùng một máy chủ.
  * Phát hiện Thành phần Lớn: Có thể giúp bạn nhận biết nếu một website có dung lượng mã nguồn bất thường, có thể do themes/plugins nặng, hoặc các tệp không cần thiết.
  * Hỗ trợ Tối ưu hóa: Là bước đầu để xem xét việc dọn dẹp, xóa bỏ các tệp, themes, plugins không sử dụng nhằm giải phóng không gian.
  * Lập kế hoạch Sao lưu/Di chuyển: Biết được dung lượng mã nguồn giúp ước tính thời gian và không gian cần thiết cho việc sao lưu hoặc di chuyển website.

  Tóm lại, tính năng này trong WPTangToc OLS cung cấp một cách nhanh chóng và tiện lợi để bạn kiểm soát dung lượng mà phần mã nguồn của các website đang chiếm dụng trên máy chủ, hỗ trợ việc quản lý và tối ưu hóa tài nguyên hiệu quả.
}

# --- 1. SETUP BIẾN ĐẦU VÀO ---
NAME=$1
[[ $NAME == "98" ]] && NAME=""

# --- 2. GIAO DIỆN CHỌN WEBSITE ---
if [[ -z "$NAME" ]]; then
  echo -e "\n========================================================================="
  echo -e "| Quản lý disk => Kiểm tra dung lượng mã nguồn website                  |"
  echo -e "=========================================================================\n"
  . /etc/wptt/tenmien-them-lua-chon-tat-ca-website
  echo -e "\nLựa chọn website bạn muốn kiểm tra dung lượng:\n"
  lua_chon_NAME
fi

# Regex hỗ trợ tất cả định dạng backup bạn yêu cầu
BACKUP_REG=".zip$|.sql$|.sql.gz$|.tar.zst$|.tar.gz$|.sql.zst$"

if [[ "$NAME" == "Tất cả website" ]]; then

  for filepath in /etc/wptt/vhost/.*.conf; do
    [[ ! -f "$filepath" || "$filepath" == *"/..conf" ]] && continue

    # Parameter Expansion
    domain="${filepath##*/}"
    domain="${domain%.conf}"
    domain="${domain#.}"

    if [[ "$domain" == ?*.?* ]]; then
      path="/usr/local/lsws/$domain/html"
      if [[ -d "$path" ]]; then
        echo "==================================================================="
        echo "CHI TIẾT DUNG LƯỢNG WEBSITE: $domain"
        echo "-------------------------------------------------------------------"

        echo "- Mã nguồn:      $(du -hs "$path" 2>/dev/null | awk '{print $1}')B"

        # Kiểm tra Backup đa định dạng
        if [[ -d "/usr/local/backup-website/$domain" ]]; then
          if ls "/usr/local/backup-website/$domain" 2>/dev/null | grep -qE "$BACKUP_REG"; then
            echo "- File Backup:   $(du -hs "/usr/local/backup-website/$domain" 2>/dev/null | awk '{print $1}')B"
          fi
        fi

        # LiteSpeed Cache
        if [[ -d "$path/wp-content/plugins/litespeed-cache" && -d "/usr/local/lsws/$domain/luucache" ]]; then
          echo "- LScache:       $(du -hs "/usr/local/lsws/$domain/luucache" 2>/dev/null | awk '{print $1}')B"
        fi

        # Logs
        if [[ -d "/usr/local/lsws/$domain/logs" ]]; then
          echo "- Logs hệ thống: $(du -hs "/usr/local/lsws/$domain/logs" 2>/dev/null | awk '{print $1}')B"
        fi

        # Database
        if [[ -f "/etc/wptt/vhost/.$domain.conf" ]]; then
          . "/etc/wptt/vhost/.$domain.conf"
          if [[ -n "$DB_Name_web" && -d "/var/lib/mysql/$DB_Name_web" ]]; then
            echo "- Database:      $(du -hs "/var/lib/mysql/$DB_Name_web" 2>/dev/null | awk '{print $1}')B"
          fi
        fi
        echo "==================================================================="
      fi
    fi
  done

  [[ $1 == "98" ]] && exec /etc/wptt/wptt-disk-main 1
  exit
fi

# --- 4. KHỐI KIỂM TRA 1 WEBSITE CỤ THỂ ---
[[ "$NAME" == "0" || -z "$NAME" ]] && exec /etc/wptt/wptt-ma-nguon-main 1

path_conf="/etc/wptt/vhost/.$NAME.conf"
if [[ ! -f "$path_conf" ]]; then
  clear
  echo "Tên miền không tồn tại trên hệ thống này"
  sleep 2
  exec /etc/wptt/wptt-disk-main 1
  exit
fi

path="/usr/local/lsws/$NAME/html"

if [[ -d "$path" ]]; then
  echo "==================================================================="
  echo "CHI TIẾT DUNG LƯỢNG WEBSITE: $NAME"
  echo "-------------------------------------------------------------------"

  echo "- Mã nguồn:      $(du -hs "$path" 2>/dev/null | awk '{print $1}')B"

  # Kiểm tra Backup cụ thể
  if [[ -d "/usr/local/backup-website/$NAME" ]]; then
    if ls "/usr/local/backup-website/$NAME" 2>/dev/null | grep -qE "$BACKUP_REG"; then
      echo "- File Backup:   $(du -hs "/usr/local/backup-website/$NAME" 2>/dev/null | awk '{print $1}')B"
    fi
  fi

  # LScache
  if [[ -d "$path/wp-content/plugins/litespeed-cache" && -d "/usr/local/lsws/$NAME/luucache" ]]; then
    echo "- LScache:       $(du -hs "/usr/local/lsws/$NAME/luucache" 2>/dev/null | awk '{print $1}')B"
  fi

  # Logs
  if [[ -d "/usr/local/lsws/$NAME/logs" ]]; then
    echo "- Logs hệ thống: $(du -hs "/usr/local/lsws/$NAME/logs" 2>/dev/null | awk '{print $1}')B"
  fi

  # Database vật lý
  . "$path_conf"
  if [[ -n "$DB_Name_web" && -d "/var/lib/mysql/$DB_Name_web" ]]; then
    echo "- Database:      $(du -hs "/var/lib/mysql/$DB_Name_web" 2>/dev/null | awk '{print $1}')B"
  fi
  echo "==================================================================="
fi

# --- 5. ĐIỀU HƯỚNG ---
[[ $1 == "98" ]] && exec /etc/wptt/wptt-disk-main 1
