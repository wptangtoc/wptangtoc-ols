#!/bin/bash
function huong_dan() {
  Tính năng Kiểm tra dung lượng mã nguồn website trong WPTangToc OLS là một công cụ cho phép bạn xác định tổng kích thước [dung lượng ổ cứng] mà các tệp và thư mục của một website cụ thể đang chiếm dụng trên máy chủ.

  🎯 Mục đích chính của tính năng này:
  * Quản lý Tài nguyên Ổ cứng: Giúp bạn theo dõi xem mỗi website đang sử dụng bao nhiêu dung lượng, đặc biệt quan trọng nếu bạn có giới hạn về ổ cứng hoặc quản lý nhiều website trên cùng một máy chủ.
  * Phát hiện Thành phần Lớn: Có thể giúp bạn nhận biết nếu một website có dung lượng mã nguồn bất thường, có thể do themes/plugins nặng, hoặc các tệp không cần thiết.
  * Hỗ trợ Tối ưu hóa: Là bước đầu để xem xét việc dọn dẹp, xóa bỏ các tệp, themes, plugins không sử dụng nhằm giải phóng không gian.
  * Lập kế hoạch Sao lưu/Di chuyển: Biết được dung lượng mã nguồn giúp ước tính thời gian và không gian cần thiết cho việc sao lưu hoặc di chuyển website.

  Tóm lại, tính năng này trong WPTangToc OLS cung cấp một cách nhanh chóng và tiện lợi để bạn kiểm soát dung lượng mà phần mã nguồn của các website đang chiếm dụng trên máy chủ, hỗ trợ việc quản lý và tối ưu hóa tài nguyên hiệu quả.
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null # Nạp thư viện UX Bo Cong

# Regex hỗ trợ tất cả định dạng backup
BACKUP_REG="\.zip$|\.sql$|\.sql\.gz$|\.tar\.zst$|\.tar\.gz$|\.sql\.zst$"

# ==============================================================================
# HÀM TÍNH TOÁN VÀ IN DUNG LƯỢNG CHO 1 WEBSITE (TỐI ƯU CODE DRY)
# ==============================================================================
in_dung_luong_website() {
  local domain="$1"
  local path="/usr/local/lsws/$domain/html"

  [[ ! -d "$path" ]] && return 0 # Bỏ qua nếu không có thư mục mã nguồn

  # 1. Tính toán dung lượng các thành phần
  local size_source=$(du -hs "$path" 2>/dev/null | awk '{print $1}')
  local size_backup="0"
  local size_cache="0"
  local size_logs="0"
  local size_db="0"

  # Backup
  if [[ -d "/usr/local/backup-website/$domain" ]] && ls "/usr/local/backup-website/$domain" 2>/dev/null | grep -qE "$BACKUP_REG"; then
    size_backup=$(du -hs "/usr/local/backup-website/$domain" 2>/dev/null | awk '{print $1}')
  fi

  # LScache
  if [[ -d "/usr/local/lsws/$domain/luucache" ]]; then
    size_cache=$(du -hs "/usr/local/lsws/$domain/luucache" 2>/dev/null | awk '{print $1}')
  fi

  # Logs
  if [[ -d "/usr/local/lsws/$domain/logs" ]]; then
    size_logs=$(du -hs "/usr/local/lsws/$domain/logs" 2>/dev/null | awk '{print $1}')
  fi

  # Database vật lý
  if [[ -f "/etc/wptt/vhost/.$domain.conf" ]]; then
    unset DB_Name_web
    . "/etc/wptt/vhost/.$domain.conf" 2>/dev/null
    if [[ -n "$DB_Name_web" && -d "/var/lib/mysql/$DB_Name_web" ]]; then
      size_db=$(du -hs "/var/lib/mysql/$DB_Name_web" 2>/dev/null | awk '{print $1}')
    fi
  fi

  # 2. In Giao diện Box UI Bo Cong (Căn lề thẳng tắp)
  echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_BOLD_WHITE}CHI TIẾT DUNG LƯỢNG: ${C_YELLOW}$domain${C_RESET}"
  echo -e "${C_CYAN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"

  # Căn lề số liệu bằng printf để output luôn đẹp
  left_text "  - Mã nguồn (Source)     : ${C_GREEN}$(printf "%-6s" "${size_source:-0}B")${C_RESET}" 2
  left_text "  - Cơ sở dữ liệu (DB)    : ${C_GREEN}$(printf "%-6s" "${size_db:-0}B")${C_RESET}" 2
  left_text "  - Bản sao lưu (Backup)  : ${C_GREEN}$(printf "%-6s" "${size_backup:-0}B")${C_RESET}" 2
  left_text "  - Bộ nhớ đệm (LSCache)  : ${C_GREEN}$(printf "%-6s" "${size_cache:-0}B")${C_RESET}" 2
  left_text "  - Nhật ký lỗi (Logs)    : ${C_GREEN}$(printf "%-6s" "${size_logs:-0}B")${C_RESET}" 2

  echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯${C_RESET}"
}

# ==============================================================================
# XỬ LÝ ĐẦU VÀO VÀ MENU CHỌN WEBSITE
# ==============================================================================
NAME=${1:-}
[[ "$NAME" == "98" ]] && NAME=""

if [[ -z "$NAME" ]]; then
  clear
  echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_YELLOW}QUẢN LÝ DISK ➜ Kiểm tra Dung lượng Mã nguồn & Website${C_RESET}"
  echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

  . /etc/wptt/tenmien-them-lua-chon-tat-ca-website 2>/dev/null
  echo -e "${C_YELLOW}Lựa chọn Website bạn muốn kiểm tra dung lượng:${C_RESET}"
  lua_chon_NAME
fi

# Rào chắn an toàn khi người dùng thoát
[[ "$NAME" == "0" || -z "$NAME" ]] && exec /etc/wptt/wptt-disk-main 1

# ==============================================================================
# NHÁNH 1: QUÉT TẤT CẢ WEBSITE
# ==============================================================================
if [[ "$NAME" == "Tất cả website" ]]; then

  for filepath in /etc/wptt/vhost/.*.conf; do
    [[ ! -f "$filepath" || "$filepath" == *"/..conf" ]] && continue

    domain="${filepath##*/}"
    domain="${domain%.conf}"
    domain="${domain#.}"

    if [[ "$domain" == ?*.?* ]]; then
      in_dung_luong_website "$domain"
    fi
  done
  echo -en "${C_GREEN}Nhấn phím [Enter] để quay lại Menu Quản lý DISK...${C_RESET}"
  read -r
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-disk-main 1
  exit 0
fi

# ==============================================================================
# NHÁNH 2: QUÉT 1 WEBSITE CỤ THỂ
# ==============================================================================
path_conf="/etc/wptt/vhost/.$NAME.conf"
if [[ ! -f "$path_conf" ]]; then
  echo -e "\n${C_RED}❌ Lỗi: Tên miền không tồn tại trên hệ thống này!${C_RESET}"
  sleep 3
  exec /etc/wptt/wptt-disk-main 1
  exit 1
fi

in_dung_luong_website "$NAME"

[[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-disk-main 1
