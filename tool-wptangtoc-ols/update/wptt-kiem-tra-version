#!/bin/bash

function huong_dan() {
  Tính năng kiểm tra phiên bản những service quan trọng, thì đây là một chức năng chẩn đoán và thông tin rất hữu ích, giúp bạn nhanh chóng xem được các phiên bản cụ thể của các phần mềm/dịch vụ cốt lõi đang chạy trên máy chủ của bạn.

  Tính năng Kiểm tra Phiên bản Service
  Mục đích chính:
  Việc biết chính xác phiên bản của các dịch vụ là rất cần thiết cho nhiều mục đích:
  * Khắc phục sự cố [Troubleshooting]: Khi website gặp lỗi, biết phiên bản giúp xác định xem có phải do xung đột hoặc lỗi đã biết của một phần mềm cụ thể hay không.
  * Kiểm tra Tương thích: Đảm bảo rằng phiên bản máy chủ [PHP, MariaDB] đáp ứng yêu cầu của phiên bản WordPress, theme, và plugin mà bạn đang sử dụng hoặc định cài đặt.
  * Đánh giá Bảo mật: Phát hiện các dịch vụ đang chạy phiên bản cũ, có thể chứa lỗ hổng bảo mật chưa được vá.
  * Lập kế hoạch Cập nhật: Giúp bạn biết dịch vụ nào cần được nâng cấp lên phiên bản mới hơn.
  * Cung cấp Thông tin Hỗ trợ: Khi bạn cần nhờ hỗ trợ kỹ thuật, việc cung cấp chính xác các phiên bản đang dùng là thông tin cơ bản và quan trọng.

  Lợi ích khi có tính năng này trong WPTangToc OLS:
  * Tiện lợi: Chỉ cần một lệnh hoặc một tùy chọn menu để xem tất cả thông tin quan trọng, thay vì phải gõ nhiều lệnh khác nhau.
  * Nhanh chóng: Cung cấp một cái nhìn tổng quan tức thì về sức khỏe và cấu hình phần mềm của máy chủ.
  * Dễ dàng: Giúp người dùng không rành về dòng lệnh cũng có thể xem được thông tin cần thiết.

  Tóm lại: Tính năng kiểm tra phiên bản dịch vụ trong WPTangToc OLS là một công cụ chẩn đoán và cung cấp thông tin hữu ích, giúp bạn nắm rõ cấu hình phần mềm trên máy chủ, hỗ trợ đắc lực cho việc khắc phục sự cố, lên kế hoạch cập nhật và đảm bảo an ninh, tương thích cho website WordPress của bạn.
}
. /etc/wptt/echo-color
check_menu_wptangtoc_active=${1:-}
if [[ $check_menu_wptangtoc_active = "99" ]]; then
echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_BOLD_WHITE}Quản lý Update => Kiểm tra phiên bản phần mềm ${C_RESET}"
echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯${C_RESET}\n"
else
echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_BOLD_WHITE}Quản lý Service => Kiểm tra phiên bản phần mềm ${C_RESET}"
echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯${C_RESET}\n"
fi

# ==============================================================================
# KHAI BÁO BẢNG MÀU CHUẨN UI WPTANGTOC
# ==============================================================================
C_RED='\033[1;31m'
C_GREEN='\033[1;32m'
C_YELLOW='\033[1;33m'
C_CYAN='\033[1;36m'
C_BOLD_WHITE='\033[1;37m' # Màu Trắng In Đậm cho phiên bản
C_RESET='\033[0m'
box_inner_width=78

# clear
echo -e "${C_YELLOW}Đang quét thông tin phiên bản hệ thống, vui lòng chờ trong giây lát...${C_RESET}"

. /etc/wptt/.wptt.conf 2>/dev/null

# ==============================================================================
# ĐỘNG CƠ THU THẬP DỮ LIỆU
# ==============================================================================
# LiteSpeed
openlitespeed_check_version=$(/usr/local/lsws/bin/lshttpd -v 2>/dev/null | grep -i LiteSpeed | cut -d'/' -f2 | cut -d' ' -f1 || echo "Chưa cài đặt")

# PHP kiểm tra phiên bản kiểu này thì đúng tuyệt đối rất ổn định
php_version=$(php -r 'echo PHP_MAJOR_VERSION.".".PHP_MINOR_VERSION.".".PHP_RELEASE_VERSION;' 2>/dev/null)

# MariaDB
database=$(mariadb --version 2>/dev/null | grep -oP '[0-9]+\.[0-9]+\.[0-9]+' | head -1 || echo "Chưa cài đặt")

# Fail2ban
fail2ban=$(fail2ban-client --version 2>/dev/null | awk '{print $2}' | sed 's/v//' || echo "Chưa cài đặt")

# OS
hedieuhanh=$(grep '^PRETTY_NAME=' /etc/os-release | cut -d'"' -f2 || echo "Không xác định")

# Trình Shell (Nhận diện Bash hoặc Zsh & Cắt gọn phiên bản)
user_shell=$(basename "$SHELL" 2>/dev/null)
if [[ "$user_shell" == "zsh" ]]; then
  shell_ver="Zsh $(zsh --version 2>/dev/null | awk '{print $2}')"
elif [[ "$user_shell" == "bash" ]]; then
  # Dùng cut -d'(' -f1 để loại bỏ phần (1)-release rườm rà phía sau
  shell_ver="Bash $(bash --version 2>/dev/null | head -n1 | awk '{print $4}' | cut -d'(' -f1)"
else
  shell_ver="${user_shell:-Không xác định}"
fi

# Trình cURL
curl_ver=$(curl --version 2>/dev/null | head -n 1 | awk '{print $2}' || echo "Chưa cài đặt")

# OpenSSL
openssl_ver=$(command -v openssl >/dev/null 2>&1 && openssl version 2>/dev/null | awk '{print $2}' || echo "Chưa cài đặt")

# WP-CLI
wp_cli=$(wp cli version --allow-root 2>/dev/null | awk '{print $2}' || echo "Chưa cài đặt")

# Kernel
kern=$(uname -r | cut -d '-' -f1)

# Firewall
if command -v csf >/dev/null 2>&1; then
  tuong_lua="CSF $(csf -v 2>/dev/null | head -n1 | awk '{print $1, $2}' | tr -d ':')"
elif command -v firewall-cmd >/dev/null 2>&1 && systemctl is-active --quiet firewalld; then
  tuong_lua="Firewalld $(firewall-cmd --version 2>/dev/null)"
elif command -v ufw >/dev/null 2>&1 && systemctl is-active --quiet ufw; then
  tuong_lua="UFW $(ufw --version 2>/dev/null | head -1 | awk '{print $2}')"
else
  tuong_lua="Iptables / Chưa bật"
fi

# Nhận diện Hệ sinh thái Caching
redis=$(command -v redis-server >/dev/null 2>&1 && redis-server -v 2>/dev/null | awk '{print $3}' | sed 's/v=//' || echo "Chưa cài đặt")
valkey=$(command -v valkey-server >/dev/null 2>&1 && valkey-server -v 2>/dev/null | awk '{print $3}' | sed 's/v=//' || echo "Chưa cài đặt")
keydb=$(command -v keydb-server >/dev/null 2>&1 && keydb-server -v 2>/dev/null | awk '{print $3}' | sed 's/v=//' || echo "Chưa cài đặt")
memcached=$(command -v memcached >/dev/null 2>&1 && memcached -V 2>/dev/null | head -n 1 | awk '{print $2}' || echo "Chưa cài đặt")

# Nhận diện các Service vận hành Webserver quan trọng khác
monit_ver=$(command -v monit >/dev/null 2>&1 && monit -V 2>/dev/null | awk 'NR==1 {print $5}' || echo "Chưa cài đặt")
imagemagick=$(command -v convert >/dev/null 2>&1 && convert -version 2>/dev/null | head -n 1 | awk '{print $3}' || echo "Chưa cài đặt")

# OpenSSH Server
openssh=$(ssh -V 2>&1 | head -n 1 | awk '{print $1}' | cut -d'_' -f2 | tr -d ',' || echo "Chưa cài đặt")

# ==============================================================================
# HÀM RENDER GIAO DIỆN TỰ CĂN CHỈNH
# ==============================================================================
center_text() {
  local text="$1"
  local clean_text=$(echo -e "$text" | sed "s/\x1B\[[0-9;]*[a-zA-Z]//g")
  local text_len=${#clean_text}
  if ((text_len >= box_inner_width)); then
    printf "${C_CYAN}│${C_RESET} %b ${C_CYAN}│${C_RESET}\n" "$text"
    return
  fi
  local pad_left=$(((box_inner_width - text_len) / 2))
  local pad_right=$((box_inner_width - text_len - pad_left))
  printf "${C_CYAN}│${C_RESET}%*s%b%*s${C_CYAN}│${C_RESET}\n" "$pad_left" "" "$text" "$pad_right" ""
}

print_row() {
  local col1="$1"
  # TUYỆT KỸ 1: Dọn sạch mọi ký tự \r \n tàng hình
  local col2=$(echo -e "$2" | tr -d '\r\n')

  # Đổ màu thông minh: Nếu chưa cài đặt thì báo Vàng, nếu có thì Trắng In Đậm
  local val_color=$C_BOLD_WHITE
  if [[ "$col2" == "Chưa cài đặt" || "$col2" == "Không xác định" || "$col2" == "Iptables / Chưa bật" ]]; then
    val_color=$C_YELLOW
  fi

  # TUYỆT KỸ 2: Tự động đếm Ký tự (Chống lỗi Byte của Tiếng Việt) và bù khoảng trắng
  local len_col1=${#col1}
  local pad1=$((25 - len_col1))
  [[ $pad1 -lt 0 ]] && pad1=0

  local clean_col2=$(echo -e "$col2" | sed "s/\x1B\[[0-9;]*[a-zA-Z]//g")
  local len_col2=${#clean_col2}
  local pad2=$((41 - len_col2))
  [[ $pad2 -lt 0 ]] && pad2=0

  # In ra kết quả với khoảng trắng được bơm trực tiếp, 100% không xê dịch!
  echo -e "${C_CYAN}│${C_RESET} ${col1}$(printf '%*s' "$pad1" "") : ${val_color}${col2}${C_RESET}$(printf '%*s' "$pad2" "") ${C_CYAN}│${C_RESET}"
}

# ==============================================================================
# XUẤT GIAO DIỆN HIỂN THỊ
# ==============================================================================
clear
echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"

check_menu_wptangtoc_active=${1:-}
if [[ $check_menu_wptangtoc_active = "99" ]]; then
  center_text "${C_YELLOW}Quản lý Update ➜ Kiểm tra phiên bản phần mềm${C_RESET}"
else
  center_text "${C_YELLOW}Quản lý Service ➜ Kiểm tra phiên bản phần mềm${C_RESET}"
fi

echo -e "${C_CYAN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
center_text "${C_GREEN}KẾT QUẢ QUÉT THÔNG TIN HỆ THỐNG${C_RESET}"
echo -e "${C_CYAN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"

print_row "WPTangToc OLS" "${version_wptangtoc_ols:-Không xác định}"
print_row "LiteSpeed Web Server" "$openlitespeed_check_version"
print_row "MariaDB Server" "$database"
print_row "PHP (CLI)" "$php_version"
print_row "Trình Shell (Terminal)" "$shell_ver"
print_row "Hệ điều hành (OS)" "$hedieuhanh"
print_row "Kernel Linux Core" "$kern"
print_row "OpenSSH Server" "$openssh"
print_row "OpenSSL Library" "$openssl_ver"
print_row "Fail2Ban" "$fail2ban"
print_row "WP-CLI" "$wp_cli"
print_row "Trình cURL" "$curl_ver"
print_row "Tường lửa (Firewall)" "$tuong_lua"

# Hiển thị các tính năng nâng cao (Chỉ in ra khi CÓ cài đặt để bảng đỡ rối)
if [[ "$imagemagick" != "Chưa cài đặt" ]]; then
  print_row "ImageMagick (WP Image)" "$imagemagick"
fi

if [[ "$monit_ver" != "Chưa cài đặt" ]]; then
  print_row "Monit System Monitor" "$monit_ver"
fi

# Hiển thị hệ sinh thái Object Cache đang dùng
if [[ "$redis" != "Chưa cài đặt" ]]; then
  print_row "Redis Object Cache" "$redis"
fi
if [[ "$valkey" != "Chưa cài đặt" ]]; then
  print_row "Valkey Object Cache" "$valkey"
fi
if [[ "$keydb" != "Chưa cài đặt" ]]; then
  print_row "KeyDB Object Cache" "$keydb"
fi
if [[ "$memcached" != "Chưa cài đặt" ]]; then
  print_row "Memcached Object Cache" "$memcached"
fi

echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯${C_RESET}"

# ==============================================================================
# HỖ TRỢ TRẢI NGHIỆM ĐỌC & QUAY LẠI MENU
# ==============================================================================
echo -en "\n${C_GREEN}Nhấn phím [Enter] để quay lại Menu...${C_RESET}"
read -r # Dừng lại để người dùng xem kết quả

if [[ $check_menu_wptangtoc_active = "98" ]]; then
  exec /etc/wptt/wptt-service-main 1
fi
if [[ $check_menu_wptangtoc_active = "99" ]]; then
  exec /etc/wptt/wptt-update-main 1
fi
