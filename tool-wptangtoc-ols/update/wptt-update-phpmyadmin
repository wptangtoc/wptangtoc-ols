#!/bin/bash
# @author: Gia Tuấn
# @website: https://wptangtoc.com
# @since: 2026

function huong_dan() {
  Tính năng Cập nhật phpMyAdmin là quá trình nâng cấp phiên bản phần mềm phpMyAdmin [công cụ quản lý cơ sở dữ liệu MySQL/MariaDB qua giao diện web] mà bạn đang sử dụng lên một phiên bản mới hơn do nhà phát triển phát hành.

  Nói một cách đơn giản, đây là việc bạn lên đời cho công cụ phpMyAdmin của mình để nó có những tính năng mới nhất, bản vá lỗi và quan trọng nhất là các cập nhật bảo mật.

  Mục Đích Chính [Rất Quan Trọng]:
  * Bảo mật [Quan trọng nhất]: Vá các lỗ hổng bảo mật được phát hiện trong phiên bản cũ.
  * Tính năng mới và cải tiến: Giao diện người dùng được cải thiện, hiệu suất tốt hơn.
  * Sửa lỗi [Bug Fixes]: Khắc phục các lỗi ổn định từ phiên bản trước.
  * Đảm bảo tương thích: Tương thích tốt hơn với các phiên bản PHP và MySQL/MariaDB mới.

  Sau khi cập nhật, cài đặt phpMyAdmin của bạn sẽ được nâng cấp lên phiên bản mới hơn, mang lại các cải tiến về bảo mật và tính năng.
}

. /etc/wptt/.wptt.conf
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh
. /etc/wptt/echo-color

check_menu_wptangtoc_active=$1
clear
echo ""
if [[ "$check_menu_wptangtoc_active" == "98" ]]; then
  echo "========================================================================="
  echo "|$quan_ly_update => $cap_nhat PhpMyAdmin                                 |"
  echo "========================================================================="
elif [[ "$check_menu_wptangtoc_active" == "97" ]]; then
  echo "========================================================================="
  echo "|$quan_ly_phpmyadmin => $cap_nhat PhpMyAdmin                               |"
  echo "========================================================================="
fi
echo ""

# Kiểm tra sự tồn tại của phpMyAdmin trước khi update
if [[ -z "$id_dang_nhap_phpmyadmin" || ! -d "/usr/local/lsws/$Website_chinh/html/phpmyadmin" ]]; then
  echoDo "$ban_chua_kich_hoat PhpMyAdmin"
  sleep 3
  exec /etc/wptt/wptt-phpmyadmin-main 1
  exit
fi

# ==============================================================================
# KIỂM TRA PHIÊN BẢN HIỆN TẠI
# ==============================================================================
check_version=$(ls "/usr/local/lsws/$Website_chinh/html/phpmyadmin" 2>/dev/null | grep 'RELEASE-DATE-' | sed 's/RELEASE-DATE-//g')
phpmyadmin_version="5.2.3"

if [[ "$check_version" == "$phpmyadmin_version" ]]; then
  echo -e "\033[1;32m$ban_dang_su_dung_phien_ban_moi_nhat ($phpmyadmin_version)\033[0m"
  sleep 2
  [[ "$check_menu_wptangtoc_active" == "97" ]] && exec /etc/wptt/wptt-phpmyadmin-main 1
  [[ "$check_menu_wptangtoc_active" == "98" ]] && exec /etc/wptt/wptt-update-main 1
  exit
fi

# ==============================================================================
# XÁC NHẬN TỪ NGƯỜI DÙNG
# ==============================================================================
echo -e "Phiên bản hiện tại: \033[1;31m${check_version:-Không rõ}\033[0m"
echo -e "Phiên bản mới nhất: \033[1;32m$phpmyadmin_version\033[0m"
echo ""
echo "$xac_nhan $ban_co_muon update PhpMyadmin? "

prompt="$nhap_lua_chon_cua_ban [1-2]: "
dongy="n"
options=("$dong_y" "$khong_dong_y")
PS3="$prompt"
select opt in "${options[@]}"; do
  case "$REPLY" in
  1)
    dongy="y"
    break
    ;;
  2)
    dongy="n"
    break
    ;;
  *)
    printf "\n$ban_nhap_sai_he_thong_se_chon_khong_dong_y\n"
    break
    ;;
  esac
done

if [[ "$dongy" == "y" ]]; then
  UI_STRING="$cap_nhat PhpMyadmin $phien_ban $phpmyadmin_version"
  _runing "$UI_STRING"

  # 1. Khai báo môi trường
  if grep -qi "ubuntu" /etc/os-release 2>/dev/null; then
    tuong_thich_nhom_litespeed="nogroup"
  else
    tuong_thich_nhom_litespeed="nobody"
  fi

  if [[ -f "/usr/local/lsws/admin/fcgi-bin/admin_php" ]]; then
    PHP_Command="/usr/local/lsws/admin/fcgi-bin/admin_php"
  else
    PHP_Command="/usr/local/lsws/admin/fcgi-bin/admin_php5"
  fi

  # 2. Tải bản mới về thư mục tạm (An toàn hơn)
  tmp_dir=$(mktemp -d)
  cd "$tmp_dir" || exit 1

  wget "https://files.phpmyadmin.net/phpMyAdmin/$phpmyadmin_version/phpMyAdmin-$phpmyadmin_version-all-languages.zip" >/dev/null 2>&1

  if [[ ! -f "phpMyAdmin-$phpmyadmin_version-all-languages.zip" ]]; then
    wget "https://files.phpmyadmin.net/phpMyAdmin/$phpmyadmin_version/phpMyAdmin-$phpmyadmin_version-all-languages.zip" --no-check-certificate >/dev/null 2>&1
  fi

  if [[ ! -f "phpMyAdmin-$phpmyadmin_version-all-languages.zip" ]]; then
    git_version="${phpmyadmin_version//./_}"
    wget -O "phpMyAdmin-$phpmyadmin_version-all-languages.zip" "https://github.com/phpmyadmin/phpmyadmin/archive/refs/tags/RELEASE_${git_version}.zip" >/dev/null 2>&1
  fi

  if [[ ! -f "phpMyAdmin-$phpmyadmin_version-all-languages.zip" ]]; then
    _runloi "Không thể tải bản cập nhật phpMyAdmin từ các nguồn!"
    rm -rf "$tmp_dir"
    exit 1
  fi

  # 3. Giải nén và chuẩn bị
  unzip -q "phpMyAdmin-$phpmyadmin_version-all-languages.zip"
  mv phpMyAdmin-$phpmyadmin_version-all-languages phpmyadmin_new

  # 4. Tráo đổi thư mục (Atomic Update)
  rm -rf "/usr/local/lsws/phpmyadmin" # Xóa thư mục temp cũ của lsws
  mkdir -p /usr/local/lsws/phpmyadmin

  # Thay thế thư mục chính trong html
  rm -rf "/usr/local/lsws/$Website_chinh/html/phpmyadmin"
  mv "$tmp_dir/phpmyadmin_new" "/usr/local/lsws/$Website_chinh/html/phpmyadmin"

  # 5. Cấu hình lại file config.inc.php
  target_config="/usr/local/lsws/$Website_chinh/html/phpmyadmin/config.inc.php"
  cp -f "/usr/local/lsws/$Website_chinh/html/phpmyadmin/config.sample.inc.php" "$target_config"

  secret=$(date | md5sum | cut -c '1-32')
  sed -i "s/\$cfg\['blowfish_secret'\] = '';/\$cfg\['blowfish_secret'\] = '$secret';/" "$target_config"
  echo "\$cfg['TempDir'] = '/usr/local/lsws/phpmyadmin';" >>"$target_config"

  # 6. Phân quyền
  chown -R nobody:$tuong_thich_nhom_litespeed /usr/local/lsws/phpmyadmin
  chown -R nobody:$tuong_thich_nhom_litespeed "/usr/local/lsws/$Website_chinh/html/phpmyadmin"
  chmod 555 /usr/local/lsws/phpmyadmin

  # 7. Dọn dẹp
  rm -rf "$tmp_dir"
  /usr/local/lsws/bin/lswsctrl reload >/dev/null 2>&1

  echo "Cập nhật PhpMyAdmin lên $phpmyadmin_version: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log
  _rundone "$UI_STRING"

  echo -e "\n\033[1;32m[OK] phpMyAdmin đã được nâng cấp lên bản $phpmyadmin_version thành công!\033[0m"
fi

# Quay lại menu cũ
if [[ "$check_menu_wptangtoc_active" == "97" ]]; then
  exec /etc/wptt/wptt-phpmyadmin-main 1
elif [[ "$check_menu_wptangtoc_active" == "98" ]]; then
  exec /etc/wptt/wptt-update-main 1
fi
