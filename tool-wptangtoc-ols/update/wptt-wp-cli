function huong_dan() {
  tính năng cập nhật WP-CLI thì đây là một chức năng tiện ích giúp bạn dễ dàng nâng cấp WP-CLI [WordPress Command-Line Interface] lên phiên bản mới nhất ngay trên máy chủ của mình.

  🎯 Mục đích của tính năng cập nhật WP-CLI:
  * Sử dụng Tính năng Mới: WP-CLI liên tục được phát triển. Các bản cập nhật mang đến các lệnh mới, tùy chọn mới và cải tiến hiệu suất, giúp bạn quản lý WordPress hiệu quả hơn.
  * Vá lỗi &
  Tăng Ổn định: Các phiên bản mới sửa các lỗi được phát hiện trong các phiên bản cũ, giúp WP-CLI hoạt động ổn định và đáng tin cậy hơn.
  * Bảo mật: Đôi khi, các bản cập nhật cũng bao gồm các bản vá bảo mật cho chính công cụ WP-CLI.
  * Đảm bảo Tương thích: Giữ cho WP-CLI tương thích tốt nhất với các phiên bản WordPress mới nhất, PHP và môi trường máy chủ.

  Tóm lại: Tính năng cập nhật WP-CLI trong WPTangToc OLS là một tiện ích giúp bạn đảm bảo rằng công cụ dòng lệnh WP-CLI trên máy chủ của mình luôn là phiên bản mới nhất, giúp bạn tiếp cận các tính năng, bản vá lỗi và cải tiến bảo mật mới nhất một cách dễ dàng.
}

if [[ $1 = '98' ]]; then
  echo ""
  echo ""
  echo ""
  echo "========================================================================="
  echo "| Quản lý cập nhật Update => Cập nhật WP-CLI                            |"
  echo "========================================================================="
  echo ""
  echo ""
fi

. /etc/wptt/echo-color

# =========================================================
# KIỂM TRA VÀ CÀI ĐẶT MỚI (NẾU CHƯA CÓ)
# =========================================================
if ! command -v wp >/dev/null 2>&1; then
  echo -e "\e[33m[*] Hệ thống chưa có WP-CLI. Đang tiến hành cài đặt mới...\e[0m"

  # Tải trực tiếp vào /usr/local/bin để tránh rác thư mục hiện tại
  if curl -sL https://raw.githubusercontent.com/wp-cli/builds/gh-pages/phar/wp-cli.phar -o /usr/local/bin/wp; then
    chmod +x /usr/local/bin/wp
    echo -e "\e[32m[OK] Đã tiến hành cài đặt WP-CLI thành công!\e[0m"
  else
    # Fallback cho hệ thống không dùng /usr/local/bin
    if curl -sL https://raw.githubusercontent.com/wp-cli/builds/gh-pages/phar/wp-cli.phar -o /usr/bin/wp; then
      chmod +x /usr/bin/wp
      echo -e "\e[32m[OK] Đã tiến hành cài đặt WP-CLI thành công!\e[0m"
    else
      echo -e "\e[31m[LỖI] Cài đặt WP-CLI thất bại. Vui lòng kiểm tra lại kết nối mạng!\e[0m"
      check_menu_wptangtoc_active=${1:-}
      if [[ $check_menu_wptangtoc_active = "98" ]]; then
        exec /etc/wptt/wptt-update-main 1
      fi
      return 2>/dev/null || exit 1
    fi
  fi

  # Nếu vừa cài mới xong, bỏ qua bước Update bên dưới
  check_menu_wptangtoc_active=${1:-}
  if [[ $check_menu_wptangtoc_active = "98" ]]; then
    exec /etc/wptt/wptt-update-main 1
  fi
  return 2>/dev/null || exit 0
fi

# =========================================================
# QUY TRÌNH NÂNG CẤP WP-CLI (Dành cho máy đã cài)
# =========================================================

# Dùng lệnh gốc của wp-cli để lấy phiên bản chuẩn xác, thêm --allow-root để không báo lỗi rác
CURRENT_VER=$(wp cli version --allow-root 2>/dev/null | awk '{print $2}')
echo -e "Phiên bản WP-CLI hiện tại của bạn là: \e[36m$CURRENT_VER\e[0m"
echo -e "\e[33mĐang tiến hành kiểm tra và cập nhật WP-CLI, vui lòng đợi...\e[0m"

# Chạy lệnh update (Thêm cờ --yes để tự động xác nhận, --allow-root chặn cảnh báo)
wp cli update --yes --allow-root >/dev/null 2>&1

# Kiểm tra lại phiên bản sau khi chạy lệnh
NEW_VER=$(wp cli version --allow-root 2>/dev/null | awk '{print $2}')

if [[ "$CURRENT_VER" == "$NEW_VER" ]]; then
  echo -e "\e[32m[✓] Hiện tại bạn đã sử dụng phiên bản WP-CLI mới nhất rồi ($NEW_VER).\e[0m"
else
  echoDone "Cập nhật thành công WP-CLI từ phiên bản $CURRENT_VER lên $NEW_VER"
fi

# =========================================================
# ĐIỀU HƯỚNG MENU
# =========================================================
check_menu_wptangtoc_active=${1:-}
if [[ $check_menu_wptangtoc_active = "98" ]]; then
  exec /etc/wptt/wptt-update-main 1
fi
