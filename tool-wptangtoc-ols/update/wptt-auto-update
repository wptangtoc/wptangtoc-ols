#!/bin/bash
# @author: Gia Tuấn
# @website: https://wptangtoc.com
# @since: 2025

function huong_dan() {
  Tính năng Thiết lập tự động cập nhật WPTangToc OLS là tự động cập nhật lên phiên bản mới nhất khi chúng được phát hành mà không cần bạn can thiệp thủ công.

  Mục Đích Chính
  * Bảo mật: Đây thường là lý do quan trọng nhất. Các bản cập nhật thường xuyên vá các lỗ hổng bảo mật.
  * Tính năng mới và cải tiến: Các phiên bản mới thường mang đến những chức năng mới, cải thiện hiệu suất và sửa lỗi.
  * Sửa lỗi: Khắc phục các vấn đề đã được phát hiện ở phiên bản trước.
  * Đảm bảo tương thích: Giữ cho các công cụ tăng tốc tương thích với phiên bản WordPress mới nhất, PHP, hoặc máy chủ OpenLiteSpeed.
  * Tiện lợi, giảm công sức quản trị: Bạn không cần phải tự mình kiểm tra và cập nhật thủ công thường xuyên.
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null # Nạp thư viện UX Bo Cong

clear
echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}QUẢN LÝ CẬP NHẬT ➜ Thiết lập Tự động Update WPTangToc OLS${C_RESET}"
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

if [[ "${1:-}" == '98' ]]; then
  WPTT_IN_MENU="yes"
  WPTT_MENU_BACK="/etc/wptt/wptt-update-main 1"
fi

CRON_FILE="/etc/cron.d/wptangtoc-ols.cron"

# Hàm chuyển đổi số thứ sang Text hiển thị (Đồng bộ với wptt-times-tuan)
get_day_name() {
  case "$1" in
  0 | 7) echo "Chủ nhật hàng tuần" ;;
  1) echo "Thứ hai hàng tuần" ;;
  2) echo "Thứ ba hàng tuần" ;;
  3) echo "Thứ tư hàng tuần" ;;
  4) echo "Thứ năm hàng tuần" ;;
  5) echo "Thứ sáu hàng tuần" ;;
  6) echo "Thứ bảy hàng tuần" ;;
  *) echo "Hàng ngày" ;;
  esac
}

# ==============================================================================
# KIỂM TRA TRẠNG THÁI HIỆN TẠI VÀ IN BẢNG THÔNG BÁO
# ==============================================================================
echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
if [[ -f "$CRON_FILE" ]]; then

  # Đọc file Cron chuẩn xác bất chấp số lượng dấu cách
  read -r c_phut c_gio c_ngay c_thang c_thu c_user c_cmd <"$CRON_FILE"

  # Phân tích ngày tháng
  if [[ "$c_ngay" != "*" && "$c_thu" == "*" ]]; then
    thu_text="Ngày $c_ngay hàng tháng"
  elif [[ "$c_thu" == "*" ]]; then
    thu_text="Hàng ngày"
  else
    thu_text=$(get_day_name "$c_thu")
  fi

  # Format thời gian đẹp (VD: 01:00)
  time_format=$(printf "%02d:%02d" "${c_gio:-0}" "${c_phut:-0}")

  left_text "Trạng thái    : ${C_GREEN}ĐÃ KÍCH HOẠT${C_RESET}" 2
  left_text "Lịch trình    : ${C_YELLOW}Lúc $time_format, $thu_text${C_RESET}" 2
  echo -e "${C_CYAN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
  left_text "Hệ thống sẽ tự động tải về và nâng cấp phiên bản lõi" 2
  left_text "WPTangToc OLS mới nhất (Cam kết 100% không Downtime)." 2
else
  left_text "Trạng thái    : ${C_RED}CHƯA KÍCH HOẠT${C_RESET}" 2
  echo -e "${C_CYAN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
  left_text "Nên bật tính năng này để hệ thống luôn nhận được các bản vá" 2
  left_text "bảo mật, sửa lỗi và các tính năng tối ưu mới nhất." 2
fi
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

# ==============================================================================
# NHÁNH 1: ĐÃ KÍCH HOẠT -> HỎI ĐỂ TẮT (DISABLE)
# ==============================================================================
if [[ -f "$CRON_FILE" ]]; then
  if wptt_xac_nhan "Tính năng Tự động Cập nhật OLS đang bật. Bạn có muốn TẮT không?" "" "" "Đồng ý Tắt" "Giữ nguyên (Hủy)"; then
    echo ""
    _runing "Đang gỡ bỏ cấu hình tự động cập nhật..."
    rm -f "$CRON_FILE"
    rm -f /etc/cron.d/wptangtoc-ols_cron 2>/dev/null

    if grep -qi "ubuntu" /etc/os-release 2>/dev/null; then
      systemctl restart cron.service
    else
      systemctl restart crond.service
    fi
    _rundone "Đã TẮT tính năng Tự động Cập nhật WPTangToc OLS!"
    sleep 2
  else
    echo -e "${C_YELLOW}Đã hủy thao tác.${C_RESET}\n"
  fi

  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-update-main 1
  exit 0
fi

# ==============================================================================
# NHÁNH 2: CHƯA KÍCH HOẠT -> TIẾN HÀNH THIẾT LẬP (ENABLE)
# ==============================================================================
echo -e "${C_YELLOW}Thiết lập Lịch trình Tự động cập nhật WPTangToc OLS:${C_RESET}"
echo -en "${C_CYAN}Nhập Giờ bạn muốn chạy (Từ 0 đến 23) [Mặc định: 1h sáng]: ${C_RESET}"
read gio

if ! [[ "$gio" =~ ^[0-9]+$ ]] || ((gio < 0 || gio > 23)); then
  echo -e "${C_YELLOW}⚠️ Nhập không hợp lệ. Hệ thống tự chọn 1h sáng.${C_RESET}"
  gio="1"
fi

# GỌI THƯ VIỆN WPTT-TIMES-TUAN ĐỂ IN GIAO DIỆN CHỌN NGÀY
. /etc/wptt/wptt-times-tuan
tuan

# Để tránh tải nặng server update của WPTangToc, có thể gắn random phút
phut=$(shuf -i1-59 -n1 2>/dev/null)
[[ -z "$phut" ]] && phut='0'

# Khởi tạo lệnh mặc định cho hàng tuần/hàng ngày
cron_thuc_thi="$phut $gio * * $thu"
thu_text=$(get_day_name "$thu")

# Bắt sự kiện nếu chọn Số 9 (Hàng tháng) từ thư viện
if [[ "$thu" == "9" ]]; then
  cron_thuc_thi="$phut $gio $ngay_cua_thang * *"
  thu_text="Ngày $ngay_cua_thang hàng tháng"
fi

echo ""
if wptt_xac_nhan "Chốt Lịch: Hệ thống sẽ tự động Cập nhật lúc $gio:$phut, $thu_text." "Cam kết không Downtime máy chủ." "" "Đồng ý Kích hoạt" "Hủy bỏ"; then

  _runing "Đang lưu lịch trình Cronjob vào hệ thống..."
  cat >"$CRON_FILE" <<EOF
$cron_thuc_thi root /etc/wptt/wptt-update-wptangtoc-ols >/dev/null 2>&1
EOF

  if grep -qi "ubuntu" /etc/os-release 2>/dev/null; then
    ln -sf "$CRON_FILE" /etc/cron.d/wptangtoc-ols_cron
    systemctl restart cron.service
  else
    systemctl restart crond.service
  fi
  _rundone "Cấu hình lịch trình hoàn tất"

  time_format=$(printf "%02d:%02d" "${gio:-0}" "${phut:-0}")

  echo -e "\n${C_GREEN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_BOLD_WHITE}HOÀN TẤT THIẾT LẬP TỰ ĐỘNG CẬP NHẬT${C_RESET}"
  echo -e "${C_GREEN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
  left_text "Lịch trình  : ${C_YELLOW}Lúc $time_format, $thu_text${C_RESET}" 2
  left_text "Hành động   : Tự động tải và áp dụng bản vá WPTangToc OLS mới nhất" 2
  echo -e "${C_GREEN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"
else
  echo -e "${C_YELLOW}Đã hủy thao tác.${C_RESET}\n"
fi

[[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-update-main 1
