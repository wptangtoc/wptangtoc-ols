#!/bin/bash

function huong_dan() {
  Rollback System: Cỗ máy thời gian cho WPTangToc OLS. Cho phép bạn quay lại phiên bản cũ ngay lập tức nếu bản cập nhật mới gặp lỗi hoặc không ưng ý.

  An tâm tuyệt đối khi cập nhật! Tính năng Rollback sẽ tự động sao lưu hệ thống trước khi nâng cấp. Bạn có thể khôi phục lại phiên bản ổn định trước đó bất cứ lúc nào chỉ với một phím bấm.
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null # Nạp thư viện UX Bo Cong

clear
echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}QUẢN LÝ CẬP NHẬT ➜ Khôi phục Hệ thống (Rollback WPTangToc OLS)${C_RESET}"
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

if [[ "${1:-}" == '98' ]]; then
  WPTT_IN_MENU="yes"
  WPTT_MENU_BACK="/etc/wptt/wptt-update-main 1"
fi

# ==============================================================================
# KIỂM TRA FILE BACKUP TỒN TẠI
# ==============================================================================
backup_files=($(ls -At /etc/wptt/wptt-backup-system/ 2>/dev/null | grep '\.zip$' | grep '^wptt_backup_'))

if [[ ${#backup_files[@]} -eq 0 ]]; then
  echo -e "${C_RED}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_BOLD_WHITE}LỖI: KHÔNG TÌM THẤY BẢN SAO LƯU NÀO${C_RESET}"
  echo -e "${C_RED}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
  left_text "Hệ thống chưa có file Backup (.zip) nào để thực hiện Rollback." 2
  left_text "File Backup sẽ được tự động tạo ra mỗi khi bạn Update." 2
  echo -e "${C_RED}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"
  sleep 3
  exec /etc/wptt/wptt-update-main 1
  exit 1
fi

echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}DANH SÁCH BẢN SAO LƯU (BACKUP) CÓ SẴN${C_RESET}"
echo -e "${C_CYAN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"

i=1
for file in "${backup_files[@]}"; do
  # Bóc tách Phiên bản và Thời gian từ tên file
  # VD: wptt_backup_14_15_04_2026_version:7.1.1.5.zip
  ver=$(echo "$file" | cut -f2 -d ':' | sed 's/\.zip//g')
  time_raw=$(echo "$file" | sed 's/wptt_backup_//g' | cut -f1 -d ':' | sed 's/_version//g')

  # Dùng IFS để cắt chuỗi 14_15_04_2026 thành các biến an toàn
  IFS='_' read -r gio ngay thang nam <<<"$time_raw"

  left_text "  ${C_CYAN}$i)${C_RESET} ${C_BOLD_WHITE}Phiên bản $ver${C_RESET} (Sao lưu lúc ${gio}h, ngày $ngay/$thang/$nam)" 2
  ((i++))
done
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯${C_RESET}"

# Vòng lặp lấy Input
while true; do
  echo -en "${C_CYAN}Nhập lựa chọn của bạn (1-${#backup_files[@]}) [0=Thoát]: ${C_RESET}"
  read -r REPLY

  [[ "$REPLY" == "0" || -z "$REPLY" ]] && {
    echo -e "\n${C_GREEN}Đang thoát...${C_RESET}"
    [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-update-main 1
    exit 0
  }

  if [[ "$REPLY" =~ ^[0-9]+$ ]] && [ "$REPLY" -ge 1 ] && [ "$REPLY" -le ${#backup_files[@]} ]; then
    file_chon="${backup_files[$((REPLY - 1))]}"
    break
  else
    echo -e "${C_RED}❌ Lựa chọn không hợp lệ!${C_RESET}"
  fi
done

# ==============================================================================
# XÁC NHẬN VÀ TIẾN HÀNH KHÔI PHỤC (ROLLBACK)
# ==============================================================================
duong_dan_thu_muc_backup_system="/etc/wptt/wptt-backup-system/$file_chon"
version_wptangtoc_ols_rollback=$(echo "$file_chon" | cut -f2 -d ':' | sed 's/\.zip//g')

echo ""
if ! wptt_xac_nhan "CẢNH BÁO: Hệ thống sẽ lùi về phiên bản $version_wptangtoc_ols_rollback" "Bạn có chắc chắn muốn tiến hành Rollback không?" "" "Đồng ý Khôi phục" "Hủy thao tác"; then
  echo -e "${C_YELLOW}Đã hủy thao tác Rollback.${C_RESET}\n"
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-update-main 1
  exit 0
fi

echo ""
_runing "Đang giải nén bản sao lưu và nạp đè vào hệ thống (Silent Mode)..."
# Thêm cờ -q (quiet) để ẩn hàng đống log xả nén rối mắt
unzip -q -o "$duong_dan_thu_muc_backup_system" -d /etc/wptt
_rundone "Xả nén tệp tin Core hoàn tất"

_runing "Đang thiết lập lại Phân quyền và Lệnh môi trường (Binaries)..."
\cp -f /etc/wptt/wptangtoc /usr/bin >/dev/null 2>&1
rm -f /etc/wptt/wptangtoc
\cp -f /etc/wptt/wptt /usr/bin >/dev/null 2>&1
rm -f /etc/wptt/wptt
chmod -R 700 /etc/wptt

# Cấp quyền theo nhóm
kiem_tra_ton_tai_nhom=$(grep '^wptangtoc-ols:' /etc/group)
if [[ -n "$kiem_tra_ton_tai_nhom" ]]; then
  chown root:wptangtoc-ols /etc/wptt
  chown root:wptangtoc-ols /etc/wptt/vhost
  chmod 750 /etc/wptt
  chmod 750 /etc/wptt/vhost
else
  chown root:root /etc/wptt
  chown root:root /etc/wptt/vhost
  chmod 700 /etc/wptt
  chmod 700 /etc/wptt/vhost
fi
_rundone "Thiết lập phân quyền hệ thống thành công"

_runing "Đang cập nhật lại biến môi trường Version..."
sed -i "/version_wptangtoc_ols/d" /etc/wptt/.wptt.conf
echo "version_wptangtoc_ols=$version_wptangtoc_ols_rollback" >>/etc/wptt/.wptt.conf
_rundone "Hạ cấp WPTangToc OLS về phiên bản: $version_wptangtoc_ols_rollback"

echo "Rollback hệ thống phiên bản: $version_wptangtoc_ols_rollback: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log

# Phân tích lại thời gian để in ra bảng
time_raw=$(echo "$file_chon" | sed 's/wptt_backup_//g' | cut -f1 -d ':' | sed 's/_version//g')
IFS='_' read -r gio ngay thang nam <<<"$time_raw"

echo -e "\n${C_GREEN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_BOLD_WHITE}HOÀN TẤT KHÔI PHỤC HỆ THỐNG${C_RESET}"
echo -e "${C_GREEN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
left_text "Hệ thống WPTangToc OLS đã được Rollback (lùi về) thành công!" 2
left_text "Phiên bản hiện tại : ${C_YELLOW}$version_wptangtoc_ols_rollback${C_RESET}" 2
left_text "Mốc sao lưu        : ${C_YELLOW}Lúc ${gio}h, ngày $ngay/$thang/$nam${C_RESET}" 2
echo -e "${C_GREEN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

[[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-update-main 1
