  "$bat_tat_access_log_domain"                 #0 (Hiển thị: 1)
  "$xem_access_log_domain"                     #1 (Hiển thị: 2)
  "$xem_access_log_domain_co_truy_van"         #2 (Hiển thị: 3)
  "$xem_error_log_domain"                      #3 (Hiển thị: 4)
  "$xem_log_access_thoi_gian_thuc"             #4 (Hiển thị: 5)
  "$real_time_statistics_monitor_domain"       #5 (Hiển thị: 6)
  "$real_time_statistics_monitor_all_domain"   #6 (Hiển thị: 7)
  "$xem_system_monitoring_he_thong"            #7 (Hiển thị: 8)

  # --- CỘT PHẢI (9 ĐẾN 16): NHẬT KÝ MÁY CHỦ, DATABASE & CÔNG CỤ ---
