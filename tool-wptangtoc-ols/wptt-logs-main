function huong_dan() {
  Tính năng Quản lý Logs trong WPTangToc OLS là một công cụ tích hợp giúp người dùng dễ dàng truy cập, xem và theo dõi các tệp nhật ký [logs] quan trọng của máy chủ OpenLiteSpeed và các website đang hoạt động.

  Giới thiệu ngắn gọn:

  Mục đích: Hỗ trợ việc theo dõi hoạt động của máy chủ, chẩn đoán lỗi, phân tích lưu lượng truy cập và các vấn đề bảo mật một cách thuận tiện.
  Cách hoạt động [thường thấy]:
  * Xem logs trực tiếp: Truy cập nhanh các tệp log phổ biến như:
  * Log lỗi của OpenLiteSpeed [error.log, stderr.log].
  * Log truy cập của website [access.log].
  * Log hoạt động của chính script WPTangToc OLS.
  * Theo dõi logs theo thời gian thực [tail logs]: Xem các dòng log mới được ghi vào tệp ngay lập tức, hữu ích cho việc gỡ lỗi trực tiếp.
  * Tìm kiếm trong logs [có thể]: Một số tiện ích nâng cao có thể cho phép tìm kiếm từ khóa trong tệp log.
  * v.v.v

  Lợi ích:
  * Gỡ lỗi hiệu quả: Nhanh chóng xác định nguyên nhân gây ra sự cố website hoặc máy chủ.
  * Theo dõi hoạt động: Hiểu rõ hơn về những gì đang diễn ra trên máy chủ.
  * Phân tích bảo mật: Phát hiện các hoạt động đáng ngờ hoặc các cuộc tấn công.
  * Tiện lợi: Truy cập logs dễ dàng mà không cần phải điều hướng phức tạp trong cấu trúc thư mục của máy chủ qua SSH.

  Tính năng này giúp quản trị viên và người dùng WPTangToc OLS có cái nhìn sâu sắc hơn về hoạt động của hệ thống, từ đó đưa ra các quyết định và hành động khắc phục sự cố kịp thời.
}

if [[ $1 = "" ]]; then
  . /etc/wptt/wptt-header-menu
  header_menu
else
  . /etc/wptt/echo-color
  echoDo "=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-="
fi

. /etc/wptt/.wptt.conf
if [[ $ngon_ngu = '' ]]; then
  ngon_ngu='vi'
fi
. /etc/wptt/lang/$ngon_ngu.sh

echo ""
echo ""
echo "$quan_ly_logs:"
echo ""

options=(
  "$xem_error_log_server"                    #0
  "$bat_tat_access_log_server"               #1
  "$xem_access_log_server"                   #2
  "$bat_tat_access_log_domain"               #3
  "$xem_access_log_domain"                   #4
  "$xem_access_log_domain_co_truy_van"       #5
  "$xem_error_log_domain"                    #6
  "$real_time_statistics_monitor_all_domain" #7
  "$real_time_statistics_monitor_domain"     #8
  "$xoa_logs"                                #9
  "$xem_system_monitoring_he_thong"          #10
  "$bat / $tat Logs Database"                #11
  "$xem_logs_database"                       #12
  "$xem_log_database_truy_van_cham"          #13
  "$xem_kiem_tra_toc_do_su_ly_php_he_thong"  #14
  "$xem_log_access_thoi_gian_thuc"           #15
)

# Hàm thực thi hành động dựa trên index (cho menu Quản lý Logs)
run_action() {
  local index=$1
  local script_path=""
  local script_args="" # Tham số sẽ được đặt trong case

  case $index in
  0)
    script_path="/etc/wptt/logs/wptt-xem-error-log-server"
    script_args="98"
    ;;
  1)
    script_path="/etc/wptt/logs/wptt-bat-tat-access-log-server"
    script_args="98"
    ;;
  2)
    script_path="/etc/wptt/logs/wptt-xem-access-log-server"
    script_args="98"
    ;;
  3)
    script_path="/etc/wptt/logs/wptt-bat-tat-log-domain"
    script_args="98"
    ;;
  4)
    script_path="/etc/wptt/logs/wptt-xem-access-log-domain"
    script_args="98"
    ;;
  5)
    script_path="/etc/wptt/logs/wptt-xem-access-log-domain-truy-van"
    script_args="98"
    ;;
  6)
    script_path="/etc/wptt/logs/wptt-xem-error-log-domain"
    script_args="98"
    ;;
  7)
    script_path="/etc/wptt/domain/real-time-check"
    script_args="99"
    ;; # Chú ý: thư mục domain và tham số 99
  8)
    script_path="/etc/wptt/domain/real-time-check"
    script_args="99"
    ;; # Chú ý: thư mục domain và tham số 99
  9)
    script_path="/etc/wptt/logs/wptt-xoa-logs"
    script_args="98"
    ;;
  10)
    script_path="/etc/wptt/logs/wptt-xem-tien-trinh"
    script_args="98"
    ;;
  11)
    # Trỏ đến file Smart Toggle mới
    script_path="/etc/wptt/logs/wptt-bat-tat-log-database"
    script_args="98"
    ;;
  12)
    script_path="/etc/wptt/logs/wptt-xem-log-db"
    script_args="98"
    ;;
  13)
    script_path="/etc/wptt/logs/wptt-xem-log-db-truy-van-cham"
    script_args="98"
    ;;
  14)
    script_path="/etc/wptt/logs/wptt-check-php-load-run-server-call"
    script_args="98"
    ;;
  15)
    script_path="/etc/wptt/logs/wptt-tail-f-realtime-xem-access-log-domain"
    script_args="98"
    ;;
  *)
    echo "${lua_chon_khong_hop_le:-Lựa chọn không hợp lệ}: Index $index."
    return 1
    ;;
  esac

  # Kiểm tra và chạy script con
  if [[ -x "$script_path" ]]; then
    # Kiểm tra xem script_args có được đặt không (đề phòng lỗi logic)
    if [[ -n "$script_args" ]]; then
      exec "$script_path" "$script_args"
    else
      echo "Lỗi logic: Không tìm thấy tham số cho index $index."
    fi
  else
    # Thêm thông báo chi tiết màu đỏ nếu bị lỗi quyền hoặc mất file
    . /etc/wptt/echo-color
    echoDo "Lỗi: Không tìm thấy hoặc không có quyền thực thi script '$script_path'."
    sleep 3
    exec /etc/wptt/wptt-logs-main 1
  fi
}

. /etc/wptt/wptt-callback-menu-chon
