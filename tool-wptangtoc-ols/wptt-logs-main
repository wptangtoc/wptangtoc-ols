  "$xem_logs_database"                         #12 (Hiển thị: 13)
  "$xem_log_database_truy_van_cham"            #13 (Hiển thị: 14)
  "$xem_kiem_tra_toc_do_su_ly_php_he_thong"    #14 (Hiển thị: 15)
  "$xoa_logs"                                  #15 (Hiển thị: 16)
)

# ==============================================================================
# 3. LOGIC XỬ LÝ
# ==============================================================================
run_action() {
  local index=$1
  local script_path=""
  local script_args="98" # Mặc định là 98

  case $index in
  # Nhóm Website
  0) script_path="/etc/wptt/logs/wptt-bat-tat-log-domain" ;;
  1) script_path="/etc/wptt/logs/wptt-xem-access-log-domain" ;;
  2) script_path="/etc/wptt/logs/wptt-xem-access-log-domain-truy-van" ;;
  3) script_path="/etc/wptt/logs/wptt-xem-error-log-domain" ;;
  4) script_path="/etc/wptt/logs/wptt-tail-f-realtime-xem-access-log-domain" ;;
  
  # Nhóm Monitor
  5) script_path="/etc/wptt/domain/real-time-check"; script_args="99" ;;
  6) script_path="/etc/wptt/domain/real-time-check"; script_args="99" ;;
  7) script_path="/etc/wptt/logs/wptt-top" ;;

  # Nhóm Server
  8) script_path="/etc/wptt/logs/wptt-bat-tat-access-log-server" ;;
  9) script_path="/etc/wptt/logs/wptt-xem-access-log-server" ;;
  10) script_path="/etc/wptt/logs/wptt-xem-error-log-server" ;;
  
  # Nhóm Database & PHP
  11) script_path="/etc/wptt/logs/wptt-bat-tat-log-database" ;;
  12) script_path="/etc/wptt/logs/wptt-xem-log-db" ;;
  13) script_path="/etc/wptt/logs/wptt-xem-log-db-truy-van-cham" ;;
  14) script_path="/etc/wptt/logs/wptt-check-php-load-run-server-call" ;;
  
  # Công cụ
  15) script_path="/etc/wptt/logs/wptt-xoa-logs" ;;
  esac

  if [[ -x "$script_path" || -f "$script_path" ]]; then
    exec bash "$script_path" "$script_args"
  else
    echo -e "\n\033[1;31m[!] Lỗi: Không tìm thấy hoặc không thể thực thi script '$script_path'.\033[0m"
    sleep 2
    exec /etc/wptt/wptt-logs-main 1
  fi
}

# ==============================================================================
# 4. GIAO DIỆN TÙY CHỈNH (TỰ ĐỘNG HÓA VÀ CĂN CHỈNH)
# ==============================================================================
draw_custom_grid() {
  print_row "" "NHẬT KÝ WEBSITE (DOMAIN)" "" "NHẬT KÝ MÁY CHỦ (SERVER)"
  
  local half=8
  for ((i=0; i<4; i++)); do
    local l_num=$((i+1))
    local r_num=$((i+1+half))
    print_row "$l_num" "${options[$i]}" "$r_num" "${options[$((i+half))]}"
  done

  print_spacer
  print_row "" "GIÁM SÁT THỜI GIAN THỰC" "" "DATABASE, PHP & CÔNG CỤ"

  for ((i=4; i<8; i++)); do
    local l_num=$((i+1))
    local r_num=$((i+1+half))
    print_row "$l_num" "${options[$i]}" "$r_num" "${options[$((i+half))]}"
  done
}

