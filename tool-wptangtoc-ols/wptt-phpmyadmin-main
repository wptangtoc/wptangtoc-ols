echo ""
echo "$quan_ly_phpmyadmin:" > /dev/null # Để wptt-search tổng vẫn bắt được danh mục

# ==============================================================================
# 2. KHAI BÁO TIÊU ĐỀ MENU VÀ OPTIONS (ĐÃ QUY HOẠCH LẠI LOGIC UX)
# ==============================================================================
MENU_TITLE="TRUNG TÂM QUẢN LÝ PHPMYADMIN"

options=(
  # --- CỘT TRÁI: TRẠNG THÁI & HỆ THỐNG ---
  "$bat PhpMyAdmin"                                #0 (Hiển thị: 1)
  "$tat PhpMyAdmin"                                #1 (Hiển thị: 2)
  "$cap_nhat PhpMyAdmin"                           #2 (Hiển thị: 3)

  # --- CỘT PHẢI: THÔNG TIN & BẢO MẬT ---
  "$xem_thong_tin_tai_khoan_bao_mat PhpMyAdmin"    #3 (Hiển thị: 4)
  "$thay_doi $tai_khoan $dang_nhap PhpMyAdmin"     #4 (Hiển thị: 5)
)

# ==============================================================================
# 3. LOGIC XỬ LÝ (ÁNH XẠ CHUẨN 100% VỚI INDEX MỚI)
# ==============================================================================
run_action() {
  local index=$1
  local script_path=""
  local script_args="98" # Mặc định là 98

  case $index in
  # Cột trái
  0) script_path="/etc/wptt/phpmyadmin/wptt-mo-phpmyadmin" ;;
  1) script_path="/etc/wptt/phpmyadmin/wptt-xoa-phpmyadmin" ;;
  2) script_path="/etc/wptt/update/wptt-update-phpmyadmin"; script_args="97" ;; # Đặc biệt: 97
  
  # Cột phải
  3) script_path="/etc/wptt/phpmyadmin/wptt-thongtin-phpmyadmin" ;;
  4) script_path="/etc/wptt/phpmyadmin/wptt-phpmyadmin-doi-password" ;;
  esac

  if [[ -x "$script_path" || -f "$script_path" ]]; then
    exec bash "$script_path" "$script_args"
  else
    echo -e "\n\033[1;31m[!] Lỗi: Không tìm thấy hoặc không thể thực thi script '$script_path'.\033[0m"
    sleep 2
    exec /etc/wptt/wptt-phpmyadmin-main 1
  fi
}

# ==============================================================================
# 4. GIAO DIỆN TÙY CHỈNH (CĂN CHỈNH SỐ THỨ TỰ TUẦN TỰ)
# ==============================================================================
draw_custom_grid() {
  print_row "" "TRẠNG THÁI & HỆ THỐNG" "" "THÔNG TIN & BẢO MẬT"
  print_row "1" "${options[0]}" "4" "${options[3]}"
  print_row "2" "${options[1]}" "5" "${options[4]}"
  print_row "3" "${options[2]}" ""  ""
}

