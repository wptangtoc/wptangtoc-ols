#!/bin/bash

function huong_dan() {
  Tính năng Cấu hình memory_limit PHP là việc điều chỉnh một cài đặt quan trọng trong PHP để quy định dung lượng bộ nhớ [RAM] tối đa mà một đoạn mã [script] PHP đơn lẻ được phép sử dụng trong quá trình thực thi.

  Nói một cách đơn giản, đây là cách bạn đặt ra giới hạn một tác vụ PHP không được phép ngốn quá X Megabytes bộ nhớ.

  Mục Đích Chính
  * Ngăn chặn lỗi hết bộ nhớ: Giúp các script PHP không sử dụng quá nhiều bộ nhớ, tránh làm cạn kiệt tài nguyên của máy chủ, có thể dẫn đến việc script bị dừng đột ngột hoặc ảnh hưởng đến hoạt động của toàn bộ server.
  * Quản lý tài nguyên máy chủ: Đảm bảo mỗi script chỉ sử dụng một phần bộ nhớ hợp lý, giúp máy chủ hoạt động ổn định.
  * Cho phép các tác vụ nặng chạy: Đối với các tác vụ cần nhiều bộ nhớ để xử lý [ví dụ: xử lý hình ảnh lớn, làm việc với tập dữ liệu khổng lồ, các thư viện phức tạp], bạn có thể cần tăng memory_limit lên để chúng hoàn thành mà không gặp lỗi.
  * Đáp ứng yêu cầu ứng dụng: Nhiều ứng dụng web [như WordPress, Magento] có yêu cầu memory_limit tối thiểu để hoạt động trơn tru.
  Nếu một script cố gắng sử dụng nhiều bộ nhớ hơn mức cho phép, nó sẽ gây ra lỗi nghiêm trọng [fatal error] và bị dừng lại.
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null # Nạp thư viện UX Bo Cong

clear
echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}QUẢN LÝ PHP ➜ Cấu Hình Giới Hạn RAM (memory_limit)${C_RESET}"
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

if [[ "${1:-}" == '98' ]]; then
  WPTT_IN_MENU="yes"
  WPTT_MENU_BACK="/etc/wptt/wptt-php-ini-main 1"
fi

. /etc/wptt/php/wptt-php-version-domain 1 >/dev/null 2>&1

echo -e "${C_YELLOW}Vui lòng chọn Phiên bản PHP mà bạn muốn điều chỉnh:${C_RESET}"
. /etc/wptt/php/tenmien-php 2>/dev/null

if [[ -z "$LSPHP" || "$LSPHP" == "0" ]]; then
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-php-ini-main 1
  exit 0
fi

phien_ban_php_co_cham=$(echo "$LSPHP" | grep -Eo '[0-9]{1,2}' | head -1 | perl -pe 's/(\d{1})(?=(?:\d{1}){1,5}\b)/\1./g')

if grep -qi "Ubuntu" /etc/*release 2>/dev/null; then
  duong_dan_php_ini="/usr/local/lsws/$LSPHP/etc/php/$phien_ban_php_co_cham/litespeed/php.ini"
else
  duong_dan_php_ini="/usr/local/lsws/$LSPHP/etc/php.ini"
fi

if [[ ! -f "$duong_dan_php_ini" ]]; then
  echo -e "\n${C_RED}❌ Lỗi: Không tìm thấy file php.ini tại: $duong_dan_php_ini${C_RESET}"
  sleep 3
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-php-ini-main 1
  exit 1
fi

# Lấy giá trị hiện tại (VD: 256M) và loại bỏ chữ M để hiển thị cho đẹp
# hien_tai=$(grep -E '^memory_limit' "$duong_dan_php_ini" | awk '{print $3}')
hien_tai=$(grep -iE '^[;[:space:]]*memory_limit[[:space:]]*=' "$duong_dan_php_ini" | awk -F'=' '{print $2}' | tr -d ' ' | head -n 1)

hien_tai_so=$(echo "$hien_tai" | sed -E 's/[mM][bB]?|[[:space:]]//g')
hien_tai_so=${hien_tai_so:-"Chưa xác định"}

echo -e "\n${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
left_text "  Đang cấu hình        : ${C_BOLD_WHITE}$LSPHP (PHP $phien_ban_php_co_cham)${C_RESET}" 2
left_text "  Giới hạn RAM hiện tại: ${C_YELLOW}${hien_tai_so} MB${C_RESET}" 2
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

# ==============================================================================
# NHẬP GIÁ TRỊ MỚI VÀ XỬ LÝ
# ==============================================================================
while true; do
  echo -e "Gợi ý: Tối thiểu là ${C_YELLOW}128${C_RESET}, tối ưu là ${C_YELLOW}128${C_RESET} hoặc ${C_YELLOW}256${C_RESET}."
  echo -en "${C_CYAN}Nhập dung lượng RAM (Megabytes) mới [0=Thoát]: ${C_RESET}"
  read -r port

  [[ "$port" == "0" || -z "$port" ]] && {
    echo -e "\n${C_YELLOW}Đã thoát.${C_RESET}"
    [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-php-ini-main 1
    exit 0
  }

  # Làm sạch input (loại bỏ M, m, MB, mb, khoảng trắng)
  port=$(echo "$port" | sed -E 's/[mM][bB]?|[[:space:]]//g')

  if [[ "$port" =~ ^[0-9]+$ ]] && [ "$port" -gt 0 ]; then
    break
  else
    echo -e "${C_RED}Lỗi: Giá trị không hợp lệ! Vui lòng chỉ nhập số nguyên dương (VD: 512).${C_RESET}\n"
  fi
done

echo ""
if ! wptt_xac_nhan "Bạn có chắc chắn muốn thay đổi memory_limit không?" \
  "Dung lượng RAM sẽ chuyển từ: [ ${hien_tai_so} MB ] ➜ sang [ ${port} MB ]" \
  "Mỗi tiến trình PHP (LSPHP) sẽ được phép tiêu thụ tối đa mức RAM này." \
  "Đồng ý Lưu" "Hủy thao tác"; then
  echo -e "${C_YELLOW}Đã hủy thao tác.${C_RESET}\n"
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-php-ini-main 1
  exit 0
fi

_runing "Ghi cấu hình memory_limit = ${port}M vào php.ini..."

if grep -qiE '^[;[:space:]]*memory_limit' "$duong_dan_php_ini"; then
  sed -i -E "s/^[;[:space:]]*memory_limit[[:space:]]*=.*/memory_limit = ${port}M/" "$duong_dan_php_ini"
else
  # Nếu file php.ini bị mất luôn dòng đó, hệ thống sẽ tự động chèn thêm
  echo "memory_limit = ${port}M" >>"$duong_dan_php_ini"
fi

# sed -i -E "s/^memory_limit[[:space:]]*=.*/memory_limit = ${port}M/" "$duong_dan_php_ini"
/usr/local/lsws/bin/lswsctrl restart >/dev/null 2>&1
_rundone "Ghi cấu hình memory_limit = ${port}M vào php.ini..."

echo -e "${C_GREEN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_BOLD_WHITE}HOÀN TẤT THAY ĐỔI MEMORY_LIMIT${C_RESET}"
echo -e "${C_GREEN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
left_text "Phiên bản PHP      : ${C_YELLOW}$LSPHP (PHP $phien_ban_php_co_cham)${C_RESET}" 2
left_text "Dung lượng RAM mới : ${C_BOLD_WHITE}${port} MB${C_RESET} / 1 tiến trình" 2
echo -e "${C_GREEN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

[[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-php-ini-main 1
