#!/bin/bash
# @author: Gia Tuấn
# @website: https://wptangtoc.com
# @since: 2026

function huong_dan() {
  Tính năng Xóa extension PHP là quá trình gỡ bỏ hoặc vô hiệu hóa các thư viện mở rộng [module] đã được cài đặt trước đó ra khỏi môi trường PHP của bạn. Khi một extension bị xóa, các chức năng mà nó cung cấp sẽ không còn sẵn có để sử dụng trong các đoạn mã PHP nữa.

  Mục đích chính của việc này:

  * Tối ưu tài nguyên: Loại bỏ các extension không sử dụng để giải phóng một phần nhỏ tài nguyên máy chủ [bộ nhớ RAM].
  * Tăng cường bảo mật: Giảm thiểu bề mặt tấn công bằng cách gỡ bỏ những thành phần không cần thiết, vì mỗi extension đều có thể tiềm ẩn lỗ hổng.
  * Giải quyết xung đột: Gỡ bỏ extension có thể giúp khắc phục sự không tương thích giữa các extension với nhau hoặc với phiên bản PHP/ứng dụng.
  * Dọn dẹp môi trường: Giữ cho môi trường PHP gọn gàng, chỉ chứa những gì thực sự cần thiết.
  * Khi không còn nhu cầu: Nếu một ứng dụng web không còn cần đến một extension cụ thể nữa.

  Sau khi xóa hoặc vô hiệu hóa và khởi động lại web server, PHP sẽ không còn tải extension đó nữa, và mọi cố gắng gọi hàm từ extension đó sẽ gây ra lỗi.
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null # Nạp thư viện UX Bo Cong

clear
echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}QUẢN LÝ PHP ➜ Xóa Extension (Gỡ bỏ thư viện mở rộng)${C_RESET}"
echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

if [[ "${1:-}" == '98' ]]; then
  WPTT_IN_MENU="yes"
  WPTT_MENU_BACK="/etc/wptt/wptt-php-ini-main 1"
fi

# ==============================================================================
# BƯỚC 1: CHỌN PHIÊN BẢN PHP
# ==============================================================================
. /etc/wptt/php/wptt-php-version-domain 1 >/dev/null 2>&1
echo -e "${C_YELLOW}Vui lòng chọn Phiên bản PHP bạn muốn GỠ BỎ Extension:${C_RESET}"
. /etc/wptt/php/tenmien-php 2>/dev/null

if [[ -z "$LSPHP" || "$LSPHP" == "0" ]]; then
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-php-ini-main 1
  exit 0
fi

if [[ ! -d "/usr/local/lsws/$LSPHP" ]]; then
  echo -e "\n${C_RED}❌ Lỗi: Phiên bản $LSPHP chưa được cài đặt trên máy chủ!${C_RESET}"
  sleep 3
  exit 1
fi

php_ver_hien_thi=$(echo "$LSPHP" | grep -Eo '[0-9]{1,2}' | head -1 | perl -pe 's/(\d{1})(?=(?:\d{1}){1,5}\b)/\1./g' | sed 's/^/PHP /g')

# ==============================================================================
# BƯỚC 2: QUÉT DANH SÁCH EXTENSION ĐÃ CÀI
# ==============================================================================
echo ""
_runing "Đang quét danh sách Extensions ĐÃ CÀI ĐẶT trên $php_ver_hien_thi..."

if command -v dnf >/dev/null 2>&1; then dnf clean all >/dev/null 2>&1; else yum clean all >/dev/null 2>&1; fi

if grep -qi "ubuntu" /etc/os-release 2>/dev/null; then
  php_extension_da_cai_dat=($(apt list --installed 2>/dev/null | grep "$LSPHP" | cut -f2-10 -d '-' | cut -f1 -d '.' | cut -f1 -d '/' | sed '/installed/d' | sed '1d' | sed '/^$/d' | sort | uniq))
elif grep -qE "release 8" /etc/redhat-release 2>/dev/null; then
  php_extension_da_cai_dat=($(yum list installed --disablerepo="*" --enablerepo="litespeed,litespeed-edge,litespeed-edge-update,litespeed-update" 2>/dev/null | grep "$LSPHP" | cut -f2-10 -d '-' | cut -f1 -d '.' | sed '1d' | sed '/^$/d' | sort | uniq))
else
  php_extension_da_cai_dat=($(yum list installed --disablerepo="*" --enablerepo="litespeed,litespeed-update" 2>/dev/null | grep "$LSPHP" | cut -f2-10 -d '-' | cut -f1 -d '.' | sed '1d' | sed '/^$/d' | sort | uniq))
fi

# Fallback nếu quét thất bại (Bơm Repo)
if [[ -z "${php_extension_da_cai_dat[*]}" ]]; then
  sed -i '/rpms.litespeedtech.com/d' /etc/hosts
  echo -e '\n52.55.120.73 rpms.litespeedtech.com\n' >>/etc/hosts
  if command -v dnf >/dev/null 2>&1; then dnf clean all >/dev/null 2>&1; else yum clean all >/dev/null 2>&1; fi
  repo_du_phong=1

  if grep -qi "ubuntu" /etc/os-release 2>/dev/null; then
    php_extension_da_cai_dat=($(apt list --installed 2>/dev/null | grep "$LSPHP" | cut -f2-10 -d '-' | cut -f1 -d '.' | cut -f1 -d '/' | sed '/installed/d' | sed '1d' | sed '/^$/d' | sort | uniq))
  elif grep -qE "release 8" /etc/redhat-release 2>/dev/null; then
    php_extension_da_cai_dat=($(yum list installed --disablerepo="*" --enablerepo="litespeed,litespeed-edge,litespeed-edge-update,litespeed-update" 2>/dev/null | grep "$LSPHP" | cut -f2-10 -d '-' | cut -f1 -d '.' | sed '1d' | sed '/^$/d' | sort | uniq))
  else
    php_extension_da_cai_dat=($(yum list installed --disablerepo="*" --enablerepo="litespeed,litespeed-update" 2>/dev/null | grep "$LSPHP" | cut -f2-10 -d '-' | cut -f1 -d '.' | sed '1d' | sed '/^$/d' | sort | uniq))
  fi
fi

rm -f /tmp/php_extension.txt
for phpexe in "${php_extension_da_cai_dat[@]}"; do
  echo "$phpexe" >>/tmp/php_extension.txt
done

# Kiểm tra Ioncube (Manual check vì nó không cài qua package manager)
if grep -qi "ubuntu" /etc/os-release 2>/dev/null; then
  [[ -d "/usr/local/lsws/$LSPHP/lib/php" && -n $(ls "/usr/local/lsws/$LSPHP/lib/php" | grep 'ioncube') ]] && echo "ioncube" >>/tmp/php_extension.txt
else
  [[ -d "/usr/local/lsws/$LSPHP/lib64/php/modules" && -n $(ls "/usr/local/lsws/$LSPHP/lib64/php/modules" | grep 'ioncube') ]] && echo "ioncube" >>/tmp/php_extension.txt
fi

_rundone "Đã quét xong danh sách Extensions"

# ==============================================================================
# BƯỚC 3: GIAO DIỆN CHỌN EXTENSION ĐỂ XÓA (LAYOUT 2 CỘT + FZF)
# ==============================================================================
mapfile -t selects < <(sort -u /tmp/php_extension.txt | sed '/^$/d')

if [[ ${#selects[@]} -eq 0 ]]; then
  echo -e "\n${C_RED}❌ Phiên bản $php_ver_hien_thi của bạn chưa cài đặt Extension nào!${C_RESET}"
  sleep 3
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-php-ini-main 1
  exit 0
fi

echo -e "\n${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_BOLD_WHITE}DANH SÁCH EXTENSIONS ĐÃ CÀI TRÊN: ${C_YELLOW}$php_ver_hien_thi${C_RESET}"
echo -e "${C_CYAN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"

# HỆ THỐNG IN DANH SÁCH 2 CỘT CỰC ĐẸP
total=${#selects[@]}
for ((i = 0; i < total; i += 2)); do
  idx1=$((i + 1))
  val1="${selects[$i]}"
  # Cố định độ rộng cột 1 là 28 khoảng trắng để đẩy cột 2 sang ngang bằng nhau
  pad_val1=$(printf "%-28s" "$val1")
  str_col1="  ${C_CYAN}$(printf "%2d" $idx1))${C_RESET} ${C_BOLD_WHITE}${pad_val1}${C_RESET}"

  idx2=$((i + 2))
  if [ $idx2 -le $total ]; then
    val2="${selects[$((i + 1))]}"
    str_col2="${C_CYAN}$(printf "%2d" $idx2))${C_RESET} ${C_BOLD_WHITE}${val2}${C_RESET}"
    left_text "${str_col1}${str_col2}" 0
  else
    left_text "${str_col1}" 0
  fi
done
echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯${C_RESET}"

php_extension_chon=""

while true; do
  if command -v fzf &>/dev/null; then
    echo -en "${C_CYAN}Nhập số thứ tự Extension cần XÓA (1-${#selects[@]}) hoặc gõ [00=Tìm kiếm, 0=Thoát]: ${C_RESET}"
  else
    echo -en "${C_CYAN}Nhập số thứ tự Extension cần XÓA (1-${#selects[@]}) [0=Thoát]: ${C_RESET}"
  fi
  read -r REPLY

  if [[ "$REPLY" == "0" ]]; then
    exit 0
  elif [[ "$REPLY" == "00" && -x $(command -v fzf) ]]; then
    fzf_result=$(printf "%s\n" "${selects[@]}" | fzf \
      --prompt="Nhập extension cần XÓA > " \
      --height='~60%' \
      --border=rounded \
      --color=border:red \
      --layout=reverse \
      --header="Tìm thấy ${#selects[@]} extension đã cài. [↑/↓] Di chuyển, [ESC] Hủy, [Enter] Chọn." \
      --preview='echo -e "CẢNH BÁO: Bạn đang chọn XÓA: \033[1;31m{}\033[0m"')
    if [[ -n "$fzf_result" ]]; then
      php_extension_chon="$fzf_result"
      break
    else
      echo -e "${C_YELLOW}Đã hủy tìm kiếm FZF.${C_RESET}"
    fi
  elif [[ "$REPLY" =~ ^[0-9]+$ ]] && [ "$REPLY" -ge 1 ] && [ "$REPLY" -le "${#selects[@]}" ]; then
    php_extension_chon="${selects[$((REPLY - 1))]}"
    break
  else
    echo -e "${C_RED}❌ Lựa chọn không hợp lệ!${C_RESET}"
  fi
done

thong_bao_2=""
case "$php_extension_chon" in
mysqlnd | mysqli | mysql | pdo | pdo_mysql)
  thong_bao_2="CẢNH BÁO TỬ HUYỆT: Xóa '$php_extension_chon' website sẽ SẬP DATABASE lập tức (Error Establishing)!"
  ;;
json)
  thong_bao_2="CẢNH BÁO CỐT LÕI: Thiếu 'json' sẽ làm hỏng Block Editor (Gutenberg) và WordPress REST API!"
  ;;
curl)
  thong_bao_2="NGUY HIỂM: Thiếu 'curl', web sẽ không thể update Plugin/Theme hay kết nối API Thanh toán!"
  ;;
mbstring)
  thong_bao_2="NGUY HIỂM: Thiếu 'mbstring' sẽ làm vỡ Font chữ (UTF-8) và gây lỗi trắng trang ở nhiều Theme!"
  ;;
zip)
  thong_bao_2="CẢNH BÁO: Thiếu 'zip' bạn sẽ KHÔNG THỂ cài đặt, upload hay update Theme/Plugin từ file .zip!"
  ;;
xml | dom | simplexml)
  thong_bao_2="CẢNH BÁO: Thiếu '$php_extension_chon' sẽ làm hỏng Sitemap (SEO) và lỗi xử lý dữ liệu chuẩn XML!"
  ;;
gd)
  thong_bao_2="CẢNH BÁO: Thiếu '$php_extension_chon', tính năng Upload, Cắt xén, Resize hình ảnh sẽ bị liệt hoàn toàn!"
  ;;
opcache)
  thong_bao_2="LƯU Ý HIỆU SUẤT: Xóa 'opcache' sẽ làm tốc độ website chậm đi cực kỳ nghiêm trọng!"
  ;;
intl)
  thong_bao_2="LƯU Ý: Xóa 'intl' sẽ gây lỗi cho các website Đa ngôn ngữ (WPML, Polylang) và dịch thuật!"
  ;;
openssl)
  thong_bao_2="CẢNH BÁO BẢO MẬT: Gỡ '$php_extension_chon' sẽ làm đứt gãy các kết nối an toàn (HTTPS/API) ra bên ngoài!"
  ;;
igbinary | memcached | pecl-memcached)
  thong_bao_2="LƯU Ý CACHE: Xóa '$php_extension_chon' có thể làm mất kết nối Object Cache Memcached!"
  ;;
igbinary | redis | pecl-redis)
  thong_bao_2="LƯU Ý CACHE: Xóa '$php_extension_chon' có thể làm mất kết nối Object Cache Redis!"
  ;;
ioncube)
  thong_bao_2="Lưu ý: Nếu source code còn dùng plugin bản quyền ioncube thì khi xoá sẽ gây lỗi!"
  ;;
*)
  thong_bao_2="Hãy chắc chắn là Source code không còn cần đến nó!"
  ;;
esac

if ! wptt_xac_nhan "Bạn có chắc chắn muốn XÓA $php_ver_hien_thi Extension này trên không?" \
  "Extension bị gỡ bỏ : ${C_RED}$php_extension_chon${C_RESET}" \
  "$thong_bao_2" \
  "Đồng ý XÓA" "Hủy thao tác"; then
  echo -e "${C_YELLOW}Đã hủy thao tác.${C_RESET}\n"
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-php-ini-main 1
  exit 0
fi

echo ""
_runing "Đang gỡ bỏ Extension: $php_extension_chon..."

phien_ban_php_co_cham=$(echo "$LSPHP" | grep -Eo '[0-9]{1,2}' | head -1 | perl -pe 's/(\d{1})(?=(?:\d{1}){1,5}\b)/\1./g')

# 1. Gỡ bỏ IONCUBE (Thủ công)
if [[ "$php_extension_chon" == 'ioncube' ]]; then
  if grep -qi "ubuntu" /etc/os-release 2>/dev/null; then
    duong_dan_luu_tru_extension_so="/usr/local/lsws/$LSPHP/lib/php"
    duong_dan_php_ini_ioncube="/usr/local/lsws/$LSPHP/etc/php/$phien_ban_php_co_cham/litespeed/php.ini"
  else
    duong_dan_luu_tru_extension_so="/usr/local/lsws/$LSPHP/lib64/php/modules"
    duong_dan_php_ini_ioncube="/usr/local/lsws/$LSPHP/etc/php.ini"
  fi
  rm -f "$duong_dan_luu_tru_extension_so/ioncube_loader_lin_${phien_ban_php_co_cham}.so"
  sed -i '/ioncube_loader_lin/d' "$duong_dan_php_ini_ioncube"

# 2. Gỡ bỏ Package thông thường (CÓ CHIA RHEL 8 vs 9/10)
else
  if grep -qi "ubuntu" /etc/os-release 2>/dev/null; then
    DEBIAN_FRONTEND=noninteractive apt-get remove -y "$LSPHP-$php_extension_chon" >/dev/null 2>&1
  elif grep -qE "release 8" /etc/redhat-release 2>/dev/null; then
    yum remove "$LSPHP-$php_extension_chon" -y --disablerepo="*" --enablerepo="litespeed,litespeed-edge,litespeed-edge-update,litespeed-update" >/dev/null 2>&1
  else # RHEL 9 và 10 support
    yum remove "$LSPHP-$php_extension_chon" -y --disablerepo="*" --enablerepo="litespeed,litespeed-update" >/dev/null 2>&1
  fi
fi

if command -v dnf >/dev/null 2>&1; then dnf clean all >/dev/null 2>&1; else yum clean all >/dev/null 2>&1; fi

# ==============================================================================
# KIỂM TRA LẠI VÀ BÁO CÁO
# ==============================================================================
if grep -qi "ubuntu" /etc/os-release 2>/dev/null; then
  check_lai=$(apt list --installed 2>/dev/null | grep "$LSPHP" | grep -w "$php_extension_chon")
elif grep -qE "release 8" /etc/redhat-release 2>/dev/null; then
  check_lai=$(yum list installed --disablerepo="*" --enablerepo="litespeed,litespeed-edge,litespeed-edge-update,litespeed-update" 2>/dev/null | grep "$LSPHP" | cut -f2-10 -d '-' | cut -f1 -d '.' | sed '1d' | sed '/^$/d' | sort | uniq | grep -w "$php_extension_chon")
else # RHEL 9 và 10 support
  check_lai=$(yum list installed --disablerepo="*" --enablerepo="litespeed,litespeed-update" 2>/dev/null | grep "$LSPHP" | cut -f2-10 -d '-' | cut -f1 -d '.' | sed '1d' | sed '/^$/d' | sort | uniq | grep -w "$php_extension_chon")
fi

[[ "$php_extension_chon" == "ioncube" ]] && check_lai="" # Ioncube gỡ file là xong

if [[ -z "$check_lai" ]]; then
  /usr/local/lsws/bin/lswsctrl restart >/dev/null 2>&1
  _rundone "Gỡ bỏ thành công!"

  echo -e "\n${C_GREEN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_BOLD_WHITE}HOÀN TẤT XÓA EXTENSION${C_RESET}"
  echo -e "${C_GREEN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
  left_text "Phiên bản PHP  : ${C_YELLOW}$php_ver_hien_thi ($LSPHP)${C_RESET}" 2
  left_text "Extension xóa  : ${C_RED}$php_extension_chon${C_RESET}" 2
  echo -e "${C_GREEN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"
else
  _runloi "Gỡ bỏ thất bại! Vui lòng kiểm tra lại."
fi

[[ "$repo_du_phong" == '1' ]] && sed -i '/rpms.litespeedtech.com/d' /etc/hosts

[[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-php-ini-main 1
