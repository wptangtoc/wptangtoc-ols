#!/bin/bash
function huong_dan() {
  Tính năng Cấu hình max_input_time PHP là việc điều chỉnh một cài đặt trong PHP để quy định thời gian tối đa [tính bằng giây] mà một đoạn mã [script] PHP được phép sử dụng để phân tích dữ liệu đầu vào nhận được từ yêu cầu của người dùng. Dữ liệu này bao gồm các biến GET, POST và đặc biệt quan trọng là dữ liệu từ việc tải tệp [file uploads].

  Nói một cách đơn giản, đây là cách bạn đặt ra giới hạn một script PHP không được tốn quá X giây để nhận và xử lý xong toàn bộ dữ liệu được gửi lên, ví dụ như một file lớn.

  Mục đích chính:
  * Ngăn chặn tấn công từ chối dịch vụ [DoS]: Giúp bảo vệ máy chủ khỏi các kịch bản mà client [người dùng hoặc bot] gửi dữ liệu lên rất chậm hoặc gửi dữ liệu lớn/lỗi khiến script bị kẹt ở giai đoạn xử lý đầu vào, làm cạn kiệt tài nguyên.
  * Cho phép tải lên tệp lớn/dữ liệu POST lớn: Nếu website của bạn cần xử lý việc tải lên các tệp tin có dung lượng lớn hoặc nhận lượng dữ liệu POST lớn, giá trị mặc định [thường là 60 giây] có thể không đủ. Tăng max_input_time cho phép các thao tác này có đủ thời gian hoàn tất.
  * Đảm bảo ổn định cho máy chủ: Đặt giới hạn thời gian xử lý đầu vào giúp máy chủ hoạt động ổn định hơn.
}
. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null # Nạp thư viện UX Bo Cong

clear
echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}QUẢN LÝ PHP ➜ Cấu Hình Thời Gian Nhận Dữ Liệu (max_input_time)${C_RESET}"
echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

if [[ "${1:-}" == '98' ]]; then
  WPTT_IN_MENU="yes"
  WPTT_MENU_BACK="/etc/wptt/wptt-php-ini-main 1"
fi

# ==============================================================================
# CHỌN PHIÊN BẢN PHP
# ==============================================================================
# Gọi list danh sách PHP đang cài
. /etc/wptt/php/wptt-php-version-domain 1 >/dev/null 2>&1

. /etc/wptt/php/tenmien-php 2>/dev/null

if [[ -z "$LSPHP" || "$LSPHP" == "0" ]]; then
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-php-ini-main 1
  exit 0
fi

# ==============================================================================
# LẤY THÔNG TIN CẤU HÌNH HIỆN TẠI
# ==============================================================================
phien_ban_php_co_cham=$(echo "$LSPHP" | grep -Eo '[0-9]{1,2}' | head -1 | perl -pe 's/(\d{1})(?=(?:\d{1}){1,5}\b)/\1./g')

if grep -qi "Ubuntu" /etc/*release 2>/dev/null; then
  duong_dan_php_ini="/usr/local/lsws/$LSPHP/etc/php/$phien_ban_php_co_cham/litespeed/php.ini"
else
  duong_dan_php_ini="/usr/local/lsws/$LSPHP/etc/php.ini"
fi

if [[ ! -f "$duong_dan_php_ini" ]]; then
  echo -e "\n${C_RED}❌ Lỗi: Không tìm thấy file php.ini tại: $duong_dan_php_ini${C_RESET}"
  sleep 3
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-php-ini-main 1
  exit 1
fi

max_input_time_hientai=$(grep -iE '^[;[:space:]]*max_input_time[[:space:]]*=' "$duong_dan_php_ini" | awk -F'=' '{print $2}' | tr -d ' ' | head -n 1)
max_input_time_hientai=${max_input_time_hientai:-"60"}

echo -e "\n${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
left_text "  Đang cấu hình        : ${C_BOLD_WHITE}$LSPHP (PHP $phien_ban_php_co_cham)${C_RESET}" 2
left_text "  Thời gian hiện tại   : ${C_YELLOW}${max_input_time_hientai} giây${C_RESET}" 2
echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

# ==============================================================================
# NHẬP GIÁ TRỊ MỚI VÀ XỬ LÝ
# ==============================================================================
while true; do
  echo -e "Gợi ý: Website WordPress thông thường nên để từ ${C_YELLOW}60${C_RESET} đến ${C_YELLOW}300${C_RESET}."
  echo -en "${C_CYAN}Nhập giá trị max_input_time mới (giây) [0=Thoát]: ${C_RESET}"
  read -r port

  [[ "$port" == "0" || -z "$port" ]] && {
    echo -e "\n${C_YELLOW}Đã thoát.${C_RESET}"
    [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-php-ini-main 1
    exit 0
  }

  # Làm sạch input (loại bỏ khoảng trắng, chữ 's' hoặc 'giây' nếu người dùng nhập nhầm)
  port=$(echo "$port" | sed -E 's/[[:alpha:]]|[[:space:]]//g')

  if [[ "$port" =~ ^[0-9]+$ ]] && [ "$port" -gt 0 ]; then
    break
  else
    echo -e "${C_RED}Lỗi: Giá trị không hợp lệ! Vui lòng chỉ nhập số nguyên dương (VD: 120).${C_RESET}\n"
  fi
done

if ! wptt_xac_nhan "Bạn có chắc chắn muốn thay đổi max_input_time không?" \
  "Hệ thống sẽ chuyển đổi từ: [ ${max_input_time_hientai} giây ] ➜ sang [ ${port} giây ]" \
  "Thời gian xử lý dữ liệu đầu vào của PHP sẽ được nới lỏng." \
  "Đồng ý Lưu" "Hủy thao tác"; then
  echo -e "${C_YELLOW}Đã hủy thao tác.${C_RESET}\n"
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-php-ini-main 1
  exit 0
fi

echo ""
_runing "Cấu hình max_input_time = $port vào php.ini"

# sed -i -E "s/^max_input_time[[:space:]]*=.*/max_input_time = $port/" "$duong_dan_php_ini"

if grep -qiE '^[;[:space:]]*max_input_time' "$duong_dan_php_ini"; then
  sed -i -E "s/^[;[:space:]]*max_input_time[[:space:]]*=.*/max_input_time = ${port}/" "$duong_dan_php_ini"
else
  # Nếu file php.ini bị mất luôn dòng đó, hệ thống sẽ tự động chèn thêm
  echo "max_input_time = ${port}" >>"$duong_dan_php_ini"
fi

/usr/local/lsws/bin/lswsctrl restart >/dev/null 2>&1
_rundone "Cấu hình max_input_time = $port vào php.ini"

echo -e "${C_GREEN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_BOLD_WHITE}HOÀN TẤT THAY ĐỔI MAX_INPUT_TIME${C_RESET}"
echo -e "${C_GREEN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
left_text "Phiên bản PHP      : ${C_YELLOW}$LSPHP (PHP $phien_ban_php_co_cham)${C_RESET}" 2
left_text "Thời gian chờ mới  : ${C_BOLD_WHITE}${port} giây${C_RESET}" 2
echo -e "${C_GREEN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

[[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-php-ini-main 1
