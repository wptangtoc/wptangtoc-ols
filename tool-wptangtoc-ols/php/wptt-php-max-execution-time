#!/bin/bash

function huong_dan() {
  Tính năng Cấu hình max_execution_time PHP là việc điều chỉnh một cài đặt quan trọng trong PHP để quy định thời gian tối đa [tính bằng giây] mà một đoạn mã [script] PHP được phép chạy trước khi bị máy chủ tự động dừng lại.

  Nói một cách đơn giản, đây là cách bạn đặt ra giới hạn một tác vụ PHP không được chạy quá X giây.

  Mục đích chính:

  * Ngăn chặn script chạy vô hạn: Giúp dừng các script bị lỗi [ví dụ: vòng lặp vô tận] hoặc các tác vụ tốn quá nhiều thời gian, tránh làm treo máy chủ hoặc tiêu tốn tài nguyên quá mức.
  * Quản lý tài nguyên máy chủ: Đảm bảo không có script nào chiếm dụng CPU quá lâu, ảnh hưởng đến các tác vụ khác.
  * Cho phép các tác vụ dài hơi hợp lệ: Đối với các tác vụ cần nhiều thời gian để hoàn thành [như xử lý file lớn, gửi email hàng loạt, đồng bộ dữ liệu], bạn có thể tăng giá trị này lên để script không bị dừng giữa chừng.

  Mặc định là 120 giây.
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null

clear
echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}QUẢN LÝ PHP ➜ Cấu Hình Thời Gian Chạy Tối Đa (max_execution_time)${C_RESET}"
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

if [[ "${1:-}" == '98' ]]; then
  WPTT_IN_MENU="yes"
  WPTT_MENU_BACK="/etc/wptt/wptt-php-ini-main 1"
fi

# ==============================================================================
# CHỌN PHIÊN BẢN PHP
# ==============================================================================
# Gọi list danh sách PHP đang cài
. /etc/wptt/php/wptt-php-version-domain 1 >/dev/null 2>&1

. /etc/wptt/php/tenmien-php 2>/dev/null

if [[ -z "$LSPHP" || "$LSPHP" == "0" ]]; then
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-php-ini-main 1
  exit 0
fi

# ==============================================================================
# LẤY THÔNG TIN CẤU HÌNH HIỆN TẠI
# ==============================================================================
phien_ban_php_co_cham=$(echo "$LSPHP" | grep -Eo '[0-9]{1,2}' | head -1 | perl -pe 's/(\d{1})(?=(?:\d{1}){1,5}\b)/\1./g')

if grep -qi "Ubuntu" /etc/*release 2>/dev/null; then
  duong_dan_php_ini="/usr/local/lsws/$LSPHP/etc/php/$phien_ban_php_co_cham/litespeed/php.ini"
else
  duong_dan_php_ini="/usr/local/lsws/$LSPHP/etc/php.ini"
fi

if [[ ! -f "$duong_dan_php_ini" ]]; then
  echo -e "\n${C_RED}❌ Lỗi: Không tìm thấy file php.ini tại: $duong_dan_php_ini${C_RESET}"
  sleep 3
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-php-ini-main 1
  exit 1
fi

max_execution_time_hientai=$(grep -iE '^[;[:space:]]*max_execution_time[[:space:]]*=' "$duong_dan_php_ini" | awk -F'=' '{print $2}' | tr -d ' ' | head -n 1)
max_execution_time_hientai=${max_execution_time_hientai:-"120"}

echo -e "\n${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
left_text "  Đang cấu hình        : ${C_BOLD_WHITE}$LSPHP (PHP $phien_ban_php_co_cham)${C_RESET}" 2
left_text "  Thời gian hiện tại   : ${C_YELLOW}${max_execution_time_hientai} giây${C_RESET}" 2
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

# Cảnh báo trước khi cấu hình
echo -e "${C_RED}LƯU Ý: Mức độ bảo mật & hiệu suất đã được WPTangToc OLS tối ưu ở mức 120s.${C_RESET}"
echo -e "${C_RED}Chỉ nên tăng giá trị này khi cần chạy tác vụ nặng (Backup, Import dữ liệu lớn).${C_RESET}\n"

# ==============================================================================
# NHẬP GIÁ TRỊ MỚI VÀ XỬ LÝ
# ==============================================================================
while true; do
  echo -e "Gợi ý: Mức an toàn là từ ${C_YELLOW}120${C_RESET} đến ${C_YELLOW}300${C_RESET}. Tối đa khuyến nghị: 1200."
  echo -en "${C_CYAN}Nhập thời gian max_execution_time mới (giây) [0=Thoát]: ${C_RESET}"
  read -r port

  [[ "$port" == "0" || -z "$port" ]] && {
    echo -e "\n${C_YELLOW}Đã thoát.${C_RESET}"
    [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-php-ini-main 1
    exit 0
  }

  # Làm sạch input (loại bỏ chữ cái, khoảng trắng...)
  port=$(echo "$port" | sed -E 's/[[:alpha:]]|[[:space:]]//g')

  if [[ "$port" =~ ^[0-9]+$ ]] && [ "$port" -gt 0 ]; then
    break
  else
    echo -e "${C_RED}❌ Lỗi: Giá trị không hợp lệ! Vui lòng chỉ nhập số nguyên dương (VD: 300).${C_RESET}\n"
  fi
done

# ==============================================================================
# XÁC NHẬN VÀ THỰC THI
# ==============================================================================
echo ""
# ==============================================================================
# XÁC NHẬN VÀ THỰC THI
# ==============================================================================
echo ""
if ! wptt_xac_nhan "Bạn có chắc chắn muốn thay đổi max_execution_time không?" \
  "Hệ thống sẽ chuyển đổi từ: [ ${max_execution_time_hientai} giây ] ➜ sang [ ${port} giây ]" \
  "PHP Script sẽ được phép chạy tối đa ${port} giây trước khi bị ép dừng." \
  "Đồng ý Lưu" "Hủy thao tác"; then
  echo -e "${C_YELLOW}Đã hủy thao tác.${C_RESET}\n"
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-php-ini-main 1
  exit 0
fi

_runing "Ghi cấu hình max_execution_time = $port vào php.ini..."

# sed -i -E "s/^max_execution_time[[:space:]]*=.*/max_execution_time = $port/" "$duong_dan_php_ini"

if grep -qiE '^[;[:space:]]*max_execution_time' "$duong_dan_php_ini"; then
  sed -i -E "s/^[;[:space:]]*max_execution_time[[:space:]]*=.*/max_execution_time = ${port}/" "$duong_dan_php_ini"
else
  # Nếu file php.ini bị mất luôn dòng đó, hệ thống sẽ tự động chèn thêm
  echo "max_execution_time = ${port}" >>"$duong_dan_php_ini"
fi

/usr/local/lsws/bin/lswsctrl restart >/dev/null 2>&1
_rundone "Ghi cấu hình max_execution_time = $port vào php.ini..."

# ==============================================================================
# BẢNG BÁO CÁO THÀNH CÔNG VÀ LỜI KHUYÊN
# ==============================================================================
echo -e "\n${C_GREEN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_BOLD_WHITE}HOÀN TẤT THAY ĐỔI MAX_EXECUTION_TIME${C_RESET}"
echo -e "${C_GREEN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
left_text "Phiên bản PHP      : ${C_YELLOW}$LSPHP (PHP $phien_ban_php_co_cham)${C_RESET}" 2
left_text "Thời gian chạy mới : ${C_BOLD_WHITE}${port} giây${C_RESET}" 2
echo -e "${C_GREEN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
left_text "${C_RED}LỜI KHUYÊN BẢO MẬT TỪ HỆ THỐNG:${C_RESET}" 2
left_text "Sau khi thực thi xong công việc nặng (Ví dụ: Backup xong)," 2
left_text "hãy vào lại Menu này và Khôi phục giá trị về ${C_BOLD_WHITE}120 giây${C_RESET}" 2
left_text "để đảm bảo hiệu suất chống treo máy chủ nhé!" 2
echo -e "${C_GREEN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

[[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-php-ini-main 1
