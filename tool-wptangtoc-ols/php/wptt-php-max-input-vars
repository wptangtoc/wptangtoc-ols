#!/bin/bash

function huong_dan() {
  Tính năng Cấu hình max_input_vars PHP là việc điều chỉnh một cài đặt trong PHP để giới hạn số lượng biến [variables] tối đa mà PHP sẽ chấp nhận từ dữ liệu đầu vào của một yêu cầu web [bao gồm dữ liệu từ $_GET, $_POST và $_COOKIE].

  Nói một cách đơn giản, đây là cách bạn đặt ra giới hạn một yêu cầu gửi lên website không được chứa quá X trường dữ liệu [ví dụ: các ô trong một form].

  Mục đích chính:

  * Bảo vệ chống tấn công Hash Collision [Denial of Service]: Đây là mục đích chính. Kẻ tấn công có thể gửi một số lượng lớn biến đầu vào để cố tình gây ra xung đột trong bảng băm [hash table] của PHP, làm tiêu tốn CPU và có thể dẫn đến từ chối dịch vụ. max_input_vars giúp giảm thiểu nguy cơ này.
  * Cho phép các form phức tạp hoạt động: Một số ứng dụng web có các biểu mẫu [form] rất lớn hoặc gửi đi nhiều dữ liệu [ví dụ: trong các trang quản trị, các thao tác xử lý hàng loạt] có thể vượt qua giới hạn mặc định [thường là 1000]. Tăng giá trị này giúp các ứng dụng đó hoạt động bình thường.
  * Đảm bảo ổn định cho máy chủ: Ngăn chặn việc xử lý quá nhiều biến đầu vào cùng lúc, có thể gây quá tải cho máy chủ.
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null # Nạp thư viện UX Bo Cong

clear
echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}QUẢN LÝ PHP ➜ Cấu Hình Số Lượng Biến Đầu Vào (max_input_vars)${C_RESET}"
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

if [[ "${1:-}" == '98' ]]; then
  WPTT_IN_MENU="yes"
  WPTT_MENU_BACK="/etc/wptt/wptt-php-ini-main 1"
fi

# Gọi list danh sách PHP đang cài
. /etc/wptt/php/wptt-php-version-domain 1 >/dev/null 2>&1

. /etc/wptt/php/tenmien-php 2>/dev/null

if [[ -z "$LSPHP" || "$LSPHP" == "0" ]]; then
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-php-ini-main 1
  exit 0
fi

# ==============================================================================
# LẤY THÔNG TIN CẤU HÌNH HIỆN TẠI
# ==============================================================================
phien_ban_php_co_cham=$(echo "$LSPHP" | grep -Eo '[0-9]{1,2}' | head -1 | perl -pe 's/(\d{1})(?=(?:\d{1}){1,5}\b)/\1./g')

if grep -qi "Ubuntu" /etc/*release 2>/dev/null; then
  duong_dan_php_ini="/usr/local/lsws/$LSPHP/etc/php/$phien_ban_php_co_cham/litespeed/php.ini"
else
  duong_dan_php_ini="/usr/local/lsws/$LSPHP/etc/php.ini"
fi

if [[ ! -f "$duong_dan_php_ini" ]]; then
  echo -e "\n${C_RED}Lỗi: Không tìm thấy file php.ini tại: $duong_dan_php_ini${C_RESET}"
  sleep 3
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-php-ini-main 1
  exit 1
fi

# Trích xuất giá trị (Bắt cả những dòng đang bị comment bằng dấu ;): mặc định giá trị này hay cất ở comment
max_input_vars_hientai=$(grep -iE '^[;[:space:]]*max_input_vars[[:space:]]*=' "$duong_dan_php_ini" | awk -F'=' '{print $2}' | tr -d ' ' | head -n 1)
max_input_vars_hientai=${max_input_vars_hientai:-"1000"}

echo -e "\n${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
left_text "  Đang cấu hình        : ${C_BOLD_WHITE}$LSPHP (PHP $phien_ban_php_co_cham)${C_RESET}" 2
left_text "  Giới hạn hiện tại    : ${C_YELLOW}${max_input_vars_hientai} biến${C_RESET}" 2
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

# ==============================================================================
# NHẬP GIÁ TRỊ MỚI VÀ XỬ LÝ
# ==============================================================================
while true; do
  echo -e "Gợi ý: Mức tiêu chuẩn là ${C_YELLOW}1000${C_RESET}. Đối với website WooCommerce nặng, nên để ${C_YELLOW}3000${C_RESET}."
  echo -en "${C_CYAN}Nhập số lượng max_input_vars mới [0=Thoát]: ${C_RESET}"
  read -r input_vars_number

  [[ "$input_vars_number" == "0" || -z "$input_vars_number" ]] && {
    echo -e "\n${C_YELLOW}Đã thoát.${C_RESET}"
    [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-php-ini-main 1
    exit 0
  }

  # Làm sạch input (loại bỏ chữ cái và khoảng trắng)
  input_vars_number=$(echo "$input_vars_number" | sed -E 's/[[:alpha:]]|[[:space:]]//g')

  if [[ "$input_vars_number" =~ ^[0-9]+$ ]] && [ "$input_vars_number" -gt 0 ]; then
    break
  else
    echo -e "${C_RED}❌ Lỗi: Giá trị không hợp lệ! Vui lòng chỉ nhập số nguyên dương (VD: 3000).${C_RESET}\n"
  fi
done

if ! wptt_xac_nhan "Bạn có chắc chắn muốn thay đổi max_input_vars không?" \
  "Số lượng biến đầu vào sẽ đổi từ: [ ${max_input_vars_hientai} ] ➜ sang [ ${input_vars_number} ]" \
  "Không nên tăng quá cao (ví dụ: > 10000) vì có thể làm chậm và dễ bị tấn công." \
  "Đồng ý Lưu" "Hủy thao tác"; then
  echo -e "${C_YELLOW}Đã hủy thao tác.${C_RESET}\n"
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-php-ini-main 1
  exit 0
fi

echo ""
_runing "Ghi cấu hình max_input_vars = ${input_vars_number} vào php.ini"

if grep -qiE '^[;[:space:]]*max_input_vars' "$duong_dan_php_ini"; then
  sed -i -E "s/^[;[:space:]]*max_input_vars[[:space:]]*=.*/max_input_vars = ${input_vars_number}/" "$duong_dan_php_ini"
else
  # Nếu file php.ini bị mất luôn dòng đó, hệ thống sẽ tự động chèn thêm
  echo "max_input_vars = ${input_vars_number}" >>"$duong_dan_php_ini"
fi

/usr/local/lsws/bin/lswsctrl restart >/dev/null 2>&1
_rundone "Ghi cấu hình max_input_vars = ${input_vars_number} vào php.ini"

echo -e "\n${C_GREEN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_BOLD_WHITE}HOÀN TẤT THAY ĐỔI MAX_INPUT_VARS${C_RESET}"
echo -e "${C_GREEN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
left_text "Phiên bản áp dụng  : ${C_YELLOW}$LSPHP (PHP $phien_ban_php_co_cham)${C_RESET}" 2
left_text "Số lượng biến mới  : ${C_BOLD_WHITE}${input_vars_number} biến${C_RESET}" 2
echo -e "${C_GREEN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

[[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-php-ini-main 1
