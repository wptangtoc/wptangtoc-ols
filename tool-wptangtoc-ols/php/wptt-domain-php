#!/bin/bash
# @author: Gia Tuấn
# @website: https://wptangtoc.com
# @email: giatuan@wptangtoc.com
# @since: 2025

function huong_dan() {
  Tính năng Thay đổi phiên bản PHP riêng cho domain là khả năng cho phép bạn chọn và áp dụng một phiên bản PHP cụ thể [ví dụ: PHP 7.4, PHP 8.0, PHP 8.1, PHP 8.2, PHP 8.3] để chạy cho một website [tên miền hoặc tên miền phụ] nhất định trên cùng một máy chủ, độc lập với phiên bản PHP mà các website khác hoặc máy chủ đang sử dụng làm mặc định.

  Nói đơn giản, nếu bạn có nhiều website trên cùng một hệ thống, bạn có thể cài đặt website A chạy PHP 8.1 trong khi website B vẫn chạy PHP 7.4, mà không ảnh hưởng lẫn nhau.

  Mục đích chính:
  * Đảm bảo tương thích ứng dụng: Các website, theme, plugin khác nhau có thể yêu cầu các phiên bản PHP khác nhau để hoạt động tối ưu hoặc tránh lỗi.
  * Thử nghiệm và nâng cấp an toàn: Cho phép bạn kiểm tra website với một phiên bản PHP mới hơn trước khi áp dụng rộng rãi, giảm thiểu rủi ro.
  * Bảo mật và hiệu suất: Giúp bạn sử dụng phiên bản PHP mới nhất, được hỗ trợ và bảo mật tốt hơn cho các website tương thích, trong khi vẫn duy trì hoạt động cho các website cũ hơn chưa thể nâng cấp ngay.
  * Tận dụng tính năng mới: Các phiên bản PHP mới thường đi kèm với các tính năng ngôn ngữ mới và cải tiến hiệu suất.

  Bài viết kiểm tra hiệu suất PHP: https://wptangtoc.com/php-kiem-tra-toc-do-cac-phien-ban/
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null # Nạp thư viện UX Bo Cong

clear
echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}QUẢN LÝ PHP ➜ Thay Đổi Phiên Bản PHP Cho 1 Website (Domain)${C_RESET}"
echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

. /etc/wptt/tenmien 2>/dev/null
lua_chon_NAME "Thay đổi PHP Domain"

[[ "$NAME" == "0" || -z "$NAME" ]] && {
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-php-ini-main 1
  exit 0
}

pathcheck="/etc/wptt/vhost/.$NAME.conf"
if [[ ! -f "$pathcheck" ]]; then
  echo -e "\n${C_RED}❌ Lỗi: Tên miền không tồn tại trên hệ thống này!${C_RESET}"
  sleep 3
  exec /etc/wptt/wptt-php-ini-main 1
  exit 1
fi

. "$pathcheck" 2>/dev/null

# Lấy phiên bản PHP hiện tại
phpcheck=$(php -v | grep cli | grep -oP 'PHP \K[0-9]+\.[0-9]+')
php_ver_chon_goc=${phpcheck//[-._]/}
checkioncube=""
[[ -f /usr/local/lsws/lsphp${php_ver_chon_goc}/lib64/php/modules/ioncube.so ]] && checkioncube="1"

php_hien_tai=${phien_ban_php_domain:-$phpcheck}

echo -e "\n${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
left_text "  Đang xử lý Website : ${C_BOLD_WHITE}$NAME${C_RESET}" 2
left_text "  PHP hiện đang chạy : ${C_YELLOW}PHP $php_hien_tai${C_RESET}" 2
echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

# ==============================================================================
# QUÉT VÀ LẤY DANH SÁCH PHP TỪ LITESPEED REPO
# ==============================================================================
_runing "Đang dọn dẹp cache và quét các phiên bản PHP khả dụng..."

if command -v dnf >/dev/null 2>&1; then
  dnf clean all >/dev/null 2>&1
else
  yum clean all >/dev/null 2>&1
fi

(/etc/wptt/php/kho-luu-tru-litespeed) # Subshell

x=$(grep -oP 'lsphp[0-9]+' /tmp/php_extension_call_eol 2>/dev/null | sort -u | grep -Eo '[0-9]{1,2}' | perl -pe 's/(\d{1})(?=(?:\d{1}){1,5}\b)/\1./g' | sed 's/^/PHP /g')

if [[ -z $(echo "$x" | grep -Eo '[0-9]{1,2}') ]]; then
  sed -i '/rpms.litespeedtech.com/d' /etc/hosts
  echo -e '\n52.55.120.73 rpms.litespeedtech.com\n' >>/etc/hosts
  (/etc/wptt/php/kho-luu-tru-litespeed)
  x=$(grep -oP 'lsphp[0-9]+' /tmp/php_extension_call_eol 2>/dev/null | sort -u | grep -Eo '[0-9]{1,2}' | perl -pe 's/(\d{1})(?=(?:\d{1}){1,5}\b)/\1./g' | sed 's/^/PHP /g')
  su_dung_repo_du_phong=1
fi

if [[ -z $(echo "$x" | grep -Eo '[0-9]{1,2}') ]]; then
  _runloi "Quét phiên bản PHP thất bại!"
  sed -i '/rpms.litespeedtech.com/d' /etc/hosts
  sleep 3
  exec /etc/wptt/wptt-php-ini-main 1
  exit 1
fi
_rundone "Quét phiên bản PHP thành công!"

# ==============================================================================
# MENU CHỌN PHIÊN BẢN PHP
# ==============================================================================
echo -e "\n${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_BOLD_WHITE}DANH SÁCH PHIÊN BẢN PHP HỖ TRỢ${C_RESET}"
echo -e "${C_CYAN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"

selects=()
while IFS= read -r line; do
  [[ -n "$line" ]] && selects+=("$line")
done <<<"$x"

i=1
for val in "${selects[@]}"; do
  left_text "  ${C_CYAN}$i)${C_RESET} ${C_BOLD_WHITE}$val${C_RESET}" 2
  ((i++))
done
echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯${C_RESET}"

while true; do
  echo -en "${C_CYAN}Nhập lựa chọn của bạn (1-${#selects[@]}) [0=Thoát]: ${C_RESET}"
  read -r REPLY
  [[ "$REPLY" == "0" || -z "$REPLY" ]] && {
    echo -e "${C_YELLOW}Đã hủy thao tác.${C_RESET}"
    [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-php-ini-main 1
    exit 0
  }

  if [[ "$REPLY" =~ ^[0-9]+$ ]] && [ "$REPLY" -ge 1 ] && [ "$REPLY" -le ${#selects[@]} ]; then
    php_version_text="${selects[$((REPLY - 1))]}"
    break
  else
    echo -e "${C_RED}❌ Lựa chọn không hợp lệ!${C_RESET}"
  fi
done

# Định dạng biến
php_version_raw=${php_version_text//[-._ PHP]/}
php_ver_chon=$(echo "$php_version_raw" | head -1)
php_version_cham=$(echo "$php_ver_chon" | perl -pe 's/(\d{1})(?=(?:\d{1}){1,5}\b)/\1./g')

if [[ "$php_hien_tai" == "$php_version_cham" ]]; then
  echo -e "\n${C_YELLOW}⚠️ Website $NAME hiện tại đã sử dụng PHP $php_version_cham rồi!${C_RESET}"
  sleep 3
  exec /etc/wptt/wptt-php-ini-main 1
  exit 0
fi

# ==============================================================================
# KIỂM TRA ĐỘ TƯƠNG THÍCH VỚI WORDPRESS CORE
# ==============================================================================
if [[ -f "/usr/local/lsws/$NAME/html/wp-load.php" ]]; then
  # ==============================================================================
  # KIỂM TRA ĐỘ TƯƠNG THÍCH VỚI WORDPRESS CORE
  # ==============================================================================

  #convert 8.3 thành 83 để thực thi cli
  php_hien_tai_cli_cua_domain_cu=${php_hien_tai/./}
  WP_EXEC="sudo -u $User_name_vhost /usr/local/lsws/lsphp${php_hien_tai_cli_cua_domain_cu}/bin/php /usr/local/bin/wp"

  check_ver_core_wordpress=$($WP_EXEC core version --path="/usr/local/lsws/$NAME/html" --allow-root 2>/dev/null | cut -f1-2 -d '.' | sed 's/\.//g')
  loi_tuong_thich=""
  if [[ -n "$check_ver_core_wordpress" ]]; then
    # WordPress 6.9 trở lên mới bắt đầu support tốt PHP 8.5
    if [[ "$php_ver_chon" == '85' ]] && ((check_ver_core_wordpress < 69)); then
      loi_tuong_thich="WordPress 6.9"
    # WordPress 6.7 trở lên mới support ổn định PHP 8.4
    elif [[ "$php_ver_chon" == '84' ]] && ((check_ver_core_wordpress < 67)); then
      loi_tuong_thich="WordPress 6.7"
    # WordPress 6.4 trở lên mới support ổn định PHP 8.3
    elif [[ "$php_ver_chon" == '83' ]] && ((check_ver_core_wordpress < 64)); then
      loi_tuong_thich="WordPress 6.4"
    # WordPress 6.0 trở lên cho PHP 8.2
    elif [[ "$php_ver_chon" == '82' ]] && ((check_ver_core_wordpress < 60)); then
      loi_tuong_thich="WordPress 6.0"
    # WordPress 5.9 trở lên cho PHP 8.1
    elif [[ "$php_ver_chon" == '81' ]] && ((check_ver_core_wordpress < 59)); then
      loi_tuong_thich="WordPress 5.9"
    # WordPress 5.6 trở lên cho PHP 8.0
    elif [[ "$php_ver_chon" == '80' ]] && ((check_ver_core_wordpress < 56)); then
      loi_tuong_thich="WordPress 5.6"
    # WordPress 5.3 trở lên cho PHP 7.4
    elif [[ "$php_ver_chon" == '74' ]] && ((check_ver_core_wordpress < 53)); then
      loi_tuong_thich="WordPress 5.3"
    # WordPress 5.0 trở lên cho PHP 7.3
    elif [[ "$php_ver_chon" == '73' ]] && ((check_ver_core_wordpress < 50)); then
      loi_tuong_thich="WordPress 5.0"
    fi
  fi

  if [[ -n "$loi_tuong_thich" ]]; then
    echo -e "\n${C_RED}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
    center_text "${C_BOLD_WHITE}LỖI TƯƠNG THÍCH MÃ NGUỒN WORDPRESS${C_RESET}"
    echo -e "${C_RED}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
    left_text "Phiên bản WordPress hiện tại của bạn QUÁ CŨ, không thể chạy" 2
    left_text "được với ${C_YELLOW}PHP $php_version_cham${C_RESET}." 2
    left_text "Vui lòng cập nhật WordPress lên tối thiểu ${C_YELLOW}$loi_tuong_thich${C_RESET} hoặc" 2
    left_text "chọn một phiên bản PHP thấp hơn để tránh bị lỗi 500." 2
    echo -e "${C_RED}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"
    sleep 5
    exec /etc/wptt/wptt-php-ini-main 1
    exit 1
  fi
fi

if
  ! wptt_xac_nhan "Xác nhận: [PHP $php_hien_tai] ➜ [PHP $php_version_cham] Website $NAME!" \
    "Nếu Source Code không tương thích, website có thể bị lỗi!" \
    "Đổi xong nếu không tương thích hãy đổi lại về phiên bản PHP cũ!" \
    "Đồng ý đổi PHP" "Hủy, để tôi kiểm tra lại Source Code"
then
  echo -e "${C_YELLOW}Đã hủy thao tác.${C_RESET}\n"
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-php-ini-main 1
  exit 0
fi

clear
echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}ĐANG TRIỂN KHAI: ${C_BOLD_WHITE}$php_version_text CHO $NAME${C_RESET}"
echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

php_run_download=""
if [[ ! -d "/usr/local/lsws/lsphp${php_ver_chon}" ]]; then
  echo "Phiên bản PHP $php_version_text chưa có sẵn trong hệ thống."
  echo "bắt đầu tiến hành Cài đặt. Thời gian chờ đợi sẽ 3 đến 5 phút"
  php_run_download='1'
fi

# Cài bù thư viện Json cho PHP 7.4 (CentOS 7)
if [[ "$php_ver_chon" == '74' ]] && ! command -v dnf >/dev/null 2>&1; then
  if [[ -z $(rpm -aq | grep 'lsphp74-json') ]]; then
    php_run_download='1'
  fi
fi

if [[ -n "$php_run_download" ]]; then
  extensions=(common gd imagick process mbstring pdo mysqlnd xml opcache mcrypt imap bcmath intl zip mysql json curl pecl-igbinary igbinary)

  if [[ $(dnf list available 2>/dev/null | grep "lsphp${php_ver_chon}") || $(apt list 2>/dev/null | grep "lsphp${php_ver_chon}") ]]; then
    _runing "Phiên bản PHP $php_version_text chưa có sẵn bắt đầu tiến hành Cài đặt, thời gian sẽ 3 đến 5 phút"

    _runing "Đang tải và cài đặt lõi lsphp${php_ver_chon}..."
    yum install -y lsphp${php_ver_chon} >/dev/null 2>&1
    _rundone "Cài đặt lõi lsphp${php_ver_chon} thành công"

    for extension in "${extensions[@]}"; do
      _runing "Đang cài đặt extension: lsphp${php_ver_chon}-$extension..."
      yum install -y lsphp${php_ver_chon}-$extension >/dev/null 2>&1
      _rundone "Cài đặt extension: lsphp${php_ver_chon}-$extension"
    done

  else
    url_repo_litespeed=$(
      awk '
      BEGIN { FS = "/" }
      {
        filename = $NF; split(filename, parts, "-")
        pkg_name = ""; version = ""
        if (parts[2] == "pecl") { pkg_name = parts[1] "-" parts[2] "-" parts[3]; version = parts[4] }
        else if (parts[2] ~ /^[0-9]+\.[0-9]+/) { pkg_name = parts[1]; version = parts[2] }
        else { pkg_name = parts[1] "-" parts[2]; version = parts[3] }
        if (version > versions[pkg_name]) { versions[pkg_name] = version; latest_lines[pkg_name] = $0 }
      }
      END { PROCINFO["sorted_in"] = "@ind_str_asc"; for (pkg in latest_lines) print latest_lines[pkg] }' /tmp/php_extension_call_eol | grep "lsphp${php_ver_chon}" | grep -oP 'href="\K[^"]+' | grep -v 'debuginfo\|-devel\|-debugsource'
    )

    for extension in "${extensions[@]}"; do
      _runing "Đang cài đặt extension: lsphp${php_ver_chon}-$extension (Kho EOL)..."
      if rpm_url=$(printf "%s\n" "${url_repo_litespeed[@]}" | grep "lsphp${php_ver_chon}-${extension}-" | grep '\.rpm'); then
        [[ -n "$rpm_url" ]] && dnf install "http://rpms.litespeedtech.com$rpm_url" -y >/dev/null 2>&1
      fi
      if deb_url=$(printf "%s\n" "${url_repo_litespeed[@]}" | grep "lsphp${php_ver_chon}-${extension}-" | grep '\.deb'); then
        if [[ -n "$deb_url" ]]; then
          TEMP_DIR_file=$(mktemp -d)
          wget -q -P "$TEMP_DIR_file" "https://rpms.litespeedtech.com$deb_url"
          apt install -y "$TEMP_DIR_file"/*.deb >/dev/null 2>&1
          rm -rf "$TEMP_DIR_file"
        fi
      fi
      _rundone "Cài đặt extension: lsphp${php_ver_chon}-$extension"
    done

    _runing "Đang tải và cài đặt lõi lsphp${php_ver_chon} (Kho EOL)..."
    url_php_eol_install=$(printf "%s\n" "${url_repo_litespeed[@]}" | grep -P "lsphp${php_ver_chon}-\K[0-9]+\.[0-9]+\|lsphp${php_ver_chon}_\K[0-9]+\.[0-9]+" | tail -n1)
    if [[ "$url_php_eol_install" == *.rpm ]]; then
      dnf install "http://rpms.litespeedtech.com${url_php_eol_install}" -y >/dev/null 2>&1
    else
      TEMP_DIR_file=$(mktemp -d)
      wget -q -P "$TEMP_DIR_file" "https://rpms.litespeedtech.com${url_php_eol_install}"
      apt install -y "$TEMP_DIR_file"/*.deb >/dev/null 2>&1
      rm -rf "$TEMP_DIR_file"
    fi
    _rundone "Cài đặt lõi lsphp${php_ver_chon} thành công"
    rm -f /tmp/php_extension_call_eol
  fi

  # Fix Json cho PHP 7.4 CentOS
  if ! command -v dnf >/dev/null 2>&1; then
    if [[ "$php_ver_chon" == '74' ]] && ! /usr/local/lsws/lsphp74/bin/php -m | grep -q 'json'; then
      _runing "Cài đặt bổ sung thư viện JSON cho PHP 7.4..."
      rpm -ivh http://rpms.litespeedtech.com/centos/7/update/x86_64/RPMS/lsphp74-json-7.4.33-2.el7.x86_64.rpm >/dev/null 2>&1
      _rundone "Cài đặt thư viện JSON hoàn tất"
    fi
  fi

  # Redis / Memcached / IonCube
  if systemctl is-active --quiet valkey 2>/dev/null || systemctl is-active --quiet keydb 2>/dev/null || systemctl is-active --quiet redis 2>/dev/null; then
    _runing "Đang cài đặt extension: lsphp${php_ver_chon}-redis..."
    if grep -qi "Ubuntu" /etc/*release; then
      yum install lsphp${php_ver_chon}-redis -y >/dev/null 2>&1
    else
      if [[ $(dnf list available 2>/dev/null | grep "lsphp${php_ver_chon}") || $(apt list 2>/dev/null | grep "lsphp${php_ver_chon}") ]]; then
        yum install lsphp${php_ver_chon}-pecl-redis lsphp${php_ver_chon}-pecl-igbinary -y >/dev/null 2>&1
      else
        for ext in pecl-igbinary pecl-redis; do
          rpm_url=$(printf "%s\n" "${url_repo_litespeed[@]}" | grep "lsphp${php_ver_chon}-${ext}-" | head -n1)
          [[ -n "$rpm_url" ]] && dnf install "http://rpms.litespeedtech.com$rpm_url" -y >/dev/null 2>&1
        done
      fi
    fi
    _rundone "Cài đặt extension: lsphp${php_ver_chon}-redis"
  fi

  if [[ $(systemctl status memcached.service 2>/dev/null | grep 'Active' | awk '{print $2}') == 'active' ]]; then
    _runing "Đang cài đặt extension: lsphp${php_ver_chon}-memcached..."
    if grep -qi "Ubuntu" /etc/*release; then
      yum install lsphp${php_ver_chon}-memcached -y >/dev/null 2>&1
    else
      if [[ $(dnf list available 2>/dev/null | grep "lsphp${php_ver_chon}") || $(apt list 2>/dev/null | grep "lsphp${php_ver_chon}") ]]; then
        yum install lsphp${php_ver_chon}-pecl-memcached -y --nogpgcheck --disablerepo="mariadb" >/dev/null 2>&1
      else
        for ext in pecl-igbinary pecl-msgpack pecl-memcached; do
          rpm_url=$(printf "%s\n" "${url_repo_litespeed[@]}" | grep "lsphp${php_ver_chon}-${ext}-" | head -n1)
          [[ -n "$rpm_url" ]] && dnf install "http://rpms.litespeedtech.com$rpm_url" -y >/dev/null 2>&1
        done
      fi
    fi
    _rundone "Cài đặt extension: lsphp${php_ver_chon}-memcached"
  fi

  if [[ "$checkioncube" == "1" ]]; then
    _runing "Đang cài đặt extension: lsphp${php_ver_chon}-ioncube..."
    yum install lsphp${php_ver_chon}-ioncube -y >/dev/null 2>&1
    _rundone "Cài đặt extension: lsphp${php_ver_chon}-ioncube"
  fi

  # ==============================================================================
  # TỐI ƯU HÓA PHP.INI CHO BẢN MỚI
  # ==============================================================================
  _runing "Đang phân tích RAM để tự động tối ưu php.ini (OPCache, JIT, Memory)..."
  if grep -qi "Ubuntu" /etc/*release; then
    duong_dan_php_ini="/usr/local/lsws/lsphp${php_ver_chon}/etc/php/$php_version_cham/litespeed/php.ini"
  else
    duong_dan_php_ini="/usr/local/lsws/lsphp${php_ver_chon}/etc/php.ini"
  fi

  TOTAL_RAM_MB=$(free -m | awk '/^Mem:/{print $2}')
  if [ "$TOTAL_RAM_MB" -le 1200 ]; then
    OPCACHE_MEM="64"
    JIT_BUFFER="0M"
    REALPATH_SIZE="512K"
  elif [ "$TOTAL_RAM_MB" -le 2500 ]; then
    OPCACHE_MEM="128"
    JIT_BUFFER="64M"
    REALPATH_SIZE="1024K"
  elif [ "$TOTAL_RAM_MB" -le 4500 ]; then
    OPCACHE_MEM="256"
    JIT_BUFFER="128M"
    REALPATH_SIZE="2048K"
  else
    OPCACHE_MEM="512"
    JIT_BUFFER="256M"
    REALPATH_SIZE="2048K"
  fi

  sed -i '/realpath_cache_size/d' "$duong_dan_php_ini"
  sed -i '/realpath_cache_ttl/d' "$duong_dan_php_ini"
  echo "realpath_cache_size = $REALPATH_SIZE
realpath_cache_ttl = 7200" >>"$duong_dan_php_ini"

  sed -i "/opcache.memory_consumption/d" "$duong_dan_php_ini"
  sed -i "/opcache.interned_strings_buffer/d" "$duong_dan_php_ini"
  sed -i "/opcache.max_accelerated_files/d" "$duong_dan_php_ini"
  sed -i "/opcache.revalidate_freq/d" "$duong_dan_php_ini"
  sed -i "/opcache.fast_shutdown/d" "$duong_dan_php_ini"
  sed -i "/opcache.enable_cli/d" "$duong_dan_php_ini"
  echo "opcache.memory_consumption=${OPCACHE_MEM}
opcache.interned_strings_buffer=8
opcache.max_accelerated_files=10000
opcache.revalidate_freq=100
opcache.fast_shutdown=1
opcache.enable_cli=1" >>"$duong_dan_php_ini"

  if ((php_ver_chon >= 80)); then
    sed -i '/opcache.jit_buffer_size/d' "$duong_dan_php_ini"
    sed -i '/opcache.jit/d' "$duong_dan_php_ini"
    echo "opcache.jit=tracing
opcache.jit_buffer_size=${JIT_BUFFER}" >>"$duong_dan_php_ini"
  fi

  if [[ "$wptangtoc_ols_giatuan" == "1" ]]; then
    sed -i "/opcache.validate_timestamps/d" "$duong_dan_php_ini"
    sed -i "/opcache.file_update_protection/d" "$duong_dan_php_ini"
    echo "opcache.validate_timestamps=0
opcache.file_update_protection=0" >>"$duong_dan_php_ini"
  fi

  sed -i "s/expose_php = On/expose_php = off/g" "$duong_dan_php_ini"
  sed -i "s/upload_max_filesize = 2M/upload_max_filesize = 8M/g" "$duong_dan_php_ini"
  sed -i "s/max_execution_time = 30/max_execution_time = 120/g" "$duong_dan_php_ini"
  _rundone "Tối ưu hóa tài nguyên PHP hoàn tất"
fi

