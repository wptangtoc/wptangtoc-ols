  function ioncube_active() {
    ioncube_support="lsphp74
			lsphp81
			lsphp82
			lsphp83
			lsphp84"
    if [[ $(echo $ioncube_support | grep $LSPHP) ]]; then
      php_co_dau_cham=$(echo $LSPHP | grep -Eo '[0-9]{1,2}' | head -1 | perl -pe 's/(\d{1})(?=(?:\d{1}){1,5}\b)/\1./g') #ví dụ thành: lsphp81 thành 8.1
