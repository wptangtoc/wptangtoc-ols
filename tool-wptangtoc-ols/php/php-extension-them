      --prompt="Nhập extension cần tìm > " \
      --height='~60%' \
      --border=rounded \
      --color=border:red \
      --layout=reverse \
      --header="Tìm thấy ${#selects[@]} extension. [↑/↓] Di chuyển, [ESC] Hủy, [Enter] Chọn." \
