        duong_dan_luu_tru_extension_so="/usr/local/lsws/$LSPHP/lib/php"
      else
        duong_dan_luu_tru_extension_so="/usr/local/lsws/$LSPHP/lib64/php/modules"
      fi

      #/usr/local/lsws/$LSPHP/lib64/php/modules/ioncube_loader_lin_${php_co_dau_cham}.so dành cho AlmaLinux
      if [[ -f $duong_dan_luu_tru_extension_so/ioncube_loader_lin_${php_co_dau_cham}.so ]]; then
        echo "Đã được cài đặt ioncube cho $LSPHP trước đó rồi"
        exec /etc/wptt/wptt-php-ini-main 1
        exit
      fi

      wget -N https://downloads.ioncube.com/loader_downloads/ioncube_loaders_lin_x86-64.zip
      unzip -oq ioncube_loaders_lin_x86-64.zip
      cd ioncube && chmod +x *.so && ls

      cp ioncube_loader_lin_${php_co_dau_cham}.so $duong_dan_luu_tru_extension_so

      cd -
      rm -rf ioncube
      rm -f ioncube_loaders_lin_x86-64.zip
      echo 'zend_extension = "'${duong_dan_luu_tru_extension_so}'/ioncube_loader_lin_'${php_co_dau_cham}'.so"' >>$duong_dan_php_ini
      /usr/local/lsws/bin/lswsctrl restart >/dev/null 2>&1
      _rundone "$cai_dat $LSPHP extension $php_extension_chon"
    else
      echo "Ioncube không support phiên bản PHP $LSPHP"
    fi
    exec /etc/wptt/wptt-php-ini-main 1
  }
  ioncube_active $LSPHP
