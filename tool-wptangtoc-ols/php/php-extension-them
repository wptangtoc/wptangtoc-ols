#!/bin/bash
# @author: Gia Tuấn
# @website: https://wptangtoc.com
# @email: giatuan@wptangtoc.com
# @since: 2025

function huong_dan() {
  Tính năng Cài đặt extension PHP là khả năng thêm các thư viện mở rộng [module hoặc plugin] vào môi trường PHP để bổ sung các chức năng cụ thể mà PHP cốt lõi không có sẵn.

  Nói một cách đơn giản, PHP có một bộ chức năng cơ bản. Khi bạn cần PHP làm những việc chuyên biệt hơn như kết nối với một loại cơ sở dữ liệu đặc thù [ví dụ: mysqli, pgsql], xử lý hình ảnh [gd, imagick], làm việc với XML, mã hóa dữ liệu, hay tăng tốc thực thi mã [opcache], bạn cần cài đặt thêm các extension tương ứng.

  Mục đích chính:
  * Mở rộng khả năng của PHP: Giúp PHP thực hiện được nhiều tác vụ đa dạng hơn.
  * Tương thích với ứng dụng: Nhiều ứng dụng web và framework [như WordPress, Laravel], một số plugin WordPress, theme WordPress... yêu cầu phải có một số extension PHP nhất định để hoạt động đúng.
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null # Nạp thư viện UX Bo Cong

clear
echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}QUẢN LÝ PHP ➜ Cài Đặt Thêm Extension (Thư viện Mở rộng)${C_RESET}"
echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

if [[ "${1:-}" == '98' ]]; then
  WPTT_IN_MENU="yes"
  WPTT_MENU_BACK="/etc/wptt/wptt-php-ini-main 1"
fi

# ==============================================================================
# BƯỚC 1: CHỌN PHIÊN BẢN PHP
# ==============================================================================
. /etc/wptt/php/wptt-php-version-domain 1 >/dev/null 2>&1
echo -e "${C_YELLOW}Vui lòng chọn Phiên bản PHP bạn muốn cài thêm Extension:${C_RESET}"
. /etc/wptt/php/tenmien-php 2>/dev/null

if [[ -z "$LSPHP" || "$LSPHP" == "0" ]]; then
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-php-ini-main 1
  exit 0
fi

if [[ ! -d "/usr/local/lsws/$LSPHP" ]]; then
  echo -e "\n${C_RED}❌ Lỗi: Phiên bản $LSPHP chưa được cài đặt trên máy chủ!${C_RESET}"
  sleep 3
  exit 1
fi

php_ver_hien_thi=$(echo "$LSPHP" | grep -Eo '[0-9]{1,2}' | head -1 | perl -pe 's/(\d{1})(?=(?:\d{1}){1,5}\b)/\1./g' | sed 's/^/PHP /g')
rm -f /tmp/php_extension.txt

_runing "Đang quét danh sách Extensions khả dụng cho $php_ver_hien_thi..."

if command -v dnf >/dev/null 2>&1; then dnf clean all >/dev/null 2>&1; else yum clean all >/dev/null 2>&1; fi

if [[ $(dnf list available 2>/dev/null | grep "$LSPHP") || $(apt list 2>/dev/null | grep "$LSPHP") ]]; then
  # PHP Còn Support
  if grep -qi "Ubuntu" /etc/*release 2>/dev/null; then
    php_extension_da_cai_dat=($(apt list --installed 2>/dev/null | grep "$LSPHP" | cut -f2-10 -d '-' | cut -f1 -d '.' | cut -f1 -d '/' | sed '/installed/d' | sed '1d' | sed '/^$/d' | sort | uniq))
    php_extension=($(yum search lsphp 2>/dev/null | grep "$LSPHP" | cut -f2-10 -d '-' | cut -f1 -d '.' | cut -f1 -d ' ' | sed '/-debuginfo/d' | sed '/^$/d' | sed "/$LSPHP/d" | sort | uniq))
  elif grep -qE "release 8" /etc/redhat-release 2>/dev/null; then
    php_extension_da_cai_dat=($(yum list installed --disablerepo="*" --enablerepo="litespeed,litespeed-edge,litespeed-edge-update,litespeed-update" 2>/dev/null | grep "$LSPHP" | cut -f2-10 -d '-' | cut -f1 -d '.' | sed '1d' | sed '/^$/d' | sort | uniq))
    php_extension=($(yum search lsphp --disablerepo="*" --enablerepo="litespeed,litespeed-edge,litespeed-edge-update,litespeed-update" 2>/dev/null | grep "$LSPHP" | cut -f2-10 -d '-' | cut -f1 -d '.' | sed '/-debuginfo/d' | sed '/^$/d' | sed "/$LSPHP/d" | sort | uniq))
  else
    php_extension_da_cai_dat=($(yum list installed --disablerepo="*" --enablerepo="litespeed,litespeed-update" 2>/dev/null | grep "$LSPHP" | cut -f2-10 -d '-' | cut -f1 -d '.' | sed '1d' | sed '/^$/d' | sort | uniq))
    php_extension=($(yum search lsphp --disablerepo="*" --enablerepo="litespeed,litespeed-update" 2>/dev/null | grep "$LSPHP" | cut -f2-10 -d '-' | cut -f1 -d '.' | sed '/-debuginfo/d' | sed '/^$/d' | sed "/$LSPHP/d" | sort | uniq))
  fi

  # Bơm Repo dự phòng nếu lỗi
  if [[ -z "${php_extension[*]}" ]]; then
    sed -i '/rpms.litespeedtech.com/d' /etc/hosts
    echo -e '\n52.55.120.73 rpms.litespeedtech.com\n' >>/etc/hosts
    if command -v dnf >/dev/null 2>&1; then dnf clean all >/dev/null 2>&1; else yum clean all >/dev/null 2>&1; fi
    repo_du_phong=1
    # Quét lại sau khi bơm (Rút gọn)
    php_extension=($(yum search lsphp 2>/dev/null | grep "$LSPHP" | cut -f2-10 -d '-' | cut -f1 -d '.' | cut -f1 -d ' ' | sed '/-debuginfo/d' | sed '/^$/d' | sed "/$LSPHP/d" | sort | uniq))
  fi

else
  # PHP Hết Hạn (EOL)
  (/etc/wptt/php/kho-luu-tru-litespeed)
  php_extension=($(grep "$LSPHP" /tmp/php_extension_call_eol | sed -E 's/.*('$LSPHP'(-[a-z-]+)*).*/\1/' | sort -u | grep -v 'debuginfo\|devel\|debugsource' | sed "s/^$LSPHP-//" | grep -v '^$' | sed 's/-$//g' | grep -v "$LSPHP"))

  if grep -qi "Ubuntu" /etc/*release 2>/dev/null; then
    php_extension_da_cai_dat=($(apt list --installed 2>/dev/null | grep "$LSPHP" | cut -f2-10 -d '-' | cut -f1 -d '.' | cut -f1 -d '/' | sed '/installed/d' | sed '1d' | sed '/^$/d' | sort | uniq))
  else
    php_extension_da_cai_dat=($(yum list installed --disablerepo="*" --enablerepo="litespeed,litespeed-update" 2>/dev/null | grep "$LSPHP" | cut -f2-10 -d '-' | cut -f1 -d '.' | sed '1d' | sed '/^$/d' | sort | uniq))
  fi
fi

if [[ -z "${php_extension[*]}" ]]; then
  _runloi "Không thể kết nối đến Repo LiteSpeed để quét Extension!"
  sed -i '/rpms.litespeedtech.com/d' /etc/hosts
  exit 1
fi

# Lọc bỏ các extension đã cài
for phpexe in "${php_extension[@]}"; do
  if [[ ! " ${php_extension_da_cai_dat[*]} " =~ " ${phpexe} " ]]; then
    echo "$phpexe" >>/tmp/php_extension.txt
  fi
done

# Kiểm tra thiếu ionCube thì bơm vào list
if grep -qi "Ubuntu" /etc/*release 2>/dev/null; then
  [[ -d "/usr/local/lsws/$LSPHP/lib/php" && -z $(ls "/usr/local/lsws/$LSPHP/lib/php" | grep 'ioncube') ]] && echo "ioncube" >>/tmp/php_extension.txt
else
  [[ -d "/usr/local/lsws/$LSPHP/lib64/php/modules" && -z $(ls "/usr/local/lsws/$LSPHP/lib64/php/modules" | grep 'ioncube') ]] && echo "ioncube" >>/tmp/php_extension.txt
fi

_rundone "Đã quét xong danh sách Extensions"

# ==============================================================================
# BƯỚC 3: GIAO DIỆN CHỌN EXTENSION (LAYOUT 2 CỘT TỐI ƯU UX)
# ==============================================================================
mapfile -t selects < <(sort -u /tmp/php_extension.txt | sed '/^$/d')

if [[ ${#selects[@]} -eq 0 ]]; then
  echo -e "\n${C_GREEN}Phiên bản $php_ver_hien_thi của bạn đã được cài ĐẦY ĐỦ tất cả các Extensions!${C_RESET}"
  sleep 3
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-php-ini-main 1
  exit 0
fi

echo -e "\n${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_BOLD_WHITE}DANH SÁCH EXTENSIONS CHƯA CÀI CHO: ${C_YELLOW}$php_ver_hien_thi${C_RESET}"
echo -e "${C_CYAN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"

# HỆ THỐNG IN DANH SÁCH 2 CỘT CỰC ĐẸP
total=${#selects[@]}
for ((i = 0; i < total; i += 2)); do
  idx1=$((i + 1))
  val1="${selects[$i]}"
  # Cố định độ rộng cột 1 là 28 khoảng trắng để đẩy cột 2 sang ngang bằng nhau
  pad_val1=$(printf "%-28s" "$val1")
  str_col1="  ${C_CYAN}$(printf "%2d" $idx1))${C_RESET} ${C_BOLD_WHITE}${pad_val1}${C_RESET}"

  idx2=$((i + 2))
  if [ $idx2 -le $total ]; then
    val2="${selects[$((i + 1))]}"
    str_col2="${C_CYAN}$(printf "%2d" $idx2))${C_RESET} ${C_BOLD_WHITE}${val2}${C_RESET}"
    left_text "${str_col1}${str_col2}" 0
  else
    left_text "${str_col1}" 0
  fi
done
echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯${C_RESET}"

php_extension_chon=""

while true; do
  if command -v fzf &>/dev/null; then
    echo -en "${C_CYAN}Nhập số thứ tự (1-${#selects[@]}) hoặc gõ [00=Tìm nhanh, 0=Thoát]: ${C_RESET}"
  else
    echo -en "${C_CYAN}Nhập số thứ tự (1-${#selects[@]}) [0=Thoát]: ${C_RESET}"
  fi

  read -r REPLY

  if [[ "$REPLY" == "0" ]]; then
    exit 0
  elif [[ "$REPLY" == "00" && -x $(command -v fzf) ]]; then
    fzf_result=$(printf "%s\n" "${selects[@]}" | fzf \
      --prompt="Nhập extension cần tìm > " \
      --height='~60%' \
      --border=rounded \
      --color=border:green \
      --layout=reverse \
      --header="Tìm thấy ${#selects[@]} extension chưa cài. [↑/↓] Di chuyển, [ESC] Hủy, [Enter] Chọn." \
      --preview='echo -e "Bạn đang chuẩn bị cài đặt: \033[1;32m{}\033[0m"')
    if [[ -n "$fzf_result" ]]; then
      php_extension_chon="$fzf_result"
      break
    else
      echo -e "${C_YELLOW}Đã hủy tìm kiếm FZF. Vui lòng chọn lại.${C_RESET}"
    fi
  elif [[ "$REPLY" =~ ^[0-9]+$ ]] && [ "$REPLY" -ge 1 ] && [ "$REPLY" -le "${#selects[@]}" ]; then
    php_extension_chon="${selects[$((REPLY - 1))]}"
    break
  else
    echo -e "${C_RED}Lựa chọn không hợp lệ!${C_RESET}"
  fi
done

# ==============================================================================
# BƯỚC 4: THỰC THI CÀI ĐẶT
# ==============================================================================
echo ""
_runing "Đang tải và cài đặt Extension: $LSPHP-$php_extension_chon..."

phien_ban_php_co_cham=$(echo "$LSPHP" | grep -Eo '[0-9]{1,2}' | head -1 | perl -pe 's/(\d{1})(?=(?:\d{1}){1,5}\b)/\1./g')
duong_dan_php_ini="/usr/local/lsws/$LSPHP/etc/php.ini"
grep -qi "Ubuntu" /etc/*release && duong_dan_php_ini="/usr/local/lsws/$LSPHP/etc/php/$phien_ban_php_co_cham/litespeed/php.ini"

# Xử lý IONCUBE thủ công
if [[ "$php_extension_chon" == 'ioncube' ]]; then
  if [[ "$LSPHP" =~ ^(lsphp74|lsphp81|lsphp82|lsphp83|lsphp84)$ ]]; then
    duong_dan_luu_tru_extension_so="/usr/local/lsws/$LSPHP/lib64/php/modules"
    grep -qi "Ubuntu" /etc/*release && duong_dan_luu_tru_extension_so="/usr/local/lsws/$LSPHP/lib/php"

    wget -q -N https://downloads.ioncube.com/loader_downloads/ioncube_loaders_lin_x86-64.zip
    unzip -oq ioncube_loaders_lin_x86-64.zip
    cp "ioncube/ioncube_loader_lin_${phien_ban_php_co_cham}.so" "$duong_dan_luu_tru_extension_so"
    rm -rf ioncube ioncube_loaders_lin_x86-64.zip

    echo "zend_extension = \"${duong_dan_luu_tru_extension_so}/ioncube_loader_lin_${phien_ban_php_co_cham}.so\"" >>"$duong_dan_php_ini"
  else
    _runloi "Ioncube không hỗ trợ phiên bản $LSPHP"
    exit 1
  fi

# Xử lý CÀI ĐẶT THƯỜNG
elif [[ $(dnf list available 2>/dev/null | grep "$LSPHP-$php_extension_chon") || $(apt list 2>/dev/null | grep "$LSPHP-$php_extension_chon") ]]; then
  if grep -qi "Ubuntu" /etc/*release 2>/dev/null; then
    apt-get install "$LSPHP-$php_extension_chon" -y >/dev/null 2>&1
  else
    if grep -qE "release 8" /etc/redhat-release 2>/dev/null; then
      yum install "$LSPHP-$php_extension_chon" -y --disablerepo="*" --enablerepo="litespeed,litespeed-edge,litespeed-edge-update,litespeed-update" >/dev/null 2>&1
    else #rehat 9 và 10 support
      yum install "$LSPHP-$php_extension_chon" -y --disablerepo="*" --enablerepo="litespeed,litespeed-update" >/dev/null 2>&1
    fi
  fi
else
  # Cài qua EOL
  url_repo_litespeed=$(
    awk -v pkg="$LSPHP-$php_extension_chon" 'BEGIN { FS = "/" } {
      filename = $NF; split(filename, parts, "-")
      pkg_name = ""; version = ""
      if (parts[2] == "pecl") { pkg_name = parts[1] "-" parts[2] "-" parts[3]; version = parts[4] }
      else if (parts[2] ~ /^[0-9]+\.[0-9]+/) { pkg_name = parts[1]; version = parts[2] }
      else { pkg_name = parts[1] "-" parts[2]; version = parts[3] }
      if (version > versions[pkg_name]) { versions[pkg_name] = version; latest_lines[pkg_name] = $0 }
    } END { PROCINFO["sorted_in"] = "@ind_str_asc"; for (p in latest_lines) if (p == pkg) print latest_lines[p] }' /tmp/php_extension_call_eol | tail -n1
  )
  if [[ -n "$url_repo_litespeed" ]]; then
    dnf install "https://rpms.litespeedtech.com${url_repo_litespeed}" -y >/dev/null 2>&1
  fi
fi

# ==============================================================================
# KIỂM TRA LẠI VÀ BÁO CÁO
# =============================================================================
if grep -qi "Ubuntu" /etc/*release 2>/dev/null; then
  check_lai=$(apt list --installed 2>/dev/null | grep "$LSPHP" | grep -w "$php_extension_chon")
else
  check_lai=$(yum list installed 2>/dev/null | grep "$LSPHP" | grep -w "$php_extension_chon")
fi

[[ "$php_extension_chon" == "ioncube" ]] && check_lai="OK"

if [[ -n "$check_lai" ]]; then
  /usr/local/lsws/bin/lswsctrl restart >/dev/null 2>&1
  _rundone "Cài đặt thành công!"

  echo -e "\n${C_GREEN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_BOLD_WHITE}HOÀN TẤT CÀI ĐẶT EXTENSION${C_RESET}"
  echo -e "${C_GREEN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
  left_text "Phiên bản PHP   : ${C_YELLOW}$php_ver_hien_thi ($LSPHP)${C_RESET}" 2
  left_text "Extension đã cài: ${C_BOLD_WHITE}$php_extension_chon${C_RESET}" 2
  echo -e "${C_GREEN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"
else
  _runloi "Cài đặt thất bại! Hãy thử lại sau."
fi

[[ "$repo_du_phong" == '1' ]] && sed -i '/rpms.litespeedtech.com/d' /etc/hosts

[[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-php-ini-main 1
