#!/bin/bash
# @author: Gia Tuấn
# @website: https://wptangtoc.com
# @since: 2026
# kiểm tra các phiên bản PHP của các domain, được print gọi thư viện chéo một số tính năng PHP
function huong_dan() {
  Tính năng Kiểm tra phiên bản PHP của từng website là khả năng xác định xem một website cụ thể [tên miền hoặc tên miền phụ] trên máy chủ đang thực sự chạy bằng phiên bản PHP nào. Điều này đặc biệt hữu ích trong các môi trường như WPTangToc OLS cho phép mỗi website sử dụng một phiên bản PHP riêng biệt.

  Nói một cách đơn giản, đây là cách để bạn biết website A đang dùng PHP phiên bản X, trong khi website B đang dùng PHP phiên bản Y.

  Mục Đích Chính
  * Gỡ lỗi tương thích: Khi website, theme, hoặc plugin gặp lỗi, việc biết phiên bản PHP đang chạy là một trong những bước chẩn đoán đầu tiên, vì vấn đề không tương thích phiên bản rất phổ biến.
  * Xác nhận cấu hình: Đảm bảo website đang sử dụng đúng phiên bản PHP đã được cài đặt.
  * Kiểm tra bảo mật: Đảm bảo website đang chạy trên các phiên bản PHP còn được hỗ trợ và cập nhật bảo mật.
  * Lên kế hoạch nâng cấp: Biết phiên bản hiện tại giúp bạn lập kế hoạch nâng cấp website lên phiên bản PHP mới hơn một cách phù hợp.
  * Đáp ứng yêu cầu ứng dụng: Kiểm tra xem website có đáp ứng yêu cầu về phiên bản PHP của các phần mềm [CMS, framework] mà nó đang sử dụng hay không.

  Việc biết được phiên bản PHP của từng website giúp bạn quản lý, bảo trì và phát triển các dự án web của mình một cách hiệu quả và an toàn hơn.
}

clear
. /etc/wptt/.wptt.conf
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh
. /etc/wptt/echo-color
. /etc/wptt/core-functions

echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_BOLD_WHITE}$quan_ly_php ➜ $kiem_tra_phien_ban_php${C_RESET}"
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯${C_RESET}\n"

# ==============================================================================
# LẤY THÔNG TIN HỆ THỐNG SIÊU TỐC
# ==============================================================================

# Lấy PHP mặc định CLI
phpcheck=$(php -r 'echo PHP_MAJOR_VERSION.".".PHP_MINOR_VERSION;' 2>/dev/null)
[[ -z "$phpcheck" ]] && phpcheck=$(php -v 2>/dev/null | grep cli | grep -oP 'PHP \K[0-9]+\.[0-9]+' | head -n 1)

# Lấy danh sách vhost hợp lệ (Bằng Globbing siêu tốc)
valid_domains=()
for filepath in /etc/wptt/vhost/.*.conf; do
  [[ ! -f "$filepath" || "$filepath" == *"/..conf" || "$filepath" == *"*"* ]] && continue

  domain="${filepath##*/}"
  domain="${domain%.conf}"
  domain="${domain#.}"

  # Chỉ đếm nếu có thư mục source
  if [[ -d "/usr/local/lsws/$domain/html" ]]; then
    valid_domains+=("$domain")
  fi
done

so_luong_website=${#valid_domains[@]}

# Hiển thị Tổng quan
echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
left_text "$tren_he_thong: $so_luong_website website"
echo -e "${C_CYAN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
left_text "Webserver CLI mặc định đang sử dụng PHP $phpcheck"
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯${C_RESET}\n"

# ==============================================================================
# HIỂN THỊ DANH SÁCH DƯỚI DẠNG BẢNG (TABLE UX)
# ==============================================================================

if [[ $so_luong_website -gt 0 ]]; then
  echo -e "\n\033[1;36m$danh_sach_domain đang sử dụng $phien_ban PHP trên hệ thống:\033[0m\n"

  # Vẽ Tiêu đề bảng
  printf "\033[1;33m%-5s | %-40s | %-15s\033[0m\n" "STT" "Tên Miền (Domain)" "Phiên Bản PHP"
  printf "%.0s-" {1..66}
  echo ""

  # Sắp xếp mảng chuẩn Version
  mapfile -t valid_domains < <(printf "%s\n" "${valid_domains[@]}" | sort -uV)

  a=1
  for domain in "${valid_domains[@]}"; do
    unset phien_ban_php_domain

    # Kéo file cấu hình của riêng domain đó
    [[ -f "/etc/wptt/vhost/.$domain.conf" ]] && . "/etc/wptt/vhost/.$domain.conf"

    # Nếu trong Vhost rỗng, chứng tỏ nó đang dùng bản PHP System mặc định
    if [[ -z "$phien_ban_php_domain" ]]; then
      phien_ban_php_domain="$phpcheck"
    fi

    # In ra từng dòng của bảng
    printf "%-5s | %-40s | \033[1;32m%-15s\033[0m\n" "$a" "$domain" "PHP $phien_ban_php_domain"
    ((a++))
  done
  echo ""
fi

#quay về menu nếu dùng từ menu gọi sang
[[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-php-ini-main 1
