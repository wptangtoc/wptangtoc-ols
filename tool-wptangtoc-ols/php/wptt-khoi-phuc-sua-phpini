#!/bin/bash
# @author: Gia Tuấn
# @website: https://wptangtoc.com
# @since: 2026

function huong_dan() {
  Tính năng khôi phục php.ini về trạng thái tối ưu mặc định của WPTangToc OLS.
  Trong quá trình vận hành, có thể bạn đã tùy biến file php.ini và vô tình gây ra lỗi [như trắng trang, lỗi 500, quá tải RAM].
  Bạn có thể sử dụng tính năng này để reset lại cấu hình, đồng thời hệ thống sẽ tự động Auto-Tune lại OPcache và JIT theo đúng phần cứng hiện tại của VPS.
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null # Nạp thư viện UI Xác nhận

clear
echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}${quan_ly_php} ➜ ${khoi_phuc_php_cau_hinh}${C_RESET}"
echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

# Hiển thị bảng danh sách các phiên bản PHP đang dùng trên các Domain
. /etc/wptt/php/wptt-php-version-domain 1
echo ""

# Gọi Menu chọn PHP (Đã tích hợp fzf siêu tốc)
. /etc/wptt/php/tenmien-php

# Chốt chặn thoát
if [[ -z "$LSPHP" || "$LSPHP" == "0" ]]; then
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-php-ini-main 1
  return 2>/dev/null || exit 0
fi

# ==============================================================================
# XỬ LÝ CHUỖI VÀ ĐƯỜNG DẪN
# ==============================================================================
num_ver=${LSPHP#lsphp}
ver_len=${#num_ver}
phien_ban_php_co_cham="${num_ver:0:$ver_len-1}.${num_ver: -1}"

if cat /etc/*release 2>/dev/null | grep -qi "ubuntu"; then
  duong_dan_php_ini="/usr/local/lsws/$LSPHP/etc/php/$phien_ban_php_co_cham/litespeed/php.ini"
else
  duong_dan_php_ini="/usr/local/lsws/$LSPHP/etc/php.ini"
fi

if [[ ! -f "$duong_dan_php_ini" ]]; then
  echo -e "\n${C_RED}❌ Lỗi: Không xác định được file php.ini cho phiên bản $LSPHP!${C_RESET}"
  sleep 3
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-php-ini-main 1
  exit 1
fi

# ==============================================================================
# HIỂN THỊ BẢNG TRẠNG THÁI (UX BO CONG)
# ==============================================================================
echo -e "\n${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
left_text "Phiên bản PHP : ${C_GREEN}PHP $phien_ban_php_co_cham ($LSPHP)${C_RESET}" 2
left_text "File thao tác : ${C_YELLOW}$duong_dan_php_ini${C_RESET}" 2
echo -e "${C_CYAN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
left_text "Hệ thống sẽ ghi đè file hiện tại bằng bản Backup gốc, đồng thời" 2
left_text "chạy trình Auto-Tune để tối ưu hóa Opcache và JIT cho VPS." 2
echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

# ==============================================================================
# XÁC NHẬN VÀ THỰC THI KHÔI PHỤC
# ==============================================================================
if wptt_xac_nhan "Bạn có CHẮC CHẮN muốn khôi phục lại file PHP.INI không?" "Mọi thông số tùy chỉnh hiện tại của bạn sẽ bị xóa bỏ!" "" "Đồng ý Khôi phục" "Hủy thao tác"; then
  echo ""

  _runing "Đang ghi đè file php.ini từ bản sao lưu hệ thống..."

  # 1. Khôi phục từ file Backup gốc
  \cp -f /etc/wptt/php/php.ini.bk "$duong_dan_php_ini"

  # 2. Cấu hình các thông số bảo mật và Limit cơ bản
  sed -i -E "s/^[[:space:]]*expose_php[[:space:]]*=.*/expose_php = Off/i" "$duong_dan_php_ini"
  sed -i -E "s/^[[:space:]]*upload_max_filesize[[:space:]]*=.*/upload_max_filesize = 8M/i" "$duong_dan_php_ini"
  sed -i -E "s/^[[:space:]]*max_execution_time[[:space:]]*=.*/max_execution_time = 120/i" "$duong_dan_php_ini"

  # 3. Cấu hình OPcache nâng cao dành riêng cho chế độ WPTangToc_GiaTuan
  if [[ "$wptangtoc_ols_giatuan" == "1" ]]; then
    sed -i -E '/^(opcache\.validate_timestamps|opcache\.file_update_protection)=/d' "$duong_dan_php_ini"
    printf "opcache.validate_timestamps=0\nopcache.file_update_protection=0\n" >>"$duong_dan_php_ini"
  fi
  _rundone "Khôi phục dữ liệu gốc hoàn tất"

  _runing "Đang tự động đo lường RAM và Auto-Tune lại Opcache/JIT..."
  # 4. GỌI SCRIPT AUTO-TUNE (Tính năng "Tune vào luôn")
  if [[ -x "/etc/wptt/cache/opcache-optimize-tune" ]]; then
    /etc/wptt/cache/opcache-optimize-tune >/dev/null 2>&1
  fi
  _rundone "Cấu hình Opcache/JIT đã được tối ưu hóa"

  _runing "Đang nạp lại tiến trình LS-PHP (Zero-Downtime)..."
  # 5. Khởi động lại lsphp (Reload OLS không gây gián đoạn)
  /usr/local/lsws/bin/lswsctrl reload >/dev/null 2>&1
  echo "Khôi phục lại PHP phiên bản $LSPHP : $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log
  _rundone "Cập nhật tiến trình hoàn tất"

  # ==============================================================================
  # BẢNG BÁO CÁO THÀNH CÔNG
  # ==============================================================================
  echo -e "\n${C_GREEN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_BOLD_WHITE}HOÀN TẤT KHÔI PHỤC VÀ TỐI ƯU HÓA${C_RESET}"
  echo -e "${C_GREEN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
  left_text "Phiên bản      : ${C_YELLOW}PHP $phien_ban_php_co_cham${C_RESET}" 2
  left_text "Bảo mật        : expose_php (Off)" 2
  left_text "Giới hạn cơ bản: Upload (8MB), Max Execution Time (120s)" 2
  echo -e "${C_GREEN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
  left_text "Trạng thái     : File đã được đưa về chuẩn an toàn nhất và" 2
  left_text "                 hiệu năng đã được Auto-Tune thành công!" 2
  echo -e "${C_GREEN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

else
  echo -e "${C_YELLOW}Đã hủy thao tác khôi phục.${C_RESET}\n"
fi

[[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-php-ini-main 1
