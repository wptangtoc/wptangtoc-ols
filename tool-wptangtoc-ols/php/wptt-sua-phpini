#!/bin/bash

function huong_dan() {
  Tính năng Sửa cấu hình php.ini là khả năng thay đổi các thiết lập hoạt động cốt lõi của PHP bằng cách chỉnh sửa trực tiếp tệp tin cấu hình chính của nó, có tên là php.ini. Tệp này chứa hàng loạt các chỉ thị [directives] điều khiển mọi khía cạnh của PHP, từ giới hạn tài nguyên, cách báo lỗi, đến việc kích hoạt các module mở rộng.

  Nói một cách đơn giản, php.ini giống như bảng điều khiển trung tâm của PHP. Việc sửa nó cho phép bạn tùy chỉnh sâu cách PHP vận hành trên máy chủ của mình.

  Mục Đích Chính
  * Tùy chỉnh hành vi PHP: Điều chỉnh PHP để phù hợp với yêu cầu cụ thể của ứng dụng web hoặc môi trường máy chủ.
  * Quản lý tài nguyên: Thiết lập các giới hạn như memory_limit [bộ nhớ tối đa], max_execution_time [thời gian thực thi tối đa], upload_max_filesize [kích thước tệp tải lên tối đa].
  * Kích hoạt/Vô hiệu hóa Extensions: Quyết định những module mở rộng nào của PHP [ví dụ: mysqli, gd, curl] sẽ được tải và sử dụng.
  * Cấu hình báo lỗi: Kiểm soát cách PHP báo cáo và hiển thị lỗi [ví dụ: error_reporting, display_errors].
  * Tăng cường bảo mật: Một số cài đặt trong php.ini có thể giúp cải thiện tính bảo mật cho ứng dụng PHP.
  * Tối ưu hiệu suất: Một vài chỉ thị có thể ảnh hưởng đến hiệu năng của PHP.

  Việc sửa đổi php.ini đòi hỏi sự cẩn trọng, vì cấu hình sai có thể khiến PHP hoặc website của bạn ngừng hoạt động.
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null # Nạp thư viện UI Xác nhận

clear
echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}${quan_ly_php} ➜ ${cau_hinh_php_ini:-Chỉnh sửa file php.ini}${C_RESET}"
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

. /etc/wptt/php/wptt-php-version-domain 1
. /etc/wptt/php/tenmien-php

# Chốt chặn thoát
if [[ "$LSPHP" == '0' || -z "$LSPHP" ]]; then
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-php-ini-main 1
  [[ "${1:-}" == "99" ]] && exec /etc/wptt/wptt-cau-hinh-websever-main 1
  return 2>/dev/null || exit 0
fi

# ==============================================================================
# TÍNH TOÁN ĐƯỜNG DẪN CONFIG THEO OS
# ==============================================================================
phien_ban_php_co_cham=$(echo "$LSPHP" | grep -Eo '[0-9]{1,2}' | head -1 | perl -pe 's/(\d{1})(?=(?:\d{1}){1,5}\b)/\1./g')

if cat /etc/*release 2>/dev/null | grep -qi "ubuntu"; then
  duong_dan_php_ini="/usr/local/lsws/$LSPHP/etc/php/$phien_ban_php_co_cham/litespeed/php.ini"
else
  duong_dan_php_ini="/usr/local/lsws/$LSPHP/etc/php.ini"
fi

if [[ ! -f "$duong_dan_php_ini" ]]; then
  echo -e "\n${C_RED}❌ Lỗi: Không xác định được file php.ini cho phiên bản $LSPHP!${C_RESET}"
  sleep 3
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-php-ini-main 1
  [[ "${1:-}" == "99" ]] && exec /etc/wptt/wptt-cau-hinh-websever-main 1
  exit 1
fi

# ==============================================================================
# HIỂN THỊ BẢNG TRẠNG THÁI (UX BO CONG)
# ==============================================================================
echo -e "\n${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
left_text "Phiên bản PHP : ${C_GREEN}PHP $phien_ban_php_co_cham ($LSPHP)${C_RESET}" 2
left_text "Đường dẫn file: ${C_YELLOW}$duong_dan_php_ini${C_RESET}" 2
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

# ==============================================================================
# XÁC NHẬN BẢO MẬT & HƯỚNG DẪN TRÌNH SOẠN THẢO
# ==============================================================================
if wptt_xac_nhan "Bạn có CHẮC CHẮN muốn mở và chỉnh sửa cấu hình php.ini không?" "CẢNH BÁO: Chỉnh sửa sai cú pháp có thể khiến toàn bộ website chạy" "trên phiên bản PHP này bị sập (Lỗi 500/503)." "Đồng ý Chỉnh sửa" "Hủy thao tác"; then
  echo ""

  [[ -z "$editor_cau_hinh" ]] && editor_cau_hinh="nano"

  # Khung hướng dẫn phím tắt Nano
  if [[ "$editor_cau_hinh" == "nano" ]]; then
    echo -e "${C_GREEN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
    center_text "${C_BOLD_WHITE}HƯỚNG DẪN LƯU FILE BẰNG NANO${C_RESET}"
    echo -e "${C_GREEN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
    left_text "1. Chỉnh sửa xong, ấn tổ hợp phím  : ${C_YELLOW}Ctrl + O${C_RESET}" 4
    left_text "2. Hệ thống hỏi tên file, ấn phím  : ${C_YELLOW}Enter${C_RESET}" 4
    left_text "3. Thoát ra ngoài Menu, ấn tổ hợp  : ${C_YELLOW}Ctrl + X${C_RESET}" 4
    echo -e "${C_GREEN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"
  else
    echo -e "${C_YELLOW}Đang mở trình soạn thảo: $editor_cau_hinh${C_RESET}\n"
  fi

  echo -e "${C_CYAN}Đang chuẩn bị dữ liệu và mở file cấu hình...${C_RESET}"
  sleep 3

  # Lấy MD5 trước khi sửa (Lưu trên RAM)
  old_md5=$(md5sum "$duong_dan_php_ini" | awk '{print $1}')

  # ==============================================================================
  # MỞ TRÌNH SOẠN THẢO
  # ==============================================================================
  $editor_cau_hinh "$duong_dan_php_ini"
  clear # Xóa màn hình sau khi Nano thoát ra

  # ==============================================================================
  # KIỂM TRA SỰ THAY ĐỔI VÀ CHECK LỖI CÚ PHÁP
  # ==============================================================================
  echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_YELLOW}ĐANG KIỂM TRA SỰ THAY ĐỔI VÀ CÚ PHÁP PHP.INI${C_RESET}"
  echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

  new_md5=$(md5sum "$duong_dan_php_ini" | awk '{print $1}')

  if [[ "$old_md5" != "$new_md5" ]]; then
    UI_STRING="Đang phân tích cú pháp PHP.ini (Syntax Check)..."
    _runing "$UI_STRING"

    # KẾT HỢP KIỂM TRA LỖI PHP.INI TRƯỚC KHI RESTART
    # Gọi nháp tiến trình PHP với file php.ini vừa sửa để xem có văng lỗi Parse/Fatal không
    kiem_tra_php=$(/usr/local/lsws/$LSPHP/bin/php -c "$duong_dan_php_ini" -v 2>&1 | grep -iE "warning|error|exception|fatal")

    _rundone "$UI_STRING"
    if [[ -n "$kiem_tra_php" ]]; then
      echo "Cấu hình lại PHP gây ra lỗi : $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log

      echo -e "\n${C_RED}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
      center_text "${C_BOLD_WHITE}LỖI CÚ PHÁP ĐÃ XẢY RA TRONG PHP.INI${C_RESET}"
      echo -e "${C_RED}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
      left_text "${C_YELLOW}Hệ thống đã HỦY LỆNH RELOAD để tránh sập các Website đang chạy!${C_RESET}" 2
      left_text "Chi tiết cảnh báo/lỗi từ trình biên dịch PHP:" 2
      echo -e "${C_RED}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"

      # In chi tiết lỗi ra màn hình cho người dùng đọc
      while IFS= read -r line; do
        if [[ -n "$line" ]]; then
          printf "${C_RED}│${C_RESET}  %-69s${C_RED}│${C_RESET}\n" "${line:0:69}"
        fi
      done <<<"$kiem_tra_php"

      left_text "${C_YELLOW}Hãy vào cấu hình PHP.ini ${C_GREEN}PHP $phien_ban_php_co_cham ($LSPHP)${C_RESET} và sửa lại cho đúng nhé!${C_RESET}" 2
      echo -e "${C_RED}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

      [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-php-ini-main 1
      [[ "${1:-}" == "99" ]] && exec /etc/wptt/wptt-cau-hinh-websever-main 1
      exit 1
    else
      _runing "Nạp lại tiến trình LS-PHP (Zero-Downtime)..."
      /usr/local/lsws/bin/lswsctrl reload >/dev/null 2>&1
      echo "Cấu hình lại PHP phiên bản $phien_ban_php_co_cham: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log
      _rundone "Nạp lại tiến trình LS-PHP (Zero-Downtime)..."

      # BẢNG BÁO CÁO THÀNH CÔNG
      echo -e "\n${C_GREEN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
      center_text "${C_BOLD_WHITE}CẬP NHẬT CẤU HÌNH PHP THÀNH CÔNG${C_RESET}"
      echo -e "${C_GREEN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
      left_text "Trạng thái : Cấu hình mới đã được áp dụng an toàn. Website" 2
      left_text "             của bạn không bị gián đoạn (Zero-Downtime)." 2
      echo -e "${C_GREEN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"
    fi
  else
    echo -e "${C_YELLOW}Không có sự thay đổi nào được phát hiện trong file. Bỏ qua bước nạp lại.${C_RESET}\n"
  fi

else
  echo -e "${C_YELLOW}Đã hủy thao tác chỉnh sửa cấu hình php.ini.${C_RESET}\n"
fi

[[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-php-ini-main 1
[[ "${1:-}" == "99" ]] && exec /etc/wptt/wptt-cau-hinh-websever-main 1
