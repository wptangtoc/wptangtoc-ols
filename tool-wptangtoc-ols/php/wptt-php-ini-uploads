#!/bin/bash

function huong_dan() {
  Tính năng Cấu hình upload_max_filesize PHP là việc điều chỉnh các cài đặt trong PHP để kiểm soát dung lượng tối đa của một tệp tin mà người dùng có thể tải lên máy chủ thông qua các ứng dụng web viết bằng PHP.

  Nói một cách đơn giản, đây là cách bạn quy định một file tải lên website không được nặng quá X Megabytes.

  Mục đích chính:

  * Cho phép tải lên tệp lớn hơn: Mặc định, PHP wptangtoc ols thường giới hạn dung lượng file tải lên ở mức khá nhỏ [là 8MB]. Cấu hình này cho phép bạn tăng giới hạn đó để người dùng có thể tải lên video, hình ảnh chất lượng cao, tài liệu lớn, v.v.
  * Ngăn chặn lạm dụng tài nguyên: Giúp bảo vệ máy chủ khỏi việc bị quá tải hoặc hết dung lượng đĩa do người dùng tải lên các tệp quá lớn.
  * Đáp ứng yêu cầu ứng dụng: Các ứng dụng web khác nhau có nhu cầu khác nhau về kích thước tệp tải lên.

}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null # Nạp thư viện UX Bo Cong

clear
echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}QUẢN LÝ PHP ➜ Cấu Hình Giới Hạn Tải Lên (Upload Max Filesize)${C_RESET}"
echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

if [[ "${1:-}" == '98' ]]; then
  WPTT_IN_MENU="yes"
  WPTT_MENU_BACK="/etc/wptt/wptt-php-ini-main 1"
fi

# ==============================================================================
# CHỌN PHIÊN BẢN PHP
# ==============================================================================
# Gọi list danh sách PHP đang cài
. /etc/wptt/php/wptt-php-version-domain 1 >/dev/null 2>&1

. /etc/wptt/php/tenmien-php 2>/dev/null

if [[ -z "$LSPHP" || "$LSPHP" == "0" ]]; then
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-php-ini-main 1
  exit 0
fi

# ==============================================================================
# LẤY THÔNG TIN CẤU HÌNH HIỆN TẠI
# ==============================================================================
phien_ban_php_co_cham=$(echo "$LSPHP" | grep -Eo '[0-9]{1,2}' | head -1 | perl -pe 's/(\d{1})(?=(?:\d{1}){1,5}\b)/\1./g')

if grep -qi "Ubuntu" /etc/*release 2>/dev/null; then
  duong_dan_php_ini="/usr/local/lsws/$LSPHP/etc/php/$phien_ban_php_co_cham/litespeed/php.ini"
else
  duong_dan_php_ini="/usr/local/lsws/$LSPHP/etc/php.ini"
fi

if [[ ! -f "$duong_dan_php_ini" ]]; then
  echo -e "\n${C_RED}Lỗi: Không tìm thấy file php.ini tại đường dẫn: $duong_dan_php_ini${C_RESET}"
  sleep 3
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-php-ini-main 1
  exit 1
fi

hien_tai=$(grep -E '^upload_max_filesize' "$duong_dan_php_ini" | awk '{print $3}')
hien_tai=${hien_tai:-"Chưa xác định"}

echo -e "\n${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
left_text "  Đang cấu hình        : ${C_BOLD_WHITE}$LSPHP (PHP $phien_ban_php_co_cham)${C_RESET}" 2
left_text "  Giới hạn hiện tại    : ${C_YELLOW}${hien_tai}B${C_RESET}" 2
echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

# ==============================================================================
# NHẬP GIÁ TRỊ MỚI VÀ XỬ LÝ (VALIDATION)
# ==============================================================================
while true; do
  echo -e "Ví dụ: Nhập ${C_YELLOW}500${C_RESET} hệ thống sẽ tự hiểu là 500 Megabytes."
  echo -en "${C_CYAN}Nhập dung lượng Upload Max mới [0=Thoát]: ${C_RESET}"
  read -r port

  [[ "$port" == "0" || -z "$port" ]] && {
    echo -e "\n${C_YELLOW}Đã thoát.${C_RESET}"
    [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-php-ini-main 1
    exit 0
  }

  # Loại bỏ khoảng trắng và các ký tự M, m, MB, mb
  port=$(echo "$port" | sed -E 's/[mM][bB]?|[[:space:]]//g')

  if [[ "$port" =~ ^[0-9]+$ ]] && [ "$port" -gt 0 ]; then
    break
  else
    echo -e "${C_RED}❌ Lỗi: Giá trị không hợp lệ! Vui lòng chỉ nhập số nguyên dương (VD: 500).${C_RESET}\n"
  fi
done

if ! wptt_xac_nhan "Bạn có chắc chắn muốn thay đổi giới hạn Upload không?" \
  "Dung lượng sẽ được chuyển từ: [ ${hien_tai}B ] ➜ sang [ ${port}MB ]" \
  "Hệ thống sẽ đồng thời tăng cả post_max_size lên ${port}M để đồng bộ." \
  "Đồng ý Lưu" "Hủy thao tác"; then
  echo -e "${C_YELLOW}Đã hủy thao tác.${C_RESET}\n"
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-php-ini-main 1
  exit 0
fi

_runing "ghi cấu hình mới vào file php.ini..."
sed -i -E "s/^upload_max_filesize[[:space:]]*=.*/upload_max_filesize = ${port}M/" "$duong_dan_php_ini"
sed -i -E "s/^post_max_size[[:space:]]*=.*/post_max_size = ${port}M/" "$duong_dan_php_ini"
/usr/local/lsws/bin/lswsctrl restart >/dev/null 2>&1
_rundone "ghi cấu hình mới vào file php.ini..."

echo -e "\n${C_GREEN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_BOLD_WHITE}HOÀN TẤT THIẾT LẬP UPLOAD MAX${C_RESET}"
echo -e "${C_GREEN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
left_text "Phiên bản PHP      : ${C_YELLOW}$LSPHP (PHP $phien_ban_php_co_cham)${C_RESET}" 2
left_text "Giới hạn tải lên   : ${C_BOLD_WHITE}${port}MB${C_RESET} (upload_max_filesize)" 2
left_text "Dung lượng POST    : ${C_BOLD_WHITE}${port}MB${C_RESET} (post_max_size)" 2
echo -e "${C_GREEN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

[[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-php-ini-main 1
