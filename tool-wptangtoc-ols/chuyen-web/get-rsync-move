#!/bin/bash
function huong_dan() {
  Tính năng này là Trái tim của quá trình Chuyển nhà [Migration]. Nó chịu trách nhiệm giải nén và lắp ráp tự động các website vừa được Rsync đưa về máy chủ.

  Hệ thống sẽ tự động thực hiện:
  1. Nhận diện danh sách tên miền mới được chuyển về.
  2. Khởi tạo không gian Web [Vhost] trên LiteSpeed.
  3. Tự động tạo Database mới, User mới và bung [Import] file SQL siêu tốc.
  4. Tự động kết nối lại file wp-config.php [WordPress] và phân quyền bảo mật.

  LƯU Ý QUAN TRỌNG:
  - Đảm bảo tiến trình Rsync dữ liệu từ máy chủ cũ đã chạy XONG HOÀN TOÀN trước khi kích hoạt lệnh này.
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null

clear
print_border_top
center_text "${C_YELLOW}Chuyển Website ➜ Khởi tạo Website sau di cư (Get Rsync)${C_RESET}"
print_border_bot

list_file=$(find /usr/local/lsws/*/html/danh-sach-website-wptangtoc-ols.txt 2>/dev/null | head -n 1)
domain_them=$(cat "$list_file" 2>/dev/null)

if [[ -z "$domain_them" ]]; then
  echo -e "${C_RED}❌ Lỗi: Không tìm thấy danh sách website nào vừa được di cư về!${C_RESET}"
  echo -e "Hãy đảm bảo quá trình Rsync dữ liệu đã hoàn tất thành công.\n"
  sleep 3
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-chuyen-web-main 1
  exit 1
fi

# Dọn dẹp danh sách tạm
find /usr/local/lsws/*/html/ -name "danh-sach-website-wptangtoc-ols.txt" -delete

# Lấy danh sách domain đã có trên máy chủ
domain_da_co=($(ls -A /etc/wptt/vhost 2>/dev/null | sed 's/^.//' | sed 's/.conf//'))

# ==============================================================================
# BƯỚC 1: KHỞI TẠO VHOST & SUBFOLDER
# ==============================================================================
for NAME in $domain_them; do
  if [[ ! " ${domain_da_co[@]} " =~ " ${NAME} " ]]; then
    _runing "Khởi tạo website: $NAME"
    . /etc/wptt/domain/wptt-themwebsite "$NAME" >/dev/null 2>&1
    rm -f "/usr/local/lsws/$NAME/html/index.html"

    # Xử lý Subfolder (Nếu có)
    sub_file="/usr/local/lsws/$NAME/html/subfolder-wptt.txt"
    if [[ -f "$sub_file" ]]; then
      for thumuc in $(cat "$sub_file"); do
        . /etc/wptt/domain/wptt-subfolder-website "$NAME" "$thumuc" >/dev/null 2>&1
      done
    fi
    _rundone "Khởi tạo website: $NAME"
  fi
done

# ==============================================================================
# BƯỚC 2: XỬ LÝ DATABASE & IMPORT SQL (UX PV TÀNG HÌNH)
# ==============================================================================
INIT_SQL="SET FOREIGN_KEY_CHECKS=0; SET UNIQUE_CHECKS=0; SET AUTOCOMMIT=0;"
END_SQL="COMMIT; SET FOREIGN_KEY_CHECKS=1; SET UNIQUE_CHECKS=1; SET AUTOCOMMIT=1;"

for NAME in $domain_them; do
  sql_file="/usr/local/lsws/$NAME/html/giatuan-wptangtoc.sql"

  if [[ -f "$sql_file" ]]; then
    print_border_top "${C_GREEN}"
    left_text "➜ Get xử lý Website: ${C_BOLD_WHITE}$NAME${C_RESET}"

    # Nạp cấu hình Database vừa tạo
    . "/etc/wptt/vhost/.$NAME.conf" 2>/dev/null

    TEMP_CNF_ROOT=$(mktemp)
    chmod 600 "$TEMP_CNF_ROOT"
    cat >"$TEMP_CNF_ROOT" <<EOF
[client]
user=${database_admin_username}
password=${database_admin_password}
host=localhost
max_allowed_packet=1G
EOF
    trap "rm -f $TEMP_CNF_ROOT" EXIT

    # Tạo Database & User
    mariadb --defaults-extra-file="$TEMP_CNF_ROOT" -e "DROP DATABASE IF EXISTS ${DB_Name_web}; CREATE DATABASE ${DB_Name_web};"
    mariadb --defaults-extra-file="$TEMP_CNF_ROOT" -e "DROP USER IF EXISTS '${DB_User_web}'@'localhost'; CREATE USER '${DB_User_web}'@'localhost' IDENTIFIED BY '${DB_Password_web}'; GRANT ALL PRIVILEGES ON ${DB_Name_web}.* TO '${DB_User_web}'@'localhost'; FLUSH PRIVILEGES;"

    # Import SQL siêu tốc với Giao diện PV Tàng Hình
_runing "Import website $NAME"

    if command -v pv &>/dev/null; then
      (
        echo "$INIT_SQL"
        # Bỏ cờ -n, thay bằng cấu hình vẽ biểu đồ. File local nên PV tự tính Size không cần truyền -s
        pv -N "Import Database" -p -t -e -r -b -w 78 "$sql_file"
        echo "$END_SQL"
      ) | mariadb --defaults-extra-file="$TEMP_CNF_ROOT" "$DB_Name_web" 2>/dev/null
      
    else
      (
        echo "$INIT_SQL"
        cat "$sql_file"
        echo "$END_SQL"
      ) | mariadb --defaults-extra-file="$TEMP_CNF_ROOT" "$DB_Name_web" 2>/dev/null
    fi
    # Dọn dẹp & Phân quyền
    rm -f "$sql_file"
    rm -f "$TEMP_CNF_ROOT"
    . /etc/wptt/db/wptt-ket-noi "$NAME" >/dev/null 2>&1
    . /etc/wptt/wptt-phanquyen "$NAME" >/dev/null 2>&1

    if [[ -d /usr/local/lsws/$NAME/logs ]]; then
      sed -i -e '/^errorlog /,/^}$/d' /usr/local/lsws/conf/vhosts/"$NAME"/"$NAME".conf
      sed -i -e '/^accesslog /,/^}$/d' /usr/local/lsws/conf/vhosts/"$NAME"/"$NAME".conf
      echo '
errorlog $VH_ROOT/logs/error.log {
  useServer               1
  logLevel                ERROR
  rollingSize             10M
}
accesslog $VH_ROOT/logs/access.log {
  useServer               0
  rollingSize             10M
  keepDays                30
  compressArchive         1
}' >>/usr/local/lsws/conf/vhosts/"$NAME"/"$NAME".conf
    fi

echo -en "\033[1A\033[2K\r"
_rundone "Import website $NAME"
sleep 1
echo -en "\033[1A\033[2K\r"
print_border_bot
echo ""
    # Cấu hình Logs cho Vhost
  fi

  # Xử lý Website trong Subfolder (nếu có)
  sub_file="/usr/local/lsws/$NAME/html/subfolder-wptt.txt"
  if [[ -f "$sub_file" ]]; then
    wp_configs=$(find "/usr/local/lsws/$NAME/html" -type f -name 'wp-config.php')
    for config_path in $wp_configs; do
      dir_path=$(dirname "$config_path")
      # Bỏ qua folder gốc
      [[ "$dir_path" == "/usr/local/lsws/$NAME/html" ]] && continue

      if [[ -f "$dir_path/giatuan-wptangtoc.sql" ]]; then
        _runing "Đang xử lý Sub-Website tại: $(basename "$dir_path")"
        (cd "$dir_path" && curl -sO https://wptangtoc.com/giatuan/wptt-import-db && bash wptt-import-db >/dev/null 2>&1)
        rm -f "$dir_path/giatuan-wptangtoc.sql"
        _rundone "Đang xử lý Sub-Website tại: $(basename "$dir_path")"
      fi
    done
    rm -f "$sub_file"
  fi
done

chown root:root /usr/local/lsws
/usr/local/lsws/bin/lswsctrl reload >/dev/null 2>&1

rm -f wptt-rsync-move ~/wptt-rsync-move

# Lấy IP Máy chủ
ip=$(curl -skf --connect-timeout 5 "https://ipv4.icanhazip.com" || curl -skf --connect-timeout 5 "https://checkip.amazonaws.com")
[[ -z "$ip" ]] && ip=$(curl -sk --connect-timeout 5 "https://ipv6.icanhazip.com")

print_border_top "${C_GREEN}"
center_text "${C_BOLD_WHITE}HOÀN TẤT NẠP TẤT CẢ WEBSITE VÀO HỆ THỐNG${C_RESET}"
print_border_mid "${C_GREEN}"
left_text "Quá trình di cư và khởi tạo đã thành công tốt đẹp!" 2
print_border_mid "${C_GREEN}"
left_text "Địa chỉ IP máy chủ mới : ${C_YELLOW}$ip${C_RESET}" 2
left_text "Hành động tiếp theo    : Trỏ DNS các website về IP trên và" 2
left_text "                         tiến hành cài đặt SSL ngay lập tức." 2
print_border_bot "${C_GREEN}"
echo -en "\n${C_GREEN}➜ nhấn [enter] để quay lại menu chuyển website...${C_RESET}"
read -r dummy
[[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-chuyen-web-main 1
