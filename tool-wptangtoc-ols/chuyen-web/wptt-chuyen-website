function huong_dan() {
  Tính năng này chuyển website ngoài [Cpanel,plesk,Cyperpanel, AApanel, Larpvs,HocVPs,VPSSim... hệ thống cũ có terminal là được] chuyển về wptangtoc ols

  Tính năng Quản lý Chuyển Website [Website Migration] trong WPTangToc OLS là một tập hợp các công cụ và quy trình được thiết kế để giúp bạn di chuyển website [đặc biệt là WordPress] từ một nơi này sang nơi khác một cách dễ dàng và ít lỗi hơn. 🚚💨

  Giới thiệu ngắn gọn:
  Mục đích: Đơn giản hóa quá trình chuyển website giữa các máy chủ, từ nhà cung cấp này sang nhà cung cấp khác, hoặc từ môi trường phát triển [staging] lên máy chủ chính [production] và ngược lại.

  Lợi ích:
  * Giảm thiểu lỗi thủ công: Tự động hóa nhiều bước phức tạp trong quá trình di chuyển.
  * Tiết kiệm thời gian: Tăng tốc độ di chuyển website so với việc làm thủ công hoàn toàn.
  * Đảm bảo tính toàn vẹn: Giúp di chuyển đầy đủ cả tệp tin và cơ sở dữ liệu một cách nhất quán.
  * Thuận tiện: Cung cấp một quy trình tích hợp ngay trong công cụ quản lý máy chủ quen thuộc.
  Tính năng này giúp quá trình chuyển nhà cho website của bạn trở nên mượt mà và ít căng thẳng hơn, đảm bảo website hoạt động ổn định trên môi trường mới.

}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null # Nạp thư viện UX Bo Cong

NAME=${1:-}
all_for=${2:-}
[[ "$NAME" == "98" ]] && NAME=""

clear
echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}CHUYỂN VÙNG DỮ LIỆU ➜ Kéo Website từ Panel khác về WPTangToc OLS${C_RESET}"
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

# ==============================================================================
# 1. GỌI MENU CHỌN DOMAIN VÀ KIỂM TRA TỒN TẠI
# ==============================================================================
if [[ -z "$NAME" ]]; then
  . /etc/wptt/tenmien 2>/dev/null
  echo -e "${C_YELLOW}Website (đã thêm vào Vhost hệ thống) mà bạn muốn chuyển dữ liệu về:${C_RESET}"
  lua_chon_NAME "chuyển dữ liệu về"
fi

[[ "$NAME" == "0" || -z "$NAME" ]] && exit 0

pathcheck="/etc/wptt/vhost/.$NAME.conf"
if [[ ! -f "$pathcheck" ]]; then
  echo -e "\n${C_RED}Tên miền chưa được khởi tạo trên hệ thống! Vui lòng Thêm Website trước.${C_RESET}"
  sleep 3
  exit 1
fi

# ==============================================================================
# 2. KIỂM TRA DNS (CHỐT CHẶN AN TOÀN)
# ==============================================================================
_runing "Đang kiểm tra phân giải DNS của tên miền $NAME..."

checkdns=$(host "$NAME" 2>/dev/null | grep -Eo -m 1 '[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}')
[[ -z "$checkdns" ]] && checkdns=$(nslookup "$NAME" 2>/dev/null | grep Address | tail -n1 | grep -Eo '[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}')

ip=$(curl -skf --connect-timeout 5 "https://ipv4.icanhazip.com" || curl -skf --connect-timeout 5 "https://checkip.amazonaws.com")
[[ -z "$ip" ]] && ip=$(curl -sk --connect-timeout 5 "https://ipv6.icanhazip.com")

if [[ "$checkdns" == "$ip" ]]; then
  _runloi "Tên miền đã trỏ về Server mới!"
  echo -e "\n${C_RED}❌ Lỗi: DNS của tên miền $NAME đã trỏ về IP của máy chủ này ($ip).${C_RESET}"
  echo -e "${C_YELLOW}Tính năng này yêu cầu DNS phải đang trỏ về máy chủ cũ để có thể tải file qua HTTP!${C_RESET}"
  exit 1
elif [[ -z "$checkdns" ]]; then
  _runloi "Tên miền không tồn tại!"
  echo -e "\n${C_RED}❌ Lỗi: Website $NAME không tồn tại hoặc không thể phân giải DNS trên Internet.${C_RESET}"
  exit 1
fi
_rundone "DNS hợp lệ: Đang trỏ về máy chủ CŨ ($checkdns)."

# ==============================================================================
# 3. HƯỚNG DẪN THAO TÁC TRÊN SERVER CŨ
# ==============================================================================
if [[ -z "$all_for" ]]; then
  echo -e "\n${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_BOLD_WHITE}HƯỚNG DẪN THAO TÁC ĐÓNG GÓI DỮ LIỆU${C_RESET}"
  echo -e "${C_CYAN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
  left_text "  ${C_YELLOW}BƯỚC 1:${C_RESET} Mở Terminal (SSH) hay Terminal online trên máy chủ CŨ." 2
  left_text "  ${C_YELLOW}BƯỚC 2:${C_RESET} Dùng lệnh 'cd' truy cập vào thư mục chứa mã nguồn website." 2
  left_text "  ${C_YELLOW}BƯỚC 3:${C_RESET} Copy và dán lệnh dưới đây vào Terminal máy chủ cũ để chạy:" 2
  echo -e "${C_CYAN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
  center_text "${C_GREEN}curl -sO https://wptangtoc.com/share/wptt && bash wptt${C_RESET}"
  echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

  if ! wptt_xac_nhan "Bạn đã chạy xong lệnh trên máy chủ CŨ chưa?" "Hệ thống sẽ tiến hành kéo File về ngay lập tức." "" "Đã Xong! Kéo dữ liệu về" "Hủy thao tác"; then
    exec /etc/wptt/wptt-chuyen-web-main 1
  fi
fi

# ==============================================================================
# 4. DOWNLOAD BẢN SAO LƯU TỪ SERVER CŨ
# ==============================================================================
echo ""
_runing "Đang kết nối tải File SQL và Source Code từ máy chủ cũ về..."
mkdir -p "/usr/local/backup-website/$NAME"
rm -f "/usr/local/backup-website/$NAME/giatuan-wptangtoc.zip"
rm -f "/usr/local/backup-website/$NAME/giatuan-wptangtoc.sql"

# Dùng wget -q để tải ngầm không gây rác màn hình
wget -q -P "/usr/local/backup-website/$NAME" "http://$NAME/giatuan-wptangtoc.sql" --no-check-certificate
wget -q -P "/usr/local/backup-website/$NAME" "http://$NAME/giatuan-wptangtoc.zip" --no-check-certificate

duong_dan_thu_muc="/usr/local/backup-website/$NAME/giatuan-wptangtoc.zip"
duong_dan_thu_muc_sql="/usr/local/backup-website/$NAME/giatuan-wptangtoc.sql"

if [[ ! -f "$duong_dan_thu_muc" || ! -f "$duong_dan_thu_muc_sql" ]]; then
  _runloi "Tải dữ liệu thất bại!"
  echo -e "\n${C_RED}Không thể tìm thấy file Backup trên máy chủ cũ. Chuyển website thất bại.${C_RESET}"
  exit 1
fi
_rundone "Tải thành công File SQL và Mã nguồn."

# ==============================================================================
# 5. KHÔI PHỤC DATABASE & MÃ NGUỒN
# ==============================================================================
. "/etc/wptt/vhost/.$NAME.conf" 2>/dev/null

_runing "Đang khởi tạo Database & Import dữ liệu SQL..."
TEMP_CNF_ROOT=$(mktemp)
chmod 600 "$TEMP_CNF_ROOT"
cat >"$TEMP_CNF_ROOT" <<EOF
[client]
user=${database_admin_username}
password=${database_admin_password}
host=localhost
max_allowed_packet=1G
default-character-set=utf8mb4
EOF
trap "rm -f $TEMP_CNF_ROOT" EXIT

# Tạo DB và Import
mariadb --defaults-extra-file="$TEMP_CNF_ROOT" -e "DROP DATABASE IF EXISTS ${DB_Name_web}; CREATE DATABASE ${DB_Name_web};"
mariadb --defaults-extra-file="$TEMP_CNF_ROOT" -e "DROP USER IF EXISTS '${DB_User_web}'@'localhost'; CREATE USER '${DB_User_web}'@'localhost' IDENTIFIED BY '${DB_Password_web}';"
mariadb --defaults-extra-file="$TEMP_CNF_ROOT" -e "GRANT ALL PRIVILEGES ON ${DB_Name_web}.* TO '${DB_User_web}'@'localhost'; FLUSH PRIVILEGES;"
mariadb --defaults-extra-file="$TEMP_CNF_ROOT" "$DB_Name_web" --force <"$duong_dan_thu_muc_sql"
rm -f "$TEMP_CNF_ROOT"
_rundone "Import Database thành công."

_runing "Đang giải nén mã nguồn vào không gian Website (Vhost)..."
rm -rf /usr/local/lsws/"$NAME"/html/*
rm -rf /usr/local/lsws/"$NAME"/luucache/*

if [[ -z "$all_for" ]]; then
  unzip -q -n "$duong_dan_thu_muc" -d /usr/local/lsws/"$NAME"/html/ -x "wptt"
else
  unzip -q -n "$duong_dan_thu_muc" -d /usr/local/lsws/"$NAME"/html/
fi

rm -f /usr/local/lsws/"$NAME"/html/index.html
_rundone "Giải nén mã nguồn hoàn tất."

# ==============================================================================
# 6. PHÂN QUYỀN VÀ CẤU HÌNH WP-CONFIG
# ==============================================================================
_runing "Đang phân quyền thư mục và cấu hình lại wp-config.php..."
chown -R "$User_name_vhost":"$User_name_vhost" /usr/local/lsws/"$NAME"/html
find /usr/local/lsws/"$NAME"/html -type d -exec chmod 755 {} \;
find /usr/local/lsws/"$NAME"/html -type f -exec chmod 644 {} \;

if [[ -f "/usr/local/lsws/$NAME/html/wp-config.php" ]]; then
  wp config set DB_HOST 'localhost' --type=constant --allow-root --path="/usr/local/lsws/$NAME/html" --quiet
  wp config set DB_NAME "$DB_Name_web" --type=constant --allow-root --path="/usr/local/lsws/$NAME/html" --quiet
  wp config set DB_USER "$DB_User_web" --type=constant --allow-root --path="/usr/local/lsws/$NAME/html" --quiet
  wp config set DB_PASSWORD "$DB_Password_web" --type=constant --allow-root --path="/usr/local/lsws/$NAME/html" --quiet
  wp rewrite flush --allow-root --path="/usr/local/lsws/$NAME/html" >/dev/null 2>&1
fi

/usr/local/lsws/bin/lswsctrl restart >/dev/null 2>&1
rm -f "$duong_dan_thu_muc" "$duong_dan_thu_muc_sql"
_rundone "Cấu hình Website và Restart LiteSpeed thành công."

# Hỗ trợ check wordpress multisite
if grep -q "MULTISITE" "/usr/local/lsws/$NAME/html/wp-config.php" 2>/dev/null; then
  . /etc/wptt/wordpress/wordpress-multisite "$NAME" 1
fi

# ==============================================================================
# 7. LOGO ASCII VÀ BÁO CÁO TỔNG KẾT
# ==============================================================================
echo -e "${C_RED}
     .:..........................             
      .::::::::::::::::::::::::::::..         
        ..:::::::::::::::::::::::::::::.      
                             ...:::::::::.    
                                  .:::::::.   
          .:::::::.         .       .:::::::  
         .::::::::::::::::::::..      ::::::: 
         ::::::::::::::::::::::::.     ::::::.
        .::::::::::::::::::::::::::.   .:::::.
        .::::::::::::::::::::::::::::  .:::::.
        .::::::::::::::::::::::::::.   .:::::.
         ::::::::::::::::::::::::.     ::::::.
.::::::  .:::::::::::::::::::::.      ::::::. 
          .:::::::.                 .:::::::  
       ::::::::::::.              .:::::::.   
       ......:::::::::...    ...:::::::::.    
               .:::::::::::::::::::::::.      
   ..............::::::::::::::::::..         
  .:::::::::::::................. ${C_RESET}"

if [[ -z "$all_for" ]]; then
  echo -e "\n${C_GREEN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_BOLD_WHITE}HOÀN TẤT ĐƯA WEBSITE '$NAME' VỀ HỆ THỐNG${C_RESET}"
  echo -e "${C_GREEN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"

  if [[ "$checkdns" != "$ip" ]]; then
    left_text "${C_YELLOW}HƯỚNG DẪN BƯỚC TIẾP THEO:${C_RESET}" 2
    left_text "  Bạn vui lòng truy cập trang quản lý Tên miền (Cloudflare...)" 2
    left_text "  và trỏ IP của tên miền về máy chủ mới: ${C_BOLD_WHITE}$ip${C_RESET}" 2
    left_text "  Sau đó vào Menu số (3) để cài đặt SSL là xong." 2
    echo -e "${C_GREEN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
  fi

  disk_info=$(df -BG / | awk '$NF=="/"{printf "%d / %d GB (Dùng %s)", $3,$2,$5}')
  left_text " 1. Dung lượng ổ đĩa : ${C_YELLOW}$disk_info${C_RESET}" 2
  left_text " 2. Thư mục Backup   : ${C_YELLOW}/usr/local/backup-website/$NAME${C_RESET}" 2
  left_text " 3. Thư mục Website  : ${C_YELLOW}/usr/local/lsws/$NAME/html${C_RESET}" 2
  echo -e "${C_GREEN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"
fi
