# Hàm tải file tích hợp Progress Bar thông minh
tai_file_ux() {
    local url="$1"
    local output_file="$2"
    local file_name="$3"

    echo -e "${C_CYAN}➜ Đang tải: ${C_BOLD_WHITE}$file_name${C_RESET}"
    # Lấy Header để check dung lượng file thực tế (Dùng -sIL để bám theo redirect HTTP -> HTTPS)
    local file_size=$(curl -sIL --insecure "$url" | grep -i "content-length:" | tail -n 1 | awk '{print $2}' | tr -d '\r')

    if command -v pv >/dev/null 2>&1; then
        if [[ -n "$file_size" && "$file_size" -gt 0 ]]; then
            # Đã lấy được dung lượng -> Vẽ thanh Bar [====> ] % ETA siêu đẹp
            curl -sL --insecure "$url" | pv -W -p -e -r -b -a -s "$file_size" > "$output_file"
        else
            # Nếu server cũ chặn lấy dung lượng, chỉ hiện tốc độ và số MB
            curl -sL --insecure "$url" | pv -W -t -r -b -a > "$output_file"
        fi
    else
        # Fallback xuống progress bar của curl nếu thiếu pv
        curl -L --insecure -# "$url" -o "$output_file"
    fi
    echo -en "\033[1A\033[2K\r"
    echo -en "\033[1A\033[2K\r"
}

