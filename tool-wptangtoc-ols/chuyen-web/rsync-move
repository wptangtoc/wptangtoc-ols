#!/bin/bash

function huong_dan() {
  rsync là một công cụ mạnh mẽ và linh hoạt dùng để đồng bộ hóa [synchronize] và truyền tải [transfer] file/thư mục giữa các máy tính/máy chủ. Khi nói về chuyển website rsync tự động hóa quá trình sao chép dữ liệu website từ một nơi này sang một nơi khác [ví dụ: từ server phát triển sang server sản phẩm, hoặc để sao lưu website].

  Các tính năng nổi bật khi dùng rsync để chuyển website tự động:

  Đồng bộ hóa thông minh: rsync chỉ sao chép những phần file đã thay đổi hoặc những file mới, giúp tiết kiệm băng thông và thời gian so với việc sao chép toàn bộ.
  * Hiệu quả và Nhanh chóng: Nhờ thuật toán delta-transfer, rsync truyền dữ liệu rất hiệu quả.
  * Bảo toàn thuộc tính file: rsync có thể giữ nguyên các thuộc tính của file như quyền truy cập, thời gian sửa đổi, v.v.
  * Bảo mật: Có thể truyền dữ liệu qua các kênh mã hóa như SSH để đảm bảo an toàn.
  * Nén dữ liệu: rsync hỗ trợ nén dữ liệu trong quá trình truyền để giảm dung lượng và tăng tốc độ.
  * Linh hoạt: Nhiều tùy chọn cấu hình cho phép bạn tùy chỉnh quá trình đồng bộ hóa theo nhu cầu cụ thể.
  Nói tóm lại, sử dụng rsync để tự động hóa việc chuyển website giúp đảm bảo dữ liệu luôn được cập nhật, tiết kiệm thời gian quản trị và giảm thiểu rủi ro lỗi do con người.
}

. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null

echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}CHUYỂN VÙNG DỮ LIỆU ➜ Đóng gói & Rsync sang Server mới${C_RESET}"
echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

while true; do
  echo -en "${C_CYAN}Nhập địa chỉ IP Server mới [0=Thoát]: ${C_RESET}"
  read -r IP
  [[ "$IP" == "0" || -z "$IP" ]] && {
    [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-chuyen-web-main 1
    exit 0
  }

  # Clean IP
  IP="${IP//[[:space:]]/}"

  # Regex kiểm tra IPv4 & IPv6
  is_ipv4=$(echo "$IP" | grep -E -o '^(25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\.(25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\.(25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\.(25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)$')
  is_ipv6=$(echo "$IP" | grep -oE '\b([0-9a-fA-F]{1,4}:){7}[0-9a-fA-F]{1,4}\b|\b([0-9a-fA-F]{1,4}:){1,7}:\b|::1')

  if [[ -n "$is_ipv4" || -n "$is_ipv6" ]]; then
    break
  else
    echo -e "${C_RED}❌ Lỗi: Định dạng IP không hợp lệ! Vui lòng nhập lại.${C_RESET}"
  fi
done

echo -en "${C_CYAN}Nhập Port SSH Server mới [Mặc định: 22]: ${C_RESET}"
read -r Port
Port=${Port:-22}
if ! [[ "$Port" =~ ^[0-9]+$ ]]; then
  echo -e "${C_RED}❌ Lỗi: Port phải là số!${C_RESET}"
  exit 1
fi

. /etc/wptt/.wptt.conf

if [ "$(ls -A /etc/wptt/vhost | grep -v '^\.\.conf$' | sort -uV)" ]; then
  echo
  rm -f /usr/local/lsws/$Website_chinh/html/danh-sach-website-wptangtoc-ols.txt
  echo '--------------------------------------------------'
  for entry in $(ls -A /etc/wptt/vhost | grep -v '^\.\.conf$' | sort -uV); do
    domain=$(echo $entry | sed 's/^.//' | sed 's/.conf//')
    path="/usr/local/lsws/$domain/html"
    i=1
    if [[ -d "$path" ]]; then               #kiểm tra thư mục mã nguồn đã tồn tại chưa
      if [[ -f $path/wp-config.php ]]; then #chỉ move database website WordPress thôi
        _runing "Sao lưu database website $domain"
        #get all tài khoản database
        unset DB_Password_web DB_User_web DB_Name_web
        DB_User_web=$(wp config get DB_USER --path=$path --allow-root 2>/dev/null)
        DB_Password_web=$(wp config get DB_PASSWORD --path=$path --allow-root 2>/dev/null)
        DB_Name_web=$(wp config get DB_NAME --path=$path --allow-root 2>/dev/null)

        # ==============================================================================
        # PHƯƠNG ÁN DỰ PHÒNG: Nếu WP-CLI thất bại (Biến bị rỗng), tự động đọc wp-config.php, một số tình huống người dùng phá tan cái PHP rồi dùng kỹ thuật này để chuyển
        # ==============================================================================
        if [[ -z "$DB_User_web" || -z "$DB_Password_web" || -z "$DB_Name_web" ]]; then
          wp_config_file="$path/wp-config.php"

          if [[ -f "$wp_config_file" ]]; then

            if [[ -z "$DB_User_web" ]]; then
              DB_User_web=$(grep -E "^[[:space:]]*define[[:space:]]*\([[:space:]]*['\"]DB_USER['\"]" "$wp_config_file" | head -n 1 | sed -E "s/.*['\"]DB_USER['\"][[:space:]]*,[[:space:]]*['\"](.*)['\"][[:space:]]*\).*/\1/")
            fi

            if [[ -z "$DB_Password_web" ]]; then
              DB_Password_web=$(grep -E "^[[:space:]]*define[[:space:]]*\([[:space:]]*['\"]DB_PASSWORD['\"]" "$wp_config_file" | head -n 1 | sed -E "s/.*['\"]DB_PASSWORD['\"][[:space:]]*,[[:space:]]*['\"](.*)['\"][[:space:]]*\).*/\1/")
            fi

            if [[ -z "$DB_Name_web" ]]; then
              DB_Name_web=$(grep -E "^[[:space:]]*define[[:space:]]*\([[:space:]]*['\"]DB_NAME['\"]" "$wp_config_file" | head -n 1 | sed -E "s/.*['\"]DB_NAME['\"][[:space:]]*,[[:space:]]*['\"](.*)['\"][[:space:]]*\).*/\1/")
            fi
          fi
        fi

        TEMP_CNF=$(mktemp)
        chmod 600 "$TEMP_CNF" # Chỉ root mới đọc được
        cat >"$TEMP_CNF" <<EOF
[client]
user=${DB_User_web}
password=${DB_Password_web}
host=localhost
max_allowed_packet=1G
default-character-set=utf8mb4

[mysqldump]
quick
quote-names
max_allowed_packet=1G
single-transaction
EOF
        trap "rm -f $TEMP_CNF" EXIT

        rm -f $path/giatuan-wptangtoc.sql
        mariadb-dump --defaults-extra-file="$TEMP_CNF" "$DB_Name_web" >$path/giatuan-wptangtoc.sql
        database="$path/giatuan-wptangtoc.sql"
        rm -f $TEMP_CNF
        check_file_error=$(du -c $database | awk '{print $1}' | sed '1d')
        if ((${check_file_error:-0} < 10)); then
          _runloi "Sao lưu database website $domain"
        else
          _rundone "Sao lưu database website $domain"
          echo "$domain" >>/usr/local/lsws/$Website_chinh/html/danh-sach-website-wptangtoc-ols.txt
        fi
      fi
    fi
  done
  echo '--------------------------------------------------'
  echo
fi

# =================================================================
# [CẢI TIẾN] Thu thập danh sách Domain và Đúc màng lọc OS thông minh
# =================================================================

FILE_TAM=$(mktemp)

RSYNC_EXCLUDES=() # Khởi tạo mảng trống

if [ "$(ls -A /etc/wptt/vhost | grep -v '^\.\.conf$' | sort -uV)" ]; then
  for entry in $(ls -A /etc/wptt/vhost | grep -v '^\.\.conf$' | sort -uV); do
    domain=$(echo $entry | sed 's/^.//' | sed 's/.conf//')
    path="/usr/local/lsws/$domain/html"
    i=1
    if [[ -d "$path" ]]; then
      echo "/usr/local/lsws/$domain" >>$FILE_TAM

      # Bơm màng lọc loại bỏ Chroot Jail cho riêng domain này
      RSYNC_EXCLUDES+=(
        "--exclude=/$domain/bin"
        "--exclude=/$domain/sbin"
        "--exclude=/$domain/lib"
        "--exclude=/$domain/lib64"
        "--exclude=/$domain/usr"
        "--exclude=/$domain/dev"
        "--exclude=/$domain/etc"
        "--exclude=/$domain/tmp"
        "--exclude=/$domain/var"
        "--exclude=/$domain/passwd"
        "--exclude=/$domain/html/phpmyadmin"
        "--exclude=/$domain/html/quan-ly-files"
        "--exclude=/$domain/.cron_spool"
        "--exclude=/$domain/.bash*"
        "--exclude=/$domain/.lsns"
        "--exclude=/$domain/luucache"
        "--exclude=/$domain/logs"
        "--exclude=/$domain/backup-website"
      )
    fi
  done
fi

#backup-database-subfolder
for entry in $(ls -A /etc/wptt/vhost | grep -v '^\.\.conf$' | sort -uV); do
  NAME=$(echo $entry | sed 's/^.//' | sed 's/.conf//')
  rm -f /usr/local/lsws/$NAME/html/subfolder-wptt.txt

  #Kiểm tra xem có sử dụng tính năng tạo subfolder website
  if [[ ! -d /etc/wptt/$NAME-wptt ]]; then
    continue
  fi

  domain_all=$(find /usr/local/lsws/$NAME/html -type f -name 'wp-config.php')
  for entry in ${domain_all[@]}; do
    path=$(echo $entry | sed 's/\/wp-config.php//g')
    i=1

    #bypass website gốc
    thumuc=$(echo $path | cut -f7 -d '/')
    if [[ $thumuc = '' ]]; then
      continue
    fi

    if [[ -f "$path/wp-config.php" ]]; then
      rm -f $path/giatuan-wptangtoc.sql

      unset DB_Password_web DB_User_web DB_Name_web
      DB_User_web=$(wp config get DB_USER --path=$path --allow-root 2>/dev/null)
      DB_Password_web=$(wp config get DB_PASSWORD --path=$path --allow-root 2>/dev/null)
      DB_Name_web=$(wp config get DB_NAME --path=$path --allow-root 2>/dev/null)

      TEMP_CNF=$(mktemp)
      chmod 600 "$TEMP_CNF" # Chỉ root mới đọc được
      cat >"$TEMP_CNF" <<EOF
[client]
user=${DB_User_web}
password=${DB_Password_web}
host=localhost
max_allowed_packet=1G
default-character-set=utf8mb4

[mysqldump]
quick
quote-names
max_allowed_packet=1G
EOF
      trap "rm -f $TEMP_CNF" EXIT

      rm -f $path/giatuan-wptangtoc.sql
      mariadb-dump --defaults-extra-file="$TEMP_CNF" "$DB_Name_web" >$path/giatuan-wptangtoc.sql
      echo "$thumuc" >>/usr/local/lsws/$NAME/html/subfolder-wptt.txt
    fi
  done
done

list_ssl_domain_all=$(cat $FILE_TAM | sort -u | uniq | sed '/^$/d' | sed 's/ $//g' | tr -s '\n' ' ')

rm -f $FILE_TAM #xoá file tạm

#bắt đầu check rsync đã cài đặt vào hệ thống hay chưa
missing_tools='rsync'
if ! command -v "$missing_tools" &>/dev/null; then
  if [ -f /etc/redhat-release ]; then #REDHAT
    dnf install -y epel-release
    dnf install -y "${missing_tools}"
  elif [ -f /etc/debian_version ]; then #Ubuntu
    apt-get update
    apt-get install -y "${missing_tools}"
  fi
fi
#end check rsync đã cài đặt vào hệ thống hay chưa

#cho ip vào danh sách trắng csf khi dùng csf, nếu sử dụng CSF
if command -v csf >/dev/null 2>&1; then
  csf -a $IP >/dev/null 2>&1
fi

echo "Chuyển toàn bộ website bằng rsync all cho $IP : $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log

# =================================================================
# Thực thi Rsync kèm mảng Exclude động đã được đúc ở trên
# =================================================================
# echo "rsync -avzh ${RSYNC_EXCLUDES[*]} -e 'ssh -p $Port -o StrictHostKeyChecking=no' $list_ssl_domain_all root@$IP:/usr/local/lsws"

echo -e "${C_CYAN}Vui lòng nhập mật khẩu SSH của Server đích khi được hỏi.${C_RESET}\n"
rsync -avzh "${RSYNC_EXCLUDES[@]}" -e "ssh -p $Port -o StrictHostKeyChecking=no" $list_ssl_domain_all root@$IP:/usr/local/lsws

echo -e "\n${C_GREEN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_BOLD_WHITE}HOÀN TẤT QUÁ TRÌNH TRUYỀN TẢI DỮ LIỆU${C_RESET}"
echo -e "${C_GREEN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
left_text "Dữ liệu đã được nén và đẩy sang máy chủ đích ($IP)." 2
echo -e "${C_GREEN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
left_text "${C_BOLD_WHITE}CÔNG VIỆC CẦN LÀM TIẾP THEO:${C_RESET}" 2
left_text "  1. Đăng nhập vào Server MỚI ($IP)." 2
left_text "  2. Truy cập Menu WPTangToc OLS." 2
left_text "  3. Chọn mục: ${C_YELLOW}Chuyển website (27)${C_RESET} ➜ ${C_YELLOW}GET nhận (5)${C_RESET}." 2
left_text "  4. Chờ hệ thống tự động Import." 2
echo -e "${C_GREEN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

echo -en "${C_GREEN}Nhấn phím [Enter] để quay lại Menu...${C_RESET}"
read -r dummy

# echo "sang bên server mới hãy gõ lệnh: curl -sO https://wptangtoc.com/share/wptt-rsync-move && bash wptt-rsync-move"
# echo "Lưu ý: Nếu đang ở status wptangtoc ols hoặc menu chính thì hãy ấn nút 0 hoặc ctrl + c để thoát ra rồi mới nhập lệnh trên"
