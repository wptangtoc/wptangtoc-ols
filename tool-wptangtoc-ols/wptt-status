#!/bin/bash
# @author: Gia Tuấn
# @website: https://wptangtoc.com
# @since: 2026

. /etc/wptt/.wptt.conf
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh
clear

export LANG=en_US.UTF-8
export LC_ALL=en_US.UTF-8

# ==============================================================================
# 1. BẢNG MÀU & CẤU HÌNH (ÉP SÁT LỀ TRÁI - KHUNG 78)
# ==============================================================================
C_RED='\033[1;31m'
C_GREEN='\033[1;32m'
C_YELLOW='\033[1;33m'
C_CYAN='\033[1;36m'
C_BOLD_WHITE='\033[1;37m'
C_RESET='\033[0m'

# Khung tỷ lệ vàng mới: 78 ký tự
box_inner_width=78
MARGIN="" # Luôn để rỗng để bám lề trái

# --- BACKGROUND ALERTS ---
if [[ "$thong_bao_login_ssh" = "1" ]]; then
  (
    client_ip=$(echo $SSH_CLIENT | awk '{ print $1}')
    vps_ip=$(curl -sf --connect-timeout 5 https://ipv4.icanhazip.com || echo "unknown")
    date="$(date "+%d-%m-%Y %H:%M")"
    text="Cảnh báo đăng nhập SSH - ${vps_ip}| IP: ${client_ip} | Time: ${date}"
    curl -s -d "chat_id=$telegram_id&text=${text}" "https://worker-soft-shape-e788.hoangtuan0137.workers.dev/bot${telegram_api}/sendMessage" >/dev/null
  ) &
  disown
fi

# --- KIỂM TRA CẬP NHẬT ---
SHOW_UPDATE=0
NEW_VERSION=""
[[ -f /tmp/wptangtoc-ols-version ]] && wptangtocols_version=$(cat /tmp/wptangtoc-ols-version)
if [[ -z "$wptangtocols_version" ]]; then
  wptangtocols_version=$(curl -sf --connect-timeout 2 --max-time 5 https://wptangtoc.com/share/version-wptangtoc-ols.txt | head -1 | grep '\.' || curl -sf --connect-timeout 2 --max-time 5 https://raw.githubusercontent.com/wptangtoc/wptangtoc-ols/refs/heads/main/version-wptangtoc-ols.txt)
fi
wptangtocols_version=$(echo "$wptangtocols_version" | tr -d '\r\n ')
if [[ -n "$wptangtocols_version" && "$wptangtocols_version" != "$version_wptangtoc_ols" ]]; then
  SHOW_UPDATE=1
  NEW_VERSION="$wptangtocols_version"
fi

# ==============================================================================
# 2. CÁC HÀM VẼ GIAO DIỆN (SÁT LỀ TRÁI - TỐI ƯU KHUNG 78)
# ==============================================================================
draw_bar() {
  local percent=$1; local length=15
  local fill=$(((percent * length) / 100))
  [[ $fill -lt 0 ]] && fill=0; [[ $fill -gt $length ]] && fill=$length
  local empty=$((length - fill))
  local color=$C_GREEN
  [[ "$percent" -ge 60 ]] && color=$C_YELLOW
  [[ "$percent" -ge 80 ]] && color=$C_RED
  local fill_str=""; [[ $fill -gt 0 ]] && printf -v fill_str "%${fill}s" "" && fill_str=${fill_str// /|}
  local empty_str=""; [[ $empty -gt 0 ]] && printf -v empty_str "%${empty}s" "" && empty_str=${empty_str// /.}
  printf "${C_CYAN}[${color}%s${C_RESET}%s${C_CYAN}]${C_RESET}" "$fill_str" "$empty_str"
}

print_line() {
  local text="$1"
  local clean_text=$(echo -e "$text" | sed "s/\x1B\[[0-9;]*[a-zA-Z]//g")
  local text_len=${#clean_text}
  local pad=$((box_inner_width - text_len - 1))
  [[ $pad -lt 0 ]] && pad=0
  echo -e "${C_CYAN}│${C_RESET} ${text}$(printf '%*s' "$pad" "")${C_CYAN}│${C_RESET}"
}

print_2col() {
  local col1="$1"; local col2="$2"
  local clean1=$(echo -e "$col1" | sed "s/\x1B\[[0-9;]*[a-zA-Z]//g")
  local len1=${#clean1}
  
  # Cột trái chiếm 38 ký tự để cân đối với tổng 78 ký tự
  local col1_width=38
  local pad1=$((col1_width - len1))
  [[ $pad1 -lt 0 ]] && pad1=0
  
  print_line "${col1}$(printf '%*s' "$pad1" "") ${C_CYAN}│${C_RESET} ${col2}"
}

center_text() {
  local text="$1"
  local clean_text=$(echo -e "$text" | sed "s/\x1B\[[0-9;]*[a-zA-Z]//g")
  local text_len=${#clean_text}
  local pad_left=$(((box_inner_width - text_len) / 2))
  local pad_right=$((box_inner_width - text_len - pad_left))
  echo -e "${C_CYAN}│${C_RESET}$(printf '%*s' "$pad_left" "")${text}$(printf '%*s' "$pad_right" "")${C_CYAN}│${C_RESET}"
}

# ==============================================================================
# 3. RENDER DASHBOARD
# ==============================================================================
OS_NAME_STATIC=$(awk -F'[="]' '/PRETTY_NAME/ {print $3}' /etc/os-release | awk '{print $1,$2}')

print_dashboard() {
  local rx_rate_in=$1; local tx_rate_in=$2; local cpu_usage_in=$3
  local ols_status_in=$4; local db_status_in=$5

  # Header tĩnh (78 dashes)
  echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "WPTANGTOC OLS $phien_ban: $version_wptangtoc_ols"
  center_text "$phat_trien_boi_gia_tuan"
  if [[ "$wptangtoc_ols_giatuan" == "1" && -n "$key_activate" ]]; then center_text "Bản Quyền: Enterprise + Premium"
  elif [[ "$wptangtoc_ols_giatuan" == "1" ]]; then center_text "Bản Quyền: Enterprise"
  elif [[ -n "$key_activate" ]]; then center_text "Bản Quyền: Premium"
  fi
  [[ "$beta_wptangtoc_ols" == "1" ]] && center_text "[Phiên bản Beta]"
  echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯${C_RESET}"

  # Data Fetching (Pure Bash)
  while read -r name value _; do
    case $name in MemTotal:) mem_total=$value ;; MemAvailable:) mem_avail=$value ;; esac
  done </proc/meminfo
  local ram_total=$((mem_total / 1024)); local ram_used=$(((mem_total - mem_avail) / 1024))
  local ram_percent=$((ram_used * 100 / ram_total))

  local net_in_display="${rx_rate_in} KB/s"; local net_out_display="${tx_rate_in} KB/s"
  [[ "$rx_rate_in" -gt 5120 ]] && net_in_display="${C_RED}${rx_rate_in} KB/s${C_RESET}"
  [[ "$tx_rate_in" -gt 5120 ]] && net_out_display="${C_RED}${tx_rate_in} KB/s${C_RESET}"

  read -r l1 l2 l3 _ </proc/loadavg; local load_avg="$l1, $l2, $l3"
  read -r uptime_full _ </proc/uptime; local up_seconds=${uptime_full%%.*}
  local d=$((up_seconds / 86400)); local h=$(((up_seconds % 86400) / 3600))
  local m=$(((up_seconds % 3600) / 60)); local uptime_display="${d}d ${h}h ${m}m"

  # Panel chính
  echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
  print_line "$(printf "CPU : %3s%% %s  %-5s %s" "$cpu_usage_in" "$(draw_bar $cpu_usage_in)" "Load:" "$load_avg")"
  print_line "$(printf "RAM : %3s%% %s  %-5s %s/%s MB" "$ram_percent" "$(draw_bar $ram_percent)" "Used:" "$ram_used" "$ram_total")"
  print_line "$(printf "Disk: %3s%% %s  %-5s %s/%s GB" "$cached_disk_percent" "$(draw_bar $cached_disk_percent)" "Used:" "$cached_disk_used" "$cached_disk_total")"
  echo -e "${C_CYAN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
  print_2col "Net In : $net_in_display" "OpenLiteSpeed : $ols_status_in"
  print_2col "Net Out: $net_out_display" "MariaDB       : $db_status_in"
  print_2col "Uptime : $uptime_display" "OS            : $OS_NAME_STATIC"
  echo -e "${C_CYAN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
  
  menu_str="${C_GREEN}[ENTER]${C_RESET} Menu | ${C_GREEN}[2]${C_RESET} Menu nhanh"
  [[ "$SHOW_UPDATE" == "1" ]] && menu_str="${menu_str} | ${C_YELLOW}[9] Cập nhật${C_RESET}"
  menu_str="${menu_str} | ${C_RED}[0]${C_RESET} Thoát (Bash CLI)"
  center_text "$menu_str"
  
  if [ "$ram_percent" -gt 85 ] || [ "$cached_disk_percent" -gt 90 ]; then
    echo -e "${C_CYAN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
    [[ "$ram_percent" -gt 85 ]] && print_line "${C_RED} ⚠️ Cảnh báo: RAM đang quá tải!${C_RESET}"
    [[ "$cached_disk_percent" -gt 90 ]] && print_line "${C_RED} ⚠️ Cảnh báo: Ổ cứng sắp đầy!${C_RESET}"
  fi
  echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯${C_RESET}"
}

# ==============================================================================
# 4. VÒNG LẶP CHÍNH
# ==============================================================================
disk_raw=$(df -BG / | awk 'NR==2 {print $3, $2, $5}' | tr -d 'G%')
read -r cached_disk_used cached_disk_total cached_disk_percent <<<"$disk_raw"

read -r cpu a b c idle rest </proc/stat
prev_total=$((a + b + c + idle)); prev_idle=$idle; cpu_display_val=0

rx_prev=0; tx_prev=0
while read -r iface rx _ _ _ _ _ _ _ tx _; do
  [[ "$iface" == *"Inter-"* || "$iface" == *"face"* || "$iface" == *"lo:"* ]] && continue
  rx_prev=$((rx_prev + rx)); tx_prev=$((tx_prev + tx))
done </proc/net/dev

tput civis
ACTION="menu"
counter=0
cached_ols_status="${C_YELLOW}Kiểm tra...${C_RESET}"
cached_db_status="${C_YELLOW}Kiểm tra...${C_RESET}"
prev_lines=0

while true; do
  # Network & CPU Data
  rx_now=0; tx_now=0
  while read -r iface rx _ _ _ _ _ _ _ tx _; do
    [[ "$iface" == *"Inter-"* || "$iface" == *"face"* || "$iface" == *"lo:"* ]] && continue
    rx_now=$((rx_now + rx)); tx_now=$((tx_now + tx))
  done </proc/net/dev
  rx_rate=$(((rx_now - rx_prev) / 1024)); tx_rate=$(((tx_now - tx_prev) / 1024))
  rx_prev=$rx_now; tx_prev=$tx_now

  read -r cpu a b c idle rest </proc/stat
  total=$((a + b + c + idle)); diff_total=$((total - prev_total)); diff_idle=$((idle - prev_idle))
  prev_total=$total; prev_idle=$idle
  [[ $diff_total -eq 0 ]] && cpu_now=0 || cpu_now=$((100 * (diff_total - diff_idle) / diff_total))
  cpu_display_val=$(((cpu_display_val + cpu_now) / 2))

  if ((counter % 10 == 0)); then
    /usr/local/lsws/bin/lswsctrl status 2>/dev/null | grep -q 'litespeed is running' && cached_ols_status="${C_GREEN}Hoạt động${C_RESET}" || cached_ols_status="${C_RED}Tạm dừng${C_RESET}"
    systemctl is-active mariadb.service >/dev/null 2>&1 && cached_db_status="${C_GREEN}Hoạt động${C_RESET}" || cached_db_status="${C_RED}Tạm dừng${C_RESET}"
    disk_raw=$(df -BG / | awk 'NR==2 {print $3, $2, $5}' | tr -d 'G%')
    read -r cached_disk_used cached_disk_total cached_disk_percent <<<"$disk_raw"
  fi
  ((counter++))

  buffer=$(print_dashboard "$rx_rate" "$tx_rate" "$cpu_display_val" "$cached_ols_status" "$cached_db_status")
  current_lines=$(echo -e "$buffer" | wc -l)
  [[ $prev_lines -gt 0 ]] && tput cuu "$prev_lines"
  echo -e "$buffer"
  
  if [[ $prev_lines -gt $current_lines ]]; then
    echo -en "\e[J"
  fi
  prev_lines=$current_lines

  read -t 1 -n 1 -s key_input
  READ_STATUS=$?
  if [[ $READ_STATUS -eq 0 ]]; then
    if [[ "$key_input" == "0" ]]; then ACTION="exit"
    elif [[ "$key_input" == "2" ]]; then ACTION="search"
    elif [[ "$key_input" == "9" && "$SHOW_UPDATE" == "1" ]]; then ACTION="update"
    else ACTION="menu"; fi
    break
  elif [[ $READ_STATUS -eq 1 || $READ_STATUS -eq 255 ]]; then
    exit 1
  fi
done

tput cnorm
echo ""
case $ACTION in
"exit") echo -e "Đã thoát ra WPTangToc OLS. Nhập lệnh ${C_GREEN}1${C_RESET} hoặc ${C_GREEN}wptangtoc${C_RESET} để quay lại menu." ;;
"search") [[ -f "/etc/wptt/search-wptangtoc" ]] && exec /etc/wptt/search-wptangtoc ;;
"update") exec /etc/wptt/wptt-update ;;
*) exec /usr/bin/wptangtoc ;;
esac
