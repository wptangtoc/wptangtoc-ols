export LANG=en_US.UTF-8
export LC_ALL=en_US.UTF-8

# Nạp cấu hình, ngôn ngữ và thư viện màu siêu cấp
. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null

clear
# echo '' #cách 1 lề khoảng chống
# ==============================================================================
# 1. CẤU HÌNH BACKGROUND ALERTS & UPDATE
# ==============================================================================
# --- BACKGROUND ALERTS ---
if [[ "$thong_bao_login_ssh" = "1" ]]; then
  (
    client_ip=$(echo $SSH_CLIENT | awk '{ print $1}')
    vps_ip=$(curl -sf --connect-timeout 5 https://ipv4.icanhazip.com || echo "unknown")
    date="$(date "+%d-%m-%Y %H:%M")"
    text="Cảnh báo đăng nhập SSH - ${vps_ip}| IP: ${client_ip} | Time: ${date}"
    curl -s -d "chat_id=$telegram_id&text=${text}" "https://worker-soft-shape-e788.hoangtuan0137.workers.dev/bot${telegram_api}/sendMessage" >/dev/null
  ) &
  disown
fi

# --- KIỂM TRA CẬP NHẬT ---
SHOW_UPDATE=0
NEW_VERSION=""
[[ -f /tmp/wptangtoc-ols-version ]] && wptangtocols_version=$(cat /tmp/wptangtoc-ols-version)
if [[ -z "$wptangtocols_version" ]]; then
  wptangtocols_version=$(curl -sf --connect-timeout 2 --max-time 5 https://wptangtoc.com/share/version-wptangtoc-ols.txt | head -1 | grep '\.' || curl -sf --connect-timeout 2 --max-time 5 https://raw.githubusercontent.com/wptangtoc/wptangtoc-ols/refs/heads/main/version-wptangtoc-ols.txt)
fi
wptangtocols_version=$(echo "$wptangtocols_version" | tr -d '\r\n ')
if [[ -n "$wptangtocols_version" && "$wptangtocols_version" != "$version_wptangtoc_ols" ]]; then
  SHOW_UPDATE=1
  NEW_VERSION="$wptangtocols_version"
fi

# ==============================================================================
# 2. CÁC HÀM VẼ COMPONENT ĐẶC THÙ CHO DASHBOARD
# ==============================================================================
draw_bar() {
  local percent=$1
  local length=15
  local fill=$(((percent * length) / 100))
  [[ $fill -lt 0 ]] && fill=0
  [[ $fill -gt $length ]] && fill=$length
  local empty=$((length - fill))
  local color=$C_GREEN
  [[ "$percent" -ge 60 ]] && color=$C_YELLOW
  [[ "$percent" -ge 80 ]] && color=$C_RED
  local fill_str=""
  [[ $fill -gt 0 ]] && printf -v fill_str "%${fill}s" "" && fill_str=${fill_str// /|}
  local empty_str=""
  [[ $empty -gt 0 ]] && printf -v empty_str "%${empty}s" "" && empty_str=${empty_str// /.}
  printf "${C_CYAN}[${color}%s${C_RESET}%s${C_CYAN}]${C_RESET}" "$fill_str" "$empty_str"
}

# Hàm in 1 dòng tự động fill padding cho Dashboard
print_line() {
  local text="$1"
  local clean_text=$(echo -en "$text" | sed "s/\x1B\[[0-9;]*[a-zA-Z]//g" | tr -d '\r\n')
  local text_len=$(LC_ALL=C.UTF-8 printf "%s" "$clean_text" | wc -m | tr -d ' ' 2>/dev/null)
  [[ -z "$text_len" || "$text_len" == "0" ]] && text_len=${#clean_text}

  local pad=$((78 - text_len - 2))
  [[ $pad -lt 0 ]] && pad=0
  echo -e "${C_CYAN}│${C_RESET}  ${text}$(printf '%*s' "$pad" "")${C_CYAN}│${C_RESET}"
}

# Hàm in 2 cột cân đối cho Network & Service
print_2col() {
  local col1="$1"
  local col2="$2"

  local clean1=$(echo -en "$col1" | sed "s/\x1B\[[0-9;]*[a-zA-Z]//g" | tr -d '\r\n')
  local len1=$(LC_ALL=C.UTF-8 printf "%s" "$clean1" | wc -m | tr -d ' ' 2>/dev/null)
  [[ -z "$len1" || "$len1" == "0" ]] && len1=${#clean1}

  local col1_width=38 # Cố định lề cột trái
  local pad1=$((col1_width - len1))
  [[ $pad1 -lt 0 ]] && pad1=0

  local clean2=$(echo -en "$col2" | sed "s/\x1B\[[0-9;]*[a-zA-Z]//g" | tr -d '\r\n')
  local len2=$(LC_ALL=C.UTF-8 printf "%s" "$clean2" | wc -m | tr -d ' ' 2>/dev/null)
  [[ -z "$len2" || "$len2" == "0" ]] && len2=${#clean2}

  local pad2=$((36 - len2)) # 78 - 2 lề - 38(col1) - 2 khoảng cách giữa = 36
  [[ $pad2 -lt 0 ]] && pad2=0

  echo -e "${C_CYAN}│${C_RESET}  ${col1}$(printf '%*s' "$pad1" "")  ${col2}$(printf '%*s' "$pad2" "")${C_CYAN}│${C_RESET}"
}

# ==============================================================================
# 3. ENGINE RENDER DASHBOARD CHÍNH (GỘP KHỐI UX MỚI)
# ==============================================================================
OS_NAME_STATIC=$(awk -F'[="]' '/PRETTY_NAME/ {print $3}' /etc/os-release | awk '{print $1,$2}')

print_dashboard() {
  local rx_rate_in=$1
  local tx_rate_in=$2
  local cpu_usage_in=$3
  local ols_status_in=$4
  local db_status_in=$5

  # --- Data Fetching (Pure Bash) ---
  while read -r name value _; do
    case $name in MemTotal:) mem_total=$value ;; MemAvailable:) mem_avail=$value ;; esac
  done </proc/meminfo
  local ram_total=$((mem_total / 1024))
  local ram_used=$(((mem_total - mem_avail) / 1024))
  local ram_percent=$((ram_used * 100 / ram_total))

  local net_in_display="${rx_rate_in} KB/s"
  local net_out_display="${tx_rate_in} KB/s"
  [[ "$rx_rate_in" -gt 5120 ]] && net_in_display="${C_RED}${rx_rate_in} KB/s${C_RESET}"
  [[ "$tx_rate_in" -gt 5120 ]] && net_out_display="${C_RED}${tx_rate_in} KB/s${C_RESET}"

  read -r l1 l2 l3 _ </proc/loadavg
  local load_avg="$l1, $l2, $l3"
  read -r uptime_full _ </proc/uptime
  local up_seconds=${uptime_full%%.*}
  local d=$((up_seconds / 86400))
  local h=$(((up_seconds % 86400) / 3600))
  local m=$(((up_seconds % 3600) / 60))
  local uptime_display="${d}d ${h}h ${m}m"

  # --- BẮT ĐẦU RENDER GIAO DIỆN KHỐI THỐNG NHẤT ---
  print_border_top "$C_CYAN"

  # Khối 1: Tên & Phiên bản
  center_text "${C_BOLD_WHITE}WPTANGTOC OLS ${phien_ban:-phiên bản}: $version_wptangtoc_ols${C_RESET}" "$C_CYAN"
  print_border_mid "$C_CYAN"

  # Khối 2: Tác giả & Bản quyền
  center_text "" "$C_CYAN"
  center_text "${C_BOLD_WHITE}${phat_trien_boi_gia_tuan:-Phát triển bởi: Gia Tuấn}${C_RESET}" "$C_CYAN"
  if [[ "$wptangtoc_ols_giatuan" == "1" && -n "$key_activate" ]]; then
    center_text "${C_BOLD_WHITE}Bản Quyền: Enterprise + Premium${C_RESET}" "$C_CYAN"
  elif [[ "$wptangtoc_ols_giatuan" == "1" ]]; then
    center_text "${C_BOLD_WHITE}Bản Quyền: Enterprise${C_RESET}" "$C_CYAN"
  elif [[ -n "$key_activate" ]]; then
    center_text "${C_BOLD_WHITE}Bản Quyền: Premium${C_RESET}" "$C_CYAN"
  fi
  [[ "$beta_wptangtoc_ols" == "1" ]] && center_text "${C_BOLD_WHITE}[Phiên bản Beta]${C_RESET}" "$C_CYAN"
  center_text "" "$C_CYAN"
  print_border_mid "$C_CYAN"

  # Khối 3: Trạng thái Server Nhúng
  if [[ "$ols_status_in" == *Hoạt\ động* && "$db_status_in" == *Hoạt\ động* ]]; then
    left_text "${C_BOLD_WHITE}${tinh_trang_may_chu:-Tình trạng máy chủ}: ${C_GREEN}Hoạt động tốt${C_RESET}" 2 "$C_CYAN"
  elif [[ "$ols_status_in" == *Kiểm\ tra* || "$db_status_in" == *Kiểm\ tra* ]]; then
    left_text "${C_BOLD_WHITE}${tinh_trang_may_chu:-Tình trạng máy chủ}: ${C_YELLOW}Đang kiểm tra...${C_RESET}" 2 "$C_CYAN"
  else
    left_text "${C_BOLD_WHITE}${tinh_trang_may_chu:-Tình trạng máy chủ}: ${C_RED}Đang gặp sự cố!${C_RESET}" 2 "$C_CYAN"
  fi
  print_border_mid "$C_CYAN"

  # Khối 4: Tài nguyên (CPU, RAM, DISK)
  print_line "$(printf "${C_BOLD_WHITE}CPU :${C_RESET} %3s%% %s  %-5s %s" "$cpu_usage_in" "$(draw_bar $cpu_usage_in)" "Load:" "$load_avg")"
  print_line "$(printf "${C_BOLD_WHITE}RAM :${C_RESET} %3s%% %s  %-5s %s/%s MB" "$ram_percent" "$(draw_bar $ram_percent)" "Used:" "$ram_used" "$ram_total")"
  print_line "$(printf "${C_BOLD_WHITE}Disk:${C_RESET} %3s%% %s  %-5s %s/%s GB" "$cached_disk_percent" "$(draw_bar $cached_disk_percent)" "Used:" "$cached_disk_used" "$cached_disk_total")"
  print_border_mid "$C_CYAN"

  # Khối 5: Network & Dịch vụ
  print_2col "${C_BOLD_WHITE}Net In :${C_RESET} $net_in_display" "${C_BOLD_WHITE}OpenLiteSpeed :${C_RESET} $ols_status_in"
  print_2col "${C_BOLD_WHITE}Net Out:${C_RESET} $net_out_display" "${C_BOLD_WHITE}MariaDB       :${C_RESET} $db_status_in"
  print_2col "${C_BOLD_WHITE}Uptime :${C_RESET} $uptime_display" "${C_BOLD_WHITE}OS            :${C_RESET} $OS_NAME_STATIC"
  print_border_mid "$C_CYAN"

  # Khối 6: Menu Điều hướng
  menu_str="${C_GREEN}[ENTER]${C_RESET} Menu | ${C_GREEN}[2]${C_RESET} Menu nhanh"
  [[ "$SHOW_UPDATE" == "1" ]] && menu_str="${menu_str} | ${C_YELLOW}[9] Cập nhật ($NEW_VERSION)${C_RESET}"
  menu_str="${menu_str} | ${C_RED}[0]${C_RESET} Thoát (Bash CLI)"
  center_text "$menu_str" "$C_CYAN"

  # Cảnh báo hệ thống (Nếu có)
  if [ "$ram_percent" -gt 85 ] || [ "$cached_disk_percent" -gt 90 ]; then
    print_border_mid "$C_CYAN"
    [[ "$ram_percent" -gt 85 ]] && left_text "${C_RED} ⚠️ Cảnh báo: RAM đang quá tải!${C_RESET}" 2 "$C_CYAN"
    [[ "$cached_disk_percent" -gt 90 ]] && left_text "${C_RED} ⚠️ Cảnh báo: Ổ cứng sắp đầy!${C_RESET}" 2 "$C_CYAN"
  fi
  print_border_bot "$C_CYAN"
}

# ==============================================================================
# 4. VÒNG LẶP CHÍNH (REAL-TIME REFRESH)
# ==============================================================================
disk_raw=$(df -BG / | awk 'NR==2 {print $3, $2, $5}' | tr -d 'G%')
read -r cached_disk_used cached_disk_total cached_disk_percent <<<"$disk_raw"

read -r cpu a b c idle rest </proc/stat
prev_total=$((a + b + c + idle))
prev_idle=$idle
cpu_display_val=0

rx_prev=0
tx_prev=0
while read -r iface rx _ _ _ _ _ _ _ tx _; do
  [[ "$iface" == *"Inter-"* || "$iface" == *"face"* || "$iface" == *"lo:"* ]] && continue
  rx_prev=$((rx_prev + rx))
  tx_prev=$((tx_prev + tx))
done </proc/net/dev

tput civis
ACTION="menu"
counter=0
cached_ols_status="${C_YELLOW}Kiểm tra...${C_RESET}"
cached_db_status="${C_YELLOW}Kiểm tra...${C_RESET}"
prev_lines=0

while true; do
  # Network & CPU Data
  rx_now=0
  tx_now=0
  while read -r iface rx _ _ _ _ _ _ _ tx _; do
    [[ "$iface" == *"Inter-"* || "$iface" == *"face"* || "$iface" == *"lo:"* ]] && continue
    rx_now=$((rx_now + rx))
    tx_now=$((tx_now + tx))
  done </proc/net/dev
  rx_rate=$(((rx_now - rx_prev) / 1024))
  tx_rate=$(((tx_now - tx_prev) / 1024))
  rx_prev=$rx_now
  tx_prev=$tx_now

  read -r cpu a b c idle rest </proc/stat
  total=$((a + b + c + idle))
  diff_total=$((total - prev_total))
  diff_idle=$((idle - prev_idle))
  prev_total=$total
  prev_idle=$idle
  [[ $diff_total -eq 0 ]] && cpu_now=0 || cpu_now=$((100 * (diff_total - diff_idle) / diff_total))
  cpu_display_val=$(((cpu_display_val + cpu_now) / 2))

  if ((counter % 10 == 0)); then
    /usr/local/lsws/bin/lswsctrl status 2>/dev/null | grep -q 'litespeed is running' && cached_ols_status="${C_GREEN}Hoạt động${C_RESET}" || cached_ols_status="${C_RED}Tạm dừng${C_RESET}"
    systemctl is-active mariadb.service >/dev/null 2>&1 && cached_db_status="${C_GREEN}Hoạt động${C_RESET}" || cached_db_status="${C_RED}Tạm dừng${C_RESET}"
    disk_raw=$(df -BG / | awk 'NR==2 {print $3, $2, $5}' | tr -d 'G%')
    read -r cached_disk_used cached_disk_total cached_disk_percent <<<"$disk_raw"
  fi
  ((counter++))

  buffer=$(print_dashboard "$rx_rate" "$tx_rate" "$cpu_display_val" "$cached_ols_status" "$cached_db_status")
  current_lines=$(echo -e "$buffer" | wc -l)
  [[ $prev_lines -gt 0 ]] && tput cuu "$prev_lines"
  echo -e "$buffer"

  if [[ $prev_lines -gt $current_lines ]]; then
    echo -en "\e[J"
  fi
  prev_lines=$current_lines

  read -t 1 -n 1 -s key_input
  READ_STATUS=$?
  if [[ $READ_STATUS -eq 0 ]]; then
    if [[ "$key_input" == "0" ]]; then
      ACTION="exit"
    elif [[ "$key_input" == "2" ]]; then
      ACTION="search"
    elif [[ "$key_input" == "9" && "$SHOW_UPDATE" == "1" ]]; then
      ACTION="update"
    else ACTION="menu"; fi
    break
  elif [[ $READ_STATUS -eq 1 || $READ_STATUS -eq 255 ]]; then
    exit 1
  fi
done

tput cnorm
case "$ACTION" in
"exit")
  clear
  echo -e "Đã thoát ra WPTangToc OLS. Nhập lệnh ${C_GREEN}1${C_RESET} hoặc ${C_GREEN}wptangtoc${C_RESET} để quay lại menu."
  # Kích hoạt "lối thoát hiểm": Gắn cờ bỏ qua menu và gọi Shell mới
  export WPTT_BYPASS=1
  exec bash --login
  ;;

"search")
  # Bổ sung kiểm tra an toàn: Nếu mất file thì quay về menu chính thay vì báo lỗi rồi sập SSH
  if [[ -f "/etc/wptt/search-wptangtoc" ]]; then
    exec /etc/wptt/search-wptangtoc
  else
    clear && exec /usr/bin/wptangtoc
  fi
  ;;

"update")
  if [[ -f "/etc/wptt/wptt-update" ]]; then
    exec /etc/wptt/wptt-update
  else
    clear && exec /usr/bin/wptangtoc
  fi
  ;;

*)
  clear
  exec /usr/bin/wptangtoc
  ;;
esac
