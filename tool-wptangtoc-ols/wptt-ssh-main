function huong_dan() {
  Tính năng Quản lý SSH trong WPTangToc OLS là một công cụ giúp bạn cấu hình và tăng cường bảo mật cho dịch vụ SSH [Secure Shell] trên máy chủ của mình một cách thuận tiện. 🔐

  Giới thiệu ngắn gọn:

  Mục đích: Đơn giản hóa việc thay đổi các cài đặt SSH phổ biến để bảo vệ máy chủ khỏi các truy cập trái phép và làm cho việc quản trị qua SSH an toàn hơn.
  Cách hoạt động:
  * Thay đổi cổng SSH: Đổi cổng SSH mặc định [22] sang một cổng khác để giảm thiểu các cuộc tấn công tự động.
  * Tắt/Bật đăng nhập của root: Vô hiệu hóa quyền đăng nhập trực tiếp của người dùng root qua SSH.
  * Thay đổi mật khẩu username.
  * v.v.v

  Lợi ích:
  * Nâng cao bảo mật: Giảm bề mặt tấn công cho máy chủ.
  * Quản lý tiện lợi: Dễ dàng thực hiện các thay đổi cấu hình SSH quan trọng mà không cần sửa file thủ công.
  * Tuân thủ thực hành tốt nhất: Hỗ trợ người dùng áp dụng các khuyến nghị bảo mật cho SSH.

  Tính năng này giúp bạn củng cố một trong những cửa ngõ quan trọng nhất vào máy chủ của mình, đảm bảo an toàn cho hệ thống.
}

if [[ -z "$1" ]]; then
  . /etc/wptt/wptt-header-menu
  header_menu
else
  . /etc/wptt/echo-color 2>/dev/null
  echoDo "=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-="
fi

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null

echo ""
echo "$quan_ly_ssh:" > /dev/null # Để wptt-search tổng vẫn bắt được danh mục

# ==============================================================================
# 2. KHAI BÁO TIÊU ĐỀ MENU VÀ OPTIONS (ĐÃ SẮP XẾP LẠI UX)
# ==============================================================================
MENU_TITLE="TRUNG TÂM QUẢN LÝ SSH (SECURE SHELL)"

options=(
  # --- CỘT TRÁI: CẤU HÌNH CƠ BẢN ---
  "$thay_doi_password_ssh"                                   #0 (Hiển thị: 1)
  "$thay_doi_port_ssh"                                       #1 (Hiển thị: 2)
  "${thoi_gian_timeout_ssh:-Thay đổi thời gian timeout ssh}" #2 (Hiển thị: 3)

  # --- CỘT PHẢI: BẢO MẬT & TRUY CẬP ---
  "$thiet_lap_canh_bao_login_ssh_qua_telegram"               #3 (Hiển thị: 4)
  "$bat_tat_dang_nhap_username_rieng_domain"                 #4 (Hiển thị: 5)
)

# ==============================================================================
# 3. LOGIC XỬ LÝ (ÁNH XẠ CHUẨN VỚI INDEX MỚI)
# ==============================================================================
run_action() {
  local index=$1
  local script_path=""
  local script_args="98" # Mặc định là 98 cho hầu hết

  case $index in
  0) script_path="/etc/wptt/ssh/wptt-passwd" ;;
  1) script_path="/etc/wptt/ssh/wptt-ssh-port" ;;
  2) script_path="/etc/wptt/ssh/wptt-set-timeout-ssh" ;;
  
  3) 
     script_path="/etc/wptt/bao-mat/thong-bao-login-ssh" 
     script_args="ssh" # Đặc thù riêng của tính năng Telegram
     ;;
  4) script_path="/etc/wptt/domain/wptt-khoi-tao-user" ;;
  esac

  if [[ -x "$script_path" || -f "$script_path" ]]; then
    exec bash "$script_path" "$script_args"
  else
    echo -e "\n\033[1;31m[!] Lỗi: Không tìm thấy tệp '$script_path'.\033[0m"
    sleep 2
    exec /etc/wptt/wptt-ssh-main 1
  fi
}

# ==============================================================================
# 4. GIAO DIỆN TÙY CHỈNH (CĂN CHỈNH SỐ THỨ TỰ TUẦN TỰ)
# ==============================================================================
draw_custom_grid() {
  print_row "" "CẤU HÌNH CƠ BẢN SSH" "" "BẢO MẬT & TRUY CẬP"
  print_row "1" "${options[0]}" "4" "${options[3]}"
  print_row "2" "${options[1]}" "5" "${options[4]}"
  print_row "3" "${options[2]}" ""  ""
}

