#!/bin/bash
# @author: Gia Tuấn
# @website: https://wptangtoc.com
# @since: 2026

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null

unset thu ngay_cua_thang

function tuan() {
  local options=()
  local box_inner_width=${box_inner_width:-71}

  if [[ "$ngon_ngu" == 'vi' ]]; then
    options=("Mỗi Thứ hai" "Mỗi Thứ ba" "Mỗi Thứ tư" "Mỗi Thứ năm" "Mỗi Thứ sáu" "Mỗi Thứ bảy" "Mỗi Chủ nhật" "Hàng ngày" "Hàng tháng")
  else
    options=("Monday" "Tuesday" "Wednesday" "Thursday" "Friday" "Saturday" "Sunday" "Daily / Everyday" "Monthly")
  fi

  echo ""
  echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"

  # Tiêu đề
  local title_text="Lựa chọn Chu kỳ Thời gian (Schedule):"
  local len=$(echo -n "$title_text" | awk '{print length($0)}')
  local pad_r=$((box_inner_width - len - 2))
  [[ $pad_r -lt 0 ]] && pad_r=0
  echo -e "${C_CYAN}│${C_RESET}  ${C_YELLOW}${title_text}${C_RESET}$(printf '%*s' "$pad_r" "")${C_CYAN}│${C_RESET}"

  # Kẻ gạch chân
  local line_len=$((len + 3))
  local pad_line_r=$((box_inner_width - line_len))
  [[ $pad_line_r -lt 0 ]] && pad_line_r=0
  local short_line=$(printf "%${line_len}s" "" | sed 's/ /─/g')
  echo -e "${C_CYAN}├${short_line}$(printf '%*s' "$pad_line_r" "")│${C_RESET}"

  # In danh sách tùy chọn
  local i=1
  for opt in "${options[@]}"; do
    local item_text=$(printf "  ${C_CYAN}%d)${C_RESET} ${C_BOLD_WHITE}%s${C_RESET}" "$i" "$opt")
    local clean_text=$(printf "  %d) %s" "$i" "$opt")
    local item_len=$(echo -n "$clean_text" | awk '{print length($0)}')
    local pad=$((box_inner_width - item_len))
    [[ $pad -lt 0 ]] && pad=0
    echo -e "${C_CYAN}│${C_RESET}${item_text}$(printf '%*s' "$pad" "")${C_CYAN}│${C_RESET}"
    ((i++))
  done
  echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯${C_RESET}"

  # Vòng lặp lấy Input chính
  while true; do
    local prompt_text="${nhap_lua_chon_cua_ban:-Nhập lựa chọn của bạn} [1-9]: "
    echo -en "${C_CYAN}${prompt_text}${C_RESET}"
    read -r REPLY

    if [[ ! "$REPLY" =~ ^[1-9]$ ]]; then
      echo -e "${C_RED}❌ Lựa chọn không hợp lệ! Vui lòng nhập số từ 1 đến 9.${C_RESET}"
      continue
    fi

    case "$REPLY" in
    1)
      thu="1"
      break
      ;;
    2)
      thu="2"
      break
      ;;
    3)
      thu="3"
      break
      ;;
    4)
      thu="4"
      break
      ;;
    5)
      thu="5"
      break
      ;;
    6)
      thu="6"
      break
      ;;
    7)
      thu="0"
      break
      ;; # Chủ nhật trong cronjob đánh số là 0
    8)
      thu="*"
      break
      ;; # Dấu * đại diện cho hàng ngày
    9)
      thu="9"
      break
      ;; # Ký hiệu riêng để nhảy sang hỏi Ngày
    esac
  done

  # Nếu chọn hàng tháng (9) -> Hỏi thêm ngày
  if [[ "$thu" == '9' ]]; then
    echo ""
    while true; do
      echo -en "${C_CYAN}Nhập ngày chạy trong tháng [1-31]: ${C_RESET}"
      read -r ngay_cua_thang

      if [[ ! "$ngay_cua_thang" =~ ^[0-9]+$ ]] || ((ngay_cua_thang < 1 || ngay_cua_thang > 31)); then
        echo -e "${C_RED}Ngày không đúng định dạng! Vui lòng nhập từ 1 đến 31.${C_RESET}"
      else
        break
      fi
    done
  fi
}
