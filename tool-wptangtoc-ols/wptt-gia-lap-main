function huong_dan() {
  tính năng giả lập website giúp tạo ra một phiên bản mô phỏng của website thật hoặc một phần của nó để thử nghiệm, xem trước hoặc trình bày ý tưởng mà không cần can thiệp vào website đang hoạt động hoặc trước khi bắt đầu xây dựng hoàn chỉnh.

  Mục đích: Tạo ra một bản sao của website chính [website đang hoạt động] trên một môi trường riêng biệt [trên cùng server].

  Tính năng chính:
  * Thử nghiệm thay đổi: Cho phép nhà phát triển, nhà thiết kế hoặc người quản trị web thử nghiệm các thay đổi về mã nguồn, giao diện, plugin, cập nhật phiên bản phần mềm mà không ảnh hưởng đến website thật đang chạy.
  * Phát hiện lỗi: Giúp tìm và sửa lỗi trước khi triển khai lên môi trường thật.
  * Đào tạo: Dùng để hướng dẫn người dùng mới cách quản trị website.
  * Lợi ích: An toàn, giảm thiểu rủi ro khi cập nhật hoặc thay đổi website. Các công cụ quản lý hosting hoặc các plugin WordPress [như WP Staging, Duplicator] thường có tính năng này.
}

if [[ -z "$1" ]]; then
  . /etc/wptt/wptt-header-menu
  header_menu
else
  . /etc/wptt/echo-color 2>/dev/null
  echoDo "────────────────────────────────────────────────────────────────────────────────"
fi

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null

echo ""
echo "$gia_lap_website:" > /dev/null # Để wptt-search tổng vẫn bắt được danh mục

# ==============================================================================
# 2. KHAI BÁO TIÊU ĐỀ MENU VÀ OPTIONS
# ==============================================================================
MENU_TITLE="TRUNG TÂM QUẢN LÝ MÔI TRƯỜNG GIẢ LẬP (STAGING)"

options=(
  "$gia_lap_website_tu_website_nao_do_trong_he_thong" #0
  "$gia_lap_website_moi_trang"                        #1
  "$chuyen_web_site_gia_lap_ve_website_chinh"         #2
)

# ==============================================================================
# 3. LOGIC XỬ LÝ (ÁNH XẠ CHUẨN VỚI INDEX)
# ==============================================================================
run_action() {
  local index=$1
  local script_path=""
  local script_args="98"

  case $index in
  0) script_path="/etc/wptt/gia-lap-website/gia-lap-website-co-du-lieu" ;;
  1) script_path="/etc/wptt/gia-lap-website/gia-lap-website-wordpress-moi-hoan-toan" ;;
  2) script_path="/etc/wptt/gia-lap-website/gia-lap-website-dua-vao-website-chinh" ;;
  esac

  if [[ -x "$script_path" || -f "$script_path" ]]; then
    exec bash "$script_path" "$script_args"
  else
    echo -e "\n\033[1;31m[!] Lỗi: Không tìm thấy hoặc không thể thực thi script '$script_path'.\033[0m"
    sleep 2
    exec /etc/wptt/wptt-gia-lap-main 1
  fi
}

# ==============================================================================
# 4. GIAO DIỆN TÙY CHỈNH (CĂN CHỈNH 1 CỘT PHÂN NHÓM CHUẨN UX)
# ==============================================================================
draw_custom_grid() {
  # --- NHÓM 1: KHỞI TẠO MÔI TRƯỜNG ---
  print_full_row "" "KHỞI TẠO MÔI TRƯỜNG (STAGING)"
  print_full_row "1" "${options[0]}"
  print_full_row "2" "${options[1]}"

  print_spacer
  # --- NHÓM 2: TRIỂN KHAI & ĐỒNG BỘ ---
  print_full_row "" "TRIỂN KHAI VÀ ĐỒNG BỘ (PRODUCTION)"
  print_full_row "3" "${options[2]}"
}

# ==============================================================================
# 5. KÍCH HOẠT THƯ VIỆN UI ENGINE CHẠY
# ==============================================================================
. /etc/wptt/wptt-callback-menu-chon
