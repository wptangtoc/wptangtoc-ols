# ==============================================================================
# 3. LOGIC XỬ LÝ (ÁNH XẠ CHUẨN 100% VỚI INDEX MỚI)
# ==============================================================================
run_action() {
  local index=$1
  local script_path=""
  local script_args="98"

  case $index in
  # Cột trái
  0) script_path="/etc/wptt/db/wptt-them-database" ;;
  1) script_path="/etc/wptt/db/wptt-xoa-database" ;;
  2) script_path="/etc/wptt/db/wptt-thongtin-db" ;;
  3) script_path="/etc/wptt/db/wptt-thongtin-db-tk" ;;
  4) script_path="/etc/wptt/db/wptt-dung-luong-database" ;;
  5) script_path="/etc/wptt/db/wptt-thay-doi-passwd-database" ;;
  6) script_path="/etc/wptt/db/wptt-ket-noi" ;;
  7) script_path="/etc/wptt/db/wptt-saoluu-database" ;;
  8) script_path="/etc/wptt/db/wptt-nhapdatabase" ;;

  # Cột phải
  9) script_path="/etc/wptt/wordpress/all-database" ;;
  10) script_path="/etc/wptt/db/wptt-tu-dong-hoa-toi-uu-database" ;;
  11) script_path="/etc/wptt/wordpress/all-database-sua-chua" ;;
  12) script_path="/etc/wptt/db/wptt-wipe-database" ;;
  13) script_path="/etc/wptt/db/wptt-remote-database" ;;
  14) script_path="/etc/wptt/db/wptt-force-restart-mariadb" ;;
  15) script_path="/etc/wptt/db/wptt-thay-doi-phien-ban-mariadb" ;;
  16) script_path="/etc/wptt/db/wptt-rebuild-mariadb" ;;
  17) script_path="/etc/wptt/db/cli-mysql-thuc-thi" ;;

  # Khối 1 cột chuyển đổi
  18) script_path="/etc/wptt/backup-restore/wptt-sql-gzip-config" ;;
  19) script_path="/etc/wptt/db/chuyen-doi-dinh-dang-luu-tru-storage-engine-innodb-myisam-aria" ;;
  esac

  if [[ -x "$script_path" || -f "$script_path" ]]; then
    bash "$script_path" "$script_args" # Đổi exec thành bash để giữ menu an toàn
  else
    echo -e "\n\033[1;31m[!] Lỗi: Không tìm thấy script '$script_path'.\033[0m"
    sleep 2
    bash /etc/wptt/wptt-db-main 1
  fi
}

