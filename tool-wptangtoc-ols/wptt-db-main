# ==============================================================================
# 3. LOGIC XỬ LÝ (ÁNH XẠ CHUẨN 100% VỚI INDEX MỚI)
# ==============================================================================
run_action() {
  local index=$1
  local script_path=""
  local script_args="98"

  case $index in
  0) script_path="/etc/wptt/db/wptt-them-database" ;;
  1) script_path="/etc/wptt/db/wptt-xoa-database" ;;
  2) script_path="/etc/wptt/db/wptt-thongtin-db" ;;
  3) script_path="/etc/wptt/db/wptt-thongtin-db-tk" ;;
  4) script_path="/etc/wptt/db/wptt-dung-luong-database" ;;
  5) script_path="/etc/wptt/db/wptt-thay-doi-passwd-database" ;;
  6) script_path="/etc/wptt/db/wptt-ket-noi" ;;
  7) script_path="/etc/wptt/db/wptt-saoluu-database" ;;
  8) script_path="/etc/wptt/db/wptt-nhapdatabase" ;;
  9) script_path="/etc/wptt/backup-restore/wptt-sql-gzip-config" ;;
  
  10) script_path="/etc/wptt/wordpress/all-database" ;;
  11) script_path="/etc/wptt/db/wptt-tu-dong-hoa-toi-uu-database" ;;
  12) script_path="/etc/wptt/wordpress/all-database-sua-chua" ;;
  13) script_path="/etc/wptt/db/wptt-wipe-database" ;;
  14) script_path="/etc/wptt/db/chuyen-doi-dinh-dang-luu-tru-storage-engine-innodb-myisam-aria" ;;
  15) script_path="/etc/wptt/db/wptt-remote-database" ;;
  16) script_path="/etc/wptt/db/wptt-auto-restart-mysql" ;;
  17) script_path="/etc/wptt/db/wptt-thay-doi-phien-ban-mariadb" ;;
  18) script_path="/etc/wptt/db/wptt-rebuild-mariadb" ;;
  19) script_path="/etc/wptt/db/cli-mysql-thuc-thi" ;;
  esac

  if [[ -x "$script_path" || -f "$script_path" ]]; then
    exec bash "$script_path" "$script_args"
  else
    echo -e "\n\033[1;31m[!] Lỗi: Không tìm thấy script '$script_path'.\033[0m"
    sleep 2
    exec /etc/wptt/wptt-db-main 1
  fi
}

