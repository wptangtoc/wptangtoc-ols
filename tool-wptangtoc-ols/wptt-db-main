# ==============================================================================
MENU_TITLE="TRUNG TÂM QUẢN LÝ DATABASE (MARIADB)"

options=(
  # --- CỘT TRÁI (1-9): QUẢN TRỊ & KẾT NỐI SAO LƯU ---
  "$them_database"                  #0  (Hiển thị: 1)
  "$xoa_database"                   #1  (Hiển thị: 2)
  "$danh_sach_database"             #2  (Hiển thị: 3)
  "$thong_tin_tai_khoan_database"   #3  (Hiển thị: 4)
  "$xem_dung_luong_database"        #4  (Hiển thị: 5)
  "$thay_doi_password_database"     #5  (Hiển thị: 6)
  "$ket_noi_database_voi_wordpress" #6  (Hiển thị: 7)
  "$sao_luu_database"               #7  (Hiển thị: 8)
  "$khoi_phuc_database"             #8  (Hiển thị: 9)

  # --- CỘT PHẢI (10-18): TỐI ƯU & HỆ THỐNG MARIADB ---
  "$toi_uu_database_all"               #9  (Hiển thị: 10)
  "$thiet_lap_tu_dong_toi_uu_database" #10 (Hiển thị: 11)
  "$sua_chua_database"                 #11 (Hiển thị: 12)
  "$xoa_toan_bo_du_lieu_database"      #12 (Hiển thị: 13)
