  "Force Restart MariaDB"              #14 (Hiển thị: 15)
  "$thay_phien_ban_mariadb"            #15 (Hiển thị: 16)
  "$cai_lai_mariadb"                   #16 (Hiển thị: 17)
  "Thực thi MariaDB CLI"               #17 (Hiển thị: 18)

  # --- KHỐI FULL 1 CỘT BÊN DƯỚI (19-20): CHUYỂN ĐỔI ĐỊNH DẠNG ---
  "$chuyen_doi_dinh_dang_sao_luu_database" #18 (Hiển thị: 19)
