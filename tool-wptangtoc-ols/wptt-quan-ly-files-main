#!/bin/bash

function huong_dan() {
  WPTangToc OLS cung cấp tính năng quản lý file [File Manager], cho phép người dùng thực hiện các thao tác với tập tin và thư mục trực tiếp trên trình duyệt web.

  Tính năng quản lý file này thường được tích hợp sẵn, dựa trên các giải pháp gọn nhẹ như Tiny File Manager. Nó giúp bạn:
  * Duyệt, xem, tải lên [upload] và tải xuống [download] các tệp tin trong thư mục mã nguồn website của bạn.
  * Tạo mới, xóa, đổi tên, sao chép, di chuyển các tệp tin và thư mục.
  * Chỉnh sửa các tệp tin văn bản trực tiếp.
  * Nén và giải nén các tệp tin [thường là định dạng .zip].

  WPTangToc OLS quản lý filemanager:
  * bật filemanager
  * tắt filemanager
  * thay đổi tài khoản filemanager
  * xem lại tài khoản filemanager

  Mặc dù tiện lợi cho các thao tác nhanh, quản lý file tích hợp trong WPTangToc OLS có thể tập trung chủ yếu vào việc quản lý mã nguồn website.

  Tuy nhiên, đây là một công cụ hữu ích để quản lý website một cách trực quan mà không cần dùng đến các dòng lệnh phức tạp.
}

if [[ -z "$1" ]]; then
  . /etc/wptt/wptt-header-menu
  header_menu
else
  clear
  . /etc/wptt/echo-color 2>/dev/null
  echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
  
  # Hàm ẩn cục bộ để vẽ tiêu đề phụ nếu không dùng Header Menu
  center_tmp() {
    local text="$1"
    local clean_len=$(echo -en "$text" | sed "s/\x1B\[[0-9;]*[a-zA-Z]//g" | tr -d '\r\n' | wc -m | tr -d ' ')
    [[ -z "$clean_len" || "$clean_len" == "0" ]] && clean_len=${#text}
    local pad_left=$(((78 - clean_len) / 2))
    local pad_right=$((78 - clean_len - pad_left))
    printf "${C_CYAN}│${C_RESET}%*s%b%*s${C_CYAN}│${C_RESET}\n" "$pad_left" "" "$text" "$pad_right" ""
  }
  
  center_tmp "${C_YELLOW}TRÌNH QUẢN LÝ FILE MANAGER${C_RESET}"
  echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯${C_RESET}"
fi

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null

echo ""
echo "$quan_ly_file_manager:" > /dev/null # Dữ liệu ẩn cho bộ tìm kiếm

# ==============================================================================
# TẠO MENU 2 CỘT (TRÁI: TRẠNG THÁI | PHẢI: BẢO MẬT & TÀI KHOẢN)
# ==============================================================================
MENU_TITLE="TRUNG TÂM QUẢN LÝ FILE MANAGER"

options=(
  # --- CỘT TRÁI ---
  "$bat File Manager"                                    # 0 (Hiện: 1)
  "$tat File Manager"                                    # 1 (Hiện: 2)
  
  # --- CỘT PHẢI ---
  "$thay_doi ID & PassWord $bao_mat"                     # 2 (Hiện: 3)
  "$xem_lai_thong_tin_tai_khoan_webguiadmin"             # 3 (Hiện: 4)
)

# Hàm thực thi hành động
run_action() {
  local index=$1
  local script_path=""
  local script_args="98"

  case $index in
  0) script_path="/etc/wptt/trinh-quan-ly-files/kich-hoat-quan-ly-files" ;;
  1) script_path="/etc/wptt/trinh-quan-ly-files/huy-kich-hoat-quan-ly-files" ;;
  2) script_path="/etc/wptt/trinh-quan-ly-files/thay-doi-tai-khoan-password-quan-ly-files" ;;
  3) script_path="/etc/wptt/trinh-quan-ly-files/xem-lai-thong-tin-quan-ly-files" ;;
  *)
    echo -e "\n${C_RED}[!] ${lua_chon_khong_hop_le:-Lựa chọn không hợp lệ}.${C_RESET}"
    return 1
    ;;
  esac

  if [[ -x "$script_path" || -f "$script_path" ]]; then
    exec bash "$script_path" "$script_args"
  else
    echo -e "\n${C_RED}[!] Lỗi: Không tìm thấy kịch bản '$script_path'.${C_RESET}"
    sleep 2
    exec /etc/wptt/wptt-quan-ly-files-main 1
  fi
}

# ==============================================================================
# GHI ĐÈ BỐ CỤC 2 CỘT CHUẨN UX
# ==============================================================================
draw_custom_grid() {
  print_row "" "TRẠNG THÁI DỊCH VỤ" "" "TÀI KHOẢN & BẢO MẬT"
  print_row "1" "${options[0]}" "3" "${options[2]}"
  print_row "2" "${options[1]}" "4" "${options[3]}"
}

# Kích hoạt Engine Menu
. /etc/wptt/wptt-callback-menu-chon
