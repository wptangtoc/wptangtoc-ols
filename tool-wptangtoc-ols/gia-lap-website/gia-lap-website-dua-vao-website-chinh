#!/bin/bash

function huong_dan() {
  Đưa website giả lập vào website chính product thực chất là quá trình triển khai [deployment] một website từ môi trường phát triển/thử nghiệm [giả lập] lên môi trường hoạt động thực tế cho người dùng cuối [production].
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null # Nạp thư viện UX Bo Cong

clear
echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}GIẢ LẬP WEBSITE ➜ Đưa Dữ Liệu Từ Bản Nháp Lên Website Chính${C_RESET}"
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

if [[ "${1:-}" == '98' ]]; then
  WPTT_IN_MENU="yes"
  WPTT_MENU_BACK="/etc/wptt/wptt-gia-lap-main 1"
fi

wptt_check_mariadb || wptt_die "MariaDB đang bị sập! Hệ thống từ chối triển khai website."
wptt_check_lsws || wptt_die "OpenLiteSpeed đang bị sập! Hệ thống từ chối triển khai website."

function lua_chon_gia_lap() {
  unset NAME selects
  selects=()
  local box_inner_width=${box_inner_width:-71}

  if [ "$(ls -At /etc/wptt/vhost 2>/dev/null)" ]; then
    for entry in $(ls -A /etc/wptt/vhost | grep -v '^\.\.conf$' | sort -uV); do
      local dom=$(echo "$entry" | sed 's/^\.//' | sed 's/\.conf$//')
      # Lọc các domain CÓ cờ domain_gia_lap=1 HOẶC có đuôi .wptangtoc-ols.com
      if [[ "$dom" == ?*.?* ]]; then
        if grep -q "domain_gia_lap=1" "/etc/wptt/vhost/.$dom.conf" 2>/dev/null || [[ "$dom" == *".wptangtoc-ols.com" ]]; then
          selects+=("$dom")
        fi
      fi
    done
  fi

  if [[ ${#selects[@]} -eq 0 ]]; then
    echo -e "${C_YELLOW}⚠️ Hệ thống không tìm thấy tên miền Giả lập (Bản nháp) nào!${C_RESET}\n"
    sleep 3
    exec /etc/wptt/wptt-gia-lap-main 1
  fi

  echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
  local title_text="Bước 1: Chọn website GIẢ LẬP (Nguồn) cần đưa lên:"
  local len=$(echo -n "$title_text" | awk '{print length($0)}')
  local pad_r=$((box_inner_width - len - 2))
  [[ $pad_r -lt 0 ]] && pad_r=0
  echo -e "${C_CYAN}│${C_RESET}  ${C_YELLOW}${title_text}${C_RESET}$(printf '%*s' "$pad_r" "")${C_CYAN}│${C_RESET}"

  local line_len=$((len + 3))
  local pad_line_r=$((box_inner_width - line_len))
  [[ $pad_line_r -lt 0 ]] && pad_line_r=0
  local short_line=$(printf "%${line_len}s" "" | sed 's/ /─/g')
  echo -e "${C_CYAN}├${short_line}$(printf '%*s' "$pad_line_r" "")│${C_RESET}"

  local i=1
  for dom in "${selects[@]}"; do
    local item_text=$(printf "  ${C_CYAN}%3d)${C_RESET} ${C_BOLD_WHITE}%-30s${C_RESET} ${C_YELLOW}[Bản Nháp]${C_RESET}" "$i" "$dom")
    local clean_text=$(printf "  %3d) %-30s [Bản Nháp]" "$i" "$dom")
    local item_len=$(echo -n "$clean_text" | awk '{print length($0)}')
    local pad=$((box_inner_width - item_len))
    [[ $pad -lt 0 ]] && pad=0
    echo -e "${C_CYAN}│${C_RESET}${item_text}$(printf '%*s' "$pad" "")${C_CYAN}│${C_RESET}"
    ((i++))
  done
  echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯${C_RESET}"

  local fzf_installed=false
  if command -v fzf &>/dev/null; then
    fzf_installed=true
    PROMPT_TEXT="Nhập lựa chọn (1-${#selects[@]}) [00=Tìm nhanh] [0=Thoát]: "
  else
    PROMPT_TEXT="Nhập lựa chọn (1-${#selects[@]}) [0=Thoát]: "
  fi

  while true; do
    echo -en "${C_CYAN}${PROMPT_TEXT}${C_RESET}"
    if ! read -r REPLY; then exit 1; fi
    REPLY=$(echo "$REPLY" | tr -d ' ' | tr '[:upper:]' '[:lower:]')

    case "$REPLY" in
    0) echo -e "\n${C_GREEN}Đang thoát...${C_RESET}"; exec /etc/wptt/wptt-gia-lap-main 1 ;;
    00)
      if $fzf_installed; then
        local selected_item=$(printf '%s\n' "${selects[@]}" | nl -w 3 -s ': ' | fzf --prompt="Tìm web giả lập >> " --height=40% --border=rounded --color=border:yellow --cycle --reverse)
        local dom=$(echo "$selected_item" | sed 's/^[[:space:]]*[0-9]\+\:[[:space:]]*//' | cut -d'|' -f1 | tr -d ' ')
        if [[ -n "$dom" ]]; then NAME="$dom"; return 0; fi
      fi
      ;;
    *)
      if [[ "$REPLY" =~ ^[0-9]+$ ]] && [ "$REPLY" -ge 1 ] && [ "$REPLY" -le ${#selects[@]} ]; then
        NAME=$(echo "${selects[$((REPLY - 1))]}" | cut -d'|' -f1 | tr -d ' ')
        return 0
      else echo -e "\n${C_RED}❌ Lựa chọn không hợp lệ!${C_RESET}"; fi
      ;;
    esac
  done
}

lua_chon_gia_lap
website_gia_lap="$NAME"

# ==============================================================================
# BƯỚC 2: MENU CHỌN WEBSITE CHÍNH (Đích)
# ==============================================================================
echo ""
function lua_chon_chinh() {
  unset NAME selects
  selects=()
  local box_inner_width=${box_inner_width:-71}

  if [ "$(ls -At /etc/wptt/vhost 2>/dev/null)" ]; then
    for entry in $(ls -A /etc/wptt/vhost | grep -v '^\.\.conf$' | sort -uV); do
      local dom=$(echo "$entry" | sed 's/^\.//' | sed 's/\.conf$//')
      # Lọc các domain KHÔNG CÓ cờ giả lập và KHÔNG có đuôi .wptangtoc-ols.com
      if [[ "$dom" == ?*.?* ]]; then
        if ! grep -q "domain_gia_lap=1" "/etc/wptt/vhost/.$dom.conf" 2>/dev/null && [[ "$dom" != *".wptangtoc-ols.com" ]]; then
          selects+=("$dom")
        fi
      fi
    done
  fi

  if [[ ${#selects[@]} -eq 0 ]]; then
    echo -e "${C_YELLOW}⚠️ Không tìm thấy tên miền Chính nào để triển khai.${C_RESET}\n"
    sleep 3
    exec /etc/wptt/wptt-gia-lap-main 1
  fi

  echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
  local title_text="Bước 2: Chọn website CHÍNH (Production) để ghi đè:"
  local len=$(echo -n "$title_text" | awk '{print length($0)}')
  local pad_r=$((box_inner_width - len - 2))
  [[ $pad_r -lt 0 ]] && pad_r=0
  echo -e "${C_CYAN}│${C_RESET}  ${C_YELLOW}${title_text}${C_RESET}$(printf '%*s' "$pad_r" "")${C_CYAN}│${C_RESET}"
  
  local line_len=$((len + 3))
  local pad_line_r=$((box_inner_width - line_len))
  [[ $pad_line_r -lt 0 ]] && pad_line_r=0
  local short_line=$(printf "%${line_len}s" "" | sed 's/ /─/g')
  echo -e "${C_CYAN}├${short_line}$(printf '%*s' "$pad_line_r" "")│${C_RESET}"

  local i=1
  for dom in "${selects[@]}"; do
    local item_text=$(printf "  ${C_CYAN}%3d)${C_RESET} ${C_BOLD_WHITE}%-30s${C_RESET} ${C_GREEN}[Website Thật]${C_RESET}" "$i" "$dom")
    local clean_text=$(printf "  %3d) %-30s [Website Thật]" "$i" "$dom")
    local item_len=$(echo -n "$clean_text" | awk '{print length($0)}')
    local pad=$((box_inner_width - item_len))
    [[ $pad -lt 0 ]] && pad=0
    echo -e "${C_CYAN}│${C_RESET}${item_text}$(printf '%*s' "$pad" "")${C_CYAN}│${C_RESET}"
    ((i++))
  done
  echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯${C_RESET}"

  local fzf_installed=false
  if command -v fzf &>/dev/null; then
    fzf_installed=true
    PROMPT_TEXT="Nhập lựa chọn (1-${#selects[@]}) [00=Tìm nhanh] [0=Thoát]: "
  else
    PROMPT_TEXT="Nhập lựa chọn (1-${#selects[@]}) [0=Thoát]: "
  fi

  while true; do
    echo -en "${C_CYAN}${PROMPT_TEXT}${C_RESET}"
    if ! read -r REPLY; then exit 1; fi
    REPLY=$(echo "$REPLY" | tr -d ' ' | tr '[:upper:]' '[:lower:]')

    case "$REPLY" in
    0) echo -e "\n${C_GREEN}Đang thoát...${C_RESET}"; exec /etc/wptt/wptt-gia-lap-main 1 ;;
    00)
      if $fzf_installed; then
        local selected_item=$(printf '%s\n' "${selects[@]}" | nl -w 3 -s ': ' | fzf --prompt="Tìm web chính >> " --height=40% --border=rounded --color=border:green --cycle --reverse)
        local dom=$(echo "$selected_item" | sed 's/^[[:space:]]*[0-9]\+\:[[:space:]]*//' | cut -d'|' -f1 | tr -d ' ')
        if [[ -n "$dom" ]]; then NAME="$dom"; return 0; fi
      fi
      ;;
    *)
      if [[ "$REPLY" =~ ^[0-9]+$ ]] && [ "$REPLY" -ge 1 ] && [ "$REPLY" -le ${#selects[@]} ]; then
        NAME=$(echo "${selects[$((REPLY - 1))]}" | cut -d'|' -f1 | tr -d ' ')
        return 0
      else echo -e "\n${C_RED}❌ Lựa chọn không hợp lệ!${C_RESET}"; fi
      ;;
    esac
  done
}

lua_chon_chinh
website_main="$NAME"

# ==============================================================================
# CẢNH BÁO XÁC NHẬN AN TOÀN (QUAN TRỌNG)
# ==============================================================================
echo -e "\n${C_RED}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_BOLD_WHITE}⚠️ CẢNH BÁO NGUY HIỂM: GHI ĐÈ DỮ LIỆU${C_RESET}"
echo -e "${C_RED}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
left_text "  Bạn đang chuẩn bị chép đè dữ liệu từ:" 2
left_text "  👉 Nguồn (Nháp) : ${C_YELLOW}$website_gia_lap${C_RESET}" 2
left_text "  👉 Đích (Chính) : ${C_GREEN}$website_main${C_RESET}" 2
echo -e "${C_RED}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
left_text " ${C_YELLOW}HẬU QUẢ:${C_RESET} Toàn bộ Database và File hiện tại của website chính" 2
left_text " (${C_GREEN}$website_main${C_RESET}) sẽ bị ${C_RED}XÓA VĨNH VIỄN${C_RESET} không thể khôi phục." 2
echo -e "${C_RED}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

if ! wptt_xac_nhan "Bạn có CHẮC CHẮN muốn tiếp tục tiến trình Ghi Đè này không?" "" "" "Đồng ý GHI ĐÈ" "Hủy thao tác"; then
  echo -e "${C_YELLOW}Đã hủy thao tác để đảm bảo an toàn.${C_RESET}\n"
  sleep 1
  exec /etc/wptt/wptt-gia-lap-main 1
fi

echo "Gỉa lập website đưa dữ liệu website giả lập $website_gia_lap về domain chính $website_main: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log
echo ""

# ==============================================================================
# XÓA DỮ LIỆU CŨ CỦA WEB CHÍNH
# ==============================================================================
_runing "Đang dọn dẹp và xóa sạch Database của website chính ($website_main)..."
. /etc/wptt/db/wptt-wipe-database "$website_main" >/dev/null 2>&1
_rundone "Làm sạch Database cũ thành công"

_runing "Đang xóa sạch File/Thư mục của website chính ($website_main)..."
rm -rf "/usr/local/lsws/$website_main/html/"*
_rundone "Làm sạch Mã nguồn cũ thành công"

# ==============================================================================
# CHUYỂN ĐỔI DATABASE
# ==============================================================================
_runing "Đang xuất (Export) Database từ bản nháp và nạp vào web chính..."

mkdir -p "/usr/local/lsws/database"
. "/etc/wptt/vhost/.$website_gia_lap.conf"
file_sql="${DB_Name_web}.sql"
duong_dan_thu_muc="/usr/local/lsws/database/$file_sql"

TEMP_CNF_ROOT=$(mktemp)
chmod 600 "$TEMP_CNF_ROOT"
cat >"$TEMP_CNF_ROOT" <<EOF
[client]
user=${database_admin_username}
password=${database_admin_password}
host=localhost
max_allowed_packet=1G
default-character-set=utf8mb4

[mysqldump]
quick
quote-names
max_allowed_packet=1G
single-transaction
EOF

# Dump từ web nháp
mariadb-dump --defaults-extra-file="$TEMP_CNF_ROOT" "$DB_Name_web" --ssl-verify-server-cert=false >"$duong_dan_thu_muc"

# Import vào web chính
. "/etc/wptt/vhost/.$website_main.conf"
mariadb --defaults-extra-file="$TEMP_CNF_ROOT" "$DB_Name_web" --ssl-verify-server-cert=false <"$duong_dan_thu_muc"

rm -f "$TEMP_CNF_ROOT" "$duong_dan_thu_muc"
_rundone "Chuyển đổi Database hoàn tất"

# ==============================================================================
# SAO CHÉP MÃ NGUỒN (ĐÃ FIX LỖI DIRECTORY)
# ==============================================================================
_runing "Đang chép đè File mã nguồn từ bản nháp sang web chính..."
duong_dan_nguon_cu="/usr/local/lsws/$website_gia_lap/html"
duong_dan_nguon_moi="/usr/local/lsws/$website_main/html"

# Copy nội dung bên trong thay vì copy đè cả folder để tránh lỗi sinh ra html/html
cp -a "$duong_dan_nguon_cu/." "$duong_dan_nguon_moi/"
_rundone "Chép đè File mã nguồn hoàn tất"

# ==============================================================================
# WP-CLI: CẤU HÌNH DATABASE MỚI VÀ REPLACE URL
# ==============================================================================
_runing "Đang đồng bộ cấu hình và đổi chuỗi URL (Search & Replace)..."

. /etc/wptt/php/php-cli-domain-config "$website_main"
. "/etc/wptt/vhost/.$website_main.conf"

/usr/local/bin/wp config set DB_HOST 'localhost' --type=constant --allow-root --path="/usr/local/lsws/$website_main/html" --quiet
/usr/local/bin/wp config set DB_NAME "$DB_Name_web" --type=constant --allow-root --path="/usr/local/lsws/$website_main/html" --quiet
/usr/local/bin/wp config set DB_USER "$DB_User_web" --type=constant --allow-root --path="/usr/local/lsws/$website_main/html" --quiet
/usr/local/bin/wp config set DB_PASSWORD "$DB_Password_web" --type=constant --allow-root --path="/usr/local/lsws/$website_main/html" --quiet

/usr/local/lsws/lsphp${phien_ban_php_domain_thuc_thi}/bin/php /usr/local/bin/wp search-replace "${website_gia_lap}" "${website_main}" --path="/usr/local/lsws/$website_main/html" --allow-root >/dev/null 2>&1

# Trả lại Public Index (Xóa Noindex của bản giả lập)
/usr/local/lsws/lsphp${phien_ban_php_domain_thuc_thi}/bin/php /usr/local/bin/wp option set blog_public 1 --allow-root --path="/usr/local/lsws/$website_main/html" >/dev/null 2>&1

_rundone "Đồng bộ cấu hình và URL thành công"

# ==============================================================================
# XÓA CACHE VÀ PHÂN QUYỀN
# ==============================================================================
_runing "Đang dọn dẹp Cache và phân quyền (Chown) bảo mật..."
. /etc/wptt/cache/wptt-xoacache "$website_main" >/dev/null 2>&1
. /etc/wptt/wptt-phanquyen "$website_main" >/dev/null 2>&1
_rundone "Phân quyền và xóa Cache hoàn tất"

# ==============================================================================
# BẢNG BÁO CÁO KẾT QUẢ CUỐI CÙNG
# ==============================================================================
echo -e "\n${C_GREEN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_BOLD_WHITE}TRIỂN KHAI LÊN WEBSITE CHÍNH THÀNH CÔNG${C_RESET}"
echo -e "${C_GREEN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
left_text "  Đã chép đè dữ liệu từ :" 2
left_text "  ${C_YELLOW}$website_gia_lap${C_RESET}" 2
left_text "  Lên website chính tại :" 2
left_text "  ${C_GREEN}https://$website_main${C_RESET}" 2
echo -e "${C_GREEN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
left_text " ${C_YELLOW}Lưu ý:${C_RESET} Bản nháp ($website_gia_lap) vẫn được giữ nguyên không đổi." 2
left_text " Mọi thiết lập SEO (Index) của web chính đã được mở khóa tự động." 2
echo -e "${C_GREEN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

check_menu_wptangtoc_active=${1:-}
if [[ "$check_menu_wptangtoc_active" == "98" ]]; then
  exec /etc/wptt/wptt-gia-lap-main 1
fi
