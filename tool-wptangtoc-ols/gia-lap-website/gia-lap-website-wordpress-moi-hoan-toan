#!/bin/bash

function huong_dan() {
  Giả lập một website WordPress trắng hoàn toàn là việc tạo ra một bản cài đặt WordPress gốc, sạch sẽ, và cung cấp một tên miền miễn phí dành cho bạn, trên máy chủ của bạn. Điều này rất hữu ích cho việc phát triển, kiểm thử, học tập và chuẩn bị cho một dự án website mới một cách an toàn và hiệu quả.
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null # Nạp thư viện UX Bo Cong

clear
echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}GIẢ LẬP WEBSITE ➜ Tạo Website WordPress Trắng (Tên miền miễn phí)${C_RESET}"
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

if [[ "${1:-}" == '98' ]]; then
  WPTT_IN_MENU="yes"
  WPTT_MENU_BACK="/etc/wptt/wptt-gia-lap-main 1"
fi

wptt_check_mariadb || wptt_die "MariaDB đang bị sập! Hệ thống từ chối khởi tạo website."
wptt_check_lsws || wptt_die "OpenLiteSpeed đang bị sập! Hệ thống từ chối khởi tạo website."

# ==============================================================================
# KHỞI TẠO BIẾN VÀ TÊN MIỀN RANDOM
# ==============================================================================
NAME="${Website_chinh:-}"
domain_phuc_vu="wptangtoc-ols.com"

# Tạo chuỗi random và định danh Subdomain
ten_ngau_nhien=$(openssl rand -base64 32 | tr -dc 'a-zA-Z0-9' | head -c 4)
ten_mien_random=${NAME//[-._]/$ten_ngau_nhien}
subdomain_ten_mien=$(echo "$ten_mien_random" | tr '[:upper:]' '[:lower:]')
STAGING_DOMAIN="${subdomain_ten_mien}.${domain_phuc_vu}"

ip=$(curl -sf --connect-timeout 5 --max-time 10 https://ipv4.icanhazip.com || curl -sf --connect-timeout 5 --max-time 10 https://checkip.amazonaws.com)

if [[ -z "$ip" ]]; then
  echo -e "\n${C_RED}❌ Lỗi: Máy chủ không có địa chỉ IPv4 Public!${C_RESET}"
  echo -e "Tính năng giả lập yêu cầu IPv4 để liên kết DNS."
  sleep 3
  exec /etc/wptt/wptt-gia-lap-main 1
fi

echo -e "${C_YELLOW}💡 Hệ thống sẽ tự động cấp phát tên miền và cài đặt WordPress trắng.${C_RESET}\n"

# ==============================================================================
# CẤU HÌNH CLOUDFLARE DNS & TẠO VHOST
# ==============================================================================
_runing "Đang kết nối Cloudflare API để tạo tên miền giả lập ($STAGING_DOMAIN)..."
. /etc/wptt/gia-lap-website/cloudflare-dns "${subdomain_ten_mien}" "$ip" >/dev/null 2>&1
_rundone "Cấu hình tên miền giả lập hoàn tất ($STAGING_DOMAIN)"

echo "Giả lập website $STAGING_DOMAIN mới trắng: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log

_runing "Khởi tạo Virtual Host và thư mục mã nguồn..."
. /etc/wptt/domain/wptt-themwebsite "$STAGING_DOMAIN" >/dev/null 2>&1

if ! wptt_kha_dung_de_xoa_xac_thuc "$STAGING_DOMAIN"; then
  _runloi "Lỗi khởi tạo Vhost rỗng. Đã hủy bỏ lệnh!"
  sleep 2
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-gia-lap-main 1
  exit 1
fi
_rundone "Khởi tạo Virtual Host thành công"

# ==============================================================================
# DOWNLOAD VÀ GIẢI NÉN WORDPRESS CORE
# ==============================================================================
_runing "Đang tải xuống và giải nén mã nguồn WordPress mới nhất..."
cd "/usr/local/lsws/$STAGING_DOMAIN/html/" || exit
rm -rf "/usr/local/lsws/$STAGING_DOMAIN/html/"*
wget -q http://wordpress.org/latest.tar.gz
tar -zxf latest.tar.gz
mv wordpress/* "/usr/local/lsws/$STAGING_DOMAIN/html/"
rm -rf wordpress latest.tar.gz
_rundone "Tải và giải nén mã nguồn WordPress hoàn tất"

# ==============================================================================
# CÀI ĐẶT DATABASE & WORDPRESS BẰNG WP-CLI
# ==============================================================================
_runing "Đang tự động thiết lập Database và cài đặt WordPress..."
. "/etc/wptt/vhost/.$STAGING_DOMAIN.conf"
tien_to_db=$(openssl rand -base64 32 | tr -dc 'a-zA-Z0-9' | head -c 6)

# Cấu hình wp-config.php
wp core config --dbname="$DB_Name_web" --dbuser="$DB_User_web" --dbpass="$DB_Password_web" --dbhost=localhost --dbprefix="${tien_to_db}_" --allow-root --extra-php >/dev/null 2>&1 <<PHP
define( 'WP_DEBUG_LOG', false );
define( 'WP_DEBUG_DISPLAY', false );
PHP

# Tạo thông tin quản trị viên ngẫu nhiên
idusername="admin_$(openssl rand -base64 32 | tr -dc 'a-zA-Z0-9' | head -c 6)"
SiteTitle="WPTangToc OLS Staging"
mypassword=$(openssl rand -base64 32 | tr -dc 'a-zA-Z0-9' | head -c 16)
emailwp="admin@${STAGING_DOMAIN}"

# Install WP
wp core install --url="http://$STAGING_DOMAIN" --title="$SiteTitle" --admin_user="$idusername" --admin_password="$mypassword" --admin_email="$emailwp" --allow-root >/dev/null 2>&1
wp language core install vi --path="/usr/local/lsws/$STAGING_DOMAIN/html" --activate --allow-root >/dev/null 2>&1
wp option update timezone_string "Asia/Ho_Chi_Minh" --path="/usr/local/lsws/$STAGING_DOMAIN/html" --allow-root >/dev/null 2>&1
wp rewrite structure '/%postname%/' --path="/usr/local/lsws/$STAGING_DOMAIN/html" --allow-root >/dev/null 2>&1

# Chặn Bot tìm kiếm
wp option set blog_public 0 --allow-root --path="/usr/local/lsws/$STAGING_DOMAIN/html" >/dev/null 2>&1

if [[ -f "/usr/local/lsws/$STAGING_DOMAIN/html/robots.txt" ]]; then
  cp -f "/usr/local/lsws/$STAGING_DOMAIN/html/robots.txt" "/tmp/$STAGING_DOMAIN-robots.txt"
fi
_rundone "Cài đặt WordPress thành công"

_runing "Đang phân quyền bảo mật (Chown) cho thư mục mã nguồn..."
chown -R "$User_name_vhost":"$User_name_vhost" "/usr/local/lsws/$STAGING_DOMAIN/html"
_rundone "Phân quyền bảo mật hoàn tất"

# ==============================================================================
# CHỜ XÁC THỰC DNS (CÓ SPINNER UX)
# ==============================================================================
unset check_dns api_google_check_dns_online_ipv4 api_cloudflare_dns_check_ipv4
a=0

tput civis
spin='-\|/'
spinner_idx=0

if [[ -f "/tmp/dem-check_dns-wptangtoc-ols" ]]; then
  rm -f "/tmp/dem-check_dns-wptangtoc-ols"
fi

while [[ -z "$check_dns" && -z "$api_google_check_dns_online_ipv4" && -z "$api_cloudflare_dns_check_ipv4" ]]; do
  spinner_idx=$(( (spinner_idx+1) % 4 ))
  echo -en "\r  ${C_CYAN} Đang chờ Cloudflare cập nhật máy chủ DNS toàn cầu... ${C_YELLOW}${spin:$spinner_idx:1}${C_RESET} ($a giây)"
  
  check_dns=$(host "$STAGING_DOMAIN" 2>/dev/null | grep -Eo -m 1 '[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}')
  api_google_check_dns_online_ipv4=$(curl -s --connect-timeout 5 "https://dns.google/resolve?name=$STAGING_DOMAIN&type=A" | grep -E -o '([0-9]{1,3}\.){3}[0-9]{1,3}' | head -1)
  api_cloudflare_dns_check_ipv4=$(curl -s --connect-timeout 5 -H 'accept: application/dns-json' "https://cloudflare-dns.com/dns-query?name=$STAGING_DOMAIN&type=A" | grep -E -o '([0-9]{1,3}\.){3}[0-9]{1,3}' | head -1)

  a=$((a + 3))
  echo "$a" > /tmp/dem-check_dns-wptangtoc-ols
  sleep 3

  if [[ $(cat /tmp/dem-check_dns-wptangtoc-ols) == '15' ]]; then
    . /etc/wptt/gia-lap-website/cloudflare-dns "${subdomain_ten_mien}" "$ip" >/dev/null 2>&1
  fi

  if [[ $(cat /tmp/dem-check_dns-wptangtoc-ols) == '30' ]]; then
    echo -en "\r\033[K"
    tput cnorm
    _runloi "Xác thực DNS quá thời gian (Timeout 30s)"
    echo -e "${C_RED}❌ Chưa thể khởi tạo website giả lập lúc này (Cloudflare phản hồi chậm).${C_RESET}"
    . /etc/wptt/domain/wptt-xoa-website "$STAGING_DOMAIN" >/dev/null 2>&1
    sleep 3
    exec /etc/wptt/wptt-gia-lap-main 1
  fi
done

echo -en "\r\033[K"
tput cnorm
_rundone "Cập nhật DNS toàn cầu thành công"

# ==============================================================================
# KIỂM TRA TRẠNG THÁI WEBSITE SAU KHI DỰNG (ĐÃ FIX BUG CHECK HTTP)
# ==============================================================================
_runing "Đang kiểm tra tính khả dụng của Website và cấu hình SEO..."

# Kiểm tra mã phản hồi HTTP trực tiếp trên tên miền VỪA TẠO (STAGING_DOMAIN)
http_status=$(curl -o /dev/null -s -w "%{http_code}\n" "http://$STAGING_DOMAIN" 2>/dev/null)

if [[ "$http_status" -ne 200 && "$http_status" -ne 301 && "$http_status" -ne 302 ]]; then 
  . /etc/wptt/domain/wptt-xoa-website "$STAGING_DOMAIN" >/dev/null 2>&1
  _runloi "Website không phản hồi. Đã hủy bỏ tiến trình."
  exec /etc/wptt/wptt-gia-lap-main 1
else
  # Đóng dấu chặn Google Bots (Noindex) ở tầng Server
  sed -i '/extraHeaders /a X-Robots-Tag noindex' "/usr/local/lsws/conf/vhosts/$STAGING_DOMAIN/$STAGING_DOMAIN.conf"
fi
_rundone "Kiểm tra khả dụng và thiết lập Noindex hoàn tất"

# ==============================================================================
# CÀI ĐẶT SSL VÀ RESTART LITESPEED
# ==============================================================================
_runing "Đang cài đặt bảo mật SSL (Let's Encrypt) cho website..."
wptt ssl "$STAGING_DOMAIN" >/dev/null 2>&1
SSL_STATUS="Đã BẬT (Let's Encrypt)"
PROTOCOL="https"
_rundone "Cài đặt SSL Let's Encrypt hoàn tất"

/usr/local/lsws/bin/lswsctrl restart >/dev/null 2>&1
echo "domain_gia_lap=1" >>"/etc/wptt/vhost/.$STAGING_DOMAIN.conf"

# ==============================================================================
# BẢNG BÁO CÁO KẾT QUẢ VÀ CẤP PHÁT TÀI KHOẢN
# ==============================================================================
echo -e "\n${C_GREEN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_BOLD_WHITE}KHỞI TẠO WEBSITE WORDPRESS TRẮNG THÀNH CÔNG${C_RESET}"
echo -e "${C_GREEN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
left_text "  Tên miền thử nghiệm : ${C_YELLOW}${PROTOCOL}://$STAGING_DOMAIN${C_RESET}" 2
left_text "  Trang quản trị (WP) : ${C_CYAN}${PROTOCOL}://$STAGING_DOMAIN/wp-admin/${C_RESET}" 2
left_text "  Trạng thái SSL      : ${C_GREEN}$SSL_STATUS${C_RESET}" 2
echo -e "${C_GREEN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
left_text " ${C_YELLOW}THÔNG TIN TÀI KHOẢN ĐĂNG NHẬP:${C_RESET}" 2
left_text "  Tên đăng nhập (User): ${C_BOLD_WHITE}$idusername${C_RESET}" 2
left_text "  Mật khẩu (Password) : ${C_RED}$mypassword${C_RESET}" 2
echo -e "${C_GREEN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
left_text " ${C_YELLOW}Ghi chú:${C_RESET}" 2
left_text " - Hãy copy Mật khẩu và lưu lại ngay lập tức!" 2
left_text " - Bản thử nghiệm đã được tự động chặn Google (Noindex)." 2
echo -e "${C_GREEN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

check_menu_wptangtoc_active=${1:-}
if [[ "$check_menu_wptangtoc_active" == "98" ]]; then
  exec /etc/wptt/wptt-gia-lap-main 1
fi
