#!/bin/bash
function huong_dan() {
  Tính năng Hiển thị IP real Cloudflare CDN trong WPTangToc OLS là một công cụ giúp bạn xác minh hoặc cấu hình để máy chủ web OpenLiteSpeed của bạn có thể nhận diện và ghi lại địa chỉ IP thực của người dùng khi website đang sử dụng dịch vụ CDN của Cloudflare.

  Tại sao cần quan tâm IP thực khi dùng Cloudflare?
  Khi website của bạn sử dụng Cloudflare, tất cả lưu lượng truy cập sẽ đi qua mạng lưới của Cloudflare trước khi đến máy chủ gốc. Do đó, trong log của máy chủ web, địa chỉ IP của người truy cập thường sẽ hiển thị là IP của Cloudflare, chứ không phải IP thực của khách truy cập. Điều này gây khó khăn cho việc:

  Phân tích log chính xác.
  * Áp dụng các quy tắc bảo mật dựa trên IP [ví dụ: chặn IP, giới hạn truy cập].
  * Hoạt động của một số plugin hoặc ứng dụng cần IP thực của người dùng.
  * Đảm bảo Dữ liệu Chính xác: Giúp các công cụ phân tích, bảo mật [như Fail2Ban,CSF,Nftables,Firewalld...] và ứng dụng trên website hoạt động chính xác với IP thực của người dùng.

  Lợi ích:
  * Log chính xác: Ghi lại đúng IP của khách truy cập trong log máy chủ.
  * Bảo mật hiệu quả hơn: Các công cụ bảo mật dựa trên IP hoạt động đúng đắn.
  * Phân tích dữ liệu tốt hơn: Hiểu rõ hơn về nguồn gốc lưu lượng truy cập.
  Tóm lại, tính năng Hiển thị IP real Cloudflare CDN trong WPTangToc OLS rất quan trọng để đảm bảo máy chủ của bạn hoạt động chính xác và hiệu quả khi website được bảo vệ và tăng tốc bởi Cloudflare, bằng cách giúp máy chủ nhận diện đúng địa chỉ IP gốc của khách truy cập.
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null

clear
echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}TÍCH HỢP CLOUDFLARE -> Hiển Thị IP Thực (Dynamic Update)${C_RESET}"
echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

# ==============================================================================
# KIỂM TRA ĐIỀU KIỆN PREMIUM
# ==============================================================================
if [[ "$2" == 'premium' ]]; then
  unset key_activate
  . /etc/wptt/.wptt.conf 2>/dev/null
  if [[ -z "$key_activate" ]]; then
    echo -e "${C_RED}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
    center_text "${C_BOLD_WHITE}[!] TÍNH NĂNG PREMIUM BỊ KHÓA${C_RESET}"
    echo -e "${C_RED}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
    left_text "  Đây là tính năng Premium. Bạn cần phải mua Active Key" 2
    left_text "  để sử dụng tính năng này cùng các Add-ons cao cấp khác." 2
    echo -e "${C_RED}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"
    
    check_menu_wptangtoc_active=${1:-}
    if [[ "$check_menu_wptangtoc_active" == "98" ]]; then
      echo -en "${C_YELLOW}>> Nhấn phím [Enter] để đến Menu Add-ons...${C_RESET}"
      read -r dummy
      exec /etc/wptt/wptt-add-one-main 1
    fi
    exit 1
  fi
fi

# Giữ log không dấu để an toàn cho file hệ thống
echo "Show IP thuc client Cloudflare (Dynamic): $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log

# ==============================================================================
# KHỞI TẠO DANH SÁCH DỰ PHÒNG (OFFLINE BACKUP)
# ==============================================================================
BACKUP_V4="103.21.244.0/22T, 103.22.200.0/22T, 103.31.4.0/22T, 104.16.0.0/13T, 104.24.0.0/14T, 108.162.192.0/18T, 131.0.72.0/22T, 141.101.64.0/18T, 162.158.0.0/15T, 172.64.0.0/13T, 173.245.48.0/20T, 188.114.96.0/20T, 190.93.240.0/20T, 197.234.240.0/22T, 198.41.128.0/17T"
BACKUP_V6="2400:cb00::/32T, 2606:4700::/32T, 2803:f800::/32T, 2405:b500::/32T, 2405:8100::/32T, 2a06:98c0::/29T, 2c0f:f248::/32T"

# ==============================================================================
# KIỂM TRA MÔI TRƯỜNG & LẤY DỮ LIỆU ONLINE (HYBRID FETCH)
# ==============================================================================
_runing "Đang kết nối Cloudflare API để cập nhật dải IP mới nhất..."

# Kiểm tra OLS có đang dùng IPv6 không
if grep -q 'address.*\[ANY\]' /usr/local/lsws/conf/httpd_config.conf 2>/dev/null; then
  ENABLE_IPV6=1
else
  ENABLE_IPV6=0
fi

# Fetch IPv4 (Bắt buộc)
ONLINE_V4=$(curl -s --connect-timeout 5 https://www.cloudflare.com/ips-v4/ | grep -v '^$' | awk '{print $1"T"}' | paste -sd "," -)

if [[ -n "$ONLINE_V4" ]]; then
  FINAL_V4="$ONLINE_V4"
  STATUS_V4="[Online]"
else
  FINAL_V4="$BACKUP_V4"
  STATUS_V4="[Dự phòng Ngoại tuyến]"
fi

# Khởi tạo list IP cơ bản
CF_TRUSTED_LIST="ALL, $FINAL_V4"

# Chỉ Fetch và nối thêm IPv6 nếu VPS có bật IPv6
if [[ "$ENABLE_IPV6" -eq 1 ]]; then
  ONLINE_V6=$(curl -s --connect-timeout 5 https://www.cloudflare.com/ips-v6/ | grep -v '^$' | awk '{print $1"T"}' | paste -sd "," -)
  if [[ -n "$ONLINE_V6" ]]; then
    FINAL_V6="$ONLINE_V6"
    STATUS_V6="[Online]"
  else
    FINAL_V6="$BACKUP_V6"
    STATUS_V6="[Dự phòng Ngoại tuyến]"
  fi
  CF_TRUSTED_LIST="ALL, $FINAL_V4, $FINAL_V6"
  _rundone "Lấy dữ liệu hoàn tất. V4: $STATUS_V4 | V6: $STATUS_V6"
else
  _rundone "Lấy dữ liệu hoàn tất. V4: $STATUS_V4 (Bỏ qua V6)"
fi

# ==============================================================================
# CẤU HÌNH OPENLITESPEED
# ==============================================================================
_runing "Đang đồng bộ cấu hình vào httpd_config.conf..."

# 1. Bật nhận diện Header Proxy
sed -i '/useIpInProxyHeader/d' /usr/local/lsws/conf/httpd_config.conf
sed -i '/adminEmails/i useIpInProxyHeader     2' /usr/local/lsws/conf/httpd_config.conf

# 2. Xử lý Access Control
ip_block_by_litespeed=$(grep 'deny' /usr/local/lsws/conf/httpd_config.conf)
sed -i -e '/^accessControl/,/^}$/d' /usr/local/lsws/conf/httpd_config.conf

if [[ -z "$ip_block_by_litespeed" ]]; then
  echo "
accessControl  {
  allow                   $CF_TRUSTED_LIST
}
" >>/usr/local/lsws/conf/httpd_config.conf
else
  echo "
accessControl  {
  allow                   $CF_TRUSTED_LIST
$ip_block_by_litespeed
}
" >>/usr/local/lsws/conf/httpd_config.conf
fi
_rundone "Đồng bộ cấu hình [OK]"

_runing "Đang khởi động lại dịch vụ OpenLiteSpeed..."
/usr/local/lsws/bin/lswsctrl restart >/dev/null 2>&1
_rundone "Khởi động lại OpenLiteSpeed [OK]"

echo -e "\n${C_GREEN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_BOLD_WHITE}[HOÀN TẤT] CẬP NHẬT DYNAMIC REAL IP${C_RESET}"
echo -e "${C_GREEN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
left_text "  - Nguồn dữ liệu V4: $STATUS_V4" 2

# Cải tiến UX: Chỉ in ra dòng báo cáo IPv6 nếu hệ thống thực sự có dùng IPv6
if [[ "$ENABLE_IPV6" -eq 1 ]]; then
  left_text "  - Nguồn dữ liệu V6: $STATUS_V6" 2
fi

left_text "  - Dải IP mới nhất đã được nạp vào hệ thống Trusted." 2
left_text "  - OLS sẽ tự động nhận diện IP thực từ môi trường CDN." 2
echo -e "${C_GREEN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

check_menu_wptangtoc_active=${1:-}
if [[ "$check_menu_wptangtoc_active" == "98" ]]; then
  exec /etc/wptt/wptt-cloudflare-main 1
fi
