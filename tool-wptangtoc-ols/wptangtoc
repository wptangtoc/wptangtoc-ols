# ==============================================================================
# 5. HÀM GIAO DIỆN CỤC BỘ (CHỈ DÙNG CHO MENU CHÍNH)
# ==============================================================================
print_status_local() {
  local label="$1"
  local val="$2"
  local color="$3"
  local plain_text="  ${label} ${val}"
  local pad=$((78 - ${#plain_text}))
  [[ $pad -lt 0 ]] && pad=0
  printf "${MARGIN}\033[1;36m│\033[0m  \033[1;37m%s\033[0m %b%*s\033[1;36m│\033[0m\n" "$label" "${color}${val}\033[0m" "$pad" ""
}

# ==============================================================================
# 6. GIAO DIỆN TÙY CHỈNH (HOOK ĐỂ THƯ VIỆN GỌI LẠI)
# ==============================================================================
draw_custom_grid() {
  # 6.1. In thông tin bản quyền và Tác giả
  print_header "$phat_trien_boi_gia_tuan"
  if [[ "$wptangtoc_ols_giatuan" == "1" && -n "$key_activate" ]]; then
    print_header "Bản Quyền: Enterprise + Premium"
  elif [[ "$wptangtoc_ols_giatuan" == "1" ]]; then
    print_header "Bản Quyền: Enterprise"
  elif [[ -n "$key_activate" ]]; then
    print_header "Bản Quyền: Premium"
  fi
  [[ "$beta_wptangtoc_ols" == "1" ]] && print_header "[Phiên bản Beta]"

  print_spacer
  echo -e "${MARGIN}\033[1;36m├──────────────────────────────────────────────────────────────────────────────┤\033[0m"

  # 6.2. Kiểm tra Live Status (LiteSpeed & MariaDB)
  if command -v systemctl &>/dev/null; then
    ols1=$(/usr/local/lsws/bin/lswsctrl status 2>/dev/null | grep -i 'litespeed is running')
    mariadb1=$(systemctl is-active mariadb.service 2>/dev/null)
    if [[ -z "$ols1" ]]; then
      /usr/local/lsws/bin/lswsctrl restart >/dev/null 2>&1
      ols1=$(/usr/local/lsws/bin/lswsctrl status 2>/dev/null | grep -i 'litespeed is running')
    fi
    if [[ "$mariadb1" != "active" ]]; then
      systemctl restart mariadb.service >/dev/null 2>&1
      mariadb1=$(systemctl is-active mariadb.service 2>/dev/null)
    fi
  else
    ols1="unknown"
    mariadb1="unknown"
  fi

  # 6.3. In trạng thái Server
  if [[ -n "$ols1" && "$mariadb1" == "active" ]]; then
    print_status_local "${tinh_trang_may_chu:-Tình trạng máy chủ}:" "Hoạt động tốt" "\033[1;32m"
  elif [[ "$ols1" == "unknown" || "$mariadb1" == "unknown" ]]; then
    print_status_local "${tinh_trang_may_chu:-Tình trạng máy chủ}:" "Không thể xác định" "\033[1;33m"
  else
    print_status_local "${tinh_trang_may_chu:-Tình trạng máy chủ}:" "Đang gặp sự cố!" "\033[1;31m"
    [[ -z "$ols1" ]] && print_status_local " ↳ Cảnh báo:" "Webserver LiteSpeed ngừng hoạt động!" "\033[1;31m"
    [[ "$mariadb1" != "active" ]] && print_status_local " ↳ Cảnh báo:" "Database MariaDB ngừng hoạt động!" "\033[1;31m"
  fi

  echo -e "${MARGIN}\033[1;36m├──────────────────────────────────────────────────────────────────────────────┤\033[0m"
  print_spacer

  # 6.4. Vẽ tự động 2 cột thông minh (Bẻ đôi mảng Options)
  local total=${#options[@]}
  local half=$(((total + 1) / 2))

  for ((i = 0; i < half; i++)); do
    local l_idx=$i
    local r_idx=$((i + half))

    local l_num=$((l_idx + 1))
    local l_text="${options[$l_idx]}"
    local r_num=""
    local r_text=""

    if [[ $r_idx -lt $total ]]; then
      r_num=$((r_idx + 1))
      r_text="${options[$r_idx]}"
    fi
    print_row "$l_num" "$l_text" "$r_num" "$r_text"
  done
}

