# TẮT PROMPT CỦA LỆNH SELECT (Để tránh in thừa chữ "#?")
PS3=""

# ==============================================================================
# ĐỘNG CƠ NHẬN PHÍM MỚI (BẢO TOÀN GIAO DIỆN GỐC - NHẬN CTRL+C 100%)
# ==============================================================================
while true; do

  # TUYỆT KỸ: Dùng /dev/null ép select chỉ in Menu 1 lần duy nhất rồi tắt ngay
  select opt in "${options[@]}"; do break; done </dev/null

  # In dòng nhắc lệnh thủ công
  echo -en "$PROMPT_TEXT"

  # Dùng lệnh read để hứng phím (Bắt Ctrl+C cực kỳ nhạy)
  read -r REPLY

  case "$REPLY" in
  0)
    echo -e "\n${C_GREEN}Đang thoát...${C_RESET}"
    if [[ -x "/etc/wptt/wptt-status2" ]]; then exec /etc/wptt/wptt-status2; fi
    exit 0
    ;;
  00)
    if $fzf_installed; then
      fzf_height=$((${#options[@]} + 3))
      fzf_prompt="🔍 ${nhap_lua_chon_cua_ban:-Tìm kiếm lựa chọn} (Mũi tên di chuyển, Enter chọn, ESC hủy): "

      # Tích hợp thêm màu sắc cho bảng FZF
      selected_opt=$(printf '%s\n' "${options[@]}" | nl -w 3 -s ': ' | fzf --prompt="$fzf_prompt" --height="$fzf_height" --border --cycle --reverse --color="bg+:#222222,fg+:#00ff00,hl:#ff0000,prompt:#00ffff,pointer:#ffff00")
      selected_opt=$(echo "$selected_opt" | sed 's/^[[:space:]]*[0-9]\+\:[[:space:]]*//')
      fzf_exit_status=$?

      if [[ $fzf_exit_status -eq 0 ]] && [[ -n "$selected_opt" ]]; then
        selected_index=-1
        for i in "${!options[@]}"; do
          if [[ "$(echo -n "${options[$i]}" | sed 's/[[:space:]]*$//')" == "$(echo -n "$selected_opt" | sed 's/[[:space:]]*$//')" ]]; then
            selected_index=$i
            break
          fi
        done

        if [[ $selected_index -ne -1 ]]; then
          echo -e "Đã chọn: ${C_CYAN}${options[$selected_index]}${C_RESET}"
          run_action "$selected_index"
        else
          echo -e "${C_RED}Lỗi: Không thể khớp lựa chọn FZF. ${vui_long_chon_lai:-Vui lòng chọn lại.}${C_RESET}"
        fi
      else
        echo -e "\n${C_YELLOW}${vui_long_chon_lai:-Vui lòng chọn lại.}${C_RESET}"
      fi
    fi
    continue
    ;;
  *)
    if [[ "$REPLY" =~ ^[0-9]+$ ]] && [ "$REPLY" -ge 1 ] && [ "$REPLY" -le ${#options[@]} ]; then
      action_index=$((REPLY - 1))
      echo -e "Đã chọn: ${C_CYAN}${options[$action_index]}${C_RESET}"
      run_action "$action_index"
    else
      # Báo lỗi nếu nhập bậy bạ
      if [[ -n "$REPLY" ]]; then
        echo -e "\n${C_RED}${lua_chon_khong_hop_le:-Lựa chọn không hợp lệ}: '$REPLY'. ${vui_long_chon_lai:-Vui lòng chọn lại.}${C_RESET}"
      fi
    fi
    continue
    ;;
  esac
done
