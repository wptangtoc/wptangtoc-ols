#!/bin/bash

function huong_dan() {
  Tính năng Chống DDoS 403 trong WPTangToc OLS là một cơ chế phòng vệ giúp máy chủ OpenLiteSpeed của bạn đối phó với các cuộc tấn công từ chối dịch vụ phân tán [DDoS] ở mức độ đơn giản đến trung bình.

  Mã lỗi HTTP 403 Forbidden là một mã trạng thái HTTP tiêu chuẩn mà máy chủ web gửi lại cho trình duyệt [hoặc client] khi máy chủ hiểu yêu cầu của bạn, nhưng từ chối thực hiện yêu cầu đó.

  Nói một cách đơn giản, máy chủ đang nói rằng: Tôi biết bạn muốn gì, nhưng bạn không có quyền truy cập vào tài nguyên đó.

  Bằng cách theo dõi các địa chỉ IP bị trả về lỗi 403 Forbidden. Nếu trong vòng 10 giây mà IP đó yêu cầu và bị trả về 403 hơn 5 lần sẽ bị tạm khoá IP trong vòng 2 tiếng.
}

. /etc/wptt/.wptt.conf
. /etc/wptt/echo-color
if [[ $ngon_ngu = '' ]]; then
  ngon_ngu='vi'
fi
. /etc/wptt/lang/$ngon_ngu.sh

echo "/-----------------------------------------------------------------------/"
echo "$bao_mat => $bat/$tat $chong HTTP 403"
echo "/-----------------------------------------------------------------------/"

if [[ ! -f /etc/fail2ban/filter.d/http-403-wptangtoc-ols.conf ]]; then
  echo "Xác nhận kích hoạt tính năng $chong HTTP 403: "
  prompt="$nhap_lua_chon_cua_ban [1-2]: "
  dongy="n"
  options=("$dong_y" "$khong_dong_y")
  PS3="$prompt"
  select opt in "${options[@]}"; do
    case "$REPLY" in
    1)
      dongy="y"
      break
      ;;

    2)
      dongy="n"
      break
      ;;

    $((${#options[@]} + 1)))
      printf "\n$ban_nhap_sai_he_thong_se_chon_khong_dong_y\n"
      break
      ;;
    *)
      printf "$ban_nhap_sai_he_thong_se_chon_khong_dong_y\n"
      break
      ;;
    esac
  done

  if [[ $dongy = 'n' ]]; then
    exec /etc/wptt/wptt-bao-mat-main 1
  fi

  _runing "$kich_hoat_webguiadmin $chong http 403"

  # =========================================================
  # AUTO-INSTALL DEPENDENCIES (IPSET & PYINOTIFY)
  # =========================================================
  if [ -f /etc/os-release ] && grep -qi "ubuntu" /etc/os-release; then
    dpkg -s python3-pyinotify ipset >/dev/null 2>&1 || {
      export DEBIAN_FRONTEND=noninteractive
      apt-get update >/dev/null 2>&1
      apt-get install -y python3-pyinotify ipset >/dev/null 2>&1
    }
  else
    rpm -q python3-inotify ipset >/dev/null 2>&1 || {
      dnf install -y python3-inotify ipset >/dev/null 2>&1
    }
  fi

  # Đoạn check Cloudflare (Lưu ý: $NAME chưa được gán nên curl có thể bị rỗng. Em giữ nguyên để không phá vỡ code gốc của anh)
  unset TRACE_OUTPUT
  TRACE_OUTPUT=$(curl -Is --connect-timeout 5 --max-time 10 "https://$NAME/cdn-cgi/trace" 2>/dev/null)
  if echo "$TRACE_OUTPUT" | grep -qi 'cloudflare\|cf-ray'; then
    if [[ $(cat /usr/local/lsws/conf/httpd_config.conf | grep 'allow' | grep '103.21.244.0') = '' ]]; then
      _runloi "$kich_hoat_webguiadmin $chong http 403"
      echo "Phát hiện website $NAME đang sử dụng Cloudflare CDN"
      echo "Vui lòng phải kích hoạt sử dụng tính năng Hiện thị IP Log Real bypass Cloudflare CDN (MENU add ons 35=>8)"
      echo "Thì mới có thể sử dụng được tính năng này để tránh bị chặn nhầm"
      check_menu_wptangtoc_active=$1
      if [[ $check_menu_wptangtoc_active = "98" ]]; then
        exec /etc/wptt/wptt-bao-mat-main 1
      fi
      return 2>/dev/null
      exit
    fi
  fi

  # =========================================================
  # TÍNH TOÁN BIẾN VÀ CẤU HÌNH FAIL2BAN ENTERPRISE
  # =========================================================
  rule_fail2ban_name="http-403-wptt"

  if [[ -f /etc/csf/csf.conf ]]; then
    action_thuc_thi_block="iptables-multiport[actname=block-tcp, name=$rule_fail2ban_name-t, port=\"80,443\", protocol=\"tcp\"]
           iptables-multiport[actname=block-udp, name=$rule_fail2ban_name-u, port=\"80,443\", protocol=\"udp\"]"
  elif [[ $(systemctl status nftables.service 2>/dev/null | grep 'Active' | cut -f2 -d':' | xargs | cut -f1 -d' ' | xargs) = "active" ]]; then
    action_thuc_thi_block="nftables-allports[name=$rule_fail2ban_name]"
  elif [[ $(systemctl status firewalld.service 2>/dev/null | grep 'Active' | cut -f2 -d':' | xargs | cut -f1 -d' ' | xargs) = "active" ]]; then
    action_thuc_thi_block="firewallcmd-ipset[actname=block-tcp, name=$rule_fail2ban_name-t, port=\"80,443\", protocol=\"tcp\"]
           firewallcmd-ipset[actname=block-udp, name=$rule_fail2ban_name-u, port=\"80,443\", protocol=\"udp\"]"
  else
    # Fallback an toàn nếu không nhận diện được (sẽ dùng iptables tiêu chuẩn có ipset)
    action_thuc_thi_block="iptables-multiport[actname=block-tcp, name=$rule_fail2ban_name-t, port=\"80,443\", protocol=\"tcp\"]
           iptables-multiport[actname=block-udp, name=$rule_fail2ban_name-u, port=\"80,443\", protocol=\"udp\"]"
  fi

  echo "
#begin-http-403-vi-pham-bao-mat
[http-403-vi-pham-bao-mat]
enabled = true
action = $action_thuc_thi_block
filter = http-403-wptangtoc-ols
logpath = /usr/local/lsws/*/logs/access.log
backend = pyinotify
bantime = 7200
maxretry = 5
findtime = 10
#end-http-403-vi-pham-bao-mat" >>/etc/fail2ban/jail.local

  # Tối ưu Regex, chặn bắt các biến thể bypass và bỏ qua file tĩnh an toàn
  echo '[Definition]
failregex = ^<HOST> .* "(GET|POST|DELETE|PUT|PATCH|HEAD) .* HTTP\/.*" 403 .*$
ignoreregex = \.(?i)(robots\.txt|favicon\.ico|jpg|png|webp|css|js|jpeg|woff2|avif|gif|svg|woff|ttf)(\?.*)?$' >/etc/fail2ban/filter.d/http-403-wptangtoc-ols.conf

  fail2ban-client reload >/dev/null 2>&1 || systemctl restart fail2ban >/dev/null 2>&1
  /usr/local/lsws/bin/lswsctrl restart >/dev/null 2>&1
  _rundone "$kich_hoat_webguiadmin $chong http 403"
  echo "Nếu trong 10 giây mà yêu cầu 5 yêu cầu 403 thì IP sẽ bị khóa trong 2 tiếng"
  exec /etc/wptt/wptt-bao-mat-main 1
fi

if [[ -f /etc/fail2ban/filter.d/http-403-wptangtoc-ols.conf ]]; then
  echo "Xác nhận tắt kích hoạt tính năng chống ddos IP: "
  prompt="Nhập lựa chọn của bạn [1-2]: "
  dongy="n"
  options=("Đồng ý" "Không đồng ý")
  PS3="$prompt"
  select opt in "${options[@]}"; do
    case "$REPLY" in
    1)
      dongy="y"
      break
      ;;

    2)
      dongy="n"
      break
      ;;

    $((${#options[@]} + 1)))
      printf "\nBạn nhập sai hệ thống sẽ chọn là không đồng ý\n"
      break
      ;;
    *)
      printf "Bạn nhập sai hệ thống sẽ chọn là không đồng ý\n"
      break
      ;;
    esac
  done

  if [[ $dongy = 'n' ]]; then
    exec /etc/wptt/wptt-bao-mat-main 1
  fi
  _runing "$tat $chong HTTP 403"
  rm -f /etc/fail2ban/filter.d/http-403-wptangtoc-ols.conf
  sed -i -e '/^#begin-http-403-vi-pham-bao-mat/,/^#end-http-403-vi-pham-bao-mat$/d' /etc/fail2ban/jail.local

  fail2ban-client reload >/dev/null 2>&1 || systemctl restart fail2ban >/dev/null 2>&1
  _rundone "$tat $chong HTTP 403"
fi

check_menu_wptangtoc_active=$1
if [[ $check_menu_wptangtoc_active = "98" ]]; then
  exec /etc/wptt/wptt-bao-mat-main 1
fi
