#!/bin/bash
# @author: Gia Tuấn
# @website: https://wptangtoc.com
# @since: 2026

function huong_dan() {
  Kích hoạt/Hủy kích hoạt Modsecurity.

  ModSecurity là một tường lửa ứng dụng web [Web Application Firewall - WAF] mã nguồn mở, đa nền tảng, được sử dụng rộng rãi. Nó hoạt động như một module cho các máy chủ web như Apache, Nginx và IIS, LiteSpeed.

  Mục đích chính của ModSecurity là bảo vệ các ứng dụng web khỏi một loạt các cuộc tấn công mạng, bao gồm:
  * SQL Injection [SQLi]: Kẻ tấn công chèn mã SQL độc hại vào các truy vấn để thao túng cơ sở dữ liệu.
  * Cross-Site Scripting [XSS]: Kẻ tấn công chèn mã độc JavaScript vào các trang web mà người dùng khác sẽ xem.
  * Local File Inclusion [LFI] / Remote File Inclusion [RFI]: Kẻ tấn công lừa ứng dụng web thực thi hoặc hiển thị các tệp tin không mong muốn trên máy chủ hoặc từ xa.
  * Session Hijacking: Kẻ tấn công chiếm đoạt phiên làm việc hợp lệ của người dùng.
  * Command Injection: Kẻ tấn công thực thi các lệnh tùy ý trên hệ điều hành của máy chủ.
  * Denial of Service [DoS] ở tầng ứng dụng: Các cuộc tấn công làm cạn kiệt tài nguyên của ứng dụng web.
  Và nhiều loại lỗ hổng và tấn công khác.

  Ghi chú: Khi kích hoạt ModSecurity sẽ làm giảm khá khá hiệu suất tốc độ của website do máy chủ phải phân tích sâu từng gói tin.
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null # Nạp thư viện UI Xác nhận

clear
echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}${bao_mat} ➜ Bật / Tắt Tường lửa ModSecurity (WAF)${C_RESET}"
echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

config_file="/usr/local/lsws/conf/httpd_config.conf"
path_owasp="/usr/local/lsws/modsec/owasp"

# ==============================================================================
# KIỂM TRA TRẠNG THÁI HIỆN TẠI
# ==============================================================================
is_modsec_active=0
if grep -q 'module mod_security' "$config_file" 2>/dev/null; then
  is_modsec_active=1
fi

echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
if [[ $is_modsec_active -eq 1 ]]; then
  left_text "Trạng thái WAF : ${C_GREEN}ĐANG BẬT (Active)${C_RESET}" 2
  left_text "Bộ quy tắc     : OWASP Core Rule Set (CRS 3.0)" 2
else
  left_text "Trạng thái WAF : ${C_YELLOW}ĐANG TẮT (Inactive)${C_RESET}" 2
fi
echo -e "${C_CYAN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
left_text "ModSecurity là tường lửa cấp ứng dụng, giúp chặn đứng SQL Injection," 2
left_text "XSS, và hàng loạt rủi ro bảo mật khác trên toàn bộ Server." 2
echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

# ==============================================================================
# NHÁNH 1: ĐANG TẮT -> HỎI ĐỂ BẬT LÊN
# ==============================================================================
if [[ $is_modsec_active -eq 0 ]]; then
  if wptt_xac_nhan "Bạn có muốn KÍCH HOẠT Tường lửa ModSecurity không?" "LƯU Ý: ModSecurity kiểm tra sâu từng gói tin, do đó nó sẽ" "tiêu thụ thêm một phần tài nguyên CPU và làm web chậm hơn đôi chút." "Đồng ý BẬT WAF" "Hủy thao tác"; then
    echo ""

    _runing "Đang dọn dẹp môi trường và chuẩn bị cấu hình..."
    rm -rf "$path_owasp"
    mkdir -p "$path_owasp"
    _rundone "Môi trường cấu hình đã sẵn sàng"

    _runing "Đang tải xuống OWASP Core Rule Set từ Github..."
    cd "$path_owasp" || exit 1
    wget -q https://github.com/coreruleset/coreruleset/archive/v4.12.0/master.zip

    if [[ ! -f "$path_owasp/master.zip" ]]; then
      _runloi "Tải xuống thất bại! Vui lòng kiểm tra lại kết nối mạng."
      [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-bao-mat-main 1
      exit 1
    fi
    _rundone "Tải xuống OWASP thành công"

    _runing "Đang giải nén và thiết lập Rule Set (Quy tắc bảo mật)..."
    unzip -oq "$path_owasp/master.zip"
    mv "$path_owasp/coreruleset-4.12.0" "$path_owasp/crs30"
    rm -f "$path_owasp/master.zip"

    path30="$path_owasp/crs30"
    mv "$path30/crs-setup.conf.example" "$path30/crs-setup.conf"

    path1="$path30/rules"
    mv "$path1/REQUEST-900-EXCLUSION-RULES-BEFORE-CRS.conf.example" "$path1/REQUEST-900-EXCLUSION-RULES-BEFORE-CRS.conf"
    mv "$path1/RESPONSE-999-EXCLUSION-RULES-AFTER-CRS.conf.example" "$path1/RESPONSE-999-EXCLUSION-RULES-AFTER-CRS.conf"

    cat <<EOF >"$path30/owasp-master.conf"
include /usr/local/lsws/modsec/owasp/crs30/crs-setup.conf
include /usr/local/lsws/modsec/owasp/crs30/rules/REQUEST-900-EXCLUSION-RULES-BEFORE-CRS.conf
include /usr/local/lsws/modsec/owasp/crs30/rules/REQUEST-901-INITIALIZATION.conf
include /usr/local/lsws/modsec/owasp/crs30/rules/REQUEST-905-COMMON-EXCEPTIONS.conf
include /usr/local/lsws/modsec/owasp/crs30/rules/REQUEST-911-METHOD-ENFORCEMENT.conf
include /usr/local/lsws/modsec/owasp/crs30/rules/REQUEST-913-SCANNER-DETECTION.conf
include /usr/local/lsws/modsec/owasp/crs30/rules/REQUEST-920-PROTOCOL-ENFORCEMENT.conf
include /usr/local/lsws/modsec/owasp/crs30/rules/REQUEST-921-PROTOCOL-ATTACK.conf
include /usr/local/lsws/modsec/owasp/crs30/rules/REQUEST-922-MULTIPART-ATTACK.conf
include /usr/local/lsws/modsec/owasp/crs30/rules/REQUEST-930-APPLICATION-ATTACK-LFI.conf
include /usr/local/lsws/modsec/owasp/crs30/rules/REQUEST-931-APPLICATION-ATTACK-RFI.conf
include /usr/local/lsws/modsec/owasp/crs30/rules/REQUEST-932-APPLICATION-ATTACK-RCE.conf
include /usr/local/lsws/modsec/owasp/crs30/rules/REQUEST-933-APPLICATION-ATTACK-PHP.conf
include /usr/local/lsws/modsec/owasp/crs30/rules/REQUEST-941-APPLICATION-ATTACK-XSS.conf
include /usr/local/lsws/modsec/owasp/crs30/rules/REQUEST-942-APPLICATION-ATTACK-SQLI.conf
include /usr/local/lsws/modsec/owasp/crs30/rules/REQUEST-943-APPLICATION-ATTACK-SESSION-FIXATION.conf
include /usr/local/lsws/modsec/owasp/crs30/rules/REQUEST-949-BLOCKING-EVALUATION.conf
include /usr/local/lsws/modsec/owasp/crs30/rules/RESPONSE-950-DATA-LEAKAGES.conf
include /usr/local/lsws/modsec/owasp/crs30/rules/RESPONSE-951-DATA-LEAKAGES-SQL.conf
include /usr/local/lsws/modsec/owasp/crs30/rules/RESPONSE-953-DATA-LEAKAGES-PHP.conf
include /usr/local/lsws/modsec/owasp/crs30/rules/RESPONSE-959-BLOCKING-EVALUATION.conf
include /usr/local/lsws/modsec/owasp/crs30/rules/RESPONSE-980-CORRELATION.conf
include /usr/local/lsws/modsec/owasp/crs30/rules/RESPONSE-999-EXCLUSION-RULES-AFTER-CRS.conf
EOF
    _rundone "Thiết lập Core Rule Set hoàn tất"

    _runing "Đang tích hợp ModSecurity vào OpenLiteSpeed..."
    cat <<EOF >>"$config_file"

module mod_security {
  modsecurity  on
  modsecurity_rules \`
    SecRuleEngine On
  \`
  modsecurity_rules_file         /usr/local/lsws/modsec/owasp/crs30/owasp-master.conf
}
EOF
    /usr/local/lsws/bin/lswsctrl reload >/dev/null 2>&1
    echo "Kích hoạt ModSecurity : $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log
    _rundone "Cập nhật Server Core thành công"

    # BẢNG BÁO CÁO BẬT
    echo -e "\n${C_GREEN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
    center_text "${C_BOLD_WHITE}HOÀN TẤT KÍCH HOẠT TƯỜNG LỬA WAF${C_RESET}"
    echo -e "${C_GREEN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
    left_text "Toàn bộ máy chủ của bạn hiện đã được bảo vệ bởi ModSecurity" 2
    left_text "cùng hệ thống quy tắc OWASP Core Rule Set chuyên nghiệp." 2
    echo -e "${C_GREEN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

  else
    echo -e "${C_YELLOW}Đã hủy thao tác kích hoạt WAF.${C_RESET}\n"
  fi

# ==============================================================================
# NHÁNH 2: ĐANG BẬT -> HỎI ĐỂ TẮT ĐI
# ==============================================================================
else
  if wptt_xac_nhan "Bạn có CHẮC CHẮN muốn TẮT Tường lửa ModSecurity không?" "Việc tắt WAF sẽ giúp giải phóng tài nguyên và tăng tốc độ xử lý," "nhưng máy chủ sẽ không còn được bảo vệ chống lại các tấn công Web." "Đồng ý TẮT WAF" "Hủy thao tác"; then
    echo ""

    _runing "dọn dẹp thư mục cấu hình Rule Set..."
    rm -rf "$path_owasp"
    _rundone "dọn dẹp thư mục cấu hình Rule Set..."

    _runing "gỡ bỏ cấu hình ModSecurity khỏi OpenLiteSpeed..."
    # SÁT CHIÊU SED: Xóa theo vùng (Range Address) an toàn 100%
    sed -i '/^[[:space:]]*module mod_security/,/^[[:space:]]*}/d' "$config_file"

    /usr/local/lsws/bin/lswsctrl reload >/dev/null 2>&1
    echo "Tắt ModSecurity : $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log
    _rundone "gỡ bỏ cấu hình ModSecurity khỏi OpenLiteSpeed..."

    # BẢNG BÁO CÁO TẮT
    echo -e "\n${C_GREEN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
    center_text "${C_BOLD_WHITE}HOÀN TẤT GỠ BỎ TƯỜNG LỬA WAF${C_RESET}"
    echo -e "${C_GREEN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
    left_text "Tường lửa ModSecurity đã được TẮT hoàn toàn. Máy chủ của bạn" 2
    left_text "sẽ hoạt động với tốc độ và hiệu suất tối đa (Raw Performance)." 2
    echo -e "${C_GREEN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

  else
    echo -e "${C_YELLOW}Đã hủy thao tác tắt WAF.${C_RESET}\n"
  fi
fi

[[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-bao-mat-main 1
