#!/bin/bash

function huong_dan() {
  Quét virus ClamAV là một công cụ quét virus mã nguồn mở, miễn phí và rất phổ biến trên các hệ điều hành Linux. Tính năng chính của nó là giúp phát hiện và loại bỏ các phần mềm độc hại như virus, trojans, worms, và các mối đe dọa khác. Nếu bạn không có nhu cầu cần sử dụng có thể dùng tính năng này để xoá cài đặt để giải phóng dung lượng cho máy chủ
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null # Nạp thư viện UX Bo Cong

clear
echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}BẢO MẬT ➜ Gỡ bỏ Phần mềm Diệt Virus (ClamAV & Maldet)${C_RESET}"
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

if [[ "${1:-}" == '98' ]]; then
  WPTT_IN_MENU="yes"
  WPTT_MENU_BACK="/etc/wptt/wptt-bao-mat-main 1"
fi

if [[ ! -d "/usr/local/maldetect" && ! -d "/var/lib/clamav" ]]; then
  echo -e "${C_YELLOW}⚠️ THÔNG BÁO: Máy chủ của bạn chưa cài đặt (hoặc đã gỡ) phần mềm diệt virus!${C_RESET}\n"
  sleep 2
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-bao-mat-main 1
  exit 0
fi

# ==============================================================================
# CẢNH BÁO XÁC NHẬN AN TOÀN
# ==============================================================================
if ! wptt_xac_nhan "⚠️ BẠN CÓ CHẮC CHẮN MUỐN GỠ CÀI ĐẶT DIỆT VIRUS?" \
  "Hành động này sẽ xóa toàn bộ hệ thống ClamAV, Maldetect," \
  "cũng như dọn dẹp sạch sẽ lịch sử và dữ liệu cách ly mã độc." \
  "Đồng ý GỠ CÀI ĐẶT" "Hủy thao tác"; then
  echo -e "${C_YELLOW}Đã hủy thao tác.${C_RESET}\n"
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-bao-mat-main 1
  exit 0
fi

echo ""

# ==============================================================================
# NHẬN DIỆN HỆ ĐIỀU HÀNH
# ==============================================================================
if grep -qi "ubuntu" /etc/*release 2>/dev/null || grep -qi "debian" /etc/*release 2>/dev/null; then
  OS_TYPE="debian"
else
  OS_TYPE="rhel"
fi

# ==============================================================================
# BƯỚC 1: DỪNG CÁC TIẾN TRÌNH QUÉT NGẦM
# ==============================================================================
_runing "Bước 1/3: Đang dừng các dịch vụ quét và tự động cập nhật ngầm..."
if [[ "$OS_TYPE" == "rhel" ]]; then
  systemctl stop clamav-server@scan >/dev/null 2>&1
  systemctl stop clamav-freshclam >/dev/null 2>&1
elif [[ "$OS_TYPE" == "debian" ]]; then
  systemctl stop clamav-daemon >/dev/null 2>&1
  systemctl stop clamav-freshclam >/dev/null 2>&1
fi
_rundone "Đã tắt các dịch vụ nền thành công"

# ==============================================================================
# BƯỚC 2: GỠ BỎ MALDETECT VÀ CRONJOB
# ==============================================================================
_runing "Bước 2/3: Đang gỡ bỏ hạt nhân Linux Malware Detect (Maldetect)..."
if [[ -f "/usr/local/maldetect/uninstall.sh" ]]; then
  bash /usr/local/maldetect/uninstall.sh >/dev/null 2>&1
fi

# Quét dọn thủ công triệt để
rm -rf /usr/local/maldetect
rm -f /etc/cron.daily/maldet
rm -f /etc/cron.d/maldet_pub
rm -rf /var/log/maldetect
_rundone "Đã gỡ bỏ Maldetect và dọn sạch dữ liệu cách ly"

# ==============================================================================
# BƯỚC 3: GỠ BỎ CLAMAV VÀ LÀM SẠCH HỆ THỐNG
# ==============================================================================
_runing "Bước 3/3: Đang gỡ bỏ lõi ClamAV và giải phóng dung lượng ổ cứng..."
if [[ "$OS_TYPE" == "rhel" ]]; then
  yum remove clamav-server clamav-update clamav-filesystem clamav clamav-scanner-systemd clamav-devel clamav-lib clamav-server-systemd -y -q >/dev/null 2>&1
  rm -rf /etc/clamd.d
  rm -rf /var/lib/clamav
  rm -f /etc/freshclam.conf
  rm -f /etc/freshclam.conf.rpmsave
elif [[ "$OS_TYPE" == "debian" ]]; then
  export DEBIAN_FRONTEND=noninteractive
  apt-get remove --purge clamav clamav-daemon clamav-base libclamav9 -y -q >/dev/null 2>&1
  apt-get autoremove -y -q >/dev/null 2>&1
  rm -rf /etc/clamav
  rm -rf /var/lib/clamav
  rm -rf /var/log/clamav
fi
_rundone "Đã gỡ bỏ ClamAV thành công"

echo -e "${C_GREEN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_BOLD_WHITE}HOÀN TẤT GỠ BỎ PHẦN MỀM DIỆT VIRUS${C_RESET}"
echo -e "${C_GREEN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
left_text "Hệ thống đã được làm sạch hoàn toàn 100%." 2
left_text "Toàn bộ dung lượng ổ cứng (Database, File Log) đã được giải phóng." 2
echo -e "${C_GREEN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

[[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-bao-mat-main 1
