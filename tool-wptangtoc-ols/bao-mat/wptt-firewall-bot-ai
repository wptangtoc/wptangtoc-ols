function huong_dan() {
  Tính năng Bật/Tắt Tường lửa Block AI Crawlers:

  * Tiết kiệm tài nguyên: Các Bot AI quét dữ liệu rất hung hãn, gây tốn CPU và làm chậm website. Chặn chúng giúp server nhẹ gánh hơn.
  * Bảo vệ bản quyền: Ngăn chặn các công ty AI lấy bài viết chất xám của bạn để huấn luyện miễn phí.
  * Ưu tiên người dùng: Dành trọn băng thông cho khách truy cập thật và Google Bot [SEO].
  * Hủy kích hoạt [Tắt]: Mở cửa cho phép các Bot AI [ChatGPT, Claude, CCBot...] truy cập lại website. Cần thiết nếu bạn muốn làm SEO cho các mô hình tìm kiếm AI [AI Search].

  Đừng để AI xài chùa tài nguyên của bạn! Tính năng này sẽ đá bay các con bot của OpenAI, Anthropic,... ra khỏi server.
  Bạn có thể dễ dàng Bật/Tắt bằng 1 cú chạm.
}

. /etc/wptt/.wptt.conf
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh
. /etc/wptt/echo-color

echo -e "\n========================================================================="
echo -e "|$bao_mat => Bật / Tắt Tường lửa Chặn BOT AI Crawlers        |"
echo -e "=========================================================================\n"

function lua_chon_NAME() {
  NAME=""
  if [[ -n "$(ls -A /etc/wptt/vhost 2>/dev/null)" ]]; then
    selects=()

    # Vòng lặp Globbing siêu tốc không qua sub-shell
    for filepath in /etc/wptt/vhost/.*.conf; do
      [[ ! -f "$filepath" || "$filepath" == *"/..conf" ]] && continue

      local domain="${filepath##*/}"
      domain="${domain%.conf}"
      domain="${domain#.}"

      if [[ "$domain" == ?*.?* ]]; then
        local htaccess_path="/usr/local/lsws/$domain/html/.htaccess"
        if [[ -f "$htaccess_path" ]]; then
          if grep -q '#begin-tuong-lua-block-bot-ai' "$htaccess_path" 2>/dev/null; then
            selects+=("$domain [Đang BẬT Chặn AI]")
          else
            selects+=("$domain [Đang TẮT]")
          fi
        fi
      fi
    done

    # Xử lý trường hợp không có website nào hợp lệ (không có file .htaccess)
    if [[ ${#selects[@]} -eq 0 ]]; then
      echo -e "\n\033[1;33mKhông tìm thấy website nào có file .htaccess trên hệ thống để thao tác!\033[0m"
      sleep 3
      exec /etc/wptt/wptt-bao-mat-main 1
    fi

    # [NÂNG CẤP UX] Nếu có từ 2 website trở lên mới hiển thị tùy chọn "TẤT CẢ" ở CUỐI MENU
    if [[ ${#selects[@]} -ge 2 ]]; then
      selects+=("TẤT CẢ WEBSITE (Thao tác đồng loạt)")
    fi

    PS3=$'\n'"-//- Lựa chọn website bạn muốn Bật/Tắt Chặn BOT AI [0=Thoát]: "
    select select in "${selects[@]}"; do
      NAME=$select
      break
    done
  else
    clear
    echo "$khong_co_domain_nao_ton_tai_tren_he_thong"
    exit
  fi
}

# Nếu gọi script kèm tên domain từ command line
if [[ -n "$1" && "$1" != "98" ]]; then
  NAME="$1"
else
  lua_chon_NAME
fi

# Tách lấy tên chuẩn (cắt phần đuôi trạng thái)
NAME=$(echo "$NAME" | cut -f1 -d ' ')

# --- CHỐT CHẶN THOÁT HIỂM ---
[[ "$NAME" == "0" || -z "$NAME" ]] && exec /etc/wptt/wptt-bao-mat-main 1

path_firewall_rules="/etc/wptt/bao-mat/firewall-bot-ai.txt"
[[ ! -f "$path_firewall_rules" ]] && {
  _runloi "Không tìm thấy bộ quy tắc Chặn BOT AI tại hệ thống (/etc/wptt/bao-mat/firewall-bot-ai.txt)!"
  exit
}

# ==============================================================================
# HÀM THỰC THI BẬT/TẮT TƯỜNG LỬA CHẶN AI CHO 1 DOMAIN
# ==============================================================================
function process_firewall_bot_ai() {
  local target_domain=$1
  local action=$2 # "bat" hoac "tat"
  local path_ht="/usr/local/lsws/$target_domain/html/.htaccess"

  if [[ ! -f "$path_ht" ]]; then
    echo "Bỏ qua $target_domain: Không tìm thấy file .htaccess"
    return
  fi

  if [[ "$action" == "bat" ]]; then
    if grep -q '#begin-tuong-lua-block-bot-ai' "$path_ht" 2>/dev/null; then
      echo "Website $target_domain đã bật Chặn AI trước đó. Bỏ qua..."
      return
    fi

    UI_STRING="Kích hoạt Tường lửa Chặn BOT AI cho $target_domain"
    _runing "$UI_STRING"

    # 1. Dọn dẹp bản cũ (nếu có lỗi sót lại) bằng SED thuần túy
    sed -i '/^#begin-tuong-lua-block-bot-ai/,/^#end-tuong-lua-block-bot-ai$/d' "$path_ht"

    # 2. Tiêm Quy tắc lên đỉnh file (Bảo toàn Quyền sở hữu) bằng mktemp an toàn
    TMP_FILE=$(mktemp)
    cat "$path_firewall_rules" >"$TMP_FILE"
    echo "" >>"$TMP_FILE" # Chèn 1 dòng trống cho thoáng code
    cat "$path_ht" >>"$TMP_FILE"
    cat "$TMP_FILE" >"$path_ht"
    rm -f "$TMP_FILE"

    # 3. Update htaccess cache Vhost nếu bật chế độ htaccess tĩnh
    vhost_chuyen_htaccess=""
    . /etc/wptt/vhost/.$target_domain.conf
    [[ -n "$vhost_chuyen_htaccess" ]] && /etc/wptt/wptt-htaccess-tat-chuyen-doi-vhost "$target_domain" >/dev/null 2>&1

    echo "Bật Chặn BOT AI website $target_domain: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log
    _rundone "$UI_STRING"

  elif [[ "$action" == "tat" ]]; then
    if ! grep -q '#begin-tuong-lua-block-bot-ai' "$path_ht" 2>/dev/null; then
      echo "Website $target_domain chưa bật Chặn AI. Bỏ qua..."
      return
    fi

    UI_STRING="Tắt (Hủy) Tường lửa Chặn BOT AI cho $target_domain"
    _runing "$UI_STRING"

    # Dọn dẹp sạch sẽ block cấu hình bằng SED thuần túy
    sed -i -e '/^#begin-tuong-lua-block-bot-ai/,/^#end-tuong-lua-block-bot-ai$/d' "$path_ht"

    # Update htaccess cache Vhost
    vhost_chuyen_htaccess=""
    . /etc/wptt/vhost/.$target_domain.conf
    [[ -n "$vhost_chuyen_htaccess" ]] && /etc/wptt/wptt-htaccess-tat-chuyen-doi-vhost "$target_domain" >/dev/null 2>&1

    echo "Tắt Chặn BOT AI website $target_domain: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log
    _rundone "$UI_STRING"
  fi
}

# ==============================================================================
# XỬ LÝ LÔGIC RẼ NHÁNH
# ==============================================================================

if [[ "$NAME" == "TẤT CẢ WEBSITE (Thao tác đồng loạt)" || "$NAME" == "TẤT" ]]; then
  # Người dùng chọn TẤT CẢ WEBSITE
  echo -e "\nBạn muốn BẬT hay TẮT Tường lửa Chặn BOT AI cho \033[1;33mTẤT CẢ\033[0m website?"
  prompt="Lựa chọn của bạn [1-2]: "
  mass_action=""
  options=("BẬT đồng loạt" "TẮT đồng loạt" "Hủy bỏ")
  PS3="$prompt"
  select opt in "${options[@]}"; do
    case "$REPLY" in
    1)
      mass_action="bat"
      break
      ;;
    2)
      mass_action="tat"
      break
      ;;
    3) exec /etc/wptt/wptt-bao-mat-main 1 ;;
    *)
      printf "\nNhập sai, tự động hủy.\n"
      exec /etc/wptt/wptt-bao-mat-main 1
      ;;
    esac
  done

  # Vòng lặp Globbing siêu tốc cho thao tác hàng loạt
  for filepath in /etc/wptt/vhost/.*.conf; do
    [[ ! -f "$filepath" || "$filepath" == *"/..conf" ]] && continue
    domain="${filepath##*/}"
    domain="${domain%.conf}"
    domain="${domain#.}"
    if [[ "$domain" == ?*.?* ]]; then
      process_firewall_bot_ai "$domain" "$mass_action"
    fi
  done

else
  # Người dùng chọn 1 WEBSITE cụ thể -> Tự động nhận dạng để Đảo Trạng Thái (Toggle)
  pathcheck="/etc/wptt/vhost/.$NAME.conf"
  [[ ! -f "$pathcheck" ]] && {
    echoDo "Tên miền không tồn tại!"
    sleep 2
    exec /etc/wptt/wptt-bao-mat-main 1
  }

  if grep -q '#begin-tuong-lua-block-bot-ai' "/usr/local/lsws/$NAME/html/.htaccess" 2>/dev/null; then
    # Nếu Đang Bật -> Tự động Tắt
    process_firewall_bot_ai "$NAME" "tat"
  else
    # Nếu Đang Tắt -> Tự động Bật
    process_firewall_bot_ai "$NAME" "bat"
  fi
fi

UI_RELOAD="Nạp lại quy tắc Tường lửa và OpenLiteSpeed"
/usr/local/lsws/bin/lswsctrl reload >/dev/null 2>&1

[[ ${1:-} == "98" ]] && exec /etc/wptt/wptt-bao-mat-main 1
