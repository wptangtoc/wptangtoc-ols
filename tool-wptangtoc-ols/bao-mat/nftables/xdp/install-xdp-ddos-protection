# --- Hàm xử lý chính ---
# Hàm này nhận tên map, tìm ID của nó và ghim nếu cần.
pin_map_if_needed() {
  local map_name=$1
  local pin_path="/sys/fs/bpf/${map_name}"

  echo "--- Đang xử lý map: ${map_name} ---"

  # 1. Kiểm tra xem map đã được ghim hay chưa
  if [ -f "${pin_path}" ]; then
    echo "✅ Map '${map_name}' đã được ghim tại ${pin_path}. Bỏ qua."
    return 0
  fi

  echo "ℹ️ Map '${map_name}' chưa được ghim. Đang tìm ID..."

  # 2. Tìm ID của map từ bpftool
  # Lệnh `bpftool map show` sẽ liệt kê tất cả map.
  # `grep "name ${map_name}"` sẽ lọc ra dòng chứa map của chúng ta.
  # `awk -F: '{print $1}'` sẽ lấy phần đầu tiên trước dấu hai chấm (:), chính là ID.
  map_id=$(bpftool map show | grep "name ${map_name}" | awk -F: '{print $1}')

  # 3. Kiểm tra xem có tìm thấy ID không
  if [ -z "${map_id}" ]; then
    echo "❌ Lỗi: Không tìm thấy map nào có tên '${map_name}' đang chạy. Hãy chắc chắn chương trình XDP đã được nạp."
    return 1
  fi

  echo "👍 Đã tìm thấy ID của map '${map_name}': ${map_id}"

  # 4. Thực hiện ghim map
  echo "📌 Đang thực hiện ghim map..."
  bpftool map pin id "${map_id}" "${pin_path}"

  # Kiểm tra lại lần nữa để chắc chắn thành công
  if [ $? -eq 0 ]; then
    echo "✅ Ghim thành công map '${map_name}' vào ${pin_path}."
  else
    echo "❌ Lỗi: Không thể ghim map '${map_name}'. Vui lòng kiểm tra lại."
    return 1
  fi
}

