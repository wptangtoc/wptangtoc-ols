#!/bin/bash
# @author: Gia Tuấn
# @website: https://wptangtoc.com
# @since: 2026

function huong_dan() {
  Tính năng bypass domain vượt qua Hotlinking là một công cụ hữu ích để cân bằng giữa việc bảo vệ tài nguyên máy chủ khỏi bị lạm dụng băng thông và việc cho phép các bên được ủy quyền truy cập và sử dụng các tài nguyên đó một cách hợp pháp. Nó tăng cường khả năng kiểm soát của bạn đối với cách nội dung của bạn được chia sẻ và sử dụng trên internet.
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null # Nạp thư viện xác nhận

clear
echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}BẢO MẬT ➜ Thêm Domain được phép vượt qua Hotlinking (Bypass)${C_RESET}"
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

# ==============================================================================
# HÀM MENU LỌC THÔNG MINH (CHỈ HIỂN THỊ DOMAIN ĐANG BẬT HOTLINKING)
# ==============================================================================
function lua_chon_NAME() {
  unset NAME selects
  selects=()
  local box_inner_width=${box_inner_width:-71}

  for filepath in /etc/wptt/vhost/.*.conf; do
    [[ ! -f "$filepath" || "$filepath" == *"/..conf" ]] && continue
    local domain="${filepath##*/}"
    domain="${domain%.conf}"
    domain="${domain#.}"

    if [[ "$domain" == ?*.?* ]]; then
      local htaccess_path="/usr/local/lsws/$domain/html/.htaccess"
      if [[ -f "$htaccess_path" ]]; then
        # Chỉ quét các domain ĐANG BẬT Hotlinking
        if grep -q '#begin-hotlink-wptangtoc-ols' "$htaccess_path" 2>/dev/null; then
          selects+=("$domain")
        fi
      fi
    fi
  done

  if [[ ${#selects[@]} -eq 0 ]]; then
    echo -e "${C_YELLOW}⚠️ Hiện tại chưa có website nào trên hệ thống BẬT chống Hotlinking!${C_RESET}"
    echo "Vui lòng bật Hotlinking trước khi cấu hình thêm Domain Bypass."
    sleep 3
    exec /etc/wptt/wptt-bao-mat-main 1
  fi

  mapfile -t selects < <(printf "%s\n" "${selects[@]}" | sort -uV)

  echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
  local title_text="Lựa chọn website gốc bạn muốn cấu hình thêm Domain Bypass:"
  local len=$(echo -n "$title_text" | awk '{print length($0)}')
  local pad_r=$((box_inner_width - len - 2))
  [[ $pad_r -lt 0 ]] && pad_r=0
  echo -e "${C_CYAN}│${C_RESET}  ${C_YELLOW}${title_text}${C_RESET}$(printf '%*s' "$pad_r" "")${C_CYAN}│${C_RESET}"

  local line_len=$((len + 3))
  local pad_line_r=$((box_inner_width - line_len))
  [[ $pad_line_r -lt 0 ]] && pad_line_r=0
  local short_line=$(printf "%${line_len}s" "" | sed 's/ /─/g')
  echo -e "${C_CYAN}├${short_line}$(printf '%*s' "$pad_line_r" "")│${C_RESET}"

  local i=1
  for domain in "${selects[@]}"; do
    local item_text=$(printf "  ${C_CYAN}%3d)${C_RESET} ${C_BOLD_WHITE}%s${C_RESET}" "$i" "$domain")
    local clean_text=$(printf "  %3d) %s" "$i" "$domain")
    local item_len=$(echo -n "$clean_text" | awk '{print length($0)}')
    local pad=$((box_inner_width - item_len))
    [[ $pad -lt 0 ]] && pad=0
    echo -e "${C_CYAN}│${C_RESET}${item_text}$(printf '%*s' "$pad" "")${C_CYAN}│${C_RESET}"
    ((i++))
  done
  echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯${C_RESET}"

  local fzf_installed=false
  if command -v fzf &>/dev/null; then
    fzf_installed=true
    PROMPT_TEXT="Nhập lựa chọn (1-${#selects[@]}) [00=Tìm nhanh] [0=Thoát]: "
  else
    PROMPT_TEXT="Nhập lựa chọn (1-${#selects[@]}) [0=Thoát]: "
  fi

  while true; do
    echo -en "${C_CYAN}👉 ${PROMPT_TEXT}${C_RESET}"
    if ! read -r REPLY; then exit 1; fi
    REPLY=$(echo "$REPLY" | tr -d ' ' | tr '[:upper:]' '[:lower:]')

    case "$REPLY" in
    0)
      echo -e "\n${C_GREEN}Đang thoát...${C_RESET}"
      NAME="0"
      return 0
      ;;
    00)
      if $fzf_installed; then
        local selected_name=$(printf '%s\n' "${selects[@]}" | nl -w 3 -s ': ' | fzf --prompt="Tìm website Bypass >> " --height=40% --border=rounded --color=border:red --cycle --reverse)
        selected_name=$(echo "$selected_name" | sed 's/^[[:space:]]*[0-9]\+\:[[:space:]]*//')
        if [[ -n "$selected_name" ]]; then
          NAME="$selected_name"
          return 0
        else echo -e "${C_YELLOW}Đã hủy chọn. Vui lòng chọn lại.${C_RESET}"; fi
      else
        echo -e "${C_RED}Lỗi: FZF chưa cài đặt.${C_RESET}"
      fi
      ;;
    *)
      if [[ "$REPLY" =~ ^[0-9]+$ ]] && [ "$REPLY" -ge 1 ] && [ "$REPLY" -le ${#selects[@]} ]; then
        local action_index=$((REPLY - 1))
        NAME="${selects[$action_index]}"
        return 0
      else
        echo -e "\n${C_RED}❌ Lựa chọn không hợp lệ! Vui lòng chọn lại.${C_RESET}"
      fi
      ;;
    esac
  done
}

lua_chon_NAME

[[ "$NAME" == "0" || -z "$NAME" ]] && {
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-bao-mat-main 1
  return 2>/dev/null || exit
}

path_htaccess="/usr/local/lsws/$NAME/html/.htaccess"

# ==============================================================================
# NỘI SOI FILE .HTACCESS VÀ RENDER BẢNG DANH SÁCH BYPASS HIỆN TẠI
# ==============================================================================
box_inner_width=${box_inner_width:-71}
echo -e "\n${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}DANH SÁCH DOMAIN ĐANG ĐƯỢC CHO PHÉP (BYPASS)${C_RESET}"
echo -e "${C_CYAN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"

# Lọc trong block hotlink, tìm các dòng RewriteCond chứa http, cắt bỏ regex để lấy domain thuần
while read -r line; do
  dom_extracted=$(echo "$line" | awk '{print $3}' | sed 's/.*)?//' | sed 's/ \[NC\]//' | tr -d '\\')

  if [[ -n "$dom_extracted" ]]; then
    if [[ "$dom_extracted" == "$NAME" ]]; then
      left_text "▪ ${C_BOLD_WHITE}$dom_extracted${C_RESET} (Website gốc)" 2
    elif [[ "$dom_extracted" =~ (google.com|bing.com|yahoo.com|facebook.com|pinterest.com|zalo.me) ]]; then
      left_text "▪ $dom_extracted (Mặc định hệ thống)" 2
    else
      left_text "▪ ${C_GREEN}$dom_extracted${C_RESET} (Người dùng thêm)" 2
    fi
  fi
done < <(sed -n '/#begin-hotlink-wptangtoc-ols/,/#end-hotlink-wptangtoc-ols/p' "$path_htaccess" | grep "RewriteCond %{HTTP_REFERER} \!^http")

echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

# ==============================================================================
# NHẬP VÀ XỬ LÝ DOMAIN MỚI
# ==============================================================================
echo -e "Nhập Domain bạn muốn CHO PHÉP hiển thị ảnh/tài nguyên từ website: ${C_GREEN}$NAME${C_RESET}"
echo -e "${C_YELLOW}Ví dụ: cdn.domain.com, doitac.vn${C_RESET}"
echo -en "${C_CYAN}Nhập Domain mới [0=Thoát]: ${C_RESET}"
read -r NAME2

if [[ -z "$NAME2" || "$NAME2" == "0" ]]; then
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-bao-mat-main 1
  exit
fi

# BỘ LỌC THÔNG MINH (SMART SANITIZE)
NAME2="${NAME2//[[:space:]]/}" # 1. Xóa toàn bộ khoảng trắng thừa
NAME2="${NAME2,,}"             # 2. Ép toàn bộ về chữ thường
NAME2="${NAME2#http://}"       # 3. Gọt bỏ http://
NAME2="${NAME2#https://}"      # 4. Gọt bỏ https://
NAME2="${NAME2#www.}"          # 5. Gọt bỏ www.
NAME2="${NAME2%%/*}"           # 6. Cắt bỏ mọi thứ từ dấu / trở về sau

# Regex kiểm tra định dạng domain
if [[ "$NAME2" == "${NAME2/./}" ]]; then
  echo -e "\n${C_RED}❌ Lỗi: Domain nhập không đúng định dạng! (Ví dụ chuẩn: wptangtoc.com)${C_RESET}"
  sleep 3
  exec /etc/wptt/wptt-bao-mat-main 1
fi

# KIỂM TRA TRÙNG LẶP (DUPLICATE CHECK)
if grep -iqE "^[[:space:]]*RewriteCond.*$NAME2" "$path_htaccess" 2>/dev/null; then
  echo -e "\n${C_YELLOW}⚠️ Domain $NAME2 đã tồn tại trong danh sách Bypass rồi!${C_RESET}"
  sleep 3
  exec /etc/wptt/wptt-bao-mat-main 1
fi

# ==============================================================================
# XÁC NHẬN VÀ THỰC THI THÊM BYPASS
# ==============================================================================
echo ""
if wptt_xac_nhan "Bạn có chắc chắn muốn cho phép domain này sử dụng tài nguyên không?" "${C_BOLD_WHITE}Domain Bypass:${C_RESET} ${C_GREEN}$NAME2${C_RESET}" "" "Đồng ý Thêm" "Hủy bỏ"; then
  echo ""
  UI_STRING="Thêm Domain Bypass $NAME2 cho website $NAME"
  _runing "$UI_STRING"

  # Sát chiêu SED: Chèn điều kiện Bypass vào NGAY PHÍA TRÊN dòng RewriteRule chặn đuôi file
  sed -i "/RewriteRule \\\.(jpg|jpeg/i RewriteCond %{HTTP_REFERER} \!^http(s)?:\/\/(www\.)?$NAME2 [NC]" "$path_htaccess"

  /usr/local/lsws/bin/lswsctrl reload >/dev/null 2>&1
  echo "Thêm domain $NAME2 vượt qua Hotlinking cho $NAME: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log

  _rundone "Cấu hình thành công vào file .htaccess"

  echo -e "\n${C_GREEN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_BOLD_WHITE}ĐÃ THÊM DOMAIN BYPASS THÀNH CÔNG${C_RESET}"
  echo -e "${C_GREEN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
  left_text "Website gốc  : ${C_YELLOW}$NAME${C_RESET}"
  left_text "Domain Bypass: ${C_GREEN}$NAME2${C_RESET}"
  left_text "Trạng thái   : Domain mới đã được cấp quyền truy cập tài nguyên static."
  echo -e "${C_GREEN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

else
  echo -e "${C_YELLOW}Đã hủy thao tác thêm Domain.${C_RESET}"
fi

[[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-bao-mat-main 1
