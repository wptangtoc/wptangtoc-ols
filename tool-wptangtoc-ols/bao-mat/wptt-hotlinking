#!/bin/bash
# @author: Gia Tuấn
# @website: https://wptangtoc.com
# @since: 2026

function huong_dan() {
  1. Tính Năng Bật Chống Hotlinking
  Hotlinking [trộm băng thông] là hành động trang web khác dùng trực tiếp link ảnh/tài nguyên trên máy chủ của bạn để hiển thị trên trang của họ.
  Khi BẬT tính năng này:
  * Bảo vệ băng thông và tài nguyên CPU/RAM của máy chủ.
  * Các domain ngoài [trừ google, bing, facebook, zalo...] khi gọi file tĩnh sẽ bị trả về mã lỗi 403 Forbidden.

  2. Tính Năng Tắt [Hủy] Chống Hotlinking
  Là việc gỡ bỏ cấu hình chặn, đưa website về trạng thái mở hoàn toàn.
  Mục đích chính:
  * Khi bạn muốn chia sẻ tài nguyên cho các trang vệ tinh, đối tác.
  * Khi bạn sử dụng các dịch vụ CDN yêu cầu máy chủ gốc phải mở cửa hoàn toàn để pull ảnh.
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null # Nạp thư viện UI Xác nhận

clear
echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}BẢO MẬT ➜ Bật / Tắt chống trộm băng thông (Hotlinking)${C_RESET}"
echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

# ==============================================================================
# HÀM MENU LỌC THÔNG MINH (KÈM TRẠNG THÁI ON/OFF)
# ==============================================================================
function lua_chon_NAME() {
  unset NAME selects
  selects=()
  local box_inner_width=${box_inner_width:-71}

  for filepath in /etc/wptt/vhost/.*.conf; do
    [[ ! -f "$filepath" || "$filepath" == *"/..conf" ]] && continue
    local domain="${filepath##*/}"
    domain="${domain%.conf}"
    domain="${domain#.}"

    if [[ "$domain" == ?*.?* ]]; then
      local htaccess_path="/usr/local/lsws/$domain/html/.htaccess"
      if [[ -f "$htaccess_path" ]]; then
        if grep -q '#begin-hotlink-wptangtoc-ols' "$htaccess_path" 2>/dev/null; then
          selects+=("$domain|[Đang BẬT]")
        else
          selects+=("$domain|[Đang TẮT]")
        fi
      fi
    fi
  done

  if [[ ${#selects[@]} -eq 0 ]]; then
    echo -e "${C_YELLOW}⚠️ Không tìm thấy file .htaccess nào trên hệ thống để thao tác!${C_RESET}"
    sleep 3
    exec /etc/wptt/wptt-bao-mat-main 1
  fi

  # Sắp xếp danh sách
  mapfile -t selects < <(printf "%s\n" "${selects[@]}" | sort -uV)

  # RENDER KHUNG MENU BO CONG
  echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
  local title_text="Lựa chọn website bạn muốn cấu hình Hotlinking:"
  local len=$(echo -n "$title_text" | awk '{print length($0)}')
  local pad_r=$((box_inner_width - len - 2))
  [[ $pad_r -lt 0 ]] && pad_r=0
  echo -e "${C_CYAN}│${C_RESET}  ${C_YELLOW}${title_text}${C_RESET}$(printf '%*s' "$pad_r" "")${C_CYAN}│${C_RESET}"

  local line_len=$((len + 3))
  local pad_line_r=$((box_inner_width - line_len))
  [[ $pad_line_r -lt 0 ]] && pad_line_r=0
  local short_line=$(printf "%${line_len}s" "" | sed 's/ /─/g')
  echo -e "${C_CYAN}├${short_line}$(printf '%*s' "$pad_line_r" "")│${C_RESET}"

  local i=1
  for item in "${selects[@]}"; do
    local dom=$(echo "$item" | cut -d'|' -f1)
    local stt=$(echo "$item" | cut -d'|' -f2)

    local color_dom="${C_BOLD_WHITE}"
    local color_stt="${C_YELLOW}"

    if [[ "$stt" == "[Đang BẬT]" ]]; then color_stt="${C_GREEN}"; fi
    if [[ "$stt" == "[Đang TẮT]" ]]; then color_stt="${C_RED}"; fi

    # Căn trái 35 ký tự cho domain để cột trạng thái luôn thẳng hàng
    local item_text=$(printf "  ${C_CYAN}%3d)${C_RESET} ${color_dom}%-35s${C_RESET} %s" "$i" "$dom" "${color_stt}${stt}${C_RESET}")
    local clean_text=$(printf "  %3d) %-35s %s" "$i" "$dom" "$stt")

    local item_len=$(echo -n "$clean_text" | awk '{print length($0)}')
    local pad=$((box_inner_width - item_len))
    [[ $pad -lt 0 ]] && pad=0
    echo -e "${C_CYAN}│${C_RESET}${item_text}$(printf '%*s' "$pad" "")${C_CYAN}│${C_RESET}"
    ((i++))
  done
  echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯${C_RESET}"

  local fzf_installed=false
  if command -v fzf &>/dev/null; then
    fzf_installed=true
    PROMPT_TEXT="Nhập lựa chọn (1-${#selects[@]}) [00=Tìm nhanh] [0=Thoát]: "
  else
    PROMPT_TEXT="Nhập lựa chọn (1-${#selects[@]}) [0=Thoát]: "
  fi

  while true; do
    echo -en "${C_CYAN}${PROMPT_TEXT}${C_RESET}"
    if ! read -r REPLY; then exit 1; fi
    REPLY=$(echo "$REPLY" | tr -d ' ' | tr '[:upper:]' '[:lower:]')

    case "$REPLY" in
    0)
      echo -e "\n${C_GREEN}Đang thoát...${C_RESET}"
      NAME="0"
      return 0
      ;;
    00)
      if $fzf_installed; then
        local selected_item=$(printf '%s\n' "${selects[@]}" | nl -w 3 -s ': ' | fzf --prompt="Tìm website >> " --height=40% --border=rounded --color=border:red --cycle --reverse)
        local dom=$(echo "$selected_item" | sed 's/^[[:space:]]*[0-9]\+\:[[:space:]]*//' | cut -d'|' -f1)
        if [[ -n "$dom" ]]; then
          NAME="$dom"
          return 0
        else echo -e "${C_YELLOW}Đã hủy chọn. Vui lòng chọn lại.${C_RESET}"; fi
      else
        echo -e "${C_RED}Lỗi: FZF chưa cài đặt.${C_RESET}"
      fi
      ;;
    *)
      if [[ "$REPLY" =~ ^[0-9]+$ ]] && [ "$REPLY" -ge 1 ] && [ "$REPLY" -le ${#selects[@]} ]; then
        local action_index=$((REPLY - 1))
        NAME=$(echo "${selects[$action_index]}" | cut -d'|' -f1)
        return 0
      else
        echo -e "\n${C_RED}❌ Lựa chọn không hợp lệ! Vui lòng chọn lại.${C_RESET}"
      fi
      ;;
    esac
  done
}

lua_chon_NAME

# --- CHỐT CHẶN THOÁT HIỂM ---
[[ "$NAME" == "0" || -z "$NAME" ]] && exec /etc/wptt/wptt-bao-mat-main 1

pathcheck="/etc/wptt/vhost/.$NAME.conf"
if [[ ! -f "$pathcheck" ]]; then
  echo -e "\n${C_RED}❌ Tên miền không tồn tại trên hệ thống này!${C_RESET}"
  sleep 3
  exec /etc/wptt/wptt-bao-mat-main 1
  exit
fi

path_htaccess="/usr/local/lsws/$NAME/html/.htaccess"
if [[ ! -f "$path_htaccess" ]]; then
  echo -e "\n${C_RED}❌ Không tìm thấy file .htaccess tại /usr/local/lsws/$NAME/html/${C_RESET}"
  sleep 3
  exec /etc/wptt/wptt-bao-mat-main 1
  exit
fi

# ==============================================================================
# XỬ LÝ LÔGIC BẬT / TẮT BẰNG WPTT_XAC_NHAN
# ==============================================================================
echo ""
thao_tac_thanh_cong=false
msg_action=""

if grep -q "#begin-hotlink-wptangtoc-ols" "$path_htaccess" 2>/dev/null; then
  # ĐANG BẬT -> HỎI TẮT
  if wptt_xac_nhan "Tính năng này đang BẬT. Bạn có muốn TẮT không?" "${C_BOLD_WHITE}Website:${C_RESET} $NAME" "" "Đồng ý TẮT" "Hủy bỏ"; then
    echo ""
    msg_action="TẮT Hotlinking (Cho phép tải tài nguyên tự do)"
    _runing "Đang gỡ bỏ cấu hình chống Hotlinking..."

    sed -i '/#begin-hotlink-wptangtoc-ols/,/#end-hotlink-wptangtoc-ols/d' "$path_htaccess"
    echo "Tắt Hotlinking website $NAME: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log

    _rundone "Gỡ bỏ cấu hình hoàn tất"
    thao_tac_thanh_cong=true
  fi
else
  # ĐANG TẮT -> HỎI BẬT
  if wptt_xac_nhan "Tính năng này đang TẮT. Bạn có muốn BẬT không?" "${C_BOLD_WHITE}Website:${C_RESET} $NAME" "" "Đồng ý BẬT" "Hủy bỏ"; then
    echo ""
    msg_action="BẬT Hotlinking (Chặn website lạ chèn link ảnh)"
    _runing "Đang chèn cấu hình bảo vệ Hotlinking..."

    # Kỹ thuật tiêm lên đỉnh file .htaccess (Zero-Downtime, Max Performance)
    TMP_FILE=$(mktemp)
    cat <<EOF >"$TMP_FILE"
#begin-hotlink-wptangtoc-ols
RewriteEngine on
RewriteCond %{HTTP_REFERER} !^$
RewriteCond %{HTTP_REFERER} !^http(s)?:\/\/(www\.)?$NAME [NC]
RewriteCond %{HTTP_REFERER} !^http(s)?:\/\/(www\.)?google.com [NC]
RewriteCond %{HTTP_REFERER} !^http(s)?:\/\/(www\.)?bing.com [NC]
RewriteCond %{HTTP_REFERER} !^http(s)?:\/\/(www\.)?yahoo.com [NC]
RewriteCond %{HTTP_REFERER} !^http(s)?:\/\/(www\.)?facebook.com [NC]
RewriteCond %{HTTP_REFERER} !^http(s)?:\/\/(www\.)?pinterest.com [NC]
RewriteCond %{HTTP_REFERER} !^http(s)?:\/\/(www\.)?zalo.me [NC]
RewriteRule \.(jpg|jpeg|png|gif|svg|webp|css|js)$ - [F,NC,L]
#end-hotlink-wptangtoc-ols

EOF
    cat "$path_htaccess" >>"$TMP_FILE"
    cat "$TMP_FILE" >"$path_htaccess"
    rm -f "$TMP_FILE"

    echo "Bật Hotlinking website $NAME: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log
    _rundone "Kích hoạt bảo vệ thành công"
    thao_tac_thanh_cong=true
  fi
fi

# ==============================================================================
# KHỞI ĐỘNG LẠI DỊCH VỤ VÀ IN BÁO CÁO
# ==============================================================================
if $thao_tac_thanh_cong; then
  # _runing "Đang nạp lại cấu hình OpenLiteSpeed..."
  /usr/local/lsws/bin/lswsctrl reload >/dev/null 2>&1
  # _rundone "Nạp lại cấu hình dịch vụ máy chủ"

  echo -e "\n${C_GREEN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_BOLD_WHITE}HOÀN TẤT CẤU HÌNH HOTLINKING${C_RESET}"
  echo -e "${C_GREEN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
  left_text "Website thao tác : ${C_YELLOW}$NAME${C_RESET}"
  left_text "Trạng thái       : ${C_GREEN}$msg_action${C_RESET}"
  echo -e "${C_GREEN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"
else
  echo -e "${C_YELLOW}Đã hủy thao tác cấu hình Hotlinking.${C_RESET}"
fi

[[ ${1:-} == "98" ]] && exec /etc/wptt/wptt-bao-mat-main 1
