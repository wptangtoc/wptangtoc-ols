#!/bin/bash
# @author: Gia Tuấn
# @website: https://wptangtoc.com
# @since: 2026

function huong_dan() {
  Tính năng này triển khai Hotlinking

  Hotlinking [còn được gọi là inline linking, direct linking hoặc bandwidth theft - trộm băng thông] là hành động hiển thị một hình ảnh, video, hoặc các tập tin đa phương tiện khác trên một trang web bằng cách trỏ trực tiếp đến tập tin đó trên máy chủ của một trang web khác, thay vì lưu trữ bản sao của tập tin đó trên máy chủ của trang web hiển thị.

  Nói một cách đơn giản, khi bạn thấy một hình ảnh trên trang web A, nhưng hình ảnh đó thực chất được tải từ máy chủ của trang web B, thì trang web A đang thực hiện hotlinking từ trang web B.

  Nó sẽ chặn nếu website B nào đó yêu cầu những file [jpg | jpeg | png | gif | svg | webp | css | js] sẽ bị chặn ngoại trừ những những domain bạn thiết lập, bạn có thể thiết lập bypass thêm những domain theo mong muốn của bạn.
  Theo mặc định sẽ loại bỏ không chặn những domain là domain của chính bạn, google, zalo, facebook, pinterest, yahoo, bing.
}

. /etc/wptt/.wptt.conf
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh

echo -e "\n========================================================================="
echo -e "|$bao_mat => Bật/Tắt chống trộm băng thông (Hotlinking)                |"
echo -e "=========================================================================\n"

RED='\033[0;31m'
NC='\033[0m'
xanh='\033[0;32m'

# --- 1. HIỂN THỊ BẢNG TRẠNG THÁI NHANH ---
if [[ -n "$(ls -A /etc/wptt/vhost 2>/dev/null)" ]]; then
  echo "Kiểm tra website kích hoạt chống Hotlinking:"
  echo "========================================================================="
  for filepath in /etc/wptt/vhost/.*.conf; do
    [[ ! -f "$filepath" || "$filepath" == *"/..conf" ]] && continue
    domain="${filepath##*/}"
    domain="${domain%.conf}"
    domain="${domain#.}"

    if [[ "$domain" == ?*.?* ]]; then
      htaccess_path="/usr/local/lsws/$domain/html/.htaccess"
      if [[ -f "$htaccess_path" ]]; then
        if grep -q '#begin-hotlink-wptangtoc-ols' "$htaccess_path" 2>/dev/null; then
          echo -e "Hệ thống kiểm tra website \033[1;33m$domain\033[0m tính năng: ${xanh}Đang được bật${NC}"
        else
          echo -e "Hệ thống kiểm tra website \033[1;33m$domain\033[0m tính năng: ${RED}Đang được tắt${NC}"
        fi
      fi
    fi
  done
  echo -e "=========================================================================\n"
fi

. /etc/wptt/tenmien
echo "Lựa chọn website muốn Bật/Tắt Hotlinking: "
lua_chon_NAME
echo ""

. /etc/wptt/echo-color

# --- CHỐT CHẶN THOÁT HIỂM ---
[[ "$NAME" == "0" || -z "$NAME" ]] && exec /etc/wptt/wptt-bao-mat-main 1

path_htaccess="/usr/local/lsws/$NAME/html/.htaccess"

if [[ ! -f "$path_htaccess" ]]; then
  clear
  echoDo "Không tìm thấy file .htaccess hoặc website không tồn tại!"
  sleep 3
  exec /etc/wptt/wptt-bao-mat-main 1
fi

# --- 2. KIỂM TRA TRẠNG THÁI VÀ XỬ LÝ LOGIC ---
is_hotlink_active=$(grep -c "#begin-hotlink-wptangtoc-ols" "$path_htaccess")

if [[ $is_hotlink_active -gt 0 ]]; then
  # TRẠNG THÁI: ĐANG BẬT -> HỎI ĐỂ TẮT
  echo -e "Hiện tại website \033[1;33m$NAME\033[0m \033[1;32mĐANG KÍCH HOẠT\033[0m chống Hotlinking."
  prompt="Bạn có muốn TẮT chống Hotlinking không? [1-2]: "
  dongytat="n"
  options=("Đồng ý TẮT CHẶN" "Không đồng ý (Thoát)")
  PS3="$prompt"
  select opt in "${options[@]}"; do
    case "$REPLY" in
    1)
      dongytat="y"
      break
      ;;
    2)
      dongytat="n"
      break
      ;;
    *)
      printf "\nNhập sai, hệ thống tự động HỦY BỎ.\n"
      break
      ;;
    esac
  done

  if [[ "$dongytat" == "y" ]]; then
    UI_STRING="Tắt Hotlinking của website $NAME"
    _runing "$UI_STRING"
    echo "Tắt hotlinking website $NAME: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log

    # Sát chiêu SED: Xóa toàn bộ khối từ #begin đến #end
    sed -i '/#begin-hotlink-wptangtoc-ols/,/#end-hotlink-wptangtoc-ols/d' "$path_htaccess"

    _rundone "$UI_STRING"
  else
    exec /etc/wptt/wptt-bao-mat-main 1
  fi

else
  # TRẠNG THÁI: ĐANG TẮT -> HỎI ĐỂ BẬT
  echo -e "Hiện tại website \033[1;33m$NAME\033[0m \033[1;31mĐANG KHÔNG KÍCH HOẠT\033[0m chống Hotlinking."
  prompt="Bạn có muốn BẬT chống Hotlinking không? [1-2]: "
  dongybat="n"
  options=("Đồng ý BẬT CHẶN" "Không đồng ý (Thoát)")
  PS3="$prompt"
  select opt in "${options[@]}"; do
    case "$REPLY" in
    1)
      dongybat="y"
      break
      ;;
    2)
      dongybat="n"
      break
      ;;
    *)
      printf "\nNhập sai, hệ thống tự động HỦY BỎ.\n"
      break
      ;;
    esac
  done

  if [[ "$dongybat" == "y" ]]; then
    UI_STRING="Bật Hotlinking của website $NAME"
    _runing "$UI_STRING"
    echo "Bật hotlinking website $NAME: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log

    # Tạo khối cấu hình. Sử dụng [F,NC,L] để trả về 403 Forbidden thay vì Redirect
    cat <<EOF >>"$path_htaccess"
#begin-hotlink-wptangtoc-ols
RewriteEngine on
RewriteCond %{HTTP_REFERER} !^$
RewriteCond %{HTTP_REFERER} !^http(s)?:\/\/(www\.)?$NAME [NC]
RewriteCond %{HTTP_REFERER} !^http(s)?:\/\/(www\.)?google.com [NC]
RewriteCond %{HTTP_REFERER} !^http(s)?:\/\/(www\.)?bing.com [NC]
RewriteCond %{HTTP_REFERER} !^http(s)?:\/\/(www\.)?yahoo.com [NC]
RewriteCond %{HTTP_REFERER} !^http(s)?:\/\/(www\.)?facebook.com [NC]
RewriteCond %{HTTP_REFERER} !^http(s)?:\/\/(www\.)?pinterest.com [NC]
RewriteCond %{HTTP_REFERER} !^http(s)?:\/\/(www\.)?zalo.me [NC]
RewriteRule \.(jpg|jpeg|png|gif|svg|webp|css|js)$ - [F,NC,L]
#end-hotlink-wptangtoc-ols
EOF

    _rundone "$UI_STRING"
  else
    exec /etc/wptt/wptt-bao-mat-main 1
  fi
fi

# Reload Litespeed siêu tốc không gây downtime
/usr/local/lsws/bin/lswsctrl reload >/dev/null 2>&1

# --- FOOTER ---
[[ ${1:-} == "98" ]] && exec /etc/wptt/wptt-bao-mat-main 1
