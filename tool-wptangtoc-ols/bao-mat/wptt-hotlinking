#!/bin/bash
# @author: Gia Tuấn
# @website: https://wptangtoc.com
# @since: 2026

function huong_dan() {
  1. Tính Năng Bật Chống Hotlinking
  Hotlinking [trộm băng thông] là hành động trang web khác dùng trực tiếp link ảnh/tài nguyên trên máy chủ của bạn để hiển thị trên trang của họ.
  Khi BẬT tính năng này:
  * Bảo vệ băng thông và tài nguyên CPU/RAM của máy chủ.
  * Các domain ngoài [trừ google, bing, facebook, zalo...] khi gọi file tĩnh sẽ bị trả về mã lỗi 403 Forbidden.

  2. Tính Năng Tắt [Hủy] Chống Hotlinking
  Là việc gỡ bỏ cấu hình chặn, đưa website về trạng thái mở hoàn toàn.
  Mục đích chính:
  * Khi bạn muốn chia sẻ tài nguyên cho các trang vệ tinh, đối tác.
  * Khi bạn sử dụng các dịch vụ CDN yêu cầu máy chủ gốc phải mở cửa hoàn toàn để pull ảnh.
}

. /etc/wptt/.wptt.conf
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh
. /etc/wptt/echo-color

echo -e "\n========================================================================="
echo -e "|$bao_mat => Bật / Tắt chống trộm băng thông [Hotlinking]              |"
echo -e "=========================================================================\n"

function lua_chon_NAME() {
  NAME=""
  if [ "$(ls -At /etc/wptt/vhost 2>/dev/null)" ]; then

    selects=()
    for filepath in /etc/wptt/vhost/.*.conf; do
      [[ ! -f "$filepath" || "$filepath" == *"/..conf" ]] && continue

      domain="${filepath##*/}"
      domain="${domain%.conf}"
      domain="${domain#.}"

      if [[ "$domain" == ?*.?* ]]; then
        local htaccess_path="/usr/local/lsws/$domain/html/.htaccess"
        if [[ -f "$htaccess_path" ]]; then
          if grep -q '#begin-hotlink-wptangtoc-ols' "$htaccess_path" 2>/dev/null; then
            selects+=("$domain [Đang BẬT Hotlinking]")
          else
            selects+=("$domain [Đang TẮT Hotlinking]")
          fi
        fi
      fi
    done

    if [[ ${#selects[@]} -eq 0 ]]; then
      echo "Tất cả domain trên hệ thống không tồn tại file .htaccess để thao tác."
      exec /etc/wptt/wptt-bao-mat-main 1
    fi

    PS3=$'\n'"-//- $lua_chon_website_ban_muon [0=$exit_thoat]: "
    select select in "${selects[@]}"; do
      NAME=$select
      break
    done
  else
    clear
    echo "$khong_co_domain_nao_ton_tai_tren_he_thong"
    exit
  fi
}

lua_chon_NAME

# Tách lấy tên domain chuẩn (Cắt bỏ phần trạng thái phía sau dấu cách)
NAME=$(echo "$NAME" | cut -f1 -d ' ')

# --- CHỐT CHẶN THOÁT HIỂM ---
[[ "$NAME" == "0" || -z "$NAME" ]] && exec /etc/wptt/wptt-bao-mat-main 1

pathcheck="/etc/wptt/vhost/.$NAME.conf"
if [[ ! -f "$pathcheck" ]]; then
  clear
  echoDo "Tên miền không tồn tại trên hệ thống này"
  sleep 3
  exec /etc/wptt/wptt-bao-mat-main 1
  exit
fi

path_htaccess="/usr/local/lsws/$NAME/html/.htaccess"
if [[ ! -f "$path_htaccess" ]]; then
  clear
  echoDo "Không tìm thấy file .htaccess tại /usr/local/lsws/$NAME/html/"
  sleep 3
  exec /etc/wptt/wptt-bao-mat-main 1
  exit
fi

unset da_setup_mods
# Kịch bản rẽ nhánh trạng thái
if grep -q "#begin-hotlink-wptangtoc-ols" "$path_htaccess" 2>/dev/null; then
  da_setup_mods='1' # Đang bật
else
  da_setup_mods='0' # Đang tắt
fi

# ==============================================================================
# NHÁNH 1: ĐANG TẮT -> HỎI ĐỂ BẬT LÊN
# ==============================================================================
if [[ $da_setup_mods = '0' ]]; then
  echo -e "\nXác nhận KÍCH HOẠT chống Hotlinking cho website \033[1;33m$NAME\033[0m"
  prompt="Nhập lựa chọn của bạn [1-2]: "
  dongy="n"
  options=("Đồng ý BẬT" "Không đồng ý [Thoát]")
  PS3="$prompt"
  select opt in "${options[@]}"; do
    case "$REPLY" in
    1)
      dongy="y"
      break
      ;;
    2)
      dongy="n"
      break
      ;;
    *)
      printf "\nBạn nhập sai, hệ thống tự động chọn Không đồng ý\n"
      break
      ;;
    esac
  done

  if [[ "$dongy" == "y" ]]; then
    UI_STRING="Bật chống Hotlinking website $NAME"
    _runing "$UI_STRING"

    # Kỹ thuật tiêm lên đỉnh file .htaccess (Zero-Downtime, Max Performance)
    TMP_FILE=$(mktemp)
    cat <<EOF >"$TMP_FILE"
#begin-hotlink-wptangtoc-ols
RewriteEngine on
RewriteCond %{HTTP_REFERER} !^$
RewriteCond %{HTTP_REFERER} !^http(s)?:\/\/(www\.)?$NAME [NC]
RewriteCond %{HTTP_REFERER} !^http(s)?:\/\/(www\.)?google.com [NC]
RewriteCond %{HTTP_REFERER} !^http(s)?:\/\/(www\.)?bing.com [NC]
RewriteCond %{HTTP_REFERER} !^http(s)?:\/\/(www\.)?yahoo.com [NC]
RewriteCond %{HTTP_REFERER} !^http(s)?:\/\/(www\.)?facebook.com [NC]
RewriteCond %{HTTP_REFERER} !^http(s)?:\/\/(www\.)?pinterest.com [NC]
RewriteCond %{HTTP_REFERER} !^http(s)?:\/\/(www\.)?zalo.me [NC]
RewriteRule \.(jpg|jpeg|png|gif|svg|webp|css|js)$ - [F,NC,L]
#end-hotlink-wptangtoc-ols

EOF
    cat "$path_htaccess" >>"$TMP_FILE"
    cat "$TMP_FILE" >"$path_htaccess"
    rm -f "$TMP_FILE"

    /usr/local/lsws/bin/lswsctrl reload >/dev/null 2>&1
    echo "Bật Hotlinking website $NAME: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log
    _rundone "$UI_STRING"
  fi
fi

# ==============================================================================
# NHÁNH 2: ĐANG BẬT -> HỎI ĐỂ TẮT ĐI
# ==============================================================================
if [[ $da_setup_mods = '1' ]]; then
  echo -e "\nXác nhận TẮT chống Hotlinking cho website \033[1;33m$NAME\033[0m"
  prompt="Nhập lựa chọn của bạn [1-2]: "
  dongy="n"
  options=("Đồng ý TẮT" "Không đồng ý [Thoát]")
  PS3="$prompt"
  select opt in "${options[@]}"; do
    case "$REPLY" in
    1)
      dongy="y"
      break
      ;;
    2)
      dongy="n"
      break
      ;;
    *)
      printf "\nBạn nhập sai, hệ thống tự động chọn Không đồng ý\n"
      break
      ;;
    esac
  done

  if [[ "$dongy" == "y" ]]; then
    UI_STRING="Tắt Hotlinking website $NAME"
    _runing "$UI_STRING"

    sed -i '/#begin-hotlink-wptangtoc-ols/,/#end-hotlink-wptangtoc-ols/d' "$path_htaccess"

    /usr/local/lsws/bin/lswsctrl reload >/dev/null 2>&1
    echo "Tắt Hotlinking website $NAME: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log
    _rundone "$UI_STRING"
  fi
fi

[[ ${1:-} == "98" ]] && exec /etc/wptt/wptt-bao-mat-main 1
