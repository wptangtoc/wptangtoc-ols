#!/bin/bash

function huong_dan() {
  Tính năng thiết lập kích hoạt.
  Nếu ai đó truy cập vào SSH của bạn, ngay lập tức nó sẽ thông báo qua telegram về thời gian đăng nhập, ip đăng nhập...
  Để bạn dễ dàng kiểm soát hệ thống
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null # Nạp thư viện UX Bo Cong

clear
echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}BẢO MẬT ➜ Cảnh báo đăng nhập SSH qua Telegram${C_RESET}"
echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

if [[ "${1:-}" == '98' ]]; then
  WPTT_IN_MENU="yes"
  WPTT_MENU_BACK="/etc/wptt/wptt-ssh-main 1"
fi

# ==============================================================================
# KIỂM TRA ĐIỀU KIỆN TIÊN QUYẾT (API TELEGRAM)
# ==============================================================================
if [[ -z "$telegram_api" || -z "$telegram_id" ]]; then
  echo -e "${C_RED}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_BOLD_WHITE}YÊU CẦU THIẾT LẬP TELEGRAM BOT${C_RESET}"
  echo -e "${C_RED}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
  left_text "Bạn chưa kết nối máy chủ với Telegram Bot!" 2
  left_text "Vui lòng thiết lập API Token và Chat ID trước khi sử dụng." 2
  echo -e "${C_RED}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

  echo -en "${C_GREEN}Nhấn phím [Enter] để chuyển tới giao diện Cài đặt Telegram...${C_RESET}"
  read -r dummy

  # Chuyển hướng sang Script cài đặt Telegram
  . /etc/wptt/bao-mat/wptt-telegram "ssh"

  # Tải lại cấu hình sau khi cài đặt xong
  . /etc/wptt/.wptt.conf 2>/dev/null

  # Nếu quay lại mà vẫn chưa cài đặt xong thì thoát
  if [[ -z "$telegram_api" || -z "$telegram_id" ]]; then
    echo -e "\n${C_YELLOW}Bạn vẫn chưa hoàn tất cấu hình Telegram. Hủy kích hoạt tính năng!${C_RESET}"
    sleep 2
    [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-ssh-main 1
    exit 1
  fi

  # Nếu đã cài xong, vẽ lại Header cho đẹp
  clear
  echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_YELLOW}BẢO MẬT ➜ Cảnh báo đăng nhập SSH qua Telegram${C_RESET}"
  echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"
fi

# ==============================================================================
# KIỂM TRA TRẠNG THÁI HIỆN TẠI VÀ IN BẢNG THÔNG BÁO
# ==============================================================================
echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
if [[ "$thong_bao_login_ssh" == "1" ]]; then
  left_text "Trạng thái    : ${C_GREEN}ĐÃ KÍCH HOẠT${C_RESET}" 2
  echo -e "${C_CYAN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
  left_text "Mỗi khi có người truy cập vào SSH (Thành công), hệ thống sẽ" 2
  left_text "ngay lập tức gửi tin nhắn báo động về Telegram của bạn." 2
else
  left_text "Trạng thái    : ${C_RED}CHƯA KÍCH HOẠT${C_RESET}" 2
  echo -e "${C_CYAN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
  left_text "Nên bật tính năng này để kiểm soát an ninh máy chủ chặt chẽ." 2
  left_text "Bạn sẽ biết ngay lập tức nếu có kẻ gian xâm nhập trái phép." 2
fi
echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

if [[ "$thong_bao_login_ssh" == "1" ]]; then
  if wptt_xac_nhan "Tính năng Cảnh báo qua Telegram đang BẬT. Bạn muốn TẮT không?" "" "" "Đồng ý Tắt" "Giữ nguyên (Hủy)"; then
    echo ""
    _runing "vô hiệu hóa cảnh báo SSH qua Telegram."
    sed -i "/thong_bao_login_ssh/d" /etc/wptt/.wptt.conf
    _rundone "vô hiệu hóa cảnh báo SSH qua Telegram."
  else
    echo -e "${C_YELLOW}Đã hủy thao tác.${C_RESET}\n"
  fi
else
  if wptt_xac_nhan "Bạn có muốn BẬT cảnh báo đăng nhập SSH qua Telegram không?" "" "" "Đồng ý Bật" "Hủy thao tác"; then
    echo ""
    _runing "kích hoạt cảnh báo SSH qua Telegram"
    sed -i "/thong_bao_login_ssh/d" /etc/wptt/.wptt.conf
    echo "thong_bao_login_ssh=1" >>/etc/wptt/.wptt.conf
    _rundone "kích hoạt cảnh báo SSH qua Telegram"
  else
    echo -e "${C_YELLOW}Đã hủy thao tác.${C_RESET}\n"
  fi
fi

if [[ "${1:-}" == "98" ]]; then
  exec /etc/wptt/wptt-ssh-main 1
fi
