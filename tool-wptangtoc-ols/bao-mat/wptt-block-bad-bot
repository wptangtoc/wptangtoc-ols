#!/bin/bash

function huong_dan() {
  Tính năng Chống Bad Bots [Công cụ cào dữ liệu và Máy quét mã độc]
  🛡️ Mục đích:
  Các công cụ SEO [Ahrefs, Semrush, MJ12bot...]và các công cụ rà quét của Hacker [sqlmap, Nmap...] liên tục cào dữ liệu website của bạn với tốc độ hàng ngàn truy vấn mỗi phút. Chúng không mang lại khách hàng mà chỉ làm máy chủ cạn kiệt CPU, RAM và Băng thông.

  ⚙️ Cơ chế hoạt động:
  Thay vì dựa vào file robots.txt [thứ mà các bot xấu luôn phớt lờ], tính năng này sử dụng Fail2ban để đọc trực tiếp trong file log.
  * Danh sách đen bao gồm: Các bot SEO rác, Bot cào dữ liệu TQ/Nga, Công cụ rà quét lỗ hổng.
  * Hành động: Bất kỳ IP nào sử dụng User-Agent nằm trong danh sách đen, CHỈ CẦN TRUY CẬP 1 LẦN DUY NHẤT sẽ bị Tường lửa Ipset khóa ngay lập tức.
  * Thời gian khóa: 24 tiếng [86400 giây].

}
. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null # Nạp thư viện UX Bo Cong

clear
echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}BẢO MẬT ➜ Chống Cào Dữ Liệu (Bad Bots) & Trình Quét Lỗ Hổng${C_RESET}"
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

if [[ "${1:-}" == '98' ]]; then
  WPTT_IN_MENU="yes"
  WPTT_MENU_BACK="/etc/wptt/wptt-bao-mat-main 1"
fi

# ==============================================================================
# KIỂM TRA TRẠNG THÁI HIỆN TẠI VÀ IN BẢNG THÔNG BÁO
# ==============================================================================
check=$(grep '#begin-badbots-wptangtoc' /etc/fail2ban/jail.local 2>/dev/null)

echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
if [[ -n "$check" ]]; then
  left_text "Trạng thái    : ${C_GREEN}ĐÃ KÍCH HOẠT${C_RESET}" 2
  echo -e "${C_CYAN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
  left_text "Mọi IP sử dụng User-Agent thuộc Danh sách đen (Ahrefs," 2
  left_text "Semrush, sqlmap, Nmap...) truy cập vào website sẽ bị khóa" 2
  left_text "chặn đứng ngay từ ${C_YELLOW}lần đầu tiên (Khóa 24 tiếng)${C_RESET}." 2
else
  left_text "Trạng thái    : ${C_RED}CHƯA KÍCH HOẠT${C_RESET}" 2
  echo -e "${C_CYAN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
  left_text "Kích hoạt để chặn đứng các bot SEO rác, công cụ cào dữ liệu," 2
  left_text "và trình dò tìm lỗ hổng bào mòn tài nguyên máy chủ của bạn." 2
fi
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

# ==============================================================================
# XỬ LÝ NHÁNH 1: ĐANG BẬT -> YÊU CẦU TẮT
# ==============================================================================
if [[ -n "$check" ]]; then
  if ! wptt_xac_nhan "Tính năng Chống Bad Bots đang BẬT. Bạn có muốn TẮT không?" "Các Bot cào dữ liệu sẽ có thể truy cập lại vào Website của bạn." "" "Đồng ý Tắt" "Giữ nguyên (Hủy)"; then
    echo -e "${C_YELLOW}Đã hủy thao tác.${C_RESET}\n"
    [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-bao-mat-main 1
    exit 0
  fi

  echo ""
  _runing "Đang vô hiệu hóa Rule chặn Bad Bots trên Fail2Ban..."
  sed -i -e '/^#begin-badbots-wptangtoc/,/^#end-badbots-wptangtoc$/d' /etc/fail2ban/jail.local
  rm -f /etc/fail2ban/filter.d/wptangtoc-badbots.conf

  if command -v fail2ban-client >/dev/null 2>&1; then
    fail2ban-client reload >/dev/null 2>&1 || systemctl restart fail2ban >/dev/null 2>&1
  fi
  _rundone "Hủy kích hoạt chặn Bad Bots thành công!"

  sleep 2
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-bao-mat-main 1
  exit 0
fi

# ==============================================================================
# XỬ LÝ NHÁNH 2: ĐANG TẮT -> YÊU CẦU BẬT
# ==============================================================================
if ! wptt_xac_nhan "Bạn có muốn KÍCH HOẠT bảo vệ Chống Bad Bots không?" "Hệ thống sẽ thiết lập Tường lửa chặn 1-hit-ban với các User-Agent xấu." "" "Đồng ý Bật" "Hủy thao tác"; then
  echo -e "${C_YELLOW}Đã hủy thao tác.${C_RESET}\n"
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-bao-mat-main 1
  exit 0
fi

echo ""
_runing "Đang cài đặt thư viện cần thiết (Ipset & Pyinotify)..."
if grep -qi "ubuntu" /etc/os-release 2>/dev/null; then
  dpkg -s python3-pyinotify ipset >/dev/null 2>&1 || {
    export DEBIAN_FRONTEND=noninteractive
    apt-get update >/dev/null 2>&1
    apt-get install -y python3-pyinotify ipset >/dev/null 2>&1
  }
else
  rpm -q python3-inotify ipset >/dev/null 2>&1 || {
    dnf install -y python3-inotify ipset >/dev/null 2>&1
  }
fi
_rundone "Cài đặt thư viện nền tảng thành công"

# ==============================================================================
# XÁC ĐỊNH TƯỜNG LỬA VÀ BƠM LUẬT FAIL2BAN
# ==============================================================================
_runing "Đang kết nối Tường lửa và bơm luật (Rules) chặn Bots..."
rule_fail2ban_name="badbots-wptt"

if [[ -f /etc/csf/csf.conf ]]; then
  action_thuc_thi_block="iptables-multiport[actname=block-tcp, name=$rule_fail2ban_name-t, port=\"80,443\", protocol=\"tcp\"]\n           iptables-multiport[actname=block-udp, name=$rule_fail2ban_name-u, port=\"80,443\", protocol=\"udp\"]"
elif [[ $(systemctl status nftables.service 2>/dev/null | grep 'Active' | awk '{print $2}') == "active" ]]; then
  action_thuc_thi_block="nftables-allports[name=$rule_fail2ban_name]"
elif [[ $(systemctl status firewalld.service 2>/dev/null | grep 'Active' | awk '{print $2}') == "active" ]]; then
  action_thuc_thi_block="firewallcmd-ipset[actname=block-tcp, name=$rule_fail2ban_name-t, port=\"80,443\", protocol=\"tcp\"]\n           firewallcmd-ipset[actname=block-udp, name=$rule_fail2ban_name-u, port=\"80,443\", protocol=\"udp\"]"
else
  _runloi "Không tìm thấy Tường lửa!"
  echo -e "\n${C_RED}❌ Lỗi: Hệ thống không xác định được Tường lửa nào đang chạy (CSF/Nftables/Firewalld).${C_RESET}"
  sleep 3
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-bao-mat-main 1
  exit 1
fi

# Ghi cấu hình Jail
echo "
#begin-badbots-wptangtoc
[wptangtoc-badbots]
enabled = true
action = $action_thuc_thi_block
filter = wptangtoc-badbots
logpath = /usr/local/lsws/*/logs/access.log
backend = pyinotify
maxretry = 1
bantime = 86400
findtime = 60
#end-badbots-wptangtoc" >>/etc/fail2ban/jail.local

# Tạo bộ lọc Regex nhận diện Bad Bots độc quyền của WPTangToc
echo '[Definition]
badbots = AhrefsBot|SemrushBot|MJ12bot|DotBot|Baiduspider|YandexBot|PetalBot|BLEXBot|MegaIndex|SeznamBot|ZoominfoBot|Barkrowler|DataForSeoBot|Serpstatbot|sqlmap|Nmap|Zmeu|Jorgee|masscan|httpx|nuclei|DirBuster|Panscient|netestate
failregex = ^<HOST> .* "(GET|POST|HEAD) .* HTTP\/.*" .* ".*(?:%(badbots)s).*"$
ignoreregex =' >/etc/fail2ban/filter.d/wptangtoc-badbots.conf

fail2ban-client reload >/dev/null 2>&1 || systemctl restart fail2ban >/dev/null 2>&1
_rundone "Kích hoạt chặn Bad Bots thành công!"

echo -e "${C_GREEN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_BOLD_WHITE}HOÀN TẤT THIẾT LẬP BẢO VỆ${C_RESET}"
echo -e "${C_GREEN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
left_text "Máy chủ đã được đặt trong trạng thái phòng thủ chống lại" 2
left_text "các trình thu thập dữ liệu rác và công cụ rà quét lỗ hổng." 2
echo -e "${C_GREEN}╰───────────────────────────────────────────────────────────────────────╯${C_RESET}"

[[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-bao-mat-main 1
