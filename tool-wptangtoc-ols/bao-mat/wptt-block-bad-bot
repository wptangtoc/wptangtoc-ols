#!/bin/bash

function huong_dan() {
  Tính năng Chống Bad Bots [Công cụ cào dữ liệu và Máy quét mã độc]
  🛡️ Mục đích:
  Các công cụ SEO [Ahrefs, Semrush, MJ12bot...]và các công cụ rà quét của Hacker [sqlmap, Nmap...] liên tục cào dữ liệu website của bạn với tốc độ hàng ngàn truy vấn mỗi phút. Chúng không mang lại khách hàng mà chỉ làm máy chủ cạn kiệt CPU, RAM và Băng thông.

  ⚙️ Cơ chế hoạt động:
  Thay vì dựa vào file robots.txt [thứ mà các bot xấu luôn phớt lờ], tính năng này sử dụng Fail2ban để đọc trực tiếp trong file log.
  * Danh sách đen bao gồm: Các bot SEO rác, Bot cào dữ liệu TQ/Nga, Công cụ rà quét lỗ hổng.
  * Hành động: Bất kỳ IP nào sử dụng User-Agent nằm trong danh sách đen, CHỈ CẦN TRUY CẬP 1 LẦN DUY NHẤT sẽ bị Tường lửa Ipset khóa ngay lập tức.
  * Thời gian khóa: 24 tiếng [86400 giây].

}

echo ""
echo ""
echo ""
echo "========================================================================="
echo "| Bảo mật => Kích hoạt chặn Bad Bots & Scanner (Cào dữ liệu)            |"
echo "========================================================================="
echo ""
echo ""
echo ""

. /etc/wptt/echo-color
check=$(cat /etc/fail2ban/jail.local 2>/dev/null | grep '#begin-badbots-wptangtoc')

if [[ $check = '' ]]; then
  echo "Xác nhận muốn kích hoạt chặn Bad Bots (Ahrefs, Semrush, MJ12bot, Scanner...)"
  prompt="Nhập lựa chọn của bạn [1-2]: "
  dongy="n"
  options=("Đồng ý" "Không đồng ý")
  PS3="$prompt"
  select opt in "${options[@]}"; do
    case "$REPLY" in
    1)
      dongy="y"
      break
      ;;
    2)
      dongy="n"
      break
      ;;
    $((${#options[@]} + 1)))
      printf "\nBạn nhập sai hệ thống sẽ chọn là không đồng ý\n"
      break
      ;;
    *)
      printf "Bạn nhập sai hệ thống sẽ chọn là không đồng ý\n"
      break
      ;;
    esac
  done

  if [[ $dongy = 'n' ]]; then
    exec /etc/wptt/wptt-bao-mat-main 1
  fi

  _runing "Kích hoạt chặn Bad Bots"

  # =========================================================
  # AUTO-INSTALL DEPENDENCIES (IPSET & PYINOTIFY)
  # =========================================================
  if [ -f /etc/os-release ] && grep -qi "ubuntu" /etc/os-release; then
    dpkg -s python3-pyinotify ipset >/dev/null 2>&1 || {
      export DEBIAN_FRONTEND=noninteractive
      apt-get update >/dev/null 2>&1
      apt-get install -y python3-pyinotify ipset >/dev/null 2>&1
    }
  else
    rpm -q python3-inotify ipset >/dev/null 2>&1 || {
      dnf install -y python3-inotify ipset >/dev/null 2>&1
    }
  fi

  # =========================================================
  # TÍNH TOÁN BIẾN VÀ CẤU HÌNH FAIL2BAN ENTERPRISE
  # =========================================================
  rule_fail2ban_name="badbots-wptt"

  if [[ -f /etc/csf/csf.conf ]]; then
    action_thuc_thi_block="iptables-multiport[actname=block-tcp, name=$rule_fail2ban_name-t, port=\"80,443\", protocol=\"tcp\"]
           iptables-multiport[actname=block-udp, name=$rule_fail2ban_name-u, port=\"80,443\", protocol=\"udp\"]"
  elif [[ $(systemctl status nftables.service 2>/dev/null | grep 'Active' | cut -f2 -d':' | xargs | cut -f1 -d' ' | xargs) = "active" ]]; then
    action_thuc_thi_block="nftables-allports[name=$rule_fail2ban_name]"
  elif [[ $(systemctl status firewalld.service 2>/dev/null | grep 'Active' | cut -f2 -d':' | xargs | cut -f1 -d' ' | xargs) = "active" ]]; then
    action_thuc_thi_block="firewallcmd-ipset[actname=block-tcp, name=$rule_fail2ban_name-t, port=\"80,443\", protocol=\"tcp\"]
           firewallcmd-ipset[actname=block-udp, name=$rule_fail2ban_name-u, port=\"80,443\", protocol=\"udp\"]"
  else
    echo "Hiện tại không support một tường lửa nào để sử dụng"
    check_menu_wptangtoc_active=$1
    if [[ $check_menu_wptangtoc_active = "98" ]]; then
      exec /etc/wptt/wptt-bao-mat-main 1
    fi
    return 2>/dev/null
    exit
  fi

  echo "
#begin-badbots-wptangtoc
[wptangtoc-badbots]
enabled = true
action = $action_thuc_thi_block
filter = wptangtoc-badbots
logpath = /usr/local/lsws/*/logs/access.log
backend = pyinotify
maxretry = 1
bantime = 86400
findtime = 60
#end-badbots-wptangtoc" >>/etc/fail2ban/jail.local

  # Tạo bộ lọc Regex nhận diện Bad Bots độc quyền của WPTangToc
  # Bot cào dữ liệu, SEO rác và Scanner lỗ hổng
  echo '[Definition]
badbots = AhrefsBot|SemrushBot|MJ12bot|DotBot|Baiduspider|YandexBot|PetalBot|BLEXBot|MegaIndex|SeznamBot|ZoominfoBot|Barkrowler|DataForSeoBot|Serpstatbot|sqlmap|Nmap|Zmeu|Jorgee|masscan|httpx|nuclei|DirBuster|Panscient|netestate
failregex = ^<HOST> .* "(GET|POST|HEAD) .* HTTP\/.*" .* ".*(?:%(badbots)s).*"$
ignoreregex =' >/etc/fail2ban/filter.d/wptangtoc-badbots.conf

  fail2ban-client reload >/dev/null 2>&1 || systemctl restart fail2ban >/dev/null 2>&1
  _rundone "Kích hoạt chặn Bad Bots thành công"
  echo "Các bot xấu, công cụ cào SEO và Scanner lỗ hổng sẽ bị chặn ngay lập tức (Ban 24h) khi truy cập."
fi

if [[ $check ]]; then
  echo "Bạn đang kích họat chặn Bad Bots"
  echo "Xác nhận muốn hủy kích hoạt chặn Bad Bots"
  prompt="Nhập lựa chọn của bạn [1-2]: "
  dongy="n"
  options=("Đồng ý" "Không đồng ý")
  PS3="$prompt"
  select opt in "${options[@]}"; do
    case "$REPLY" in
    1)
      dongy="y"
      break
      ;;
    2)
      dongy="n"
      break
      ;;
    $((${#options[@]} + 1)))
      printf "\nBạn nhập sai hệ thống sẽ chọn là không đồng ý\n"
      break
      ;;
    *)
      printf "Bạn nhập sai hệ thống sẽ chọn là không đồng ý\n"
      break
      ;;
    esac
  done

  if [[ $dongy = 'n' ]]; then
    exec /etc/wptt/wptt-bao-mat-main 1
  fi

  _runing "Hủy kích hoạt chặn Bad Bots"
  sed -i -e '/^#begin-badbots-wptangtoc/,/^#end-badbots-wptangtoc$/d' /etc/fail2ban/jail.local
  rm -f /etc/fail2ban/filter.d/wptangtoc-badbots.conf
  fail2ban-client reload >/dev/null 2>&1 || systemctl restart fail2ban >/dev/null 2>&1
  _rundone "Hủy kích hoạt chặn Bad Bots"
fi

check_menu_wptangtoc_active=$1
if [[ $check_menu_wptangtoc_active = "98" ]]; then
  exec /etc/wptt/wptt-bao-mat-main 1
fi
