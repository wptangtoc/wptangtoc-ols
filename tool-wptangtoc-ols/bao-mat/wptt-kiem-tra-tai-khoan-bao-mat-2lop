#!/bin/bash
# @author: Gia Tuấn
# @website: https://wptangtoc.com
# @since: 2026

. /etc/wptt/.wptt.conf
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh
. /etc/wptt/echo-color

clear
echo -e "\n========================================================================="
echo -e "| Bảo mật => Xem thông tin tài khoản Bảo mật 2 lớp wp-admin             |"
echo -e "=========================================================================\n"

# ==============================================================================
# HÀM MENU LỌC THÔNG MINH (CHỈ HIỂN THỊ DOMAIN ĐANG BẬT 2FA)
# ==============================================================================
function lua_chon_NAME() {
  NAME=""
  if [[ -n "$(ls -A /etc/wptt/vhost 2>/dev/null)" ]]; then
    selects=()

    # Vòng lặp Globbing siêu tốc không qua sub-shell
    for filepath in /etc/wptt/vhost/.*.conf; do
      [[ ! -f "$filepath" || "$filepath" == *"/..conf" ]] && continue

      local domain="${filepath##*/}"
      domain="${domain%.conf}"
      domain="${domain#.}"

      # Chỉ đưa vào Menu những domain có tồn tại file bảo mật .mk
      if [[ -f "/usr/local/lsws/$domain/passwd/.mk" ]]; then
        selects+=("$domain")
      fi
    done

    # Nếu không có domain nào đang bật
    if [[ ${#selects[@]} -eq 0 ]]; then
      echo -e "\033[1;33mHệ thống chưa có Website nào được kích hoạt bảo mật 2 lớp!\033[0m"
      sleep 3
      exec /etc/wptt/wptt-bao-mat-main 1
    fi

    # [NÂNG CẤP UX] Hiển thị tùy chọn "TẤT CẢ" nếu có nhiều website
    if [[ ${#selects[@]} -ge 2 ]]; then
      selects+=("TẤT CẢ WEBSITE (Xem toàn bộ)")
    fi

    PS3=$'\n'"-//- Lựa chọn website bạn muốn xem thông tin [0=Thoát]: "
    select select in "${selects[@]}"; do
      NAME=$select
      break
    done
  else
    clear
    echo "$khong_co_domain_nao_ton_tai_tren_he_thong"
    exit
  fi
}

lua_chon_NAME

# --- CHỐT CHẶN THOÁT HIỂM ---
[[ "$NAME" == "0" || -z "$NAME" ]] && exec /etc/wptt/wptt-bao-mat-main 1

# ==============================================================================
# HÀM IN THÔNG TIN TÀI KHOẢN
# ==============================================================================
function show_account_info() {
  local target_domain=$1
  local config_file="/etc/wptt/vhost/.$target_domain.conf"

  if [[ -f "$config_file" ]]; then
    # Reset biến để tránh in nhầm tài khoản của domain trước đó
    id_dang_nhap_wordpress_2=""
    password_dang_nhap_wordpress_2=""

    . "$config_file" # Nạp biến từ file conf

    echo -e "Website: \033[1;32m$target_domain\033[0m"
    echo -e "ID Đăng nhập: \033[1;33m${id_dang_nhap_wordpress_2:-Không tìm thấy trong hệ thống}\033[0m"
    echo -e "Mật khẩu: \033[1;33m${password_dang_nhap_wordpress_2:-Không tìm thấy trong hệ thống}\033[0m"
    echo "-------------------------------------------------------------------------"
  fi
}

# ==============================================================================
# GIAO DIỆN HIỂN THỊ KẾT QUẢ
# ==============================================================================
clear
echo -e "\n========================================================================="
echo -e "                 THÔNG TIN TÀI KHOẢN BẢO MẬT 2 LỚP"
echo -e "========================================================================="

if [[ "$NAME" == "TẤT CẢ WEBSITE (Xem toàn bộ)" ]]; then
  for filepath in /etc/wptt/vhost/.*.conf; do
    [[ ! -f "$filepath" || "$filepath" == *"/..conf" ]] && continue
    domain="${filepath##*/}"
    domain="${domain%.conf}"
    domain="${domain#.}"

    if [[ -f "/usr/local/lsws/$domain/passwd/.mk" ]]; then
      show_account_info "$domain"
    fi
  done
else
  show_account_info "$NAME"
fi

echo -e "=========================================================================\n"

# [NÂNG CẤP UX CỰC KỲ QUAN TRỌNG] Tạm dừng màn hình để người dùng có thời gian COPY
read -p "Nhấn phím [Enter] để quay lại menu..." dummy

[[ ${1:-} == "98" ]] && exec /etc/wptt/wptt-bao-mat-main 1
