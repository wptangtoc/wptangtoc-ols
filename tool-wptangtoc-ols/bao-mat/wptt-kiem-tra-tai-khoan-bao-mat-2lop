# @since: 2026


function huong_dan(){
Chức năng xem lại thông tin tài khoản bảo mật 2 lớp trong WordPress cho phép người dùng kiểm tra và quản lý các thiết lập bảo mật đã được kích hoạt. Điều này các phương thức xác thực hai yếu tố khác nhau. Sử dụng chức năng này, bạn có thể đảm bảo rằng thông tin tài khoản của mình luôn an toàn.
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null

clear
echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}BẢO MẬT ➜ Xem thông tin tài khoản Bảo mật 2 lớp (2FA)${C_RESET}"
echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

tmp_selects=()
for filepath in /etc/wptt/vhost/.*.conf; do
  [[ ! -f "$filepath" || "$filepath" == *"/..conf" ]] && continue
  domain="${filepath##*/}"
  domain="${domain%.conf}"
  domain="${domain#.}"

  if [[ -f "/usr/local/lsws/$domain/passwd/.mk" ]]; then
    tmp_selects+=("$domain")
  fi
done

if [[ ${#tmp_selects[@]} -eq 0 ]]; then
  echo -e "${C_YELLOW}⚠️ Hệ thống chưa có Website nào được kích hoạt bảo mật 2 lớp!${C_RESET}"
  sleep 3
  exec /etc/wptt/wptt-bao-mat-main 1
fi

# Tận dụng code xịn của bạn, nhưng sửa lại xíu cho tương thích với UX mới
function lua_chon_NAME_Custom() {
  unset NAME
  local box_inner_width=${box_inner_width:-71}

  mapfile -t tmp_selects < <(printf "%s\n" "${tmp_selects[@]}" | sort -uV)

  if [[ ${#tmp_selects[@]} -ge 2 ]]; then
    tmp_selects+=("TẤT CẢ WEBSITE")
  fi

  echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
  local title_text="Lựa chọn website bạn muốn xem thông tin 2FA:"
  local len=$(echo -n "$title_text" | awk '{print length($0)}')
  local pad_r=$((box_inner_width - len - 2))
  [[ $pad_r -lt 0 ]] && pad_r=0
  echo -e "${C_CYAN}│${C_RESET}  ${C_YELLOW}${title_text}${C_RESET}$(printf '%*s' "$pad_r" "")${C_CYAN}│${C_RESET}"

  local line_len=$((len + 3))
  local pad_line_r=$((box_inner_width - line_len))
  [[ $pad_line_r -lt 0 ]] && pad_line_r=0
  local short_line=$(printf "%${line_len}s" "" | sed 's/ /─/g')
  echo -e "${C_CYAN}├${short_line}$(printf '%*s' "$pad_line_r" "")│${C_RESET}"

  local i=1
  for domain in "${tmp_selects[@]}"; do
    if [[ "$domain" == "TẤT CẢ WEBSITE" ]]; then
      local item_text=$(printf "  ${C_CYAN}%3d)${C_RESET} ${C_YELLOW}%s${C_RESET}" "$i" "$domain")
    else
      local item_text=$(printf "  ${C_CYAN}%3d)${C_RESET} ${C_BOLD_WHITE}%s${C_RESET}" "$i" "$domain")
    fi
    local clean_text=$(printf "  %3d) %s" "$i" "$domain")
    local item_len=$(echo -n "$clean_text" | awk '{print length($0)}')
    local pad=$((box_inner_width - item_len))
    [[ $pad -lt 0 ]] && pad=0
    echo -e "${C_CYAN}│${C_RESET}${item_text}$(printf '%*s' "$pad" "")${C_CYAN}│${C_RESET}"
    ((i++))
  done
  echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯${C_RESET}"

  local fzf_installed=false
  if command -v fzf &>/dev/null; then
    fzf_installed=true
    PROMPT_TEXT="Nhập lựa chọn (1-${#tmp_selects[@]}) [00=Tìm nhanh] [0=Thoát]: "
  else
    PROMPT_TEXT="Nhập lựa chọn (1-${#tmp_selects[@]}) [0=Thoát]: "
  fi

  while true; do
    echo -en "${C_CYAN}${PROMPT_TEXT}${C_RESET}"
    if ! read -r REPLY; then exit 1; fi
    REPLY=$(echo "$REPLY" | tr -d ' ' | tr '[:upper:]' '[:lower:]')

    case "$REPLY" in
    0)
      echo -e "\n${C_GREEN}Đang thoát...${C_RESET}"
      NAME="0"
      return 0
      ;;
    00)
      if $fzf_installed; then
        local selected_name=$(printf '%s\n' "${tmp_selects[@]}" | nl -w 3 -s ': ' | fzf --prompt="Tìm website xem 2FA >> " --height=40% --border=rounded --color=border:red --cycle --reverse)
        selected_name=$(echo "$selected_name" | sed 's/^[[:space:]]*[0-9]\+\:[[:space:]]*//')
        if [[ -n "$selected_name" ]]; then
          NAME="$selected_name"
          return 0
        else echo -e "${C_YELLOW}Đã hủy chọn. Vui lòng chọn lại.${C_RESET}"; fi
      else
        echo -e "${C_RED}Lỗi: FZF chưa cài đặt.${C_RESET}"
      fi
      ;;
    *)
      if [[ "$REPLY" =~ ^[0-9]+$ ]] && [ "$REPLY" -ge 1 ] && [ "$REPLY" -le ${#tmp_selects[@]} ]; then
        local action_index=$((REPLY - 1))
        NAME="${tmp_selects[$action_index]}"
        return 0
      else
        echo -e "\n${C_RED}❌ Lựa chọn không hợp lệ! Vui lòng chọn lại.${C_RESET}"
      fi
      ;;
    esac
  done
}

lua_chon_NAME_Custom

# --- CHỐT CHẶN THOÁT HIỂM ---
[[ "$NAME" == "0" || -z "$NAME" ]] && {
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-bao-mat-main 1
  return 2>/dev/null || exit
}

# ==============================================================================
# HÀM IN THÔNG TIN TÀI KHOẢN (UX BO CONG)
# ==============================================================================
box_inner_width=${box_inner_width:-71}

function in_dong() {
  local raw_text="$1"
  local colored_text="$2"
  local len=$(echo -n "$raw_text" | awk '{print length($0)}')
  local pad=$((box_inner_width - len - 2))
  [[ $pad -lt 0 ]] && pad=0
  echo -e "${C_GREEN}│${C_RESET}  ${colored_text}$(printf '%*s' "$pad" "")${C_GREEN}│${C_RESET}"
}

function show_account_info() {
  local target_domain=$1
  local config_file="/etc/wptt/vhost/.$target_domain.conf"

  if [[ -f "$config_file" ]]; then
    # Reset biến để tránh in nhầm tài khoản của domain trước đó
    id_dang_nhap_wordpress_2=""
    password_dang_nhap_wordpress_2=""

    . "$config_file" 2>/dev/null

    in_dong "▪ Website      : $target_domain" "${C_BOLD_WHITE}▪ Website      :${C_RESET} ${C_GREEN}$target_domain${C_RESET}"
    in_dong "  ID Đăng nhập : ${id_dang_nhap_wordpress_2:-Không tìm thấy trong hệ thống}" "  ID Đăng nhập : ${C_YELLOW}${id_dang_nhap_wordpress_2:-Không tìm thấy trong hệ thống}${C_RESET}"
    in_dong "  Mật khẩu     : ${password_dang_nhap_wordpress_2:-Không tìm thấy trong hệ thống}" "  Mật khẩu     : ${C_YELLOW}${password_dang_nhap_wordpress_2:-Không tìm thấy trong hệ thống}${C_RESET}"
    in_dong "-------------------------------------------------" "-------------------------------------------------"
  fi
}

# ==============================================================================
# GIAO DIỆN HIỂN THỊ KẾT QUẢ
# ==============================================================================
clear
echo -e "\n${C_GREEN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_BOLD_WHITE}THÔNG TIN TÀI KHOẢN BẢO MẬT 2 LỚP WP-ADMIN${C_RESET}"
echo -e "${C_GREEN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"

if [[ "$NAME" == "TẤT CẢ WEBSITE" ]]; then
  for filepath in /etc/wptt/vhost/.*.conf; do
    [[ ! -f "$filepath" || "$filepath" == *"/..conf" ]] && continue
    domain="${filepath##*/}"
    domain="${domain%.conf}"
    domain="${domain#.}"

    if [[ -f "/usr/local/lsws/$domain/passwd/.mk" ]]; then
      show_account_info "$domain"
    fi
  done
else
  show_account_info "$NAME"
fi

echo -e "${C_GREEN}╰──────────────────────────────────────────────────────────────────────────────╯${C_RESET}\n"

echo -en "${C_GREEN}Nhấn phím [Enter] để quay lại Menu...${C_RESET}"
read -r dummy

[[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-bao-mat-main 1
