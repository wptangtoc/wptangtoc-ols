#!/bin/bash

function huong_dan() {
  Tính năng Chống DDoS Trang Chủ [Home Page] trong WPTangToc OLS

  🛡️ Mục đích:
  Trang chủ [Home page] thường là trang nặng nhất của một website WordPress, tiêu tốn nhiều CPU và Database nhất để tải hàng loạt truy vấn. Botnet thường nhắm thẳng vào trang chủ [truy cập đường dẫn gốc /] để làm cạn kiệt tài nguyên máy chủ. Tính năng này thiết lập một hàng rào bảo vệ đặc biệt, nhạy cảm hơn nhiều so với các trang khác.

  ⚙️ Cơ chế hoạt động:
  * Theo dõi hành vi truy cập thẳng vào trang chủ [Root URL /].
  * Điều kiện Kích hoạt: Nếu một IP truy cập trang chủ 5 lần chỉ trong vòng 10 giây [Hành vi F5 liên tục hoặc dùng tool cào].
  * Hành động: Lập tức bị Tường lửa khóa chặn mọi kết nối vào máy chủ.
  * Thời gian khóa: 20 tiếng [72000 giây] - Khóa cực gắt để trừng phạt Bot.

  [Bản nâng cấp Enterprise: Tích hợp Ipset tốc độ cao, khóa kép HTTP/3 UDP, tối ưu pyinotify không nghẽn CPU và Regex chính xác tuyệt đối]
}

. /etc/wptt/.wptt.conf
echo "/-----------------------------------------------------------------------/"
echo "Bảo mật => Chống ddos website home page"
echo "/-----------------------------------------------------------------------/"

NAME=$1
if [[ $NAME = "98" ]]; then
  NAME=""
fi

. /etc/wptt/echo-color

if [[ $NAME = '' ]]; then
  if [ "$(ls -A /etc/wptt/vhost | grep -v '^\.\.conf$' | sort -uV)" ]; then
    echo "========================================================================="
    echo "Danh sách Domain đã kích hoạt chống ddos trang chủ:"
    echo "========================================================================="
    for entry in $(ls -A /etc/wptt/vhost | grep -v '^\.\.conf$' | sort -uV); do
      domain=$(echo $entry | sed 's/^.//' | sed 's/.conf//')
      domain2=${domain//[-._]/wp}
      path="/etc/fail2ban/filter.d/ddos-$domain2-home-page.conf"
      if [[ -f "$path" ]]; then
        checkauto="Đã kích hoạt"
      else
        checkauto="Chưa kích hoạt"
      fi
      echo "Website $domain $checkauto chống ddos trang chủ"
    done
    echo "========================================================================="
    echo
  fi

  echo ""
  echo "Lựa chọn website kích hoạt chống ddos website home page: "
  echo ""
  function lua_chon_NAME() {
    NAME=""
    if [ "$(ls -At /etc/wptt/vhost)" ]; then
      selects=()
      for entry in $(ls -A /etc/wptt/vhost | grep -v '^\.\.conf$' | sort -uV); do
        NAME=$(echo $entry | sed 's/^.//' | sed 's/.conf//')
        NAME2=${NAME//[-._]/wp}
        if [[ ! -f /etc/fail2ban/filter.d/ddos-$NAME2-home-page.conf ]]; then
          selects+=("$NAME")
        fi
      done

      if [[ $selects = '' ]]; then
        echo "Tất cả website WordPress trên hệ thống đã được kích hoạt chống DDOS Trang chủ hết rồi"
        exec /etc/wptt/wptt-bao-mat-main 1
      fi

      a=0
      for select in ${selects[@]}; do
        a=$(expr $a + 1)
      done

      if [[ $a != 1 ]]; then
        selects+=("Tat-ca-website")
      fi

      PS3="
-//- Nhập lựa chọn website của bạn [0=Thoát]: "
      select select in ${selects[@]}; do
        NAME=$select
        break
      done
    else
      clear
      echo "Khong co domain tren he thong cua ban."
      exit
    fi
  }

  lua_chon_NAME
fi

if [[ $NAME = 'Tat-ca-website' ]]; then
  if [ "$(ls -A /etc/wptt/vhost | grep -v '^\.\.conf$' | sort -uV)" ]; then
    for entry in $(ls -A /etc/wptt/vhost | grep -v '^\.\.conf$' | sort -uV); do
      domain=$(echo $entry | sed 's/^.//' | sed 's/.conf//')
      domain2=${domain//[-._]/wp}
      if [[ ! -f /etc/fail2ban/filter.d/ddos-"$domain2"-home-page.conf ]]; then
        _runing "Thiết lập chống ddos trang chủ website $domain"
        . /etc/wptt/bao-mat/wptt-ddos-trang-chu-home-page-thiet-lap $domain >/dev/null 2>&1
        _rundone "Thiết lập chống ddos trang chủ website $domain"
      fi
    done
  fi

  check_menu_wptangtoc_active=$1
  if [[ $check_menu_wptangtoc_active = "98" ]]; then
    exec /etc/wptt/wptt-logs-main 1
  fi
  exit
fi

if [[ $NAME = '0' || $NAME = '' ]]; then
  exec /etc/wptt/wptt-bao-mat-main 1
  exit
fi

. /etc/wptt/echo-color

NAME2=${NAME//[-._]/wp}

read -p "Bạn có muốn bật tính năng chống ddos trang chủ website? (y/n): " dongy
if [[ "$dongy" = "y" ]]; then
  _runing "Thiết lập chống ddos trang chủ cho website $NAME"

  # =========================================================
  # AUTO-INSTALL DEPENDENCIES (IPSET & PYINOTIFY)
  # =========================================================
  if [ -f /etc/os-release ] && grep -qi "ubuntu" /etc/os-release; then
    dpkg -s python3-pyinotify ipset >/dev/null 2>&1 || {
      export DEBIAN_FRONTEND=noninteractive
      apt-get update >/dev/null 2>&1
      apt-get install -y python3-pyinotify ipset >/dev/null 2>&1
    }
  else
    rpm -q python3-inotify ipset >/dev/null 2>&1 || {
      dnf install -y python3-inotify ipset >/dev/null 2>&1
    }
  fi

  # Cảnh báo Cloudflare
  unset TRACE_OUTPUT
  TRACE_OUTPUT=$(curl -Is --connect-timeout 5 --max-time 10 "https://$NAME/cdn-cgi/trace" 2>/dev/null)
  if echo "$TRACE_OUTPUT" | grep -qi 'cloudflare\|cf-ray'; then
    if [[ $(cat /usr/local/lsws/conf/httpd_config.conf | grep 'allow' | grep '103.21.244.0') = '' ]]; then
      _runloi "Thiết lập chống ddos trang chủ cho website $NAME"
      echo "Phát hiện website $NAME đang sử dụng Cloudflare CDN"
      echo "Vui lòng phải kích hoạt sử dụng tính năng Hiện thị IP Log Real bypass Cloudflare CDN (MENU add ons 35=>8)"
      echo "Thì mới có thể sử dụng được tính năng này để tránh bị chặn nhầm"
      check_menu_wptangtoc_active=$1
      if [[ $check_menu_wptangtoc_active = "98" ]]; then
        exec /etc/wptt/wptt-bao-mat-main 1
      fi
      return 2>/dev/null
      exit
    fi
  fi

  if [[ ! $(cat /usr/local/lsws/conf/vhosts/"$NAME"/"$NAME".conf | grep 'accesslog') ]]; then
    sed -i -e '/^errorlog /,/^}$/d' /usr/local/lsws/conf/vhosts/"$NAME"/"$NAME".conf
    sed -i -e '/^accesslog /,/^}$/d' /usr/local/lsws/conf/vhosts/"$NAME"/"$NAME".conf
    echo '
errorlog $VH_ROOT/logs/error.log {
  useServer               1
  logLevel                ERROR
  rollingSize             10M
}

accesslog $VH_ROOT/logs/access.log {
  useServer               0
  rollingSize             10M
  keepDays                30
  compressArchive         1
}' >>/usr/local/lsws/conf/vhosts/"$NAME"/"$NAME".conf
  fi

  mkdir -p /usr/local/lsws/"$NAME"/logs

  if $(cat /etc/*release | grep -q "Ubuntu"); then
    tuong_thich_nhom_litespeed="nogroup"
  else
    tuong_thich_nhom_litespeed="nobody"
  fi

  chown -R nobody:$tuong_thich_nhom_litespeed /usr/local/lsws/"$NAME"/logs
  chmod 700 /usr/local/lsws/"$NAME"/logs

  # =========================================================
  # TÍNH TOÁN BIẾN VÀ CẤU HÌNH FAIL2BAN ENTERPRISE
  # =========================================================
  rule_fail2ban_name="ddos-home-$NAME2"
  if ((${#rule_fail2ban_name} > 20)); then
    rule_fail2ban_name=$(echo $rule_fail2ban_name | cut -c 1-20)
  fi

  if [[ -f /etc/csf/csf.conf ]]; then
    action_thuc_thi_block="iptables-multiport[actname=block-tcp, name=$rule_fail2ban_name-t, port=\"80,443\", protocol=\"tcp\"]
           iptables-multiport[actname=block-udp, name=$rule_fail2ban_name-u, port=\"80,443\", protocol=\"udp\"]"
  elif [[ $(systemctl status nftables.service 2>/dev/null | grep 'Active' | cut -f2 -d':' | xargs | cut -f1 -d' ' | xargs) = "active" ]]; then
    action_thuc_thi_block="nftables-allports[name=$rule_fail2ban_name]"
  elif [[ $(systemctl status firewalld.service 2>/dev/null | grep 'Active' | cut -f2 -d':' | xargs | cut -f1 -d' ' | xargs) = "active" ]]; then
    action_thuc_thi_block="firewallcmd-ipset[actname=block-tcp, name=$rule_fail2ban_name-t, port=\"80,443\", protocol=\"tcp\"]
           firewallcmd-ipset[actname=block-udp, name=$rule_fail2ban_name-u, port=\"80,443\", protocol=\"udp\"]"
  else
    action_thuc_thi_block="iptables-multiport[actname=block-tcp, name=$rule_fail2ban_name-t, port=\"80,443\", protocol=\"tcp\"]
           iptables-multiport[actname=block-udp, name=$rule_fail2ban_name-u, port=\"80,443\", protocol=\"udp\"]"
  fi

  echo "
#begin-ddos-website-$NAME2-home-page
[ddos-$NAME2-home-page]
enabled = true
action = $action_thuc_thi_block
filter = ddos-$NAME2-home-page
logpath = /usr/local/lsws/$NAME/logs/access.log
backend = pyinotify
bantime = 72000
maxretry = 5
findtime = 10
#end-ddos-website-$NAME2-home-page" >>/etc/fail2ban/jail.local

  # Tối ưu Regex: Chỉ bắt chính xác các request gọi vào root ("GET / HTTP...").
  # Không bắt nhầm các URL có query string (?v=123) hoặc các file con nằm ở thư mục root.
  echo '[Definition]
failregex = ^<HOST> .* "(GET|POST) \/ HTTP\/.*" (200|500) .*
ignoreregex = \.(?i)(robots\.txt|favicon\.ico|jpg|png|webp|css|js|jpeg|woff2|avif|gif|svg|woff|ttf)(\?.*)?$' >/etc/fail2ban/filter.d/ddos-$NAME2-home-page.conf

  fail2ban-client reload >/dev/null 2>&1 || systemctl restart fail2ban >/dev/null 2>&1
  /usr/local/lsws/bin/lswsctrl restart >/dev/null 2>&1
  _rundone "Thiết lập chống ddos trang chủ cho website $NAME"
  echo "Nếu trong 10 giây mà có 5 yêu cầu (html document) thẳng vào trang chủ, IP sẽ bị khóa 20 tiếng"
fi

check_menu_wptangtoc_active=$1
if [[ $check_menu_wptangtoc_active = "98" ]]; then
  exec /etc/wptt/wptt-bao-mat-main 1
fi
