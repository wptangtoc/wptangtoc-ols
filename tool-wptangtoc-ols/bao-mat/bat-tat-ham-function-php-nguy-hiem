# @since: 2026

function huong_dan() {
  Kích hoạt hoặc huỷ kích hoạt chặn thực thi những hàm nguy hiểm về bảo mật PHP:

  Chặn các hàm PHP như exec, system, passthru, shell_exec, dl, show_source, và các hàm posix_* khác là một biện pháp bảo mật quan trọng trên máy chủ web. Việc này giúp ngăn chặn các cuộc tấn công tiềm ẩn, đặc biệt khi chạy các ứng dụng PHP có thể chứa lỗ hổng.

  Gồm những hàm: exec,system,passthru,shell_exec,dl,show_source,posix_kill,posix_mkfifo,posix_getpwuid,posix_setpgid,posix_setsid,posix_setuid,posix_setgid,posix_seteuid,posix_setegid,posix_uname

  Tại sao cần chặn các hàm này?
  Các hàm bạn liệt kê có khả năng thực hiện những tác vụ nhạy cảm, có thể bị lạm dụng nếu mã PHP bị xâm nhập hoặc chứa lỗ hổng:

  Thực thi lệnh hệ thống:
  * exec[], system[], passthru[], shell_exec[]: Cho phép PHP chạy các lệnh trực tiếp trên hệ điều hành của máy chủ. Nếu kẻ tấn công kiểm soát được đầu vào của các hàm này, họ có thể thực thi mã độc, chiếm quyền kiểm soát máy chủ.
  * Tải thư viện động và hiển thị mã nguồn:
  * dl[]: Cho phép tải các phần mở rộng PHP động trong lúc chạy. Kẻ tấn công có thể dùng nó để tải mã độc. [Hàm này thường bị vô hiệu hóa mặc định ở các phiên bản PHP mới hơn].
  * show_source[] [còn gọi là highlight_file[]]: Hiển thị mã nguồn của một tệp PHP. Kẻ tấn công có thể lợi dụng để xem mã nguồn, tìm kiếm lỗ hổng.
  * Quản lý tiến trình và thông tin POSIX:
  * Các hàm posix_* [như posix_kill, posix_setuid, posix_getpwuid, posix_uname]: Cung cấp khả năng tương tác sâu với hệ điều hành dựa trên POSIX, bao gồm việc kết thúc tiến trình, thay đổi quyền sở hữu của tiến trình, hoặc thu thập thông tin chi tiết về hệ thống và người dùng. Việc lạm dụng các hàm này có thể dẫn đến leo thang đặc quyền hoặc phá hoại hệ thống.

  Tác động
  * Tăng cường bảo mật: Giảm đáng kể nguy cơ máy chủ bị tấn công qua các lỗ hổng trong mã PHP hoặc khi kẻ tấn công tìm cách thực thi mã tùy ý.
  * Có thể ảnh hưởng đến một số ứng dụng: Một số plugin, theme hoặc ứng dụng PHP hợp lệ có thể sử dụng các hàm này cho các chức năng cụ thể [ví dụ: một số plugin backup có thể dùng shell_exec]. Nếu bạn chặn chúng, các ứng dụng đó có thể không hoạt động đúng cách. Trong trường hợp này, bạn cần cân nhắc kỹ giữa bảo mật và tính năng, hoặc tìm giải pháp thay thế an toàn hơn.

  Ghi chú: khi bật có thể bị lỗi một số tính năng bạn vui lòng kiểm tra kỹ trước khi triển khai.
}

. /etc/wptt/.wptt.conf
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh

echo -e "\n========================================================================="
echo -e "| Quản lý bảo mật => Bật/Tắt chặn hàm nguy hiểm PHP                     |"
echo -e "=========================================================================\n"

RED='\033[0;31m'
NC='\033[0m'
xanh='\033[0;32m'

# --- 1. HIỂN THỊ BẢNG TRẠNG THÁI NHANH ---
if [[ -n "$(ls -A /etc/wptt/vhost 2>/dev/null)" ]]; then
  echo "Kiểm tra website chặn hàm nguy hiểm PHP:"
  echo "========================================================================="
  for filepath in /etc/wptt/vhost/.*.conf; do
    [[ ! -f "$filepath" || "$filepath" == *"/..conf" ]] && continue
    domain="${filepath##*/}"
    domain="${domain%.conf}"
    domain="${domain#.}"

    if [[ "$domain" == ?*.?* ]]; then
      vhost_path="/usr/local/lsws/conf/vhosts/$domain/$domain.conf"
      if [[ -f "$vhost_path" ]]; then
        if grep -q 'disable_functions' "$vhost_path" 2>/dev/null; then
          echo -e "Hệ thống kiểm tra website \033[1;33m$domain\033[0m tính năng: ${xanh}Đang được bật${NC}"
        else
          echo -e "Hệ thống kiểm tra website \033[1;33m$domain\033[0m tính năng: ${RED}Đang được tắt${NC}"
        fi
      fi
    fi
  done
  echo -e "=========================================================================\n"
fi

. /etc/wptt/tenmien
echo "Lựa chọn website muốn Bật/Tắt chặn hàm nguy hiểm PHP: "
lua_chon_NAME
echo ""

. /etc/wptt/echo-color

# --- CHỐT CHẶN THOÁT HIỂM ---
[[ "$NAME" == "0" || -z "$NAME" ]] && exec /etc/wptt/wptt-bao-mat-main 1

vhost_conf="/usr/local/lsws/conf/vhosts/$NAME/$NAME.conf"
[[ ! -f "$vhost_conf" ]] && {
  clear
  echoDo "Tên miền không tồn tại trên hệ thống này"
  sleep 2
  exec /etc/wptt/wptt-bao-mat-main 1
}

# --- 2. KIỂM TRA TRẠNG THÁI VÀ XỬ LÝ LOGIC ---
has_disable_funcs=$(grep -c 'disable_functions' "$vhost_conf")
# CHỈ TÌM khối phpIniOverride độc lập ở ngoài cùng (sát lề trái)
has_root_php_override=$(grep -c '^phpIniOverride' "$vhost_conf")

FUNCS_LIST="exec,system,passthru,shell_exec,dl,show_source,posix_kill,posix_mkfifo,posix_getpwuid,posix_setpgid,posix_setsid,posix_setuid,posix_setgid,posix_seteuid,posix_setegid,posix_uname"

if [[ $has_disable_funcs -gt 0 ]]; then
  # TRẠNG THÁI: ĐANG BẬT -> HỎI ĐỂ TẮT
  echo -e "Hiện tại website \033[1;33m$NAME\033[0m \033[1;32mĐANG KÍCH HOẠT\033[0m chặn các hàm PHP nguy hiểm."
  prompt="Bạn có muốn TẮT tính năng chặn hàm không? [1-2]: "
  dongytat="n"
  options=("Đồng ý TẮT CHẶN" "Không đồng ý (Thoát)")
  PS3="$prompt"
  select opt in "${options[@]}"; do
    case "$REPLY" in
    1)
      dongytat="y"
      break
      ;;
    2)
      dongytat="n"
      break
      ;;
    *)
      printf "\nNhập sai, hệ thống tự động HỦY BỎ.\n"
      break
      ;;
    esac
  done

  if [[ "$dongytat" == "y" ]]; then
    UI_STRING="Tắt chặn các hàm nguy hiểm cho website $NAME"
    _runing "$UI_STRING"
    echo "Tắt chặn hàm nguy hiểm PHP website $NAME: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log

    # BƯỚC 1: Xóa đúng dòng disable_functions
    sed -i '/disable_functions/d' "$vhost_conf"

    #phpIniOverride xoá nếu rỗng
    sed -i '/^phpIniOverride[[:space:]]*{/{:a; /}/!{N; ba;}; /^phpIniOverride[[:space:]]*{[[:space:]\n]*}$/d}' "$vhost_conf"

    _rundone "$UI_STRING"
  else
    exec /etc/wptt/wptt-bao-mat-main 1
  fi

else
  # TRẠNG THÁI: ĐANG TẮT -> HỎI ĐỂ BẬT
  echo -e "Hiện tại website \033[1;33m$NAME\033[0m \033[1;31mĐANG KHÔNG CHẶN\033[0m các hàm PHP nguy hiểm."
  prompt="Bạn có muốn BẬT tính năng chặn hàm không? [1-2]: "
  dongybat="n"
  options=("Đồng ý BẬT CHẶN" "Không đồng ý (Thoát)")
  PS3="$prompt"
  select opt in "${options[@]}"; do
    case "$REPLY" in
    1)
      dongybat="y"
      break
      ;;
    2)
      dongybat="n"
      break
      ;;
    *)
      printf "\nNhập sai, hệ thống tự động HỦY BỎ.\n"
      break
      ;;
    esac
  done

  if [[ "$dongybat" == "y" ]]; then
    UI_STRING="Bật chặn các hàm nguy hiểm cho website $NAME"
    _runing "$UI_STRING"
    echo "Bật chặn hàm nguy hiểm PHP website $NAME: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log

    if [[ $has_root_php_override -gt 0 ]]; then
      sed -i "/^phpIniOverride/a \  php_admin_value disable_functions \"$FUNCS_LIST\"" "$vhost_conf"
    else
      echo -e "\nphpIniOverride  {\n  php_admin_value disable_functions \"$FUNCS_LIST\"\n}" >>"$vhost_conf"
    fi
    _rundone "$UI_STRING"
  else
    exec /etc/wptt/wptt-bao-mat-main 1
  fi
fi

/usr/local/lsws/bin/lswsctrl reload >/dev/null 2>&1

[[ ${1:-} == "98" ]] && exec /etc/wptt/wptt-bao-mat-main 1
