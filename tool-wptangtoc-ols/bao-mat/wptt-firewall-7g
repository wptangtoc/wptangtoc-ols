function huong_dan() {
  Kích hoạt tường lửa 8G:

  Tường lửa 8G giúp bảo vệ chống lại các mối đe dọa phổ biến:
  * Nâng cao bảo mật cho WordPress.
  * Bad Bots: Chặn các bot độc hại, trình thu thập dữ liệu rác.
  * Malicious Requests: Ngăn chặn các yêu cầu chứa mã độc, dấu hiệu tấn công.
  * SQL Injection [SQLi]: Các mẫu tấn công SQL phổ biến.
  * Cross-Site Scripting [XSS]: Các mẫu tấn công XSS.
  * Directory Traversal: Cố gắng truy cập vào các tệp hoặc thư mục không được phép.
  * Remote File Inclusion [RFI] / Local File Inclusion [LFI]: Cố gắng chèn và thực thi tệp từ xa hoặc cục bộ.
  * Spam Referrers: Chặn các referrer spam.

  Ghi chú: Khi kích hoạt tường lửa 8G sẽ làm giảm một phần nhỏ hiệu suất tốc độ của website do máy chủ phải quét qua các quy tắc này.
}

. /etc/wptt/.wptt.conf
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh
. /etc/wptt/echo-color

clear
echo -e "\n========================================================================="
echo -e "| $bao_mat => Bật / Tắt Tường Lửa 8G                                     |"
echo -e "=========================================================================\n"

function lua_chon_NAME() {
  unset NAME domain selects
  selects=()

  # 1. Vòng lặp Globbing siêu tốc quét trạng thái từng website
  for filepath in /etc/wptt/vhost/.*.conf; do
    [[ ! -f "$filepath" || "$filepath" == *"/..conf" ]] && continue

    local domain="${filepath##*/}"
    domain="${domain%.conf}"
    domain="${domain#.}"

    if [[ "$domain" == ?*.?* ]]; then
      local htaccess_path="/usr/local/lsws/$domain/html/.htaccess"
      if [[ -f "$htaccess_path" ]]; then
        if grep -q '#begin-tuong-lua-bao-mat-8g' "$htaccess_path" 2>/dev/null; then
          selects+=("$domain [Đang BẬT 8G]")
        else
          selects+=("$domain [Đang TẮT]")
        fi
      fi
    fi
  done

  # Xử lý trường hợp không có website nào hợp lệ
  if [[ ${#selects[@]} -eq 0 ]]; then
    echo -e "\n\033[1;33mKhông tìm thấy website nào có file .htaccess trên hệ thống để thao tác!\033[0m"
    sleep 3
    exec /etc/wptt/wptt-bao-mat-main 1
  fi

  # 2. Sắp xếp mảng chuẩn Version (Alphabetical)
  mapfile -t selects < <(printf "%s\n" "${selects[@]}" | sort -uV)

  # 3. Thêm tùy chọn "Tất Cả" xuống cuối menu
  if [[ ${#selects[@]} -ge 2 ]]; then
    selects+=("TẤT CẢ WEBSITE (Thao tác đồng loạt)")
  fi

  # 4. Hiển thị Menu PS3 hỗ trợ 00 (FZF)
  if command -v fzf &>/dev/null; then
    PS3="$(tput setab 0)-//- Lựa chọn website muốn thao tác [00=Chọn Nhanh] [0=Thoát]:$(tput sgr0) "
  else
    PS3="$(tput setab 0)-//- Lựa chọn website muốn thao tác [0=Thoát]:$(tput sgr0) "
  fi

  # 5. Vòng lặp lấy giá trị
  select selected_domain in "${selects[@]}"; do
    NAME="$selected_domain"
    break
  done

  # 6. XỬ LÝ CHỌN NHANH [00] VỚI FZF
  if [[ "$REPLY" == "00" ]] && command -v fzf &>/dev/null; then
    local selected_name
    selected_name=$(printf "%s\n" "${selects[@]}" | nl -w 3 -s ': ' | fzf --height 40% --border=rounded --color=border:red --reverse --prompt=">> Tìm website 8G [0=Thoát]: ")
    selected_name=$(echo "$selected_name" | sed 's/^[[:space:]]*[0-9]\+\:[[:space:]]*//')

    if [[ -z "$selected_name" ]]; then
      echo "Đã hủy chọn."
      exec /etc/wptt/wptt-bao-mat-main 1
    fi
    NAME="$selected_name"
  fi

  # 7. Xử lý nhập input thẳng tên domain (nếu không chọn số)
  if [[ -z "$NAME" && "$REPLY" != "0" && "$REPLY" != "00" ]]; then
    REPLY=$(echo "$REPLY" | tr '[:upper:]' '[:lower:]' | xargs)
    for item in "${selects[@]}"; do
      local check_dom=$(echo "$item" | cut -f1 -d ' ')
      if [[ "$check_dom" == "$REPLY" ]]; then
        NAME="$item"
        break
      fi
    done
  fi
}

# Nếu gọi script kèm tên domain từ command line
if [[ -n "$1" && "$1" != "98" ]]; then
  NAME="$1"
else
  lua_chon_NAME
fi

# Tách lấy tên chuẩn (cắt phần đuôi "[Đang BẬT]")
NAME=$(echo "$NAME" | cut -f1 -d ' ')

# --- CHỐT CHẶN THOÁT HIỂM ---
[[ "$NAME" == "0" || -z "$NAME" ]] && exec /etc/wptt/wptt-bao-mat-main 1

path_firewall_rules="/etc/wptt/bao-mat/firewall.txt"
[[ ! -f "$path_firewall_rules" ]] && {
  _runloi "Không tìm thấy bộ quy tắc Tường lửa 8G tại hệ thống!"
  sleep 3
  exec /etc/wptt/wptt-bao-mat-main 1
}

# ==============================================================================
# HÀM THỰC THI BẬT/TẮT TƯỜNG LỬA 8G CHO 1 DOMAIN
# ==============================================================================
function process_firewall_8g() {
  local target_domain=$1
  local action=$2 # "bat" hoac "tat"
  local path_ht="/usr/local/lsws/$target_domain/html/.htaccess"

  if [[ ! -f "$path_ht" ]]; then
    echo "Bỏ qua $target_domain: Không tìm thấy file .htaccess"
    return
  fi

  if [[ "$action" == "bat" ]]; then
    if grep -q '#begin-tuong-lua-bao-mat-8g' "$path_ht" 2>/dev/null; then
      echo "Website $target_domain đã bật 8G trước đó. Bỏ qua..."
      return
    fi

    UI_STRING="Kích hoạt Tường lửa 8G cho $target_domain"
    _runing "$UI_STRING"

    # 1. Dọn dẹp bản 7G hoặc 8G cũ bằng SED thuần túy
    sed -i '/#begin-tuong-lua-bao-mat-[78]g/,/#end-tuong-lua-bao-mat-[78]g/d' "$path_ht"

    # 2. Tiêm Tường lửa 8G lên đỉnh file (Bảo toàn Quyền sở hữu)
    TMP_FILE=$(mktemp)
    cat "$path_firewall_rules" >"$TMP_FILE"
    echo "" >>"$TMP_FILE"
    cat "$path_ht" >>"$TMP_FILE"
    cat "$TMP_FILE" >"$path_ht"
    rm -f "$TMP_FILE"

    # Cập nhật Config Panel
    sed -i '/tuong_lua_7g/d' "/etc/wptt/vhost/.$target_domain.conf" 2>/dev/null
    echo 'tuong_lua_7g=1' >>"/etc/wptt/vhost/.$target_domain.conf"

    # 3. Xử lý Bypass phpMyAdmin cho website chính
    . /etc/wptt/.wptt.conf
    if [[ "$Website_chinh" == "$target_domain" && -d "/usr/local/lsws/$target_domain/html/phpmyadmin" ]]; then
      if ! grep -q 'phpmyadmin/index\\.php' "$path_ht" 2>/dev/null; then
        sed -i '/RewriteCond %{QUERY_STRING} \^(%2d|-)/i \ \ \ \ RewriteCond %{REQUEST_URI} !^\/phpmyadmin\/index\\.php$ [NC]' "$path_ht"
      fi
    fi

    # Update htaccess cache Vhost
    . /etc/wptt/vhost/.$target_domain.conf
    [[ -n "$vhost_chuyen_htaccess" ]] && /etc/wptt/wptt-htaccess-tat-chuyen-doi-vhost "$target_domain" >/dev/null 2>&1

    echo "Bật Firewall 8G website $target_domain: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log
    _rundone "$UI_STRING"

  elif [[ "$action" == "tat" ]]; then
    if ! grep -q '#begin-tuong-lua-bao-mat-8g' "$path_ht" 2>/dev/null; then
      echo "Website $target_domain chưa bật 8G. Bỏ qua..."
      return
    fi

    UI_STRING="Tắt (Hủy) Tường lửa 8G cho $target_domain"
    _runing "$UI_STRING"

    # Dọn dẹp cả 7G và 8G sạch sẽ bằng SED thuần túy
    sed -i '/#begin-tuong-lua-bao-mat-[78]g/,/#end-tuong-lua-bao-mat-[78]g/d' "$path_ht"
    sed -i '/tuong_lua_7g/d' "/etc/wptt/vhost/.$target_domain.conf" 2>/dev/null

    # Update htaccess cache Vhost
    . /etc/wptt/vhost/.$target_domain.conf
    [[ -n "$vhost_chuyen_htaccess" ]] && /etc/wptt/wptt-htaccess-tat-chuyen-doi-vhost "$target_domain" >/dev/null 2>&1

    echo "Tắt Firewall 8G website $target_domain: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log
    _rundone "$UI_STRING"
  fi
}

# ==============================================================================
# XỬ LÝ LÔGIC RẼ NHÁNH
# ==============================================================================

if [[ "$NAME" == "TẤT CẢ WEBSITE (Thao tác đồng loạt)" || "$NAME" == "TẤT" ]]; then
  echo -e "\nBạn muốn BẬT hay TẮT Tường lửa 8G cho \033[1;33mTẤT CẢ\033[0m website?"
  prompt="Lựa chọn của bạn [1-2]: "
  mass_action=""
  options=("BẬT đồng loạt" "TẮT đồng loạt" "Hủy bỏ")
  PS3="$prompt"
  select opt in "${options[@]}"; do
    case "$REPLY" in
    1)
      mass_action="bat"
      break
      ;;
    2)
      mass_action="tat"
      break
      ;;
    3) exec /etc/wptt/wptt-bao-mat-main 1 ;;
    *)
      printf "\nNhập sai, tự động hủy.\n"
      exec /etc/wptt/wptt-bao-mat-main 1
      ;;
    esac
  done

  # Thao tác hàng loạt
  for filepath in /etc/wptt/vhost/.*.conf; do
    [[ ! -f "$filepath" || "$filepath" == *"/..conf" ]] && continue
    domain="${filepath##*/}"
    domain="${domain%.conf}"
    domain="${domain#.}"
    if [[ "$domain" == ?*.?* ]]; then
      process_firewall_8g "$domain" "$mass_action"
    fi
  done

else
  # Đảo trạng thái (Toggle) cho 1 website cụ thể
  pathcheck="/etc/wptt/vhost/.$NAME.conf"
  [[ ! -f "$pathcheck" ]] && {
    echoDo "Tên miền không tồn tại!"
    sleep 2
    exec /etc/wptt/wptt-bao-mat-main 1
  }

  if grep -q '#begin-tuong-lua-bao-mat-8g' "/usr/local/lsws/$NAME/html/.htaccess" 2>/dev/null; then
    process_firewall_8g "$NAME" "tat"
  else
    process_firewall_8g "$NAME" "bat"
  fi
fi

# ==============================================================================
# KHỞI ĐỘNG LẠI DỊCH VỤ & NEO MÀN HÌNH
# ==============================================================================
UI_RELOAD="Nạp lại quy tắc Tường lửa 8G và OpenLiteSpeed"
/usr/local/lsws/bin/lswsctrl reload >/dev/null 2>&1

echo -e "\n========================================================================="

[[ ${1:-} == "98" ]] && exec /etc/wptt/wptt-bao-mat-main 1
