#!/bin/bash

function huong_dan() {
  Tính năng Lockdown WordPress [bảo mật] nó ám chỉ việc áp dụng một tập hợp các biện pháp và cấu hình bảo mật nghiêm ngặt nhằm khóa chặt và làm cứng [harden] website WordPress của bạn, giảm thiểu tối đa các bề mặt tấn công và nguy cơ bị xâm nhập. 🛡️🔒⚙️

  Nói một cách đơn giản, lockdown là bạn triển khai nhiều lớp bảo vệ mạnh mẽ để niêm phong các khu vực nhạy cảm của website, khiến cho kẻ xấu khó có thể đột nhập hoặc gây hại. hoặc dù có đột nhập được nhưng không thể phá hoại được gì.

  Mục Đích Chính
  * Nâng cao bảo mật tối đa: Tạo ra một hàng rào phòng thủ vững chắc chống lại các cuộc tấn công dò mật khẩu, mã độc, và truy cập trái phép.
  * Bảo vệ các khu vực quan trọng: Đặc biệt khóa các phần nhạy cảm như trang quản trị [wp-admin], [Plugin], [Themes] và các tệp tin cốt lõi [như wp-config.php].
  * Giảm thiểu bề mặt tấn công: Hạn chế hoặc vô hiệu hóa các tính năng không cần thiết có thể bị lợi dụng.
  * Phòng ngừa chủ động: Áp dụng các biện pháp mạnh mẽ để ngăn chặn tấn công thay vì chỉ phản ứng sau khi sự cố xảy ra.
  Một website WordPress được lockdown sẽ có khả năng chống chịu tấn công tốt hơn nhiều, giảm thiểu rủi ro và mang lại sự an tâm hơn cho người quản trị.
}

. /etc/wptt/.wptt.conf
[[ $ngon_ngu == '' ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh

echo -e "\n========================================================================="
echo -e "|$bao_mat => $bat/$tat Lock Down                                         |"
echo -e "=========================================================================\n"

RED='\033[0;31m'
NC='\033[0m'
xanh='\033[0;32m'

# --- 1. KIỂM TRA TRẠNG THÁI TOÀN BỘ WEBSITE (SIÊU TỐC) ---
echo "Kiểm tra trạng thái Lock Down:"
echo "========================================================================="
for filepath in /etc/wptt/vhost/.*.conf; do
  [[ ! -f "$filepath" || "$filepath" == *"/..conf" ]] && continue

  domain="${filepath##*/}"
  domain="${domain%.conf}"
  domain="${domain#.}"

  if [[ "$domain" == ?*.?* ]]; then
    path="/usr/local/lsws/$domain/html"
    if [[ -d "$path" ]]; then
      unset lock_down
      . "$filepath"
      if [[ -z "$lock_down" ]]; then
        echo -e "Hệ thống kiểm tra website $domain: ${RED}Đang tắt${NC}"
      else
        echo -e "Hệ thống kiểm tra website $domain: ${xanh}Đang bật${NC}"
      fi
    fi
  fi
done
echo "========================================================================="
echo ""

. /etc/wptt/tenmien
echo -e "\n$lua_chon_website_ban_muon $bat/$tat Lock Down: \n"
lua_chon_NAME

[[ "$NAME" == "0" || -z "$NAME" ]] && exec /etc/wptt/wptt-bao-mat-main 1

path_conf="/etc/wptt/vhost/.$NAME.conf"
[[ ! -f "$path_conf" ]] && {
  echoDo "Tên miền không tồn tại trên hệ thống này"
  sleep 2
  exec /etc/wptt/wptt-wordpress-main 1
}

. /etc/wptt/echo-color
unset lock_down
path_conf="/etc/wptt/vhost/.$NAME.conf"
. "$path_conf"
path="/usr/local/lsws/$NAME/html"

# --- 2. BẬT TÍNH NĂNG LOCK DOWN ---
if [[ -z "$lock_down" ]]; then
  echo "Xác nhận bạn muốn BẬT tính năng Lock Down cho website ${NAME}? "
  prompt="Nhập lựa chọn của bạn [1-2]: "
  dongy="n"
  options=("Đồng ý" "Không đồng ý")
  PS3="$prompt"
  select opt in "${options[@]}"; do
    case "$REPLY" in
    1)
      dongy="y"
      break
      ;;
    2)
      dongy="n"
      break
      ;;
    *)
      printf "\nBạn nhập sai hệ thống sẽ chọn là không đồng ý\n"
      break
      ;;
    esac
  done

  if [[ "$dongy" == 'y' ]]; then
    UI_STRING="Kích hoạt tính năng Lock Down cho $NAME"
    _runing "$UI_STRING"

    # Lockdown toàn bộ (Khóa chốt chặn)
    find "$path" -type f -print0 | xargs -0 chmod 404
    find "$path" -type d -print0 | xargs -0 chmod 515

    # Trả quyền các file Preload của WPTangToc
    [[ -f "$path/wp-content/preload-wptangtoc-url.txt" ]] && chmod 644 "$path/wp-content/preload-wptangtoc-url.txt"
    [[ -f "$path/wp-content/preload-wptangtoc.json" ]] && chmod 644 "$path/wp-content/preload-wptangtoc.json"

    # Trả quyền thư mục Uploads
    if [[ -d "$path/wp-content/uploads" ]]; then
      find "$path/wp-content/uploads" -type d -print0 | xargs -0 chmod 755
      # Khóa toàn bộ index.php trong Uploads (Fix mảng khoảng trắng)
      find "$path/wp-content/uploads" -type f -name "index.php" -print0 | xargs -0 chmod 404
    fi

    # Gọi module Chattr
    . /etc/wptt/bao-mat/wptt-chattr-file-lock "$NAME" on

    # Tương thích Plugin Cache & Litespeed
    for bypass_dir in "cache" "litespeed"; do
      if [[ -d "$path/wp-content/$bypass_dir" ]]; then
        find "$path/wp-content/$bypass_dir" -type d -print0 | xargs -0 chmod 755
        find "$path/wp-content/$bypass_dir" -type f -print0 | xargs -0 chmod 644
      fi
    done

    # Tương thích SQLite
    if [[ -d "$path/wp-content/database" ]]; then
      chmod 755 "$path/wp-content/database"
      find "$path/wp-content/database" -type f -print0 | xargs -0 chmod 644
      find "$path/wp-content/database" -type f -name ".ht.sqlite*" -print0 | xargs -0 chmod 644
    fi

    # Cập nhật config
    sed -i '/lock_down/d' "$path_conf"
    echo "lock_down=1" >>"$path_conf"

    _rundone "$UI_STRING"
  fi
fi

# --- 3. TẮT TÍNH NĂNG LOCK DOWN ---
if [[ -n "$lock_down" ]]; then
  echo "Xác nhận bạn muốn TẮT tính năng Lock Down cho website ${NAME}? "
  prompt="Nhập lựa chọn của bạn [1-2]: "
  dongy="n"
  options=("Đồng ý" "Không đồng ý")
  PS3="$prompt"
  select opt in "${options[@]}"; do
    case "$REPLY" in
    1)
      dongy="y"
      break
      ;;
    2)
      dongy="n"
      break
      ;;
    *)
      printf "\nBạn nhập sai hệ thống sẽ chọn là không đồng ý\n"
      break
      ;;
    esac
  done

  if [[ "$dongy" == 'y' ]]; then
    UI_STRING="Tắt tính năng Lock Down cho $NAME"
    _runing "$UI_STRING"

    . /etc/wptt/bao-mat/wptt-chattr-file-lock "$NAME" off

    find "$path" -type f -print0 | xargs -0 chmod 644
    find "$path" -type d -print0 | xargs -0 chmod 755

    sed -i '/lock_down/d' "$path_conf"

    _rundone "$UI_STRING"
  fi
fi

[[ ${1:-} == "98" ]] && exec /etc/wptt/wptt-bao-mat-main 1
