#!/bin/bash

function huong_dan() {
  Tính năng Lockdown WordPress [bảo mật] nó ám chỉ việc áp dụng một tập hợp các biện pháp và cấu hình bảo mật nghiêm ngặt nhằm khóa chặt và làm cứng [harden] website WordPress của bạn, giảm thiểu tối đa các bề mặt tấn công và nguy cơ bị xâm nhập.

  Nói một cách đơn giản, lockdown là bạn triển khai nhiều lớp bảo vệ mạnh mẽ để niêm phong các khu vực nhạy cảm của website, khiến cho kẻ xấu khó có thể đột nhập hoặc gây hại. hoặc dù có đột nhập được nhưng không thể phá hoại được gì.

  Mục Đích Chính
  * Nâng cao bảo mật tối đa: Tạo ra một hàng rào phòng thủ vững chắc chống lại các cuộc tấn công dò mật khẩu, mã độc, và truy cập trái phép.
  * Bảo vệ các khu vực quan trọng: Đặc biệt khóa các phần nhạy cảm như trang quản trị [wp-admin], [Plugin], [Themes] và các tệp tin cốt lõi [như wp-config.php].
  * Giảm thiểu bề mặt tấn công: Hạn chế hoặc vô hiệu hóa các tính năng không cần thiết có thể bị lợi dụng.
  * Phòng ngừa chủ động: Áp dụng các biện pháp mạnh mẽ để ngăn chặn tấn công thay vì chỉ phản ứng sau khi sự cố xảy ra.
  Một website WordPress được lockdown sẽ có khả năng chống chịu tấn công tốt hơn nhiều, giảm thiểu rủi ro và mang lại sự an tâm hơn cho người quản trị.
}

# ==============================================================================
# NẠP CẤU HÌNH, NGÔN NGỮ VÀ MÀU SẮC
# ==============================================================================
. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null

clear
echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}$bao_mat ➜ Bật / Tắt Lock Down (Đóng băng File/Folder)${C_RESET}"
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯${C_RESET}\n"

# ==============================================================================
# HÀM CHỌN WEBSITE CÓ HIỂN THỊ TRẠNG THÁI LOCK DOWN
# ==============================================================================
function lua_chon_NAME() {
  unset NAME
  local selects=()
  local i=1
  local box_inner_width=${box_inner_width:-71}

  if [ "$(ls -A /etc/wptt/vhost 2>/dev/null)" ]; then
    for filepath in /etc/wptt/vhost/.*.conf; do
      [[ ! -f "$filepath" || "$filepath" == *"/..conf" ]] && continue

      local domain="${filepath##*/}"
      domain="${domain%.conf}"
      domain="${domain#.}"

      if [[ "$domain" == ?*.?* ]]; then
        local path_html="/usr/local/lsws/$domain/html"
        if [[ -d "$path_html" ]]; then
          unset lock_down
          . "$filepath" 2>/dev/null

          local status_text=""
          local status_color=""

          if [[ -z "$lock_down" ]]; then
            status_text="[Đang MỞ - Cho phép sửa đổi]"
            status_color=$C_RED
          else
            status_text="[Đang KHÓA - Đóng băng]"
            status_color=$C_GREEN
          fi

          selects+=("$domain|$status_text|$status_color")
        fi
      fi
    done
  fi

  if [[ ${#selects[@]} -eq 0 ]]; then
    echo -e "\n${C_RED}❌ Lỗi: $khong_co_domain_nao_ton_tai_tren_he_thong${C_RESET}"
    exit
  fi

  mapfile -t selects < <(printf "%s\n" "${selects[@]}" | sort -uV)

  # RENDER BOX CHỌN DOMAIN (UX TAB GẠCH CHÂN)
  echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
  local title_text="Nhập lựa chọn website muốn thao tác Lock Down:"
  local clean_title=$(echo -e "$title_text" | sed "s/\x1B\[[0-9;]*[a-zA-Z]//g")
  local len=${#clean_title}
  local pad_r=$((box_inner_width - len - 2))
  [[ $pad_r -lt 0 ]] && pad_r=0

  echo -e "${C_CYAN}│${C_RESET}  ${C_YELLOW}${title_text}${C_RESET}$(printf '%*s' "$pad_r" "")${C_CYAN}│${C_RESET}"

  local line_len=$((len + 3))
  local pad_line_r=$((box_inner_width - line_len))
  [[ $pad_line_r -lt 0 ]] && pad_line_r=0
  local short_line=$(printf "%${line_len}s" "" | sed 's/ /─/g')
  echo -e "${C_CYAN}├${short_line}$(printf '%*s' "$pad_line_r" "")│${C_RESET}"

  for val in "${selects[@]}"; do
    IFS='|' read -r d s c <<<"$val"
    local clean_row=$(printf "  %3d) %-32s %s" "$i" "$d" "$s")
    local item_row=$(printf "  ${C_CYAN}%3d)${C_RESET} ${C_BOLD_WHITE}%-32s${C_RESET} ${c}%s${C_RESET}" "$i" "$d" "$s")
    local pad=$((box_inner_width - ${#clean_row}))
    [[ $pad -lt 0 ]] && pad=0

    echo -e "${C_CYAN}│${C_RESET}${item_row}$(printf '%*s' "$pad" "")${C_CYAN}│${C_RESET}"
    ((i++))
  done
  echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯${C_RESET}"

  local fzf_installed=false
  command -v fzf &>/dev/null && fzf_installed=true
  local prompt_msg="${lua_chon_website_ban_muon:-Nhập lựa chọn} (1-${#selects[@]}) [00=${chon_nhanh:-Chọn nhanh}] [0=${exit_thoat:-Thoát}]: "

  while true; do
    echo -en "${C_CYAN}${prompt_msg}${C_RESET}"
    if ! read -r REPLY; then exit 1; fi
    REPLY=$(echo "$REPLY" | tr -d ' ' | tr '[:upper:]' '[:lower:]')

    case "$REPLY" in
    0) exec /etc/wptt/wptt-bao-mat-main 1 ;;
    00)
      if $fzf_installed; then
        local fzf_list=()
        for val in "${selects[@]}"; do
          IFS='|' read -r d s c <<<"$val"
          fzf_list+=("$d $s")
        done
        local sel=$(printf '%s\n' "${fzf_list[@]}" | nl -w 3 -s ': ' | fzf --height=40% --border=rounded --reverse)
        NAME=$(echo "$sel" | sed 's/^[[:space:]]*[0-9]\+\:[[:space:]]*//' | awk '{print $1}')
        [[ -n "$NAME" ]] && return 0 || continue
      fi
      ;;
    *)
      if [[ "$REPLY" =~ ^[0-9]+$ ]] && [ "$REPLY" -ge 1 ] && [ "$REPLY" -le ${#selects[@]} ]; then
        local val="${selects[$((REPLY - 1))]}"
        NAME="${val%|*|*}"
        return 0
      elif [[ "$REPLY" == ?*.?* ]]; then
        NAME="$REPLY"
        return 0
      fi
      ;;
    esac
  done
}

# Nếu gọi script kèm tên domain từ command line
if [[ -n "$1" && "$1" != "98" ]]; then
  NAME="$1"
else
  lua_chon_NAME "Bật / Tắt Lock Down"
fi

# ==============================================================================
# XỬ LÝ LOGIC BẬT / TẮT LOCK DOWN
# ==============================================================================
path_conf="/etc/wptt/vhost/.$NAME.conf"
[[ ! -f "$path_conf" ]] && echo -e "\n${C_RED}❌ Tên miền không tồn tại trên hệ thống này${C_RESET}" && sleep 2 && exec /etc/wptt/wptt-bao-mat-main 1

path="/usr/local/lsws/$NAME/html"
[[ ! -d "$path" ]] && echo -e "\n${C_RED}❌ Không tìm thấy thư mục chứa mã nguồn của $NAME${C_RESET}" && sleep 2 && exec /etc/wptt/wptt-bao-mat-main 1

unset lock_down
. "$path_conf"

if [[ -z "$lock_down" ]]; then
  # Đang TẮT -> Gợi ý BẬT
  action_text="BẬT (Khóa cứng file/thư mục)"
  wp_action="bat"
else
  # Đang BẬT -> Gợi ý TẮT
  action_text="TẮT (Mở khóa file/thư mục)"
  wp_action="tat"
fi

echo -en "\n${C_YELLOW}Xác nhận $action_text cho website ${C_BOLD_WHITE}$NAME${C_YELLOW}? [y/n]: ${C_RESET}"
read -r confirm
[[ ! "$confirm" =~ ^[yY]$ ]] && echo -e "${C_YELLOW}Đã hủy thao tác.${C_RESET}" && sleep 1 && exec /etc/wptt/wptt-bao-mat-main 1

echo ""
_runing "$action_text cho $NAME (Có thể mất vài giây)"

if [[ "$wp_action" == "bat" ]]; then
  # =====================================
  # THỰC THI BẬT LOCK DOWN
  # =====================================
  # 1. Khóa toàn bộ
  find "$path" -type f -print0 | xargs -0 chmod 404
  find "$path" -type d -print0 | xargs -0 chmod 515

  # 2. Trả quyền các file Preload của WPTangToc
  [[ -f "$path/wp-content/preload-wptangtoc-url.txt" ]] && chmod 644 "$path/wp-content/preload-wptangtoc-url.txt"
  [[ -f "$path/wp-content/preload-wptangtoc.json" ]] && chmod 644 "$path/wp-content/preload-wptangtoc.json"

  # 3. Trả quyền thư mục Uploads
  if [[ -d "$path/wp-content/uploads" ]]; then
    find "$path/wp-content/uploads" -type d -print0 | xargs -0 chmod 755
    find "$path/wp-content/uploads" -type f -name "index.php" -print0 | xargs -0 chmod 404
  fi

  # 4. Tương thích Plugin Cache & Litespeed
  for bypass_dir in "cache" "litespeed"; do
    if [[ -d "$path/wp-content/$bypass_dir" ]]; then
      find "$path/wp-content/$bypass_dir" -type d -print0 | xargs -0 chmod 755
      find "$path/wp-content/$bypass_dir" -type f -print0 | xargs -0 chmod 644
    fi
  done

  # 5. Tương thích SQLite
  if [[ -d "$path/wp-content/database" ]]; then
    chmod 755 "$path/wp-content/database"
    find "$path/wp-content/database" -type f -print0 | xargs -0 chmod 644
    find "$path/wp-content/database" -type f -name ".ht.sqlite*" -print0 | xargs -0 chmod 644
  fi

  # 6. Gọi module Chattr
  . /etc/wptt/bao-mat/wptt-chattr-file-lock "$NAME" on

  # 7. Cập nhật config
  sed -i '/lock_down/d' "$path_conf"
  echo "lock_down=1" >>"$path_conf"

else
  . /etc/wptt/bao-mat/wptt-chattr-file-lock "$NAME" off
  find "$path" -type f -print0 | xargs -0 chmod 644
  find "$path" -type d -print0 | xargs -0 chmod 755

  sed -i '/lock_down/d' "$path_conf"
fi

echo "$action_text Lock Down website $NAME: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log
_rundone "Hoàn tất thao tác $action_text cho $NAME"

if [[ ${1:-} == "98" ]]; then
  exec /etc/wptt/wptt-bao-mat-main 1
fi
