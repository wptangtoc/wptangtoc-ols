#!/bin/bash
# @author: Gia Tuấn
# @website: https://wptangtoc.com
# @since: 2026

function huong_dan() {
  Kích hoạt hoặc huỷ kích hoạt open_basedir để nâng cao bảo mật PHP để giảm thiểu tối đa việc 1 website bị hack, nó lây ra website còn lại.

  open_basedir là đóng phân vùng hoạt động của PHP

  Mục đích chính của open_basedir:

  * Tăng cường bảo mật: Đây là mục đích cốt lõi. Bằng cách giới hạn phạm vi truy cập tệp tin, open_basedir giúp ngăn chặn các script PHP [đặc biệt là khi website bị tấn công hoặc chứa mã độc] truy cập, đọc hoặc ghi vào các tệp tin nhạy cảm nằm ngoài thư mục gốc của website đó. Điều này đặc biệt hữu ích trong môi trường hosting chia sẻ, nơi nhiều website cùng hoạt động trên một máy chủ. Nếu một website bị xâm nhập, open_basedir sẽ giúp hạn chế khả năng mã độc lây lan sang các website khác hoặc truy cập vào các tệp tin hệ thống của máy chủ.
  * Kiểm soát môi trường thực thi của PHP: Nó giúp quản trị viên máy chủ định rõ những khu vực nào trên hệ thống tệp mà các kịch bản PHP được phép tương tác.

  Thường anh em sử dụng plugin backup như duplicator hay backupbuddy sẽ bị lỗi.. nếu bạn không sử dụng plugin thì hãy nên bật tính năng này.
  Ghi chú: khi bật có thể bị lỗi một số tính năng bạn vui lòng kiểm tra kỹ trước khi triển khai.
}

. /etc/wptt/.wptt.conf
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh

echo -e "\n========================================================================="
echo -e "|$bao_mat => Bật/Tắt open_basedir                                      |"
echo -e "=========================================================================\n"

RED='\033[0;31m'
NC='\033[0m'
xanh='\033[0;32m'

# --- 1. HIỂN THỊ BẢNG TRẠNG THÁI NHANH ---
if [[ -n "$(ls -A /etc/wptt/vhost 2>/dev/null)" ]]; then
  echo "Kiểm tra website kích hoạt open_basedir:"
  echo "========================================================================="
  for filepath in /etc/wptt/vhost/.*.conf; do
    [[ ! -f "$filepath" || "$filepath" == *"/..conf" ]] && continue
    domain="${filepath##*/}"
    domain="${domain%.conf}"
    domain="${domain#.}"

    if [[ "$domain" == ?*.?* ]]; then
      vhost_path="/usr/local/lsws/conf/vhosts/$domain/$domain.conf"
      if [[ -f "$vhost_path" ]]; then
        if grep -q 'open_basedir' "$vhost_path" 2>/dev/null; then
          echo -e "Hệ thống kiểm tra website \033[1;33m$domain\033[0m tính năng: ${xanh}Đang được bật${NC}"
        else
          echo -e "Hệ thống kiểm tra website \033[1;33m$domain\033[0m tính năng: ${RED}Đang được tắt${NC}"
        fi
      fi
    fi
  done
  echo -e "=========================================================================\n"
fi

. /etc/wptt/tenmien
echo "Lựa chọn website muốn Bật/Tắt open_basedir: "
lua_chon_NAME
echo ""

. /etc/wptt/echo-color

# --- CHỐT CHẶN THOÁT HIỂM ---
[[ "$NAME" == "0" || -z "$NAME" ]] && exec /etc/wptt/wptt-bao-mat-main 1

vhost_conf="/usr/local/lsws/conf/vhosts/$NAME/$NAME.conf"
[[ ! -f "$vhost_conf" ]] && {
  clear
  echoDo "Tên miền không tồn tại trên hệ thống này"
  sleep 2
  exec /etc/wptt/wptt-bao-mat-main 1
}

# --- 2. KIỂM TRA TRẠNG THÁI VÀ XỬ LÝ LOGIC ---
has_open_basedir=$(grep -c 'open_basedir' "$vhost_conf")
# CHỈ TÌM khối phpIniOverride độc lập ở ngoài cùng (sát lề trái)
has_root_php_override=$(grep -c '^phpIniOverride' "$vhost_conf")

ALLOWED_PATHS="/usr/local/lsws/$NAME:/tmp:/var/run/redis:/var/run/memcached:/var/run/valkey:/var/run/keydb"

if [[ $has_open_basedir -gt 0 ]]; then
  # TRẠNG THÁI: ĐANG BẬT -> HỎI ĐỂ TẮT
  echo -e "Hiện tại website \033[1;33m$NAME\033[0m \033[1;32mĐANG KÍCH HOẠT\033[0m tính năng open_basedir."
  prompt="Bạn có muốn TẮT open_basedir không? [1-2]: "
  dongytat="n"
  options=("Đồng ý TẮT CHẶN" "Không đồng ý (Thoát)")
  PS3="$prompt"
  select opt in "${options[@]}"; do
    case "$REPLY" in
    1)
      dongytat="y"
      break
      ;;
    2)
      dongytat="n"
      break
      ;;
    *)
      printf "\nNhập sai, hệ thống tự động HỦY BỎ.\n"
      break
      ;;
    esac
  done

  if [[ "$dongytat" == "y" ]]; then
    UI_STRING="Tắt open_basedir của website $NAME"
    _runing "$UI_STRING"
    echo "Tắt open_basedir website $NAME: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log

    # BƯỚC 1: Xóa đúng dòng open_basedir
    sed -i '/open_basedir/d' "$vhost_conf"

    #phpIniOverride xoá nếu rỗng
    sed -i '/^phpIniOverride[[:space:]]*{/{:a; /}/!{N; ba;}; /^phpIniOverride[[:space:]]*{[[:space:]\n]*}$/d}' "$vhost_conf"

    _rundone "$UI_STRING"
  else
    exec /etc/wptt/wptt-bao-mat-main 1
  fi

else
  # TRẠNG THÁI: ĐANG TẮT -> HỎI ĐỂ BẬT
  echo -e "Hiện tại website \033[1;33m$NAME\033[0m \033[1;31mĐANG KHÔNG KÍCH HOẠT\033[0m tính năng open_basedir."
  prompt="Bạn có muốn BẬT open_basedir không? [1-2]: "
  dongybat="n"
  options=("Đồng ý BẬT CHẶN" "Không đồng ý (Thoát)")
  PS3="$prompt"
  select opt in "${options[@]}"; do
    case "$REPLY" in
    1)
      dongybat="y"
      break
      ;;
    2)
      dongybat="n"
      break
      ;;
    *)
      printf "\nNhập sai, hệ thống tự động HỦY BỎ.\n"
      break
      ;;
    esac
  done

  if [[ "$dongybat" == "y" ]]; then
    UI_STRING="Bật open_basedir của website $NAME"
    _runing "$UI_STRING"
    echo "Bật open_basedir website $NAME: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log

    if [[ $has_root_php_override -gt 0 ]]; then
      # Tiêm vào khối phpIniOverride sát lề trái
      sed -i "/^phpIniOverride/a \  php_admin_value open_basedir \"$ALLOWED_PATHS\"" "$vhost_conf"
    else
      # Nếu CHƯA TỒN TẠI, tự động xây một khối ĐỘC LẬP MỚI ở cuối file
      echo -e "\nphpIniOverride  {\n  php_admin_value open_basedir \"$ALLOWED_PATHS\"\n}" >>"$vhost_conf"
    fi
    _rundone "$UI_STRING"
  else
    exec /etc/wptt/wptt-bao-mat-main 1
  fi
fi

# Reload Litespeed siêu tốc không gây downtime
/usr/local/lsws/bin/lswsctrl reload >/dev/null 2>&1

# --- FOOTER ---
[[ ${1:-} == "98" ]] && exec /etc/wptt/wptt-bao-mat-main 1
