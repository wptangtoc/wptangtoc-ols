function huong_dan() {
  Kích hoạt hoặc huỷ kích hoạt open_basedir để nâng cao bảo mật PHP để giảm thiểu tối đa việc 1 website bị hack, nó lây ra website còn lại.

  open_basedir là đóng phân vùng hoạt động của PHP

  Mục đích chính của open_basedir:

  * Tăng cường bảo mật: Đây là mục đích cốt lõi. Bằng cách giới hạn phạm vi truy cập tệp tin, open_basedir giúp ngăn chặn các script PHP [đặc biệt là khi website bị tấn công hoặc chứa mã độc] truy cập, đọc hoặc ghi vào các tệp tin nhạy cảm nằm ngoài thư mục gốc của website đó. Điều này đặc biệt hữu ích trong môi trường hosting chia sẻ, nơi nhiều website cùng hoạt động trên một máy chủ. Nếu một website bị xâm nhập, open_basedir sẽ giúp hạn chế khả năng mã độc lây lan sang các website khác hoặc truy cập vào các tệp tin hệ thống của máy chủ.
  * Kiểm soát môi trường thực thi của PHP: Nó giúp quản trị viên máy chủ định rõ những khu vực nào trên hệ thống tệp mà các kịch bản PHP được phép tương tác.

  Thường anh em sử dụng plugin backup như duplicator hay backupbuddy sẽ bị lỗi.. nếu bạn không sử dụng plugin thì hãy nên bật tính năng này.
  Ghi chú: khi bật có thể bị lỗi một số tính năng bạn vui lòng kiểm tra kỹ trước khi triển khai.
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null # Nạp thư viện UI Xác nhận

clear
echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}${bao_mat} ➜ Bật / Tắt open_basedir PHP${C_RESET}"
echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

# ==============================================================================
# HÀM MENU QUÉT VHOST VÀ TRẠNG THÁI (UX BO CONG)
# ==============================================================================
function lua_chon_NAME() {
  unset NAME selects
  selects=()
  local box_inner_width=${box_inner_width:-71}

  if [ "$(ls -At /etc/wptt/vhost 2>/dev/null | grep -v '^\.\.conf$' | sort -uV)" ]; then
    for filepath in /etc/wptt/vhost/.*.conf; do
      [[ ! -f "$filepath" || "$filepath" == *"/..conf" ]] && continue
      local dom="${filepath##*/}"
      dom="${dom%.conf}"
      dom="${dom#.}"

      if [[ "$dom" == ?*.?* ]]; then
        local vhost_path="/usr/local/lsws/conf/vhosts/$dom/$dom.conf"
        if [[ -f "$vhost_path" ]]; then
          if grep -q 'open_basedir' "$vhost_path" 2>/dev/null; then
            selects+=("$dom|1") # 1 = Đang Bật
          else
            selects+=("$dom|0") # 0 = Đang Tắt
          fi
        fi
      fi
    done
  fi

  if [[ ${#selects[@]} -eq 0 ]]; then
    echo -e "${C_YELLOW}Hệ thống chưa có website nào được khởi tạo để cấu hình!${C_RESET}"
    sleep 3
    exec /etc/wptt/wptt-bao-mat-main 1
  fi

  # Render Menu Bo Cong
  echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
  local title_text="Trạng thái hiện tại & Chọn Website muốn thao tác:"
  local len=$(echo -n "$title_text" | awk '{print length($0)}')
  local pad_r=$((box_inner_width - len - 2))
  [[ $pad_r -lt 0 ]] && pad_r=0
  echo -e "${C_CYAN}│${C_RESET}  ${C_YELLOW}${title_text}${C_RESET}$(printf '%*s' "$pad_r" "")${C_CYAN}│${C_RESET}"

  local line_len=$((len + 3))
  local pad_line_r=$((box_inner_width - line_len))
  [[ $pad_line_r -lt 0 ]] && pad_line_r=0
  local short_line=$(printf "%${line_len}s" "" | sed 's/ /─/g')
  echo -e "${C_CYAN}├${short_line}$(printf '%*s' "$pad_line_r" "")│${C_RESET}"

  local i=1
  for item in "${selects[@]}"; do
    local dom=$(echo "$item" | cut -d'|' -f1)
    local stt=$(echo "$item" | cut -d'|' -f2)

    local color_stt="${C_GREEN}[Đang BẬT]"
    local clean_stt="[Đang BẬT]"
    if [[ "$stt" == "0" ]]; then
      color_stt="${C_YELLOW}[Đang TẮT (Chưa bảo vệ)]"
      clean_stt="[Đang TẮT (Chưa bảo vệ)]"
    fi

    local item_text=$(printf "  ${C_CYAN}%3d)${C_RESET} ${C_BOLD_WHITE}%-30s${C_RESET} %s" "$i" "$dom" "${color_stt}${C_RESET}")
    local clean_text=$(printf "  %3d) %-30s %s" "$i" "$dom" "$clean_stt")
    local item_len=$(echo -n "$clean_text" | awk '{print length($0)}')
    local pad=$((box_inner_width - item_len))
    [[ $pad -lt 0 ]] && pad=0
    echo -e "${C_CYAN}│${C_RESET}${item_text}$(printf '%*s' "$pad" "")${C_CYAN}│${C_RESET}"
    ((i++))
  done
  echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯${C_RESET}"

  local fzf_installed=false
  if command -v fzf &>/dev/null; then
    fzf_installed=true
    PROMPT_TEXT="Nhập lựa chọn (1-${#selects[@]}) [00=Tìm nhanh] [0=Thoát]: "
  else
    PROMPT_TEXT="Nhập lựa chọn (1-${#selects[@]}) [0=Thoát]: "
  fi

  while true; do
    echo -en "${C_CYAN}${PROMPT_TEXT}${C_RESET}"
    if ! read -r REPLY; then exit 1; fi
    REPLY=$(echo "$REPLY" | tr -d ' ' | tr '[:upper:]' '[:lower:]')

    case "$REPLY" in
    0)
      echo -e "\n${C_GREEN}Đang thoát...${C_RESET}"
      NAME="0"
      return 0
      ;;
    00)
      if $fzf_installed; then
        local selected_item=$(printf '%s\n' "${selects[@]}" | nl -w 3 -s ': ' | fzf --prompt="Tìm website >> " --height=40% --border=rounded --color=border:red --cycle --reverse)
        local extracted_data=$(echo "$selected_item" | sed 's/^[[:space:]]*[0-9]\+\:[[:space:]]*//')
        if [[ -n "$extracted_data" ]]; then
          NAME=$(echo "$extracted_data" | cut -d'|' -f1)
          DOMAIN_CURRENT_STT=$(echo "$extracted_data" | cut -d'|' -f2)
          return 0
        else
          echo -e "${C_YELLOW}Đã hủy chọn. Vui lòng chọn lại.${C_RESET}"
        fi
      else
        echo -e "${C_RED}Lỗi: FZF chưa cài đặt.${C_RESET}"
      fi
      ;;
    *)
      if [[ "$REPLY" =~ ^[0-9]+$ ]] && [ "$REPLY" -ge 1 ] && [ "$REPLY" -le ${#selects[@]} ]; then
        local action_index=$((REPLY - 1))
        local extracted_data="${selects[$action_index]}"
        NAME=$(echo "$extracted_data" | cut -d'|' -f1)
        DOMAIN_CURRENT_STT=$(echo "$extracted_data" | cut -d'|' -f2)
        return 0
      else
        echo -e "\n${C_RED}❌ Lựa chọn không hợp lệ! Vui lòng chọn lại.${C_RESET}"
      fi
      ;;
    esac
  done
}

lua_chon_NAME

[[ "$NAME" == "0" || -z "$NAME" ]] && {
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-bao-mat-main 1
  return 2>/dev/null || exit
}

vhost_conf="/usr/local/lsws/conf/vhosts/$NAME/$NAME.conf"
if [[ ! -f "$vhost_conf" ]]; then
  echo -e "\n${C_RED}❌ Tên miền không tồn tại trên hệ thống này!${C_RESET}"
  sleep 3
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-bao-mat-main 1
  return 2>/dev/null || exit
fi

echo ""
ALLOWED_PATHS="/usr/local/lsws/$NAME:/tmp:/var/run/redis:/var/run/memcached:/var/run/valkey:/var/run/keydb"
has_root_php_override=$(grep -c '^phpIniOverride' "$vhost_conf")

action_msg=""

# ĐANG BẬT (1) -> HỎI TẮT
if [[ "$DOMAIN_CURRENT_STT" == "1" ]]; then
  if wptt_xac_nhan "Tính năng open_basedir đang BẬT. Bạn có muốn TẮT đi không?" "${C_BOLD_WHITE}Website:${C_RESET} $NAME" "Lưu ý: Việc tắt sẽ làm giảm mức độ cách ly của website này." "Đồng ý TẮT" "Hủy bỏ"; then
    echo ""
    _runing "Đang tắt giới hạn open_basedir cho $NAME..."
    echo "Tắt open_basedir website $NAME: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log

    # Xóa dòng open_basedir
    sed -i '/open_basedir/d' "$vhost_conf"
    # Xóa khối phpIniOverride nếu rỗng
    sed -i '/^phpIniOverride[[:space:]]*{/{:a; /}/!{N; ba;}; /^phpIniOverride[[:space:]]*{[[:space:]\n]*}$/d}' "$vhost_conf"

    action_msg="Đã TẮT giới hạn an toàn (Không khuyến nghị)."
    action_color="${C_YELLOW}"
    _rundone "Cập nhật cấu hình Vhost thành công"
  else
    echo -e "${C_YELLOW}Đã hủy thao tác.${C_RESET}"
    [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-bao-mat-main 1
    exit 0
  fi
# ĐANG TẮT (0) -> HỎI BẬT
else
  if wptt_xac_nhan "Tính năng open_basedir đang TẮT. Bạn có muốn BẬT lên không?" "${C_BOLD_WHITE}Website:${C_RESET} $NAME" "Lưu ý: Một số Plugin Backup cũ có thể bị lỗi khi tính năng này bật." "Đồng ý BẬT" "Hủy bỏ"; then
    echo ""
    _runing "Đang bật giới hạn an toàn open_basedir cho $NAME..."
    echo "Bật open_basedir website $NAME: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log

    if [[ $has_root_php_override -gt 0 ]]; then
      # Tiêm vào khối phpIniOverride sát lề trái
      sed -i "/^phpIniOverride/a \  php_admin_value open_basedir \"$ALLOWED_PATHS\"" "$vhost_conf"
    else
      # Nếu CHƯA TỒN TẠI, tự động xây một khối ĐỘC LẬP MỚI ở cuối file
      echo -e "\nphpIniOverride  {\n  php_admin_value open_basedir \"$ALLOWED_PATHS\"\n}" >>"$vhost_conf"
    fi

    action_msg="Đã BẬT giới hạn an toàn open_basedir."
    action_color="${C_GREEN}"
    _rundone "Cập nhật cấu hình Vhost thành công"
  else
    echo -e "${C_YELLOW}Đã hủy thao tác.${C_RESET}"
    [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-bao-mat-main 1
    exit 0
  fi
fi

# ==============================================================================
# KHỞI ĐỘNG LẠI & BÁO CÁO
# ==============================================================================
# _runing "Đang nạp lại cấu hình cho OpenLiteSpeed (Reload)..."
/usr/local/lsws/bin/lswsctrl reload >/dev/null 2>&1
# _rundone "Máy chủ đã cập nhật cấu hình mới"

echo -e "\n${C_GREEN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_BOLD_WHITE}HOÀN TẤT THAY ĐỔI OPEN_BASEDIR${C_RESET}"
echo -e "${C_GREEN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
left_text "Website thao tác : ${C_YELLOW}$NAME${C_RESET}" 2
left_text "Trạng thái mới   : ${action_color}${action_msg}${C_RESET}" 2
echo -e "${C_GREEN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

[[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-bao-mat-main 1
