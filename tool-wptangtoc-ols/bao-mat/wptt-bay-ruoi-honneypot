#!/bin/bash

function huong_dan() {
  Tính năng Bẫy Ruồi Honeypot [Bắt Hacker từ trong trứng nước]
  🛡️ Mục đích:
  Hacker thường sử dụng các công cụ rà quét tự động để tìm kiếm các lỗ hổng lộ lọt thông tin nhạy cảm trước khi chính thức tấn công. Chúng sẽ dò tìm các file như biến môi trường [.env], cấu hình mã nguồn [.git], file backup cơ sở dữ liệu [db.sql], hay file debug [phpinfo.php].

  ⚙️ Cơ chế hoạt động:
  * Người dùng bình thường không bao giờ truy cập vào các đường dẫn này.
  * Nếu một địa chỉ IP cố tình truy vấn các đường dẫn nhạy cảm nằm trong "Danh sách Đen" của bẫy ruồi.
  * Hành động: IP đó sẽ bị Tường lửa khóa ngay lập tức CHỈ VỚI 1 LẦN TRUY CẬP DUY NHẤT.
  * Thời gian khóa: 24 tiếng [86400 giây] - Đánh chặn từ xa trước khi chúng kịp tìm ra lỗ hổng web.

  [Lưu ý: Quản trị viên cũng không nên tự truy cập các file như info.php hay .env trên trình duyệt để tránh bị block nhầm]
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null # Nạp thư viện UI Xác nhận

clear
echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}${bao_mat} ➜ Bật / Tắt Bẫy ruồi Honeypot (Anti-Scanner)${C_RESET}"
echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

# ==============================================================================
# KIỂM TRA TRẠNG THÁI HIỆN TẠI
# ==============================================================================
is_honeypot_active=0
if grep -q '#begin-honeypot-wptangtoc' /etc/fail2ban/jail.local 2>/dev/null; then
  is_honeypot_active=1
fi

echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
if [[ $is_honeypot_active -eq 1 ]]; then
  left_text "Trạng thái Bẫy : ${C_GREEN}ĐANG BẬT (Active)${C_RESET}" 2
  left_text "Chính sách BAN : Khóa ngay lập tức (Ban 24 tiếng)" 2
else
  left_text "Trạng thái Bẫy : ${C_YELLOW}ĐANG TẮT (Inactive)${C_RESET}" 2
fi
echo -e "${C_CYAN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
left_text "Bẫy ruồi Honeypot sẽ tự động bắt và KHÓA VĨNH VIỄN các IP cố tình" 2
left_text "truy quét file nhạy cảm (.env, .git, db.sql, phpinfo...) trên VPS." 2
echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

# ==============================================================================
# NHÁNH 1: ĐANG TẮT -> HỎI ĐỂ BẬT LÊN
# ==============================================================================
if [[ $is_honeypot_active -eq 0 ]]; then
  if wptt_xac_nhan "Bạn có muốn KÍCH HOẠT Bẫy ruồi Honeypot không?" "LƯU Ý: Quản trị viên TUYỆT ĐỐI KHÔNG tự gõ thử các đường dẫn nhạy cảm" "(như wp-config.php.bak, .env) lên trình duyệt để tránh bị khóa nhầm!" "Đồng ý BẬT Bẫy ruồi" "Hủy thao tác"; then
    echo ""

    # ---------------------------------------------------------
    # BƯỚC 1: CÀI ĐẶT THƯ VIỆN
    # ---------------------------------------------------------
    _runing "Đang kiểm tra và cài đặt thư viện phụ thuộc (ipset, inotify)..."
    if grep -qi "ubuntu" /etc/os-release 2>/dev/null; then
      dpkg -s python3-pyinotify ipset >/dev/null 2>&1 || {
        export DEBIAN_FRONTEND=noninteractive
        apt-get update >/dev/null 2>&1
        apt-get install -y python3-pyinotify ipset >/dev/null 2>&1
      }
    else
      rpm -q python3-inotify ipset >/dev/null 2>&1 || {
        dnf install -y python3-inotify ipset >/dev/null 2>&1
      }
    fi
    _rundone "Thư viện nền tảng đã sẵn sàng"

    # ---------------------------------------------------------
    # BƯỚC 2: KIỂM TRA CLOUDFLARE VÀ CẤU HÌNH LOG VHOST
    # ---------------------------------------------------------
    _runing "Đang quét các Website và thiết lập nhật ký truy cập (Access Log)..."
    if [ "$(ls -At /etc/wptt/vhost 2>/dev/null)" ]; then
      for entry in $(ls -A /etc/wptt/vhost | grep -v '^\.\.conf$' | sort -uV); do
        NAME=$(echo "$entry" | sed 's/^.//' | sed 's/.conf//')
        if [[ "$NAME" == ?*.?* ]]; then

          # Kiểm tra Cloudflare CDN
          TRACE_OUTPUT=$(curl -Is --connect-timeout 5 --max-time 10 "https://$NAME/cdn-cgi/trace" 2>/dev/null)
          if echo "$TRACE_OUTPUT" | grep -qi 'cloudflare\|cf-ray'; then
            if ! grep -q 'allow.*103\.21\.244\.0' /usr/local/lsws/conf/httpd_config.conf 2>/dev/null; then
              _runloi "Phát hiện cấu hình không an toàn!"
              echo -e "\n${C_RED}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
              center_text "${C_BOLD_WHITE}❌ LỖI: PHÁT HIỆN CLOUDFLARE NHƯNG CHƯA BẬT REAL IP${C_RESET}"
              echo -e "${C_RED}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
              left_text "Website ${C_YELLOW}$NAME${C_RESET} đang sử dụng Cloudflare CDN." 2
              left_text "Để tránh việc Fail2ban khóa NHẦM IP của máy chủ Cloudflare" 2
              left_text "(gây sập web), bạn phải kích hoạt tính năng [Hiển thị IP Real" 2
              left_text "Bypass Cloudflare] trong Menu Add-ons trước khi bật Honeypot!" 2
              echo -e "${C_RED}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

              [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-bao-mat-main 1
              exit 1
            fi
          fi

          # Tự động thêm Access Log nếu chưa có
          if ! grep -q 'accesslog' "/usr/local/lsws/conf/vhosts/$NAME/$NAME.conf" 2>/dev/null; then
            sed -i -e '/^errorlog /,/^}$/d' "/usr/local/lsws/conf/vhosts/$NAME/$NAME.conf"
            sed -i -e '/^accesslog /,/^}$/d' "/usr/local/lsws/conf/vhosts/$NAME/$NAME.conf"

            cat <<EOF >>"/usr/local/lsws/conf/vhosts/$NAME/$NAME.conf"

errorlog \$VH_ROOT/logs/error.log {
  useServer               1
  logLevel                ERROR
  rollingSize             10M
}

accesslog \$VH_ROOT/logs/access.log {
  useServer               0
  rollingSize             10M
  keepDays                30
  compressArchive         1
}
EOF
            mkdir -p "/usr/local/lsws/$NAME/logs"

            tuong_thich_nhom_litespeed="nobody"
            cat /etc/*release 2>/dev/null | grep -qi "Ubuntu" && tuong_thich_nhom_litespeed="nogroup"

            chown -R "nobody:$tuong_thich_nhom_litespeed" "/usr/local/lsws/$NAME/logs"
            chmod 700 "/usr/local/lsws/$NAME/logs"
            /usr/local/lsws/bin/lswsctrl reload >/dev/null 2>&1
          fi
        fi
      done
    fi
    _rundone "Cấu hình Log cho các Vhost hoàn tất"

    # ---------------------------------------------------------
    # BƯỚC 3: CẤU HÌNH FAIL2BAN ENTERPRISE
    # ---------------------------------------------------------
    _runing "Đang thiết lập luật Firewall và nạp Honeypot vào Fail2ban..."
    rule_fail2ban_name="honeypot-wptt"

    if [[ -f /etc/csf/csf.conf ]]; then
      action_thuc_thi_block="iptables-multiport[actname=block-tcp, name=$rule_fail2ban_name-t, port=\"80,443\", protocol=\"tcp\"]
           iptables-multiport[actname=block-udp, name=$rule_fail2ban_name-u, port=\"80,443\", protocol=\"udp\"]"
    elif [[ $(systemctl status nftables.service 2>/dev/null | grep 'Active' | cut -f2 -d':' | xargs | cut -f1 -d' ' | xargs) == "active" ]]; then
      action_thuc_thi_block="nftables-allports[name=$rule_fail2ban_name]"
    elif [[ $(systemctl status firewalld.service 2>/dev/null | grep 'Active' | cut -f2 -d':' | xargs | cut -f1 -d' ' | xargs) == "active" ]]; then
      action_thuc_thi_block="firewallcmd-ipset[actname=block-tcp, name=$rule_fail2ban_name-t, port=\"80,443\", protocol=\"tcp\"]
           firewallcmd-ipset[actname=block-udp, name=$rule_fail2ban_name-u, port=\"80,443\", protocol=\"udp\"]"
    else
      # Fallback tiêu chuẩn
      action_thuc_thi_block="iptables-multiport[actname=block-tcp, name=$rule_fail2ban_name-t, port=\"80,443\", protocol=\"tcp\"]
           iptables-multiport[actname=block-udp, name=$rule_fail2ban_name-u, port=\"80,443\", protocol=\"udp\"]"
    fi

    cat <<EOF >>/etc/fail2ban/jail.local

#begin-honeypot-wptangtoc
[honeypot-wptangtoc]
enabled = true
action = $action_thuc_thi_block
filter = honeypot-wptangtoc
logpath = /usr/local/lsws/*/logs/access.log
backend = pyinotify
maxretry = 1
bantime = 86400
findtime = 60
#end-honeypot-wptangtoc
EOF

    # Định nghĩa Regex
    cat <<'EOF' >/etc/fail2ban/filter.d/honeypot-wptangtoc.conf
[Definition]
traps = \.env.*|\.git\/.*|\.svn\/.*|\.aws\/.*|wp-config\.(?:php\.bak|bak|txt|save|swp|old)|(?:phpinfo|info|pi|test)\.php|eval-stdin\.php|(?:db|dump|backup|database)\.sql
failregex = ^<HOST> .* "(GET|POST|HEAD) \/+(?:%(traps)s) HTTP\/.*" .*$
ignoreregex =
EOF

    fail2ban-client reload >/dev/null 2>&1 || systemctl restart fail2ban >/dev/null 2>&1
    _rundone "Hệ thống Bẫy ruồi đã đi vào hoạt động"

    # BẢNG BÁO CÁO THÀNH CÔNG
    echo -e "\n${C_GREEN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
    center_text "${C_BOLD_WHITE}HOÀN TẤT KÍCH HOẠT BẪY RUỒI HONEYPOT${C_RESET}"
    echo -e "${C_GREEN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
    left_text "Mọi hành vi rà quét lỗ hổng (.env, .git, db.sql, backup...)" 2
    left_text "từ Hacker sẽ bị hệ thống phát hiện và BAN IP ngay lập tức!" 2
    echo -e "${C_GREEN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

  else
    echo -e "${C_YELLOW}Đã hủy thao tác kích hoạt Bẫy ruồi.${C_RESET}\n"
  fi

else
  if wptt_xac_nhan "Bạn có CHẮC CHẮN muốn TẮT Bẫy ruồi Honeypot không?" "Việc tắt Bẫy ruồi sẽ làm giảm khả năng phòng thủ chủ động của máy chủ." "" "Đồng ý TẮT Bẫy" "Hủy thao tác"; then
    echo ""

    _runing "Đang gỡ bỏ cấu hình luật Honeypot khỏi Fail2ban..."
    sed -i -e '/^#begin-honeypot-wptangtoc/,/^#end-honeypot-wptangtoc$/d' /etc/fail2ban/jail.local
    rm -f /etc/fail2ban/filter.d/honeypot-wptangtoc.conf

    fail2ban-client reload >/dev/null 2>&1 || systemctl restart fail2ban >/dev/null 2>&1
    _rundone "Gỡ bỏ cấu hình hoàn tất"

    # BẢNG BÁO CÁO TẮT
    echo -e "\n${C_GREEN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
    center_text "${C_BOLD_WHITE}HOÀN TẤT GỠ BỎ BẪY RUỒI HONEYPOT${C_RESET}"
    echo -e "${C_GREEN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
    left_text "Tính năng chặn tự động (Anti-Scanner) đã được TẮT hoàn toàn." 2
    echo -e "${C_GREEN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

  else
    echo -e "${C_YELLOW}Đã hủy thao tác tắt Bẫy ruồi.${C_RESET}\n"
  fi
fi

[[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-bao-mat-main 1
