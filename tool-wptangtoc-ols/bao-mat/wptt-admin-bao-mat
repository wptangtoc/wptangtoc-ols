function huong_dan() {
  Đây là một tính năng bảo mật rất hữu ích nhằm chống lại các cuộc tấn công Brute Force [dò mật khẩu] vào trang quản trị wp-admin của website WordPress.

  Giới thiệu ngắn gọn tính năng:
  Tính năng này hoạt động bằng cách theo dõi số lần đăng nhập sai liên tiếp từ một địa chỉ IP cụ thể. Cụ thể, nếu một địa chỉ IP:
  * Nhập sai mật khẩu 3 lần
  * Trong khoảng thời gian 5 phút
  Thì địa chỉ IP đó sẽ tự động bị tạm khóa, không thể truy cập vào toàn bộ hệ thống trong vòng 2 tiếng.

  Bạn có thể dễ dàng Bật hoặc Tắt tính năng này tùy theo nhu cầu:
  * Kích hoạt [Bật]: Ngăn chặn bot tự động, bảo vệ tài khoản và giảm tải CPU cho máy chủ.
  * Hủy kích hoạt [Tắt]: Dành cho các trường hợp bạn hoặc đối tác bị khóa IP nhầm và cần vào quản trị gấp, hoặc khi bạn dùng giải pháp Firewall khác.
}

. /etc/wptt/.wptt.conf
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh
. /etc/wptt/echo-color

clear
echo -e "\n========================================================================="
echo -e "| Bảo mật => Bật / Tắt chống Brute Force wp-admin [Fail2ban]             |"
echo -e "=========================================================================\n"

# ==============================================================================
# HÀM MENU LỌC THÔNG MINH (CHỈ HIỂN THỊ DOMAIN WORDPRESS + CÓ TRẠNG THÁI + FZF)
# ==============================================================================
function lua_chon_NAME() {
  unset NAME domain selects
  selects=()

  # Vòng lặp Globbing siêu tốc không qua sub-shell
  for filepath in /etc/wptt/vhost/.*.conf; do
    [[ ! -f "$filepath" || "$filepath" == *"/..conf" ]] && continue

    local domain="${filepath##*/}"
    domain="${domain%.conf}"
    domain="${domain#.}"

    # Chỉ quét các domain có định dạng chuẩn và có nhân WordPress
    if [[ "$domain" == ?*.?* && -f "/usr/local/lsws/$domain/html/wp-load.php" ]]; then
      local domain_fail2ban="${domain//[-._]/wp}"
      local filter_path="/etc/fail2ban/filter.d/wordpress-dangnhap-$domain_fail2ban.conf"

      if [[ -f "$filter_path" ]]; then
        selects+=("$domain [Đang BẬT]")
      else
        selects+=("$domain [Đang TẮT]")
      fi
    fi
  done

  if [[ ${#selects[@]} -eq 0 ]]; then
    echo -e "\033[1;33mHệ thống chưa có Website WordPress nào để cấu hình Brute Force!\033[0m"
    sleep 3
    exec /etc/wptt/wptt-bao-mat-main 1
  fi

  # Sắp xếp mảng chuẩn Version (Alphabetical)
  mapfile -t selects < <(printf "%s\n" "${selects[@]}" | sort -uV)

  # Cải tiến UX: Thêm tùy chọn "Tất Cả" ở cuối nếu có >= 2 website WP
  if [[ ${#selects[@]} -ge 2 ]]; then
    selects+=("TẤT CẢ WEBSITE (Thao tác đồng loạt)")
  fi

  # Hiển thị Menu PS3 hỗ trợ 00 (FZF)
  if command -v fzf &>/dev/null; then
    PS3="$(tput setab 0)-//- Lựa chọn website WP bạn muốn cấu hình [00=Tìm nhanh] [0=Thoát]:$(tput sgr0) "
  else
    PS3="$(tput setab 0)-//- Lựa chọn website WP bạn muốn cấu hình [0=Thoát]:$(tput sgr0) "
  fi

  # Vòng lặp lấy giá trị
  select selected_domain in "${selects[@]}"; do
    NAME="$selected_domain"
    break
  done

  # XỬ LÝ CHỌN NHANH [00] VỚI FZF
  if [[ "$REPLY" == "00" ]] && command -v fzf &>/dev/null; then
    local selected_name
    selected_name=$(printf "%s\n" "${selects[@]}" | nl -w 3 -s ': ' | fzf --height 40% --border=rounded --color=border:red --reverse --prompt=">> Tìm website WP Brute Force [0=Thoát]: ")
    selected_name=$(echo "$selected_name" | sed 's/^[[:space:]]*[0-9]\+\:[[:space:]]*//')

    if [[ -z "$selected_name" ]]; then
      echo "Đã hủy chọn."
      exec /etc/wptt/wptt-bao-mat-main 1
    fi
    NAME="$selected_name"
  fi

  # Xử lý nhập input thẳng tên domain (nếu không chọn số)
  if [[ -z "$NAME" && "$REPLY" != "0" && "$REPLY" != "00" ]]; then
    REPLY=$(echo "$REPLY" | tr '[:upper:]' '[:lower:]' | xargs)
    for item in "${selects[@]}"; do
      local check_dom=$(echo "$item" | cut -f1 -d ' ')
      if [[ "$check_dom" == "$REPLY" ]]; then
        NAME="$item"
        break
      fi
    done
  fi
}

# Nếu gọi script kèm tên domain từ command line
if [[ -n "$1" && "$1" != "98" ]]; then
  NAME="$1"
else
  lua_chon_NAME
fi

# Tách lấy tên chuẩn (Cắt bỏ dòng trạng thái)
NAME=$(echo "$NAME" | cut -f1 -d ' ')

# --- CHỐT CHẶN THOÁT HIỂM ---
[[ "$NAME" == "0" || -z "$NAME" ]] && exec /etc/wptt/wptt-bao-mat-main 1

# ==============================================================================
# HÀM CÀI ĐẶT GÓI PHỤ THUỘC (Chạy 1 lần duy nhất cho toàn hệ thống)
# ==============================================================================
function install_dependencies() {
  if grep -qi "ubuntu" /etc/os-release 2>/dev/null; then
    if ! dpkg -s python3-pyinotify ipset >/dev/null 2>&1; then
      export DEBIAN_FRONTEND=noninteractive
      apt-get update >/dev/null 2>&1
      apt-get install -y python3-pyinotify ipset >/dev/null 2>&1
    fi
    tuong_thich_nhom_litespeed="nogroup"
  else
    if ! rpm -q python3-inotify ipset >/dev/null 2>&1; then
      dnf install -y python3-inotify ipset >/dev/null 2>&1
    fi
    tuong_thich_nhom_litespeed="nobody"
  fi
}

# Lấy chuẩn nhóm Litespeed
if grep -qi "ubuntu" /etc/os-release 2>/dev/null; then
  tuong_thich_nhom_litespeed="nogroup"
else
  tuong_thich_nhom_litespeed="nobody"
fi

# ==============================================================================
# HÀM THỰC THI BẬT/TẮT BRUTE FORCE CHO 1 DOMAIN
# ==============================================================================
function process_bruteforce() {
  local target_domain=$1
  local action=$2 # "bat" hoac "tat"
  local domain_fail2ban="${target_domain//[-._]/wp}"
  local filter_path="/etc/fail2ban/filter.d/wordpress-dangnhap-$domain_fail2ban.conf"
  local vhost_conf="/usr/local/lsws/conf/vhosts/$target_domain/$target_domain.conf"

  if [[ "$action" == "bat" ]]; then
    [[ -f "$filter_path" ]] && return # Đã bật rồi thì bỏ qua

    UI_STRING="Kích hoạt chống Brute Force cho $target_domain"
    _runing "$UI_STRING"

    # 1. Tách biệt Access Log cho Vhost để Fail2ban đọc
    if ! grep -q 'accesslog' "$vhost_conf" 2>/dev/null; then
      sed -i '/^errorlog /,/^}$/d' "$vhost_conf"
      sed -i '/^accesslog /,/^}$/d' "$vhost_conf"
      cat <<EOF >>"$vhost_conf"

errorlog \$VH_ROOT/logs/error.log {
  useServer               1
  logLevel                ERROR
  rollingSize             10M
}

accesslog \$VH_ROOT/logs/access.log {
  useServer               0
  rollingSize             10M
  keepDays                30
  compressArchive         1
}
EOF
    fi

    mkdir -p "/usr/local/lsws/$target_domain/logs"
    chown -R nobody:$tuong_thich_nhom_litespeed "/usr/local/lsws/$target_domain/logs"
    chmod 700 "/usr/local/lsws/$target_domain/logs"

    # 2. Xử lý logic tên Rule (Cắt ngắn tối đa 20 ký tự)
    local rule_fail2ban_name="wp-admin-$domain_fail2ban"
    if ((${#rule_fail2ban_name} > 20)); then
      rule_fail2ban_name=$(echo "$rule_fail2ban_name" | cut -c 1-20)
    fi

    # 3. Phân luồng Action theo Tường lửa của máy chủ
    local action_thuc_thi_block=""
    if [[ -f /etc/csf/csf.conf ]]; then
      action_thuc_thi_block="iptables-multiport[actname=block-tcp, name=$rule_fail2ban_name-t, port=\"80,443\", protocol=\"tcp\"]
          iptables-multiport[actname=block-udp, name=$rule_fail2ban_name-u, port=\"80,443\", protocol=\"udp\"]"
    elif [[ $(systemctl status nftables.service 2>/dev/null | grep -i 'Active' | grep -o 'active') == "active" ]]; then
      action_thuc_thi_block="nftables-allports[name=$rule_fail2ban_name]"
    else
      action_thuc_thi_block="firewallcmd-ipset[actname=block-tcp, name=$rule_fail2ban_name-t, port=\"80,443\", protocol=\"tcp\"]
          firewallcmd-ipset[actname=block-udp, name=$rule_fail2ban_name-u, port=\"80,443\", protocol=\"udp\"]"
    fi

    # 4. Ghi cấu hình Fail2ban
    cat <<EOF >>"/etc/fail2ban/jail.local"

#begin-wordpress-dangnhap-$domain_fail2ban
[$rule_fail2ban_name]
enabled = true
action = $action_thuc_thi_block
filter = wordpress-dangnhap-$domain_fail2ban
logpath = /usr/local/lsws/$target_domain/logs/access.log
backend = pyinotify
bantime = 7200
maxretry = 3
findtime = 300
#end-wordpress-dangnhap-$domain_fail2ban
EOF

    echo '[Definition]
failregex = ^<HOST> .* "POST \/+wp-login\.php HTTP\/.*" 200' >"$filter_path"

    echo "Kích hoạt Brute Force website $target_domain: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log
    _rundone "$UI_STRING"

  elif [[ "$action" == "tat" ]]; then
    [[ ! -f "$filter_path" ]] && return # Chưa bật thì bỏ qua

    UI_STRING="Tắt (Hủy) chống Brute Force cho $target_domain"
    _runing "$UI_STRING"

    # 1. Kiểm tra Vhost Config để gỡ Log (Chỉ gỡ nếu người dùng không chủ động giữ log)
    bat_log_domain=""
    [[ -f "/etc/wptt/vhost/.$target_domain.conf" ]] && . "/etc/wptt/vhost/.$target_domain.conf"

    if [[ -z "$bat_log_domain" ]]; then
      sed -i '/^errorlog /,/^}$/d' "$vhost_conf"
      sed -i '/^accesslog /,/^}$/d' "$vhost_conf"
      rm -rf "/usr/local/lsws/$target_domain/logs"
    fi

    # Dự phòng bảo vệ thư mục log tổng của server
    if [[ ! -d "/usr/local/lsws/logs" ]]; then
      mkdir -p /usr/local/lsws/logs
      chown root:nobody /usr/local/lsws/logs
    fi

    # 2. Xóa cấu hình Fail2ban bằng SED (Xóa theo vùng siêu an toàn)
    rm -f "$filter_path"
    sed -i "/^#begin-wordpress-dangnhap-$domain_fail2ban/,/^#end-wordpress-dangnhap-$domain_fail2ban$/d" /etc/fail2ban/jail.local

    echo "Tắt Brute Force website $target_domain: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log
    _rundone "$UI_STRING"
  fi
}

# ==============================================================================
# XỬ LÝ LÔGIC RẼ NHÁNH BẬT / TẮT
# ==============================================================================

if [[ "$NAME" == "TẤT CẢ WEBSITE (Thao tác đồng loạt)" || "$NAME" == "TẤT" ]]; then
  echo -e "\nBạn muốn BẬT hay TẮT chống Brute Force cho \033[1;33mTẤT CẢ\033[0m website WordPress?"
  prompt="Lựa chọn của bạn [1-2]: "
  mass_action=""
  options=("BẬT đồng loạt" "TẮT đồng loạt" "Hủy bỏ")
  PS3="$prompt"
  select opt in "${options[@]}"; do
    case "$REPLY" in
    1)
      mass_action="bat"
      break
      ;;
    2)
      mass_action="tat"
      break
      ;;
    3) exec /etc/wptt/wptt-bao-mat-main 1 ;;
    *)
      printf "\nNhập sai, tự động hủy.\n"
      exec /etc/wptt/wptt-bao-mat-main 1
      ;;
    esac
  done

  # Chỉ chạy check Dependencies 1 lần nếu là lệnh BẬT
  [[ "$mass_action" == "bat" ]] && install_dependencies

  for filepath in /etc/wptt/vhost/.*.conf; do
    [[ ! -f "$filepath" || "$filepath" == *"/..conf" ]] && continue
    domain="${filepath##*/}"
    domain="${domain%.conf}"
    domain="${domain#.}"
    if [[ "$domain" == ?*.?* && -f "/usr/local/lsws/$domain/html/wp-load.php" ]]; then
      process_bruteforce "$domain" "$mass_action"
    fi
  done

else
  pathcheck="/etc/wptt/vhost/.$NAME.conf"
  [[ ! -f "$pathcheck" ]] && {
    echoDo "Tên miền không tồn tại!"
    sleep 2
    exec /etc/wptt/wptt-bao-mat-main 1
  }

  domain_fail2ban="${NAME//[-._]/wp}"
  if [[ -f "/etc/fail2ban/filter.d/wordpress-dangnhap-$domain_fail2ban.conf" ]]; then
    # Đang Bật -> Tự động Tắt
    process_bruteforce "$NAME" "tat"
  else
    # Đang Tắt -> Tự động Bật
    install_dependencies
    process_bruteforce "$NAME" "bat"
  fi
fi

# ==============================================================================
# KHỞI ĐỘNG LẠI DỊCH VỤ (Chạy 1 lần sau khi vòng lặp kết thúc)
# ==============================================================================
/usr/local/lsws/bin/lswsctrl reload >/dev/null 2>&1
fail2ban-client reload >/dev/null 2>&1 || systemctl restart fail2ban >/dev/null 2>&1
echo -e "\033[1;32mHoàn tất!\033[0m"

[[ ${1:-} == "98" ]] && exec /etc/wptt/wptt-bao-mat-main 1
