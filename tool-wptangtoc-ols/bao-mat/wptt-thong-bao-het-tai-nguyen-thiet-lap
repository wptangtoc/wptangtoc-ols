#!/bin/bash
# @author: Gia Tuấn
# @website: https://wptangtoc.com
# @email: giatuan@wptangtoc.com
# @since: 2026

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null # Nạp thư viện UX Bo Cong

clear
echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}BẢO MẬT ➜ Thiết lập Cảnh báo cạn kiệt Tài nguyên (Telegram)${C_RESET}"
echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

if [[ "${1:-}" == '98' ]]; then
  WPTT_IN_MENU="yes"
  WPTT_MENU_BACK="/etc/wptt/wptt-bao-mat-main 1"
fi

# ==============================================================================
# KIỂM TRA ĐIỀU KIỆN TIÊN QUYẾT (TELEGRAM API)
# ==============================================================================
if [[ -z "$telegram_api" || -z "$telegram_id" ]]; then
  echo -e "${C_RED}❌ Lỗi: Bạn chưa cấu hình Bot Telegram!${C_RESET}"
  echo -e "Hệ thống cần Token Bot và Chat ID để có thể gửi cảnh báo cho bạn."
  sleep 3
  exec /etc/wptt/bao-mat/wptt-telegram 1
  exit 1
fi

if [[ -f /etc/cron.d/tai-nguyen-check.cron ]]; then
  TRANG_THAI="ON"
else
  TRANG_THAI="OFF"
fi

echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
if [[ "$TRANG_THAI" == "ON" ]]; then
  left_text "Trạng thái    : ${C_GREEN}ĐÃ KÍCH HOẠT${C_RESET}" 2
  echo -e "${C_CYAN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
  left_text "Hệ thống đang liên tục theo dõi % sử dụng CPU, RAM, Disk." 2
  left_text "Sẽ tự động gửi tin nhắn Telegram nếu máy chủ bị quá tải." 2
else
  left_text "Trạng thái    : ${C_RED}CHƯA KÍCH HOẠT${C_RESET}" 2
  echo -e "${C_CYAN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
  left_text "Chức năng này giúp bạn theo dõi sức khỏe máy chủ 24/7." 2
  left_text "Ngay khi CPU/RAM/Disk vượt ngưỡng, Bot Telegram sẽ báo động." 2
fi
echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

# ==============================================================================
# XỬ LÝ NHÁNH 1: ĐANG BẬT -> YÊU CẦU TẮT
# ==============================================================================
if [[ "$TRANG_THAI" == "ON" ]]; then
  if ! wptt_xac_nhan "Tính năng Cảnh báo đang BẬT. Bạn có muốn TẮT không?" "Hệ thống sẽ ngừng theo dõi và ngừng gửi thông báo Telegram." "" "Đồng ý Tắt" "Giữ nguyên (Hủy)"; then
    echo -e "${C_YELLOW}Đã hủy thao tác.${C_RESET}\n"
    [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-bao-mat-main 1
    exit 0
  fi

  echo ""
  _runing "Đang gỡ bỏ cấu hình tự động (Cronjob)..."

  rm -f /etc/cron.d/tai-nguyen-check.cron

  if grep -qi "Ubuntu" /etc/*release 2>/dev/null; then
    rm -f /etc/cron.d/tai-nguyen-check_cron
    systemctl restart cron.service >/dev/null 2>&1
  else
    systemctl restart crond.service >/dev/null 2>&1
  fi
  _rundone "Hủy kích hoạt thông báo thành công!"

  sleep 2
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-bao-mat-main 1
  exit 0
fi

# ==============================================================================
# XỬ LÝ NHÁNH 2: ĐANG TẮT -> YÊU CẦU BẬT VÀ CẤU HÌNH
# ==============================================================================
if ! wptt_xac_nhan "Bạn có muốn BẬT cảnh báo quá tải máy chủ không?" "Cần thiết lập ngưỡng (%) và chu kỳ (phút) ở bước tiếp theo." "" "Đồng ý Bật" "Hủy thao tác"; then
  echo -e "${C_YELLOW}Đã hủy thao tác.${C_RESET}\n"
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-bao-mat-main 1
  exit 0
fi

echo ""
# 1. NHẬP NGƯỠNG CẢNH BÁO
while true; do
  echo -e "Gợi ý: Nên để ${C_YELLOW}85${C_RESET} hoặc ${C_YELLOW}90${C_RESET}. Khi tài nguyên vượt mức này sẽ báo động."
  echo -en "${C_CYAN}👉 Nhập Ngưỡng cảnh báo (%) (70-99) [Enter=85]: ${C_RESET}"
  read -r tainguyen

  tainguyen=${tainguyen:-85}

  if [[ "$tainguyen" =~ ^[0-9]+$ ]] && [ "$tainguyen" -ge 70 ] && [ "$tainguyen" -le 100 ]; then
    break
  else
    echo -e "${C_RED}❌ Lỗi: Vui lòng chỉ nhập số từ 70 đến 100!${C_RESET}\n"
  fi
done

echo ""
# 2. NHẬP CHU KỲ KIỂM TRA
while true; do
  echo -e "Gợi ý: Nên để ${C_YELLOW}10${C_RESET} phút. Không nên để quá thấp (1-2 phút) tránh spam tin nhắn."
  echo -en "${C_CYAN}👉 Nhập Chu kỳ kiểm tra (phút) (1-60) [Enter=10]: ${C_RESET}"
  read -r phut

  phut=${phut:-10}

  if [[ "$phut" =~ ^[0-9]+$ ]] && [ "$phut" -ge 1 ] && [ "$phut" -le 60 ]; then
    break
  else
    echo -e "${C_RED}❌ Lỗi: Vui lòng chỉ nhập số phút từ 1 đến 60!${C_RESET}\n"
  fi
done

echo ""
_runing "Đang kết nối nhận diện IP máy chủ..."
ip=$(curl -skf --connect-timeout 5 --max-time 10 https://ipv4.icanhazip.com || curl -skf --connect-timeout 5 --max-time 10 https://checkip.amazonaws.com)
[[ -z "$ip" ]] && ip=$(curl -sk --connect-timeout 5 --max-time 10 https://ipv6.icanhazip.com)
_rundone "Nhận diện IP thành công: $ip"

_runing "Đang tạo lịch trình tự động (Cronjob)..."

# Giữ nguyên cấu trúc Tương thích ngược của WPTangToc
cat >"/etc/cron.d/tai-nguyen-check.cron" <<END
*/$phut * * * * root /etc/wptt/bao-mat/wptt-thong-bao-het-tai-nguyen "$ip" "$tainguyen" >/dev/null 2>&1
END

chmod 644 /etc/cron.d/tai-nguyen-check.cron

if grep -qi "Ubuntu" /etc/*release 2>/dev/null; then
  ln -sf /etc/cron.d/tai-nguyen-check.cron /etc/cron.d/tai-nguyen-check_cron
  systemctl restart cron.service >/dev/null 2>&1
else
  systemctl restart crond.service >/dev/null 2>&1
fi
_rundone "Khởi chạy lịch trình giám sát thành công"

echo -e "${C_GREEN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_BOLD_WHITE}HOÀN TẤT THIẾT LẬP CẢNH BÁO TÀI NGUYÊN${C_RESET}"
echo -e "${C_GREEN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
left_text "Chu kỳ giám sát : ${C_BOLD_WHITE}Mỗi ${phut} phút quét 1 lần${C_RESET}" 2
left_text "Ngưỡng báo động : ${C_RED}>= ${tainguyen}%${C_RESET} ${C_YELLOW}(Áp dụng cho CPU/RAM/Disk)${C_RESET}" 2
left_text "Kênh tiếp nhận  : ${C_CYAN}Bot Telegram của bạn${C_RESET}" 2
echo -e "${C_GREEN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

[[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-bao-mat-main 1
