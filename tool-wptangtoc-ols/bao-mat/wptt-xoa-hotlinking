#!/bin/bash
# @author: Gia Tuấn
# @website: https://wptangtoc.com
# @since: 2026

function huong_dan() {
  Xoá chống Hotlinking [hay vô hiệu hóa tính năng chống Hotlinking] có nghĩa là bạn cho phép các trang web khác hiển thị trực tiếp các tài nguyên [như hình ảnh, video, tệp tin] từ máy chủ của bạn trên trang của họ.

  Giới thiệu ngắn gọn về việc hủy tính năng này:

  Khi bạn hủy bỏ việc chống hotlink, các website khác có thể dùng các liên kết trực tiếp khác để nhúng hình ảnh hoặc tệp tin từ website của bạn vào nội dung của họ. Điều này có nghĩa là mỗi khi ai đó truy cập trang web của họ và xem các tài nguyên đó, băng thông sẽ được tính cho máy chủ của bạn [ví dụ thông qua thẻ img hoặc iframe].

  Tại sao có thể cần hủy tính năng chống Hotlinking:
  * Cho phép chia sẻ tài nguyên: Bạn muốn các trang web khác [ví dụ: đối tác, blog, mạng xã hội] có thể nhúng trực tiếp hình ảnh hoặc tài liệu của bạn.
  * Sử dụng với CDN hoặc dịch vụ bên thứ ba: Một số cấu hình CDN hoặc dịch vụ nhất định có thể yêu cầu tắt chống hotlink ở máy chủ gốc để chúng hoạt động đúng cách.
  * Khắc phục sự cố: Đôi khi cấu hình chống hotlink quá chặt chẽ có thể vô tình chặn các lượt nhúng hợp lệ.
  * Không lo ngại về băng thông: Nếu việc sử dụng băng thông không phải là vấn đề lớn đối với bạn.

  Việc quyết định hủy tính năng chống hotlinking nên được cân nhắc dựa trên nhu cầu chia sẻ tài nguyên và khả năng quản lý băng thông của bạn.
}

. /etc/wptt/.wptt.conf
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh

echo -e "\n========================================================================="
echo -e "|$bao_mat => Hủy kích hoạt Hotlinking                                   |"
echo -e "=========================================================================\n"

. /etc/wptt/tenmien
echo -e "\nLựa chọn website bạn muốn HỦY kích hoạt Hotlinking: \n"
lua_chon_NAME
echo ""

# --- CHỐT CHẶN THOÁT HIỂM ---
[[ "$NAME" == "0" || -z "$NAME" ]] && exec /etc/wptt/wptt-bao-mat-main 1

path_htaccess="/usr/local/lsws/$NAME/html/.htaccess"
[[ ! -f "$path_htaccess" ]] && {
  clear
  . /etc/wptt/echo-color
  echoDo "Không tìm thấy file .htaccess hoặc website không tồn tại!"
  sleep 2
  exec /etc/wptt/wptt-bao-mat-main 1
}

is_hotlink_active=$(grep -c "#begin-hotlink-wptangtoc-ols" "$path_htaccess")

if [[ "$is_hotlink_active" -eq 0 ]]; then
  echo -e "\033[1;33mWebsite $NAME chưa kích hoạt Hotlinking trước đó!\033[0m"
  sleep 2
  exec /etc/wptt/wptt-bao-mat-main 1
  exit
fi

. /etc/wptt/echo-color

# --- XÁC NHẬN AN TOÀN ---
echo -e "Bạn đang chuẩn bị HỦY chống Hotlinking cho website \033[1;33m$NAME\033[0m."
prompt="Bạn có CHẮC CHẮN muốn thực hiện không? [1-2]: "
dongy="n"
options=("Đồng ý HỦY Hotlinking" "Không đồng ý (Thoát)")
PS3="$prompt"
select opt in "${options[@]}"; do
  case "$REPLY" in
  1)
    dongy="y"
    break
    ;;
  2)
    dongy="n"
    break
    ;;
  *)
    printf "\nNhập sai, hệ thống tự động HỦY BỎ.\n"
    break
    ;;
  esac
done

if [[ "$dongy" == "y" ]]; then
  UI_STRING="Hủy kích hoạt Hotlinking cho website $NAME"
  _runing "$UI_STRING"
  echo "Hủy kích hoạt hotlinking website $NAME: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log

  # Cạo sạch cấu hình (Bỏ ^ và $ để regex chống lỗi khoảng trắng)
  sed -i '/#begin-hotlink-wptangtoc-ols/,/#end-hotlink-wptangtoc-ols/d' "$path_htaccess"

  # Reload Zero-Downtime
  /usr/local/lsws/bin/lswsctrl reload >/dev/null 2>&1

  _rundone "$UI_STRING"
else
  exec /etc/wptt/wptt-bao-mat-main 1
fi

# --- FOOTER ---
[[ ${1:-} == "98" ]] && exec /etc/wptt/wptt-bao-mat-main 1
