#!/bin/bash
domain_thuc_thi=$1

if [[ $2 = 'on' ]]; then
  cong_tac='+i'
elif [[ $2 = 'off' ]]; then
  cong_tac='-i'
else
  return 2>/dev/null || exit
fi

path="/usr/local/lsws/$domain_thuc_thi/html"

# 1. Khoá/Mở khoá các thư mục cốt lõi (Gộp chung vào vòng lặp cho gọn code)
for dir in "wp-content/themes" "wp-content/plugins" "wp-admin" "wp-includes"; do
  if [[ -d "$path/$dir" ]]; then
    chattr -R $cong_tac "$path/$dir" 2>/dev/null
  fi
done

# 2. Khoá/Mở khoá các file PHP ở thư mục gốc (wp-config.php, wp-login.php...)
if [[ -d "$path" ]]; then
  # Dùng -exec {} + để tối ưu hiệu suất, thay vì vòng lặp for
  find "$path" -maxdepth 1 -type f -name "*.php" -exec chattr $cong_tac {} + 2>/dev/null
fi

# 3. Khoá/Mở khoá các file index.php trong thư mục uploads
if [[ -d "$path/wp-content/uploads" ]]; then
  find "$path/wp-content/uploads" -type f -name "index.php" -exec chattr $cong_tac {} + 2>/dev/null
fi
