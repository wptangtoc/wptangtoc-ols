#!/bin/bash

function huong_dan() {
  WPTangToc OLS có tính năng chống DDoS LiteSpeed Web Server, thì đây là chức năng giúp bạn cấu hình và tận dụng các cơ chế bảo vệ tích hợp sẵn ngay bên trong máy chủ web OpenLiteSpeed [OLS] để chống lại các cuộc tấn công từ chối dịch vụ [DDoS] hoặc các truy cập quá mức.

  Khác với Fail2ban [hoạt động bằng cách đọc log và chặn qua firewall], các tính năng này hoạt động trực tiếp tại tầng web server, thường tập trung vào việc giới hạn kết nối và yêu cầu [throttling].

  Tính năng Chống DDoS Tích hợp của LiteSpeed Web Server
  🛡️ Mục đích chính:
  * Bảo vệ Máy chủ: Ngăn chặn các địa chỉ IP đơn lẻ hoặc các bot tạo ra quá nhiều kết nối hoặc yêu cầu, làm cạn kiệt tài nguyên máy chủ [CPU, RAM, connections].
  * Duy trì Ổn định: Giúp website hoạt động ổn định hơn ngay cả khi có lượng truy cập cao hoặc đang bị tấn công ở mức độ nhỏ đến vừa.
  * Phản ứng Nhanh: Vì là tính năng tích hợp, OLS có thể phản ứng rất nhanh với các thay đổi về lưu lượng truy cập.

  ✅ Lợi ích:
  * Hiệu suất Cao: Xử lý ngay tại tầng web server, rất nhanh và hiệu quả.
  * Tích hợp Sẵn: Không cần cài đặt thêm phần mềm bên ngoài.
  * Kiểm soát Trực tiếp: Quản lý trực tiếp cách OLS xử lý các kết nối.

  Tóm lại: Tính năng này trong WPTangToc OLS giúp bạn khai thác và quản lý các cơ chế phòng thủ DDoS tích hợp sẵn của OpenLiteSpeed, chủ yếu thông qua việc giới hạn kết nối và yêu cầu từ mỗi IP, tạo thêm một lớp bảo vệ quan trọng cho website của bạn.

  Mode limit chống ddos LiteSpeed thiết lập như sau:
  Nếu IP đó truy cập gọi file tính static 40 yêu cầu / giây sẽ bị chặn
  Nếu IP đó truy cập gọi file tính động [html document] 3 yêu cầu / giây sẽ bị chặn
  Nếu IP đó truy cập gọi file tính động [html document] quá 20 giây sẽ bị chặn
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null # Nạp thư viện UI Xác nhận

clear
echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}${bao_mat} ➜ Chế độ Chống DDoS (I'm Under Attack)${C_RESET}"
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

config_file="/usr/local/lsws/conf/httpd_config.conf"

# ==============================================================================
# KIỂM TRA TRẠNG THÁI HIỆN TẠI
# ==============================================================================
is_under_attack=0
if [[ "$mod_chong_ddos" == "1" ]] || grep -q 'staticReqPerSec.*40' "$config_file" 2>/dev/null; then
  is_under_attack=1
fi

echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
if [[ $is_under_attack -eq 1 ]]; then
  left_text "Trạng thái bảo vệ : ${C_RED}ĐANG BẬT (Under Attack Mode)${C_RESET}" 2
  left_text "Cảnh báo          : ${C_YELLOW}Giới hạn Request rất gắt gao. Người dùng thật${C_RESET}" 2
  left_text "                    ${C_YELLOW}có thể phải xác thực reCAPTCHA liên tục.${C_RESET}" 2
else
  left_text "Trạng thái bảo vệ : ${C_GREEN}ĐANG TẮT (Chế độ Bình Thường)${C_RESET}" 2
  left_text "Hiệu suất Server  : Đạt mức tối đa (Raw Performance)" 2
fi
echo -e "${C_CYAN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
left_text "Tính năng này can thiệp vào lõi OpenLiteSpeed, ép bật reCAPTCHA," 2
left_text "bóp nghẹt số Request/giây và giảm Timeout để chống cạn kiệt RAM." 2
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

# Tính toán tài nguyên phần cứng chung
cpucore=$(grep -c ^processor /proc/cpuinfo)
work_cpucore=1024

# ==============================================================================
# NHÁNH 1: ĐANG TẮT -> HỎI ĐỂ BẬT LÊN
# ==============================================================================
if [[ $is_under_attack -eq 0 ]]; then
  if wptt_xac_nhan "Website đang bị tấn công? Bạn có CHẮC CHẮN muốn BẬT chế độ chống DDoS?" "LƯU Ý: Chỉ kích hoạt khi thực sự có bão Traffic/DDoS." "Khi bão tan, hãy nhớ vào tắt đi để website hoạt động trơn tru nhất." "Đồng ý BẬT" "Hủy thao tác"; then
    echo ""

    _runing "Đang cấu hình bóp nghẹt băng thông và bật reCAPTCHA..."

    # Tính toán Max Client khẩn cấp (x12 để tránh nghẽn Port 443 do botnet giữ connection)
    max_client_max=$((work_cpucore * cpucore * 12))

    # 1. Cấu hình lại khối Tuning (Giảm Timeout chống Slowloris)
    sed -i -e '/^tuning /,/^}$/d' "$config_file"
    cat <<EOF >>"$config_file"
tuning  {
  maxConnections          $max_client_max
  maxSSLConnections       $max_client_max
  connTimeout             20
  maxKeepAliveReq         1000
  keepAliveTimeout        10
  sndBufSize              0
  rcvBufSize              0
  maxReqURLLen            32768
  maxReqHeaderSize        65536
  maxReqBodySize          2047M
  maxDynRespHeaderSize    32768
  maxDynRespSize          2047M
  maxCachedFileSize       4096
  totalInMemCacheSize     20M
  maxMMapFileSize         256K
  totalMMapCacheSize      40M
  useSendfile             1
  fileETag                28
  enableGzipCompress      1
  compressibleTypes       default
  enableDynGzipCompress   1
  gzipCompressLevel       1
  gzipAutoUpdateStatic    1
  gzipStaticCompressLevel 6
  brStaticCompressLevel   6
  gzipMaxFileSize         10M
  gzipMinFileSize         300

  quicEnable              1
  quicShmDir              /dev/shm
} 
EOF

    # 2. Xóa cấu hình giới hạn cũ và lsrecaptcha
    sed -i -e '/^perClientConnLimit /,/^}$/d' "$config_file"
    sed -i -e '/^lsrecaptcha /,/^}$/d' "$config_file"

    # 3. Tiêm cấu hình Giới hạn siêu ngặt nghèo
    cat <<EOF >>"$config_file"
perClientConnLimit {
  staticReqPerSec         40
  dynReqPerSec            3
  outBandwidth            0
  inBandwidth             0
  softLimit               15
  hardLimit               20
  blockBadReq             1
  gracePeriod             15
  banPeriod               900
}

lsrecaptcha  {
  enabled                 1
  type                    1
  botWhiteList  {
  }
}
EOF

    # Cập nhật biến môi trường
    sed -i '/mod_chong_ddos/d' /etc/wptt/.wptt.conf
    echo 'mod_chong_ddos=1' >>/etc/wptt/.wptt.conf

    _rundone "Cập nhật các thông số bảo vệ lõi thành công"

    _runing "Đang nạp lại cấu hình OpenLiteSpeed (Restart)..."
    /usr/local/lsws/bin/lswsctrl restart >/dev/null 2>&1
    _rundone "Lớp khiên bảo vệ đã được dựng lên"

    # BẢNG BÁO CÁO THÀNH CÔNG
    echo -e "\n${C_RED}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
    center_text "${C_BOLD_WHITE}ĐÃ KÍCH HOẠT CHẾ ĐỘ CHỐNG DDOS KHẨN CẤP${C_RESET}"
    echo -e "${C_RED}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
    left_text "Mức độ bảo vệ hiện tại:" 2
    left_text " - Giới hạn File động (PHP) : ${C_YELLOW}3 Yêu cầu / 1 Giây / 1 IP${C_RESET}" 2
    left_text " - Giới hạn File tĩnh       : ${C_YELLOW}40 Yêu cầu / 1 Giây / 1 IP${C_RESET}" 2
    left_text " - Thời gian khóa (Ban)     : ${C_YELLOW}900 Giây (15 Phút)${C_RESET}" 2
    left_text " - Trạng thái Anti-Bot      : ${C_YELLOW}Bật xác thực reCAPTCHA Server${C_RESET}" 2
    echo -e "${C_RED}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

  else
    echo -e "${C_YELLOW}Đã hủy thao tác kích hoạt chế độ chống DDoS.${C_RESET}\n"
  fi

# ==============================================================================
# NHÁNH 2: ĐANG BẬT -> HỎI ĐỂ TẮT ĐI
# ==============================================================================
else
  if wptt_xac_nhan "Website đã hết bão Traffic? Bạn có muốn TẮT chế độ chống DDoS?" "Thao tác này sẽ dỡ bỏ giới hạn reCAPTCHA và đưa Server về trạng" "thái hiệu suất cao nhất để phục vụ người dùng bình thường." "Đồng ý TẮT" "Hủy thao tác"; then
    echo ""

    _runing "Đang gỡ bỏ giới hạn và khôi phục hiệu suất tối đa..."

    # Tính toán Max Client bình thường (x3)
    max_client_max=$((work_cpucore * cpucore * 3))

    # 1. Cấu hình lại khối Tuning (Timeout bình thường)
    sed -i -e '/^tuning /,/^}$/d' "$config_file"
    cat <<EOF >>"$config_file"
tuning  {
  maxConnections          $max_client_max
  maxSSLConnections       $max_client_max
  connTimeout             300
  maxKeepAliveReq         1000
  keepAliveTimeout        10
  sndBufSize              0
  rcvBufSize              0
  maxReqURLLen            32768
  maxReqHeaderSize        65536
  maxReqBodySize          2047M
  maxDynRespHeaderSize    32768
  maxDynRespSize          2047M
  maxCachedFileSize       4096
  totalInMemCacheSize     20M
  maxMMapFileSize         256K
  totalMMapCacheSize      40M
  useSendfile             1
  fileETag                28
  enableGzipCompress      1
  compressibleTypes       default
  enableDynGzipCompress   1
  gzipCompressLevel       1
  gzipAutoUpdateStatic    1
  gzipStaticCompressLevel 6
  brStaticCompressLevel   6
  gzipMaxFileSize         10M
  gzipMinFileSize         300

  quicEnable              1
  quicShmDir              /dev/shm
} 
EOF

    # 2. Xóa cấu hình giới hạn ngặt nghèo và lsrecaptcha
    sed -i -e '/^perClientConnLimit /,/^}$/d' "$config_file"
    sed -i -e '/^lsrecaptcha /,/^}$/d' "$config_file"

    # 3. Tiêm lại giới hạn siêu rộng (Gần như không giới hạn)
    cat <<EOF >>"$config_file"
perClientConnLimit  {
  softLimit               100000
  hardLimit               150000
}
EOF

    #tune auto config tối ưu
    echo '100' >/etc/wptt/.ram_hien_tai #để ép thực thi wptt-auto-tune
    (/bin/bash /etc/wptt/cau-hinh/wptt-auto-tune >/dev/null 2>&1)

    # Cập nhật biến môi trường
    sed -i '/mod_chong_ddos/d' /etc/wptt/.wptt.conf
    _rundone "Dỡ bỏ khiên bảo vệ, khôi phục thông số chuẩn"

    _runing "Nạp lại cấu hình OpenLiteSpeed (Restart)..."
    /usr/local/lsws/bin/lswsctrl restart >/dev/null 2>&1
    _rundone "Nạp lại cấu hình OpenLiteSpeed (Restart)..."

    # BẢNG BÁO CÁO TẮT
    echo -e "\n${C_GREEN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
    center_text "${C_BOLD_WHITE}ĐÃ TẮT CHẾ ĐỘ CHỐNG DDOS (KHÔI PHỤC BÌNH THƯỜNG)${C_RESET}"
    echo -e "${C_GREEN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
    left_text "Mọi giới hạn khắt khe và hệ thống reCAPTCHA đã được gỡ bỏ." 2
    left_text "Website của bạn đã quay trở lại trạng thái tối ưu tốc độ." 2
    echo -e "${C_GREEN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

  else
    echo -e "${C_YELLOW}Đã hủy thao tác tắt chế độ chống DDoS.${C_RESET}\n"
  fi
fi

[[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-bao-mat-main 1
