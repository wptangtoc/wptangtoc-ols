#!/bin/bash

function huong_dan() {
  Thiết lập telegram API để tiền để phục vụ các tính năng có cần sự trợ giúp của telegram API.
  Như: thông báo login ssh, thông báo downtime website...
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null # Nạp thư viện UX Bo Cong

clear
echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}${bao_mat} ➜ Thiết lập Telegram Bot (Nhận Cảnh Báo)${C_RESET}"
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
if [[ -z "$telegram_api" || -z "$telegram_id" ]]; then
  left_text "Trạng thái Bot : ${C_RED}CHƯA ĐƯỢC THIẾT LẬP${C_RESET}" 2
  echo -e "${C_CYAN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
  left_text "Thiết lập Bot Telegram giúp VPS gửi cảnh báo bảo mật" 2
  left_text "(VD: Đăng nhập SSH trái phép, Backup xong, Web bị sập...) thẳng" 2
  left_text "về điện thoại của bạn ngay lập tức theo thời gian thực." 2
else
  left_text "Trạng thái Bot : ${C_GREEN}ĐÃ KÍCH HOẠT THÀNH CÔNG${C_RESET}" 2
  left_text "Bot API Token  : ${C_YELLOW}${telegram_api:0:15}****...${C_RESET}" 2
  left_text "Chat ID (User) : ${C_YELLOW}$telegram_id${C_RESET}" 2
  echo -e "${C_CYAN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
  left_text "VPS đã được kết nối với Telegram. Mọi cảnh báo bảo mật và sao lưu" 2
  left_text "sẽ được gửi tự động về Chat ID này." 2
fi
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

if [[ -n "$telegram_api" && -n "$telegram_id" ]]; then
  if wptt_xac_nhan "Hệ thống đã có cấu hình Telegram. Bạn có muốn XÓA để thiết lập lại không?" "" "" "Đồng ý XÓA và Cài lại" "Hủy (Giữ nguyên)"; then
    echo ""
    _runing "Đang gỡ bỏ cấu hình Telegram cũ..."
    sed -i "/telegram_api=/d" /etc/wptt/.wptt.conf
    sed -i "/telegram_id=/d" /etc/wptt/.wptt.conf
    telegram_api=""
    telegram_id=""
    _rundone "Gỡ bỏ cấu hình cũ thành công. Bắt đầu thiết lập mới."
    echo ""
  else
    # Thoát và quay về nhánh gọi script
    if [[ "${1:-}" == "98" ]]; then exec /etc/wptt/wptt-bao-mat-main 1; fi
    [[ "${1:-}" == "1998" ]] && . /etc/wptt/add-one/check.sh
    [[ "${1:-}" == "backup" ]] && . /etc/wptt/add-one/sao-luu-telegram.sh
    [[ "${1:-}" == "restore" ]] && . /etc/wptt/add-one/restore-telegram.sh
    [[ "${1:-}" == "auto-backup-setup" ]] && . /etc/wptt/add-one/thiet-lap-auto-backup-telegram
    exit 0
  fi
fi

# ==============================================================================
# NHÁNH 2: TIẾN HÀNH THIẾT LẬP MỚI
# ==============================================================================
if [[ -z "$telegram_api" || -z "$telegram_id" ]]; then
  echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_BOLD_WHITE}Hướng dẫn tạo Bot lấy API và ID chi tiết tại:${C_RESET}"
  echo -e "${C_CYAN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
  left_text "Truy cập vào đường dẫn link:" 2
  left_text "https://wptangtoc.com/thiet-lap-telegram-chat-bot-cho-wptangtoc-ols/" 2
  echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

  if wptt_xac_nhan "Bạn đã chuẩn bị sẵn mã Bot API và Chat ID chưa? Kích hoạt ngay?" "" "" "Đồng ý Kích Hoạt" "Hủy thao tác"; then
    echo ""
    echo -e "${C_YELLOW}Nhập thông tin Bot Telegram của bạn:${C_RESET}"
    read -rp " ➜ Nhập Telegram API (Token) : " new_telegram_api
    read -rp " ➜ Nhập Telegram Chat ID     : " new_telegram_id
    echo ""

    # Dọn dẹp khoảng trắng dư thừa do copy nhầm
    new_telegram_api=$(echo "$new_telegram_api" | xargs)
    new_telegram_id=$(echo "$new_telegram_id" | xargs)

    if [[ -z "$new_telegram_api" || -z "$new_telegram_id" ]]; then
      echo -e "${C_RED}❌ Bạn không được để trống API hoặc ID. Đã hủy thiết lập.${C_RESET}"
      sleep 2
      [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-bao-mat-main 1
      exit 1
    fi

    telegram_loi=""
    _runing "Đang lưu cấu hình vào hệ thống..."
    sed -i "/telegram_api=/d" /etc/wptt/.wptt.conf
    echo "telegram_api=$new_telegram_api" >>/etc/wptt/.wptt.conf
    sed -i "/telegram_id=/d" /etc/wptt/.wptt.conf
    echo "telegram_id=$new_telegram_id" >>/etc/wptt/.wptt.conf
    _rundone "Đã lưu cấu hình mới"

    # =========================================================
    # KIỂM TRA BOT (GET UPDATES)
    # =========================================================
    _runing "Đang kết nối tới Telegram Server để kiểm tra Token..."
    checkactivate=$(curl -s --connect-timeout 5 "https://worker-soft-shape-e788.hoangtuan0137.workers.dev/bot${new_telegram_api}/getUpdates")

    if [[ $checkactivate != *"\"ok\":true"* ]]; then
      _runloi "Kết nối thất bại! Token API không hợp lệ"
      telegram_loi='1'
    else
      _rundone "Token API hợp lệ. Kết nối tới Bot thành công"

      # =========================================================
      # GỬI TIN NHẮN THỬ NGHIỆM (PING)
      # =========================================================
      _runing "Đang gửi thử tin nhắn cảnh báo tới Chat ID: $new_telegram_id..."
      ip=$(curl -sf --connect-timeout 5 --max-time 10 https://ipv4.icanhazip.com || curl -sf --connect-timeout 5 --max-time 10 https://checkip.amazonaws.com)
      text="*KẾT NỐI BOT THÀNH CÔNG*%0A%0ACảm ơn bạn đã sử dụng WPTangToc OLS.%0APhiên bản OLS: \`$version_wptangtoc_ols\`%0AIP Máy chủ: \`$ip\`%0APhát triển bởi: [Gia Tuấn](https://wptangtoc.com)"

      url_tele="https://worker-soft-shape-e788.hoangtuan0137.workers.dev/bot${new_telegram_api}/sendMessage"
      http_telegram=$(curl -s -d "chat_id=$new_telegram_id&text=${text}&disable_web_page_preview=true&parse_mode=markdown" "$url_tele")

      if [[ $http_telegram == *"\"ok\":true"* ]]; then
        _rundone "Tin nhắn đã được gửi thành công đến điện thoại của bạn!"
      else
        _runloi "Gửi tin nhắn thất bại. Vui lòng kiểm tra lại Chat ID."
        telegram_loi='1'
      fi
    fi

    # =========================================================
    # XỬ LÝ NẾU CÓ LỖI XẢY RA
    # =========================================================
    if [[ -n "$telegram_loi" ]]; then
      sed -i "/telegram_api=/d" /etc/wptt/.wptt.conf
      sed -i "/telegram_id=/d" /etc/wptt/.wptt.conf

      echo -e "\n${C_RED}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
      center_text "${C_BOLD_WHITE}LỖI: THIẾT LẬP TELEGRAM THẤT BẠI${C_RESET}"
      echo -e "${C_RED}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
      left_text "VPS không thể giao tiếp với Telegram. Hãy kiểm tra các nguyên nhân:" 2
      left_text " 1. Copy dư khoảng trắng (Dấu cách) ở Token hoặc Chat ID." 2
      left_text " 2. Nhập nhầm Chat ID (Ghi nhầm ID người khác hoặc thiếu dấu -)." 2
      left_text " 3. Bạn CHƯA bấm nút /start hoặc nhắn tin cho Bot trước khi" 2
      left_text "    cấu hình, khiến Bot không có quyền gửi tin nhắn cho bạn." 2
      echo -e "${C_RED}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

      sleep 3
      check_menu_wptangtoc_active=${1:-}
      if [[ "$check_menu_wptangtoc_active" == "1998" || "$check_menu_wptangtoc_active" == "restore" || "$check_menu_wptangtoc_active" == "backup" || "$check_menu_wptangtoc_active" == "auto-backup-setup" ]]; then
        exec /etc/wptt/wptt-add-one-main 1
        return 2>/dev/null || exit 1
      fi
      [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-bao-mat-main 1
      exit 1

    else
      echo -e "\n${C_GREEN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
      center_text "${C_BOLD_WHITE}HOÀN TẤT THIẾT LẬP TELEGRAM BOT${C_RESET}"
      echo -e "${C_GREEN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
      left_text "Kiểm tra ngay điện thoại của bạn, một tin nhắn thông báo từ" 2
      left_text "WPTangToc OLS đã được gửi tới thành công!" 2
      echo -e "${C_GREEN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

      sleep 2
    fi

  else
    echo -e "${C_YELLOW}Đã hủy thao tác thiết lập Telegram.${C_RESET}\n"
    [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-bao-mat-main 1
    exit 0
  fi
fi

# ==============================================================================
# ĐIỀU HƯỚNG QUAY LẠI MENU GỐC NẾU GỌI TỪ NƠI KHÁC ĐẾN
# ==============================================================================
check_menu_wptangtoc_active=${1:-}
if [[ "$check_menu_wptangtoc_active" == "1998" ]]; then
  . /etc/wptt/add-one/check.sh
elif [[ "$check_menu_wptangtoc_active" == "backup" ]]; then
  . /etc/wptt/add-one/sao-luu-telegram.sh
elif [[ "$check_menu_wptangtoc_active" == "restore" ]]; then
  . /etc/wptt/add-one/restore-telegram.sh
elif [[ "$check_menu_wptangtoc_active" == "auto-backup-setup" ]]; then
  . /etc/wptt/add-one/thiet-lap-auto-backup-telegram
elif [[ "$check_menu_wptangtoc_active" == "98" ]]; then
  exec /etc/wptt/wptt-bao-mat-main 1
fi
