function huong_dan() {
  Tính năng Chống DDoS [WPTangToc OLS] sử dụng Fail2ban:
  🛡️ Mục đích:
  Tự động phát hiện và chặn các địa chỉ IP có dấu hiệu truy cập bất thường, đặc biệt là nhắm vào các nội dung động [dynamic content] - những nội dung tốn nhiều tài nguyên xử lý của máy chủ [như PHP, cơ sở dữ liệu].

  ⚙️ Quy tắc hoạt động cụ thể:
  * Công cụ: Sử dụng Fail2ban, một phần mềm giám sát log và chặn IP.
  * Điều kiện Kích hoạt [Trigger]: Nếu một địa chỉ IP thực hiện 20 yêu cầu [requests] đến các tệp tin động [html document] trong vòng 30 giây.
  * Hành động [Action]: Ngay lập tức, Fail2ban sẽ ra lệnh cho tường lửa chặn [block] địa chỉ IP đó trong vòng 2 tiếng.

  Bạn có thể dễ dàng Bật/Tắt tính năng này cho từng website hoặc tất cả website bằng 1 cú chạm.
}

. /etc/wptt/.wptt.conf
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh
. /etc/wptt/echo-color

echo -e "\n========================================================================="
echo -e "| Bảo mật => Bật / Tắt Chống DDoS Website [Fail2ban]                    |"
echo -e "=========================================================================\n"

# ==============================================================================
# HÀM MENU LỌC THÔNG MINH
# ==============================================================================
function lua_chon_NAME() {
  NAME=""
  if [[ -n "$(ls -A /etc/wptt/vhost 2>/dev/null)" ]]; then
    selects=()

    for filepath in /etc/wptt/vhost/.*.conf; do
      [[ ! -f "$filepath" || "$filepath" == *"/..conf" ]] && continue

      local domain="${filepath##*/}"
      domain="${domain%.conf}"
      domain="${domain#.}"

      if [[ "$domain" == ?*.?* ]]; then
        local domain_fail2ban="${domain//[-._]/wp}"
        local filter_path="/etc/fail2ban/filter.d/ddos-$domain_fail2ban.conf"

        if [[ -f "$filter_path" ]]; then
          selects+=("$domain [Đang BẬT]")
        else
          selects+=("$domain [Đang TẮT]")
        fi
      fi
    done

    if [[ ${#selects[@]} -eq 0 ]]; then
      echo -e "\033[1;33mHệ thống chưa có Website nào để cấu hình Chống DDoS!\033[0m"
      sleep 3
      exec /etc/wptt/wptt-bao-mat-main 1
    fi

    if [[ ${#selects[@]} -ge 2 ]]; then
      selects+=("TẤT CẢ WEBSITE (Thao tác đồng loạt)")
    fi

    PS3=$'\n'"-//- Lựa chọn website bạn muốn cấu hình [0=Thoát]: "
    select select in "${selects[@]}"; do
      NAME=$select
      break
    done
  else
    clear
    echo "$khong_co_domain_nao_ton_tai_tren_he_thong"
    exit
  fi
}

if [[ -n "$1" && "$1" != "98" ]]; then
  NAME="$1"
else
  lua_chon_NAME
fi

NAME=$(echo "$NAME" | cut -f1 -d ' ')

[[ "$NAME" == "0" || -z "$NAME" ]] && exec /etc/wptt/wptt-bao-mat-main 1

# ==============================================================================
# HÀM CÀI ĐẶT GÓI PHỤ THUỘC (Chạy 1 lần duy nhất)
# ==============================================================================
function install_dependencies() {
  if grep -qi "ubuntu" /etc/os-release 2>/dev/null; then
    if ! dpkg -s python3-pyinotify ipset >/dev/null 2>&1; then
      export DEBIAN_FRONTEND=noninteractive
      apt-get update >/dev/null 2>&1
      apt-get install -y python3-pyinotify ipset >/dev/null 2>&1
    fi
    tuong_thich_nhom_litespeed="nogroup"
  else
    if ! rpm -q python3-inotify ipset >/dev/null 2>&1; then
      dnf install -y python3-inotify ipset >/dev/null 2>&1
    fi
    tuong_thich_nhom_litespeed="nobody"
  fi
}

if grep -qi "ubuntu" /etc/os-release 2>/dev/null; then
  tuong_thich_nhom_litespeed="nogroup"
else
  tuong_thich_nhom_litespeed="nobody"
fi

# ==============================================================================
# HÀM THỰC THI BẬT/TẮT CHỐNG DDOS CHO 1 DOMAIN
# ==============================================================================
function process_ddos() {
  local target_domain=$1
  local action=$2 # "bat" hoac "tat"
  local domain_fail2ban="${target_domain//[-._]/wp}"
  local filter_path="/etc/fail2ban/filter.d/ddos-$domain_fail2ban.conf"
  local vhost_conf="/usr/local/lsws/conf/vhosts/$target_domain/$target_domain.conf"

  if [[ "$action" == "bat" ]]; then
    [[ -f "$filter_path" ]] && return # Đã bật rồi thì bỏ qua

    UI_STRING="Kích hoạt Chống DDoS (Fail2ban) cho $target_domain"
    _runing "$UI_STRING"

    # Kiểm tra Cloudflare CDN
    local TRACE_OUTPUT=$(curl -Is --connect-timeout 5 --max-time 10 "https://$target_domain/cdn-cgi/trace" 2>/dev/null)
    if echo "$TRACE_OUTPUT" | grep -qi 'cloudflare\|cf-ray'; then
      if ! grep -q '103.21.244.0' /usr/local/lsws/conf/httpd_config.conf 2>/dev/null; then
        echo -e "\n\033[1;31m[CẢNH BÁO] Phát hiện $target_domain dùng Cloudflare nhưng chưa bật Real IP!\033[0m"
        echo "Vui lòng bật tính năng Hiện thị IP Log Real bypass Cloudflare CDN trước khi dùng chức năng này để tránh chặn nhầm."
        _rundone "Đã BỎ QUA website $target_domain để đảm bảo an toàn."
        return
      fi
    fi

    # Tách log cho Vhost
    if ! grep -q 'accesslog' "$vhost_conf" 2>/dev/null; then
      sed -i '/^errorlog /,/^}$/d' "$vhost_conf"
      sed -i '/^accesslog /,/^}$/d' "$vhost_conf"
      cat <<EOF >>"$vhost_conf"

errorlog \$VH_ROOT/logs/error.log {
  useServer               1
  logLevel                ERROR
  rollingSize             10M
}

accesslog \$VH_ROOT/logs/access.log {
  useServer               0
  rollingSize             10M
  keepDays                30
  compressArchive         1
}
EOF
    fi

    mkdir -p "/usr/local/lsws/$target_domain/logs"
    chown -R nobody:$tuong_thich_nhom_litespeed "/usr/local/lsws/$target_domain/logs"
    chmod 700 "/usr/local/lsws/$target_domain/logs"

    # Tính toán biến Rule
    local rule_fail2ban_name="ddos-$domain_fail2ban"
    if ((${#rule_fail2ban_name} > 20)); then
      rule_fail2ban_name=$(echo "$rule_fail2ban_name" | cut -c 1-20)
    fi

    local action_thuc_thi_block=""
    if [[ -f /etc/csf/csf.conf ]]; then
      action_thuc_thi_block="iptables-multiport[actname=block-tcp, name=$rule_fail2ban_name-t, port=\"80,443\", protocol=\"tcp\"]
          iptables-multiport[actname=block-udp, name=$rule_fail2ban_name-u, port=\"80,443\", protocol=\"udp\"]"
    elif [[ $(systemctl status nftables.service 2>/dev/null | grep -i 'Active' | grep -o 'active') == "active" ]]; then
      action_thuc_thi_block="nftables-allports[name=$rule_fail2ban_name]"
    elif [[ $(systemctl status firewalld.service 2>/dev/null | grep -i 'Active' | grep -o 'active') == "active" ]]; then
      action_thuc_thi_block="firewallcmd-ipset[actname=block-tcp, name=$rule_fail2ban_name-t, port=\"80,443\", protocol=\"tcp\"]
          firewallcmd-ipset[actname=block-udp, name=$rule_fail2ban_name-u, port=\"80,443\", protocol=\"udp\"]"
    else
      action_thuc_thi_block="iptables-multiport[actname=block-tcp, name=$rule_fail2ban_name-t, port=\"80,443\", protocol=\"tcp\"]
          iptables-multiport[actname=block-udp, name=$rule_fail2ban_name-u, port=\"80,443\", protocol=\"udp\"]"
    fi

    cat <<EOF >>"/etc/fail2ban/jail.local"

#begin-ddos-website-$domain_fail2ban
[$rule_fail2ban_name]
enabled = true
action = $action_thuc_thi_block
filter = ddos-$domain_fail2ban
logpath = /usr/local/lsws/$target_domain/logs/access.log
backend = pyinotify
bantime = 7200
maxretry = 20
findtime = 30
#end-ddos-website-$domain_fail2ban
EOF

    echo '[Definition]
failregex = ^<HOST> .* "(GET|POST|HEAD) .* HTTP\/.*"
ignoreregex = \.(?i)(robots\.txt|favicon\.ico|jpg|png|webp|css|js|jpeg|woff2|avif|gif|svg|woff|ttf)(\?.*)?$' >"$filter_path"

    echo "Bật Chống DDoS website $target_domain: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log
    _rundone "$UI_STRING"

  elif [[ "$action" == "tat" ]]; then
    [[ ! -f "$filter_path" ]] && return # Chưa bật thì bỏ qua

    UI_STRING="Tắt (Hủy) Chống DDoS cho $target_domain"
    _runing "$UI_STRING"

    bat_log_domain=""
    [[ -f "/etc/wptt/vhost/.$target_domain.conf" ]] && . "/etc/wptt/vhost/.$target_domain.conf"

    if [[ -z "$bat_log_domain" ]]; then
      sed -i '/^errorlog /,/^}$/d' "$vhost_conf"
      sed -i '/^accesslog /,/^}$/d' "$vhost_conf"
      rm -rf "/usr/local/lsws/$target_domain/logs"
    fi

    if [[ ! -d "/usr/local/lsws/logs" ]]; then
      mkdir -p /usr/local/lsws/logs
      chown root:nobody /usr/local/lsws/logs
    fi

    sed -i "/^#begin-ddos-website-$domain_fail2ban/,/^#end-ddos-website-$domain_fail2ban$/d" /etc/fail2ban/jail.local
    rm -f "$filter_path"

    echo "Tắt Chống DDoS website $target_domain: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log
    _rundone "$UI_STRING"
  fi
}

# ==============================================================================
# XỬ LÝ LÔGIC RẼ NHÁNH
# ==============================================================================

if [[ "$NAME" == "TẤT CẢ WEBSITE (Thao tác đồng loạt)" || "$NAME" == "TẤT" ]]; then
  echo -e "\nBạn muốn BẬT hay TẮT Chống DDoS cho \033[1;33mTẤT CẢ\033[0m website?"
  prompt="Lựa chọn của bạn [1-2]: "
  mass_action=""
  options=("BẬT đồng loạt" "TẮT đồng loạt" "Hủy bỏ")
  PS3="$prompt"
  select opt in "${options[@]}"; do
    case "$REPLY" in
    1)
      mass_action="bat"
      break
      ;;
    2)
      mass_action="tat"
      break
      ;;
    3) exec /etc/wptt/wptt-bao-mat-main 1 ;;
    *)
      printf "\nNhập sai, tự động hủy.\n"
      exec /etc/wptt/wptt-bao-mat-main 1
      ;;
    esac
  done

  [[ "$mass_action" == "bat" ]] && install_dependencies

  for filepath in /etc/wptt/vhost/.*.conf; do
    [[ ! -f "$filepath" || "$filepath" == *"/..conf" ]] && continue
    domain="${filepath##*/}"
    domain="${domain%.conf}"
    domain="${domain#.}"
    if [[ "$domain" == ?*.?* ]]; then
      process_ddos "$domain" "$mass_action"
    fi
  done

else
  pathcheck="/etc/wptt/vhost/.$NAME.conf"
  [[ ! -f "$pathcheck" ]] && {
    echoDo "Tên miền không tồn tại!"
    sleep 2
    exec /etc/wptt/wptt-bao-mat-main 1
  }

  domain_fail2ban="${NAME//[-._]/wp}"
  if [[ -f "/etc/fail2ban/filter.d/ddos-$domain_fail2ban.conf" ]]; then
    process_ddos "$NAME" "tat"
  else
    install_dependencies
    process_ddos "$NAME" "bat"
  fi
fi

# ==============================================================================
# KHỞI ĐỘNG LẠI DỊCH VỤ
# ==============================================================================
UI_RELOAD="Nạp lại quy tắc Fail2ban và OpenLiteSpeed"
_runing "$UI_RELOAD"
/usr/local/lsws/bin/lswsctrl reload >/dev/null 2>&1
fail2ban-client reload >/dev/null 2>&1 || systemctl restart fail2ban >/dev/null 2>&1
_rundone "$UI_RELOAD"

[[ ${1:-} == "98" ]] && exec /etc/wptt/wptt-bao-mat-main 1
