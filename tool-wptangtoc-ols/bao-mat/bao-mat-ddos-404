#!/bin/bash

function huong_dan() {
  Tính năng Chống DDoS 404 trong WPTangToc OLS là một cơ chế phòng vệ giúp máy chủ OpenLiteSpeed của bạn đối phó với các cuộc tấn công từ chối dịch vụ phân tán [DDoS] ở mức độ đơn giản đến trung bình.

  Mã lỗi HTTP 404 là một mã trạng thái HTTP trang không tồn tại tiêu chuẩn mà máy chủ web gửi lại cho trình duyệt [hoặc client] khi máy chủ hiểu yêu cầu của bạn.

  Nói một cách đơn giản, máy chủ đang nói rằng: Tôi biết bạn muốn gì, nhưng bạn không có quyền truy cập vào tài nguyên đó.

  Bằng cách theo dõi các địa chỉ IP bị trả về lỗi 404 là trang động, html không phải là những file static như css, js, png, jpg, woff...
  Nếu trong vòng 15 giây mà IP đó yêu cầu và trả về 404 hơn tận 5 lần sẽ bị tạm khoá IP trong vòng 2 tiếng.
  [Bản nâng cấp Enterprise: Tích hợp Ipset tốc độ cao, nhận diện HTTP/3 UDP và tối ưu pyinotify]
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null

clear
echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}BẢO MẬT ➜ Chống tấn công DDoS 404${C_RESET}"
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────── ──────────╯\n${C_RESET}"

if [[ "${1:-}" == '98' ]]; then
  WPTT_IN_MENU="yes"
  WPTT_MENU_BACK="/etc/wptt/wptt-bao-mat-main 1"
fi

check=$(grep '#begin-ddos-404-website' /etc/fail2ban/jail.local 2>/dev/null)

echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
if [[ -n "$check" ]]; then
  left_text "Trạng thái    : ${C_GREEN}ĐÃ KÍCH HOẠT${C_RESET}" 2
  echo -e "${C_CYAN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
  left_text "Hệ thống đang được bảo vệ bởi Ipset và Pyinotify tốc độ cao." 2
  left_text "Nếu 1 IP phát sinh ${C_RED}5 lỗi 404${C_RESET} trong 15s, nó sẽ bị khóa 2 tiếng." 2
else
  left_text "Trạng thái    : ${C_RED}CHƯA KÍCH HOẠT${C_RESET}" 2
  echo -e "${C_CYAN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
  left_text "Nên bật tính năng này để ngăn chặn các cuộc tấn công dò tìm" 2
  left_text "lỗ hổng (Scan URL) hoặc DDoS làm cạn kiệt tài nguyên máy chủ." 2
fi
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

# ==============================================================================
# XỬ LÝ NHÁNH 1: ĐANG BẬT -> YÊU CẦU TẮT
# ==============================================================================
if [[ -n "$check" ]]; then
  if ! wptt_xac_nhan "Tính năng Chống DDoS 404 đang BẬT. Bạn có muốn TẮT không?" "" "" "Đồng ý Tắt" "Giữ nguyên (Hủy)"; then
    echo -e "${C_YELLOW}Đã hủy thao tác.${C_RESET}\n"
    [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-bao-mat-main 1
    exit 0
  fi

  echo ""
  _runing "Đang vô hiệu hóa Rule chống DDoS 404 trên Fail2Ban..."
  sed -i -e '/^#begin-ddos-404-website/,/^#end-ddos-404-website$/d' /etc/fail2ban/jail.local
  rm -f /etc/fail2ban/filter.d/wptangtoc-404.conf

  if command -v fail2ban-client >/dev/null 2>&1; then
    fail2ban-client reload >/dev/null 2>&1 || systemctl restart fail2ban >/dev/null 2>&1
  fi
  _rundone "Hủy kích hoạt chống DDoS 404 thành công!"

  sleep 2
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-bao-mat-main 1
  exit 0
fi

if ! wptt_xac_nhan "Bạn có muốn KÍCH HOẠT bảo vệ Chống DDoS 404 không?" "Hệ thống sẽ tự động cài đặt thư viện cần thiết và thiết lập Rule." "" "Đồng ý Bật" "Hủy thao tác"; then
  echo -e "${C_YELLOW}Đã hủy thao tác.${C_RESET}\n"
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-bao-mat-main 1
  exit 0
fi

echo ""
_runing "Đang cài đặt thư viện cần thiết (Ipset & Pyinotify)..."
if grep -qi "ubuntu" /etc/os-release 2>/dev/null; then
  dpkg -s python3-pyinotify ipset >/dev/null 2>&1 || {
    export DEBIAN_FRONTEND=noninteractive
    apt-get update >/dev/null 2>&1
    apt-get install -y python3-pyinotify ipset >/dev/null 2>&1
  }
else
  rpm -q python3-inotify ipset >/dev/null 2>&1 || {
    dnf install -y python3-inotify ipset >/dev/null 2>&1
  }
fi
_rundone "Cài đặt thư viện nền tảng thành công"

_runing "Đang quét và cấu hình Log cho các Website (Vhost)..."
if [ "$(ls -A /etc/wptt/vhost 2>/dev/null | grep -v '^\.\.conf$')" ]; then
  for entry in $(ls -A /etc/wptt/vhost | grep -v '^\.\.conf$' | sort -uV); do
    NAME=$(echo "$entry" | sed 's/^.//' | sed 's/.conf//')

    # Bỏ qua nếu là chuỗi rỗng hoặc chỉ có dấu chấm
    if [ "$NAME" != "${NAME/./}" ] && [ "$NAME" != '.' ]; then

      # ========================================================================
      # RÀO CHẮN BẢO VỆ CLOUDFLARE (CỰC KỲ QUAN TRỌNG)
      # ========================================================================
      TRACE_OUTPUT=$(curl -Is --connect-timeout 5 --max-time 10 "https://$NAME/cdn-cgi/trace" 2>/dev/null)
      if echo "$TRACE_OUTPUT" | grep -qi 'cloudflare\|cf-ray'; then
        if ! grep -q 'allow.*103.21.244.0' /usr/local/lsws/conf/httpd_config.conf 2>/dev/null; then
          _runloi "Phát hiện Website đang sử dụng Cloudflare nhưng chưa cấu hình Real IP!"

          echo -e "\n${C_RED}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
          center_text "${C_BOLD_WHITE}LỖI: CHƯA BẬT [HIỆN THỊ IP THẬT CLOUDFLARE]${C_RESET}"
          echo -e "${C_RED}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
          left_text "Website ${C_YELLOW}$NAME${C_RESET} đang được proxy qua Cloudflare CDN." 2
          left_text "Tuy nhiên, máy chủ chưa được cấu hình để nhận diện IP thật." 2
          left_text "Điều này sẽ khiến Fail2Ban chặn nhầm IP của Cloudflare và" 2
          left_text "làm SẬP toàn bộ website của bạn!" 2
          echo -e "${C_RED}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
          left_text "CÁCH XỬ LÝ: Thoát ra ngoài, vào ${C_YELLOW}Menu Add-ons (35) ➜ Chọn số (8)${C_RESET}" 2
          left_text "để bật tính năng Hiện thị IP thật bypass Cloudflare trước nhé." 2
          echo -e "${C_RED}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

          sleep 4
          [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-bao-mat-main 1
          exit 1
        fi
      fi

      # Cấu hình Access Log cho LiteSpeed nếu chưa có
      if ! grep -q 'accesslog' /usr/local/lsws/conf/vhosts/"$NAME"/"$NAME".conf 2>/dev/null; then
        sed -i -e '/^errorlog /,/^}$/d' /usr/local/lsws/conf/vhosts/"$NAME"/"$NAME".conf
        sed -i -e '/^accesslog /,/^}$/d' /usr/local/lsws/conf/vhosts/"$NAME"/"$NAME".conf
        echo '
errorlog $VH_ROOT/logs/error.log {
  useServer               1
  logLevel                ERROR
  rollingSize             10M
}
accesslog $VH_ROOT/logs/access.log {
  useServer               0
  rollingSize             10M
  keepDays                30
  compressArchive         1
}' >>/usr/local/lsws/conf/vhosts/"$NAME"/"$NAME".conf

        mkdir -p /usr/local/lsws/"$NAME"/logs
        tuong_thich_nhom_litespeed="nobody"
        grep -qi "Ubuntu" /etc/*release && tuong_thich_nhom_litespeed="nogroup"

        chown -R nobody:$tuong_thich_nhom_litespeed /usr/local/lsws/"$NAME"/logs
        chmod 700 /usr/local/lsws/"$NAME"/logs
        /usr/local/lsws/bin/lswsctrl restart >/dev/null 2>&1
      fi
    fi
  done
fi
_rundone "Cấu hình Log cho các Website hoàn tất"

_runing "Đang kết nối Tường lửa và bơm luật (Rules) Fail2Ban..."
rule_fail2ban_name="ddos-404-wptt"

if [[ -f /etc/csf/csf.conf ]]; then
  action_thuc_thi_block="iptables-multiport[actname=block-tcp, name=$rule_fail2ban_name-t, port=\"80,443\", protocol=\"tcp\"]\n           iptables-multiport[actname=block-udp, name=$rule_fail2ban_name-u, port=\"80,443\", protocol=\"udp\"]"
elif [[ $(systemctl status nftables.service 2>/dev/null | grep 'Active' | awk '{print $2}') == "active" ]]; then
  action_thuc_thi_block="nftables-allports[name=$rule_fail2ban_name]"
elif [[ $(systemctl status firewalld.service 2>/dev/null | grep 'Active' | awk '{print $2}') == "active" ]]; then
  action_thuc_thi_block="firewallcmd-ipset[actname=block-tcp, name=$rule_fail2ban_name-t, port=\"80,443\", protocol=\"tcp\"]\n           firewallcmd-ipset[actname=block-udp, name=$rule_fail2ban_name-u, port=\"80,443\", protocol=\"udp\"]"
else
  _runloi "Không tìm thấy Tường lửa!"
  echo -e "\n${C_RED}Lỗi: Hệ thống không xác định được Tường lửa nào đang chạy (CSF/Nftables/Firewalld).${C_RESET}"
  sleep 3
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-bao-mat-main 1
  exit 1
fi

echo "
#begin-ddos-404-website
[wptangtoc-404]
enabled = true
action = $action_thuc_thi_block
filter = wptangtoc-404
logpath = /usr/local/lsws/*/logs/access.log
backend = pyinotify
maxretry = 5
bantime = 7200
findtime = 15
#end-ddos-404-website" >>/etc/fail2ban/jail.local

# Tối ưu lại biểu thức regex để hoạt động nhanh hơn, tránh back-tracking
echo '[Definition]
failregex = ^<HOST> .* "(GET|POST|HEAD) .* HTTP\/.*" 404 .*$
ignoreregex = \.(?i)(robots\.txt|favicon\.ico|jpg|png|webp|css|js|jpeg|woff2|avif|gif|svg)(\?.*)?$' >/etc/fail2ban/filter.d/wptangtoc-404.conf

fail2ban-client reload >/dev/null 2>&1 || systemctl restart fail2ban >/dev/null 2>&1
_rundone "Kích hoạt chặn DDoS 404 thành công!"

echo -e "\n${C_GREEN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_BOLD_WHITE}HOÀN TẤT THIẾT LẬP BẢO VỆ${C_RESET}"
echo -e "${C_GREEN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
left_text "Máy chủ đã được đặt trong trạng thái phòng thủ DDoS 404." 2
echo -e "${C_GREEN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

[[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-bao-mat-main 1
