#!/bin/bash

function huong_dan() {
  Tính năng Chống DDoS 404 trong WPTangToc OLS là một cơ chế phòng vệ giúp máy chủ OpenLiteSpeed của bạn đối phó với các cuộc tấn công từ chối dịch vụ phân tán [DDoS] ở mức độ đơn giản đến trung bình.

  Mã lỗi HTTP 404 là một mã trạng thái HTTP trang không tồn tại tiêu chuẩn mà máy chủ web gửi lại cho trình duyệt [hoặc client] khi máy chủ hiểu yêu cầu của bạn.

  Nói một cách đơn giản, máy chủ đang nói rằng: Tôi biết bạn muốn gì, nhưng bạn không có quyền truy cập vào tài nguyên đó.

  Bằng cách theo dõi các địa chỉ IP bị trả về lỗi 404 là trang động, html không phải là những file static như css, js, png, jpg, woff...
  Nếu trong vòng 15 giây mà IP đó yêu cầu và trả về 404 hơn tận 5 lần sẽ bị tạm khoá IP trong vòng 2 tiếng.
  [Bản nâng cấp Enterprise: Tích hợp Ipset tốc độ cao, nhận diện HTTP/3 UDP và tối ưu pyinotify]
}

echo ""
echo ""
echo ""
echo "========================================================================="
echo "|Bảo mật => Kích hoạt chống ddos 404                                    |"
echo "========================================================================="
echo ""
echo ""
echo ""

. /etc/wptt/echo-color
check=$(cat /etc/fail2ban/jail.local 2>/dev/null | grep '#begin-ddos-404-website')

if [[ $check = '' ]]; then
  echo "Xác nhận muốn kích hoạt chống ddos 404"
  prompt="Nhập lựa chọn của bạn [1-2]: "
  dongy="n"
  options=("Đồng ý" "Không đồng ý")
  PS3="$prompt"
  select opt in "${options[@]}"; do
    case "$REPLY" in
    1)
      dongy="y"
      break
      ;;

    2)
      dongy="n"
      break
      ;;

    $((${#options[@]} + 1)))
      printf "\nBạn nhập sai hệ thống sẽ chọn là không đồng ý\n"
      break
      ;;
    *)
      printf "Bạn nhập sai hệ thống sẽ chọn là không đồng ý\n"
      break
      ;;
    esac
  done

  if [[ $dongy = 'n' ]]; then
    exec /etc/wptt/wptt-bao-mat-main 1
  fi

  _runing "Kích hoạt chặn ddos 404"

  # =========================================================
  # AUTO-INSTALL DEPENDENCIES (IPSET & PYINOTIFY)
  # =========================================================
  if [ -f /etc/os-release ] && grep -qi "ubuntu" /etc/os-release; then
    dpkg -s python3-pyinotify ipset >/dev/null 2>&1 || {
      export DEBIAN_FRONTEND=noninteractive
      apt-get update >/dev/null 2>&1
      apt-get install -y python3-pyinotify ipset >/dev/null 2>&1
    }
  else
    rpm -q python3-inotify ipset >/dev/null 2>&1 || {
      dnf install -y python3-inotify ipset >/dev/null 2>&1
    }
  fi

  if [ "$(ls -At /etc/wptt/vhost)" ]; then
    selects=()
    for entry in $(ls -A /etc/wptt/vhost | grep -v '^\.\.conf$' | sort -uV); do
      NAME=$(echo $entry | sed 's/^.//' | sed 's/.conf//')
      if [ "$NAME" != "${NAME/./}" ] && [ "$NAME" != '.' ]; then #điều kiện domain phải có dấu . và lỗi chỉ có only .
        unset TRACE_OUTPUT
        TRACE_OUTPUT=$(curl -Is --connect-timeout 5 --max-time 10 "https://$NAME/cdn-cgi/trace" 2>/dev/null)
        # Kiểm tra output có chứa các key đặc trưng của Cloudflare không
        if echo "$TRACE_OUTPUT" | grep -qi 'cloudflare\|cf-ray'; then #check xem có đang sử dụng cloudflare cdn không
          if [[ $(cat /usr/local/lsws/conf/httpd_config.conf | grep 'allow' | grep '103.21.244.0') = '' ]]; then
            _runloi "Kích hoạt chặn ddos 404"
            echo "Phát hiện website $NAME đang sử dụng Cloudflare CDN"
            echo "Vui lòng phải kích hoạt sử dụng tính năng Hiện thị IP Log Real bypass Cloudflare CDN (MENU add ons 35=>8)"
            echo "Thì mới có thể sử dụng được tính năng này để tránh bị chặn nhầm"
            check_menu_wptangtoc_active=$1
            if [[ $check_menu_wptangtoc_active = "98" ]]; then
              exec /etc/wptt/wptt-bao-mat-main 1
            fi
            return 2>/dev/null
            exit
          fi
        fi

        if [[ ! $(cat /usr/local/lsws/conf/vhosts/"$NAME"/"$NAME".conf | grep 'accesslog') ]]; then
          sed -i -e '/^errorlog /,/^}$/d' /usr/local/lsws/conf/vhosts/"$NAME"/"$NAME".conf
          sed -i -e '/^accesslog /,/^}$/d' /usr/local/lsws/conf/vhosts/"$NAME"/"$NAME".conf
          echo '
errorlog $VH_ROOT/logs/error.log {
  useServer               1
  logLevel                ERROR
  rollingSize             10M
}

accesslog $VH_ROOT/logs/access.log {
  useServer               0
  rollingSize             10M
  keepDays                30
  compressArchive         1
}' >>/usr/local/lsws/conf/vhosts/"$NAME"/"$NAME".conf
          mkdir -p /usr/local/lsws/"$NAME"/logs
          #tuong thich ubuntu tuong thich nhom litespeed
          if $(cat /etc/*release | grep -q "Ubuntu"); then
            tuong_thich_nhom_litespeed="nogroup"
          else
            tuong_thich_nhom_litespeed="nobody"
          fi

          chown -R nobody:$tuong_thich_nhom_litespeed /usr/local/lsws/"$NAME"/logs
          chmod 700 /usr/local/lsws/"$NAME"/logs
          /usr/local/lsws/bin/lswsctrl restart >/dev/null 2>&1
        fi
      fi
    done
  fi

  # =========================================================
  # TÍNH TOÁN BIẾN VÀ CẤU HÌNH FAIL2BAN ENTERPRISE
  # =========================================================
  rule_fail2ban_name="ddos-404-wptt"

  if [[ -f /etc/csf/csf.conf ]]; then
    action_thuc_thi_block="iptables-multiport[actname=block-tcp, name=$rule_fail2ban_name-t, port=\"80,443\", protocol=\"tcp\"]
           iptables-multiport[actname=block-udp, name=$rule_fail2ban_name-u, port=\"80,443\", protocol=\"udp\"]"
  elif [[ $(systemctl status nftables.service 2>/dev/null | grep 'Active' | cut -f2 -d':' | xargs | cut -f1 -d' ' | xargs) = "active" ]]; then
    action_thuc_thi_block="nftables-allports[name=$rule_fail2ban_name]"
  elif [[ $(systemctl status firewalld.service 2>/dev/null | grep 'Active' | cut -f2 -d':' | xargs | cut -f1 -d' ' | xargs) = "active" ]]; then
    action_thuc_thi_block="firewallcmd-ipset[actname=block-tcp, name=$rule_fail2ban_name-t, port=\"80,443\", protocol=\"tcp\"]
           firewallcmd-ipset[actname=block-udp, name=$rule_fail2ban_name-u, port=\"80,443\", protocol=\"udp\"]"
  else
    echo "Hiện tại không support một tường lửa nào để sử dụng"
    check_menu_wptangtoc_active=$1
    if [[ $check_menu_wptangtoc_active = "98" ]]; then
      exec /etc/wptt/wptt-bao-mat-main 1
    fi
    return 2>/dev/null
    exit
  fi

  echo "
#begin-ddos-404-website
[wptangtoc-404]
enabled = true
action = $action_thuc_thi_block
filter = wptangtoc-404
logpath = /usr/local/lsws/*/logs/access.log
backend = pyinotify
maxretry = 5
bantime = 7200
findtime = 15
#end-ddos-404-website" >>/etc/fail2ban/jail.local

  # Tối ưu lại biểu thức regex để hoạt động nhanh hơn, tránh back-tracking
  echo '[Definition]
failregex = ^<HOST> .* "(GET|POST|HEAD) .* HTTP\/.*" 404 .*$
ignoreregex = \.(?i)(robots\.txt|favicon\.ico|jpg|png|webp|css|js|jpeg|woff2|avif|gif|svg)(\?.*)?$' >/etc/fail2ban/filter.d/wptangtoc-404.conf

  fail2ban-client reload >/dev/null 2>&1 || systemctl restart fail2ban >/dev/null 2>&1
  _rundone "Kích hoạt chặn ddos 404"
  echo "Nếu trong 15 giây mà yêu cầu 5 lần lỗi 404 thì IP sẽ bị khóa trong 2 tiếng"
fi

if [[ $check ]]; then
  echo "Bạn đang kích họat chống ddos 404"
  echo "Xác nhận muốn hủy kích hoạt chống ddos 404"
  prompt="Nhập lựa chọn của bạn [1-2]: "
  dongy="n"
  options=("Đồng ý" "Không đồng ý")
  PS3="$prompt"
  select opt in "${options[@]}"; do
    case "$REPLY" in
    1)
      dongy="y"
      break
      ;;

    2)
      dongy="n"
      break
      ;;

    $((${#options[@]} + 1)))
      printf "\nBạn nhập sai hệ thống sẽ chọn là không đồng ý\n"
      break
      ;;
    *)
      printf "Bạn nhập sai hệ thống sẽ chọn là không đồng ý\n"
      break
      ;;
    esac
  done

  if [[ $dongy = 'n' ]]; then
    exec /etc/wptt/wptt-bao-mat-main 1
  fi

  _runing "Hủy kích hoạt chống ddos 404"
  sed -i -e '/^#begin-ddos-404-website/,/^#end-ddos-404-website$/d' /etc/fail2ban/jail.local
  rm -f /etc/fail2ban/filter.d/wptangtoc-404.conf
  fail2ban-client reload >/dev/null 2>&1 || systemctl restart fail2ban >/dev/null 2>&1
  _rundone "Hủy kích hoạt chống ddos 404"
fi

check_menu_wptangtoc_active=$1
if [[ $check_menu_wptangtoc_active = "98" ]]; then
  exec /etc/wptt/wptt-bao-mat-main 1
fi
