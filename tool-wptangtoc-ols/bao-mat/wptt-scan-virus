#!/bin/bash
# WPTangToc OLS - Malware Scanner (Gia Tuấn)

function huong_dan() {
  Quét virus ClamAV là một công cụ quét virus mã nguồn mở, miễn phí và rất phổ biến trên các hệ điều hành Linux. Tính năng chính của nó là giúp phát hiện và loại bỏ các phần mềm độc hại như virus, trojans, worms, và các mối đe dọa khác.

  Giới thiệu ngắn gọn về tính năng quét virus của ClamAV trên Linux:

  * Phát hiện đa dạng mã độc: ClamAV sử dụng một cơ sở dữ liệu chữ ký virus [virus signatures] được cập nhật thường xuyên để nhận diện hàng triệu loại phần mềm độc hại khác nhau.
  * Quét theo yêu cầu: Bạn có thể sử dụng lệnh clamscan từ dòng lệnh để quét các tệp tin, thư mục cụ thể hoặc toàn bộ hệ thống theo cách thủ công bất cứ khi nào bạn muốn.
  * Quét tự động [Daemon]: ClamAV cung cấp clamd, một tiến trình nền [daemon] có thể thực hiện quét theo thời gian thực [on-access scanning] đối với các tệp tin khi chúng được truy cập, hoặc tích hợp với các dịch vụ khác như máy chủ mail để quét email.
  * Cập nhật cơ sở dữ liệu tự động: Công cụ freshclam giúp tự động tải về các bản cập nhật chữ ký virus mới nhất, đảm bảo khả năng phát hiện các mối đe dọa mới.
  * Linh hoạt và tích hợp: ClamAV có thể được tích hợp vào các ứng dụng khác, ví dụ như máy chủ email [để quét tệp đính kèm] hoặc máy chủ tập tin [để quét các tệp được tải lên/tải xuống].
  * Miễn phí và mã nguồn mở: Là một giải pháp không tốn chi phí bản quyền và được cộng đồng phát triển, kiểm tra liên tục.
  Mặc dù Linux ít bị ảnh hưởng bởi virus truyền thống nhắm vào máy tính để bàn hơn Windows, ClamAV vẫn đóng vai trò quan trọng trong việc bảo vệ máy chủ Linux khỏi việc lưu trữ hoặc phát tán mã độc sang các hệ thống khác [ví dụ: trong vai trò máy chủ mail hoặc file server], cũng như phát hiện các rootkit hoặc mã độc nhắm vào chính Linux.
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null # Nạp thư viện UX Bo Cong

clear
echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}BẢO MẬT ➜ Quét & Diệt Mã Độc (ClamAV & Maldetect)${C_RESET}"
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

if grep -qi "ubuntu" /etc/os-release 2>/dev/null; then
  OS_TYPE="debian"
else
  OS_TYPE="rhel"
fi

IS_INSTALLED=0
if [[ "$OS_TYPE" == "rhel" && -f "/etc/clamd.d/scan.conf" ]]; then IS_INSTALLED=1; fi
if [[ "$OS_TYPE" == "debian" && -f "/etc/clamav/clamd.conf" ]]; then IS_INSTALLED=1; fi

if [[ $IS_INSTALLED -eq 0 ]] || [[ ! -f "/usr/local/maldetect/conf.maldet" ]]; then
  _runing "Lần đầu sử dụng: Đang tiến hành cài đặt ClamAV Engine & Maldetect..."

  # --- A. CÀI ĐẶT GÓI MÃ NGUỒN ---
  if [[ "$OS_TYPE" == "rhel" ]]; then
    yum install epel-release -y -q >/dev/null 2>&1
    yum install clamav-server clamav-update clamav-filesystem clamav clamav-scanner-systemd clamav-devel clamav-lib clamav-server-systemd -y -q >/dev/null 2>&1

    CLAM_CONF="/etc/clamd.d/scan.conf"
    FRESH_CONF="/etc/freshclam.conf"

    if [[ -f "$CLAM_CONF" ]]; then
      sed -i 's/^Example/#Example/' "$CLAM_CONF"
      sed -i 's/#LocalSocket /LocalSocket /' "$CLAM_CONF"
    fi
    [[ -f "$FRESH_CONF" ]] && sed -i 's/^Example/#Example/' "$FRESH_CONF"

  elif [[ "$OS_TYPE" == "debian" ]]; then
    export DEBIAN_FRONTEND=noninteractive
    apt-get update -y -q >/dev/null 2>&1
    apt-get install clamav clamav-daemon libclamav-dev -y -q >/dev/null 2>&1

    CLAM_CONF="/etc/clamav/clamd.conf"
    FRESH_CONF="/etc/clamav/freshclam.conf"
    systemctl stop clamav-freshclam 2>/dev/null
  fi

  # --- B. THÊM DATABASE CHUYÊN DỤNG (Malware Expert) ---
  if [[ -f "$FRESH_CONF" ]] && ! grep -q "malware.expert" "$FRESH_CONF"; then
    {
      echo "DatabaseCustomURL http://cdn.malware.expert/malware.expert.ndb"
      echo "DatabaseCustomURL http://cdn.malware.expert/malware.expert.hdb"
      echo "DatabaseCustomURL http://cdn.malware.expert/malware.expert.ldb"
      echo "DatabaseCustomURL http://cdn.malware.expert/malware.expert.fp"
    } >>"$FRESH_CONF"
  fi

  # --- C. CÀI ĐẶT MALDETECT (TỪ MÃ NGUỒN) ---
  if [ ! -d "/usr/local/maldetect" ]; then
    cd /usr/src || exit
    wget -q http://www.rfxn.com/downloads/maldetect-current.tar.gz
    tar -xzf maldetect-current.tar.gz
    maldet_folder=$(ls | grep "maldetect-" | head -1)
    cd "$maldet_folder" && bash install.sh >/dev/null 2>&1
    cd /usr/src && rm -rf maldetect-current.tar.gz "$maldet_folder"
  fi

  # --- D. LIÊN KẾT MALDET VÀ CLAMAV ---
  conf_maldet="/usr/local/maldetect/conf.maldet"
  if [[ -f "$conf_maldet" ]] && ! grep -q "clam_av=1" "$conf_maldet"; then
    sed -i 's/quar_hits=0/quar_hits=1/' "$conf_maldet"
    sed -i 's/quar_clean=0/quar_clean=1/' "$conf_maldet"
    sed -i 's/clam_av=0/clam_av=1/' "$conf_maldet"
    [[ "$OS_TYPE" == "debian" ]] && sed -i 's/scan_ignore_root=1/scan_ignore_root=0/' "$conf_maldet"
  fi

  _rundone "Cài đặt nền tảng Quét Virus hoàn tất"
  sleep 1
fi

# ==============================================================================
# PHẦN 3: LỰA CHỌN WEBSITE ĐỂ QUÉT
# ==============================================================================
NAME=$1
[[ "$NAME" == "98" ]] && NAME=""

if [[ -z "$NAME" ]]; then
  if [[ -f "/etc/wptt/tenmien-them-lua-chon-tat-ca-website" ]]; then
    . /etc/wptt/tenmien-them-lua-chon-tat-ca-website
    lua_chon_NAME "kiểm tra mã độc (scan virus)"
  else
    echo -e "${C_RED}❌ Lỗi: Không tìm thấy thư viện chọn tên miền.${C_RESET}"
    exit 1
  fi
fi

# --- XỬ LÝ NHÁNH: QUÉT TẤT CẢ WEBSITE ---
if [[ "$NAME" == 'Tất cả website' ]]; then
  echo -e "\n${C_YELLOW}ĐANG KÍCH HOẠT QUÉT DIỆN RỘNG TOÀN BỘ WEBSITE...${C_RESET}\n"
  for entry in $(ls -A /etc/wptt/vhost 2>/dev/null | grep -v '^\.\.conf$' | sort -uV); do
    domain=$(echo "$entry" | sed 's/^\.//' | sed 's/\.conf$//')
    path_html="/usr/local/lsws/$domain/html"
    if [[ -d "$path_html" ]]; then
      $0 "$domain" # Gọi đệ quy lại chính script này
    fi
  done

  check_menu_wptangtoc_active=$1
  [[ "$check_menu_wptangtoc_active" == "98" ]] && exec /etc/wptt/wptt-bao-mat-main 1
  exit 0
fi

# --- KIỂM TRA ĐẦU VÀO ---
if [[ "$NAME" == "0" || -z "$NAME" ]]; then
  [[ -f "/etc/wptt/wptt-bao-mat-main" ]] && exec /etc/wptt/wptt-bao-mat-main 1
  exit 0
fi

if [[ ! -f "/etc/wptt/vhost/.$NAME.conf" ]]; then
  echo -e "\n${C_RED}❌ Lỗi: Không tìm thấy cấu hình cho website $NAME${C_RESET}"
  sleep 2
  [[ -f "/etc/wptt/wptt-bao-mat-main" ]] && exec /etc/wptt/wptt-bao-mat-main 1
  exit 0
fi

# ==============================================================================
# PHẦN 4: CẬP NHẬT DATABASE (SAFE UPDATE)
# ==============================================================================
_runing "Đang đồng bộ cơ sở dữ liệu Virus (Signatures) mới nhất..."

systemctl stop clamav-freshclam >/dev/null 2>&1
# Dùng timeout để tránh bị treo vĩnh viễn nếu máy chủ CDN của ClamAV bị lỗi
timeout 120 freshclam >/dev/null 2>&1
systemctl start clamav-freshclam >/dev/null 2>&1 # FIX BUG CŨ: Phải start lại

_rundone "Cập nhật dữ liệu Virus thành công"

# ==============================================================================
# PHẦN 5: THỰC THI QUÉT (SAFE MODE + SPINNER UX)
# ==============================================================================
PATH_SCAN="/usr/local/lsws/$NAME/html"
DIR_SIZE=$(du -sh "$PATH_SCAN" 2>/dev/null | cut -f1)

echo -e "\n${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
left_text "  Tiến trình : ${C_BOLD_WHITE}Đang quét Website $NAME${C_RESET}" 2
left_text "  Dung lượng : ${C_YELLOW}$DIR_SIZE${C_RESET}" 2
left_text "  Đường dẫn  : ${C_CYAN}$PATH_SCAN${C_RESET}" 2
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯${C_RESET}"

TEMP_OUT=$(mktemp)

# TRAP: Bắt tín hiệu Ctrl+C để dọn dẹp sạch sẽ
cleanup_process() {
  echo -e "\n\n${C_RED}NHẬN TÍN HIỆU HỦY! Đang dừng tiến trình quét...${C_RESET}"
  [[ -n "$MALDET_PID" ]] && kill -9 "$MALDET_PID" 2>/dev/null
  rm -f "$TEMP_OUT"
  tput cnorm # Hiện lại con trỏ chuột
  exit 1
}
trap cleanup_process SIGINT SIGTERM

# Chạy ngầm Maldet với tối ưu hóa Tuyệt đối (nice: CPU thấp nhất, ionice: IO thấp nhất)
nice -n 19 ionice -c 3 maldet -a "$PATH_SCAN" >"$TEMP_OUT" 2>&1 &
MALDET_PID=$!

# Hiệu ứng Spinner quay siêu mượt
tput civis # Ẩn con trỏ chuột
spin='-\|/'
i=0
while kill -0 "$MALDET_PID" 2>/dev/null; do
  i=$(((i + 1) % 4))
  printf "\r  ${C_CYAN} Đang rà soát và bóc tách tệp tin... ${C_YELLOW}${spin:$i:1}${C_RESET} "
  sleep 0.15
done
printf "\r\033[K" # Xóa dòng spinner khi xong
tput cnorm        # Hiện lại con trỏ

trap - SIGINT SIGTERM
scan_output=$(cat "$TEMP_OUT")
rm -f "$TEMP_OUT"

SCAN_ID=$(echo "$scan_output" | grep "SCAN ID:" | awk -F': ' '{print $2}' | tr -d ' ')

if [[ -n "$SCAN_ID" ]]; then
  TOTAL_FILES=$(maldet --report "$SCAN_ID" | grep "TOTAL FILES:" | awk -F': ' '{print $2}' | tr -d ' ')
  TOTAL_HITS=$(maldet --report "$SCAN_ID" | grep "TOTAL HITS:" | awk -F': ' '{print $2}' | tr -d ' ')
  CLEANED=$(maldet --report "$SCAN_ID" | grep "CLEANED HITS:" | awk -F': ' '{print $2}' | tr -d ' ')
else
  TOTAL_FILES="N/A"
  TOTAL_HITS="0"
  CLEANED="0"
fi

if [[ "$TOTAL_HITS" == "0" || -z "$TOTAL_HITS" ]]; then
  echo -e "\n${C_GREEN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_BOLD_WHITE}WEBSITE AN TOÀN - KHÔNG PHÁT HIỆN MÃ ĐỘC${C_RESET}"
  echo -e "${C_GREEN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
  left_text "Số file đã quét : ${C_BOLD_WHITE}$TOTAL_FILES tệp tin${C_RESET}" 2
  left_text "Trạng thái      : ${C_GREEN}Sạch sẽ (Clean)${C_RESET}" 2
  echo -e "${C_GREEN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"
else
  echo -e "\n${C_RED}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_BOLD_WHITE}CẢNH BÁO: PHÁT HIỆN MÃ ĐỘC (MALWARE)${C_RESET}"
  echo -e "${C_RED}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
  left_text "Số file đã quét : ${C_BOLD_WHITE}$TOTAL_FILES tệp tin${C_RESET}" 2
  left_text "Tệp bị nhiễm    : ${C_RED}$TOTAL_HITS tệp${C_RESET}" 2
  left_text "Đã cách ly/xóa  : ${C_YELLOW}$CLEANED tệp${C_RESET}" 2
  echo -e "${C_RED}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
  left_text "Xem danh sách mã độc bị cách ly tại thư mục:" 2
  left_text "${C_CYAN}/usr/local/maldetect/quarantine/${C_RESET}" 2
  echo -e "${C_RED}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

  # In danh sách file bị nhiễm ra màn hình
  echo -e "${C_YELLOW}Chi tiết các file bị lây nhiễm:${C_RESET}"
  maldet --report "$SCAN_ID" | grep "FILE HIT" | sed 's/.*FILE HIT: //' | sed 's/^/ - /'
  echo ""
fi

check_menu_wptangtoc_active=$1
if [[ "$check_menu_wptangtoc_active" == "98" ]]; then
  exec /etc/wptt/wptt-bao-mat-main 1
fi
