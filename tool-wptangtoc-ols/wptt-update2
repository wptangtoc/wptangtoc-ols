#!/bin/bash
# @author: Gia Tuấn
# @website: https://wptangtoc.com
# @email: giatuan@wptangtoc.com
# @since: 2026

function huong_dan() {
  Tính năng Chuyển nhánh Beta hoặc Nhánh Chính thức trong WPTangToc OLS cho phép người dùng lựa chọn giữa việc sử dụng phiên bản ổn định [nhánh chính thức] hoặc phiên bản thử nghiệm mới nhất [nhánh beta] của bộ script wptangtoc ols.

  Giải thích ngắn gọn:
  Nhánh Chính thức [Stable/Main Branch]:
  * Đây là phiên bản đã được kiểm thử kỹ lưỡng, được coi là ổn định và đáng tin cậy nhất.
  * Khuyến nghị cho hầu hết người dùng, đặc biệt là cho các website quan trọng đang hoạt động [production environment].
  * Tập trung vào sự ổn định và các tính năng đã được chứng minh.

  Nhánh Beta [Beta Branch]:
  * Đây là phiên bản đang trong quá trình phát triển, chứa các tính năng mới nhất, các cải tiến hoặc bản vá lỗi thử nghiệm.
  * Người dùng có thể trải nghiệm sớm các cập nhật nhưng cũng có khả năng gặp lỗi hoặc hoạt động chưa ổn định.
  * Phù hợp cho người dùng có kinh nghiệm muốn thử nghiệm, đóng góp ý kiến và giúp tác giả phát hiện lỗi trước khi các thay đổi được đưa vào nhánh chính thức.

  Tóm lại, tính năng chuyển đổi nhánh trong WPTangToc OLS mang lại sự linh hoạt cho người dùng, cho phép họ lựa chọn giữa sự ổn định của phiên bản chính thức và sự mới mẻ của phiên bản beta, tùy theo nhu cầu và mức độ chấp nhận rủi ro.
}

unset khong_dau_vi_ngon_ngu wptangtocols_version ngon_ngu
. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null

PATH='/root/.local/bin:/root/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin'

nhanh_wptangtoc_ols=$1
[[ "$nhanh_wptangtoc_ols" == '999' ]] && nhanh_wptangtoc_ols=''

# ==============================================================================
# XÁC ĐỊNH NHÁNH VÀ HIỂN THỊ GIAO DIỆN
# ==============================================================================
clear
echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"

if [[ "$nhanh_wptangtoc_ols" == "chinhthuc" ]]; then
  target_branch="ỔN ĐỊNH (Stable/Main)"
  call_log="(chuyển đổi phiên bản ổn định)"
elif [[ "$nhanh_wptangtoc_ols" == "beta" ]]; then
  target_branch="THỬ NGHIỆM (Beta)"
  call_log="(chuyển đổi phiên bản beta)"
else
  # Cài lại nhánh hiện tại (Reinstall)
  if [[ "$beta_wptangtoc_ols" == '1' ]]; then
    target_branch="THỬ NGHIỆM (Beta) - Cài đặt lại"
    call_log="(Cài đặt lại phiên bản beta)"
  else
    target_branch="ỔN ĐỊNH (Stable/Main) - Cài đặt lại"
    call_log="(Cài đặt lại phiên bản ổn định)"
  fi
fi

center_text "${C_YELLOW}HỆ THỐNG ➜ Cài đặt lại / Chuyển nhánh WPTangToc OLS${C_RESET}"
echo -e "${C_CYAN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"

box_inner_width=${box_inner_width:-71}
info_text="Tiến hành cài đặt nhánh: $target_branch"
pad_info=$((box_inner_width - ${#info_text} - 2))
[[ $pad_info -lt 0 ]] && pad_info=0
echo -e "${C_CYAN}│${C_RESET}  ${C_BOLD_WHITE}Tiến hành cài đặt nhánh:${C_RESET} ${C_YELLOW}$target_branch${C_RESET}$(printf '%*s' "$pad_info" "")${C_CYAN}│${C_RESET}"

echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯${C_RESET}\n"

# ==============================================================================
# BẮT ĐẦU TẢI FILE VÀ CÀI ĐẶT
# ==============================================================================
# _runing "Đang tải mã nguồn và cài đặt hệ thống..."
_runing "WPTangToc OLS đang tiến hành cập nhật, vui lòng đợi..."

OLD_PWD=$(pwd)
TMP_DIR=$(mktemp -d)
cd "$TMP_DIR" || exit

# ------------------------------------------------------------------------------
# 1. TẢI FILE CORE THEO NHÁNH
# ------------------------------------------------------------------------------
if [[ "$nhanh_wptangtoc_ols" == "chinhthuc" || (-z "$nhanh_wptangtoc_ols" && "$beta_wptangtoc_ols" != '1') ]]; then
  sed -i "/beta_wptangtoc_ols/d" /etc/wptt/.wptt.conf 2>/dev/null

  wget -q --timeout=15 --tries=3 https://wptangtoc.com/share/wptangtoc-ols.zip

  # Xác thực Checksum
  checksum_wptangtoc_file=$(curl -sL --connect-timeout 60 --max-time 60 https://wptangtoc.com/share/checksum.txt)
  [[ -z "$checksum_wptangtoc_file" ]] && checksum_wptangtoc_file=$(curl -skL --connect-timeout 60 --max-time 60 http://wptangtoc.com/share/checksum.txt)

  mapfile -t checksum_array <<<"$checksum_wptangtoc_file"
  id_checksum="${checksum_array[0]}"

  [[ "$id_checksum" != $(md5sum wptangtoc-ols.zip 2>/dev/null | awk '{print $1}') ]] && rm -f wptangtoc-ols.zip

  if [[ ! -f wptangtoc-ols.zip ]]; then
    sleep 3
    wget -q --timeout=15 --tries=3 https://wptangtoc.com/share/wptangtoc-ols.zip --no-check-certificate
    [[ "$id_checksum" != $(md5sum wptangtoc-ols.zip 2>/dev/null | awk '{print $1}') ]] && rm -f wptangtoc-ols.zip
  fi

  # Dự phòng qua GitHub
  if [[ ! -f wptangtoc-ols.zip ]]; then
    wget -q --timeout=15 --tries=3 https://github.com/wptangtoc/wptangtoc-ols/raw/refs/heads/main/wptangtoc-ols.zip
    id_checksum=$(curl -sL --connect-timeout 60 --max-time 60 https://raw.githubusercontent.com/wptangtoc/wptangtoc-ols/refs/heads/main/checksum.txt | head -1)
    [[ "$id_checksum" != $(md5sum wptangtoc-ols.zip 2>/dev/null | awk '{print $1}') ]] && rm -f wptangtoc-ols.zip
  fi

elif [[ "$nhanh_wptangtoc_ols" == "beta" || (-z "$nhanh_wptangtoc_ols" && "$beta_wptangtoc_ols" == '1') ]]; then
  sed -i "/beta_wptangtoc_ols/d" /etc/wptt/.wptt.conf 2>/dev/null
  echo "beta_wptangtoc_ols=1" >>/etc/wptt/.wptt.conf
  [[ ! -f /tmp/beta-wptangtoc-check ]] && echo "" >/tmp/beta-wptangtoc-check

  wget -q --timeout=15 --tries=3 https://wptangtoc.com/share/wptangtoc-ols-beta.zip --no-check-certificate -O wptangtoc-ols.zip
fi

# Chốt chặn lỗi tải file
if [[ ! -f wptangtoc-ols.zip ]]; then
  _runloi "Tải mã nguồn thất bại! Đã hủy thao tác để đảm bảo an toàn."
  cd "$OLD_PWD" || cd /root
  rm -rf "$TMP_DIR"
  return 2>/dev/null || exit 1
fi

# ------------------------------------------------------------------------------
# 2. BACKUP ĐỂ ROLLBACK
# ------------------------------------------------------------------------------
mkdir -p /etc/wptt/wptt-backup-system
timedate=$(date +%Hgio_%d_%m_%Y)
BACKUP_FILE="/etc/wptt/wptt-backup-system/wptt_backup_${timedate}_version:$version_wptangtoc_ols.zip"

(cd /etc/wptt && zip -r -q "$BACKUP_FILE" . -x "wptt-backup-system/*" -x ".wptt.conf" -x ".ram_hien_tai" -x "vhost/*")
[[ -f "$BACKUP_FILE" ]] && zip -g -j -q "$BACKUP_FILE" /usr/bin/wptangtoc /usr/bin/wptt
ls -dt /etc/wptt/wptt-backup-system/*.zip 2>/dev/null | tail -n +11 | xargs -r rm -f

# ------------------------------------------------------------------------------
# 3. GIẢI NÉN VÀ CÀI ĐẶT
# ------------------------------------------------------------------------------
kiem_tra_ton_tai_nhom=$(cat /etc/group | grep '^wptangtoc-ols:')
unzip -oq wptangtoc-ols.zip

if ! \cp -rf tool-wptangtoc-ols/* /etc/wptt/ 2>/dev/null; then
  _runloi "Lỗi giải nén! Đang tự động khôi phục lại phiên bản cũ..."
  unzip -oq "$BACKUP_FILE" -d /etc/wptt/
  \cp -f /etc/wptt/wptangtoc /usr/bin
  rm -f /etc/wptt/wptangtoc
  \cp -f /etc/wptt/wptt /usr/bin
  rm -f /etc/wptt/wptt
  cd "$OLD_PWD" || cd /root
  rm -rf "$TMP_DIR"

  check_menu_wptangtoc_active=$2
  [[ "$check_menu_wptangtoc_active" == "98" ]] && exec /etc/wptt/wptt-update-main 1
  exec /etc/wptt/wptt-status2
  exit
fi

# FIX: Tách lệnh xóa file và thư mục riêng biệt
rm -f wptangtoc-ols.zip
rm -rf tool-wptangtoc-ols

chmod -R 700 /etc/wptt
if [[ -n "$kiem_tra_ton_tai_nhom" ]]; then
  chown root:wptangtoc-ols /etc/wptt /etc/wptt/vhost
  chmod 750 /etc/wptt /etc/wptt/vhost
else
  chown root:root /etc/wptt /etc/wptt/vhost
fi

\cp -f /etc/wptt/wptangtoc /usr/bin
rm -f /etc/wptt/wptangtoc
\cp -f /etc/wptt/wptt /usr/bin
rm -f /etc/wptt/wptt

# Chown thư mục Vhost
if [[ -n "$kiem_tra_ton_tai_nhom" ]]; then
  for entry in $(ls -A /etc/wptt/vhost | grep -v '^\.\.conf$' | sort -uV); do
    domain=$(echo $entry | sed 's/^.//' | sed 's/.conf//')
    path="/usr/local/lsws/$domain/html"
    if [[ -d "$path" && -f /etc/wptt/vhost/.$domain.conf ]]; then
      . /etc/wptt/vhost/.$domain.conf
      if [[ -n $(cat /etc/group | grep '^wptangtoc-ols:' | grep "$User_name_vhost") ]]; then
        chown $User_name_vhost:$User_name_vhost /etc/wptt/vhost/.$domain.conf
      fi
    fi
  done
fi

# Tải gói User
if [[ "$beta_wptangtoc_ols" == '1' || "$nhanh_wptangtoc_ols" == "beta" ]]; then
  wget -q --timeout=15 --tries=3 https://wptangtoc.com/share/wptangtoc-ols-user-beta.zip -O wptangtoc-ols-user.zip
else
  wget -q --timeout=15 --tries=3 https://wptangtoc.com/share/wptangtoc-ols-user.zip
fi

unzip -qo wptangtoc-ols-user.zip
\cp -rf tool-wptangtoc-ols-user/* /etc/wptt-user

# FIX: Tách lệnh xóa file và thư mục riêng biệt
rm -f wptangtoc-ols-user.zip
rm -rf tool-wptangtoc-ols-user

[[ -d /etc/wptt-child ]] && \cp -rf /etc/wptt-child/* /etc/wptt

if [[ -n "$kiem_tra_ton_tai_nhom" ]]; then
  chown -R root:wptangtoc-ols /etc/wptt-user
  chmod -R 750 /etc/wptt-user
  \cp -f /etc/wptt-user/wptangtoc-user /usr/bin
  chown root:wptangtoc-ols /usr/bin/wptangtoc-user
  chmod 750 /usr/bin/wptangtoc-user
else
  chown -R root:root /etc/wptt-user
  chmod -R 700 /etc/wptt-user
  \cp -f /etc/wptt-user/wptangtoc-user /usr/bin
  chown root:root /usr/bin/wptangtoc-user
  chmod 700 /usr/bin/wptangtoc-user
fi

# ------------------------------------------------------------------------------
# 4. THIẾT LẬP VERSION VÀ KEY PREMIUM
# ------------------------------------------------------------------------------
if [[ "$beta_wptangtoc_ols" == '1' || "$nhanh_wptangtoc_ols" == "beta" ]]; then
  wptangtocols_version=$(curl -sL --connect-timeout 60 --max-time 60 https://wptangtoc.com/share/version-wptangtoc-ols.txt?wptt-update-2-version-beta)
else
  wptangtocols_version=$(curl -sL --connect-timeout 60 --max-time 60 https://wptangtoc.com/share/version-wptangtoc-ols.txt?wptt-update-2)
fi

[[ -z "$wptangtocols_version" ]] && wptangtocols_version=$(curl -sL --connect-timeout 60 --max-time 60 https://raw.githubusercontent.com/wptangtoc/wptangtoc-ols/refs/heads/main/version-wptangtoc-ols.txt)

if [[ -n "$key_activate" ]]; then
  wget -q --timeout=15 --tries=3 "https://key.wptangtoc.com/?${key_activate}" -U "Activate key WPTangToc OLS" -O premium.zip
  [[ ! -s premium.zip ]] && wget -q --timeout=15 --tries=3 "https://key.wptangtoc.com/?${key_activate}" --no-check-certificate -U "Activate key WPTangToc OLS" -O premium.zip

  if [[ -s premium.zip ]]; then
    unzip -oq premium.zip -d /etc/wptt/add-one
    rm -f premium.zip
    chmod -R 700 /etc/wptt/add-one
  fi
fi

sed -i "/version_wptangtoc_ols/d" /etc/wptt/.wptt.conf
echo "version_wptangtoc_ols=$wptangtocols_version" >>/etc/wptt/.wptt.conf
echo "$wptangtocols_version" >/tmp/wptangtoc-ols-version
echo "$version_wptangtoc_ols" >/tmp/wptangtoc-ols-version-main

# Khử ngôn ngữ
if [[ "$khong_dau_vi_ngon_ngu" == '1' ]]; then
  find /etc/wptt -type f ! -path '/etc/wptt/lang/wptt-set-lang-vi' ! -path '/etc/wptt/wptt-update2' ! -path '/etc/wptt/wptt-update' ! -name '.*' -exec sed -i 'y/áàảãạăắằẳẵặâấầẩẫậđéèẻẽẹêếềểễệíìỉĩịóòỏõọôốồổỗộơớờởỡợúùủũụưứừửữựýỳỷỹỵÁÀẢÃẠĂẮẰẲẴẶÂẤẦẨẪẬĐÉÈẺẼẸÊẾỀỂỄỆÍÌỈĨỊÓÒỎÕỌÔỐỒỔỖỘƠỚỜỞỠỢÚÙỦŨỤƯỨỪỬỮỰÝỲỶỸỴ/aaaaaaaaaaaaaaaaadeeeeeeeeeeeiiiiiooooooooooooooooouuuuuuuuuuuyyyyyAAAAAAAAAAAAAAAAADEEEEEEEEEEEIIIIIOOOOOOOOOOOOOOOOOUUUUUUUUUUUYYYYY/' {} +
  [[ -n "$kiem_tra_ton_tai_nhom" ]] && find /etc/wptt-user -type f -exec sed -i 'y/áàảãạăắằẳẵặâấầẩẫậđéèẻẽẹêếềểễệíìỉĩịóòỏõọôốồổỗộơớờởỡợúùủũụưứừửữựýỳỷỹỵÁÀẢÃẠĂẮẰẲẴẶÂẤẦẨẪẬĐÉÈẺẼẸÊẾỀỂỄỆÍÌỈĨỊÓÒỎÕỌÔỐỒỔỖỘƠỚỜỞỠỢÚÙỦŨỤƯỨỪỬỮỰÝỲỶỸỴ/aaaaaaaaaaaaaaaaadeeeeeeeeeeeiiiiiooooooooooooooooouuuuuuuuuuuyyyyyAAAAAAAAAAAAAAAAADEEEEEEEEEEEIIIIIOOOOOOOOOOOOOOOOOUUUUUUUUUUUYYYYY/' {} +
fi

# Dọn dẹp tmp
cd "$OLD_PWD" || cd /root
rm -rf "$TMP_DIR"

# FIX: Xóa mã màu C_YELLOW trong _rundone
_rundone "WPTangToc OLS cập nhật lên bản $wptangtocols_version"
echo "Cài đặt WPTangToc OLS $wptangtocols_version $call_log: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log

# ==============================================================================
# 5. KẾT THÚC VÀ ĐIỀU HƯỚNG
# ==============================================================================
check_menu_wptangtoc_active=$2
if [[ "$check_menu_wptangtoc_active" == "98" ]]; then
  exec /etc/wptt/wptt-update-main 1
fi

if [[ "$1" == '999' ]]; then
  exec /etc/wptt/wptt-status2
fi
