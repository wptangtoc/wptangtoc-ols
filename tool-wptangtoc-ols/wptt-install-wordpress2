#!/bin/bash
function huong_dan() {
  Tính năng cài đặt mã nguồn WordPress, thì đây là một chức năng tự động hóa mạnh mẽ, giúp bạn triển khai một website WordPress hoàn toàn mới lên máy chủ một cách nhanh chóng và dễ dàng.

  Tính năng Cài đặt Mã nguồn WordPress [WPTangToc OLS]
  🚀 Mục đích chính:
  * Tiết kiệm Thời gian &
  Công sức: Thay vì phải thực hiện hàng loạt bước thủ công [tạo database, tải WordPress, cấu hình wp-config.php, chạy cài đặt], tính năng này sẽ làm tất cả chỉ bằng một vài thao tác hoặc một lệnh.
  * Chuẩn hóa Cài đặt: Đảm bảo các website mới được cài đặt theo một cấu trúc và cấu hình chuẩn, có thể đã được tối ưu sẵn cho môi trường OpenLiteSpeed và các tính năng khác của WPTangToc OLS.
  * Giảm thiểu Lỗi: Tự động hóa giúp hạn chế tối đa các sai sót có thể xảy ra khi thực hiện thủ công.
  * Thân thiện với Người dùng: Giúp cả những người không quá rành về kỹ thuật cũng có thể dễ dàng tạo một website WordPress mới.

  ✅ Lợi ích:
  * Triển khai Nhanh: Tạo website mới chỉ trong vài phút.
  * Dễ dàng &
  Tiện lợi: Quy trình đơn giản hóa.
  * Tối ưu Sẵn: Website mới có khả năng được cài đặt với các thiết lập tối ưu cho OLS.
  Tóm lại: Tính năng cài đặt mã nguồn WordPress trong WPTangToc OLS là một công cụ tự động hóa giúp đơn giản hóa và tăng tốc quá trình tạo một website WordPress mới trên máy chủ OpenLiteSpeed, đồng thời đảm bảo website được thiết lập theo các tiêu chuẩn có thể đã được tối ưu hóa bởi bộ công cụ này.
}


export LANG=en_US.UTF-8
export LC_ALL=en_US.UTF-8
stty iutf8 2>/dev/null

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null

if [[ "$1" == '99' ]]; then
  WPTT_IN_MENU="yes"
  WPTT_MENU_BACK="/usr/bin/wptangtoc 1"
fi

if [[ "$1" == '98' ]]; then
  WPTT_IN_MENU="yes"
  WPTT_MENU_BACK="/etc/wptt/wptt-wordpress-main 1"
fi

# ==============================================================================
# 1. KHỞI TẠO VÀ CHỌN DOMAIN
# ==============================================================================
clear
echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}CÀI ĐẶT MỚI MÃ NGUỒN WORDPRESS${C_RESET}"
echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

wptt_check_mariadb || wptt_die "MariaDB đang bị sập! Hệ thống từ chối cài đặt WordPress cho website."

. /etc/wptt/tenmien
lua_chon_NAME "$thiet_lap WordPress"
domain="$NAME"

if [[ "$NAME" == "0" || -z "$NAME" ]]; then
  [[ ${1:-} == "98" ]] && exec /etc/wptt/wptt-wordpress-main 1
  [[ ${1:-} == "99" ]] && exec /usr/bin/wptangtoc 1
  return 2>/dev/null || exit
fi

pathcheck="/etc/wptt/vhost/.$NAME.conf"
if [[ ! -f "$pathcheck" ]]; then
  echo -e "\n${C_RED}❌ Tên miền không tồn tại trên hệ thống này!${C_RESET}"
  sleep 3
  exec /usr/bin/wptangtoc 1
  exit
fi

. "$pathcheck"
. /etc/wptt/.wptt.conf

# ==============================================================================
# 1.5. TRẠM KIỂM LÂM: PHÁT HIỆN DATABASE "MA" (BỊ XÓA LÉN)
# ==============================================================================
if [[ -n "$DB_Name_web" || -n $DB_User_web ]]; then
  TEMP_CNF_CHK=$(mktemp)
  chmod 600 "$TEMP_CNF_CHK"
  cat >"$TEMP_CNF_CHK" <<EOF
[client]
user=${database_admin_username}
password=${database_admin_password}
host=localhost
EOF

  # Truy vấn MariaDB xem DB và User có còn tồn tại thật không

if [[ -n $DB_Name_web ]];then
  db_exists=$(mariadb --defaults-extra-file="$TEMP_CNF_CHK" -sse "SELECT EXISTS(SELECT 1 FROM information_schema.schemata WHERE schema_name = '$DB_Name_web');")
else
	db_exists='0'
fi

if [[ -n $DB_User_web ]];then
  user_exists=$(mariadb --defaults-extra-file="$TEMP_CNF_CHK" -sse "SELECT EXISTS(SELECT 1 FROM mysql.user WHERE user = '$DB_User_web');")
else
	user_exists='0'
fi

  rm -f "$TEMP_CNF_CHK"

  if [[ "$db_exists" == "0" || "$user_exists" == "0" ]]; then
    echo -e "\n${C_RED}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
    center_text "${C_BOLD_WHITE}CẢNH BÁO: LỖI ĐỒNG BỘ DATABASE BIÊN CHẾ${C_RESET}" "$C_RED"
    echo -e "${C_RED}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
    left_text "${C_YELLOW}Hệ thống phát hiện thông tin Database biên chế trong file cấu hình${C_RESET}"
    left_text "${C_YELLOW}không khớp với thực tế trên MariaDB (bị xóa thủ công hoặc nhầm lẫn).${C_RESET}"
    echo -e "${C_RED}│${C_RESET}                                                                              ${C_RED}│${C_RESET}"
    
    [[ "$db_exists" == "0" ]] && st_db="${C_RED}[ĐÃ BỊ XÓA]${C_RESET}" || st_db="${C_GREEN}[OK]${C_RESET}"
    [[ "$user_exists" == "0" ]] && st_user="${C_RED}[ĐÃ BỊ XÓA]${C_RESET}" || st_user="${C_GREEN}[OK]${C_RESET}"
    
    left_text "Tên Database      : ${C_BOLD_WHITE}$DB_Name_web${C_RESET} $st_db"
    left_text "User Database     : ${C_BOLD_WHITE}$DB_User_web${C_RESET} $st_user"
    
    echo -e "${C_RED}│${C_RESET}                                                                              ${C_RED}│${C_RESET}"
    left_text "${C_GREEN}Hướng giải quyết:${C_RESET}"
    left_text "1. Vui lòng quay lại Menu: Quản lý Database ➜ Thêm Database mới."
    left_text "2. Hệ thống sẽ tự động cập nhật lại biên chế mới cho website này."
    echo -e "${C_RED}╰──────────────────────────────────────────────────────────────────────────────╯${C_RESET}\n"
    
    echo -en "${C_GREEN}➜ Nhấn [Enter] để quay lại Menu...${C_RESET}"
    read -r dummy
    [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-wordpress-main 1
    exec /usr/bin/wptangtoc 1
    exit 1
  fi
fi

# ==============================================================================
# 2. XÁC NHẬN CÀI ĐẶT
# ==============================================================================
msg_title="Xác nhận thiết lập WordPress mới cho domain: $domain"
if [[ -f "/usr/local/lsws/$NAME/html/wp-load.php" ]]; then
  msg_info1="${C_RED}CẢNH BÁO: Thao tác này sẽ XÓA SẠCH toàn bộ mã nguồn WP hiện tại!${C_RESET}"
else
  msg_info1="${C_BOLD_WHITE}Lưu ý:${C_RESET} Mọi dữ liệu cũ trong thư mục html sẽ bị xóa sạch."
fi

if ! wptt_xac_nhan "$msg_title" "$msg_info1" "" "Đồng ý (Bắt đầu cài đặt)" "Không đồng ý (Hủy thao tác)"; then
  echo -e "${C_YELLOW}Đã hủy thao tác cài đặt.${C_RESET}"
  sleep 1.5
  [[ ${1:-} == "98" ]] && exec /etc/wptt/wptt-wordpress-main 1
  [[ ${1:-} == "99" ]] && exec /usr/bin/wptangtoc 1
  exit
fi

echo "Install mã nguồn Wordpress website $NAME : $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log

# ==============================================================================
# 3. LÀM SẠCH VÀ CHUẨN BỊ
# ==============================================================================
echo ""
if [[ -n "$lock_down" ]]; then
  _runing "$tat lock down website $NAME"
  . /etc/wptt/bao-mat/wptt-chattr-file-lock $NAME off
  sed -i '/lock_down/d' "/etc/wptt/vhost/.$NAME.conf"
  _rundone "$tat lock down website $NAME"
fi

_runing "$lam_sach_toan_bo_du_lieu_ma_nguon_cua $NAME"
if ! wptt_kha_dung_de_xoa_xac_thuc "$NAME"; then
  echo -e "\n${C_RED}Lỗi: Domain rỗng. Hủy bỏ lệnh xóa an toàn!${C_RESET}"
  [[ ${1:-} == "98" ]] && exec /usr/bin/wptangtoc 1
  return 2>/dev/null || exit 1
fi

cd "/usr/local/lsws/$NAME/html/" || exit 1
rm -rf ./*
[[ -d "/usr/local/lsws/$NAME/luucache" ]] && rm -rf "/usr/local/lsws/$NAME/luucache"

vhost_conf="/usr/local/lsws/conf/vhosts/$NAME/$NAME.conf"
if [[ "$Website_chinh" == "$NAME" && -f "$vhost_conf" && -n $id_dang_nhap_phpmyadmin ]] && grep -qiE "realm.*phpmyadmin|context /phpmyadmin" "$vhost_conf"; then
  rm -f "/usr/local/lsws/$Website_chinh/passwd/.phpmyadmin"
  sed -i "/id_dang_nhap_phpmyadmin/d" /etc/wptt/.wptt.conf
  sed -i "/password_dang_nhap_phpmyadmin/d" /etc/wptt/.wptt.conf
  sed -i -e "/^realm ${Website_chinh}phpmyadmin/,/^}/d" "$vhost_conf" 2>/dev/null
  sed -i -e "/^context \/phpmyadmin\//,/^}/d" "$vhost_conf" 2>/dev/null
  sed -i -e '/^realm '${Website_chinh}phpphpmyadmin'/,/^}$/d' "$vhost_conf" 2>/dev/null
fi

if [[ -f "$vhost_conf" && -n $id_dang_nhap_quan_ly_file_cap_2 ]] && grep -qiE "realm.*files|context /quan-ly-files" "$vhost_conf"; then
  sed -i -e '/^realm '${NAME}files'/,/^}$/d' "$vhost_conf"
  sed -i -e '/^context \/quan-ly-files\//,/^}$/d' "$vhost_conf"
  sed -i '/password_dang_nhap_quan_ly_file_cap_2/d' "/etc/wptt/vhost/.$NAME.conf"
  sed -i '/id_dang_nhap_quan_ly_file_cap_2/d' "/etc/wptt/vhost/.$NAME.conf"
  sed -i '/id_quan_ly_files/d' "/etc/wptt/vhost/.$NAME.conf"
  sed -i '/password_quan_ly_file/d' "/etc/wptt/vhost/.$NAME.conf"
  rm -f "/usr/local/lsws/$NAME/passwd/.files"
  rm -f "/usr/local/lsws/$NAME/passwd/.password-giatuan.json"
  rm -f "/usr/local/lsws/$NAME/passwd/.user-giatuan.json"
fi
_rundone "$lam_sach_toan_bo_du_lieu_ma_nguon_cua $NAME"

# ==============================================================================
# 4. TẢI VÀ GIẢI NÉN MÃ NGUỒN
# ==============================================================================
_runing "$tai $ma_nguon WordPress mới nhất"

OLD_PWD=$(pwd)
TMP_DIR=$(mktemp -d)
cd "$TMP_DIR" || exit

wget -q --timeout=15 --tries=3 https://wordpress.org/latest.tar.gz
id_checksum_wordpress=$(curl -s https://wordpress.org/latest.tar.gz.md5 | head -1)
[[ "$id_checksum_wordpress" != $(md5sum latest.tar.gz 2>/dev/null | awk '{print $1}') ]] && rm -f latest.tar.gz

if [[ ! -f latest.tar.gz ]]; then
  wget -q --timeout=15 --tries=3 http://wordpress.org/latest.tar.gz
  id_checksum_wordpress=$(curl -s http://wordpress.org/latest.tar.gz.md5 | head -1)
  [[ "$id_checksum_wordpress" != $(md5sum latest.tar.gz 2>/dev/null | awk '{print $1}') ]] && rm -f latest.tar.gz
fi

if [[ ! -f latest.tar.gz ]]; then
  _runloi "$tai $ma_nguon WordPress"
  echo -e "${C_RED}Lỗi: Chưa thể download mã nguồn WordPress, vui lòng thử lại sau!${C_RESET}"
  cd "$OLD_PWD" || cd /root
  rm -rf "$TMP_DIR"
  [[ "${1:-}" == "99" ]] && exec /usr/bin/wptangtoc 1
  return 2>/dev/null
  exit
fi
_rundone "$tai $ma_nguon WordPress mới nhất"

_runing "$giai_nen $ma_nguon WordPress"
tar -zxf latest.tar.gz
mv wordpress/* "/usr/local/lsws/$NAME/html" && rm -rf wordpress latest.tar.gz
cd "$OLD_PWD" || cd /root
rm -rf "$TMP_DIR"
_rundone "$giai_nen $ma_nguon WordPress"

. /etc/wptt/ssl/check-ssl-cert-con-kha-dung $NAME
if [[ "$ssl_xac_thuc_kha_dung" == 'true' ]]; then
  ssl_check="https://"
else
  ssl_check="http://"
fi

# ==============================================================================
# 5. XỬ LÝ DATABASE
# ==============================================================================
if [[ -n "$DB_Name_web" ]]; then
  _runing "$lam_sach_toan_bo_du_lieu_database $NAME"

  TEMP_CNF_ROOT=$(mktemp)
  chmod 600 "$TEMP_CNF_ROOT"
  cat >"$TEMP_CNF_ROOT" <<EOF
[client]
user=${database_admin_username}
password=${database_admin_password}
host=localhost
EOF

  # Chỉ DROP và CREATE lại Database (Reset trắng Database, User thì vẫn giữ nguyên vì đã check ở Trạm kiểm lâm)
  mariadb --defaults-extra-file="$TEMP_CNF_ROOT" --ssl-verify-server-cert=false -e "DROP DATABASE IF EXISTS \`$DB_Name_web\`;"
  mariadb --defaults-extra-file="$TEMP_CNF_ROOT" --ssl-verify-server-cert=false -e "CREATE DATABASE IF NOT EXISTS \`$DB_Name_web\`;"
  rm -rf "$TEMP_CNF_ROOT"
  _rundone "$lam_sach_toan_bo_du_lieu_database $NAME"

  # ==============================================================================
  # 6. HỎI CẤU HÌNH WP-ADMIN
  # ==============================================================================
  dongyconfig="n"
  if wptt_xac_nhan "Sếp có muốn thiết lập thông tin Quản trị viên (Admin) ngay không?" "" "" "Có (Thiết lập ngay)" "Không (Để sau)"; then
    dongyconfig="y"
  fi

  if [[ ! -x /usr/local/bin/wp ]]; then
    _runing "Đang cài đặt WP-CLI..."
    curl -sO https://raw.githubusercontent.com/wp-cli/builds/gh-pages/phar/wp-cli.phar
    chmod +x wp-cli.phar
    mv wp-cli.phar /usr/local/bin/wp
    _rundone "Cài đặt WP-CLI"
  fi

  _runing "Cấu hình wp-config.php..."
  tien_to_db=$(openssl rand -base64 32 | tr -dc 'a-zA-Z0-9' | head -c 6)
  /usr/local/bin/wp core config --dbname="$DB_Name_web" --dbuser="$DB_User_web" --dbpass="$DB_Password_web" --dbhost=localhost --dbprefix="${tien_to_db}_" --dbcharset='utf8mb4' --dbcollate='utf8mb4_unicode_ci' --allow-root --path="/usr/local/lsws/$domain/html/" --extra-php >/dev/null 2>&1 <<PHP
define( 'WP_DEBUG_LOG', false );
define( 'WP_DEBUG_DISPLAY', false );
PHP
  _rundone "Cấu hình wp-config.php"

  # NẾU KHÔNG CẤU HÌNH NGAY -> TẠO BẢO MẬT 2 LỚP TẠM THỜI
  if [[ "$dongyconfig" != "y" ]]; then
    mkdir -p "/usr/local/lsws/$NAME/passwd"
    Webadmin_Pass=$(openssl rand -base64 48 | tr -dc 'a-zA-Z0-9' | head -c 12)
    id_ols_admin=$(openssl rand -base64 32 | tr -dc 'a-zA-Z0-9' | head -c 12)
    Encrypt_string=$(/usr/local/lsws/admin/fcgi-bin/admin_php -q /usr/local/lsws/admin/misc/htpasswd.php "${Webadmin_Pass}")
    echo "$id_ols_admin:$Encrypt_string" >"/usr/local/lsws/$NAME/passwd/.mk-setup"

    sed -i -e '/^realm '${NAME}wordpress-setup'/,/^}$/d' "/usr/local/lsws/conf/vhosts/$NAME/$NAME.conf"
    sed -i -e '/^context exp:wp-admin\/install.php/,/^}$/d' "/usr/local/lsws/conf/vhosts/$NAME/$NAME.conf"

    cat <<EOF >>"/usr/local/lsws/conf/vhosts/$NAME/$NAME.conf"
realm ${NAME}wordpress-setup {
  userDB  {
    location              /usr/local/lsws/$NAME/passwd/.mk-setup
  }
}
context exp:wp-admin/install.php {
  location                \$DOC_ROOT/\$0
  allowBrowse             1
  realm                   ${NAME}wordpress-setup
  accessControl  {
    allow                 ALL
  }
  addDefaultCharset       off
}
EOF
  fi

  # NẾU ĐỒNG Ý CẤU HÌNH NGAY
  if [[ "$dongyconfig" == "y" ]]; then
    echo -e "\n${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
    center_text "${C_YELLOW}THIẾT LẬP THÔNG TIN QUẢN TRỊ VIÊN WORDPRESS${C_RESET}"
    echo -e "${C_CYAN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"

    echo -en "${C_CYAN}│${C_RESET} ${C_BOLD_WHITE}1. Tên Website (Site Title):${C_RESET} "
    read -r SiteTitle

    echo -en "${C_CYAN}│${C_RESET} ${C_BOLD_WHITE}2. User đăng nhập Admin:${C_RESET} "
    read -r idusername

    mypassword=""
    echo -en "${C_CYAN}│${C_RESET} ${C_BOLD_WHITE}3. Mật khẩu (Ít nhất 12 ký tự):${C_RESET} "
    while IFS= read -r -s -N 1 char; do
      if [[ -z "$char" ]] || [[ "$char" == $'\n' ]] || [[ "$char" == $'\r' ]]; then
        echo; break
      elif [[ "$char" == $'\x7f' ]]; then
        if [[ -n "$mypassword" ]]; then
          mypassword="${mypassword%?}"; echo -ne '\b \b'
        fi
      else
        mypassword+="$char"; echo -n '*'
      fi
    done

    while [[ -z "$mypassword" ]]; do
      echo -e "${C_CYAN}│${C_RESET} ${C_RED}❌ Bạn chưa nhập mật khẩu!${C_RESET}"
      echo -en "${C_CYAN}│${C_RESET} ${C_BOLD_WHITE}3. Nhập lại Mật khẩu:${C_RESET} "
      while IFS= read -r -s -N 1 char; do
        if [[ -z "$char" ]] || [[ "$char" == $'\n' ]] || [[ "$char" == $'\r' ]]; then
          echo; break
        elif [[ "$char" == $'\x7f' ]]; then
          [[ -n "$mypassword" ]] && mypassword="${mypassword%?}" && echo -ne '\b \b'
        else
          mypassword+="$char" && echo -n '*'
        fi
      done
    done

    echo -en "${C_CYAN}│${C_RESET} ${C_BOLD_WHITE}4. Email quản trị viên:${C_RESET} "
    read -r emailwp
    while [[ "$emailwp" == "${emailwp/@/}" ]]; do
      echo -e "${C_CYAN}│${C_RESET} ${C_RED}❌ Email không đúng định dạng!${C_RESET}"
      echo -en "${C_CYAN}│${C_RESET} ${C_BOLD_WHITE}4. Nhập lại Email:${C_RESET} "
      read -r emailwp
    done
    echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯${C_RESET}"

    _runing "$thiet_lap WordPress (Cài đặt Core)"
    wp core install --url="${ssl_check}${domain}" --title="$SiteTitle" --admin_user="$idusername" --admin_password="$mypassword" --admin_email="$emailwp" --allow-root --path="/usr/local/lsws/$domain/html/" >/dev/null 2>&1
    unset mypassword
  fi
fi

# ==============================================================================
# 7. HOÀN THIỆN CẤU HÌNH
# ==============================================================================
echo '# BEGIN WordPress
<IfModule mod_rewrite.c>
RewriteEngine On
RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]
RewriteBase /
RewriteRule ^index\.php$ - [L]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . /index.php [L]
</IfModule>
# END WordPress' >"/usr/local/lsws/$domain/html/.htaccess"

if [[ "$dongyconfig" == "y" ]]; then
  wp language core install vi --path="/usr/local/lsws/$NAME/html" --activate --allow-root >/dev/null 2>&1
  wp option update timezone_string "Asia/Ho_Chi_Minh" --path="/usr/local/lsws/$NAME/html" --allow-root >/dev/null 2>&1
  wp rewrite structure '/%postname%/' --path="/usr/local/lsws/$NAME/html" --allow-root >/dev/null 2>&1

  sed -i -e '/^realm '${NAME}wordpress-setup'/,/^}$/d' "/usr/local/lsws/conf/vhosts/$NAME/$NAME.conf"
  sed -i -e '/^context exp:wp-admin\/install.php/,/^}$/d' "/usr/local/lsws/conf/vhosts/$NAME/$NAME.conf"
  rm -f "/usr/local/lsws/$NAME/passwd/.mk-setup"
  _rundone "$thiet_lap WordPress (Cài đặt Core)"
fi

echo "User-agent: *
Disallow: /wp-admin/
Allow: /wp-admin/admin-ajax.php" >"/usr/local/lsws/$NAME/html/robots.txt"

_runing "$phan_quyen website $NAME"
chown -R "$User_name_vhost":"$User_name_vhost" "/usr/local/lsws/$NAME/html"
chown root:root "/usr/local/lsws/$NAME"
/usr/local/lsws/bin/lswsctrl restart >/dev/null 2>&1
_rundone "$phan_quyen website $NAME"

# ==============================================================================
# 8. BẢNG TÓM TẮT CUỐI CÙNG (SỬ DỤNG LEFT_TEXT ĐỂ ĐỒNG BỘ UI)
# ==============================================================================
echo -e "\n${C_GREEN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_BOLD_WHITE}[ THÀNH CÔNG ] CÀI ĐẶT MÃ NGUỒN WORDPRESS${C_RESET}" "$C_GREEN"
echo -e "${C_GREEN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"

left_text "${C_BOLD_WHITE}Domain         :${C_RESET} ${C_YELLOW}${ssl_check}${domain}${C_RESET}" "$C_GREEN"
left_text "${C_BOLD_WHITE}Đường dẫn HTML :${C_RESET} ${C_WHITE}/usr/local/lsws/$domain/html/${C_RESET}" "$C_GREEN"

