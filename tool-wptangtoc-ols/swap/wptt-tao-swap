#!/bin/bash

function huong_dan() {
  Tính năng Tạo swap Linux là quá trình thiết lập một không gian trên ổ cứng [HDD hoặc SSD] để hệ điều hành Linux sử dụng như một bộ nhớ ảo [virtual memory] khi bộ nhớ vật lý [RAM] bị đầy.

  Nói một cách đơn giản, khi RAM của bạn không còn đủ chỗ trống để chạy các ứng dụng, Linux sẽ chuyển những dữ liệu ít được sử dụng từ RAM sang không gian swap này trên ổ cứng. Điều này giúp hệ thống tiếp tục hoạt động thay vì bị treo hoặc báo lỗi hết bộ nhớ.

  Mục Đích Chính
  * Mở rộng bộ nhớ khả dụng: Cho phép hệ thống chạy được nhiều ứng dụng hơn hoặc xử lý các tác vụ nặng hơn so với chỉ dùng RAM vật lý.
  * Tăng tính ổn định cho hệ thống: Giúp ngăn chặn tình trạng hệ thống bị sập hoặc không phản hồi khi RAM bị quá tải.
  * Hỗ trợ chế độ ngủ đông [Hibernation]: Swap thường cần thiết để lưu trạng thái của hệ thống [nội dung RAM] vào ổ cứng khi máy tính vào chế độ ngủ đông, cho phép khôi phục nhanh chóng sau đó.
  * Cải thiện hiệu suất [trong một số trường hợp]: Bằng cách chuyển dữ liệu ít dùng sang swap, RAM sẽ có thêm không gian cho các dữ liệu được truy cập thường xuyên hơn. Tuy nhiên, truy cập swap chậm hơn RAM rất nhiều.

  Tạo swap là một kỹ thuật hữu ích để tăng cường khả năng xử lý của hệ thống Linux, đặc biệt khi tài nguyên RAM hạn chế.

  Ghi chú: thêm swap nó chỉ là giải pháp tạm thời hoặc eo hẹp về ngân sách máy chủ RAM. Về lâu dài bảo đảm hiệu suất hãy nâng cấp ram thật. Tốc độ swap ổ cứng chậm hơn gấp 3000 lần so với RAM thật.
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null # Nạp thư viện UX Bo Cong

clear
echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}QUẢN LÝ SWAP ➜ Thêm bộ nhớ Ảo (Swap Truyền Thống)${C_RESET}"
echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

if [[ "${1:-}" == '98' ]]; then
  WPTT_IN_MENU="yes"
  WPTT_MENU_BACK="/etc/wptt/wptt-swap-main 1"
fi

if grep -qiE "ubuntu" /etc/os-release; then
  duong_dan_config_zram="/etc/default/zramswap"
else
  duong_dan_config_zram="/etc/systemd/zram-generator.conf"
fi

if [[ -f "$duong_dan_config_zram" ]]; then
  echo -e "${C_RED}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_BOLD_WHITE}XUNG ĐỘT HỆ THỐNG: MÁY CHỦ ĐANG BẬT ZRAM${C_RESET}"
  echo -e "${C_RED}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
  left_text "  Máy chủ của bạn hiện đang được tăng tốc bằng ${C_YELLOW}ZRAM${C_RESET}." 2
  left_text "  ZRAM và Swap Truyền thống KHÔNG NÊN hoạt động cùng nhau" 2
  left_text "  vì sẽ gây ra hiện tượng cạnh tranh bộ nhớ (Thrashing) cực kỳ lag." 2
  echo -e "${C_RED}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
  left_text "  ${C_CYAN}Cách xử lý:${C_RESET}" 2
  left_text "  Hãy vào 'Menu Quản lý Swap' -> Chọn 'Xóa ZRAM' trước khi tạo Swap." 2
  echo -e "${C_RED}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"
  
  echo -en "${C_YELLOW}Nhấn phím [Enter] để quay lại Menu...${C_RESET}"
  read -r dummy
  exec /etc/wptt/wptt-swap-main 1
  exit 0
fi

tong_ram_byte=$(awk '/MemTotal/ {print $2}' /proc/meminfo)
rong_ram_mb=$(echo "scale=0;${tong_ram_byte}/1024" | bc)
[[ -z "$rong_ram_mb" ]] && rong_ram_mb="2048"

echo -e "${C_YELLOW}Gợi ý: Máy chủ của bạn có ${C_GREEN}${rong_ram_mb} MB${C_YELLOW} RAM thật.${C_RESET}"
echo -e "   Khuyến nghị Swap bằng ${C_CYAN}1x${C_RESET} hoặc ${C_CYAN}2x${C_RESET} dung lượng RAM thật."
echo -e "   Ví dụ: Nhập 1024 cho 1GB, hoặc 2048 cho 2GB.\n"

echo -en "${C_CYAN}Nhập dung lượng Swap (MB) muốn tạo [0=Thoát]: ${C_RESET}"
read -r swap

if [[ "$swap" == '0' || -z "$swap" ]]; then
  echo -e "${C_YELLOW}Đã hủy thao tác.${C_RESET}\n"
  sleep 1
  exec /etc/wptt/wptt-swap-main 1
fi

# Làm sạch input (FIX BUGS BẢN CŨ)
swap=$(echo "$swap" | sed -E 's/[mM][bB]?|[[:space:]]//g')

if ! [[ "$swap" =~ ^[0-9]+$ ]]; then
  echo -e "\n${C_RED}❌ Lỗi: Bạn phải nhập một số nguyên (VD: 1024, 2048...).${C_RESET}"
  sleep 2
  exec /etc/wptt/wptt-swap-main 1
fi

gap3swap=$(( rong_ram_mb * 2 ))

if (( swap > gap3swap )); then
  echo -e "\n${C_RED}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_BOLD_WHITE}CẢNH BÁO HIỆU SUẤT: SWAP QUÁ LỚN${C_RESET}"
  echo -e "${C_RED}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
  left_text "  Bạn đang cố tạo Swap (${C_YELLOW}${swap} MB${C_RESET}) lớn hơn gấp đôi RAM thật." 2
  left_text "  ${C_RED}HẬU QUẢ:${C_RESET} Ổ cứng chậm hơn RAM tới 3000 lần. Nếu Swap quá lớn," 2
  left_text "  máy chủ sẽ bị 'nghẽn cổ chai' ổ cứng (I/O Wait) và sập toàn tập." 2
  echo -e "${C_RED}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"
  
  if ! wptt_xac_nhan "Bạn có CHẮC CHẮN muốn bỏ qua cảnh báo và tiếp tục tạo Swap không?" "" "" "Vẫn tiếp tục tạo" "Hủy bỏ an toàn"; then
    echo -e "${C_YELLOW}Đã hủy thao tác để bảo vệ máy chủ.${C_RESET}\n"
    sleep 2
    exec /etc/wptt/wptt-swap-main 1
  fi
  echo ""
fi

if ! wptt_xac_nhan "Hệ thống chuẩn bị cấp phát ổ cứng và tạo file Swap (${swap} MB)." "Quá trình này có thể mất vài phút tùy tốc độ ổ cứng của bạn." "" "Đồng ý Tạo Swap" "Hủy thao tác"; then
  echo -e "${C_YELLOW}Đã hủy thao tác.${C_RESET}\n"
  sleep 1
  exec /etc/wptt/wptt-swap-main 1
fi

echo ""
echo "Thiết lập ${swap}MB làm swap: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log

_runing "Đang tắt các tiến trình Swap cũ (nếu có)..."
swapoff -a -v >/dev/null 2>&1
rm -f /var/swap.1
_rundone "Dọn dẹp môi trường Swap thành công"

# Bước dd cực kỳ chậm nếu tạo Swap to, ta thêm Spinner thủ công cho xịn
echo -en "   ${C_CYAN}Đang ghi ${C_YELLOW}${swap} MB${C_CYAN} dữ liệu rỗng (Zero Bytes) xuống ổ cứng...${C_RESET}"
/bin/dd if=/dev/zero of=/var/swap.1 bs=1M count=$swap >/dev/null 2>&1
echo -e "\r  ${C_GREEN} ✔ Đã cấp phát thành công ${C_YELLOW}${swap} MB${C_GREEN} không gian trên ổ cứng.        ${C_RESET}"

_runing "Đang định dạng phân vùng thành chuẩn Swap Linux..."
/sbin/mkswap /var/swap.1 >/dev/null 2>&1
_rundone "Định dạng không gian ổ đĩa thành công"

_runing "Đang kích hoạt bộ nhớ ảo (Swapon)..."
/sbin/swapon /var/swap.1 >/dev/null 2>&1
_rundone "Kích hoạt Swap thành công"

_runing "Đang thêm thiết lập khởi động (Fstab) tự động..."
sed -i '/swap.1/d' /etc/fstab
sed -i '/ swap / s/^\(.*\)$/#\1/g' /etc/fstab # Vô hiệu hóa các swap khác
echo '/var/swap.1 none swap defaults 0 0' >>/etc/fstab
_rundone "Cấu hình tự khởi chạy Fstab thành công"

echo -e "\n${C_GREEN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_BOLD_WHITE}HOÀN TẤT THIẾT LẬP SWAP TRUYỀN THỐNG${C_RESET}"
echo -e "${C_GREEN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
left_text "  Vị trí File Swap: ${C_YELLOW}/var/swap.1${C_RESET}" 2
left_text "  Dung lượng      : ${C_CYAN}${swap} MB${C_RESET}" 2
left_text "  Trạng thái      : ${C_GREEN}Đang hoạt động (Active)${C_RESET}" 2
left_text "  Khởi động cùng OS: Tự động (Fstab)" 2
echo -e "${C_GREEN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

check_menu_wptangtoc_active=${1:-}
if [[ "$check_menu_wptangtoc_active" == "98" ]]; then
  exec /etc/wptt/wptt-swap-main 1
fi
