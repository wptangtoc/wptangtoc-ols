#!/bin/bash

function huong_dan() {
  Tính năng Xóa swap Linux là quá trình vô hiệu hóa và loại bỏ không gian swap [bộ nhớ ảo] đã được thiết lập trước đó trên hệ thống Linux của bạn, cho dù đó là một phân vùng swap [swap partition] hay một tệp swap [swap file].

  Nói một cách đơn giản, đây là hành động thu hồi lại phần ổ cứng đã được dùng làm RAM ảo. Sau khi xóa, hệ thống sẽ không còn sử dụng không gian đĩa đó để lưu trữ dữ liệu từ RAM khi RAM đầy nữa.

  Mục Đích Chính
  * Giải phóng dung lượng ổ đĩa: Nếu bạn cần không gian ổ cứng mà swap đang chiếm giữ cho các mục đích khác [lưu trữ tệp, mở rộng phân vùng khác].
  * Cấu hình lại hệ thống: Khi thay đổi sơ đồ phân vùng ổ đĩa hoặc chuyển sang một thiết lập lưu trữ mới.
  * Không còn nhu cầu sử dụng: Nếu hệ thống có đủ RAM và swap không được sử dụng đến, hoặc bạn không dùng tính năng ngủ đông [hibernation].
  * Thay đổi vị trí/kích thước swap: Xóa swap cũ để tạo một swap mới ở vị trí khác hoặc với kích thước khác.
  * Lo ngại về hiệu suất/tuổi thọ SSD [trong một số trường hợp]: Nếu hệ thống thường xuyên dùng swap trên ổ cứng chậm hoặc bạn muốn giảm thiểu ghi lên SSD, có thể cân nhắc xóa swap [nhưng cần đảm bảo đủ RAM].

  Sau khi xóa swap thành công, không gian đĩa đó sẽ được giải phóng hoặc sẵn sàng cho mục đích sử dụng khác.
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null # Nạp thư viện UX Bo Cong

clear
echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}QUẢN LÝ SWAP ➜ Xóa bộ nhớ Ảo (Swap Truyền Thống)${C_RESET}"
echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

if [[ "${1:-}" == '98' ]]; then
  WPTT_IN_MENU="yes"
  WPTT_MENU_BACK="/etc/wptt/wptt-swap-main 1"
fi

if grep -qiE "ubuntu" /etc/os-release 2>/dev/null; then
  duong_dan_config_zram="/etc/default/zramswap"
else
  duong_dan_config_zram="/etc/systemd/zram-generator.conf"
fi

if [[ -f "$duong_dan_config_zram" ]]; then
  echo -e "${C_RED}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_BOLD_WHITE}THÔNG BÁO: MÁY CHỦ ĐANG SỬ DỤNG ZRAM${C_RESET}"
  echo -e "${C_RED}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
  left_text "  Máy chủ của bạn hiện đang được tăng tốc bằng ${C_YELLOW}ZRAM${C_RESET}." 2
  left_text "  Bạn không thể và không cần quản lý Swap truyền thống lúc này." 2
  echo -e "${C_RED}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
  left_text "  ${C_CYAN}Cách xử lý:${C_RESET}" 2
  left_text "  Hãy vào 'Menu Quản lý Swap' -> Chọn 'Xóa ZRAM' trước nếu muốn." 2
  echo -e "${C_RED}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"
  
  echo -en "${C_YELLOW}Nhấn phím [Enter] để quay lại Menu...${C_RESET}"
  read -r dummy
  exec /etc/wptt/wptt-swap-main 1
  exit 0
fi

if [[ ! -f "/var/swap.1" ]]; then
  echo -e "${C_YELLOW}⚠️ THÔNG BÁO: Hệ thống chưa kích hoạt Swap truyền thống!${C_RESET}"
  echo -e "Không tìm thấy file lưu trữ /var/swap.1. Không có dữ liệu để xóa.\n"
  sleep 2
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-swap-main 1
  exit 0
fi

if ! wptt_xac_nhan "Bạn có CHẮC CHẮN muốn XÓA Swap truyền thống không?" "Hành động này sẽ vô hiệu hóa RAM ảo và giải phóng dung lượng ổ cứng." "" "Đồng ý XÓA SWAP" "Hủy thao tác"; then
  echo -e "${C_YELLOW}Đã hủy thao tác. Swap vẫn đang hoạt động bình thường.${C_RESET}\n"
  sleep 1
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-swap-main 1
  exit 0
fi

echo ""
echo "Thiết lập Delete Xóa swap: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log

_runing "Đang tắt và ngắt kết nối bộ nhớ ảo (Swapoff)..."
swapoff -a -v >/dev/null 2>&1
_rundone "Ngắt kết nối hệ thống thành công"

_runing "Đang xóa File lưu trữ và dọn dẹp cấu hình Fstab..."
rm -f /var/swap.1
sed -i '/swap.1/d' /etc/fstab
_rundone "Giải phóng ổ cứng và Fstab thành công"

echo -e "\n${C_GREEN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_BOLD_WHITE}HOÀN TẤT XÓA BỎ SWAP TRUYỀN THỐNG${C_RESET}"
echo -e "${C_GREEN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
left_text "  Trạng thái      : ${C_RED}Đã vô hiệu hóa (Disabled)${C_RESET}" 2
left_text "  Dung lượng      : ${C_GREEN}Đã thu hồi trả lại cho ổ cứng hệ thống${C_RESET}" 2
left_text "  Khởi động (Fstab): Đã xóa cấu hình tự chạy" 2
echo -e "${C_GREEN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

check_menu_wptangtoc_active=${1:-}
if [[ "$check_menu_wptangtoc_active" == "98" ]]; then
  exec /etc/wptt/wptt-swap-main 1
fi
