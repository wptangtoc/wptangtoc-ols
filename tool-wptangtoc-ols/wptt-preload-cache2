#!/bin/bash
# @author: Gia Tuấn
# @website: https://wptangtoc.com
# @since: 2026
# @email: giatuan@wptangtoc.com

function huong_dan() {
  Tính năng Preload Cache [Tải trước bộ nhớ đệm] là một kỹ thuật chủ động tạo và lưu trữ các phiên bản đã được cache [lưu tạm] của các trang web [hoặc các tài nguyên khác] trước khi có bất kỳ người dùng nào thực sự truy cập vào những trang đó.

  Mục Đích Chính:
  * Đảm bảo khách truy cập đầu tiên cũng có trải nghiệm nhanh.
  * Cải thiện hiệu suất cảm nhận được & Nâng cao trải nghiệm người dùng.
  * Lợi ích SEO [gián tiếp]: Tốc độ website là một yếu tố xếp hạng.
  * [ĐỘT PHÁ]: Fallback Spider Crawl đệ quy + Real-time UI + Localhost Routing.
}

. /etc/wptt/.wptt.conf 2>/dev/null
if [[ $ngon_ngu = '' ]]; then
  ngon_ngu='vi'
fi
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null # Nạp thư viện UX Bo Cong

NAME=$1

if [[ $NAME = "98" ]]; then
  NAME=""
fi

if [[ "$NAME" ]]; then
  if [ "$NAME" = "${NAME/./}" ]; then
    clear
    _runloi "$domain_nhap_khong_dung_dinh_dang"
    exit
  fi
fi

if [[ "$NAME" = "" ]]; then
  clear
  echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_BOLD_WHITE}PRELOAD CACHE${C_RESET}"
  echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"
  . /etc/wptt/tenmien-them-lua-chon-tat-ca-website
  lua_chon_NAME "preload cache"

  if [[ "$NAME" = "0" || "$NAME" = "" ]]; then
    exec /usr/bin/wptangtoc 1
  fi
fi

# Xử lý khi chọn Tất cả website
if [[ $NAME = 'Tất cả website' ]]; then
  if [ "$(ls -A /etc/wptt/vhost | grep -v '^\.\.conf$' | sort -uV)" ]; then
    for entry in $(ls -A /etc/wptt/vhost | grep -v '^\.\.conf$' | sort -uV); do
      domain=$(echo $entry | sed 's/^.//' | sed 's/.conf//')
      path_html="/usr/local/lsws/$domain/html"
      if [ "$domain" != "${domain/./}" ] && [ "$domain" != '.' ]; then
        if [[ -d "$path_html" ]]; then
          (/etc/wptt/wptt-preload-cache2 $domain)
        fi
      fi
    done
  fi

  [[ ${1:-} == "98" ]] && exec /usr/bin/wptangtoc 1
  exit
fi

if [[ ! -f /etc/wptt/vhost/.$NAME.conf ]]; then
  clear
  _runloi "Tên miền không tồn tại trên hệ thống này"
  sleep 3
  exec /usr/bin/wptangtoc 1
fi

echo "Preload website $NAME : $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log

domain="$NAME"
if [[ $ip_domain ]]; then
  domain_ip=$(curl -skf --connect-timeout 5 --max-time 10 https://ipv4.icanhazip.com || curl -skf --connect-timeout 5 --max-time 10 https://checkip.amazonaws.com)
  [[ -n "$domain_ip" ]] && domain=$(echo "$domain_ip" | grep -E -o '([0-9]{1,3}\.){3}[0-9]{1,3}') || domain="$NAME"
fi

echo ""
_runing "Kiểm tra kết nối cho website: $NAME"

checkssl=$(curl -kIs https://${domain} --connect-to "${domain}::127.0.0.1:443" --connect-to "${domain}::127.0.0.1:80" -A "WPTangToc OLS preload cache" | head -n 1 | grep -c "200")
checkssl2=$(curl -kIs http://${domain} --connect-to "${domain}::127.0.0.1:443" --connect-to "${domain}::127.0.0.1:80" -A "WPTangToc OLS preload cache" | head -n 1 | grep -c "200")
checkssl3=$(curl -kIs https://www.${domain} --connect-to "${domain}::127.0.0.1:443" --connect-to "${domain}::127.0.0.1:80" -A "WPTangToc OLS preload cache" | head -n 1 | grep -c "200")
checkssl4=$(curl -kIs http://www.${domain} --connect-to "${domain}::127.0.0.1:443" --connect-to "${domain}::127.0.0.1:80" -A "WPTangToc OLS preload cache" | head -n 1 | grep -c "200")

if [[ "$checkssl" = "0" && "$checkssl2" = "0" && "$checkssl3" = "0" && "$checkssl4" = "0" ]]; then
  _runloi "Website $NAME ngưng hoạt động hoặc không phản hồi nội bộ."
  sleep 4
  exec /usr/bin/wptangtoc 1
fi
_rundone "Kiểm tra kết nối"

. /etc/wptt/vhost/.$NAME.conf
if [[ $vhost_chuyen_htaccess ]]; then
  check=$(cat /usr/local/lsws/conf/vhosts/$NAME/$NAME.conf | sed -e '/^context/,/^}$/!d' | sed -e '/rewrite/,/^}$/!d')
else
  check=$(cat /usr/local/lsws/$NAME/html/.htaccess)
fi

NAME_path="$NAME"
if [[ "$checkssl3" = "1" || "$checkssl4" = "1" ]]; then
  domain=$(echo www.${domain})
fi

ssl="http"
[[ "$checkssl" = "1" || "$checkssl3" = "1" ]] && ssl="https"

grepmobile=$(echo $check | grep -c Android)
grepwebp=$(echo $check | grep -c "+webp")

# =======================================================================
# 2. TÌM KIẾM SITEMAP & PHÂN LOẠI CÔNG NGHỆ CACHE
# =======================================================================
_runing "Đang quét cấu trúc Sitemap..."
sitemap_paths=("/sitemap_index.xml" "/sitemap.xml" "/wp-sitemap.xml" "/sitemaps.xml")

check_sitemap() {
  local domain="$1"

  local ssl="$2"
  local path="$3"
  local full_url="${ssl}://${domain}${path}"

  # tuong thích với www preload cache
  if [[ $(echo $domain | grep '^www\.') ]]; then
    local domain=$(echo $domain | sed 's/^www.//g')
  fi

  # Sử dụng --connect-to thay vì --connect-to
  local check_http_200=$(curl -kIs "$full_url" --connect-to "${domain}::127.0.0.1:443" --connect-to "${domain}::127.0.0.1:80" -A "WPTangToc OLS preload cache" | head -n 1 | grep -c "200")

  if [[ "$check_http_200" != "0" ]]; then
    return 0 # Thành công
  else
    return 1 # Thất bại
  fi
}

found_sitemap=false

for path in "${sitemap_paths[@]}"; do
  if check_sitemap "$domain" "$ssl" "$path"; then
    found_sitemap=true
    NAME2="${ssl}://${domain}${path}"
    break # Thoát vòng lặp khi tìm thấy sitemap
  fi
done

spider_mode=false
if ! "$found_sitemap"; then
  _runloi "$khong_xac_dinh_duoc sitemap website $NAME"
  echo -e "    ➜ ${C_YELLOW}Tự động kích hoạt chế độ Spider Crawl${C_RESET}"
  spider_mode=true
else
  _rundone "Tìm thấy Sitemap: $NAME2"
fi

# Xác định công cụ Cache
cong_cu=""
grep=$(echo $check | grep -c LiteSpeed)
if [[ "$grep" = "0" ]]; then
  pluginsspeed=(cache-enabler fast-velocity-minify wp-rocket w3-total-cache wp-super-cache wp2speed nitropack wp-fastest-cache hummingbird-performance swift-performance-lite swift-performance-pro breeze wp-meteor phastpress flying-press simple-cache powered-cache yasakani-cache batcache sg-cachepress cloudflare)
  for plugintt in ${pluginsspeed[@]}; do
    pathcheckplugin3="/usr/local/lsws/${NAME_path}/html/wp-content/plugins/$plugintt"
    if [[ -d "$pathcheckplugin3" ]]; then
      plugintt2=$(echo $plugintt | sed 's/-/ /g')
      echo -e "${C_GREEN}Xác nhận bạn đang sử dụng công nghệ cache: ${C_YELLOW}$plugintt2${C_RESET}"
      cong_cu="wptt-preload-cache-all.sh"
    fi
  done
  if [[ -f /usr/local/lsws/${NAME_path}/html/wp-content/plugins/wptangtoc/class/Cache.php ]]; then
    echo -e "${C_GREEN}Đang sử dụng hệ thống WPTangToc Cache${C_RESET}"
    cong_cu="wptt-preload-cache-all.sh"
  fi
  if [[ $cong_cu = "" ]]; then
    _runloi "Hệ thống xác định bạn chưa sử dụng công nghệ cache tương thích nào."
    sleep 4
    exec /usr/bin/wptangtoc 1
  fi
else
  echo -e "${C_GREEN}Xác nhận bạn đang sử dụng công nghệ: ${C_YELLOW}LiteSpeed Cache${C_RESET}"
  cong_cu="wptt-preload-cache-all.sh"
fi

# =======================================================================
# 3. KIỂM TRA TÀI NGUYÊN HỆ THỐNG TRƯỚC KHI CHẠY (BẢO VỆ SERVER)
# =======================================================================
ps -ef | grep -v grep | grep 'bash' | grep '/etc/wptt' | grep -E 'wptt-preload-cache.sh|wptt-preload-cache-all.sh' | grep $NAME | awk '{print $2}' | xargs kill -9 >/dev/null 2>&1

cpu_su_dung=$(grep 'cpu ' /proc/stat | awk '{usage=($2+$4)*100/($2+$4+$5)} END {print usage "%"}' | cut -f1 -d '.')
if [[ -n $cpu_su_dung ]] && ((cpu_su_dung > 85)); then
  _runloi "Cảnh báo: CPU đang quá tải ($cpu_su_dung%). Tạm dừng để bảo vệ server."
  [[ ${1:-} == "98" ]] && exec /usr/bin/wptangtoc 1
  exit
fi

ram_sudung=$(free | grep Mem | awk '{print $3/$2 * 100.0}' | cut -f1 -d '.')
if [[ -n $ram_sudung ]] && ((ram_sudung > 85)); then
  _runloi "Cảnh báo: RAM đang đầy ($ram_sudung%). Tạm dừng để bảo vệ server."
  [[ ${1:-} == "98" ]] && exec /usr/bin/wptangtoc 1
  exit
fi

# =======================================================================
# 4. PHÂN NHÁNH THỰC THI (SITEMAP HOẶC SPIDER LOCALHOST TRỰC QUAN)
# =======================================================================
echo ""
echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}TIẾN TRÌNH PRELOAD ĐANG CHẠY${C_RESET}"
echo -e "${C_CYAN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"

if [ "$spider_mode" = false ]; then
  # TRƯỜNG HỢP 1: CÓ SITEMAP (CHẠY TOOL WPTANGTOC LITE)
  if [[ "$grepmobile" != "0" ]]; then
    left_text "  ➜ Tạo cache Mobile giao diện..." 2
    check_run='1'
    ionice -c 3 nice -n 19 bash /etc/wptt/$cong_cu -i 0.5 -m -g ${NAME2}
  fi
  if [[ "$grepwebp" != "0" ]]; then
    left_text "  ➜ Tạo cache WebP định dạng..." 2
    check_run='1'
    ionice -c 3 nice -n 19 bash /etc/wptt/$cong_cu -i 0.5 -w ${NAME2}
  fi
  if [[ $check_run = '' ]]; then
    left_text "  ➜ Tạo cache mặc định..." 2
    ionice -c 3 nice -n 19 bash /etc/wptt/$cong_cu -i 0.5 ${NAME2}
  fi
else
  # TRƯỜNG HỢP 2: KHÔNG CÓ SITEMAP (WGET ĐỆ QUY GET + CHỐNG DDOS + REAL-TIME UI + LOCALHOST ROUTING)
  UA_DESKTOP="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36"
  UA_MOBILE="Mozilla/5.0 (iPhone; CPU iPhone OS 16_0 like Mac OS X) Version/16.0 Mobile/15E148"
  HEADER_WEBP="Accept: text/html,application/xhtml+xml,application/xml;q=0.9,image/webp,*/*;q=0.8"

  # Biểu thức Regex chặn rác tuyệt đối
  REGEX_REJECT="(wp-content|wp-includes|/wp-admin/|/wp-json/|/feed/|\.php|\.png|\.jpg|\.jpeg|\.gif|\.css|\.js|\.svg|\.woff|p=|replytocom=|attachment_id=|s=|add-to-cart=|/%20|add_to_wishlist=|add_to_compare=|add-to-wishlist|tel:|action=|filtera-kich-thuoc=|product-cato=|price=|designId=|wmc-currency=)"

  # Tạo file hosts ảo (Chỉ dành riêng cho tiến trình này)
  FAKE_HOSTS="/tmp/wptt_hosts_fake_${domain}.tmp"
  cp /etc/hosts "$FAKE_HOSTS"
  echo -e "127.0.0.1\t${domain}\n127.0.0.1\twww.${domain}" >>"$FAKE_HOSTS"

  # Cờ Tối Ưu Wget: BỎ -nv để lấy log chi tiết nhằm bắt trạng thái "Đang tải"
  CMD_WGET="ionice -c 3 nice -n 19 wget -r -l 3 -nd --delete-after -w 1 -T 5 -t 1 --domains=${domain} --no-check-certificate --reject-regex=\"$REGEX_REJECT\""

  # Hàm xử lý in log thời gian thực (Real-time UI)
  process_spider_log() {
    local current_url=""
    while read -r line; do
      # 1. Bắt lấy dòng "Đang chuẩn bị tải" của Wget
      if echo "$line" | grep -qE "^--[0-9 :-]+--  http"; then
        current_url=$(echo "$line" | sed -E 's/^--[0-9 :-]+--  //')
        
        # Lọc rác bảo hiểm thêm lần nữa
        if ! echo "$current_url" | grep -i -qE "$REGEX_REJECT"; then
          # Tuyệt kỹ \r và \033[K: Ghi đè dòng hiện tại tạo hiệu ứng loading động
          printf "\r\033[K      \033[0;33mĐang quét:\033[0m \033[0;36m%s\033[0m" "$current_url"
        else
          current_url=""
        fi
        
      # 2. Bắt lấy dòng "Tải thành công" (Báo HTTP 200 OK)
      elif echo "$line" | grep -q "200 OK"; then
        if [[ -n "$current_url" ]]; then
          # Ghi đè dòng "Đang quét" thành "Đã nạp" và bắt buộc xuống dòng (\n)
          printf "\r\033[K      \033[0;32mĐã nạp Cache:\033[0m %s\n" "$current_url"
          current_url="" # Reset lại biến để đón link tiếp theo
        fi
      fi
    done
    echo "" # Đẩy thêm 1 dòng trống khi kết thúc để không dính chữ
  }

  left_text "  ➜ Cào liên kết chế độ mặc định" 2
  unshare -m bash -c "mount --bind '$FAKE_HOSTS' /etc/hosts && $CMD_WGET -U '$UA_DESKTOP' '${ssl}://${domain}/'" 2>&1 | process_spider_log

  if [[ "$grepmobile" != "0" ]]; then
    left_text "  ➜ Cào liên kết chế độ Mobile" 2
    unshare -m bash -c "mount --bind '$FAKE_HOSTS' /etc/hosts && $CMD_WGET -U '$UA_MOBILE' '${ssl}://${domain}/'" 2>&1 | process_spider_log
  fi

  if [[ "$grepwebp" != "0" ]]; then
    left_text "  ➜ Cào liên kết chế độ WebP" 2
    unshare -m bash -c "mount --bind '$FAKE_HOSTS' /etc/hosts && $CMD_WGET -U '$UA_DESKTOP' --header='$HEADER_WEBP' '${ssl}://${domain}/'" 2>&1 | process_spider_log
  fi

  rm -f "$FAKE_HOSTS"
fi

echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯${C_RESET}\n"

_rundone "Hoàn tất tạo bộ nhớ đệm cho: $NAME"

[[ ${1:-} == "98" ]] && exec /usr/bin/wptangtoc 1
