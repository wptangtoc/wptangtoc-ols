function huong_dan() {
  Tính năng Cấu hình file .htaccess là việc tạo hoặc chỉnh sửa một tệp tin đặc biệt có tên là .htaccess để kiểm soát và tùy chỉnh cách máy chủ web Apache [hoặc các máy chủ tương thích như LiteSpeed] xử lý các yêu cầu truy cập đến một thư mục cụ thể và các thư mục con của nó trên website của bạn.

  Nói một cách đơn giản, .htaccess giống như một bộ quy tắc riêng bạn đặt ra cho từng khu vực [thư mục] trên website của mình. Máy chủ Apache sẽ đọc những quy tắc này và hành xử theo đó khi có người truy cập vào khu vực đó.

  Mục Đích Chính [Các ứng dụng phổ biến]
  * Viết lại URL https://httpd.apache.org/docs/current/mod/mod_rewrite.html: Đây là một trong những công dụng mạnh mẽ nhất. Dùng để tạo URL thân thiện với SEO [ví dụ: example.com/san-pham/ao-thun thay vì example.com/product.php?id=123], chuyển hướng URL, bắt buộc sử dụng HTTPS, chuyển hướng từ www sang không www [hoặc ngược lại].
  * Kiểm soát truy cập và Bảo mật:
  * Chặn truy cập từ các địa chỉ IP cụ thể.
  * Ngăn chặn việc liệt kê nội dung thư mục [directory listing].
  * Chống Hotlink: Ngăn chặn các website khác nhúng trực tiếp hình ảnh hoặc tệp của bạn.

  File .htaccess là một công cụ mạnh mẽ và linh hoạt.
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null # Nạp thư viện UI Xác nhận

clear
echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}${cau_hinh_webserver} ➜ Chỉnh sửa file .htaccess${C_RESET}"
echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

# ==============================================================================
# CHỌN WEBSITE VÀ KIỂM TRA ĐƯỜNG DẪN
# ==============================================================================
. /etc/wptt/tenmien
lua_chon_NAME "chỉnh sửa file .htaccess"

[[ "$NAME" == "0" || -z "$NAME" ]] && {
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-cau-hinh-websever-main 1
  return 2>/dev/null || exit
}

pathcheck="/etc/wptt/vhost/.$NAME.conf"
if [[ ! -f "$pathcheck" ]]; then
  echo -e "\n${C_RED}❌ Tên miền không tồn tại trên hệ thống này!${C_RESET}"
  sleep 3
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-cau-hinh-websever-main 1
  return 2>/dev/null || exit
fi

htaccess_file="/usr/local/lsws/$NAME/html/.htaccess"

# Nếu file chưa tồn tại thì tạo file trống trước để Editor không bị lỗi
[[ ! -f "$htaccess_file" ]] && touch "$htaccess_file"

# ==============================================================================
# XÁC NHẬN BẢO MẬT & HƯỚNG DẪN TRÌNH SOẠN THẢO (UX BO CONG)
# ==============================================================================
echo ""
if wptt_xac_nhan "Bạn có CHẮC CHẮN muốn mở và chỉnh sửa file .htaccess không?" "CẢNH BÁO: File .htaccess chứa các quy tắc chuyển hướng (Rewrite Rules)." "Cấu hình sai có thể gây ra Lỗi 500 hoặc Vòng lặp chuyển hướng (Redirect Loop)!" "Đồng ý Chỉnh sửa" "Hủy thao tác"; then
  echo ""

  [[ -z "$editor_cau_hinh" ]] && editor_cau_hinh="nano"

  # Khung hướng dẫn phím tắt Nano
  if [[ "$editor_cau_hinh" == "nano" ]]; then
    echo -e "${C_GREEN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
    center_text "${C_BOLD_WHITE}HƯỚNG DẪN LƯU FILE BẰNG NANO${C_RESET}"
    echo -e "${C_GREEN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
    left_text "1. Chỉnh sửa xong, ấn tổ hợp phím  : ${C_YELLOW}Ctrl + O${C_RESET}" 4
    left_text "2. Hệ thống hỏi tên file, ấn phím  : ${C_YELLOW}Enter${C_RESET}" 4
    left_text "3. Thoát ra ngoài Menu, ấn tổ hợp  : ${C_YELLOW}Ctrl + X${C_RESET}" 4
    echo -e "${C_GREEN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"
  else
    echo -e "${C_YELLOW}Đang mở trình soạn thảo: $editor_cau_hinh${C_RESET}\n"
  fi

  echo -e "${C_CYAN}Đang chuẩn bị dữ liệu và mở file .htaccess...${C_RESET}"
  sleep 3

  # Lấy MD5 trước khi sửa (Lưu trên RAM)
  old_md5=$(md5sum "$htaccess_file" | awk '{print $1}')

  # ==============================================================================
  # MỞ TRÌNH SOẠN THẢO
  # ==============================================================================
  $editor_cau_hinh "$htaccess_file"
  clear # Xóa màn hình sau khi Nano thoát ra để giao diện sạch sẽ

  echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_YELLOW}ĐANG KIỂM TRA SỰ THAY ĐỔI DỮ LIỆU${C_RESET}"
  echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

  new_md5=$(md5sum "$htaccess_file" | awk '{print $1}')

  if [[ "$old_md5" != "$new_md5" ]]; then
    _runing "Nạp lại cấu hình .htaccess cho website $NAME..."

    # Kiểm tra tính năng htaccess tĩnh (chuyển đổi Vhost)
    unset vhost_chuyen_htaccess
    . "/etc/wptt/vhost/.$NAME.conf" 2>/dev/null

    if [[ -n "$vhost_chuyen_htaccess" ]]; then
      # Nếu đang dùng htaccess tĩnh -> Chạy script biên dịch lại
      /etc/wptt/wptt-htaccess-tat-chuyen-doi-vhost "$NAME" >/dev/null 2>&1
    else
      # Nếu dùng htaccess động thông thường -> Reload OLS
      /usr/local/lsws/bin/lswsctrl reload >/dev/null 2>&1
    fi

    _rundone "Nạp lại cấu hình .htaccess cho website $NAME..."
    echo "Chỉnh sửa .htaccess website $NAME : $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log

    # BẢNG BÁO CÁO THÀNH CÔNG
    echo -e "\n${C_GREEN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
    center_text "${C_BOLD_WHITE}CẬP NHẬT .HTACCESS THÀNH CÔNG${C_RESET}"
    echo -e "${C_GREEN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
    left_text "Website thao tác : ${C_YELLOW}$NAME${C_RESET}" 2
    left_text "Trạng thái       : Các quy tắc Rewrite mới đã được hệ thống ghi nhận." 2
    echo -e "${C_GREEN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

  else
    echo -e "${C_YELLOW}Không có sự thay đổi nào được phát hiện trong file .htaccess. Bỏ qua nạp lại.${C_RESET}\n"
  fi

else
  echo -e "${C_YELLOW}Đã hủy thao tác chỉnh sửa .htaccess.${C_RESET}\n"
fi

[[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-cau-hinh-websever-main 1
