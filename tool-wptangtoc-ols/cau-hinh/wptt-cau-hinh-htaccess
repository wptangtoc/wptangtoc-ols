function huong_dan() {
  Tính năng Cấu hình file .htaccess là việc tạo hoặc chỉnh sửa một tệp tin đặc biệt có tên là .htaccess để kiểm soát và tùy chỉnh cách máy chủ web Apache [hoặc các máy chủ tương thích như LiteSpeed] xử lý các yêu cầu truy cập đến một thư mục cụ thể và các thư mục con của nó trên website của bạn.

  Nói một cách đơn giản, .htaccess giống như một bộ quy tắc riêng bạn đặt ra cho từng khu vực [thư mục] trên website của mình. Máy chủ Apache sẽ đọc những quy tắc này và hành xử theo đó khi có người truy cập vào khu vực đó.

  Mục Đích Chính [Các ứng dụng phổ biến]
  * Viết lại URL https://httpd.apache.org/docs/current/mod/mod_rewrite.html: Đây là một trong những công dụng mạnh mẽ nhất. Dùng để tạo URL thân thiện với SEO [ví dụ: example.com/san-pham/ao-thun thay vì example.com/product.php?id=123], chuyển hướng URL, bắt buộc sử dụng HTTPS, chuyển hướng từ www sang không www [hoặc ngược lại].
  * Kiểm soát truy cập và Bảo mật:
  * Chặn truy cập từ các địa chỉ IP cụ thể.
  * Ngăn chặn việc liệt kê nội dung thư mục [directory listing].
  * Chống Hotlink: Ngăn chặn các website khác nhúng trực tiếp hình ảnh hoặc tệp của bạn.

  File .htaccess là một công cụ mạnh mẽ và linh hoạt.
}

. /etc/wptt/.wptt.conf
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh
. /etc/wptt/echo-color

clear
echo -e "\n========================================================================="
echo -e "| Cấu hình webserver => Cấu hình .htaccess                                |"
echo -e "=========================================================================\n"

. /etc/wptt/tenmien
echo -e "Lựa chọn website bạn muốn sửa lại .htaccess:\n"
lua_chon_NAME

[[ "$NAME" == "0" || -z "$NAME" ]] && exec /etc/wptt/wptt-cau-hinh-websever-main 1

pathcheck="/etc/wptt/vhost/.$NAME.conf"
if [[ ! -f "$pathcheck" ]]; then
  clear
  echoDo "Tên miền không tồn tại trên hệ thống này!"
  sleep 3
  exec /etc/wptt/wptt-cau-hinh-websever-main 1
fi

htaccess_file="/usr/local/lsws/$NAME/html/.htaccess"

# Nếu file chưa tồn tại thì tạo file trống trước để Editor không bị lỗi
[[ ! -f "$htaccess_file" ]] && touch "$htaccess_file"

echo -e "\n\033[1;33mLưu ý: Hãy thật sự cẩn thận khi sửa cấu hình hệ thống.\033[0m"
prompt="$nhap_lua_chon_cua_ban [1-2]: "
dongy="n"
options=("$dong_y" "$khong_dong_y")
PS3="$prompt"

select opt in "${options[@]}"; do
  case "$REPLY" in
  1)
    dongy="y"
    break
    ;;
  2)
    dongy="n"
    break
    ;;
  *)
    printf "\n$ban_nhap_sai_he_thong_se_chon_khong_dong_y\n"
    break
    ;;
  esac
done

if [[ "$dongy" == "y" ]]; then
  [[ -z "$editor_cau_hinh" ]] && editor_cau_hinh="nano"

  echo -e '\033[1;36m                                                
                    ::::                    
                   :-::-:                   
        ..      ..::::::::::..      ..      
       :-:-:..:----::::::::---::..:-:-:       
       .:::::--:..          ..:--:::::.       
        .::::.                  :::::.        
        ::::                     .::::        
       ::::       .-=++++=-.       ::::       
      .-::       =*******##*=       ::-.      
  ..::::-.      +********:.+#=      ::::::..  
  ---:::-.     .***=-**- .=*** .-:::---  
  ..::::-.      +**=.  .=****=      ::::::..  
      .-::      .+*#*==*****=       ::-.      
       ::::       :=+***++-.       ::::       
        ::::                      ::::        
        .::::.                  :::::.        
       .:::::--:.            .:--:::::.       
       :-:-:..::--::::..:::---::..:-:-:       
        ..       ..::::::::..       ..        
                    .::::.                    
                     ::::                     
                                                \033[0m'

  echo -e "\n\033[1;33m[Sử dụng công cụ editor: $editor_cau_hinh để chỉnh sửa]\033[0m\n"

  if [[ "$editor_cau_hinh" == "nano" ]]; then
    echo -e "\033[1;33m--- HƯỚNG DẪN LƯU FILE ---\033[0m"
    echo -e "1. Chỉnh sửa xong, ấn \033[1;32mCtrl + O\033[0m để lưu."
    echo -e "2. Ấn \033[1;32mEnter\033[0m để xác nhận tên file."
    echo -e "3. Ấn \033[1;32mCtrl + X\033[0m để thoát ra ngoài."
    echo -e "\033[1;33m--------------------------\033[0m"
  fi

  echo -e "\n\033[1;31mHãy cẩn thận khi chỉnh sửa quy tắc chuyển hướng (Rewrite) !!\033[0m"
  echo "Đang mở trình soạn thảo..."
  sleep 3

  # Lấy MD5 trước khi sửa (Lưu trên RAM)
  old_md5=$(md5sum "$htaccess_file" | awk '{print $1}')

  # Mở Trình soạn thảo
  $editor_cau_hinh "$htaccess_file"

  # Lấy MD5 sau khi sửa để đối chiếu
  new_md5=$(md5sum "$htaccess_file" | awk '{print $1}')

  if [[ "$old_md5" != "$new_md5" ]]; then
    UI_STRING="Đang cập nhật cấu hình .htaccess cho $NAME"
    _runing "$UI_STRING"

    # Kiểm tra tính năng htaccess tĩnh (chuyển đổi Vhost)
    unset vhost_chuyen_htaccess
    . "/etc/wptt/vhost/.$NAME.conf" 2>/dev/null

    if [[ -n "$vhost_chuyen_htaccess" ]]; then
      # Nếu đang dùng htaccess tĩnh -> Bắt buộc chạy script nạp lại config
      /etc/wptt/wptt-htaccess-tat-chuyen-doi-vhost "$NAME" >/dev/null 2>&1
    else
      /usr/local/lsws/bin/lswsctrl reload >/dev/null 2>&1
    fi

    _rundone "$UI_STRING"
    echo "Chỉnh sửa .htaccess website $NAME : $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log

  else
    echo -e "\n\033[1;36mKhông có sự thay đổi nào được thực hiện.\033[0m"
    sleep 2
  fi
fi

[[ ${1:-} == "98" ]] && exec /etc/wptt/wptt-cau-hinh-websever-main 1
