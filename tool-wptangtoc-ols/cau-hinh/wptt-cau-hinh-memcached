#!/bin/bash

function huong_dan() {
  Tính năng Cấu hình Memcached là quá trình điều chỉnh các thiết lập và tham số hoạt động của máy chủ Memcached để tối ưu hóa hiệu suất, quản lý chặt chẽ bộ nhớ RAM, thiết lập kết nối mạng, và tùy chỉnh các khía cạnh khác cho phù hợp với nhu cầu sử dụng [use case] cụ thể của hệ thống.

  Nói một cách đơn giản, đây là việc bạn tinh chỉnh các nút vặn của Memcached – một hệ thống bộ nhớ đệm [cache] phân tán siêu tốc – để nó hoạt động mượt mà nhất, sử dụng RAM hợp lý nhất và phục vụ tốt nhất cho các ứng dụng web [ví dụ: lưu kết quả truy vấn database, object cache cho WordPress].

  Mục Đích Chính
  * Quản lý bộ nhớ [RAM] và Kích thước Cache:
  * -m [Cachesize]: Đặt giới hạn bộ nhớ RAM tối đa [tính bằng MB] mà Memcached được phép sử dụng. Khi bộ nhớ đầy, nó sẽ tự động xóa các dữ liệu cũ nhất theo cơ chế LRU [Least Recently Used].
  * -I [Item size]: Điều chỉnh kích thước tối đa của một đối tượng lưu trữ [mặc định là 1MB, có thể tăng lên nếu website có các cục dữ liệu lớn].
  * Cấu hình Mạng và Kết nối:
  * -s [Unix Socket] hoặc -p [Port]: Ưu tiên sử dụng Unix Socket [/var/run/memcached/memcached.sock] để tăng tốc độ kết nối nội bộ, hoặc mở cổng mạng [mặc định 11211].
  * -c [Max connections]: Đặt giới hạn số lượng kết nối đồng thời tối đa từ các client/ứng dụng đến máy chủ Cache.
  * Tối ưu Hiệu suất đa luồng [Multi-threading]:
  * -t [Threads]: Chỉ định số lượng luồng xử lý yêu cầu, giúp Memcached tận dụng tối đa sức mạnh của CPU đa nhân [multi-core].
  * Tăng cường bảo mật và Quyền hạn:
  * -u [User]: Chỉ định tài khoản hệ thống chạy tiến trình Memcached [ví dụ: user memcached] để giới hạn quyền hạn, thay vì chạy bằng quyền root.
  * -l [Listen]: Giới hạn địa chỉ IP mà Memcached lắng nghe [thường là 127.0.0.1] để ngăn chặn truy cập trái phép từ internet.
  * Thiết lập Logging: Định hướng các bản ghi hoạt động và cảnh báo lỗi vào file log [logfile] để dễ dàng theo dõi và gỡ lỗi.

  Sau khi cấu hình, máy chủ Memcached sẽ hoạt động với hiệu suất cao nhất, sử dụng tài nguyên RAM một cách có kiểm soát và cung cấp tốc độ phản hồi siêu tốc cho hệ thống website của bạn.

  Ghi chú: Phải cài đặt dịch vụ Memcached trước đó thì bạn mới có thể tiến hành cấu hình.
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null # Nạp thư viện UI Xác nhận

clear
echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}${cau_hinh_webserver} ➜ Chỉnh sửa cấu hình Memcached${C_RESET}"
echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

name_service='Memcached'

# ==============================================================================
# NHẬN DIỆN ĐƯỜNG DẪN CẤU HÌNH
# ==============================================================================
if cat /etc/*release 2>/dev/null | grep -qi "Ubuntu"; then
  duong_path_memcached_config="/etc/memcached.conf"
else
  duong_path_memcached_config="/etc/sysconfig/memcached"
fi

if [[ ! -f "${duong_path_memcached_config}" ]]; then
  echo -e "${C_RED}❌ Lỗi: Hệ thống chưa cài đặt hoặc chưa kích hoạt dịch vụ Memcached!${C_RESET}"
  sleep 3
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-cau-hinh-websever-main 1
  exit 1
fi

# ==============================================================================
# HIỂN THỊ BẢNG TRẠNG THÁI (UX BO CONG)
# ==============================================================================
echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
left_text "Trạng thái    : ${C_GREEN}Hệ thống đang chạy Memcached${C_RESET}" 2
left_text "File cấu hình : ${C_YELLOW}$duong_path_memcached_config${C_RESET}" 2
echo -e "${C_CYAN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
left_text "WPTangToc OLS đã cấu hình sẵn bộ nhớ MAXCONN và CACHESIZE." 2
left_text "Chỉ chỉnh sửa khi bạn có nhu cầu đặc biệt và hiểu rõ hệ thống." 2
echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

# ==============================================================================
# XÁC NHẬN BẢO MẬT & HƯỚNG DẪN TRÌNH SOẠN THẢO
# ==============================================================================
if wptt_xac_nhan "Bạn có CHẮC CHẮN muốn mở và chỉnh sửa cấu hình Memcached không?" "CẢNH BÁO: Thiết lập sai tham số RAM có thể làm Memcached không thể" "khởi động lại. Chỉ chỉnh sửa khi bạn thực sự hiểu rõ." "Đồng ý Chỉnh sửa" "Hủy thao tác"; then
  echo ""

  [[ -z "$editor_cau_hinh" ]] && editor_cau_hinh="nano"

  # Khung hướng dẫn phím tắt Nano
  if [[ "$editor_cau_hinh" == "nano" ]]; then
    echo -e "${C_GREEN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
    center_text "${C_BOLD_WHITE}HƯỚNG DẪN LƯU FILE BẰNG NANO${C_RESET}"
    echo -e "${C_GREEN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
    left_text "1. Chỉnh sửa xong, ấn tổ hợp phím  : ${C_YELLOW}Ctrl + O${C_RESET}" 4
    left_text "2. Hệ thống hỏi tên file, ấn phím  : ${C_YELLOW}Enter${C_RESET}" 4
    left_text "3. Thoát ra ngoài Menu, ấn tổ hợp  : ${C_YELLOW}Ctrl + X${C_RESET}" 4
    echo -e "${C_GREEN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"
  else
    echo -e "${C_YELLOW}Đang mở trình soạn thảo: $editor_cau_hinh${C_RESET}\n"
  fi

  echo -e "${C_CYAN}Đang chuẩn bị dữ liệu và mở file cấu hình...${C_RESET}"
  sleep 3

  # Lấy MD5 trước khi sửa (Lưu trên RAM)
  old_md5=$(md5sum "$duong_path_memcached_config" | awk '{print $1}')

  # ==============================================================================
  # MỞ TRÌNH SOẠN THẢO
  # ==============================================================================
  $editor_cau_hinh "$duong_path_memcached_config"
  clear # Xóa màn hình sau khi Nano thoát ra để giao diện sạch sẽ

  # ==============================================================================
  # KIỂM TRA SỰ THAY ĐỔI VÀ KHỞI ĐỘNG LẠI DỊCH VỤ
  # ==============================================================================
  echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_YELLOW}ĐANG KIỂM TRA SỰ THAY ĐỔI DỮ LIỆU${C_RESET}"
  echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

  new_md5=$(md5sum "$duong_path_memcached_config" | awk '{print $1}')

  if [[ "$old_md5" != "$new_md5" ]]; then
    _runing "Nạp lại cấu hình mới cho $name_service (Restart)..."

    systemctl restart memcached.service >/dev/null 2>&1

    echo "Cấu hình lại $name_service : $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log
    _rundone "Nạp lại cấu hình mới cho $name_service (Restart)..."

    # BẢNG BÁO CÁO THÀNH CÔNG
    echo -e "\n${C_GREEN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
    center_text "${C_BOLD_WHITE}CẬP NHẬT CẤU HÌNH THÀNH CÔNG${C_RESET}"
    echo -e "${C_GREEN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
    left_text "Dịch vụ $name_service đã được khởi động lại để áp dụng" 2
    left_text "các thông số cấu hình mới nhất của bạn." 2
    echo -e "${C_GREEN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

  else
    echo -e "${C_YELLOW}💡 Không có sự thay đổi nào được phát hiện trong file. Bỏ qua bước nạp lại.${C_RESET}\n"
  fi

else
  echo -e "${C_YELLOW}Đã hủy thao tác chỉnh sửa cấu hình Memcached.${C_RESET}\n"
fi

[[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-cau-hinh-websever-main 1
