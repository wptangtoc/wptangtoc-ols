function huong_dan() {
  Tính năng Sửa cấu hình OpenLiteSpeed là quá trình điều chỉnh các thiết lập và tham số của máy chủ web OpenLiteSpeed để tùy biến cách nó hoạt động, hiệu suất, bảo mật, và cách nó phục vụ các website được lưu trữ trên đó.

  Nói một cách đơn giản, OpenLiteSpeed [OLS] là một đầu bếp hiệu suất cao cho website của bạn. Sửa cấu hình là việc bạn hướng dẫn đầu bếp này cách nấu nướng [phục vụ website], bảo quản nguyên liệu [quản lý cache], đảm bảo an toàn vệ sinh [bảo mật], và tối ưu gian bếp [hiệu suất] cho phù hợp nhất.

  Mục Đích Chính
  * Thiết lập Website [Virtual Hosts]: Định nghĩa cách OLS phục vụ các tên miền [website] khác nhau, bao gồm thư mục gốc chứa website, cổng lắng nghe, và các cài đặt riêng cho từng trang.
  * Tối ưu hiệu suất: Điều chỉnh các thông số liên quan đến xử lý kết nối, bộ nhớ đệm [LSCache - một điểm mạnh của LiteSpeed], xử lý PHP, nén GZIP để website chạy nhanh và hiệu quả hơn.
  * Tăng cường bảo mật: Cấu hình các tính năng bảo mật như chứng chỉ SSL/TLS [cho HTTPS], kiểm soát truy cập, chống lại các kiểu tấn công web phổ biến.
  * Tích hợp và Cấu hình PHP: Thiết lập cách OLS làm việc với PHP [thường qua LSAPI], chọn phiên bản PHP, cấu hình các tiến trình PHP.
  * Quản lý Cache [LSCache]: Bật và tinh chỉnh LiteSpeed Cache, một cơ chế cache mạnh mẽ ở cấp độ máy chủ giúp tăng tốc đáng kể các ứng dụng web động [như WordPress].
  * Quản lý Log: Cấu hình file log truy cập, log lỗi.
  * Thiết lập Listeners: Định nghĩa các địa chỉ IP và cổng mà máy chủ sẽ lắng nghe yêu cầu [ví dụ: cổng 80 cho HTTP, cổng 443 cho HTTPS].

  Sau khi cấu hình, máy chủ OpenLiteSpeed sẽ được tối ưu để phục vụ các website cụ thể một cách hiệu quả, an toàn, và với hiệu suất cao theo đúng yêu cầu của bạn.
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null # Nạp thư viện UI Xác nhận

clear
echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}${cau_hinh_webserver} ➜ Chỉnh sửa file OpenLiteSpeed gốc${C_RESET}"
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

# ==============================================================================
# XÁC NHẬN BẢO MẬT & HƯỚNG DẪN TRÌNH SOẠN THẢO
# ==============================================================================
if wptt_xac_nhan "Bạn có CHẮC CHẮN muốn mở và chỉnh sửa HTTPD không?" "CẢNH BÁO NGUY HIỂM: File cấu hình HTTPD gốc rất nhạy cảm." "Chỉ một sai sót nhỏ cũng có thể làm sập toàn bộ hệ thống Webserver" "Đồng ý Chỉnh sửa" "Hủy thao tác"; then
  echo ""

  [[ -z "$editor_cau_hinh" ]] && editor_cau_hinh="nano"

  # Khung hướng dẫn phím tắt Nano (UX Bo Cong)
  if [[ "$editor_cau_hinh" == "nano" ]]; then
    echo -e "${C_GREEN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
    center_text "${C_BOLD_WHITE}HƯỚNG DẪN LƯU FILE BẰNG NANO${C_RESET}"
    echo -e "${C_GREEN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
    left_text "1. Chỉnh sửa xong, ấn tổ hợp phím  : ${C_YELLOW}Ctrl + O${C_RESET}" 4
    left_text "2. Hệ thống hỏi tên file, ấn phím  : ${C_YELLOW}Enter${C_RESET}" 4
    left_text "3. Thoát ra ngoài Menu, ấn tổ hợp  : ${C_YELLOW}Ctrl + X${C_RESET}" 4
    echo -e "${C_GREEN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"
  else
    echo -e "${C_YELLOW}Đang mở trình soạn thảo: $editor_cau_hinh${C_RESET}\n"
  fi

  echo -e "${C_CYAN}Đang chuẩn bị dữ liệu và mở file...${C_RESET}"
  sleep 3

  config_path="/usr/local/lsws/conf/httpd_config.conf"

  # Lấy mã băm MD5 trước khi sửa (Lưu trên RAM)
  old_md5=$(md5sum "$config_path" | awk '{print $1}')

  # ==============================================================================
  # MỞ TRÌNH SOẠN THẢO
  # ==============================================================================
  $editor_cau_hinh "$config_path"
  clear # Xóa màn hình sau khi Nano thoát ra để giao diện sạch sẽ

  # ==============================================================================
  # KIỂM TRA MD5 VÀ SYNTAX (CHỐNG SẬP WEBSERVER)
  # ==============================================================================
  echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_YELLOW}ĐANG KIỂM TRA SỰ THAY ĐỔI VÀ CÚ PHÁP${C_RESET}"
  echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

  new_md5=$(md5sum "$config_path" | awk '{print $1}')

  if [[ "$old_md5" != "$new_md5" ]]; then
    UI_STRING="Đang phân tích cú pháp cấu hình (Syntax Check)..."
    _runing "$UI_STRING"

    # Kiểm tra cú pháp an toàn tuyệt đối
    syntax_check=$(/usr/local/lsws/bin/openlitespeed -t 2>&1)
    _rundone "$UI_STRING"

    if echo "$syntax_check" | grep -q "ERROR\|WARN"; then
      echo "Cấu hình lại Litespeed Webserver làm gây ra lỗi : $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log

      echo -e "\n${C_RED}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
      center_text "${C_BOLD_WHITE}LỖI CÚ PHÁP NGHIÊM TRỌNG ĐÃ XẢY RA${C_RESET}"
      echo -e "${C_RED}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
      left_text "${C_YELLOW}Hệ thống đã HỦY LỆNH RELOAD để bảo vệ website của bạn khỏi bị sập!${C_RESET}" 2
      left_text "Chi tiết mã lỗi từ OpenLiteSpeed:" 2
      echo -e "${C_RED}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"

      # In chi tiết lỗi ra màn hình cho người dùng đọc
      while IFS= read -r line; do
        printf "${C_RED}│${C_RESET}  %-69s${C_RED}│${C_RESET}\n" "$line"
      done <<<"$syntax_check"

      echo -e "${C_RED}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
      left_text "Hãy vào và sửa lại HTTPD OpenLiteSpeed cho đúng nhé!"
      echo -e "${C_RED}╰───────────────────────────────────────────────────────────────────────╯${C_RESET}"

      [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-cau-hinh-websever-main 1
      exit 1
    else
      # Nếu cấu hình chuẩn xác -> Reload an toàn (Zero-Downtime)

      _runing "Đang nạp lại cấu hình mới cho OpenLiteSpeed..."
      /usr/local/lsws/bin/lswsctrl reload >/dev/null 2>&1
      echo "Cấu hình lại Litespeed Webserver thành công : $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log
      _rundone "Đang nạp lại cấu hình mới cho OpenLiteSpeed..."

      echo -e "\n${C_GREEN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
      center_text "${C_BOLD_WHITE}CẬP NHẬT CẤU HÌNH THÀNH CÔNG${C_RESET}"
      echo -e "${C_GREEN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
      left_text "Trạng thái : Các thay đổi đã được áp dụng mượt mà không gây gián đoạn." 2
      echo -e "${C_GREEN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"
    fi
  else
    echo -e "${C_YELLOW}Không có sự thay đổi nào được phát hiện trong file. Bỏ qua bước nạp lại.${C_RESET}\n"
  fi

else
  echo -e "${C_YELLOW}Đã hủy thao tác chỉnh sửa cấu hình.${C_RESET}\n"
fi

[[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-cau-hinh-websever-main 1
