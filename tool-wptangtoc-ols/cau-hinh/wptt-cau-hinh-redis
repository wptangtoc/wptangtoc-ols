#!/bin/bash
function huong_dan() {
  Tính năng Cấu hình Object Cache [Redis/Valkey/KeyDB] là quá trình điều chỉnh các thiết lập và tham số hoạt động của máy chủ Cache để tối ưu hóa hiệu suất, quản lý bộ nhớ, đảm bảo độ bền dữ liệu [persistence], tăng cường bảo mật, và tùy chỉnh các khía cạnh khác cho phù hợp với nhu Hướng dẫn sử dụng [use case] cụ thể của bạn.

  Nói một cách đơn giản, đây là việc bạn tinh chỉnh các nút vặn của bộ nhớ đệm để nó hoạt động hiệu quả nhất, an toàn nhất và đáp ứng đúng yêu cầu của ứng dụng đang sử dụng nó.

  Mục Đích Chính
  * Tối ưu hiệu suất: Điều chỉnh các cài đặt để phản hồi nhanh nhất có thể.
  * Quản lý bộ nhớ [RAM]:
  * maxmemory: Đặt giới hạn bộ nhớ tối đa được phép sử dụng.
  * maxmemory-policy: Quy định cách xử lý khi đạt đến giới hạn bộ nhớ [ví dụ: xóa các key ít dùng nhất - allkeys-lru].
  * Thiết lập Logging: Cấu hình ghi log để theo dõi và gỡ lỗi.

  Ghi chú: Phải cài đặt dịch vụ Object Cache trước đó thì bạn mới có thể cấu hình được.
}

. /etc/wptt/echo-color

# =========================================================================
# NHẬN DIỆN ENGINE ĐANG HOẠT ĐỘNG (RADAR)
# =========================================================================
name_service=""
ten_hien_thi=""

if systemctl is-active --quiet valkey 2>/dev/null || [[ -d /etc/valkey ]]; then
  name_service="valkey"
  ten_hien_thi="Valkey"
elif systemctl is-active --quiet keydb 2>/dev/null || [[ -d /etc/keydb ]]; then
  name_service="keydb"
  ten_hien_thi="KeyDB"
elif systemctl is-active --quiet redis 2>/dev/null || systemctl is-active --quiet redis-server 2>/dev/null || [[ -d /etc/redis ]]; then
  name_service="redis"
  ten_hien_thi="Redis"
fi

echo ""
echo ""
echo ""
echo "========================================================================="
if [[ -n "$ten_hien_thi" ]]; then
  echo "|Cấu hình webserver => Cấu hình $ten_hien_thi                               |"
else
  echo "|Cấu hình webserver => Cấu hình Object Cache (Chưa cài đặt)             |"
fi
echo "========================================================================="
echo ""
echo ""

if [[ -z "$name_service" ]]; then
  echoDo "Hệ thống chưa cài đặt hoặc chưa kích hoạt bất kỳ dịch vụ Object Cache nào (Redis/Valkey/KeyDB)!"
  exit
fi

# =========================================================================
# XÁC ĐỊNH ĐƯỜNG DẪN CONFIG THÔNG MINH (KẾT HỢP FALLBACK)
# =========================================================================
duong_dan_config_redis="/etc/$name_service/$name_service.conf"

if $(cat /etc/*release | grep -q "AlmaLinux 8\|Rocky Linux 8\|Red Hat Enterprise Linux 8\|Oracle Linux Server 8") && [[ $name_service = 'redis' ]]; then
  duong_dan_config_redis="/etc/$name_service.conf"
fi

# Fallback sửa lỗi đường dẫn nếu package cài đặt cấu trúc khác
if [[ ! -f "$duong_dan_config_redis" && -f "/etc/$name_service.conf" ]]; then
  duong_dan_config_redis="/etc/$name_service.conf"
elif [[ ! -f "$duong_dan_config_redis" && -f "/etc/$name_service/$name_service.conf" ]]; then
  duong_dan_config_redis="/etc/$name_service/$name_service.conf"
fi

if [[ ! -f "${duong_dan_config_redis}" ]]; then
  echoDo "Không tìm thấy file cấu hình của $ten_hien_thi tại đường dẫn dự kiến!"
  exit
fi

echo "Mọi cấu hình, mình đã cấu hình tối ưu, nếu bạn có nhu cầu đặc biệt bạn có thể tự sửa"
echo "Lưu ý: hãy thật sự cẩn thân khi sửa cấu hình hệ thống"
sleep 2

prompt="$nhap_lua_chon_cua_ban [1-2]: "
dongy="n"
options=("$dong_y" "$khong_dong_y")
PS3="$prompt"
select opt in "${options[@]}"; do
  case "$REPLY" in
  1)
    dongy="y"
    break
    ;;
  2)
    dongy="n"
    break
    ;;
  *)
    printf "\n$ban_nhap_sai_he_thong_se_chon_khong_dong_y\n"
    break
    ;;
  esac
done

if [[ "$dongy" = "y" ]]; then
  . /etc/wptt/.wptt.conf
  if [[ $editor_cau_hinh = "" ]]; then
    editor_cau_hinh="nano"
  fi
  echo '                                              
                    ::::                    
                   :-::-:                   
        ..      ..::::::::::..      ..        
       :-:-:..:----::::::::---::..:-:-:       
       .:::::--:..          ..:--:::::.       
        .::::.                  :::::.        
        ::::                     .::::        
       ::::       .-=++++=-.       ::::       
      .-::       =*******##*=       ::-.      
  ..::::-.      +********:.+#=      ::::::..  
  ---:::-.     .***=-**- .=*** .-:::---  
  ..::::-.      +**=.  .=****=      ::::::..  
      .-::      .+*#*==*****=       ::-.      
       ::::       :=+***++-.       ::::       
        ::::                      ::::        
        .::::.                  :::::.        
       .:::::--:.            .:--:::::.       
       :-:-:..::--::::..:::---::..:-:-:       
        ..       ..::::::::..       ..        
                    .::::.                    
                     ::::                     
                                              
'
  echo "Sử dụng công cụ editor: $editor_cau_hinh để chỉnh sửa"
  if [[ $editor_cau_hinh = "nano" ]]; then
    RED='\033[0;31m'
    GREEN='\033[0;32m'
    YELLOW='\033[0;33m'
    CYAN='\033[0;36m'
    NC='\033[0m'
    echo -e "${YELLOW}--- HƯỚNG DẪN LƯU FILE ---${NC}"
    echo -e "1. Chỉnh sửa xong, ấn ${GREEN}Ctrl + O${NC} để lưu."
    echo -e "2. Ấn ${GREEN}Enter${NC} để xác nhận tên file."
    echo -e "3. Ấn ${GREEN}Ctrl + X${NC} để thoát ra ngoài."
    echo -e "${YELLOW}--------------------------${NC}"
    echo "Đang mở trình soạn thảo..."

    echoVang "Hãy cẩn thận khi chỉnh sửa lại ${ten_hien_thi}!!"
    sleep 3
  fi
  sleep 2

  check_thay_doi=$(md5sum $duong_dan_config_redis | cut -f1 -d ' ' >/tmp/redis_cau_hinh_wptangtoc)
  $editor_cau_hinh $duong_dan_config_redis

  if [[ $(cat /tmp/redis_cau_hinh_wptangtoc) != $(md5sum $duong_dan_config_redis | cut -f1 -d ' ') ]]; then
    . /etc/wptt/echo-color
    _runing "Khởi động lại ${ten_hien_thi} để cập nhật giá trị"

    # Tương thích tên service riêng cho Ubuntu nếu dùng Redis
    if [[ "$name_service" == "redis" ]] && $(cat /etc/*release | grep -q "Ubuntu"); then
      systemctl restart redis-server.service
    else
      systemctl restart ${name_service}.service
    fi

    _rundone "Khởi động lại ${ten_hien_thi} để cập nhật giá trị"
    echo "Cấu hình lại ${ten_hien_thi} : $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log
  fi
else
  exec /etc/wptt/wptt-cau-hinh-websever-main 1
fi

check_menu_wptangtoc_active=$1
if [[ $check_menu_wptangtoc_active = "98" ]]; then
  exec /etc/wptt/wptt-cau-hinh-websever-main 1
fi
