#!/bin/bash
function huong_dan() {
  Tính năng Cấu hình Object Cache [Redis/Valkey/KeyDB] là quá trình điều chỉnh các thiết lập và tham số hoạt động của máy chủ Cache để tối ưu hóa hiệu suất, quản lý bộ nhớ, đảm bảo độ bền dữ liệu [persistence], tăng cường bảo mật, và tùy chỉnh các khía cạnh khác cho phù hợp với nhu Hướng dẫn sử dụng [use case] cụ thể của bạn.

  Nói một cách đơn giản, đây là việc bạn tinh chỉnh các nút vặn của bộ nhớ đệm để nó hoạt động hiệu quả nhất, an toàn nhất và đáp ứng đúng yêu cầu của ứng dụng đang sử dụng nó.

  Mục Đích Chính
  * Tối ưu hiệu suất: Điều chỉnh các cài đặt để phản hồi nhanh nhất có thể.
  * Quản lý bộ nhớ [RAM]:
  * maxmemory: Đặt giới hạn bộ nhớ tối đa được phép sử dụng.
  * maxmemory-policy: Quy định cách xử lý khi đạt đến giới hạn bộ nhớ [ví dụ: xóa các key ít dùng nhất - allkeys-lru].
  * Thiết lập Logging: Cấu hình ghi log để theo dõi và gỡ lỗi.

  Ghi chú: Phải cài đặt dịch vụ Object Cache trước đó thì bạn mới có thể cấu hình được.
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null # Nạp thư viện UI Xác nhận

clear
echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}${cau_hinh_webserver} ➜ Chỉnh sửa file Object Cache${C_RESET}"
echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

#nhận dạng service Object cache hiện tại
unset ten_hien_thi name_service
if systemctl is-active --quiet valkey 2>/dev/null || [[ -d /etc/valkey ]]; then
  name_service="valkey"
  ten_hien_thi="Valkey"
elif systemctl is-active --quiet keydb 2>/dev/null || [[ -d /etc/keydb ]]; then
  name_service="keydb"
  ten_hien_thi="KeyDB"
elif systemctl is-active --quiet redis 2>/dev/null || systemctl is-active --quiet redis-server 2>/dev/null || [[ -d /etc/redis ]]; then
  name_service="redis"
  ten_hien_thi="Redis"
fi

if [[ -z "$name_service" ]]; then
  echo -e "${C_RED}❌ Lỗi: Hệ thống chưa cài đặt hoặc chưa kích hoạt bất kỳ dịch vụ Object Cache nào (Redis/Valkey/KeyDB)!${C_RESET}"
  sleep 3
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-cau-hinh-websever-main 1
  exit 1
fi

# =========================================================================
# XÁC ĐỊNH ĐƯỜNG DẪN CONFIG THÔNG MINH
# =========================================================================
duong_dan_config_redis="/etc/$name_service/$name_service.conf"

if $(cat /etc/*release | grep -q "AlmaLinux 8\|Rocky Linux 8\|Red Hat Enterprise Linux 8\|Oracle Linux Server 8") && [[ "$name_service" == 'redis' ]]; then
  duong_dan_config_redis="/etc/$name_service.conf"
fi

# Fallback sửa lỗi đường dẫn
if [[ ! -f "$duong_dan_config_redis" && -f "/etc/$name_service.conf" ]]; then
  duong_dan_config_redis="/etc/$name_service.conf"
elif [[ ! -f "$duong_dan_config_redis" && -f "/etc/$name_service/$name_service.conf" ]]; then
  duong_dan_config_redis="/etc/$name_service/$name_service.conf"
fi

if [[ ! -f "$duong_dan_config_redis" ]]; then
  echo -e "\n${C_RED}❌ Lỗi: Không tìm thấy file cấu hình của $ten_hien_thi tại đường dẫn dự kiến!${C_RESET}"
  sleep 3
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-cau-hinh-websever-main 1
  exit 1
fi

# ==============================================================================
# HIỂN THỊ BẢNG TRẠNG THÁI (UX BO CONG)
# ==============================================================================
echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
left_text "Trạng thái    : ${C_GREEN}Hệ thống đang chạy ${ten_hien_thi}${C_RESET}" 2
left_text "File cấu hình : ${C_YELLOW}$duong_dan_config_redis${C_RESET}" 2
echo -e "${C_CYAN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
left_text "WPTangToc OLS đã tối ưu hóa sẵn mọi thông số cho VPS của bạn." 2
left_text "Chỉ chỉnh sửa khi bạn có nhu cầu đặc biệt và hiểu rõ hệ thống." 2
echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

# ==============================================================================
# XÁC NHẬN BẢO MẬT & HƯỚNG DẪN TRÌNH SOẠN THẢO
# ==============================================================================
if wptt_xac_nhan "Bạn có CHẮC CHẮN muốn mở và chỉnh sửa cấu hình $ten_hien_thi không?" "CẢNH BÁO: Cấu hình sai giới hạn bộ nhớ (maxmemory) có thể gây Crash." "Chỉ chỉnh sửa khi bạn thực sự hiểu rõ các tham số." "Đồng ý Chỉnh sửa" "Hủy thao tác"; then
  echo ""

  [[ -z "$editor_cau_hinh" ]] && editor_cau_hinh="nano"

  # Khung hướng dẫn phím tắt Nano
  if [[ "$editor_cau_hinh" == "nano" ]]; then
    echo -e "${C_GREEN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
    center_text "${C_BOLD_WHITE}HƯỚNG DẪN LƯU FILE BẰNG NANO${C_RESET}"
    echo -e "${C_GREEN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
    left_text "1. Chỉnh sửa xong, ấn tổ hợp phím  : ${C_YELLOW}Ctrl + O${C_RESET}" 4
    left_text "2. Hệ thống hỏi tên file, ấn phím  : ${C_YELLOW}Enter${C_RESET}" 4
    left_text "3. Thoát ra ngoài Menu, ấn tổ hợp  : ${C_YELLOW}Ctrl + X${C_RESET}" 4
    echo -e "${C_GREEN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"
  else
    echo -e "${C_YELLOW}Đang mở trình soạn thảo: $editor_cau_hinh${C_RESET}\n"
  fi

  echo -e "${C_CYAN}Đang chuẩn bị dữ liệu và mở file cấu hình...${C_RESET}"
  sleep 3

  # Lấy MD5 trước lưu vào ram
  old_md5=$(md5sum "$duong_dan_config_redis" | awk '{print $1}')

  # ==============================================================================
  # MỞ TRÌNH SOẠN THẢO
  # ==============================================================================
  $editor_cau_hinh "$duong_dan_config_redis"
  clear # Xóa màn hình sau khi Nano thoát ra để giao diện sạch sẽ

  # ==============================================================================
  # KIỂM TRA SỰ THAY ĐỔI VÀ KHỞI ĐỘNG LẠI DỊCH VỤ
  # ==============================================================================
  echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_YELLOW}ĐANG KIỂM TRA SỰ THAY ĐỔI DỮ LIỆU${C_RESET}"
  echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

  new_md5=$(md5sum "$duong_dan_config_redis" | awk '{print $1}')

  if [[ "$old_md5" != "$new_md5" ]]; then
    _runing "Nạp lại cấu hình mới cho $ten_hien_thi (Restart)..."

    # Tương thích tên service riêng cho Ubuntu nếu dùng Redis
    if [[ "$name_service" == "redis" ]] && grep -qi "ubuntu" /etc/os-release 2>/dev/null; then
      systemctl restart redis-server.service
    else
      systemctl restart "${name_service}.service"
    fi

    echo "Cấu hình lại ${ten_hien_thi} : $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log
    _rundone "Nạp lại cấu hình mới cho $ten_hien_thi (Restart)..."

    # BẢNG BÁO CÁO THÀNH CÔNG
    echo -e "\n${C_GREEN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
    center_text "${C_BOLD_WHITE}CẬP NHẬT CẤU HÌNH THÀNH CÔNG${C_RESET}"
    echo -e "${C_GREEN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
    left_text "Dịch vụ $ten_hien_thi đã được khởi động lại để áp dụng" 2
    left_text "các thông số cấu hình mới nhất của bạn." 2
    echo -e "${C_GREEN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

  else
    echo -e "${C_YELLOW}Không có sự thay đổi nào được phát hiện trong file. Bỏ qua bước nạp lại.${C_RESET}\n"
  fi

else
  echo -e "${C_YELLOW}Đã hủy thao tác chỉnh sửa cấu hình Object Cache.${C_RESET}\n"
fi

[[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-cau-hinh-websever-main 1
