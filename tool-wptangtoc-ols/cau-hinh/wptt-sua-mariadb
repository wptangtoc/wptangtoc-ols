function huong_dan() {
  Tính năng Cấu hình MariaDB là quá trình điều chỉnh các tham số và cài đặt hoạt động của máy chủ cơ sở dữ liệu MariaDB để tối ưu hóa hiệu suất, tăng cường bảo mật, quản lý tài nguyên và đảm bảo nó hoạt động ổn định theo nhu cầu cụ thể của bạn.

  Nói một cách đơn giản, đây là việc bạn tinh chỉnh các nút vặn bên trong MariaDB để nó chạy nhanh nhất, an toàn nhất và phù hợp nhất với website hoặc ứng dụng mà nó phục vụ, cũng như với phần cứng của máy chủ.

  Mục Đích Chính
  * Tối ưu hiệu suất [Performance Tuning]: Điều chỉnh các cài đặt liên quan đến bộ nhớ đệm [ví dụ: innodb_buffer_pool_size], cách xử lý luồng, query cache,... để MariaDB xử lý truy vấn nhanh hơn.
  * Tăng cường bảo mật [Security Hardening]: Cấu hình các tùy chọn bảo mật như giới hạn kết nối mạng, vô hiệu hóa đăng nhập từ xa của user root, kích hoạt SSL/TLS, quản lý quyền người dùng.
  * Quản lý tài nguyên: Kiểm soát lượng RAM, dung lượng đĩa, CPU mà MariaDB sử dụng.
  * Đảm bảo tính ổn định và tin cậy: Cấu hình cho việc phục hồi sau sự cố tốt hơn [đặc biệt với InnoDB/Aria].
  * Thiết lập Logging: Bật và cấu hình các loại log [error log, slow query log, binary log] để theo dõi, gỡ lỗi và phục vụ cho việc sao chép [replication].
  * Cấu hình Replication/Clustering: Thiết lập các thông số cho việc nhân bản dữ liệu giữa các server.
  * Tùy chỉnh Storage Engine: Đặt storage engine mặc định hoặc tinh chỉnh các tham số riêng cho InnoDB, Aria, MyISAM.

  Sau khi cấu hình, máy chủ MariaDB sẽ được điều chỉnh tốt hơn cho khối lượng công việc cụ thể, hoạt động an toàn hơn, ổn định hơn và đáp ứng đúng các yêu cầu của quản trị viên và ứng dụng. Việc cấu hình đòi hỏi hiểu biết về MariaDB và tác động của từng tham số.
}

#!/bin/bash
# @author: Gia Tuấn
# @website: https://wptangtoc.com
# @email: giatuan@wptangtoc.com
# @since: 2026

function huong_dan() {
  # Tính năng Cấu hình MariaDB là quá trình điều chỉnh các tham số...
  :
}

# ==============================================================================
# NẠP CẤU HÌNH, NGÔN NGỮ VÀ MÀU SẮC
# ==============================================================================
. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null # Nạp thư viện UI Xác nhận

clear
echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}${cau_hinh_webserver} ➜ Chỉnh sửa file MariaDB Database${C_RESET}"
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

if wptt_xac_nhan "Bạn có CHẮC CHẮN muốn mở và chỉnh sửa cấu hình MariaDB không?" "CẢNH BÁO NGUY HIỂM: File cấu hình Database (my.cnf) rất nhạy cảm." "Chỉ một sai sót nhỏ cũng có thể làm sập toàn bộ Cơ sở dữ liệu!" "Đồng ý Chỉnh sửa" "Hủy thao tác"; then
  echo ""

  [[ -z "$editor_cau_hinh" ]] && editor_cau_hinh="nano"

  # Khung hướng dẫn phím tắt Nano (UX Bo Cong)
  if [[ "$editor_cau_hinh" == "nano" ]]; then
    echo -e "${C_GREEN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
    center_text "${C_BOLD_WHITE}HƯỚNG DẪN LƯU FILE BẰNG NANO${C_RESET}"
    echo -e "${C_GREEN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
    left_text "1. Chỉnh sửa xong, ấn tổ hợp phím  : ${C_YELLOW}Ctrl + O${C_RESET}" 4
    left_text "2. Hệ thống hỏi tên file, ấn phím  : ${C_YELLOW}Enter${C_RESET}" 4
    left_text "3. Thoát ra ngoài Menu, ấn tổ hợp  : ${C_YELLOW}Ctrl + X${C_RESET}" 4
    echo -e "${C_GREEN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"
  else
    echo -e "${C_YELLOW}Đang mở trình soạn thảo: $editor_cau_hinh${C_RESET}\n"
  fi

  echo -e "${C_CYAN}Đang chuẩn bị dữ liệu và mở file...${C_RESET}"
  sleep 3

  # Nhận diện đường dẫn config theo OS
  if grep -qi "ubuntu" /etc/os-release 2>/dev/null; then
    duong_dan_cau_hinh_mariadb="/etc/mysql/my.cnf"
  else
    duong_dan_cau_hinh_mariadb="/etc/my.cnf.d/server.cnf"
  fi

  # Lấy mã băm MD5 trước khi sửa (Lưu trên RAM)
  old_md5=$(md5sum "$duong_dan_cau_hinh_mariadb" | awk '{print $1}')

  # ==============================================================================
  # MỞ TRÌNH SOẠN THẢO
  # ==============================================================================
  $editor_cau_hinh "$duong_dan_cau_hinh_mariadb"
  clear # Xóa màn hình sau khi Nano thoát ra để giao diện sạch sẽ

  # ==============================================================================
  # KIỂM TRA MD5 VÀ SYNTAX (CHỐNG SẬP DATABASE)
  # ==============================================================================
  echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_YELLOW}ĐANG KIỂM TRA SỰ THAY ĐỔI VÀ CÚ PHÁP${C_RESET}"
  echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

  new_md5=$(md5sum "$duong_dan_cau_hinh_mariadb" | awk '{print $1}')

  if [[ "$old_md5" != "$new_md5" ]]; then
    UI_STRING="Đang phân tích cú pháp cấu hình (Syntax Check)..."
    _runing "$UI_STRING"

    # Bắt lỗi cú pháp thông qua Exit Code của mariadbd
    loi_chi_tiet=$(mariadbd --help --verbose 2>&1 >/dev/null)
    exit_status=$?

    _rundone "$UI_STRING"

    if [[ $exit_status -ne 0 ]]; then
      echo "Cấu hình lại Mariadb làm gây ra lỗi : $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log

      echo -e "\n${C_RED}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
      center_text "${C_BOLD_WHITE}LỖI CÚ PHÁP NGHIÊM TRỌNG ĐÃ XẢY RA${C_RESET}"
      echo -e "${C_RED}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
      left_text "${C_YELLOW}Hệ thống đã HỦY LỆNH RESTART để bảo vệ Database của bạn khỏi bị sập!${C_RESET}" 2
      left_text "Chi tiết mã lỗi từ MariaDB:" 2
      echo -e "${C_RED}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"

      # In chi tiết lỗi ra màn hình cho người dùng đọc
      while IFS= read -r line; do
        if [[ -n "$line" ]]; then
          printf "${C_RED}│${C_RESET}  %-69s${C_RED}│${C_RESET}\n" "${line:0:69}" # Cắt chuỗi nếu quá dài
        fi
      done <<<"$loi_chi_tiet"

      echo -e "${C_RED}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
      left_text "Hãy vào và sửa lại MariaDB my.cnf cho đúng nhé!"
      echo -e "${C_RED}╰───────────────────────────────────────────────────────────────────────╯${C_RESET}"

      [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-cau-hinh-websever-main 1
      exit 1
    else
      # Nếu cấu hình chuẩn xác -> Khởi động lại

      _runing "Nạp lại cấu hình mới cho MariaDB (Restart)..."
      systemctl restart mariadb >/dev/null 2>&1
      echo "Cấu hình lại MariaDB thành công : $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log
      _rundone "Nạp lại cấu hình mới cho MariaDB (Restart)..."

      echo -e "${C_GREEN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
      center_text "${C_BOLD_WHITE}CẬP NHẬT CẤU HÌNH THÀNH CÔNG${C_RESET}"
      echo -e "${C_GREEN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
      left_text "Trạng thái : Database đã được khởi động lại với thông số mới." 2
      echo -e "${C_GREEN}╰───────────────────────────────────────────────────────────────────────╯${C_RESET}"
    fi
  else
    echo -e "${C_YELLOW}Không có sự thay đổi nào được phát hiện trong file. Bỏ qua bước nạp lại.${C_RESET}\n"
  fi

else
  echo -e "${C_YELLOW}Đã hủy thao tác chỉnh sửa cấu hình.${C_RESET}\n"
fi

[[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-cau-hinh-websever-main 1
