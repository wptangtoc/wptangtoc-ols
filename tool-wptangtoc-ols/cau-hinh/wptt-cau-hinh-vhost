function huong_dan() {
  Tính năng Sửa cấu hình OpenLiteSpeed vhost website là việc thiết lập hoặc điều chỉnh các cài đặt cho một Virtual Host [viết tắt là vhost] cụ thể trên máy chủ OpenLiteSpeed. Mỗi vhost đại diện cho một website [một tên miền hoặc tên miền phụ] riêng biệt mà bạn muốn máy chủ phục vụ.

  Nói một cách đơn giản, nếu OpenLiteSpeed là một chung cư lớn, thì mỗi căn hộ [website] trong đó sẽ có một bảng nội quy [cấu hình vhost] riêng. Sửa cấu hình vhost chính là việc bạn tùy chỉnh bảng nội quy cho từng căn hộ đó.

  Mục Đích Chính [Các Cài Đặt Quan Trọng Trong Vhost]
  * Định nghĩa Thư mục gốc [Document Root]: Chỉ định thư mục trên máy chủ chứa toàn bộ mã nguồn và tệp tin của website đó.
  * Liên kết Tên miền [Domain Name]: Gán một hoặc nhiều tên miền [ví dụ: yourdomain.com, www.yourdomain.com] với cấu hình vhost này.
  * Cấu hình PHP [qua LSAPI]: Thiết lập cách PHP được xử lý cho website này, ví dụ: chọn phiên bản PHP, các biến môi trường, giới hạn tài nguyên PHP riêng.
  * Thiết lập SSL/TLS [HTTPS]: Gán chứng chỉ SSL [certificate, private key, chain] để kích hoạt kết nối HTTPS an toàn cho tên miền.
  * Quy tắc Viết lại URL [Rewrite Rules]: Tạo các quy tắc chuyển hướng URL, URL thân thiện SEO, bắt buộc HTTPS, v.v., áp dụng riêng cho website này [tương thích với mod_rewrite của Apache].
  * Kiểm soát Truy cập: Thiết lập các quy tắc chặn/cho phép truy cập dựa trên địa chỉ IP.
  * Cấu hình Log: Chỉ định vị trí lưu file log truy cập và log lỗi riêng cho website.
  * Cài đặt LiteSpeed Cache [LSCache]: Bật và tùy chỉnh chính sách cache cho website này.

  Mỗi website trên máy chủ OpenLiteSpeed sẽ có một bộ cấu hình riêng, cho phép nó hoạt động đúng với các tệp tin, chứng chỉ SSL, quy tắc viết lại URL và cài đặt PHP của riêng mình, tất cả đều được phục vụ bởi cùng một tiến trình OpenLiteSpeed.
}

. /etc/wptt/.wptt.conf
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh
. /etc/wptt/echo-color

clear
echo -e "\n========================================================================="
echo -e "| $cau_hinh_webserver => $chinh_sua Vhost                                 |"
echo -e "=========================================================================\n"

. /etc/wptt/tenmien
echo -e "\n$lua_chon_website_ban_muon $chinh_sua vhost: \n"
lua_chon_NAME

[[ "$NAME" == "0" || -z "$NAME" ]] && exec /etc/wptt/wptt-cau-hinh-websever-main 1

vhost_conf="/usr/local/lsws/conf/vhosts/$NAME/$NAME.conf"

if [[ ! -f "$vhost_conf" ]]; then
  echoDo "$ten_mien_nay_khong_ton_tai_tren_he_thong"
  sleep 3
  exec /etc/wptt/wptt-cau-hinh-websever-main 1
fi

if [[ -f "/usr/local/lsws/conf/vhosts/$NAME/$NAME.conf.bkwptt" ]]; then
  echo -e "\033[1;33mBạn đã khoá domain $NAME nên không thể sử dụng tính năng này!\033[0m"
  sleep 3
  exec /etc/wptt/wptt-cau-hinh-websever-main 1
fi

echo "$xac_nhan $ban_muon $chinh_sua vhost website $NAME?"
prompt="$nhap_lua_chon_cua_ban [1-2]: "
dongy="n"
options=("$dong_y" "$khong_dong_y")

PS3="$prompt"
select opt in "${options[@]}"; do
  case "$REPLY" in
  1)
    dongy="y"
    break
    ;;
  2)
    dongy="n"
    break
    ;;
  *)
    printf "\n$ban_nhap_sai_he_thong_se_chon_khong_dong_y\n"
    break
    ;;
  esac
done

if [[ "$dongy" == "y" ]]; then
  [[ -z "$editor_cau_hinh" ]] && editor_cau_hinh="nano"

  echo -e '\033[1;36m                                                
                    ::::                    
                   :-::-:                   
        ..      ..::::::::::..      ..      
       :-:-:..:----::::::::---::..:-:-:       
       .:::::--:..          ..:--:::::.       
        .::::.                  :::::.        
        ::::                     .::::        
       ::::       .-=++++=-.       ::::       
      .-::       =*******##*=       ::-.      
  ..::::-.      +********:.+#=      ::::::..  
  ---:::-.     .***=-**- .=*** .-:::---  
  ..::::-.      +**=.  .=****=      ::::::..  
      .-::      .+*#*==*****=       ::-.      
       ::::       :=+***++-.       ::::       
        ::::                      ::::        
        .::::.                  :::::.        
       .:::::--:.            .:--:::::.       
       :-:-:..::--::::..:::---::..:-:-:       
        ..       ..::::::::..       ..        
                    .::::.                    
                     ::::                     
                                                \033[0m'

  echo -e "\n\033[1;33m[$cong_cu_cau_hinh: $editor_cau_hinh] $de $chinh_sua\033[0m\n"

  if [[ "$editor_cau_hinh" == "nano" ]]; then
    echo -e "\033[1;33m--- HƯỚNG DẪN LƯU FILE ---\033[0m"
    echo -e "1. Chỉnh sửa xong, ấn \033[1;32mCtrl + O\033[0m để lưu."
    echo -e "2. Ấn \033[1;32mEnter\033[0m để xác nhận tên file."
    echo -e "3. Ấn \033[1;32mCtrl + X\033[0m để thoát ra ngoài."
    echo -e "\033[1;33m--------------------------\033[0m"
  fi

  echo -e "\n\033[1;31m$hay_het_suc_can_than_trong_qua_trinh_chinh_sua webserver LiteSpeed !!\033[0m"
  echo "Đang mở trình soạn thảo..."
  sleep 3

  # Lấy MD5 trước khi sửa (Lưu trên RAM)
  old_md5=$(md5sum "$vhost_conf" | awk '{print $1}')

  # Mở Trình soạn thảo
  $editor_cau_hinh "$vhost_conf"

  # Lấy MD5 sau khi sửa để đối chiếu
  new_md5=$(md5sum "$vhost_conf" | awk '{print $1}')

  if [[ "$old_md5" != "$new_md5" ]]; then
    # Gán 1 biến duy nhất để không bị lệch chữ (Ghosting) khi in đè màn hình
    UI_STRING="Kiểm tra cú pháp và $khoi_dong_lai LiteSpeed"
    _runing "$UI_STRING"

    # Kiểm tra cú pháp an toàn tuyệt đối
    syntax_check=$(/usr/local/lsws/bin/openlitespeed -t 2>&1)

    if echo "$syntax_check" | grep -q "ERROR"; then
      echo "Cấu hình lại Vhost Litespeed Webserver làm gây ra lỗi : $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log
      _runloi "$UI_STRING"
      echo ""
      echoDo "Cấu hình Vhost bị LỖI NGHIÊM TRỌNG, hệ thống HỦY LỆNH RELOAD để tránh sập web!"
      echo -e "\033[1;31mChi tiết lỗi từ OpenLiteSpeed:\033[0m"
      echo "$syntax_check"
      echo ""
      read -p "Nhấn phím [Enter] để quay lại menu (Hãy vào sửa lại file cho đúng)..." dummy
      [[ ${1:-} == "98" ]] && exec /etc/wptt/wptt-cau-hinh-websever-main 1
      exit
    else
      # Nếu cấu hình chuẩn xác -> Reload an toàn
      /usr/local/lsws/bin/lswsctrl reload >/dev/null 2>&1
      _rundone "$UI_STRING"
      echo "Cấu hình lại Vhost Litespeed Webserver website $NAME : $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log
    fi
  else
    echo -e "\n\033[1;36mKhông có sự thay đổi nào được thực hiện. Bỏ qua reload.\033[0m"
    sleep 2
  fi
fi

[[ ${1:-} == "98" ]] && exec /etc/wptt/wptt-cau-hinh-websever-main 1
