function huong_dan() {
  Tính năng Sửa cấu hình OpenLiteSpeed vhost website là việc thiết lập hoặc điều chỉnh các cài đặt cho một Virtual Host [viết tắt là vhost] cụ thể trên máy chủ OpenLiteSpeed. Mỗi vhost đại diện cho một website [một tên miền hoặc tên miền phụ] riêng biệt mà bạn muốn máy chủ phục vụ.

  Nói một cách đơn giản, nếu OpenLiteSpeed là một chung cư lớn, thì mỗi căn hộ [website] trong đó sẽ có một bảng nội quy [cấu hình vhost] riêng. Sửa cấu hình vhost chính là việc bạn tùy chỉnh bảng nội quy cho từng căn hộ đó.

  Mục Đích Chính [Các Cài Đặt Quan Trọng Trong Vhost]
  * Định nghĩa Thư mục gốc [Document Root]: Chỉ định thư mục trên máy chủ chứa toàn bộ mã nguồn và tệp tin của website đó.
  * Liên kết Tên miền [Domain Name]: Gán một hoặc nhiều tên miền [ví dụ: yourdomain.com, www.yourdomain.com] với cấu hình vhost này.
  * Cấu hình PHP [qua LSAPI]: Thiết lập cách PHP được xử lý cho website này, ví dụ: chọn phiên bản PHP, các biến môi trường, giới hạn tài nguyên PHP riêng.
  * Thiết lập SSL/TLS [HTTPS]: Gán chứng chỉ SSL [certificate, private key, chain] để kích hoạt kết nối HTTPS an toàn cho tên miền.
  * Quy tắc Viết lại URL [Rewrite Rules]: Tạo các quy tắc chuyển hướng URL, URL thân thiện SEO, bắt buộc HTTPS, v.v., áp dụng riêng cho website này [tương thích với mod_rewrite của Apache].
  * Kiểm soát Truy cập: Thiết lập các quy tắc chặn/cho phép truy cập dựa trên địa chỉ IP.
  * Cấu hình Log: Chỉ định vị trí lưu file log truy cập và log lỗi riêng cho website.
  * Cài đặt LiteSpeed Cache [LSCache]: Bật và tùy chỉnh chính sách cache cho website này.

  Mỗi website trên máy chủ OpenLiteSpeed sẽ có một bộ cấu hình riêng, cho phép nó hoạt động đúng với các tệp tin, chứng chỉ SSL, quy tắc viết lại URL và cài đặt PHP của riêng mình, tất cả đều được phục vụ bởi cùng một tiến trình OpenLiteSpeed.
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null # Nạp thư viện UI Xác nhận

clear
echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}${cau_hinh_webserver} ➜ Chỉnh sửa Virtual Host (Vhost) Website${C_RESET}"
echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

# ==============================================================================
# GỌI MENU CHỌN DOMAIN LÕI
# ==============================================================================
. /etc/wptt/tenmien
lua_chon_NAME "cấu hình Vhost"

[[ "$NAME" == "0" || -z "$NAME" ]] && {
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-cau-hinh-websever-main 1
  return 2>/dev/null || exit
}

vhost_conf="/usr/local/lsws/conf/vhosts/$NAME/$NAME.conf"

if [[ ! -f "$vhost_conf" ]]; then
  echo -e "\n${C_RED}❌ Tên miền không tồn tại trên hệ thống này!${C_RESET}"
  sleep 3
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-cau-hinh-websever-main 1
  return 2>/dev/null || exit
fi

if [[ -f "/usr/local/lsws/conf/vhosts/$NAME/$NAME.conf.bkwptt" ]]; then
  echo -e "\n${C_YELLOW}Website $NAME đang bị TẠM KHÓA. Không thể sửa cấu hình lúc này!${C_RESET}"
  sleep 3
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-cau-hinh-websever-main 1
  return 2>/dev/null || exit
fi

echo ""
if wptt_xac_nhan "Bạn có CHẮC CHẮN muốn mở và chỉnh sửa cấu hình Vhost không?" "CẢNH BÁO NGUY HIỂM: File cấu hình Vhost rất nhạy cảm." "Chỉ một sai sót nhỏ cũng có thể làm sập Website này!" "Đồng ý Chỉnh sửa" "Hủy thao tác"; then
  echo ""

  [[ -z "$editor_cau_hinh" ]] && editor_cau_hinh="nano"

  # Khung hướng dẫn phím tắt Nano (UX Bo Cong)
  if [[ "$editor_cau_hinh" == "nano" ]]; then
    echo -e "${C_GREEN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
    center_text "${C_BOLD_WHITE}HƯỚNG DẪN LƯU FILE BẰNG NANO${C_RESET}"
    echo -e "${C_GREEN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
    left_text "1. Chỉnh sửa xong, ấn tổ hợp phím  : ${C_YELLOW}Ctrl + O${C_RESET}" 4
    left_text "2. Hệ thống hỏi tên file, ấn phím  : ${C_YELLOW}Enter${C_RESET}" 4
    left_text "3. Thoát ra ngoài Menu, ấn tổ hợp  : ${C_YELLOW}Ctrl + X${C_RESET}" 4
    echo -e "${C_GREEN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"
  else
    echo -e "${C_YELLOW}Đang mở trình soạn thảo: $editor_cau_hinh${C_RESET}\n"
  fi

  echo -e "${C_CYAN}Đang chuẩn bị dữ liệu và mở file cấu hình Vhost...${C_RESET}"
  sleep 3

  # Lấy mã băm MD5 trước khi sửa (Lưu trên RAM)
  old_md5=$(md5sum "$vhost_conf" | awk '{print $1}')

  $editor_cau_hinh "$vhost_conf"

  echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_YELLOW}ĐANG KIỂM TRA SỰ THAY ĐỔI VÀ CÚ PHÁP${C_RESET}"
  echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

  new_md5=$(md5sum "$vhost_conf" | awk '{print $1}')

  if [[ "$old_md5" != "$new_md5" ]]; then
    UI_STRING="Đang phân tích cú pháp cấu hình (Syntax Check)..."
    _runing "$UI_STRING"

    # Kiểm tra cú pháp an toàn tuyệt đối
    syntax_check=$(/usr/local/lsws/bin/openlitespeed -t 2>&1)
    _rundone "$UI_STRING"

    # Bắt cả ERROR và WARN để bảo đảm an toàn tối đa
    if echo "$syntax_check" | grep -q "ERROR\|WARN"; then
      echo "Cấu hình lại Vhost Litespeed Webserver làm gây ra lỗi : $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log

      echo -e "\n${C_RED}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
      center_text "${C_BOLD_WHITE}LỖI CÚ PHÁP NGHIÊM TRỌNG ĐÃ XẢY RA${C_RESET}"
      echo -e "${C_RED}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
      left_text "${C_YELLOW}Hệ thống đã HỦY LỆNH RELOAD để bảo vệ website khỏi bị sập!${C_RESET}" 2
      left_text "Chi tiết mã lỗi từ OpenLiteSpeed:" 2
      echo -e "${C_RED}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"

      # In chi tiết lỗi ra màn hình cho người dùng đọc
      while IFS= read -r line; do
        if [[ -n "$line" ]]; then
          printf "${C_RED}│${C_RESET}  %-69s${C_RED}│${C_RESET}\n" "${line:0:69}" # Cắt chuỗi nếu quá dài
        fi
      done <<<"$syntax_check"
      echo -e "${C_RED}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
      left_text "Hãy vào và sửa lại vhost OLS website $NAME cho đúng nhé!"
      echo -e "${C_RED}╰──────────────────────────────────────────────────────────────────────────────╯${C_RESET}"

      [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-cau-hinh-websever-main 1
      exit 1
    else
      # Nếu cấu hình chuẩn xác -> Reload an toàn (Zero-Downtime)
      _runing "Nạp lại cấu hình Vhost mới cho OpenLiteSpeed..."
      /usr/local/lsws/bin/lswsctrl reload >/dev/null 2>&1
      echo "Cấu hình lại Vhost Litespeed Webserver website $NAME : $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log
      _rundone "Nạp lại cấu hình Vhost mới cho OpenLiteSpeed..."

      echo -e "\n${C_GREEN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
      center_text "${C_BOLD_WHITE}CẬP NHẬT CẤU HÌNH VHOST THÀNH CÔNG${C_RESET}"
      echo -e "${C_GREEN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
      left_text "Website thao tác : ${C_YELLOW}$NAME${C_RESET}" 2
      left_text "Trạng thái       : Các thay đổi đã được áp dụng mượt mà." 2
      echo -e "${C_GREEN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"
    fi
  else
    echo -e "${C_YELLOW}Không có sự thay đổi nào được phát hiện trong file. Bỏ qua bước nạp lại.${C_RESET}\n"
  fi

else
  echo -e "${C_YELLOW}Đã hủy thao tác chỉnh sửa cấu hình Vhost.${C_RESET}\n"
fi

[[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-cau-hinh-websever-main 1
