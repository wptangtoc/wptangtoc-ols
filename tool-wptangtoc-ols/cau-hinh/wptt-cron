#!/bin/bash
function huong_dan() {
  Tính năng Cấu hình cron [hay Lập lịch cron] là việc thiết lập và quản lý các tác vụ tự động [cron jobs] trên hệ điều hành Linux [và các hệ thống tương tự Unix]. Cron là một trình nền [daemon] chạy ngầm, cho phép bạn lên lịch để các lệnh hoặc kịch bản [script] được thực thi lặp đi lặp lại vào những thời điểm cụ thể [phút, giờ, ngày, tháng, thứ]. ⏰⚙️📜

  Nói một cách đơn giản, cron giống như một người thư ký cần mẫn mà bạn có thể dặn dò để tự động làm một việc gì đó cho bạn theo lịch trình đã định, ví dụ: đúng 2 giờ sáng mỗi ngày, hãy chạy script sao lưu này.

  Mục Đích Chính
  * Tự động hóa các tác vụ lặp đi lặp lại: Đây là công dụng cốt lõi.
  * Sao lưu [Backup]: Tự động sao lưu database, file website, hoặc toàn bộ hệ thống.
  * Bảo trì hệ thống: Chạy các script dọn dẹp log cũ, file tạm, cập nhật hệ thống, kiểm tra sức khỏe server.
  * Tạo báo cáo: Tự động tạo và gửi báo cáo định kỳ.
  * Đồng bộ hóa dữ liệu: Tự động đồng bộ file giữa các server.
  * Gửi email thông báo, nhắc nhở.
  * Thực thi các tác vụ của ứng dụng: Nhiều ứng dụng web [như WordPress, Magento] cần cron để chạy các tác vụ nền [ví dụ: đăng bài theo lịch, cập nhật chỉ mục].

  Sau khi cấu hình, cron sẽ tự động thực thi các lệnh hoặc script theo đúng lịch trình bạn đã đặt ra, giúp tự động hóa nhiều công việc quản trị và vận hành hệ thống.
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null # Nạp thư viện UI Xác nhận

clear
echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}${cau_hinh_webserver} ➜ Chỉnh sửa Cron Job (Tác vụ tự động)${C_RESET}"
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
left_text " ${C_BOLD_WHITE}GỢI Ý CÔNG CỤ TẠO CRONTAB NHANH CHÓNG:${C_RESET}" 2
echo -e "${C_CYAN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
left_text " Bạn có thể truy cập công cụ tạo mã lệnh Crontab chuẩn xác tại:" 2
left_text " ${C_GREEN}https://wptangtoc.com/crontab/${C_RESET}" 2
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

if wptt_xac_nhan "Bạn có CHẮC CHẮN muốn mở và chỉnh sửa các lệnh Cron Job không?" "CẢNH BÁO: Cấu hình sai lệnh Cron có thể gây chạy quá tải hệ thống," "hoặc làm sập các tác vụ tự động hiện có (Backup, Dọn dẹp...)." "Đồng ý Chỉnh sửa" "Hủy thao tác"; then
  echo ""

  [[ -z "$editor_cau_hinh" ]] && editor_cau_hinh="nano"

  # Khung hướng dẫn phím tắt Nano
  if [[ "$editor_cau_hinh" == "nano" ]]; then
    echo -e "${C_GREEN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
    center_text "${C_BOLD_WHITE}HƯỚNG DẪN LƯU FILE BẰNG NANO${C_RESET}"
    echo -e "${C_GREEN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
    left_text "1. Chỉnh sửa xong, ấn tổ hợp phím  : ${C_YELLOW}Ctrl + O${C_RESET}" 4
    left_text "2. Hệ thống hỏi tên file, ấn phím  : ${C_YELLOW}Enter${C_RESET}" 4
    left_text "3. Thoát ra ngoài Menu, ấn tổ hợp  : ${C_YELLOW}Ctrl + X${C_RESET}" 4
    echo -e "${C_GREEN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"
  else
    echo -e "${C_YELLOW}Đang mở trình soạn thảo: $editor_cau_hinh${C_RESET}\n"
  fi

  echo -e "${C_CYAN}Đang chuẩn bị sao lưu bảo vệ cấu hình hiện tại...${C_RESET}"
  sleep 3

  echo "Cấu hình crond : $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log

  if cat /etc/*release 2>/dev/null | grep -qi "ubuntu"; then
    service_cron="cron"
  else
    service_cron="crond"
  fi

  # Sao lưu Crontab hiện tại trước khi chỉnh sửa
  rm -f "/tmp/${USER}-crontab_backup.txt"
  if [[ $(systemctl is-active "$service_cron.service" 2>/dev/null) == 'active' ]]; then
    crontab -l >"/tmp/${USER}-crontab_backup.txt" 2>/dev/null
  fi

  export VISUAL="$editor_cau_hinh"
  export EDITOR="$editor_cau_hinh"
  crontab -e

  clear # Xóa màn hình sau khi Editor thoát

  echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_YELLOW}ĐANG KIỂM TRA SỰ ỔN ĐỊNH CỦA DỊCH VỤ CROND${C_RESET}"
  echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

  _runing "Kiểm tra trạng thái tiến trình $service_cron..."

  if [[ -f "/tmp/${USER}-crontab_backup.txt" ]]; then
    if [[ $(systemctl is-active "$service_cron.service" 2>/dev/null) != 'active' ]]; then
      _runloi "Dịch vụ Cron bị lỗi sau khi chỉnh sửa"
      echo -e "\n${C_RED}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
      center_text "${C_BOLD_WHITE}LỖI NGHIÊM TRỌNG ĐÃ XẢY RA${C_RESET}"
      echo -e "${C_RED}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
      left_text "${C_YELLOW}Cấu hình Crontab mới đã làm dịch vụ ($service_cron) ngừng hoạt động!${C_RESET}" 2
      left_text "Hệ thống đang TỰ ĐỘNG KHÔI PHỤC (Restore) lại cấu hình cũ..." 2
      echo -e "${C_RED}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

      _runing "Đang phục hồi bản sao lưu Crontab cũ..."
      crontab "/tmp/${USER}-crontab_backup.txt"
      systemctl restart "$service_cron.service" >/dev/null 2>&1
      _rundone "Phục hồi thành công. Dịch vụ đã hoạt động trở lại."
    else
      _rundone "Cấu hình Crontab mới hợp lệ. Dịch vụ đang hoạt động ổn định."

      echo -e "\n${C_GREEN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
      center_text "${C_BOLD_WHITE}CẬP NHẬT CẤU HÌNH THÀNH CÔNG${C_RESET}"
      echo -e "${C_GREEN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
      left_text "Trạng thái : Các lịch trình Cron Job đã được ghi nhận." 2
      echo -e "${C_GREEN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"
    fi
  else
    _rundone "Hoàn tất chỉnh sửa Crontab."
  fi

  # Dọn dẹp file temp backup
  rm -f "/tmp/${USER}-crontab_backup.txt" 2>/dev/null

else
  echo -e "${C_YELLOW}Đã hủy thao tác chỉnh sửa Cron Job.${C_RESET}\n"
fi

[[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-cau-hinh-websever-main 1
