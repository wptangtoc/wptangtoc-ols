function huong_dan() {
  Tính năng Cấu hình Fail2ban là việc bạn tùy chỉnh cách Fail2ban hoạt động để bảo vệ máy chủ của mình, chủ yếu bằng cách dạy nó theo dõi nhật ký [log] của các dịch vụ [như SSH, web server], phát hiện các hành vi đáng ngờ [như đăng nhập sai nhiều lần] và thực hiện hành động [như chặn IP] dựa trên các quy tắc bạn đặt ra.

  Sau khi cấu hình, Fail2ban sẽ tự động theo dõi và chặn các địa chỉ IP có hành vi tấn công theo đúng những gì bạn đã thiết lập, giúp tăng cường an ninh cho máy chủ.
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null # Nạp thư viện UI Xác nhận

clear
echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}${cau_hinh_webserver} ➜ Chỉnh sửa cấu hình Fail2ban${C_RESET}"
echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

config_path="/etc/fail2ban/jail.local"

if [[ ! -f "$config_path" ]]; then
  echo -e "${C_RED}❌ Lỗi: Bạn chưa kích hoạt Fail2ban hoặc file cấu hình không tồn tại!${C_RESET}"
  sleep 3
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-cau-hinh-websever-main 1
  exit 1
fi

echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
left_text "Mọi cấu hình mặc định (Maxretry, Bantime...) đã được WPTangToc OLS" 2
left_text "tối ưu hóa sẵn để bảo vệ Server và chống khóa nhầm." 2
echo -e "${C_CYAN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
left_text "${C_YELLOW}LƯU Ý: Chỉ nên chỉnh sửa khi bạn thực sự hiểu rõ các tham số!${C_RESET}" 2
echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

# ==============================================================================
# XÁC NHẬN BẢO MẬT & HƯỚNG DẪN TRÌNH SOẠN THẢO
# ==============================================================================
if wptt_xac_nhan "Bạn có CHẮC CHẮN muốn mở và chỉnh sửa cấu hình Fail2ban không?" "CẢNH BÁO: Cấu hình sai có thể dẫn đến việc Server khóa nhầm" "địa chỉ IP của chính bạn (Lockout) hoặc ngừng bảo vệ hệ thống!" "Đồng ý Chỉnh sửa" "Hủy thao tác"; then
  echo ""

  [[ -z "$editor_cau_hinh" ]] && editor_cau_hinh="nano"

  # Khung hướng dẫn phím tắt Nano
  if [[ "$editor_cau_hinh" == "nano" ]]; then
    echo -e "${C_GREEN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
    center_text "${C_BOLD_WHITE}HƯỚNG DẪN LƯU FILE BẰNG NANO${C_RESET}"
    echo -e "${C_GREEN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
    left_text "1. Chỉnh sửa xong, ấn tổ hợp phím  : ${C_YELLOW}Ctrl + O${C_RESET}" 4
    left_text "2. Hệ thống hỏi tên file, ấn phím  : ${C_YELLOW}Enter${C_RESET}" 4
    left_text "3. Thoát ra ngoài Menu, ấn tổ hợp  : ${C_YELLOW}Ctrl + X${C_RESET}" 4
    echo -e "${C_GREEN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"
  else
    echo -e "${C_YELLOW}Đang mở trình soạn thảo: $editor_cau_hinh${C_RESET}\n"
  fi

  echo -e "${C_CYAN}Đang chuẩn bị dữ liệu và mở file cấu hình...${C_RESET}"
  sleep 3

  old_md5=$(md5sum "$config_path" | awk '{print $1}')

  $editor_cau_hinh "$config_path"
  clear # Xóa màn hình sau khi Nano thoát ra để giao diện sạch sẽ

  echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
  center_text "${C_YELLOW}ĐANG KIỂM TRA SỰ THAY ĐỔI VÀ CÚ PHÁP${C_RESET}"
  echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

  new_md5=$(md5sum "$config_path" | awk '{print $1}')

  if [[ "$old_md5" != "$new_md5" ]]; then
    UI_STRING="Đang phân tích cú pháp cấu hình (Syntax Check)..."
    _runing "$UI_STRING"

    # Kiểm tra cú pháp an toàn (Bắt Exit Code)
    syntax_check=$(fail2ban-client -t 2>&1)
    exit_status=$?

    _rundone "$UI_STRING"
    if [[ $exit_status -ne 0 ]]; then
      # _runloi "$UI_STRING"
      echo "Cấu hình lại Fail2ban làm gây ra lỗi : $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log

      echo -e "\n${C_RED}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
      center_text "${C_BOLD_WHITE}LỖI CÚ PHÁP ĐÃ XẢY RA${C_RESET}"
      echo -e "${C_RED}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
      left_text "${C_YELLOW}Hệ thống đã HỦY LỆNH RELOAD để Fail2ban không bị ngừng hoạt động!${C_RESET}" 2
      left_text "Chi tiết mã lỗi từ Fail2ban-client:" 2
      echo -e "${C_RED}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"

      # In chi tiết lỗi ra màn hình cho người dùng đọc
      while IFS= read -r line; do
        if [[ -n "$line" ]]; then
          printf "${C_RED}│${C_RESET}  %-69s${C_RED}│${C_RESET}\n" "${line:0:69}"
        fi
      done <<<"$syntax_check"

      echo -e "${C_RED}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

      [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-cau-hinh-websever-main 1
      exit 1
    else
      # Nếu cấu hình chuẩn xác -> Reload an toàn (Zero-Downtime)

      _runing "Nạp lại cấu hình mới cho Fail2ban (Reload)..."
      fail2ban-client reload >/dev/null 2>&1
      echo "Cấu hình lại fail2ban thành công : $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log
      _rundone "Nạp lại cấu hình mới cho Fail2ban (Reload)..."

      # BẢNG BÁO CÁO THÀNH CÔNG
      echo -e "\n${C_GREEN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
      center_text "${C_BOLD_WHITE}CẬP NHẬT CẤU HÌNH THÀNH CÔNG${C_RESET}"
      echo -e "${C_GREEN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
      left_text "Trạng thái : Các luật mới đã được Fail2ban ghi nhận." 2
      echo -e "${C_GREEN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"
    fi
  else
    echo -e "${C_YELLOW}Không có sự thay đổi nào được phát hiện trong file. Bỏ qua bước nạp lại.${C_RESET}\n"
  fi

else
  echo -e "${C_YELLOW}Đã hủy thao tác chỉnh sửa cấu hình Fail2ban.${C_RESET}\n"
fi

[[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-cau-hinh-websever-main 1
