function huong_dan() {
  Tính năng Cấu hình Fail2ban là việc bạn tùy chỉnh cách Fail2ban hoạt động để bảo vệ máy chủ của mình, chủ yếu bằng cách dạy nó theo dõi nhật ký [log] của các dịch vụ [như SSH, web server], phát hiện các hành vi đáng ngờ [như đăng nhập sai nhiều lần] và thực hiện hành động [như chặn IP] dựa trên các quy tắc bạn đặt ra.

  Sau khi cấu hình, Fail2ban sẽ tự động theo dõi và chặn các địa chỉ IP có hành vi tấn công theo đúng những gì bạn đã thiết lập, giúp tăng cường an ninh cho máy chủ.
}

. /etc/wptt/.wptt.conf
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh
. /etc/wptt/echo-color

clear
echo -e "\n========================================================================="
echo -e "| Cấu hình webserver => Cấu hình Fail2ban                                 |"
echo -e "=========================================================================\n"

if [[ ! -f /etc/fail2ban/jail.local ]]; then
  echoDo "Bạn chưa kích hoạt Fail2ban hoặc file cấu hình không tồn tại!"
  sleep 3
  exec /etc/wptt/wptt-cau-hinh-websever-main 1
fi

echo -e "\033[1;36mMọi cấu hình mặc định đã được tối ưu, nếu có nhu cầu đặc biệt bạn có thể tự sửa.\033[0m"
echo -e "\033[1;33mLưu ý: Hãy thật sự cẩn thận khi sửa cấu hình hệ thống!\033[0m"
sleep 2

prompt="$nhap_lua_chon_cua_ban [1-2]: "
dongy="n"
options=("$dong_y" "$khong_dong_y")
PS3="$prompt"

select opt in "${options[@]}"; do
  case "$REPLY" in
  1)
    dongy="y"
    break
    ;;
  2)
    dongy="n"
    break
    ;;
  *)
    printf "\n$ban_nhap_sai_he_thong_se_chon_khong_dong_y\n"
    break
    ;;
  esac
done

if [[ "$dongy" == "y" ]]; then
  [[ -z "$editor_cau_hinh" ]] && editor_cau_hinh="nano"

  echo -e '\033[1;36m                                                
                    ::::                    
                   :-::-:                   
        ..      ..::::::::::..      ..      
       :-:-:..:----::::::::---::..:-:-:       
       .:::::--:..          ..:--:::::.       
        .::::.                  :::::.        
        ::::                     .::::        
       ::::       .-=++++=-.       ::::       
      .-::       =*******##*=       ::-.      
  ..::::-.      +********:.+#=      ::::::..  
  ---:::-.     .***=-**- .=*** .-:::---  
  ..::::-.      +**=.  .=****=      ::::::..  
      .-::      .+*#*==*****=       ::-.      
       ::::       :=+***++-.       ::::       
        ::::                      ::::        
        .::::.                  :::::.        
       .:::::--:.            .:--:::::.       
       :-:-:..::--::::..:::---::..:-:-:       
        ..       ..::::::::..       ..        
                    .::::.                    
                     ::::                     
                                                \033[0m'

  echo -e "\n\033[1;33m[Sử dụng công cụ editor: $editor_cau_hinh để chỉnh sửa]\033[0m\n"

  if [[ "$editor_cau_hinh" == "nano" ]]; then
    echo -e "\033[1;33m--- HƯỚNG DẪN LƯU FILE ---\033[0m"
    echo -e "1. Chỉnh sửa xong, ấn \033[1;32mCtrl + O\033[0m để lưu."
    echo -e "2. Ấn \033[1;32mEnter\033[0m để xác nhận tên file."
    echo -e "3. Ấn \033[1;32mCtrl + X\033[0m để thoát ra ngoài."
    echo -e "\033[1;33m--------------------------\033[0m"
  fi

  echo -e "\n\033[1;31mHãy cẩn thận khi chỉnh sửa lại Fail2ban !!\033[0m"
  echo "Đang mở trình soạn thảo..."
  sleep 3

  config_path="/etc/fail2ban/jail.local"

  # Lấy MD5 trước khi sửa (Lưu trên RAM)
  old_md5=$(md5sum "$config_path" | awk '{print $1}')

  # Mở Trình soạn thảo
  $editor_cau_hinh "$config_path"

  # Lấy MD5 sau khi sửa để đối chiếu
  new_md5=$(md5sum "$config_path" | awk '{print $1}')

  if [[ "$old_md5" != "$new_md5" ]]; then
    UI_STRING="Kiểm tra cú pháp và nạp lại cấu hình Fail2ban"
    _runing "$UI_STRING"

    # Kiểm tra cú pháp an toàn (Bắt Exit Code)
    syntax_check=$(fail2ban-client -t 2>&1)
    exit_status=$?

    if [[ $exit_status -ne 0 ]]; then
      echo "Cấu hình lại Fail2ban làm gây ra lỗi : $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log
      _runloi "Kiểm tra cú pháp thất bại!"
      echo ""
      echoDo "Cấu hình Fail2ban bị LỖI NGHIÊM TRỌNG, hệ thống HỦY LỆNH RELOAD để bảo vệ Server!"
      echo -e "\033[1;31mChi tiết lỗi từ Fail2ban:\033[0m"
      echo "$syntax_check"
      echo ""
      read -p "Nhấn phím [Enter] để quay lại menu (Hãy vào sửa lại file cho đúng)..." dummy
      [[ ${1:-} == "98" ]] && exec /etc/wptt/wptt-cau-hinh-websever-main 1
      exit
    else
      # Nếu cấu hình chuẩn xác -> Reload an toàn (Zero-Downtime)
      fail2ban-client reload >/dev/null 2>&1
      _rundone "$UI_STRING"
      echo "Cấu hình lại fail2ban thành công : $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log

    fi
  else
    echo -e "\n\033[1;36mKhông có sự thay đổi nào được thực hiện. Bỏ qua reload.\033[0m"
    sleep 2
  fi
fi

[[ ${1:-} == "98" ]] && exec /etc/wptt/wptt-cau-hinh-websever-main 1
