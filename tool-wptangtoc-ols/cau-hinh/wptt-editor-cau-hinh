function huong_dan() {
  Tính năng Thay đổi công cụ cấu hình editor: vim, nano, vi là khả năng cho phép bạn chọn và đặt trình soạn thảo văn bản [text editor] mặc định sẽ được sử dụng khi bạn cần chỉnh sửa các tệp tin cấu hình hoặc văn bản từ dòng lệnh [command line] trên hệ thống Linux hoặc Unix.

  Nói một cách đơn giản, đây là cách bạn chỉ định cho hệ thống biết rằng: Khi tôi cần sửa file bằng dòng lệnh [ví dụ: khi chạy crontab -e], hãy mở file đó bằng nano [hoặc vim, vi] thay vì một trình soạn thảo mặc định khác mà tôi không quen.

  Mục Đích Chính
  * Sở thích và sự quen thuộc của người dùng: Mỗi người có thể quen và làm việc hiệu quả hơn với một trình soạn thảo nhất định.
  * Tăng hiệu quả công việc: Sử dụng trình soạn thảo bạn thành thạo giúp việc chỉnh sửa file nhanh chóng và ít lỗi hơn.
  * Đảm bảo tính nhất quán: Có một trình soạn thảo mặc định quen thuộc cho mọi tác vụ chỉnh sửa từ dòng lệnh.

  Sau khi thiết lập hệ thống sẽ tự động sử dụng trình soạn thảo mà bạn đã chọn làm mặc định, giúp bạn làm việc thoải mái và hiệu quả hơn.
  Mặc định nếu chưa thiết lập sẽ sử dụng: nano
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null # Nạp thư viện UI Xác nhận

clear
echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}${cau_hinh_webserver} ➜ Thiết lập Trình soạn thảo (Editor) Mặc định${C_RESET}"
echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

[[ -z "$editor_cau_hinh" ]] && editor_cau_hinh="nano"

echo -e "${C_CYAN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
left_text "Editor hiện tại : ${C_GREEN}[ $editor_cau_hinh ]${C_RESET}" 2
echo -e "${C_CYAN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
center_text "${C_YELLOW}VUI LÒNG CHỌN TRÌNH SOẠN THẢO BẠN MUỐN SỬ DỤNG${C_RESET}"
echo -e "${C_CYAN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
left_text "  ${C_CYAN}1)${C_RESET} ${C_BOLD_WHITE}vim${C_RESET}   (Mạnh mẽ, nhiều phím tắt cho Dev chuyên nghiệp)" 2
left_text "  ${C_CYAN}2)${C_RESET} ${C_BOLD_WHITE}vi${C_RESET}    (Trình soạn thảo truyền thống, nhẹ nhất)" 2
left_text "  ${C_CYAN}3)${C_RESET} ${C_BOLD_WHITE}nano${C_RESET}  (Dễ sử dụng nhất, phù hợp với mọi người)" 2
echo -e "${C_CYAN}╰──────────────────────────────────────────────────────────────────────────────╯${C_RESET}"

trinh_go_code="nano"
while true; do
  echo -en "${C_CYAN}Nhập lựa chọn của bạn [1-3] [0=Thoát]: ${C_RESET}"
  read -r REPLY

  if [[ "$REPLY" == "0" ]]; then
    echo -e "\n${C_GREEN}Đang thoát...${C_RESET}"
    [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-cau-hinh-websever-main 1
    exit 0
  fi

  case "$REPLY" in
  1)
    trinh_go_code="vim"
    break
    ;;
  2)
    trinh_go_code="vi"
    break
    ;;
  3)
    trinh_go_code="nano"
    break
    ;;
  *) echo -e "${C_RED}❌ Lựa chọn không hợp lệ! Vui lòng chọn từ 1 đến 3.${C_RESET}" ;;
  esac
done

echo ""

# Nếu chọn giống cái cũ thì không làm gì cả
if [[ "$trinh_go_code" == "$editor_cau_hinh" ]]; then
  echo -e "${C_YELLOW}Hệ thống hiện tại đã sử dụng [$trinh_go_code] làm trình soạn thảo mặc định rồi!${C_RESET}\n"

  echo -en "${C_GREEN}Nhấn phím [Enter] để quay lại Menu...${C_RESET}"
  read -r dummy
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-cau-hinh-websever-main 1
  exit 0
fi

if ! command -v "$trinh_go_code" >/dev/null 2>&1; then
  UI_STRING="Đang tải và cài đặt Package: $trinh_go_code..."
  _runing "$UI_STRING"

  if grep -qi "ubuntu" /etc/os-release 2>/dev/null; then
    export DEBIAN_FRONTEND=noninteractive
    apt-get update >/dev/null 2>&1
    apt-get install -y "$trinh_go_code" >/dev/null 2>&1
  else
    dnf install -y "$trinh_go_code" >/dev/null 2>&1 || yum install -y "$trinh_go_code" >/dev/null 2>&1
  fi

  _rundone "Cài đặt Package thành công"
fi

# ==============================================================================
# CẬP NHẬT CẤU HÌNH WPTANGTOC VÀ BÁO CÁO
# ==============================================================================
_runing "Đang ghi cấu hình mặc định vào hệ thống..."
sed -i "/editor_cau_hinh=/d" /etc/wptt/.wptt.conf 2>/dev/null
echo "editor_cau_hinh=$trinh_go_code" >>/etc/wptt/.wptt.conf

echo "Thay đổi công cụ cấu hình $trinh_go_code : $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log
_rundone "Lưu cấu hình thành công"

# BẢNG BÁO CÁO THÀNH CÔNG
echo -e "\n${C_GREEN}╭──────────────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_BOLD_WHITE}HOÀN TẤT THAY ĐỔI EDITOR${C_RESET}"
echo -e "${C_GREEN}├──────────────────────────────────────────────────────────────────────────────┤${C_RESET}"
left_text "Editor mặc định mới : ${C_GREEN}[ $trinh_go_code ]${C_RESET}" 2
left_text "Kể từ bây giờ, mọi thao tác chỉnh sửa cấu hình (Webserver," 2
left_text "Database, Cronjob...) sẽ được mở bằng công cụ này." 2
echo -e "${C_GREEN}╰──────────────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

[[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-cau-hinh-websever-main 1
