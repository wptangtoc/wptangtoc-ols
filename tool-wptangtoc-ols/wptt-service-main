# ==============================================================================
# 3. LOGIC XỬ LÝ (ÁNH XẠ CHUẨN VỚI INDEX MỚI)
# ==============================================================================
run_action() {
  local index=$1
  local script_path=""
  local script_args="98"

  case $index in
  0) script_path="/etc/wptt/service/wptt-start-main" ;;
  1) script_path="/etc/wptt/service/wptt-stop-main" ;;
  2) script_path="/etc/wptt/service/wptt-reboot-main" ;;
  3) script_path="/etc/wptt/service/wptt-status" ;;
  4) script_path="/etc/wptt/service/reboot-server" ;;
  5) script_path="/etc/wptt/update/wptt-kiem-tra-version" ;;
  6) script_path="/etc/wptt/service/reboot-app/wptt-auto-reboot-thiet-lap" ;;
  7) script_path="/etc/wptt/bao-mat/wptt-thong-bao-het-tai-nguyen-thiet-lap" ;;
  esac

  if [[ -x "$script_path" || -f "$script_path" ]]; then
    bash "$script_path" "$script_args" # Tháo lệnh exec để giữ lại menu
  else
    echo -e "\n\033[1;31m[!] Lỗi: Không tìm thấy script '$script_path'.\033[0m"
    sleep 2
    bash /etc/wptt/wptt-service-main 1
  fi
}

