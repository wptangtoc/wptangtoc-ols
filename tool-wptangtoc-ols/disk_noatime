#!/bin/bash
function wptt_optimize_disk_noatime() {

  #Nếu không có noatime (để mặc định là relatime), hệ điều hành thỉnh thoảng vẫn phải thực hiện tác vụ GHI xuống ổ cứng chỉ để đánh dấu: "File ảnh này vừa được khách đọc vào hôm nay". cũng chả mấy ai quan tâm file này đã từng đọc trong ngày hôm nay chưa

  #WordPress, OpenLiteSpeed, MariaDB, PHP OPcache, JIT... KHÔNG MỘT AI quan tâm đến Access Time cả. Bọn chúng chỉ quan tâm đến Modify Time (mtime - thời gian sửa file)
  echo "Đang tối ưu hóa Ổ cứng: Giải phóng lệnh thừa bằng cờ 'noatime'..."
  # Bước 1: Kiểm tra xem phân vùng gốc (/) đã có noatime chưa
  if grep -E "^[^#].*[[:space:]]/[[:space:]].*noatime" /etc/fstab >/dev/null; then
    echo "- Tính năng noatime đã được bật sẵn trên hệ thống. Bỏ qua!"
  else
    # Bước 2: Tạo bản sao lưu an toàn trước khi đụng vào fstab
    cp /etc/fstab /etc/fstab.wptt.bak

    # Bước 3: Dùng awk tìm đúng dòng mount vào "/" và nhét ",noatime" vào cột options (cột thứ 4)
    # Lệnh column -t giúp căn lề lại file fstab cho đẹp mắt sau khi chỉnh sửa
    awk '{ if ($2 == "/" && $4 !~ /noatime/) { $4 = $4 ",noatime" }; print }' /etc/fstab | column -t >/tmp/fstab.new
    # Ghi đè an toàn vào fstab gốc
    cat /tmp/fstab.new >/etc/fstab
    rm -f /tmp/fstab.new

    # Bước 4: Áp dụng cấu hình ngay lập tức mà KHÔNG CẦN khởi động lại máy chủ
    mount -o remount /

    echo "- Đã tích hợp 'noatime' thành công! Ổ cứng của bạn vừa được giảm tải cho ổ cứng."

    #lệnh để xem giá trị: findmnt /
  fi
}

# Gọi hàm thực thi
wptt_optimize_disk_noatime
