draw_custom_grid() {
  print_row "" "CẬP NHẬT WPTANGTOC OLS" "" "CẬP NHẬT PHẦN MỀM (SERVER)"
  print_row "1" "${options[0]}" "6"  "${options[5]}"
  print_row "2" "${options[1]}" "7"  "${options[6]}"
  print_row "3" "${options[2]}" "8"  "${options[7]}"
  print_row "4" "${options[3]}" "9"  "${options[8]}"
  print_row "5" "${options[4]}" "10" "${options[9]}"
}

