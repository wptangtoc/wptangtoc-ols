# ==============================================================================
# 2. KHAI BÁO TIÊU ĐỀ MENU VÀ OPTIONS (ĐÃ QUY HOẠCH LẠI LOGIC UX)
# ==============================================================================
MENU_TITLE="TRUNG TÂM QUẢN LÝ CẬP NHẬT (UPDATE)"

options=(
  # --- CỘT TRÁI (1-5): QUẢN LÝ WPTANGTOC OLS ---
  "$update_wptangtoc_ols"                  #0 (Hiển thị: 1)
  "On/OFF auto Update WPTangToc OLS"       #1 (Hiển thị: 2)
  "$chuyen_nhanh_wptangtoc_ols_chinh_thuc" #2 (Hiển thị: 3)
  "$chuyen_nhanh_wptangtoc_ols_beta"       #3 (Hiển thị: 4)
  "Rollback restore WPTangToc OLS"         #4 (Hiển thị: 5)

  # --- CỘT PHẢI (6-10): HỆ THỐNG & PHẦN MỀM LÕI ---
  "$cap_nhat_toan_bo_webserver"            #5 (Hiển thị: 6)
  "Cập nhật MariaDB"                       #6 (Hiển thị: 7)
  "$cap_nhat PhpMyAdmin"                   #7 (Hiển thị: 8)
  "$cap_nhat WP CLI"                       #8 (Hiển thị: 9)
  "$kiem_tra_phien_ban_cac_service"        #9 (Hiển thị: 10)
)

# ==============================================================================
# 3. LOGIC XỬ LÝ (ÁNH XẠ CHUẨN 100% VỚI INDEX MỚI)
# ==============================================================================
run_action() {
  local index=$1
  local script_path=""
  local arg1="98" # Mặc định
  local arg2=""

  case $index in
  # Nhóm WPTangToc
  0) script_path="/etc/wptt/wptt-update" ;;
  1) script_path="/etc/wptt/update/wptt-auto-update" ;;
  2) script_path="/etc/wptt/wptt-update2"; arg1="chinhthuc"; arg2="98" ;;
  3) script_path="/etc/wptt/wptt-update2"; arg1="beta"; arg2="98" ;;
  4) script_path="/etc/wptt/update/wptt-rollback-update-wptangtoc" ;;
  
  # Nhóm Hệ thống
  5) script_path="/etc/wptt/update/wptt-update-he-thong" ;;
  6) script_path="/etc/wptt/update/update-mariadb" ;;
  7) script_path="/etc/wptt/update/wptt-update-phpmyadmin" ;;
  8) script_path="/etc/wptt/update/wptt-wp-cli" ;;
  9) script_path="/etc/wptt/update/wptt-kiem-tra-version"; arg1="99" ;; # 99 cho luồng update
  esac

  if [[ -x "$script_path" || -f "$script_path" ]]; then
    if [[ -n "$arg2" ]]; then
      exec bash "$script_path" "$arg1" "$arg2"
    elif [[ -n "$arg1" ]]; then
      exec bash "$script_path" "$arg1"
    else
      exec bash "$script_path"
    fi
  else
    echo -e "\n\033[1;31m[!] Lỗi: Không tìm thấy hoặc không thể thực thi script '$script_path'.\033[0m"
    sleep 2
    exec /etc/wptt/wptt-update-main 1
  fi
}

