#!/bin/bash
. /etc/wptt/.wptt.conf
. /etc/wptt/echo-color

_runing "Cấu hình webserver dành cho Woocommerce"
echo "Thiết lập cấu hình Woocommerce webserver : $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log

#all version php và tương thich với ubuntu, almalinux, redhet, rocky
php_cli=$(php -i | grep "Loaded Configuration File" | awk '{print $5}')

php_cli_version=$(echo $php_cli | cut -f5 -d '/')
lsphp=($(ls /usr/local/lsws | grep -P '^lsphp[0-9]+$'))
for php_all in ${lsphp[@]}; do
  php=$(echo $php_cli | sed "s/$php_cli_version/$php_all/g")
  if [[ -f $php ]]; then
    sed -i "/memory_limit/d" "$php"
    sed -i "/memory-limit/a memory_limit = 256M" "$php"

    sed -i "/max_input_time/d" "$php"
    sed -i "/max-input-time/a max_input_time = 120" "$php"

    sed -i '/opcache.memory_consumption/d' "$php"
    sed -i '/opcache.interned_strings_buffer/d' "$php"
    sed -i '/opcache.max_accelerated_files/d' "$php"
    echo 'opcache.memory_consumption=256
opcache.max_accelerated_files=20000
opcache.interned_strings_buffer=16
' >>"$php"
  fi
done

#support JIT
# Lấy danh sách các thư mục lsphp (ví dụ: lsphp74, lsphp81, lsphp82)
lsphp_list=($(ls /usr/local/lsws | grep -P '^lsphp[0-9]+$'))

for php_dir in "${lsphp_list[@]}"; do
  # Tách lấy phần số của phiên bản (ví dụ: "lsphp82" -> "82", "lsphp74" -> "74")
  version_num=$(echo "$php_dir" | grep -oP '[0-9]+')

  # Điều kiện: Chỉ thực thi nếu phần số >= 80 (Tức là PHP 8.0 trở lên)
  if ((version_num >= 80)); then
    # Đường dẫn chuẩn xác tới file php.ini của OpenLiteSpeed

    if $(cat /etc/*release | grep -q "Ubuntu"); then
      phien_ban_php_co_cham=$(echo $version_num | grep -Eo '[0-9]{1,2}' | head -1 | perl -pe 's/(\d{1})(?=(?:\d{1}){1,5}\b)/\1./g')
      php_ini_path="/usr/local/lsws/$php_dir/etc/php/$phien_ban_php_co_cham/litespeed/php.ini"
    else
      php_ini_path="/usr/local/lsws/$php_dir/etc/php.ini"
    fi

    if [[ -f "$php_ini_path" ]]; then
      echo "Đang cấu hình JIT cho $php_dir..."

      # Xóa cấu hình cũ (nếu có) để tránh lặp dòng
      sed -i '/opcache.jit_buffer_size/d' "$php_ini_path"
      sed -i '/opcache.jit/d' "$php_ini_path"

      # Thêm cấu hình JIT mới
      echo 'opcache.jit=tracing
opcache.jit_buffer_size=128M' >>"$php_ini_path"
    fi
  else
    # Có thể log ra hoặc ẩn đi tùy anh
    echo "Bỏ qua $php_dir (Không hỗ trợ JIT)."
  fi
done
#END JIT

duong_dan_config_redis=$(systemctl cat redis | grep 'ExecStart' | sed -n 's#^.* \(/.*\.conf\).*#\1#p')
if [[ -f $duong_dan_config_redis ]]; then
  sed -i 's/128mb/256mb/g' $duong_dan_config_redis
  systemctl restart redis.service
fi

/usr/local/lsws/bin/lswsctrl restart >/dev/null 2>&1
_rundone "Cấu hình webserver dành cho Woocommerce"
