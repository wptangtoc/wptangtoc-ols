#!/bin/bash
# @author: Gia Tuấn
# @website: https://wptangtoc.com
# @email: giatuan@wptangtoc.com
# @since: 2025

function huong_dan() {
  Tính năng nhân bản website [website cloning/duplication] là một công cụ cho phép bạn tạo ra một bản sao y hệt của một website hiện có, bao gồm toàn bộ tệp tin, cơ sở dữ liệu và cấu hình.

  Mục đích: Tạo nhanh một bản sao của website để phục vụ nhiều mục đích khác nhau mà không ảnh hưởng đến website gốc đang hoạt động.

  Lợi ích:
  * Tiết kiệm thời gian và công sức: Không cần xây dựng lại website từ đầu.
  * Giảm thiểu rủi ro: An toàn thử nghiệm thay đổi trên bản sao.
  * Linh hoạt: Dễ dàng tạo nhiều phiên bản website cho các mục đích khác nhau.

  Đây là một tính năng rất hữu ích quản lý máy chủ.
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null # Nạp thư viện UI Xác nhận

export LANG=en_US.UTF-8
export LC_ALL=en_US.UTF-8

NAME=$1
NAME2=$2

if [[ $NAME == "98" ]]; then
  NAME=""
fi

if [[ "$1" == '98' ]]; then
  WPTT_IN_MENU="yes"
  WPTT_MENU_BACK="/usr/bin/wptangtoc 1"
fi

clear
echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}Nhân bản (Clone) Website${C_RESET}"
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

# ==============================================================================
# 1. CHỌN WEBSITE NGUỒN
# ==============================================================================
if [[ -z "$NAME" ]]; then
  . /etc/wptt/tenmien
  lua_chon_NAME "Chọn Website NGUỒN để nhân bản"
fi

[[ "$NAME" == "0" || -z "$NAME" ]] && exec /usr/bin/wptangtoc 1

pathcheck="/etc/wptt/vhost/.$NAME.conf"
if [[ ! -f "$pathcheck" ]]; then
  echo -e "\n${C_RED}❌ Tên miền không tồn tại trên hệ thống này!${C_RESET}"
  sleep 3
  exec /usr/bin/wptangtoc 1
fi

NAME_NGUON=$(echo "$NAME")
NAME=$(echo "$NAME" | tr '[:upper:]' '[:lower:]')

# ==============================================================================
# 2. NHẬP WEBSITE ĐÍCH VÀ KIỂM TRA ĐỊNH DẠNG
# ==============================================================================
if [[ -z "$2" ]]; then
  stty iutf8
  echo ""
  echo -e "Website Nguồn: ${C_GREEN}$NAME_NGUON${C_RESET}"
  echo -e "${C_YELLOW}Ví dụ web đích: clone.wptangtoc.com, shop.vn...${C_RESET}"
  echo -en "${C_CYAN}Nhập Tên miền MỚI (Website Đích) [0=Thoát]: ${C_RESET}"
  read -r NAME2
fi

if [[ -z "$NAME2" || "$NAME2" == "0" ]]; then
  [[ "${1:-}" == "98" ]] && exec /usr/bin/wptangtoc 1
  return 2>/dev/null || exit
fi

# Kiểm tra Regex chuẩn
if [[ ! "$NAME2" =~ ^[a-z0-9]+([a-z0-9.-]*[a-z0-9]+)?\.[a-z]{2,}$ ]]; then
  echo -e "\n${C_RED}❌ Lỗi: Tên miền đích chứa ký tự không hợp lệ hoặc sai cấu trúc!${C_RESET}"
  [[ "${1:-}" == "98" ]] && {
    read -r -p "Bấm phím Enter để quay lại Menu... " dummy
    exec /usr/bin/wptangtoc 1
  }
  return 2>/dev/null || exit 1
fi

# Chuyển domain punycode
NAME2=$(php /etc/wptt/domain/punycode.php "$NAME2" 2>/dev/null)
if [[ -z "$NAME2" ]]; then
  echo -e "\n${C_RED}❌ Lỗi: Xử lý Punycode thất bại. Không thể thêm website $NAME2${C_RESET}"
  [[ "${1:-}" == "98" ]] && exec /usr/bin/wptangtoc 1
  return 2>/dev/null || exit
fi

# Loại bỏ toàn bộ khoảng trắng và ép chữ thường
NAME2="${NAME2//[[:space:]]/}"
NAME2=$(echo "$NAME2" | tr '[:upper:]' '[:lower:]')

if [[ "$NAME2" == "${NAME2/./}" ]]; then
  echo -e "\n${C_RED}❌ Lỗi: Tên miền nhập không đúng định dạng (thiếu dấu chấm)!${C_RESET}"
  [[ "${1:-}" == "98" ]] && exec /usr/bin/wptangtoc 1
  return 2>/dev/null || exit
fi

# ==============================================================================
# 3. KIỂM TRA DỊCH VỤ VÀ TỒN TẠI WEBSITE
# ==============================================================================
wptt_check_mariadb || wptt_die "MariaDB đang bị sập! Hệ thống từ chối sao chép website."
wptt_check_lsws || wptt_die "OpenLiteSpeed đang bị sập! Hệ thống từ chối sao chép website."

path2="/etc/wptt/vhost/.$NAME2.conf"
if [[ -f "$path2" ]]; then
  echo -e "\n${C_YELLOW}CẢNH BÁO QUAN TRỌNG:${C_RESET}"
  echo -e "Tên miền đích (${C_BOLD_WHITE}$NAME2${C_RESET}) đã tồn tại trên hệ thống!"
  echo -e "Nếu tiếp tục, ${C_RED}TOÀN BỘ DỮ LIỆU HIỆN TẠI${C_RESET} của $NAME2 sẽ bị XÓA SẠCH để nhường chỗ cho bản Clone.\n"

  if wptt_xac_nhan "Bạn có chắc chắn muốn GHI ĐÈ $NAME lên $NAME2 không?" "${C_BOLD_WHITE}Nguồn:${C_RESET} $NAME" "${C_BOLD_WHITE}Đích :${C_RESET} $NAME2" "Đồng ý XÓA VÀ GHI ĐÈ" "Hủy bỏ"; then
    echo ""
    website_nhan_ban_nguon="$NAME"
    website_nhan_ban_dich="$NAME2"

    # Thực hiện xóa website đích cũ
    . /etc/wptt/domain/wptt-xoa-website "$NAME2" 'nhan-ban'

    # Trả lại biến
    NAME="$website_nhan_ban_nguon"
    NAME2="$website_nhan_ban_dich"
    unset website_nhan_ban_dich website_nhan_ban_nguon
  else
    echo -e "${C_YELLOW}Đã hủy thao tác nhân bản.${C_RESET}"
    sleep 2
    [[ "${1:-}" == "98" ]] && exec /usr/bin/wptangtoc 1
    return 2>/dev/null || exit
  fi
fi

# ==============================================================================
# 4. CHUẨN BỊ MÔI TRƯỜNG & KHỞI TẠO USER
# ==============================================================================
if [[ $(echo "$NAME2" | grep '://') ]]; then NAME2=$(echo "$NAME2" | cut -f3 -d '/'); fi
if [[ $(echo "$NAME2" | grep '^www\.') ]]; then NAME2=$(echo "$NAME2" | sed 's/^www.//g'); fi

USER=${NAME2//[-._]/wp}

. /etc/wptt/.wptt.conf

work_cpucore='1024'
cpucore=$(grep -c ^processor /proc/cpuinfo)
max_client=$(expr $work_cpucore \* $cpucore \* 2)
max_client_max=$(expr $work_cpucore \* $cpucore \* 3)
max_client_php=$(expr $work_cpucore \* $cpucore \/ 8)
tong_ram_byte=$(awk '/MemTotal/ {print $2}' /proc/meminfo)
rong_ram_mb=$(echo "scale=0;${tong_ram_byte}/1024" | bc)
gioi_han_tien_trinh_bao_loi_503=$(expr $max_client \/ 8)
core_tien_lsphp_child=$(expr $cpucore \* 2)

echo ""
_runing "Đang khởi tạo hệ thống cho $NAME2..."

check_ky_tu=$(echo ${#USER})
if ((check_ky_tu > 32)); then USER=$(echo "$USER" | cut -c 1-30); fi

useradd -p -m -d "/usr/local/lsws/$NAME2" "$USER" >/dev/null 2>&1

if ! id "$USER" &>/dev/null; then
  random=$(openssl rand -base64 32 | tr -dc 'a-zA-Z0-9' | head -c 2)
  USER=${NAME2//[-._]/$random}
  USER=$(echo "$USER" | tr '[:upper:]' '[:lower:]')
  check_ky_tu2=$(echo ${#USER})
  if ((check_ky_tu2 > 32)); then USER=$(echo "$USER" | cut -c 1-30); fi
  useradd -p -m -d "/usr/local/lsws/$NAME2" "$USER" >/dev/null 2>&1
fi

if ! id "$USER" &>/dev/null; then
  _runloi "Khởi tạo hệ thống cho $NAME2"
  echo -e "${C_RED}❌ Lỗi: Hệ điều hành không thể tạo User hệ thống mới!${C_RESET}"
  exec /usr/bin/wptangtoc 1
fi

echo "Sao chép website $NAME sang website $NAME2: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log

# (GIỮ NGUYÊN TOÀN BỘ LOGIC TẠO VHOST CONFIG, SSL TỰ KÝ CỦA BẠN - KHÔNG CHẠM VÀO)
echo "virtualhost $NAME2 {
  vhRoot                  /usr/local/lsws/$NAME2/
  configFile              /usr/local/lsws/conf/vhosts/$NAME2/$NAME2.conf
  allowSymbolLink         1
  enableScript            1
  restrained              1
  maxKeepAliveReq         1000
  setUIDMode              2
  user                    $USER
  group                   $USER
}" >>/usr/local/lsws/conf/httpd_config.conf
sed -i "/listener http/a map 		$NAME2 $NAME2" /usr/local/lsws/conf/httpd_config.conf
mkdir "/usr/local/lsws/conf/vhosts/$NAME2/"
touch "/usr/local/lsws/conf/vhosts/$NAME2/$NAME2.conf"
NAMEPHP=${NAME2//[-._]/}
echo "docRoot                   /usr/local/lsws/$NAME2/html
vhDomain                  $NAME2
enableGzip                1
cgroups                   0


index  {
  useServer               0
  indexFiles              index.html index.php
  autoIndex               0
}

scripthandler  {
  add                     lsapi:$NAMEPHP php
}

accessControl  {
  allow                   *
}

lsrecaptcha  {
  enabled                 1
  type                    0
}

namespace                 2

extprocessor $NAMEPHP {
  type                    lsapi
  address                 uds://tmp/lshttpd/$NAMEPHP.sock
  maxConns                $core_tien_lsphp_child
  env                     PHP_LSAPI_CHILDREN=$core_tien_lsphp_child
  env                     LSAPI_ACCEPT_NOTIFY=1
  env                     LSAPI_MAX_CMD_SCRIPT_PATH_LEN=200
  env                     LSAPI_AVOID_FORK=300M
  initTimeout             60
  retryTimeout            0
  pcKeepAliveTimeout      5
  respBuffer              0
  autoStart               1
  path                    /usr/local/lsws/lsphp74/bin/lsphp
  backlog                 100
  instances               1
  extUser                 $USER
  extGroup                $USER
  runOnStartUp            2
  priority                0
  memSoftLimit            2048M
  memHardLimit            2048M
  procSoftLimit           300
  procHardLimit           400
}

context / {
  location                /usr/local/lsws/$NAME2/html
  allowBrowse             1
  extraHeaders            <<<END_extraHeaders
X-XSS-Protection 1;mode=block
X-Frame-Options SAMEORIGIN
Referrer-Policy strict-origin-when-cross-origin
X-Content-Type-Options nosniff
X-Powered-By WPTangTocOLS
permissions-policy accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=()
  END_extraHeaders


  rewrite  {

  }
  addDefaultCharset       off

  phpIniOverride  {

  }
}

rewrite  {
  enable                  1
  autoLoadHtaccess        1
/usr/local/lsws/$NAME2/html/.htaccess
}

vhssl  {
  keyFile                 /etc/wptt-ssl-tu-ky/$NAME2/$NAME2.key
  certFile                /etc/wptt-ssl-tu-ky/$NAME2/cert.crt
  certChain               0
  sslProtocol             24
  renegProtection         1
  sslSessionCache         1
  sslSessionTickets       1
  enableSpdy              15
  enableQuic              1
}


module cache {
checkPrivateCache   1
checkPublicCache    1
maxCacheObjSize     10000000
maxStaleAge         200
qsCache             1
reqCookieCache      1
respCookieCache     1
ignoreReqCacheCtrl  1
ignoreRespCacheCtrl 0
storagePath /usr/local/lsws/$NAME2/luucache
enableCache         0
expireInSeconds     3600
enablePrivateCache  0
privateExpireInSeconds 3600
  ls_enabled              1
}" >/usr/local/lsws/conf/vhosts/"$NAME2"/"$NAME2".conf

mkdir -p /etc/wptt-ssl-tu-ky/"$NAME2"
cd /etc/wptt-ssl-tu-ky/"$NAME2" || exit
openssl req -new -newkey rsa:2048 -nodes -keyout "$NAME2.key" -out "$NAME2.csr" -subj "/C=VN/ST=Hanoi/L=Hanoi/O=wptangtoc ols/OU=IT Department/CN=$NAME2/emailAddress=admin@example.com" >/dev/null 2>&1
openssl x509 -req -in "$NAME2.csr" -signkey "$NAME2.key" -out cert.crt -days 3650 >/dev/null 2>&1

if $(cat /etc/*release | grep -q "Ubuntu"); then
  tuong_thich_nhom_litespeed="nogroup"
else
  tuong_thich_nhom_litespeed="nobody"
fi

chown -R lsadm:$tuong_thich_nhom_litespeed /usr/local/lsws/conf/vhosts/"$NAME2"
chmod -R 750 /usr/local/lsws/conf/vhosts/"$NAME2"

mkdir -p /usr/local/lsws/"$NAME2"
mkdir -p /usr/local/lsws/"$NAME2"/html
mkdir -p /usr/local/lsws/"$NAME2"/backup-website
mkdir -p /usr/local/lsws/"$NAME2"/luucache
chmod 755 /usr/local/lsws/"$NAME2"/
chmod 755 /usr/local/lsws/"$NAME2"/html
chmod 700 /usr/local/lsws/"$NAME2"/backup-website

chown -R "$USER":"$USER" /usr/local/lsws/"$NAME2"/html
chown root:root /usr/local/lsws/"$NAME2"
chmod 755 /usr/local/lsws/"$NAME2"
touch /usr/local/lsws/"$NAME2"/html/.htaccess

echo '# BEGIN WordPress
<IfModule mod_rewrite.c>
RewriteEngine On
RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]
RewriteBase /
RewriteRule ^index\.php$ - [L]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . /index.php [L]
</IfModule>
# END WordPress' >/usr/local/lsws/"$NAME2"/html/.htaccess

_rundone "Khởi tạo hệ thống cho $NAME2 hoàn tất"

# ==============================================================================
# 5. KHỞI TẠO VÀ SAO CHÉP DATABASE (PIPELINE XỊN XÒ)
# ==============================================================================
name_db=${NAME2//[-._]/}
ramdom_db=$(openssl rand -base64 32 | tr -dc 'a-zA-Z0-9' | head -c 18)
database=${name_db}_${ramdom_db}_dbname
username=${name_db}_${ramdom_db}_username
password=$(openssl rand -base64 48 | tr -dc 'a-zA-Z0-9' | head -c 36)

if ((${#database} > 60)); then database=$(echo "$database" | cut -c 1-60); fi
if ((${#username} > 60)); then username=$(echo "$username" | cut -c 1-60); fi

_runing "Đang khởi tạo Database cho website $NAME2..."

TEMP_CNF_ROOT=$(mktemp)
chmod 600 "$TEMP_CNF_ROOT"
cat >"$TEMP_CNF_ROOT" <<EOF
[client]
user=${database_admin_username}
password=${database_admin_password}
host=localhost
max_allowed_packet=1G
default-character-set=utf8mb4

[mysqldump]
quick
quote-names
max_allowed_packet=1G
single-transaction
EOF
trap "rm -f $TEMP_CNF_ROOT" EXIT

mariadb --defaults-extra-file="$TEMP_CNF_ROOT" --ssl-verify-server-cert=false -e "DROP DATABASE IF EXISTS ${database}"
mariadb --defaults-extra-file="$TEMP_CNF_ROOT" --ssl-verify-server-cert=false -e "CREATE DATABASE IF NOT EXISTS ${database}"
mariadb --defaults-extra-file="$TEMP_CNF_ROOT" --ssl-verify-server-cert=false -e "DROP USER IF EXISTS '${username}'@'localhost'"
mariadb --defaults-extra-file="$TEMP_CNF_ROOT" --ssl-verify-server-cert=false -e "CREATE USER IF NOT EXISTS '${username}'@'localhost' IDENTIFIED BY '${password}'"
mariadb --defaults-extra-file="$TEMP_CNF_ROOT" --ssl-verify-server-cert=false -e "GRANT ALL PRIVILEGES ON ${database}.* TO '${username}'@'localhost' WITH GRANT OPTION"
mariadb --defaults-extra-file="$TEMP_CNF_ROOT" --ssl-verify-server-cert=false -e "FLUSH PRIVILEGES"
_rundone "Khởi tạo Database hoàn tất"

_runing "Đang Clone dữ liệu từ $NAME sang $NAME2 (Sẽ mất vài phút)..."
. /etc/wptt/vhost/."$NAME".conf

if [[ -z "$phien_ban_php_domain" ]]; then
  phien_ban_php_domain=$(php -v | grep cli | grep -oP 'PHP \K[0-9]+\.[0-9]+')
fi
php_ver_chon=${phien_ban_php_domain//[-._]/}
sed -E -i "s/lsphp[0-9]+/lsphp$php_ver_chon/g" /usr/local/lsws/conf/vhosts/$NAME2/$NAME2.conf

. /etc/wptt/php/php-cli-domain-config "$NAME"
PHP_EXEC="/usr/local/lsws/lsphp${phien_ban_php_domain_thuc_thi:-$php_ver_chon}/bin/php"

IS_SQLITE_SOURCE=0
if [[ -f "/usr/local/lsws/$NAME/html/wp-content/db.php" ]] && grep -q -i "sqlite" "/usr/local/lsws/$NAME/html/wp-content/db.php"; then
  IS_SQLITE_SOURCE=1
fi

mkdir -p "/usr/local/lsws/database"
INIT_SQL="SET FOREIGN_KEY_CHECKS=0; SET UNIQUE_CHECKS=0; SET AUTOCOMMIT=0;"
END_SQL="COMMIT; SET FOREIGN_KEY_CHECKS=1; SET UNIQUE_CHECKS=1; SET AUTOCOMMIT=1;"

(
  echo "$INIT_SQL"
  mariadb-dump --defaults-extra-file="$TEMP_CNF_ROOT" "$DB_Name_web" --ssl-verify-server-cert=false
  echo "$END_SQL"
) | mariadb --defaults-extra-file="$TEMP_CNF_ROOT" "$database" --ssl-verify-server-cert=false

rm -rf "$TEMP_CNF_ROOT"

# ==============================================================================
# 6. COPY MÃ NGUỒN VÀ SEARCH & REPLACE
# ==============================================================================
duong_dan_nguon_cu="/usr/local/lsws/$NAME/html"
duong_dan_nguon_moi21="/usr/local/lsws/$NAME2"
duong_dan_nguon_moi="/usr/local/lsws/$NAME2/html"

cp -r "$duong_dan_nguon_cu" "$duong_dan_nguon_moi21"
chown -R "$USER:$USER" "$duong_dan_nguon_moi"
find "$duong_dan_nguon_moi" -type d -print0 | xargs -0 chmod 755
find "$duong_dan_nguon_moi" -type f -print0 | xargs -0 chmod 644

if [[ $IS_SQLITE_SOURCE -eq 1 ]]; then
  chmod 755 "$duong_dan_nguon_moi/wp-content/database"
  chown -R "$USER:$USER" "$duong_dan_nguon_moi/wp-content/database"
fi

if [[ $(lsattr /usr/local/lsws/$NAME2/html/wp-config.php | cut -f1 -d ' ' | grep 'i') ]]; then
  . /etc/wptt/bao-mat/wptt-chattr-file-lock "$NAME2" off
  find /usr/local/lsws/"$NAME2"/html -type f -print0 | xargs -0 chmod 644
  find /usr/local/lsws/"$NAME2"/html -type d -print0 | xargs -0 chmod 755
fi

/usr/local/bin/wp config set DB_HOST 'localhost' --type=constant --allow-root --path="/usr/local/lsws/$NAME2/html" --quiet
/usr/local/bin/wp config set DB_NAME "$database" --type=constant --allow-root --path="/usr/local/lsws/$NAME2/html" --quiet
/usr/local/bin/wp config set DB_USER "$username" --type=constant --allow-root --path="/usr/local/lsws/$NAME2/html" --quiet
/usr/local/bin/wp config set DB_PASSWORD "$password" --type=constant --allow-root --path="/usr/local/lsws/$NAME2/html" --quiet

cd /usr/local/lsws/"$NAME2"/html/ || exit 1

$PHP_EXEC /usr/local/bin/wp config shuffle-salts WP_CACHE_KEY_SALT --force --path=/usr/local/lsws/$NAME2/html --allow-root >/dev/null 2>&1
for line_num in $(grep -n "define( 'WP_CACHE_KEY_SALT'" /usr/local/lsws/$NAME2/html/wp-config.php | head -n -1 | cut -d: -f1 | tac); do sed -i "${line_num}d" /usr/local/lsws/$NAME2/html/wp-config.php; done
if [[ $(cat /usr/local/lsws/$NAME2/html/wp-config.php | grep WP_CACHE_KEY_SALT) == '' ]]; then
  sed -i "/define( 'WP_CACHE_KEY_SALT'/d" /usr/local/lsws/$NAME2/html/wp-config.php && sed -i "/^define( 'NONCE_SALT'/a define( 'WP_CACHE_KEY_SALT', '$NAME2' );" /usr/local/lsws/$NAME2/html/wp-config.php
  $PHP_EXEC /usr/local/bin/wp config shuffle-salts WP_CACHE_KEY_SALT --force --path=/usr/local/lsws/$NAME2/html --allow-root >/dev/null 2>&1
  for line_num in $(grep -n "define( 'WP_CACHE_KEY_SALT'" /usr/local/lsws/$NAME2/html/wp-config.php | head -n -1 | cut -d: -f1 | tac); do sed -i "${line_num}d" /usr/local/lsws/$NAME2/html/wp-config.php; done
fi

if [[ $IS_SQLITE_SOURCE -eq 1 ]]; then
  mv "$duong_dan_nguon_moi/wp-content/db.php" "$duong_dan_nguon_moi/wp-content/db.php.bak" 2>/dev/null
fi

$PHP_EXEC /usr/local/bin/wp search-replace "//${NAME}" "//${NAME2}" --path="$duong_dan_nguon_moi" --allow-root --all-tables >/dev/null 2>&1
$PHP_EXEC /usr/local/bin/wp search-replace "/usr/local/lsws/${NAME}/html" "/usr/local/lsws/${NAME2}/html" --path="$duong_dan_nguon_moi" --allow-root --all-tables >/dev/null 2>&1

if [[ $IS_SQLITE_SOURCE -eq 1 ]]; then
  mv "$duong_dan_nguon_moi/wp-content/db.php.bak" "$duong_dan_nguon_moi/wp-content/db.php" 2>/dev/null
  chown "$USER:$USER" "$duong_dan_nguon_moi/wp-content/db.php"

  /usr/local/bin/wp config set WP_SQLITE_AST_DRIVER true --raw --type=constant --allow-root --path="$duong_dan_nguon_moi" --quiet
  /usr/local/bin/wp config set DB_ENGINE "'sqlite'" --raw --type=constant --allow-root --path="$duong_dan_nguon_moi" --quiet

  $PHP_EXEC /usr/local/bin/wp search-replace "//${NAME}" "//${NAME2}" --path="$duong_dan_nguon_moi" --allow-root --all-tables >/dev/null 2>&1
  $PHP_EXEC /usr/local/bin/wp search-replace "/usr/local/lsws/${NAME}/html" "/usr/local/lsws/${NAME2}/html" --path="$duong_dan_nguon_moi" --allow-root --all-tables >/dev/null 2>&1

  if [[ -f "$duong_dan_nguon_moi/wp-content/database/.ht.sqlite" ]]; then
    sqlite3 "$duong_dan_nguon_moi/wp-content/database/.ht.sqlite" "VACUUM;" >/dev/null 2>&1
  fi

  /usr/local/bin/wp config delete WP_SQLITE_AST_DRIVER --type=constant --allow-root --path="$duong_dan_nguon_moi" --quiet 2>/dev/null
  /usr/local/bin/wp config delete DB_ENGINE --type=constant --allow-root --path="$duong_dan_nguon_moi" --quiet 2>/dev/null

  chown -R "$USER:$USER" "$duong_dan_nguon_moi/wp-content/database" 2>/dev/null
