#!/bin/bash
# @author: Gia Tuấn
# @website: https://wptangtoc.com
# @since: 2026

function huong_dan() {
  Tính năng Xem tài khoản đăng nhập phpMyAdmin là khả năng xem danh sách các tài khoản người dùng MySQL/MariaDB đã được tạo trên máy chủ, những tài khoản này có thể được sử dụng để đăng nhập vào phpMyAdmin và quản lý cơ sở dữ liệu và tài khoản bảo mật 2 lớp để truy cập vào trình PhpMyAdmin

  Mục Đích Chính
  * Quản lý người dùng database: Biết được danh sách các user đang có để quản lý quyền truy cập và bảo mật.
  * Xác định user cho từng database: Khi có nhiều database, giúp bạn biết user nào được gán cho database nào.
  * Kiểm tra bảo mật: Rà soát các user hiện có, xóa bỏ những user không cần thiết hoặc có quyền quá rộng.
  * Gỡ lỗi kết nối: Nếu website không kết nối được database, việc kiểm tra lại username là một bước quan trọng.
  * Chuẩn bị thông tin đăng nhập: Biết được username nào có sẵn để sử dụng khi phpMyAdmin yêu cầu đăng nhập.
}

. /etc/wptt/.wptt.conf 2>/dev/null
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh 2>/dev/null
. /etc/wptt/echo-color 2>/dev/null
. /etc/wptt/core-functions 2>/dev/null

clear
echo -e "${C_CYAN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_YELLOW}QUẢN LÝ PHPMYADMIN ➜ $xem_thong_tin_tai_khoan_bao_mat PhpMyAdmin${C_RESET}"
echo -e "${C_CYAN}╰───────────────────────────────────────────────────────────────────────╯\n${C_RESET}"

# ==============================================================================
# KIỂM TRA ĐÃ CÀI ĐẶT PHPMYADMIN CHƯA
# ==============================================================================
if [[ -z "$id_dang_nhap_phpmyadmin" || ! -d "/usr/local/lsws/$Website_chinh/html/phpmyadmin" ]]; then
  echo -e "${C_RED}❌ Bạn chưa kích hoạt PhpMyAdmin trên hệ thống này!${C_RESET}"
  sleep 3
  [[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-phpmyadmin-main 1
  return 2>/dev/null || exit 1
fi

# ==============================================================================
# THIẾT LẬP ĐƯỜNG DẪN TRUY CẬP (CHECK SSL THÔNG MINH)
# ==============================================================================
ssl_xac_thuc_kha_dung="false"
. /etc/wptt/ssl/check-ssl-cert-con-kha-dung "$Website_chinh" >/dev/null 2>&1

if [[ "$ssl_xac_thuc_kha_dung" == "true" ]]; then
  url_truy_cap="https://$Website_chinh/phpmyadmin"
else
  url_truy_cap="http://$Website_chinh/phpmyadmin"
fi

# ==============================================================================
# IN BẢNG THÔNG TIN TÀI KHOẢN (UX BO CONG CĂN LỀ TỰ ĐỘNG)
# ==============================================================================
box_inner_width=${box_inner_width:-71}

echo -e "${C_GREEN}╭───────────────────────────────────────────────────────────────────────╮${C_RESET}"
center_text "${C_BOLD_WHITE}THÔNG TIN TRUY CẬP PHPMYADMIN${C_RESET}"
echo -e "${C_GREEN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"

# Hàm in dòng tự động tính toán khoảng trắng (Fix lỗi Unicode Tiếng Việt)
function in_dong() {
  local raw_text="$1"
  local colored_text="$2"
  local len=$(echo -n "$raw_text" | awk '{print length($0)}')
  local pad=$((box_inner_width - len))
  [[ $pad -lt 0 ]] && pad=0
  echo -e "${C_GREEN}│${C_RESET}${colored_text}$(printf '%*s' "$pad" "")${C_GREEN}│${C_RESET}"
}

in_dong "  Đường dẫn truy cập : $url_truy_cap" "  ${C_BOLD_WHITE}Đường dẫn truy cập :${C_RESET} ${C_CYAN}$url_truy_cap${C_RESET}"

echo -e "${C_GREEN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
in_dong "  LỚP 1: BẢO MẬT MÁY CHỦ (Bắt buộc khi truy cập link)" "  ${C_BOLD_WHITE}LỚP 1: BẢO MẬT MÁY CHỦ (Bắt buộc khi truy cập link)${C_RESET}"
in_dong "  User bảo mật       : $id_dang_nhap_phpmyadmin" "  User bảo mật       : ${C_YELLOW}$id_dang_nhap_phpmyadmin${C_RESET}"
in_dong "  Password           : $password_dang_nhap_phpmyadmin" "  Password           : ${C_YELLOW}$password_dang_nhap_phpmyadmin${C_RESET}"

echo -e "${C_GREEN}├───────────────────────────────────────────────────────────────────────┤${C_RESET}"
in_dong "  LỚP 2: TÀI KHOẢN DATABASE (MariaDB) CỦA CÁC WEBSITE" "  ${C_BOLD_WHITE}LỚP 2: TÀI KHOẢN DATABASE (MariaDB) CỦA CÁC WEBSITE${C_RESET}"

for filepath in /etc/wptt/vhost/.*.conf; do
  [[ ! -f "$filepath" || "$filepath" == *"/..conf" ]] && continue

  domain="${filepath##*/}"
  domain="${domain%.conf}"
  domain="${domain#.}"
  path_html="/usr/local/lsws/$domain/html"

  if [[ -d "$path_html" ]]; then
    DB_User_web=""
    DB_Password_web=""
    . "$filepath"

    in_dong "  ▪ Website  : $domain" "  ${C_BOLD_WHITE}▪ Website  :${C_RESET} ${C_GREEN}$domain${C_RESET}"
    in_dong "    User DB  : ${DB_User_web:-Chưa thiết lập}" "    User DB  : ${C_YELLOW}${DB_User_web:-Chưa thiết lập}${C_RESET}"
    in_dong "    Pass DB  : ${DB_Password_web:-Chưa thiết lập}" "    Pass DB  : ${C_YELLOW}${DB_Password_web:-Chưa thiết lập}${C_RESET}"
    in_dong "  -------------------------------------------------" "  -------------------------------------------------"
  fi
done

echo -e "${C_GREEN}╰───────────────────────────────────────────────────────────────────────╯${C_RESET}\n"

echo "Xem thông tin PhpMyAdmin: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log

echo -en "${C_GREEN}Nhấn phím [Enter] để quay lại Menu...${C_RESET}"
read -r dummy

[[ "${1:-}" == "98" ]] && exec /etc/wptt/wptt-phpmyadmin-main 1
