function huong_dan() {
  Tính năng Kích hoạt phpMyAdmin thường có nghĩa là truy cập và sử dụng công cụ phpMyAdmin, một ứng dụng web phổ biến để quản lý cơ sở dữ liệu MySQL hoặc MariaDB trực tiếp thông qua giao diện đồ họa trên trình duyệt.

  Nói một cách đơn giản, đây là cách bạn mở một cánh cửa có giao diện thân thiện để làm việc với database của website mình, thay vì phải dùng các dòng lệnh phức tạp.

  Mục Đích Chính [Chức năng của phpMyAdmin]
  * Quản lý cơ sở dữ liệu [Database]: Tạo, xóa, sửa đổi database.
  * Quản lý bảng [Table]: Tạo, sửa, xóa bảng quản lý cột, chỉ mục [index].
  * Thao tác dữ liệu: Xem, tìm kiếm, thêm, sửa, xóa các hàng dữ liệu trong bảng.
  * Thực thi lệnh SQL: Cho phép bạn chạy các truy vấn SQL tùy chỉnh.
  * Import/Export dữ liệu: Nhập dữ liệu từ file [SQL, CSV] vào database hoặc xuất database/bảng ra các định dạng khác nhau [quan trọng cho việc sao lưu và di chuyển].
  * Quản lý người dùng database: Tạo và quản lý quyền của người dùng truy cập database [nếu có đủ quyền].

  Sau khi kích hoạt [truy cập], bạn có thể bắt đầu quản lý cơ sở dữ liệu của website một cách trực quan.
}

. /etc/wptt/.wptt.conf
[[ -z "$ngon_ngu" ]] && ngon_ngu='vi'
. /etc/wptt/lang/$ngon_ngu.sh
. /etc/wptt/echo-color

echo -e "\n\n\n========================================================================="
echo -e "| $quan_ly_phpmyadmin => $bat PhpMyAdmin                              |"
echo -e "=========================================================================\n"

if [[ -n "$id_dang_nhap_phpmyadmin" && -d "/usr/local/lsws/$Website_chinh/html/phpmyadmin" ]]; then
  echoDo "$ban_da_kich_hoat PhpMyadmin $truoc_do_roi"
  sleep 3
  exec /etc/wptt/wptt-phpmyadmin-main 1
  exit
fi

echo '                                                .               
                                               ::               
                                               *. ::            
                                     -        +* *:           
                                    =+       :#+   =#-          
                                   .#-      .##= : -##=         
                                   *#:      *##= =-:#*#+        
                                  -##:     +###- .#+*###*.      
                                 .##*.    +####:  *#++###*:     
                                 *##* +####*.  *##=:=***=    
                                =###+   +#####*.  *###+  .:=:   
                               :####= :#######+   ***+*=        
                               +**++: --:::::::...-------:..    
        ::         --.  --     :.:--:-:---=--=======+==:        
  ----..==-: ---- =#*..*#+:= :=-+*+*=-+++*+-*+*+++-++-+-=:      
 :=.:=-=:.+:-=.-=-*-*+++*.*- *--*+=#-=*.-*:*--*.++-*:*-.*-      
.==--.:- :-:=--- == +=.+::*+*+==  .+--+=+:-= +:.+.+:-= -=       
:-         -:            --=-                                   
                                                                
'

# ==============================================================================
# KHAI BÁO BIẾN DÙNG CHUNG (DRY PRINCIPLE)
# ==============================================================================
phpmyadmin_version="5.2.3"

if grep -qi "ubuntu" /etc/os-release 2>/dev/null; then
  tuong_thich_nhom_litespeed="nogroup"
else
  tuong_thich_nhom_litespeed="nobody"
fi

if [[ -f "/usr/local/lsws/admin/fcgi-bin/admin_php" ]]; then
  PHP_Command="/usr/local/lsws/admin/fcgi-bin/admin_php"
else
  PHP_Command="/usr/local/lsws/admin/fcgi-bin/admin_php5"
fi

# ==============================================================================
# TẢI VÀ GIẢI NÉN PHPMYADMIN
# ==============================================================================
_runing "$cai PhpMyadmin $phpmyadmin_version"
cd "/usr/local/lsws/$Website_chinh/html" || exit 1

wget -P "/usr/local/lsws/$Website_chinh/html" "https://files.phpmyadmin.net/phpMyAdmin/$phpmyadmin_version/phpMyAdmin-$phpmyadmin_version-all-languages.zip" >/dev/null 2>&1

if [[ ! -f "/usr/local/lsws/$Website_chinh/html/phpMyAdmin-$phpmyadmin_version-all-languages.zip" ]]; then
  wget -P "/usr/local/lsws/$Website_chinh/html" "https://files.phpmyadmin.net/phpMyAdmin/$phpmyadmin_version/phpMyAdmin-$phpmyadmin_version-all-languages.zip" --no-check-certificate >/dev/null 2>&1
fi

if [[ ! -f "/usr/local/lsws/$Website_chinh/html/phpMyAdmin-$phpmyadmin_version-all-languages.zip" ]]; then
  git_version="${phpmyadmin_version//./_}"
  wget -O "/usr/local/lsws/$Website_chinh/html/phpMyAdmin-${phpmyadmin_version}-all-languages.zip" "https://github.com/phpmyadmin/phpmyadmin/archive/refs/tags/RELEASE_${git_version}.zip" >/dev/null 2>&1
fi

unzip -q "/usr/local/lsws/$Website_chinh/html/phpMyAdmin-$phpmyadmin_version-all-languages.zip"
mv "/usr/local/lsws/$Website_chinh/html/phpMyAdmin-$phpmyadmin_version-all-languages" "/usr/local/lsws/$Website_chinh/html/phpmyadmin"

if [[ ! -d "/usr/local/lsws/$Website_chinh/html/phpmyadmin" ]]; then
  _runloi "Cài đặt PhpMyadmin $phpmyadmin_version"
  exec /etc/wptt/wptt-phpmyadmin-main 1
fi

rm -f "/usr/local/lsws/$Website_chinh/html/phpMyAdmin-$phpmyadmin_version-all-languages.zip"

cp -f "/usr/local/lsws/$Website_chinh/html/phpmyadmin/config.sample.inc.php" "/usr/local/lsws/$Website_chinh/html/phpmyadmin/config.inc.php"
mkdir -p /usr/local/lsws/phpmyadmin
echo "\$cfg['TempDir'] = '/usr/local/lsws/phpmyadmin';" >>"/usr/local/lsws/$Website_chinh/html/phpmyadmin/config.inc.php"

secret=$(date | md5sum | cut -c '1-32')
sed -i "s/\$cfg\['blowfish_secret'\] = '';/\$cfg\['blowfish_secret'\] = '$secret';/" "/usr/local/lsws/$Website_chinh/html/phpmyadmin/config.inc.php"

chown -R nobody:$tuong_thich_nhom_litespeed /usr/local/lsws/phpmyadmin
chown -R nobody:$tuong_thich_nhom_litespeed "/usr/local/lsws/$Website_chinh/html/phpmyadmin"
chmod 555 /usr/local/lsws/phpmyadmin

# ==============================================================================
# TẠO TÀI KHOẢN BẢO MẬT 2 LỚP (HTTP BASIC AUTH)
# ==============================================================================
mkdir -p "/usr/local/lsws/$Website_chinh/passwd"
Webadmin_Pass=$(openssl rand -base64 48 | tr -dc 'a-zA-Z0-9' | head -c 36)
id_ols_admin=$(openssl rand -base64 32 | tr -dc 'a-zA-Z0-9' | head -c 24)
Encrypt_string=$($PHP_Command -q /usr/local/lsws/admin/misc/htpasswd.php "${Webadmin_Pass}")

echo "$id_ols_admin:$Encrypt_string" >"/usr/local/lsws/$Website_chinh/passwd/.phpmyadmin"

# Dọn dẹp cấu hình cũ và tiêm cấu hình mới vào Vhost bằng SED cực chuẩn
sed -i -e "/^realm ${Website_chinh}phpmyadmin/,/^}/d" "/usr/local/lsws/conf/vhosts/$Website_chinh/$Website_chinh.conf" 2>/dev/null
sed -i -e "/^context \/phpmyadmin\//,/^}/d" "/usr/local/lsws/conf/vhosts/$Website_chinh/$Website_chinh.conf" 2>/dev/null

cat <<EOF >>"/usr/local/lsws/conf/vhosts/$Website_chinh/$Website_chinh.conf"

realm ${Website_chinh}phpmyadmin {
  userDB  {
    location              /usr/local/lsws/$Website_chinh/passwd/.phpmyadmin
  }
}
context /phpmyadmin/ {
  location                phpmyadmin/
  allowBrowse             1
  realm                   ${Website_chinh}phpmyadmin

  accessControl  {
    allow                 ALL
  }

  rewrite  {

  }
  addDefaultCharset       off

  phpIniOverride  {
php_value upload_max_filesize 10G
php_value max_file_uploads 10000
php_value post_max_size 10G
php_value max_execution_time 10000
php_admin_value open_basedir ""
  }
}
EOF

# Cập nhật config panel
sed -i "/id_dang_nhap_phpmyadmin/d" /etc/wptt/.wptt.conf
sed -i "/password_dang_nhap_phpmyadmin/d" /etc/wptt/.wptt.conf
echo "id_dang_nhap_phpmyadmin=$id_ols_admin" >>/etc/wptt/.wptt.conf
echo "password_dang_nhap_phpmyadmin=$Webadmin_Pass" >>/etc/wptt/.wptt.conf

chown nobody:$tuong_thich_nhom_litespeed "/usr/local/lsws/$Website_chinh/passwd/.phpmyadmin"
chmod 400 "/usr/local/lsws/$Website_chinh/passwd/.phpmyadmin"

# ==============================================================================
# TƯƠNG THÍCH TƯỜNG LỬA 8G (ĐÃ FIX LỖI DUPLICATE/IDEMPOTENT)
# ==============================================================================
htaccess_path="/usr/local/lsws/$Website_chinh/html/.htaccess"
if grep -q '#begin-tuong-lua-bao-mat-8g' "$htaccess_path" 2>/dev/null; then
  # Kiểm tra xem Rule Bypass phpMyAdmin đã tồn tại trong file chưa
  if ! grep -q 'phpmyadmin/index\\.php' "$htaccess_path" 2>/dev/null; then
    # Chưa có thì mới tiến hành tiêm cấu hình vào
    sed -i '/RewriteCond %{QUERY_STRING} \^(%2d|-)/i \ \ \ \ RewriteCond %{REQUEST_URI} !^\/phpmyadmin\/index\\.php$ [NC]' "$htaccess_path"
  fi
fi

# ==============================================================================
# RELOAD SERVICE
# ==============================================================================
/usr/local/lsws/bin/lswsctrl reload >/dev/null 2>&1
_rundone "$cai PhpMyadmin $phpmyadmin_version"
echo "Kích hoạt PhpMyAdmin: $(date '+%d-%m-%Y %H:%M')" >>/var/log/wptangtoc-ols.log

# ==============================================================================
# IN THÔNG TIN TÀI KHOẢN (ĐÃ TÍCH HỢP CHECK SSL THÔNG MINH)
# ==============================================================================
echo -e "\n============================================================================="
echo -e "\033[1;32m HOÀN TẤT! HÃY LƯU TRỮ CÁC THÔNG TIN ĐĂNG NHẬP SAU:\033[0m"
echo -e "============================================================================="

ssl_xac_thuc_kha_dung="false"
. /etc/wptt/ssl/check-ssl-cert-con-kha-dung "$Website_chinh" >/dev/null 2>&1

if [[ "$ssl_xac_thuc_kha_dung" == "true" ]]; then
  echo -e "$truy_cap: \033[1;36mhttps://$Website_chinh/phpmyadmin\033[0m"
else
  echo -e "$truy_cap: \033[1;36mhttp://$Website_chinh/phpmyadmin\033[0m"
fi

echo -e "ID $dang_nhap      : \033[1;33m$id_ols_admin\033[0m"
echo -e "Password $dang_nhap: \033[1;33m$Webadmin_Pass\033[0m"
echo "============================================================================="

echo -e "\n\033[1;32m[+] TÀI KHOẢN DATABASE CỦA CÁC WEBSITE:\033[0m"
echo "-------------------------------------------------------------------------"

for filepath in /etc/wptt/vhost/.*.conf; do
  [[ ! -f "$filepath" || "$filepath" == *"/..conf" ]] && continue

  domain="${filepath##*/}"
  domain="${domain%.conf}"
  domain="${domain#.}"
  path_html="/usr/local/lsws/$domain/html"

  if [[ -d "$path_html" ]]; then
    DB_User_web=""
    DB_Password_web=""
    . "$filepath"

    echo -e "Website  : \033[1;32m$domain\033[0m"
    echo -e "Username : \033[1;33m${DB_User_web:-Chưa thiết lập}\033[0m"
    echo -e "Password : \033[1;33m${DB_Password_web:-Chưa thiết lập}\033[0m"
    echo "-------------------------------------------------------------------------"
  fi
done

echo -e "\n(Có thể xem lại tài khoản tại menu: $quan_ly_phpmyadmin => $xem_thong_tin_tai_khoan_bao_mat PhpMyadmin)"
echo -e "=============================================================================\n"

read -p "Nhấn phím [Enter] để quay lại menu..." dummy

[[ ${1:-} == "98" ]] && exec /etc/wptt/wptt-phpmyadmin-main 1
