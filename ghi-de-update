#!/bin/bash
# @author: Gia Tuấn
# @website: https://wptangtoc.com
# @email: giatuan@wptangtoc.com
# @since: 2022

RED='\033[0;31m' # Định nghĩa màu đỏ cho văn bản
NC='\033[0m'      # Đặt lại màu mặc định của terminal

echo -e "${RED}-------------------------------------------------------------------------"
echo "Cài đặt WPTangToc OLS"
echo "-------------------------------------------------------------------------"
echo -e "--------------------------------------------------------------------------${NC}"

# Sử dụng curl thay vì wget để tải file
# Bổ sung kiểm tra quyền truy cập để đảm bảo script có thể thực thi lệnh curl
if ! command -v curl &> /dev/null; then
  echo "curl không được tìm thấy, vui lòng cài đặt curl trước!"
  exit 1
fi

# Sử dụng biến để lưu trữ URL tránh rủi ro lỗi chính tả hoặc bảo mật thông qua việc quote nó
DOWNLOAD_URL="https://wptangtoc.com/share/wptangtoc-ols.zip"

# Thêm -o để chỉ định tên tệp đầu ra, đảm bảo rằng tên tệp không bị ảnh hưởng bởi các ký tự đặc biệt trong URL
curl -sSL -o "wptangtoc-ols.zip" "$DOWNLOAD_URL"

# Kiểm tra xem curl có thực thi thành công hay không
if [ $? -ne 0 ]; then
  echo "Lỗi: Không thể tải xuống tệp từ $DOWNLOAD_URL"
  exit 1
fi

# Giải thích các tham số của curl:
# -s: Tắt chế độ hiển thị tiến trình (silent)
# -S: Hiển thị lỗi (show error)
# -L: Theo dõi chuyển hướng URL
# -O: Lưu tệp với tên gốc từ URL
# -o "wptangtoc-ols.zip": Chỉ định tên tệp đầu ra để tránh rủi ro bảo mật và sự cố do ký tự đặc biệt trong URL

# Thêm kiểm tra quyền truy cập cho tệp zip sau khi tải xuống
if [ ! -f "wptangtoc-ols.zip" ]; then
  echo "Lỗi: Không thể tìm thấy tệp wptangtoc-ols.zip"
  exit 1
fi

# Giải thích thêm:
# Kiểm tra xem tệp có tồn tại hay không sau khi tải xuống, đảm bảo rằng quá trình tải xuống hoàn thành thành công và không bị lỗi đột ngột.

if [[ ! -f wptangtoc-ols.zip ]]; then
  echo "Cập nhật chuyển đổi thất bại" # Báo lỗi nếu không tìm thấy tệp zip
  exit 1 # Thoát khỏi script với mã lỗi
fi

# Sử dụng unzip với tùy chọn -o để ghi đè nếu cần thiết
unzip -oq wptangtoc-ols.zip # Giải nén tệp zip và ẩn thông tin tiến trình, cho phép ghi đè các tệp đã tồn tại

# Thay vì sử dụng cd, tốt hơn là lưu đường dẫn hiện tại và trả về sau khi hoàn thành
current_dir=$(pwd) # Lưu đường dẫn thư mục hiện tại
tool_dir="${current_dir}/tool-wptangtoc-ols" # Định nghĩa đường dẫn tới thư mục chứa công cụ

if [[ ! -d "$tool_dir" ]]; then
  echo "Thư mục cài đặt không tồn tại" # Báo lỗi nếu thư mục không tồn tại
  exit 1 # Thoát khỏi script với mã lỗi
fi

# Sao chép các tệp tin vào /etc/wptt và xóa thư mục tạm thời
cp -rf "$tool_dir/*" /etc/wptt/ # Sao chép tất cả các tệp từ thư mục công cụ sang thư mục đích, cho phép ghi đè
rm -f wptangtoc-ols.zip # Xóa tệp zip đã tải xuống
rm -rf "$tool_dir" # Xóa thư mục tạm thời

# Đảm bảo quyền truy cập phù hợp cho thư mục đích
chmod -R 740 /etc/wptt # Cài đặt quyền truy cập 740 (read, write, execute cho sở hữu; read, execute cho nhóm và người khác) cho thư mục đích

# Sao chép các tệp tin thực thi vào /usr/bin và xóa bản gốc
cp -f /etc/wptt/wptangtoc /usr/bin # Sao chép tệp thực thi wptangtoc sang thư mục bin, cho phép ghi đè
rm -f /etc/wptt/wptangtoc # Xóa bản gốc của tệp thực thi wptangtoc
cp -f /etc/wptt/wptt /usr/bin # Sao chép tệp thực thi wptt sang thư mục bin, cho phép ghi đè
rm -f /etc/wptt/wptt # Xóa bản gốc của tệp thực thi wptt

# Lấy phiên bản hiện tại và cập nhật tệp cấu hình
wptangtocols_version=$(curl -s https://wptangtoc.com/share/version-wptangtoc-ols.txt?force-update) # Lấy phiên bản mới nhất từ URL
sed -i "/version_wptangtoc_ols/d" /etc/wptt/.wptt.conf # Xóa dòng chứa thông tin phiên bản cũ trong tệp cấu hình
echo "version_wptangtoc_ols=$wptangtocols_version" >> /etc/wptt/.wptt.conf # Thêm thông tin phiên bản mới vào tệp cấu hình

# Ghi phiên bản hiện tại vào tệp tạm thời
echo "$wptangtocols_version" > /tmp/wptangtoc-ols-version # Lưu phiên bản mới nhất vào tệp tạm thời

# Xóa tệp ghi chú cập nhật
rm -f ghi-de-update # Xóa tệp ghi chú cập nhật nếu có

# In thông báo hoàn thành cài đặt
echo -e "${RED}-------------------------------------------------------------------------"
echo "Cài đặt WPTangToc OLS $wptangtocols_version" # Thông báo về phiên bản đã cài đặt
echo "-------------------------------------------------------------------------"
echo -e "--------------------------------------------------------------------------${NC}"
